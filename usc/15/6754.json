{"tag":"section","attrib":{"id":"id7a6403f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754"},"text":null,"children":[{"tag":"num","attrib":{"value":"6754"},"text":"§ 6754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6403f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a board of directors of the Association, which shall have authority to govern and supervise all activities of the Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6403f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall have such of the powers and authority of the Association as may be specified in the bylaws of the Association.","children":[{"tag":"ref","attrib":{"idref":"fn002558"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002558"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “such powers and authority as may be specified in the bylaws of the Association.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6403f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6403f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of 13 members who shall be appointed by the President, by and with the advice and consent of the Senate, in accordance with the procedures established under Senate Resolution 116 of the 112th Congress, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6403f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 shall be State insurance commissioners appointed in the manner provided in paragraph (2), 1 of whom shall be designated by the President to serve as the chairperson of the Board until the Board elects one such State insurance commissioner Board member to serve as the chairperson of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6403f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 shall have demonstrated expertise and experience with property and casualty insurance producer licensing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6403f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall have demonstrated expertise and experience with life or health insurance producer licensing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6403fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State insurance regulator representatives","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6403fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before making any appointments pursuant to paragraph (1)(A), the President shall request a list of recommended candidates from the States through the NAIC, which shall not be binding on the President. If the NAIC fails to submit a list of recommendations not later than 15 business days after the date of the request, the President may make the requisite appointments without considering the views of the NAIC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6403fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political affiliation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 4 Board members appointed under paragraph (1)(A) shall belong to the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6403fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former State insurance commissioners","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a6403fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after offering each currently serving State insurance commissioner an appointment to the Board, fewer than 8 State insurance commissioners have accepted appointment to the Board, the President may appoint the remaining State insurance commissioner Board members, as required under paragraph (1)(A), of the appropriate political party as required under subparagraph (B), from among individuals who are former State insurance commissioners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a6403ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A former State insurance commissioner appointed as described in clause (i) may not be employed by or have any present direct or indirect financial interest in any insurer, insurance producer, or other entity in the insurance industry, other than direct or indirect ownership of, or beneficial interest in, an insurance policy or annuity contract written or sold by an insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a640400-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service through term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Board member appointed under paragraph (1)(A) ceases to be a State insurance commissioner during the term of the Board member, the Board member shall cease to be a Board member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640401-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making any appointment pursuant to subparagraph (B) or (C) of paragraph (1), the President may seek recommendations for candidates from groups representing the category of individuals described, which shall not be binding on the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640402-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State insurance commissioner defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “State insurance commissioner” means a person who serves in the position in State government, or on the board, commission, or other body that is the primary insurance regulatory authority for the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640403-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640404-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under paragraph (2), the term of service for each Board member shall be 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640405-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a640406-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1-year terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of service shall be 1 year, as designated by the President at the time of the nomination of the subject Board members for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a640407-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 of the State insurance commissioner Board members initially appointed under paragraph (1)(A),","children":[{"tag":"ref","attrib":{"idref":"fn002559"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002559"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “paragraph (1)(A) of subsection (c),”."}],"tail":" of whom not more than 2 shall belong to the same political party;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a640408-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of the Board members initially appointed under paragraph (1)(B); ","children":[{"tag":"ref","attrib":{"idref":"fn002560"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002560"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “paragraph (1)(B) of subsection (c);”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a640409-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of the Board members initially appointed under paragraph (1)(C).","children":[{"tag":"ref","attrib":{"idref":"fn002561"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002561"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be “paragraph (1)(C) of subsection (c).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a64040a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Board member may continue to serve after the expiration of the term to which the Board member was appointed for the earlier of 2 years or until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a64040b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mid-term appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Board member appointed to fill a vacancy occurring before the expiration of the term for which the predecessor of the Board member was appointed shall be appointed only for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64040c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successive terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Board members may be reappointed to successive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a64040d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointment of initial Board members shall be made no later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-01-12"},"text":"January 12, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a64040e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a64040f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a640410-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the call of the chairperson;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a640411-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as requested in writing to the chairperson by not fewer than 5 Board members; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a640412-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise provided by the bylaws of the Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640413-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of all Board members shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640414-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions of the Board shall require the approval of a majority of all Board members present at a meeting, a quorum being present.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640415-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall hold its first meeting not later than 45 days after the date on which all initial Board members have been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640416-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Board members appointed pursuant to subparagraphs (B) and (C) of subsection (c)(1) shall not have access to confidential information received by the Association in connection with complaints, investigations, or disciplinary proceedings involving insurance producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640417-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics and conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall issue and enforce an ethical conduct code to address permissible and prohibited activities of Board members and Association officers, employees, agents, or consultants. The code shall, at a minimum, include provisions that prohibit any Board member or Association officer, employee, agent or consultant from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640418-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in unethical conduct in the course of performing Association duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640419-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in the making or influencing the making of any Association decision, the outcome of which the Board member, officer, employee, agent, or consultant knows or had reason to know would have a reasonably foreseeable material financial effect, distinguishable from its effect on the public generally, on the person or a member of the immediate family of the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64041a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepting any gift from any person or entity other than the Association that is given because of the position held by the person in the Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64041b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making political contributions to any person or entity on behalf of the Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64041c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobbying or paying a person to lobby on behalf of the Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a64041d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a64041e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no Board member may receive any compensation from the Association or any other person or entity on account of Board membership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64041f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6754/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses and per diem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Board members may be reimbursed only by the Association for travel expenses, including per diem in lieu of subsistence, at rates consistent with rates authorized for employees of Federal agencies under subchapter I of chapter 57 of title 5, while away from home or regular places of business in performance of services for the Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a640420-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s324"},"text":"Pub. L. 106–102, title III, § 324","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/20"},"text":"129 Stat. 20","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a640421-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a640422-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a640423-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Senate Resolution 116 of the 112th Congress, referred to in subsec. (c)(1), which was agreed to ","children":[{"tag":"date","attrib":{"date":"2011-06-29"},"text":"June 29, 2011","children":[],"tail":", provided for expedited Senate consideration of certain nominations subject to advice and consent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a640424-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6756"},"text":"section 6756 of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6754, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s324"},"text":"Pub. L. 106–102, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1424"},"text":"113 Stat. 1424","children":[],"tail":", related to relationship to the Federal Government, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
