{"tag":"section","attrib":{"id":"id7a4753eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804"},"text":null,"children":[{"tag":"num","attrib":{"value":"4804"},"text":"§ 4804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4753ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition and representation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4753ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall consist of 12 members, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4753ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" four members shall be appointed by the President, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4753ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in the labor community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader who has been active in public interest activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a head of a Federal department or agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" four members shall be appointed by the majority leader and the minority leader of the Senate, acting jointly, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4753f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience or background in business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in the labor community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in the academic community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a representative of State or local government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4753f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" four members shall be appointed by the Speaker, the minority leader of the House of Representatives, acting jointly, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4753f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in the labor community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a national leader with experience and background in the academic community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4753fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be a representative of State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the head of a Federal department or agency appointed in accordance with subsection (a)(1)(A)(iv), other Federal officials may participate on an ex-officio basis as requested by the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All members of the Council shall be individuals who have a broad understanding of the United States economy and the United States competitive position internationally.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4753ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 6 members of the Council shall be members of the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475400-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial members of the Council shall be appointed within 30 days after ","children":[{"tag":"date","attrib":{"date":"1990-08-20"},"text":"August 20, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475401-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475402-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy on the Council shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475403-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member appointed to fill a vacancy on the Council occurring before the expiration of the term for which the predecessor of such member was appointed shall be appointed only for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475404-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Council may serve after the expiration of the term of such member until the successor of such member has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475405-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council may be removed only for malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475406-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Council shall not serve as an agent for a foreign principal or a lobbyist for a foreign entity (as the terms “lobbyist” and “foreign entity” are defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602"},"text":"section 1602 of title 2","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475407-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council, while engaged in duties as a member of the Council, shall be paid actual travel expenses, and per diem in lieu of subsistence expenses when away from the usual place of residence of such member, in accordance with subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475408-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475409-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Seven members of the Council constitute a quorum, except that a lesser number may hold hearings if such action is approved by a two-thirds vote of the entire Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47540a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall not commence its duties until all the nongovernmental members have been appointed and have qualified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47540b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall elect, by a two-thirds vote of the entire Council, a chairperson from among the nongovernmental members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47540c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the call of the chairperson or a majority of the members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47540d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (g), no action establishing policy shall be taken by the Council unless approved by two-thirds of the entire membership of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a47540e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a47540f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Council shall designate one alternate representative to attend any meeting that such member is unable to attend.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a475410-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4804/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the course of attending any such meeting, an alternate representative shall be considered a member of the Council for all purposes, except for voting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a475411-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5205"},"text":"Pub. L. 100–418, title V, § 5205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1457"},"text":"102 Stat. 1457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/tI/s133/a"},"text":"Pub. L. 101–382, title I, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/648"},"text":"104 Stat. 648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s12/a"},"text":"Pub. L. 104–65, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/701"},"text":"109 Stat. 701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a475412-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a475413-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a475414-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":", which directed amendment of section “5206(e) of the Competitiveness Policy Council Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4804/e"},"text":"15 U.S.C. 4804(e)","children":[],"tail":")” by inserting “or a lobbyist for a foreign entity (as the terms ‘lobbyist’ and ‘foreign entity’ are defined under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602"},"text":"section 1602 of title 2","children":[],"tail":")” after “an agent for a foreign principal”, was executed to section 5205(e) of such Act, which is subsec. (e) of this section, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s133/a/1"},"text":"Pub. L. 101–382, § 133(a)(1)","children":[],"tail":", substituted reference to "},{"tag":"date","attrib":{"date":"1990-08-20"},"text":"Aug. 20, 1990","children":[],"tail":", for reference to "},{"tag":"date","attrib":{"date":"1989-01-21"},"text":"Jan. 21, 1989","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s133/a/2"},"text":"Pub. L. 101–382, § 133(a)(2)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) A member of the Council may not serve as an agent for a foreign principal.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Members of the Council shall be required to file a financial disclosure report under title II of the Ethics in Government Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521"},"text":"Public Law 95–521","children":[],"tail":"), except that such reports shall be held confidential and exempt from any law otherwise requiring their public disclosure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Members of the Council shall be deemed to be special Government employees, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of title 18","children":[],"tail":", for purposes of sections 201, 202, 203, 205, and 208 of such title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s133/a/2"},"text":"Pub. L. 101–382, § 133(a)(2)","children":[],"tail":", added subsec. (f) and struck out former subsec. (f) “Compensation” which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Each member of the Council who is not employed by the Federal Government or any State or local government—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) shall be compensated at a rate equal to the daily equivalent of the rate for GS–18 of the General Schedule pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" for each day such member is engaged in duties as a member of the Council; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) shall be paid actual travel expenses, and per diem in lieu of subsistence expenses when away from the usual place of residence of such member, in accordance with section 5703 of such title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Each member of the Council who is employed by the Federal Government or any State or local government shall serve on the Council without additional compensation, but while engaged in duties as a member of the Council shall be paid actual travel expenses, and per diem in lieu of subsistence expenses when away from the usual place of residence of such member, in accordance with subchapter I of chapter 57 of title 5.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/101/382/s133/a/3"},"text":"Pub. L. 101–382, § 133(a)(3)","children":[],"tail":", struck out subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") which read as follows: “The Council may procure temporary and intermittent services under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", but at rates for individuals not to exceed the daily equivalent of the maximum annual rate of basic pay for GS–16 of the General Schedule.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/382/s133/a/3"},"text":"Pub. L. 101–382, § 133(a)(3)","children":[],"tail":", struck out subsec. (m) which read as follows: “Upon request of the Council, the head of any other Federal agency is authorized to detail, on a reimbursable basis, any of the personnel of such agency to the Council to assist the Council in carrying out its duties under this chapter.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a475415-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a475416-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
