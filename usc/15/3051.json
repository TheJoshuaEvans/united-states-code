{"tag":"section","attrib":{"id":"id7a12d6ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051"},"text":null,"children":[{"tag":"num","attrib":{"value":"3051"},"text":"§ 3051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d6ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Authority” means the Horseracing Integrity and Safety Authority designated by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3052/a"},"text":"section 3052(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breeder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “breeder” means a person who is in the business of breeding covered horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered horse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered horse” means any Thoroughbred horse, or any other horse made subject to this chapter by election of the applicable State racing commission or the breed governing organization for such horse under section 3054(k) ","children":[{"tag":"ref","attrib":{"idref":"fn002477"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002477"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 3054("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")”."}],"tail":" of this title, during the period—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d6b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date of the horse’s first timed and reported workout at a racetrack that participates in covered horseraces or at a training facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d6b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date on which the Authority receives written notice that the horse has been retired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered horserace","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered horserace” means any horserace involving covered horses that has a substantial relation to interstate commerce, including any Thoroughbred horserace that is the subject of interstate off-track or advance deposit wagers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered persons” means all trainers, owners, breeders, jockeys, racetracks, veterinarians, persons (legal and natural) licensed by a State racing commission and the agents, assigns, and employees of such persons and other horse support personnel who are engaged in the care, training, or racing of covered horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equine constituencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “equine constituencies” means, collectively, owners, breeders, trainers, racetracks, veterinarians, State racing commissions, and jockeys who are engaged in the care, training, or racing of covered horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equine industry representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “equine industry representative” means an organization regularly and significantly engaged in the equine industry, including organizations that represent the interests of, and whose membership consists of, owners, breeders, trainers, racetracks, veterinarians, State racing commissions, and jockeys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Horseracing anti-doping and medication control program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “horseracing anti-doping and medication control program” means the anti-doping and medication program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3055/a"},"text":"section 3055(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate family member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “immediate family member” shall include a spouse, domestic partner, mother, father, aunt, uncle, sibling, or child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate off-track wager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interstate off-track wager” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3002"},"text":"section 3002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jockey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “jockey” means a rider or driver of a covered horse in covered horseraces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “owner” means a person who holds an ownership interest in one or more covered horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program effective date” means ","children":[{"tag":"date","attrib":{"date":"2022-07-01"},"text":"July 1, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racetrack","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “racetrack” means an organization licensed by a State racing commission to conduct covered horseraces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racetrack safety program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “racetrack safety program” means the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3056/a"},"text":"section 3056(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stakes race","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “stakes race” means any race so designated by the racetrack at which such race is run, including, without limitation, the races comprising the Breeders’ Cup World Championships and the races designated as graded stakes by the American Graded Stakes Committee of the Thoroughbred Owners and Breeders Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State racing commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State racing commission” means an entity designated by State law or regulation that has jurisdiction over the conduct of horseracing within the applicable State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trainer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trainer” means an individual engaged in the training of covered horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “training facility” means a location that is not a racetrack licensed by a State racing commission that operates primarily to house covered horses and conduct official timed workouts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterinarian","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veterinarian” means a licensed veterinarian who provides veterinary services to covered horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d6c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3051/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workout","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “workout” means a timed running of a horse over a predetermined distance not associated with a race or its first qualifying race, if such race is made subject to this chapter by election under section 3054(k) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title of the horse’s breed governing organization or the applicable State racing commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12d6c5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1202"},"text":"Pub. L. 116–260, div. FF, title XII, § 1202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3252"},"text":"134 Stat. 3252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a12d6c6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a12d6c7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a12d6c8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” and was translated as reading “this title”, meaning title XII of div. FF of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a12d6c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a12d6ca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1201"},"text":"Pub. L. 116–260, div. FF, title XII, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3252"},"text":"134 Stat. 3252","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dFF/tXII/s1201"},"text":"“This title [enacting this chapter] may be cited as the ‘Horseracing Integrity and Safety Act of 2020’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
