{"tag":"section","attrib":{"id":"id783abaf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"78q–2"},"text":"§ 78q–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated quotation systems for penny stocks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id783abaf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783abaf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the market for penny stocks suffers from a lack of reliable and accurate quotation and last sale information available to investors and regulators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783abaf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest and appropriate for the protection of investors and the maintenance of fair and orderly markets to improve significantly the information available to brokers, dealers, investors, and regulators with respect to quotations for and transactions in penny stocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783abaf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fully implemented automated quotation system for penny stocks would meet the information needs of investors and market participants and would add visibility and regulatory and surveillance data to that market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783abaf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandate to facilitate establishment of automated quotation systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id783abaf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall facilitate the widespread dissemination of reliable and accurate last sale and quotation information with respect to penny stocks in accordance with the findings set forth in subsection (a), with a view toward establishing, at the earliest feasible time, one or more automated quotation systems that will collect and disseminate information regarding all penny stocks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783abaf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Characteristics of systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such automated quotation system shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id783abaf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be operated by a registered securities association or a national securities exchange in accordance with such rules as the Commission and these entities shall prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id783abaf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate quotation and transaction information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id783abafa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (c), provide bid and ask quotations of participating brokers or dealers, or comparably accurate and reliable pricing information, which shall constitute firm bids or offers for at least such minimum numbers of shares or minimum dollar amounts as the Commission and the registered securities association or national securities exchange shall require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id783abafb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the reporting of the volume of penny stock transactions, including last sale reporting, when the volume reaches appropriate levels that the Commission shall specify by rule or order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783abafc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptive authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, by rule or order, grant such exemptions, in whole or in part, conditionally or unconditionally, to any penny stock or class of penny stocks from the requirements of subsection (b) as the Commission determines to be consistent with the public interest, the protection of investors, and the maintenance of fair and orderly markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id783abafd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission reporting requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall, in each of the first 5 annual reports (under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78w/b/1"},"text":"section 78w(b)(1) of this title","children":[],"tail":") submitted more than 12 months after "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"October 15, 1990","children":[],"tail":", include a description of the status of the penny stock automated quotation system or systems required by subsection (b). Such description shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id783abafe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the development, implementation, and progress of the project, including achievement of significant milestones and current project schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id783abaff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78q–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the activities of registered securities associations and national securities exchanges in the development of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id783abb00-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 17B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/429/tV/s506"},"text":"Pub. L. 101–429, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/955"},"text":"104 Stat. 955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id783abb01-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id783abb02-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id783abb03-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78w/b/1"},"text":"Section 78w(b)(1) of this title","children":[],"tail":", referred to in subsec. (d), was omitted from the Code. For further details related to reports referred to in subsec. (d), see Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78w"},"text":"section 78w of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id783abb04-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id783abb05-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", with provisions relating to civil penalties and accounting and disgorgement, see section 1(c)(1), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/429"},"text":"Pub. L. 101–429","children":[],"tail":", set out in an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77g"},"text":"section 77g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
