{"tag":"section","attrib":{"id":"id7a9f8611-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051"},"text":null,"children":[{"tag":"num","attrib":{"value":"9051"},"text":"§ 9051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary relief from troubled debt restructurings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9f8612-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8613-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “applicable period” means the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":" and ending on the earlier of "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":", or the date that is 60 days after the date on which the national emergency concerning the novel coronavirus disease (COVID–19) outbreak declared by the President on "},{"tag":"date","attrib":{"date":"2020-03-13"},"text":"March 13, 2020","children":[],"tail":" under the National Emergencies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.) terminates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8614-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate federal banking agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Federal banking agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f8615-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f8616-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the National Credit Union Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f8617-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8618-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the applicable period, a financial institution, including an insurance company, may elect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f8619-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend the requirements under United States generally accepted accounting principles for loan modifications related to the coronavirus disease 2019 (COVID–19) pandemic that would otherwise be categorized as a troubled debt restructuring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f861a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend any determination of a loan modified as a result of the effects of the coronavirus disease 2019 (COVID–19) pandemic as being a troubled debt restructuring, including impairment for accounting purposes under United States Generally Accepted Accounting Principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f861b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any suspension under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9f861c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be applicable for the term of the loan modification, but solely with respect to any modification, including a forbearance arrangement, an interest rate modification, a repayment plan, and any other similar arrangement that defers or delays the payment of principal or interest, that occurs during the applicable period for a loan that was not more than 30 days past due as of ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9f861d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not apply to any adverse impact on the credit of a borrower that is not related to the coronavirus disease 2019 (COVID–19) pandemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f861e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate Federal banking agency of the financial institution, including an insurance company, shall defer to the determination of the financial institution, including an insurance company, to make a suspension under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9f861f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For modified loans for which suspensions under subsection (a) apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9f8620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial institutions, including insurance companies, should continue to maintain records of the volume of loans involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9f8621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9051/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate Federal banking agencies may collect data about such loans for supervisory purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9f8622-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4013"},"text":"Pub. L. 116–136, div. A, title IV, § 4013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/480"},"text":"134 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tV/s541"},"text":"Pub. L. 116–260, div. N, title V, § 541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2090"},"text":"134 Stat. 2090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9f8623-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9f8624-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9f8625-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", which is classified principally to chapter 34 (§ 1601 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9f8626-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s541/2"},"text":"Pub. L. 116–260, § 541(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s541/1"},"text":"Pub. L. 116–260, § 541(1)","children":[],"tail":", inserted “, including an insurance company,” after “financial institution” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s541/3"},"text":"Pub. L. 116–260, § 541(3)","children":[],"tail":", inserted “under United States Generally Accepted Accounting Principles” after “accounting purposes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s541/1"},"text":"Pub. L. 116–260, § 541(1)","children":[],"tail":", inserted “, including an insurance company,” after “financial institution” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s541/4"},"text":"Pub. L. 116–260, § 541(4)","children":[],"tail":", inserted “, including insurance companies,” after “financial institutions”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
