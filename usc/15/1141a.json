{"tag":"section","attrib":{"id":"id7964bba7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1141a"},"text":"§ 1141a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International applications based on United States applications or registrations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7964bba8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The owner of a basic application pending before the United States Patent and Trademark Office, or the owner of a basic registration granted by the United States Patent and Trademark Office may file an international application by submitting to the United States Patent and Trademark Office a written application in such form, together with such fees, as may be prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7964bba9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified owners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified owner, under subsection (a), shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7964bbaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a national of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bbab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be domiciled in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bbac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a real and effective industrial or commercial establishment in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7964bbad-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title XII, § 61, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13402"},"text":"Pub. L. 107–273, div. C, title III, § 13402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1915"},"text":"116 Stat. 1915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
