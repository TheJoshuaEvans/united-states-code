{"tag":"section","attrib":{"id":"id7a475490-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4905"},"text":null,"children":[{"tag":"num","attrib":{"value":"4905"},"text":"§ 4905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation among executive agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each executive agency shall furnish to the Secretary such information for inclusion in the National Trade Data Bank as the Secretary, in consultation with the Advisory Committee, considers necessary to the operation of the Data Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a475491-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5405"},"text":"Pub. L. 100–418, title V, § 5405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1464"},"text":"102 Stat. 1464","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
