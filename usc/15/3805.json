{"tag":"section","attrib":{"id":"id7a2f866e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805"},"text":null,"children":[{"tag":"num","attrib":{"value":"3805"},"text":"§ 3805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through appropriate agencies and contractors, shall initiate and provide for the conduct of research and development in areas relating to methane-fueled vehicles, including but not limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a2f866f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flammability and combustibility of methane under conditions likely to develop in storage or during vehicular use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8670-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" handling, storage, and distribution of methane for vehicular propulsion purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8671-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive assessment of the relative hazards under identical circumstances of methane, propane, gasoline, and diesel fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8672-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feasibility, economy, and efficiency of technologies for the production and recovery of methane from unconventional and supplemental sources, as provided for in other authorization Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8673-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engine and fuel tank design including, but not limited to, optimum design for dual fuel capacity vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8674-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total vehicle construction and design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8675-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and quantities of emissions, and alterations in or alternatives to emission control systems presently in use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a2f8676-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3805/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overcoming institutional barriers to widespread use including but not limited to restrictions on the transportation of methane for vehicular use through tunnels, and the potential expansion of the distribution of methane for vehicular purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a2f8677-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/512/s6"},"text":"Pub. L. 96–512, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2830"},"text":"94 Stat. 2830","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
