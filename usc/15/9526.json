{"tag":"section","attrib":{"id":"id7ab04fa9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9526"},"text":null,"children":[{"tag":"num","attrib":{"value":"9526"},"text":"§ 9526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the MBDA Business Center Program, the Under Secretary shall widely publicize the MBDA Business Center Program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04faa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9526/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the website of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9526/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" via social media outlets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04fac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9526/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by sharing information relating to the MBDA Business Center Program with community-based organizations, including interpretation groups where necessary, to communicate in the most common languages spoken by the groups served by those organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04fad-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tI/s100116"},"text":"Pub. L. 117–58, div. K, title I, § 100116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1455"},"text":"135 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
