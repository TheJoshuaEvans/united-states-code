<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id7a7960ae-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7461"><num value="7461">§ 7461.</num><heading> Definitions</heading>
<chapeau style="-uslm-lc:I11" class="indent0">In this subchapter:</chapeau><paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id7a7960af-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7461/1"><num value="1" class="bold">(1)</num><heading class="bold"> Director</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Director” means the Director of the National Institute of Standards and Technology.</p>
</content>
</paragraph>
<paragraph style="-uslm-lc:I79" class="indent3 firstIndent-2" id="id7a7960b0-552d-11f1-9071-ff305b7c3ff0" identifier="/us/usc/t15/s7461/2"><num value="2" class="bold">(2)</num><heading class="bold"> Institute</heading><content><p style="-uslm-lc:I12" class="indent1">The term “Institute” means the National Institute of Standards and Technology.</p>
</content>
</paragraph>
<sourceCredit id="id7a7960b1-552d-11f1-9071-ff305b7c3ff0">(<ref href="/us/pl/113/274/tV/s501">Pub. L. 113–274, title V, § 501</ref>, <date date="2014-12-18">Dec. 18, 2014</date>, <ref href="/us/stat/128/2986">128 Stat. 2986</ref>.)</sourceCredit>
</section>
