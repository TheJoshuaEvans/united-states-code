{"tag":"section","attrib":{"id":"id7a36b282-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107"},"text":null,"children":[{"tag":"num","attrib":{"value":"4107"},"text":"§ 4107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Interagency Committee; report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a36b283-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Interagency Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b284-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survey Arctic research conducted by Federal, State, and local agencies, universities, and other public and private institutions to help determine priorities for future Arctic research, including natural resources and materials, physical and biological sciences, and social and behavioral sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b285-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the Commission to develop and establish an integrated national Arctic research policy that will guide Federal agencies in developing and implementing their research programs in the Arctic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b286-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with the Commission on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a36b287-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of the national Arctic research policy and the 5-year plan implementing the policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b288-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arctic research programs of Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b289-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations of the Commission on future Arctic research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b28a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines for Federal agencies for awarding and administering Arctic research grants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b28b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a 5-year plan to implement the national policy, as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4108"},"text":"section 4108 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b28c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the necessary coordination, data, and assistance for the preparation of a single integrated, coherent, and multiagency budget request for Arctic research as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4109"},"text":"section 4109 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b28d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate cooperation between the Federal Government and State and local governments in Arctic research, and recommend the undertaking of neglected areas of research in accordance with the findings and purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b28e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and promote cooperative Arctic scientific research programs with other nations, subject to the foreign policy guidance of the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b28f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the Governor of the State of Alaska in fulfilling its responsibilities under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b290-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote Federal interagency coordination of all Arctic research activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a36b291-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" logistical planning and coordination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b292-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sharing of data and information associated with Arctic research, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b293-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide public notice of its meetings and an opportunity for the public to participate in the development and implementation of national Arctic research policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b294-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1986-01-31"},"text":"January 31, 1986","children":[],"tail":", and biennially thereafter, the Interagency Committee shall submit to the Congress through the President, a brief, concise report containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b295-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the activities and accomplishments of the Interagency Committee since its last report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b296-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement detailing with particularity the recommendations of the Commission with respect to Federal interagency activities in Arctic research and the disposition and responses to those recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a36b297-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s108"},"text":"Pub. L. 98–373, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1246"},"text":"98 Stat. 1246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/609/s6"},"text":"Pub. L. 101–609, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3126"},"text":"104 Stat. 3126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a36b298-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a36b299-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a36b29a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609"},"text":"Pub. L. 101–609","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “a description of the activities of the Commission, detailing with particularity the recommendations of the Commission with respect to Federal activities in Arctic research.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a36b29b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a36b29c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which the requirement, under subsec. (b) of this section, to submit a biennial report to Congress is listed on page 174), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, and section 1(a)(4) [div. A, § 1402] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7a36b29d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id7a36b29e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to the National Science and Technology Council, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2010-07-22"},"text":"July 22, 2010","children":[],"tail":", 75 F.R. 44063, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4106"},"text":"section 4106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a36b29f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Reporting Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2005-02-17"},"text":"Feb. 17, 2005","children":[],"tail":", 70 F.R. 9841, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Director of the National Science Foundation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you the functions and authority conferred upon the President by "},{"tag":"ref","attrib":{"href":"/us/pl/98/373"},"text":"Public Law 98–373","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4107/b"},"text":"15 U.S.C. 4107(b)","children":[],"tail":" and 4108(a)), to provide the specified report and plan to the Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George W. Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
