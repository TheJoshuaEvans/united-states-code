/26/s2/2/A"},"text":"Pub. L. 105–26, § 2(2)(A)","children":[],"tail":"–(C), added par. (2), redesignated former par. (2) as (1), and struck out heading and text of former par. (1). Text read as follows: “The term ‘annuity rate’ means the percentage of the fair market value of a gift (determined as of the date of the gift) given in exchange for a charitable gift annuity, that represents the amount of the annual payment to be made to 1 or 2 annuitants over the life of either or both under the terms of the agreement to give such gift in exchange for such annuity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/26/s2/2/D"},"text":"Pub. L. 105–26, § 2(2)(D)","children":[],"tail":", (E), added par. (4) and redesignated former pars. (4) and (5) as (5) and (6), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77beacc2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77beacc3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/26"},"text":"Pub. L. 105–26","children":[],"tail":" applicable with respect to all conduct occurring before, on, or after "},{"tag":"date","attrib":{"date":"1997-07-03"},"text":"July 3, 1997","children":[],"tail":", and applicable in all administrative and judicial actions pending on or commenced after "},{"tag":"date","attrib":{"date":"1997-07-03"},"text":"July 3, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/26/s3"},"text":"sect