{"tag":"section","attrib":{"id":"id77bc63c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s37a"},"text":null,"children":[{"tag":"num","attrib":{"value":"37a"},"text":"§ 37a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s37"},"text":"section 37 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id77bc63c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s37a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “antitrust laws” has the meaning given it in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":", except that such term includes "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":" to the extent that such section 45 applies to unfair methods of competition."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77bc63c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s37a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charitable remainder trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “charitable remainder trust” has the meaning given it in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s664/d"},"text":"section 664(d) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77bc63ca-552d-1