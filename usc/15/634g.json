{"tag":"section","attrib":{"id":"id78c2af41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634g"},"text":null,"children":[{"tag":"num","attrib":{"value":"634g"},"text":"§ 634g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgetary line item and authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78c2af42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each budget of the United States Government submitted by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" shall include a separate statement of the amount of appropriations requested for the Office of Advocacy of the Small Business Administration, which shall be designated in a separate account in the General Fund of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78c2af43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Small Business Administration shall provide the Office of Advocacy with appropriate and adequate office space at central and field office locations, together with such equipment, operating budget, and communications facilities and services as may be necessary, and shall provide necessary maintenance services for such offices and the equipment and facilities located in such offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78c2af44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s634g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out sections 634a to 634g of this title. Any amount appropriated under this subsection shall remain available, without fiscal year limitation, until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78c2af45-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305/tII/s207"},"text":"Pub. L. 94–305, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/240/tI/s1602/b"},"text":"Pub. L. 111–240, title I, § 1602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2551"},"text":"124 Stat. 2551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78c2af46-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78c2af47-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78c2af48-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id78c2af49-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 634g, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305/tII/s207"},"text":"Pub. L. 94–305, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/671"},"text":"90 Stat. 671","children":[],"tail":", related to authorization of appropriations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/240/tI/s1602/b"},"text":"Pub. L. 111–240, title I, § 1602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2551"},"text":"124 Stat. 2551","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
