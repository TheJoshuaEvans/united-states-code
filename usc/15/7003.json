{"tag":"section","attrib":{"id":"id7a68bf57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003"},"text":null,"children":[{"tag":"num","attrib":{"value":"7003"},"text":"§ 7003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a68bf58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":" shall not apply to a contract or other record to the extent it is governed by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bf59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statute, regulation, or other rule of law governing the creation and execution of wills, codicils, or testamentary trusts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bf5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State statute, regulation, or other rule of law governing adoption, divorce, or other matters of family law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bf5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Uniform Commercial Code, as in effect in any State, other than sections 1–107 and 1–206 and Articles 2 and 2A.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bf5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":" shall not apply to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bf5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" court orders or notices, or official court documents (including briefs, pleadings, and other writings) required to be executed in connection with court proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bf5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bf5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cancellation or termination of utility services (including water, heat, and power);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bf60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" default, acceleration, repossession, foreclosure, or eviction, or the right to cure, under a credit agreement secured by, or a rental agreement for, a primary residence of an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bf61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cancellation or termination of health insurance or benefits or life insurance benefits (excluding annuities); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bf62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recall of a product, or material failure of a product, that risks endangering health or safety; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bf63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any document required to accompany any transportation or handling of hazardous materials, pesticides, or other toxic or dangerous materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a68bf64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bf65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, acting through the Assistant Secretary for Communications and Information, shall review the operation of the exceptions in subsections (a) and (b) to evaluate, over a period of 3 years, whether such exceptions continue to be necessary for the protection of consumers. Within 3 years after ","children":[{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", the Assistant Secretary shall submit a report to the Congress on the results of such evaluation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bf66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Federal regulatory agency, with respect to matter within its jurisdiction, determines after notice and an opportunity for public comment, and publishes a finding, that one or more such exceptions are no longer necessary for the protection of consumers and eliminating such exceptions will not increase the material risk of harm to consumers, such agency may extend the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":" to the exceptions identified in such finding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bf67-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/229/tI/s103"},"text":"Pub. L. 106–229, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-30"},"text":"June 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/468"},"text":"114 Stat. 468","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a68bf68-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a68bf69-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a68bf6a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Oct. 1, 2000","children":[],"tail":", with exceptions relating to record retention and certain loans, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/229/s107"},"text":"section 107 of Pub. L. 106–229","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7001"},"text":"section 7001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
