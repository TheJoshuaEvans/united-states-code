{"tag":"section","attrib":{"id":"id787d9062-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b–3a"},"text":"§ 80b–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and Federal responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id787d9063-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisers subject to State authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787d9064-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No investment adviser that is regulated or required to be regulated as an investment adviser in the State in which it maintains its principal office and place of business shall register under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":", unless the investment adviser—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787d9065-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has assets under management of not less than $25,000,000, or such higher amount as the Commission may, by rule, deem appropriate in accordance with the purposes of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787d9066-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an adviser to an investment company registered under subchapter I of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787d9067-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of mid-sized investment advisers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787d9068-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No investment adviser described in subparagraph (B) shall register under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":", unless the investment adviser is an adviser to an investment company registered under the Investment Company Act of 1940 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–1"},"text":"15 U.S.C. 80a–1","children":[],"tail":" et seq.], or a company which has elected to be a business development company pursuant to section 54 of the Investment Company Act of 1940 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–53"},"text":"15 U.S.C. 80a–53","children":[],"tail":"], and has not withdrawn the election, except that, if by effect of this paragraph an investment adviser would be required to register with 15 or more States, then the adviser may register under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787d9069-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An investment adviser described in this subparagraph is an investment adviser that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id787d906a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to be registered as an investment adviser with the securities commissioner (or any agency or office performing like functions) of the State in which it maintains its principal office and place of business and, if registered, would be subject to examination as an investment adviser by any such commissioner, agency, or office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id787d906b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has assets under management between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id787d906c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount specified under subparagraph (A) of paragraph (1), as such amount may have been adjusted by the Commission pursuant to that subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id787d906d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000, or such higher amount as the Commission may, by rule, deem appropriate in accordance with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787d906e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Assets under management” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “assets under management” means the securities portfolios with respect to which an investment adviser provides continuous and regular supervisory or management services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787d906f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisers subject to Commission authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id787d9070-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No law of any State or political subdivision thereof requiring the registration, licensing, or qualification as an investment adviser or supervised person of an investment adviser shall apply to any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id787d9071-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":" as an investment adviser, or that is a supervised person of such person, except that a State may license, register, or otherwise qualify any investment adviser representative who has a place of business located within that State;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787d9072-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":" because that person is excepted from the definition of an investment adviser under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2/a/11"},"text":"section 80b–2(a)(11) of this title","children":[],"tail":"; or "},{"tag":"ref","attrib":{"idref":"fn002131"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “or” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787d9073-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":" because that person is exempt from registration as provided in subsection (b)(7) of such section, or is a supervised person of such person; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id787d9074-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–3"},"text":"section 80b–3 of this title","children":[],"tail":" because that person is exempt from registration as provided in subsection (b)(8) of such section, or is a supervised person of such person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id787d9075-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall prohibit the securities commission (or any agency or office performing like functions) of any State from investigating and bringing enforcement actions with respect to fraud or deceit against an investment adviser or person associated with an investment adviser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787d9076-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the Commission, by rule or regulation upon its own motion, or by order upon application, may permit the registration with the Commission of any person or class of persons to which the application of subsection (a) would be unfair, a burden on interstate commerce, or otherwise inconsistent with the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id787d9077-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–3a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request of the securities commissioner (or any agency or officer performing like functions) of any State, the Commission may provide such training, technical assistance, or other reasonable assistance in connection with the regulation of investment advisers by the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id787d9078-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title II, § 203A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/tIII/s303/a"},"text":"Pub. L. 104–290, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3437"},"text":"110 Stat. 3437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/290/s7/b/1"},"text":"Pub. L. 109–290, § 7(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-29"},"text":"Sept. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1321"},"text":"120 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIV/s410"},"text":"Pub. L. 111–203, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1576"},"text":"124 Stat. 1576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXIV/s74003"},"text":"Pub. L. 114–94, div. G, title LXXIV, § 74003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1786"},"text":"129 Stat. 1786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/417/s3"},"text":"Pub. L. 115–417, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5439"},"text":"132 Stat. 5439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787d9079-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787d907a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id787d907b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Investment Company Act of 1940, referred to in subsec. (a)(2)(A), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"act Aug. 22, 1940, ch. 686","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/789"},"text":"54 Stat. 789","children":[],"tail":", which is classified generally to subchapter I (§ 80a–1 et seq.) of this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787d907c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/417"},"text":"Pub. L. 115–417","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/290"},"text":"Pub. L. 109–290","children":[],"tail":" redesignated subsec. (e) as (d) and struck out heading and text of former subsec. (d). Text read as follows: “The Commission may, by rule, require an investment adviser—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to file with the Commission any fee, application, report, or notice required by this subchapter or by the rules issued under this subchapter through any entity designated by the Commission for that purpose; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to pay the reasonable costs associated with such filing.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787d907d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id787d907e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 year after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except that any investment adviser may, at the discretion of the investment adviser, register with the Commission under the Investment Advisers Act of 1940 during that 1-year period, subject to the rules of the Commission, and except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s419"},"text":"section 419 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2"},"text":"section 80b–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id787d907f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 270 days after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/s308/a"},"text":"section 308(a) of Pub. L. 104–290","children":[],"tail":", as amended, set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2"},"text":"section 80b–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id787d9080-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued State Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/290/tIII/s307"},"text":"Pub. L. 104–290, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3440"},"text":"110 Stat. 3440","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/290/tIII/s307"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Filing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title [see Short Title of 1996 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–20"},"text":"section 80b–20 of this title","children":[],"tail":"] or any amendment made by this title prohibits the securities commission (or any agency or office performing like functions) of any State from requiring the filing of any documents filed with the Commission pursuant to the securities laws solely for notice purposes, together with a consent to service of process and any required fee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Until otherwise provided by law, rule, regulation, or order, or other administrative action of any State, or any political subdivision thereof, adopted after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"], filing, registration, or licensing fees shall, notwithstanding the amendments made by this title, continue to be paid in amounts determined pursuant to the law, rule, regulation, or order, or other administrative action as in effect on the day before such date of enactment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Preemption Contingent on Payment of Fees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"] and ending 3 years after that date of enactment, the securities commission (or any agency or office performing like functions) of any State may require registration of any investment adviser that fails or refuses to pay the fees required by subsection (b) in or to such State, notwithstanding the limitations on the laws, rules, regulations, or orders, or other administrative actions of any State, or any political subdivision thereof, contained in subsection (a), if the laws of such State require registration of investment advisers."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delays","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, delays in payment of fees or underpayments of fees that are promptly remedied in accordance with the applicable laws, rules, regulations, or orders, or other administrative actions of the relevant State shall not constitute a failure or refusal to pay fees.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
