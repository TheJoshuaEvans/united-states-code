{"tag":"section","attrib":{"id":"id77b2c5f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s13b"},"text":null,"children":[{"tag":"num","attrib":{"value":"13b"},"text":"§ 13b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative association; return of net earnings or surplus","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall prevent a cooperative association from returning to its members, producers, or consumers the whole, or any part of, the net earnings or surplus resulting from its trading operations, in proportion to their purchases or sales from, to, or through the association.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77b2c5f3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-19/ch592/s4"},"text":"June 19, 1936, ch. 592, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1528"},"text":"49 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b2c5f4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77b2c5f5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77b2c5f6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-19/ch592"},"text":"act June 19, 1936, ch. 592","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1526"},"text":"49 Stat. 1526","children":[],"tail":", popularly known as the Robinson-Patman Antidiscrimination Act and also as the Robinson-Patman Price Discrimination Act, which enacted sections 13a, 13b, and 21a of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s13"},"text":"section 13 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s13"},"text":"section 13 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
