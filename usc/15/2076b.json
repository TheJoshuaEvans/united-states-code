{"tag":"section","attrib":{"id":"id79d99de1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2076b"},"text":"§ 2076b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General audits and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d99de2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements by the Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of the Commission shall conduct reviews and audits to assess—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d99de3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission’s capital improvement efforts, including improvements and upgrades of the Commission’s information technology architecture and systems and the development of the database of publicly available information on incidents involving injury or death required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2055a"},"text":"section 2055a of this title","children":[],"tail":", as added by section 212 of this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d99de4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of procedures for accrediting conformity assessment bodies as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/a/3"},"text":"section 2063(a)(3) of this title","children":[],"tail":", as amended by this Act, and overseeing the third party testing required by such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99de5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee complaints","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Inspector General shall conduct a review of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d99de6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complaints received by the Inspector General from employees of the Commission about failures of other employees to enforce the rules or regulations of the Consumer Product Safety Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"15 U.S.C. 2051","children":[],"tail":" et seq.] or any other Act enforced by the Commission or otherwise carry out their responsibilities under such Acts if such alleged failures raise issues of conflicts of interest, ethical violations, or the absence of good faith; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d99de7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken by the Commission to address such failures and complaints, including an assessment of the timeliness and effectiveness of such actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99de8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public Internet website links","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Commission shall establish and maintain—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d99de9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a direct link on the homepage of its Internet website to the Internet webpage of the Commission’s Office of Inspector General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d99dea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism on the webpage of the Commission’s Office of Inspector General by which individuals may anonymously report cases of waste, fraud, or abuse with respect to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d99deb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d99dec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities and needs of Inspector General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Inspector General of the Commission shall transmit a report to the appropriate Congressional committees on the activities of the Inspector General, any structural barriers which prevent the Inspector General from providing robust oversight of the activities of the Commission, and any additional authority or resources that would facilitate more effective oversight."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d99ded-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2076b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews of improvements and employee complaints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning for fiscal year 2010, the Inspector General of the Commission shall include in an annual report to the appropriate Congressional committees the Inspector General’s findings, conclusions, and recommendations from the reviews and audits under subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d99dee-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s205"},"text":"Pub. L. 110–314, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3043"},"text":"122 Stat. 3043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d99def-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d99df0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79d99df1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3016"},"text":"122 Stat. 3016","children":[],"tail":", known as the Consumer Product Safety Improvement Act of 2008. For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Consumer Product Safety Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573"},"text":"Pub. L. 92–573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1207"},"text":"86 Stat. 1207","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79d99df2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Consumer Product Safety Improvement Act of 2008, and not as part of the Consumer Product Safety Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d99df3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79d99df4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Commission” and “appropriate Congressional committees” used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s2/a"},"text":"section 2(a) of Pub. L. 110–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
