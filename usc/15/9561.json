{"tag":"section","attrib":{"id":"id7ab29927-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561"},"text":null,"children":[{"tag":"num","attrib":{"value":"9561"},"text":"§ 9561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to nonprofit organizations that support minority business enterprises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab29928-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered entity” means a private nonprofit organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29929-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in paragraph (3), (4), (5), or (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2992a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can demonstrate that a primary activity of the organization is to provide services to minority business enterprises, whether through education, making grants or loans, or other similar activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab2992b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to make grants to covered entities to help those covered entities continue the necessary work of supporting minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab2992c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab2992d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Under Secretary shall designate an office to make and administer grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2992e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In designating an office under paragraph (1), the Under Secretary shall ensure that the office designated has adequate staffing to carry out the responsibilities of the office under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab2992f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered entity desiring a grant under this section shall submit to the Under Secretary an application at such time, in such manner, and containing such information as the Under Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29930-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall, in carrying out this section, prioritize granting an application submitted by a covered entity that is located in a federally recognized area of economic distress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29931-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered entity to which a grant is made under this section may use the grant funds to support the development, growth, or retention of minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29932-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall establish procedures to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29933-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discourage and prevent waste, fraud, and abuse by applicants for, and recipients of, grants made under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29934-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that grants are made under this section to a diverse array of covered entities, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab29935-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered entities with a national presence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29936-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based covered entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29937-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered entities with annual budgets below $1,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29938-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered entities that principally serve low-income and rural communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29939-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General audit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the Under Secretary begins making grants under this section, the Inspector General of the Department of Commerce shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab2993a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an audit of grants made under this section, which shall seek to identify any discrepancies or irregularities with respect to those grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2993b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report regarding the audit conducted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab2993c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which the Under Secretary makes the designation required under subsection (c), and once every 30 days thereafter, the Under Secretary shall submit to Congress a report that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab2993d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of grants made under this section during the period covered by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2993e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the grants described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab2993f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic distribution of those grants by State and county;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29940-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, demographic information with respect to the minority business enterprises served by the covered entities to which the grants were made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29941-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9561/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the industries of the minority business enterprises served by the covered entities to which the grants were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab29942-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tIV/s100401"},"text":"Pub. L. 117–58, div. K, title IV, § 100401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1461"},"text":"135 Stat. 1461","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
