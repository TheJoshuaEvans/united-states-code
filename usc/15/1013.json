{"tag":"section","attrib":{"id":"id7951a8e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013"},"text":null,"children":[{"tag":"num","attrib":{"value":"1013"},"text":"§ 1013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension until ","children":[{"tag":"date","attrib":{"date":"1948-06-30"},"text":"June 30, 1948","children":[],"tail":", of application of certain Federal laws; Sherman Act applicable to agreements to, or acts of, boycott, coercion, or intimidation"}],"tail":null},{"tag":"subsection","attrib":{"id":"id7951a8e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until ","children":[{"tag":"date","attrib":{"date":"1948-06-30"},"text":"June 30, 1948","children":[],"tail":", the Act of "},{"tag":"date","attrib":{"date":"1890-07-02"},"text":"July 2, 1890","children":[],"tail":", as amended, known as the Sherman Act, and the Act of "},{"tag":"date","attrib":{"date":"1914-10-15"},"text":"October 15, 1914","children":[],"tail":", as amended, known as the Clayton Act, and the Act of "},{"tag":"date","attrib":{"date":"1914-09-26"},"text":"September 26, 1914","children":[],"tail":", known as the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.], and the Act of "},{"tag":"date","attrib":{"date":"1936-06-19"},"text":"June 19, 1936","children":[],"tail":", known as the Robinson-Patman Anti-Discrimination Act, shall not apply to the business of insurance or to acts in the conduct thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7951a8e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this chapter shall render the said Sherman Act inapplicable to any agreement to boycott, coerce, or intimidate, or act of boycott, coercion, or intimidation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7951a8e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7951a8e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing contained in this chapter shall modify, impair, or supersede the operation of any of the antitrust laws with respect to the business of health insurance (including the business of dental insurance and limited-scope dental benefits).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7951a8e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) shall not apply with respect to making a contract, or engaging in a combination or conspiracy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7951a8e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect, compile, or disseminate historical loss data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7951a8e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine a loss development factor applicable to historical loss data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7951a8e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform actuarial services if such contract, combination, or conspiracy does not involve a restraint of trade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7951a8ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or disseminate a standard insurance policy form (including a standard addendum to an insurance policy form and standard terminology in an insurance policy form) if such contract, combination, or conspiracy is not to adhere to such standard form or require adherence to such standard form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7951a8eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7951a8ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “antitrust laws” has the meaning given it in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":", except that such term includes "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":" to the extent that such section 45 applies to unfair methods of competition;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7951a8ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “business of health insurance (including the business of dental insurance and limited-scope dental benefits)” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7951a8ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business of life insurance (including annuities); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7951a8ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the business of property or casualty insurance, including but not limited to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7951a8f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insurance or benefits defined as “excepted benefits” under paragraph (1), subparagraph (B) or (C) of paragraph (2), or paragraph (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9832/c"},"text":"section 9832(c) of title 26","children":[],"tail":" whether offered separately or in combination with insurance or benefits described in paragraph (2)(A) of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7951a8f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other line of insurance that is classified as property or casualty insurance under State law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7951a8f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “historical loss data” means information respecting claims paid, or reserves held for claims reported, by any person engaged in the business of insurance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7951a8f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1013/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “loss development factor” means an adjustment to be made to reserves held for losses incurred for claims reported by any person engaged in the business of insurance, for the purpose of bringing such reserves to an ultimate paid basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7951a8f4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-03-09/ch20/s3"},"text":"Mar. 9, 1945, ch. 20, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/34"},"text":"59 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-25/ch326"},"text":"July 25, 1947, ch. 326","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/448"},"text":"61 Stat. 448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/327/s2/a"},"text":"Pub. L. 116–327, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5097"},"text":"134 Stat. 5097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7951a8f5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7951a8f6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7951a8f7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1890-07-02"},"text":"July 2, 1890","children":[],"tail":", as amended, known as the Sherman Act, referred to in subsecs. (a) and (b), is classified to sections 1 to 7 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1914-10-15"},"text":"October 15, 1914","children":[],"tail":", as amended, known as the Clayton Act, referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323"},"text":"act Oct. 15, 1914, ch. 323","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/730"},"text":"38 Stat. 730","children":[],"tail":", which is classified generally to sections 12, 13, 14 to 19, 21, and 22 to 27 of this title and to sections 52 and 53 of Title 29, Labor. For further details and complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"section 12 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1914-09-26"},"text":"September 26, 1914","children":[],"tail":", known as the Federal Trade Commission Act, referred to in subsec. (a), is generally classified to subchapter I (§ 41 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1936-06-19"},"text":"June 19, 1936","children":[],"tail":", known as the Robinson-Patman Anti-Discrimination Act, referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-19/ch592"},"text":"act June 19, 1936, ch. 592","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1526"},"text":"49 Stat. 1526","children":[],"tail":", known as the Robinson-Patman Antidiscrimination Act and also as the Robinson-Patman Price Discrimination Act, which enacted sections 13a, 13b, and 21a of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s13"},"text":"section 13 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s13"},"text":"section 13 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7951a8f8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/327"},"text":"Pub. L. 116–327","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1947—Act ","children":[{"tag":"date","attrib":{"date":"1947-07-25"},"text":"July 25, 1947","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1948-06-30"},"text":"June 30, 1948","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1948-01-01"},"text":"January 1, 1948","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7951a8f9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7951a8fa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Related Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/327/s2/b"},"text":"Pub. L. 116–327, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5098"},"text":"134 Stat. 5098","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/327/s2/b"},"text":"“For purposes of section 5 of the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"15 U.S.C. 45","children":[],"tail":") to the extent such section applies to unfair methods of competition, section 3(c) of the McCarran-Ferguson Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1013/c"},"text":"15 U.S.C. 1013(c)","children":[],"tail":"] shall apply with respect to the business of health insurance without regard to whether such business is carried on for profit, notwithstanding the definition of ‘Corporation’ contained in section 4 of the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s44"},"text":"15 U.S.C. 44","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
