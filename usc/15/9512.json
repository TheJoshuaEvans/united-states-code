{"tag":"section","attrib":{"id":"id7ab04f1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512"},"text":null,"children":[{"tag":"num","attrib":{"value":"9512"},"text":"§ 9512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public sector development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall, whenever the Under Secretary determines such action is necessary or appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult and cooperate with public sector entities for the purpose of leveraging resources available in the jurisdictions of those public sector entities to promote the position of minority business enterprises in the local economies of those public sector entities, including by assisting public sector entities to establish or enhance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to procure goods and services through minority business enterprises and goals for that procurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs offering assistance relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab04f1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financing, including accounting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab04f23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce development; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informational programs designed to inform minority business enterprises located in the jurisdictions of those public sector entities about the availability of programs described in this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet with leaders and officials of public sector entities for the purpose of recommending and promoting local administrative and legislative initiatives needed to advance the position of minority business enterprises in the local economies of those public sector entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9512/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the efforts of public sector entities and Federal agencies to advance the growth of minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04f27-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tI/s100102"},"text":"Pub. L. 117–58, div. K, title I, § 100102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1450"},"text":"135 Stat. 1450","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
