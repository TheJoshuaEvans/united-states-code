{"tag":"section","attrib":{"id":"id7a1c72ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3391a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3391a"},"text":"§ 3391a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Essential agricultural use” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3391"},"text":"section 3391 of this title","children":[],"tail":", the term “essential agricultural use” shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c7300-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3391a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include use of natural gas in sugar refining for production of alcohol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7301-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3391a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include use of natural gas for agricultural production on set-aside acreage or acreage diverted from the production of a commodity (as provided under the Agricultural Act of 1949 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.]) to be devoted to the production of any commodity for conversion into alcohol or hydrocarbons for use as motor fuel or other fuels; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7302-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3391a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the 5-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", include use of natural gas in the distillation of fuel-grade alcohol from food grains or other biomass by facilities in existence on "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", which do not have the installed capability to burn coal lawfully."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c7303-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s273"},"text":"Pub. L. 96–294, title II, § 273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/711"},"text":"94 Stat. 711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1c7304-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1c7305-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a1c7306-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Act of 1949, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"act Oct. 31, 1949, ch. 792","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/1051"},"text":"63 Stat. 1051","children":[],"tail":", which is classified principally to chapter 35A (§ 1421 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a1c7307-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Biomass Energy and Alcohol Fuels Act of 1980 which is title II of the Energy Security Act, and not as part of the Natural Gas Policy Act of 1978 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
