{"tag":"section","attrib":{"id":"id796be901-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1245"},"text":null,"children":[{"tag":"num","attrib":{"value":"1245"},"text":"§ 1245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ballistic knives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796be902-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition and penalties for possession, manufacture, sale, or importation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever in or affecting interstate commerce, within any Territory or possession of the United States, within Indian country (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"), or within the special maritime and territorial jurisdiction of the United States (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of title 18","children":[],"tail":"), knowingly possesses, manufactures, sells, or imports a ballistic knife shall be fined as provided in title 18, or imprisoned not more than ten years, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be903-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition and penalties for possession or use during commission of Federal crime of violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever possesses or uses a ballistic knife in the commission of a Federal crime of violence shall be fined as provided in title 18, or imprisoned not less than five years and not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be904-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1245/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exceptions provided in paragraphs (1), (2), and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1244"},"text":"section 1244 of this title","children":[],"tail":" with respect to switchblade knives shall apply to ballistic knives under subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796e5905-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1245/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Ballistic knife” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “ballistic knife” means a knife with a detachable blade that is propelled by a spring-operated mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796e5906-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623/s7"},"text":"Pub. L. 85–623, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tX/s10002"},"text":"Pub. L. 99–570, title X, § 10002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-167"},"text":"100 Stat. 3207–167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6472"},"text":"Pub. L. 100–690, title VI, § 6472","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4379"},"text":"102 Stat. 4379","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796e5907-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796e5908-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id796e5909-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6472/1"},"text":"Pub. L. 100–690, § 6472(1)","children":[],"tail":", substituted “in or affecting interstate commerce, within any Territory or possession of the United States, within Indian country (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"), or within the special maritime and territorial jurisdiction of the United States (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of title 18","children":[],"tail":"), knowingly possesses, manufactures, sells, or imports” for “knowingly possesses, manufactures, sells, or imports”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6472/2"},"text":"Pub. L. 100–690, § 6472(2)","children":[],"tail":", struck out “or State” after “Federal”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796e590a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id796e590b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tX/s10004"},"text":"Pub. L. 99–570, title X, § 10004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-167"},"text":"100 Stat. 3207–167","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/570/tX/s10004"},"text":"“The amendments made by this title [enacting this section, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1716"},"text":"section 1716 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1241"},"text":"section 1241 of this title","children":[],"tail":"] shall take effect 30 days after the date of enactment of this title ["},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
