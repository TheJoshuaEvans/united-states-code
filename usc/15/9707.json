{"tag":"section","attrib":{"id":"id7ab50940-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707"},"text":null,"children":[{"tag":"num","attrib":{"value":"9707"},"text":"§ 9707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates of precipitation frequency in the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab50941-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab50942-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freely Associated States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Freely Associated States” means the Republic of Palau, the Republic of the Marshall Islands, and the Federated States of Micronesia, which have each entered into a Compact of Free Association with the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50943-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means the 50 States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and the Freely Associated States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50944-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a program, to be known as the “NOAA Precipitation Frequency Atlas of the United States”, to compile, estimate, analyze, and communicate the frequency of precipitation in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50945-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The NOAA Precipitation Frequency Atlas of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab50946-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall better inform the public and provide information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab50947-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporal and spatial distribution of heavy precipitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50948-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyses of seasonality in precipitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50949-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends in annual maximum series data; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5094a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may serve as the official source of the Federal Government on estimates of precipitation frequency and associated information with respect to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab5094b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab5094c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The NOAA Precipitation Frequency Atlas of the United States shall include such estimates of the frequency of precipitation in the United States as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab5094d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such estimates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab5094e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted not less frequently than once every 10 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab5094f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be conducted more frequently if determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50950-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such estimates and methodologies used to conduct such estimates shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab50951-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to an appropriate, scientific process, as determined by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50952-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" published on a publicly accessible website of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50953-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may partner with other Federal agencies, members of the private sector, academic cooperative partnerships, or nongovernment associations to assist in carrying out the functions described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50954-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Administrator may consult with relevant Federal, State, local, Tribal, and Territorial government agencies, research institutions, and the private sector, as the Administrator determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50955-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Administrator may coordinate with other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab50956-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9707/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, from amounts otherwise authorized to be appropriated to the Administrator to carry out this chapter, $3,500,000 for each of fiscal years 2022 through 2030.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab50957-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s12"},"text":"Pub. L. 117–316, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4413"},"text":"136 Stat. 4413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab50958-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab50959-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab5095a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (h), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316"},"text":"Pub. L. 117–316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4406"},"text":"136 Stat. 4406","children":[],"tail":", known as the Flood Level Observation, Operations, and Decision Support Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9701"},"text":"section 9701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
