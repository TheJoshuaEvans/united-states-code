{"tag":"section","attrib":{"id":"id78824b8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b–18a"},"text":"§ 80b–18a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State regulation of investment advisers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78824b8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of State regulators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall affect the jurisdiction of the securities commissioner (or any agency or officer performing like functions) of any State over any security or any person insofar as it does not conflict with the provisions of this subchapter or the rules and regulations thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824b90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dual compliance purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No State may enforce any law or regulation that would require an investment adviser to maintain any books or records in addition to those required under the laws of the State in which it maintains its principal office and place of business, if the investment adviser—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78824b91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered or licensed as such in the State in which it maintains its principal office and place of business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78824b92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with the applicable books and records requirements of the State in which it maintains its principal office and place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824b93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on capital and bond requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No State may enforce any law or regulation that would require an investment adviser to maintain a higher minimum net capital or to post any bond in addition to any that is required under the laws of the State in which it maintains its principal office and place of business, if the investment adviser—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78824b94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered or licensed as such in the State in which it maintains its principal office and place of business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78824b95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with the applicable net capital or bonding requirements of the State in which it maintains its principal office and place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824b96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National de minimis standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No law of any State or political subdivision thereof requiring the registration, licensing, or qualification as an investment adviser shall require an investment adviser to register with the securities commissioner of the State (or any agency or officer performing like functions) or to comply with such law (other than any provision thereof prohibiting fraudulent conduct) if the investment adviser—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78824b97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a place of business located within the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78824b98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the preceding 12-month period, has had fewer than 6 clients who are residents of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78824b99-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title II, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/750/s16"},"text":"Pub. L. 86–750, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/888"},"text":"74 Stat. 888","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/tIII/s304"},"text":"Pub. L. 104–290, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3438"},"text":"110 Stat. 3438","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/353/tIII/s301/d/2"},"text":"Pub. L. 105–353, title III, § 301(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3237"},"text":"112 Stat. 3237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s985/e/4"},"text":"Pub. L. 111–203, title IX, § 985(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1935"},"text":"124 Stat. 1935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824b9a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78824b9b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78824b9c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “principal office and place of business” for “principal place of business” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353"},"text":"Pub. L. 105–353","children":[],"tail":" substituted “principal” for “principle”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/290"},"text":"Pub. L. 104–290","children":[],"tail":" substituted “regulation” for “control” in section catchline and amended text generally, designating existing provisions as subsec. (a), inserting heading, and adding subsecs. (b) to (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78824b9d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78824b9e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78824b9f-552d-11f1-9071