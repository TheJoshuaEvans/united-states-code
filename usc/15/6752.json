{"tag":"section","attrib":{"id":"id7a619384-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6752"},"text":null,"children":[{"tag":"num","attrib":{"value":"6752"},"text":"§ 6752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of the Association shall be to provide a mechanism through which licensing, continuing education, and other nonresident insurance producer qualification requirements and conditions may be adopted and applied on a multi-state basis without affecting the laws, rules, and regulations, and preserving the rights of a State, pertaining to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a619385-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6752/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensing, continuing education, and other qualification requirements of insurance producers that are not members of the Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a619386-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6752/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resident or nonresident insurance producer appointment requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a619387-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6752/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervising and disciplining resident and nonresident insurance producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a619388-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6752/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing licensing fees for resident and nonresident insurance producers so that there is no loss of insurance producer licensing revenue to the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a619389-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6752/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing and enforcing laws and regulations regulating the conduct of resident and nonresident insurance producers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a61938a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s322"},"text":"Pub. L. 106–102, title III, § 322","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/13"},"text":"129 Stat. 13","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a61938b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a61938c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a61938d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"