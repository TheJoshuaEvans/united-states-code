{"tag":"section","attrib":{"id":"id7a87b849-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8516"},"text":null,"children":[{"tag":"num","attrib":{"value":"8516"},"text":"§ 8516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Observing system planning","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b84a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8516/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a prioritized list of observation data requirements necessary to ensure weather forecasting capabilities to protect life and property to the maximum extent practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b84b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8516/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8517"},"text":"section 8517 of this title","children":[],"tail":", utilize Observing System Simulation Experiments, Observing System Experiments, Analyses of Alternatives, and other appropriate assessment tools to ensure continuous systemic evaluations of the observing systems, data, and information needed to meet the requirements of paragraph (1), including options to maximize observational capabilities and their cost-effectiveness;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b84c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8516/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify current and potential future data gaps in observing capabilities related to the requirements listed under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b84d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8516/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine a range of options to address gaps identified under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b84e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tI/s106"},"text":"Pub. L. 115–25, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/95"},"text":"131 Stat. 95","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
