{"tag":"section","attrib":{"id":"id7a939ec4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962"},"text":null,"children":[{"tag":"num","attrib":{"value":"8962"},"text":"§ 8962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PFAS research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a939ec5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, acting through the Assistant Administrator for the Office of Research and Development, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939ec6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939ec7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further examine the effects of perfluoroalkyl and polyfluoroalkyl substances on human health and the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939ec8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available information relating to the findings under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ec9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a process for prioritizing which perfluoroalkyl and polyfluoroalkyl substances, or classes of perfluoroalkyl and polyfluoroalkyl substances, should be subject to additional research efforts that is based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939eca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential for human exposure to the substances or classes of substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939ecb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential toxicity of the substances or classes of substances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939ecc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information available about the substances or classes of substances;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ecd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new tools to characterize and identify perfluoroalkyl and polyfluoroalkyl substances in the environment, including in drinking water, wastewater, surface water, groundwater, solids, and the air;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ece-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate approaches for the remediation of contamination by perfluoroalkyl and polyfluoroalkyl substances in the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939ecf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement new tools and materials to communicate with the public about perfluoroalkyl and polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939ed0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section $15,000,000 for each of fiscal years 2020 through 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a939ed1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7362"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7362","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2290"},"text":"133 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
