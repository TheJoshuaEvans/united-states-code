{"tag":"section","attrib":{"id":"id799bab3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649"},"text":null,"children":[{"tag":"num","attrib":{"value":"1649"},"text":"§ 1649.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain limitations on liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799bab3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any closed end consumer credit transaction that is secured by real property or a dwelling, that is subject to this subchapter, and that is consummated before ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":", a creditor or any assignee of a creditor shall have no civil, administrative, or criminal liability under this subchapter for, and a consumer shall have no extended rescission rights under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1635/f"},"text":"section 1635(f) of this title","children":[],"tail":" with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the creditor’s treatment, for disclosure purposes, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605/d/3"},"text":"section 1605(d)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees described in section 1605(e)(2) and (5) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees and amounts referred to in the 3rd sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605/a"},"text":"section 1605(a) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrower-paid mortgage broker fees referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605/a/6"},"text":"section 1605(a)(6) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form of written notice used by the creditor to inform the obligor of the rights of the obligor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1635"},"text":"section 1635 of this title","children":[],"tail":" if the creditor provided the obligor with a properly dated form of written notice published and adopted by the Bureau or a comparable written notice, and otherwise complied with all the requirements of this section regarding notice; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any disclosure relating to the finance charge imposed with respect to the transaction if the amount or percentage actually disclosed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be treated as accurate for purposes of this subchapter if the amount disclosed as the finance charge does not vary from the actual finance charge by more than $200;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1605/f/2"},"text":"section 1605(f)(2) of this title","children":[],"tail":", be treated as accurate for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1635"},"text":"section 1635 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1649/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is greater than the amount or percentage required to be disclosed under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsectio