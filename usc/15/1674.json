{"tag":"section","attrib":{"id":"id79a06630-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1674"},"text":null,"children":[{"tag":"num","attrib":{"value":"1674"},"text":"§ 1674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on discharge from employment by reason of garnishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a06631-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of employment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No employer may discharge any employee by reason of the fact that his earnings have been subjected to garnishment for any one indebtedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06632-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever willfully violates subsection (a) of this section shall be fined not more than $1,000, or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a06633-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s304"},"text":"Pub. L. 90–321, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/163"},"text":"82 Stat. 163","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
