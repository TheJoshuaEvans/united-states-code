{"tag":"section","attrib":{"id":"id79a06587-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1666i–2"},"text":"§ 1666i–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional limits on interest rate increases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a06588-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on increases within first year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of an increase described in paragraph (1), (2), (3), or (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1666i–1/b"},"text":"section 1666i–1(b) of this title","children":[],"tail":", no increase in any annual percentage rate, fee, or finance charge on any credit card account under an open end consumer credit plan shall be effective before the end of the 1-year period beginning on the date on which the account is opened."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06589-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1666i–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotional rate minimum term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No increase in any annual percentage rate applicable to a credit card account under an open end consumer credit plan that is a promotional rate (as that term is defined by the Bureau) shall be effective before the end of the 6-month period beginning on the date on which the promotional rate takes effect, subject to such reasonable exceptions as the Bureau may establish, by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a0658a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s172"},"text":"Pub. L. 90–321, title I, § 172","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s101/d"},"text":"Pub. L. 111–24, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1738"},"text":"123 Stat. 1738","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a0658b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a0658c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a0658d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a0658e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"tex