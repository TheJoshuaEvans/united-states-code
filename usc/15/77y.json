{"tag":"section","attrib":{"id":"id77e9b53e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77y"},"text":null,"children":[{"tag":"num","attrib":{"value":"77y"},"text":"§ 77y.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of other Government agencies over securities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall relieve any person from submitting to the respective supervisory units of the Government of the United States information, reports, or other documents that may be required by any provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77e9b53f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 25, "},{"tag":"ref","attrib":{"href":"/us/stat/48/87"},"text":"48 Stat. 87","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
