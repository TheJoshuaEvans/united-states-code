{"tag":"section","attrib":{"id":"id7ab50a0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9805"},"text":null,"children":[{"tag":"num","attrib":{"value":"9805"},"text":"§ 9805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data on domestic travel and tourism","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary of Commerce for Travel and Tourism, subject to the availability of appropriations, shall collect and make public aggregate data on domestic travel and tourism trends.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7ab50a0c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tVI/s608"},"text":"Pub. L. 117–328, div. BB, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5570"},"text":"136 Stat. 5570","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
