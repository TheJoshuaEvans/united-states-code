{"tag":"section","attrib":{"id":"id7a36b22a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102"},"text":null,"children":[{"tag":"num","attrib":{"value":"4102"},"text":"§ 4102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arctic Research Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a36b22b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish an Arctic Research Commission (hereafter referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b22c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b22d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall be composed of seven members appointed by the President, with the Director of the National Science Foundation serving as a nonvoting, ex officio member. The members appointed by the President shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a36b22e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members appointed from among individuals from academic or other research institutions with expertise in areas of research relating to the Arctic, including the physical, biological, health, environmental, social, and behavioral sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b22f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member appointed from among indigenous residents of the Arctic who are representative of the needs and interests of Arctic residents and who live in areas directly affected by Arctic resource development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b230-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members appointed from among individuals familiar with the Arctic and representative of the needs and interests of private industry undertaking resource development in the Arctic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b231-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall designate one of the appointed members of the Commission to be chairperson of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b232-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office; vacancies; hold-over status","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b233-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, the term of office of each member of the Commission appointed under subsection (b)(1) shall be four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b234-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the members of the Commission originally appointed under subsection (b)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a36b235-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be appointed for a term of two years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b236-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for a term of three years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a36b237-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be appointed for a term of four years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b238-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy occurring in the membership of the Commission shall be filled, after notice of the vacancy is published in the Federal Register, in the manner provided by the preceding provisions of this section, for the remainder of the unexpired term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b239-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member may serve after the expiration of the member’s term of office until the President appoints a successor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b23a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member may serve consecutive terms beyond the member’s original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b23b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses; Federal employee status; meetings; observer-designees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b23c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commission may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":". A member of the Commission not presently employed for compensation shall be compensated at a rate equal to the daily equivalent of the rate for GS–18 of the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" for each day the member is engaged in the actual performance of his duties as a member of the Commission, not to exceed 90 days of service each year. Except for the purposes of chapter 81 of title 5 (relating to compensation for work injuries) and chapter 171 of title 28 (relating to tort claims), a member of the Commission shall not be considered an employee of the United States for any purpose."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b23d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall meet at the call of its Chairman or a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b23e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Federal agency referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4106/b"},"text":"section 4106(b) of this title","children":[],"tail":" may designate a representative to participate as an observer with the Commission. These representatives shall report to and advise the Commission on the activities relating to Arctic research of their agencies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b23f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4102/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall conduct at least one public meeting in the State of Alaska annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a36b240-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s103"},"text":"Pub. L. 98–373, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1243"},"text":"98 Stat. 1243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/609"},"text":"Pub. L. 101–609","children":[],"tail":", §§ 2, 3, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3125"},"text":"104 Stat. 3125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a36b241-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a36b242-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a36b243-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609/s2"},"text":"Pub. L. 101–609, § 2","children":[],"tail":", in introductory provisions, substituted “seven” for “five”, in subpar. (A), substituted “four” for “three”, and in subpar. (C), substituted “two members” for “one member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609/s3"},"text":"Pub. L. 101–609, § 3","children":[],"tail":", substituted “GS–18” for “GS–16”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a36b244-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a36b245-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
