{"tag":"section","attrib":{"id":"id7897a861-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"278n–2"},"text":"§ 278n–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Green manufacturing and construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall carry out a green manufacturing and construction initiative—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a862-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop accurate sustainability metrics and practices for use in manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a863-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the development of standards, including high performance green building standards, and the creation of an information infrastructure to communicate sustainability information about suppliers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a864-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278n–2/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to move buildings toward becoming high performance green buildings, including improving energy performance, service life, and indoor air quality of new and retrofitted buildings through validated measurement data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7897a865-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIV/s408"},"text":"Pub. L. 111–358, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4004"},"text":"124 Stat. 4004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7897a866-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7897a867-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7897a868-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and as part of the National Institute of Standards and Technology Authorization Act of 2010, and not as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7897a869-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7897a86a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Director” and “high performance green building” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s409"},"text":"section 409 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278n–1"},"text":"section 278n–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
