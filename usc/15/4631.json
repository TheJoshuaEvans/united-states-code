{"tag":"section","attrib":{"id":"id7a3b6e00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4631"},"text":null,"children":[{"tag":"num","attrib":{"value":"4631"},"text":"§ 4631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology transfer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3b6e01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall adopt procedures to provide for timely and efficient transfer of semiconductor technology developed under the Initiative pursuant to applicable laws, Executive orders, and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6e02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for commercialization enhancement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6e03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the date on which funds are first appropriated to conduct the Initiative, the Secretary of Energy shall transmit to the committees of Congress named in paragraph (2) a plan for the transfer of semiconductor technology and information generated by the Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6e04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The committees of Congress referred to in paragraph (1) are the Committees on Armed Services of the Senate and House of Representatives, the Committee on Energy and Natural Resources of the Senate, and the Committee on Science, Space, and Technology of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3b6e05-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tI/s3151"},"text":"Pub. L. 100–180, div. C, title I, § 3151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1244"},"text":"101 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s5/b/6"},"text":"Pub. L. 103–437, § 5(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4582"},"text":"108 Stat. 4582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3b6e06-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3b6e07-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a3b6e08-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Committee on Science, Space, and Technology” for “Committee on Science and Technology”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
