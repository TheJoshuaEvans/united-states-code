{"tag":"section","attrib":{"id":"id7a55ac2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301"},"text":null,"children":[{"tag":"num","attrib":{"value":"6301"},"text":"§ 6301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a55ac2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boxer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “boxer” means an individual who fights in a professional boxing match.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boxing commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002547"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002547"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subpar. (B) has been enacted."}],"tail":" The term “boxing commission” means an entity authorized under State law to regulate professional boxing matches."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boxer registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “boxer registry” means any entity certified by the Association of Boxing Commissions for the purposes of maintaining records and identification of boxers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “licensee” means an individual who serves as a trainer, second, or cut man for a boxer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manager” means a person who receives compensation for service as an agent or representative of a boxer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matchmaker","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “matchmaker” means a person that proposes, selects, and arranges the boxers to participate in a professional boxing match.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physician","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “physician” means a doctor of medicine legally authorized to practice medicine by the State in which the physician performs such function or action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional boxing match","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “professional boxing match” means a boxing contest held in the United States between individuals for financial compensation. Such term does not include a boxing contest that is regulated by an amateur sports organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “promoter” means the person primarily responsible for organizing, promoting, and producing a professional boxing match. The term “promoter” does not include a hotel, casino, resort, or other commercial establishment hosting or sponsoring a professional boxing match unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hotel, casino, resort, or other commercial establishment is primarily responsible for organizing, promoting, and producing the match; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no other person primarily responsible for organizing, promoting, and producing the match.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, Puerto Rico, the District of Columbia, and any territory or possession of the United States, including the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of the contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “effective date of the contract” means the day upon which a boxer becomes legally bound by the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boxing service provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “boxing service provider” means a promoter, manager, sanctioning body, licensee, or matchmaker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract provision” means any legal obligation between a boxer and a boxing service provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctioning organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sanctioning organization” means an organization that sanctions professional boxing matches in the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a55ac40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between boxers who are residents of different States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a55ac41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are advertised, otherwise promoted, or broadcast (including closed circuit television) in interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a55ac42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6301/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “suspension” includes within its meaning the revocation of a boxing license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a55ac43-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s2"},"text":"Pub. L. 104–272, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3309"},"text":"110 Stat. 3309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/a"},"text":"Pub. L. 106–210, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/327"},"text":"114 Stat. 327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55ac44-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a55ac45-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a55ac46-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/a"},"text":"Pub. L. 106–210, § 7(a)","children":[],"tail":", which directed amendments to subsec. (a) of this section, was executed as if it directed amendments to this section rather than to subsec. (a) of this section to reflect the probable intent of Congress because this section does not contain a subsec. (a). See 2000 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a55ac47-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/a/1"},"text":"Pub. L. 106–210, § 7(a)(1)","children":[],"tail":", inserted last sentence. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/a/2"},"text":"Pub. L. 106–210, § 7(a)(2)","children":[],"tail":", inserted “, including the Virgin Islands” before the period at end. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (11) to (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s7/a/3"},"text":"Pub. L. 106–210, § 7(a)(3)","children":[],"tail":", added pars. (11) to (15). See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ac48-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a55ac49-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23"},"text":"Pub. L. 104–272, § 23","children":[],"tail":", formerly § 15, "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3314"},"text":"110 Stat. 3314","children":[],"tail":", as renumbered § 23 by "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/1"},"text":"Pub. L. 106–210, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/210/s4/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The provisions of this Act [enacting this chapter] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", except as follows:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9 [now section 17, enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6308"},"text":"section 6308 of this title","children":[],"tail":"] shall not apply to an otherwise authorized boxing commission in the Commonwealth of Virginia until "},{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 5 through 9 [enacting sections 6304 to 6308 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7a55ac4a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s1"},"text":"Pub. L. 106–210, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/321"},"text":"114 Stat. 321","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/210/s1"},"text":"“This Act [enacting sections 6307a to 6307h of this title, amending this section and sections 6303, 6305, 6306, and 6308 to 6313 of this title, and enacting and amending provisions set out as notes under this section] may be cited as the ‘Muhammad Ali Boxing Reform Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a55ac4b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s1"},"text":"Pub. L. 104–272, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3309"},"text":"110 Stat. 3309","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/272/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Professional Boxing Safety Act of 1996’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a55ac4c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s2"},"text":"Pub. L. 106–210, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/321"},"text":"114 Stat. 321","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/210/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional boxing differs from other major, interstate professional sports industries in the United States in that it operates without any private sector association, league, or centralized industry organization to establish uniform and appropriate business practices and ethical standards. This has led to repeated occurrences of disreputable and coercive business practices in the boxing industry, to the detriment of professional boxers nationwide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State officials are the proper regulators of professional boxing events, and must protect the welfare of professional boxers and serve the public interest by closely supervising boxing activity in their jurisdiction. State boxing commissions do not currently receive adequate information to determine whether boxers competing in their jurisdiction are being subjected to contract terms and business practices which may violate State regulations, or are onerous and confiscatory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoters who engage in illegal, coercive, or unethical business practices can take advantage of the lack of equitable business standards in the sport by holding boxing events in States with weaker regulatory oversight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sanctioning organizations which have proliferated in the boxing industry have not established credible and objective criteria to rate professional boxers, and operate with virtually no industry or public oversight. Their ratings are susceptible to manipulation, have deprived boxers of fair opportunities for advancement, and have undermined public confidence in the integrity of the sport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Open competition in the professional boxing industry has been significantly interfered with by restrictive and anticompetitive business practices of certain promoters and sanctioning bodies, to the detriment of the athletes and the ticket-buying public. Common practices of promoters and sanctioning organizations represent restraints of interstate trade in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is necessary and appropriate to establish national contracting reforms to protect professional boxers and prevent exploitive business practices, and to require enhanced financial disclosures to State athletic commissions to improve the public oversight of the sport.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a55ac4d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s3"},"text":"Pub. L. 106–210, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/210/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [see Short Title of 2000 Amendment note above] are—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the rights and welfare of professional boxers on an interstate basis by preventing certain exploitive, oppressive, and unethical business practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist State boxing commissions in their efforts to provide more effective public oversight of the sport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote honorable competition in professional boxing and enhance the overall integrity of the industry.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
