{"tag":"section","attrib":{"id":"id79baa42e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1692m"},"text":"§ 1692m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress by the Bureau; views of other Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79baa42f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the effective date of this subchapter and at one-year intervals thereafter, the Bureau shall make reports to the Congress concerning the administration of its functions under this subchapter, including such recommendations as the Bureau deems necessary or appropriate. In addition, each report of the Bureau shall include its assessment of the extent to which compliance with this subchapter is being achieved and a summary of the enforcement actions taken by the Bureau under section 1692","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79baa430-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1692m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the exercise of its functions under this subchapter, the Bureau may obtain upon request the views of any other Federal agency which exercises enforcement functions under section 1692","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79baa431-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tVIII/s815"},"text":"Pub. L. 90–321, title VIII, § 815","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/109"},"text":"Pub. L. 95–109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/882"},"text":"91 Stat. 882","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1089/1"},"text":"Pub. L. 111–203, title X, § 1089(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2092"},"text":"124 Stat. 2092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79baa432-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79baa433-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79baa434-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subchapter, referred to in subsec. (a), is the date occurring on expiration of six months after ","children":[{"tag":"date","attrib":{"date":"1977-09-20"},"text":"Sept. 20, 1977","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s819"},"text":"section 819 of Pub. L. 90–321","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1692"},"text":"section 1692 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79baa435-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"t