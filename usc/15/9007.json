{"tag":"section","attrib":{"id":"id7a939f7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007"},"text":null,"children":[{"tag":"num","attrib":{"value":"9007"},"text":"§ 9007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority Business Development Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a939f7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Agency” means the Minority Business Development Agency of the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “minority business center” means a Business Center of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “minority business enterprise” means a for-profit business enterprise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 51 percent of which is owned by 1 or more socially disadvantaged individuals, as determined by the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and daily business operations of which are controlled by 1 or more socially disadvantaged individuals, as determined by the Agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “minority chamber of commerce” means a chamber of commerce developed specifically to support minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education, training, and advising grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency may provide financial assistance in the form of grants to minority business centers and minority chambers of commerce to provide education, training, and advising to minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section shall be used for the education, training, and advising of minority business enterprises and their employees on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and applying for resources provided by the Agency and other Federal resources relating to access to capital and business resiliency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hazards and prevention of the transmission and communication of COVID–19 and other communicable diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f89-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential effects of COVID–19 on the supply chains, distribution, and sale of products of minority business enterprises and the mitigation of those effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f8a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and practice of telework to reduce possible transmission of COVID–19;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f8b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and practice of remote customer service by electronic or other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risks of and mitigation of cyber threats in remote customer service or telework practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mitigation of the effects of reduced travel or outside activities on minority business enterprises during COVID–19 or similar occurrences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant business practices necessary to mitigate the economic effects of COVID–19 or similar occurrences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No matching funds required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Matching funds shall not be required for any grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals and metrics","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Goals and metrics for the funds made available under this section shall be jointly developed, negotiated, and agreed upon, with full participation of both parties, between the minority business centers, minority chambers of commerce, and the Agency, which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the extent of the circumstances relating to the spread of COVID–19, or similar occurrences, that affect minority business enterprises located in the areas covered by minority business centers and minority chambers of commerce, particularly in rural areas or economically distressed areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally follow the use of funds outlined in paragraph (2), but shall not restrict the activities of minority business centers and minority chambers of commerce in responding to unique situations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage minority business centers and minority chambers of commerce to develop and provide services to minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency shall make publicly available the methodology by which the Agency, minority business centers, and minority chambers of commerce jointly develop the metrics and goals described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or regulation, the Agency may, during the 3-month period that begins on ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", waive any matching requirement imposed on a minority business center or a specialty center of the Agency under a cooperative agreement between such a center and the Agency if the applicable center is unable to raise funds, or has suffered a loss of revenue, because of the effects of COVID–19."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining compliant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of a cooperative agreement between the Agency and a minority business center, if, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", such a center decides not to collect fees because of the economic consequences of COVID–19, the center shall be considered to be in compliance with that agreement if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the center notifies the Agency with respect to that decision, which the center may provide through electronic mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Agency, not later than 15 days after the date on which the center provides notice to the Agency under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirms receipt of the notification under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepts the decision of the center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and annually thereafter, the Agency shall submit to the Committee on Small Business and Entrepreneurship and the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Small Business and the Committee on Energy and Commerce of the House of Representatives a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the period covered by the initial report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs and services developed and provided by the Agency, minority business centers, and minority chambers of commerce under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939fa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial efforts to provide those services under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939fa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to subsequent years covered by the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939fa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002616"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002616"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subpar. (B) has been enacted."}],"tail":" with respect to the grant program under subsection (b)—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a939fa3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Agency, minority business centers, and minority chambers of commerce to develop services to assist minority business enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939fa4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the challenges faced by owners of minority business enterprises in accessing services provided by the Agency, minority business centers, and minority chambers of commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939fa5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unique minority business enterprises that were served by the Agency, minority business centers, or minority chambers of commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939fa6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant outcome performance data with respect to minority business enterprises, including the number of employees affected, the effect on sales, the disruptions of supply chains, and the efforts made by the Agency, minority business centers, and minority chambers of commerce to mitigate these effects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939fa7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9007/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $10,000,000 to carry out this section, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a939fa8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tI/s1108"},"text":"Pub. L. 116–136, div. A, title I, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/302"},"text":"134 Stat. 302","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
