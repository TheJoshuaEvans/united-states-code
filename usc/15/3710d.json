{"tag":"section","attrib":{"id":"id7a2859fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710d"},"text":null,"children":[{"tag":"num","attrib":{"value":"3710d"},"text":"§ 3710d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a2859fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Federal agency which has ownership of or the right of ownership to an invention made by a Federal employee does not intend to file for a patent application or otherwise to promote commercialization of such invention, the agency shall allow the inventor, if the inventor is a Government employee or former employee who made the invention during the course of employment with the Government, to obtain or retain title to the invention (subject to reservation by the Government of a nonexclusive, nontransferrable, irrevocable, paid-up license to practice the invention or have the invention practiced throughout the world by or on behalf of the Government). In addition, the agency may condition the inventor’s right to title on the timely filing of a patent application in cases when the Government determines that it has or may have a need to practice the invention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2859fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Special Government employees” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, Federal employees include “special Government employees” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a2859ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3710d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section is intended to limit or diminish existing authorities of any agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a285a00-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s15"},"text":"Pub. L. 96–480, § 15","children":[],"tail":", as added and renumbered § 14, "},{"tag":"ref","attrib":{"href":"/us/pl/99/502"},"text":"Pub. L. 99–502","children":[],"tail":", §§ 8, 9(e)(1), "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1794"},"text":"100 Stat. 1794","children":[],"tail":", 1797; renumbered § 15, "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5122/a/1"},"text":"Pub. L. 100–418, title V, § 5122(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1438"},"text":"102 Stat. 1438","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/113/s6"},"text":"Pub. L. 104–113, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/779"},"text":"110 Stat. 779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a285a01-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a285a02-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a285a03-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113"},"text":"Pub. L. 104–113","children":[],"tail":" substituted “ownership of or the right of ownership to an invention made by a Federal employee” for “the right of ownership to an invention under this chapter” and inserted “obtain or” before “retain title to the invention”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
