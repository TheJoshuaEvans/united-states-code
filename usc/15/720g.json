{"tag":"section","attrib":{"id":"id794833da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g"},"text":null,"children":[{"tag":"num","attrib":{"value":"720g"},"text":"§ 720g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of alternative means of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794833db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no application for the issuance of a certificate or amended certificate of public convenience and necessity authorizing the construction and operation of an Alaska natural gas transportation project has been filed with the Commission by the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2004-10-13"},"text":"October 13, 2004","children":[],"tail":", the Secretary shall conduct a study of alternative approaches to the construction and operation of such an Alaska natural gas transportation project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of study","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study under subsection (a) shall take into consideration the feasibility of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794833dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a Federal Government corporation to construct an Alaska natural gas transportation project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing alternative means of providing Federal financing and ownership (including alternative combinations of Government and private corporate ownership) of the Alaska natural gas transportation project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the study under subsection (a), the Secretary shall consult with the Secretary of the Treasury and the Secretary of the Army (acting through the Chief of Engineers).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794833e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of any study under subsection (a), the Secretary shall submit to Congress a report that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794833e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794833e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Secretary (including proposals for legislation to implement the recommendations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794833e3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/dC/s109"},"text":"Pub. L. 108–324, div. C, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1262"},"text":"118 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
