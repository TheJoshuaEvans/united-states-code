{"tag":"section","attrib":{"id":"id7a12d743-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054"},"text":null,"children":[{"tag":"num","attrib":{"value":"3054"},"text":"§ 3054.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of the Commission and the Horseracing Integrity and Safety Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a12d744-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the program effective date, the Commission, the Authority, and the anti-doping and medication control enforcement agency, each within the scope of their powers and responsibilities under this chapter, as limited by subsection (j),","children":[{"tag":"ref","attrib":{"idref":"fn002478"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002478"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (k)”."}],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d745-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement and enforce the horseracing anti-doping and medication control program and the racetrack safety program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d746-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" exercise independent and exclusive national authority over—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d747-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety, welfare, and integrity of covered horses, covered persons, and covered horseraces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d748-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all horseracing safety, performance, and anti-doping and medication control matters for covered horses, covered persons, and covered horseraces; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d749-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have safety, performance, and anti-doping and medication control authority over covered persons similar to such authority of the State racing commissions before the program effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d74a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rules of the Authority promulgated in accordance with this chapter shall preempt any provision of State law or regulation with respect to matters within the jurisdiction of the Authority under this chapter, as limited by subsection (j).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Nothing contained in this chapter shall be construed to limit the authority of the Commission under any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d74b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d74c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d74d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall develop uniform procedures and rules authorizing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d74e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to offices, racetrack facilities, other places of business, books, records, and personal property of covered persons that are used in the care, treatment, training, and racing of covered horses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d74f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuance and enforcement of subpoenas and subpoenas duces tecum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d750-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other investigatory powers of the nature and scope exercised by State racing commissions before the program effective date; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d751-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an unfair or deceptive act or practice described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3059"},"text":"section 3059 of this title","children":[],"tail":", may recommend that the Commission commence an enforcement action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d752-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procedures and rules developed under paragraph (1)(A) shall be subject to approval by the Commission in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d753-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of covered persons with Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d754-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of participating in covered races and in the care, ownership, treatment, and training of covered horses, a covered person shall register with the Authority in accordance with rules promulgated by the Authority and approved by the Commission in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d755-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with respect to Authority rules, standards, and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Registration under this subsection shall include an agreement by the covered person to be subject to and comply with the rules, standards, and procedures developed and approved under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d756-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered person registered under this subsection shall, at all times—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d757-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the Commission, the Authority, the anti-doping and medication control enforcement agency, and any respective designee, during any civil investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d758-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond truthfully and completely to the best of the knowledge of the covered person if questioned by the Commission, the Authority, the anti-doping and medication control enforcement agency, or any respective designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d759-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure of a covered person to comply with this subsection shall be a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3057/a/2/G"},"text":"section 3057(a)(2)(G) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d75a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d75b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-doping and medication control enforcement agency","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d75c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with USADA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall seek to enter into an agreement with the United States Anti-Doping Agency under which the Agency acts as the anti-doping and medication control enforcement agency under this chapter for services consistent with the horseracing anti-doping and medication control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d75d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement with other entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Authority and the United States Anti-Doping Agency are unable to enter into the agreement described in subparagraph (A), the Authority shall enter into an agreement with an entity that is nationally recognized as being a medication regulation agency equal in qualification to the United States Anti-Doping Agency to act as the anti-doping and medication control enforcement agency under this chapter for services consistent with the horseracing anti-doping and medication control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d75e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any negotiations under this paragraph shall be conducted in good faith and designed to achieve efficient, effective best practices for anti-doping and medication control and enforcement on commercially reasonable terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d75f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement under this paragraph shall include a description of the scope of work, performance metrics, reporting obligations, and budgets of the United States Anti-Doping Agency while acting as the anti-doping and medication control enforcement agency under this chapter, as well as a provision for the revision of the agreement to increase in the scope of work as provided for in subsection (k),","children":[{"tag":"ref","attrib":{"idref":"fn002479"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002479"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" and any other matter the Authority considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d760-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers of enforcement agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The anti-doping and medication control enforcement agency under an agreement under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d761-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the independent anti-doping and medication control enforcement organization for covered horses, covered persons, and covered horseraces, implementing the anti-doping and medication control program on behalf of the Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d762-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that covered horses and covered persons are deterred from using or administering medications, substances, and methods in violation of the rules established in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d763-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement anti-doping education, research, testing, compliance and adjudication programs designed to prevent covered persons and covered horses from using or administering medications, substances, and methods in violation of the rules established in accordance with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d764-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise the powers specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3055/c/4"},"text":"section 3055(c)(4) of this title","children":[],"tail":" in accordance with that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d765-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement and undertake any other responsibilities specified in the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d766-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term and extension","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d767-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of initial agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial agreement entered into by the Authority under this paragraph shall be in effect for the 5-year period beginning on the program effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d768-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the end of the 5-year period described in clause (i), the Authority may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a12d769-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend the term of the initial agreement under this paragraph for such additional term as is provided by the rules of the Authority and consistent with this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a12d76a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/1/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement meeting the requirements of this paragraph with an entity described by subparagraph (B) for such term as is provided by such rules and consistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d76b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements for enforcement by State racing commissions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d76c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State racing commissions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d76d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racetrack safety program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may enter into agreements with State racing commissions for services consistent with the enforcement of the racetrack safety program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d76e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-doping and medication control program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The anti-doping and medication control enforcement agency may enter into agreements with State racing commissions for services consistent with the enforcement of the anti-doping and medication control program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d76f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement under this paragraph shall include a description of the scope of work, performance metrics, reporting obligations, budgets, and any other matter the Authority considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d770-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may coordinate with State racing commissions and other State regulatory agencies to monitor and enforce racetrack compliance with the standards developed under paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3056/c"},"text":"section 3056(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d771-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures with respect to rules of Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d772-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-doping and medication control","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d773-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recommendations for rules regarding anti-doping and medication control shall be developed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3055"},"text":"section 3055 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d774-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The anti-doping and medication control enforcement agency shall consult with the anti-doping and medication control standing committee and the Board of the Authority on all anti-doping and medication control rules of the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d775-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racetrack safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recommendations for rules regarding racetrack safety shall be developed by the racetrack safety standing committee of the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d776-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d777-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Authority may issue guidance that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d778-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sets forth—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d779-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interpretation of an existing rule, standard, or procedure of the Authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d77a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a policy or practice with respect to the administration or enforcement of such an existing rule, standard, or procedure; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d77b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relates solely to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a12d77c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the Authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a12d77d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter, as specified by the Commission, by rule, consistent with the public interest and the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d77e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submittal to Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall submit to the Commission any guidance issued under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d77f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Guidance issued under paragraph (1) shall take effect on the date on which the guidance is submitted to the Commission under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d780-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoena and investigatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall have subpoena and investigatory authority with respect to civil violations committed under its jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d781-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall develop a list of civil penalties with respect to the enforcement of rules for covered persons and covered horseraces under its jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d782-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d783-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to civil sanctions imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3057"},"text":"section 3057 of this title","children":[],"tail":", the Authority may commence a civil action against a covered person or racetrack that has engaged, is engaged, or is about to engage, in acts or practices constituting a violation of this chapter or any rule established under this chapter in the proper district court of the United States, the United States District Court for the District of Columbia, or the United States courts of any territory or other place subject to the jurisdiction of the United States, to enjoin such acts or practices, to enforce any civil sanctions imposed under that section, and for all other relief to which the Authority may be entitled."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d784-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions and restraining orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a civil action commenced under paragraph (1), upon a proper showing, a permanent or temporary injunction or restraining order shall be granted without bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d785-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d786-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospective application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The jurisdiction and authority of the Authority and the Commission with respect to the horseracing anti-doping and medication control program and the racetrack safety program shall be prospective only.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d787-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Previous matters","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a12d788-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority and the Commission may not investigate, prosecute, adjudicate, or penalize conduct in violation of the horseracing anti-doping and medication control program and the racetrack safety program that occurs before the program effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a12d789-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State racing commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to conduct described in subparagraph (A), the applicable State racing commission shall retain authority until the final resolution of the matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d78a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other laws unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This chapter shall not be construed to modify, impair or restrict the operation of the general laws or regulations, as may be amended from time to time, of the United States, the States and their political subdivisions relating to criminal conduct, cruelty to animals, matters unrelated to antidoping, medication control and racetrack and racing safety of covered horses and covered races, and the use of medication in human participants in covered races.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d78b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election for other breed coverage under chapter","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a12d78c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State racing commission or a breed governing organization for a breed of horses other than Thoroughbred horses may elect to have such breed be covered by this chapter by the filing of a designated election form and subsequent approval by the Authority. A State racing commission may elect to have a breed covered by this chapter for the applicable State only.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d78d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election conditional on funding mechanism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A commission or organization may not make an election under paragraph (1) unless the commission or organization has in place a mechanism to provide sufficient funds to cover the costs of the administration of this chapter with respect to the horses that will be covered by this chapter as a result of the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a12d78e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3054/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall apportion costs described in paragraph (2) in connection with an election under paragraph (1) fairly among all impacted segments of the horseracing industry, subject to approval by the Commission in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":". Such apportionment may not provide for the allocation of costs or funds among breeds of horses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12d78f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1205"},"text":"Pub. L. 116–260, div. FF, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3259"},"text":"134 Stat. 3259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a12d790-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a12d791-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a12d792-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b), (e)(1), (j)(1), (k)(3), and (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), (2), was in the original “this Act” and was translated as reading “this title”, meaning title XII of div. FF of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
