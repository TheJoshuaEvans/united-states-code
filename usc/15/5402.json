{"tag":"section","attrib":{"id":"id7a4c0efc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402"},"text":null,"children":[{"tag":"num","attrib":{"value":"5402"},"text":"§ 5402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4c0efd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “accredited laboratory” means a fastener testing facility used to perform end-of-line testing required by a consensus standard or standards to verify that a lot of fasteners conforms to the grade identification marking called for in the consensus standard or standards to which the lot of fasteners has been manufactured, and which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4c0efe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of ISO/IEC Guide 25 (or another document approved by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5411a/c"},"text":"section 5411a(c) of this title","children":[],"tail":"), including revisions from time-to-time; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0eff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been accredited by a laboratory accreditation body that meets the requirements of ISO/IEC Guide 58 (or another document approved by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5411a/d"},"text":"section 5411a(d) of this title","children":[],"tail":"), including revisions from time-to-time;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “consensus standard” means the provisions of a document that describes fastener characteristics published by a consensus standards organization or a Federal agency, and does not include a proprietary standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “consensus standards organization” means the American Society for Testing and Materials, the American National Standards Institute, the American Society of Mechanical Engineers, the Society of Automotive Engineers, the International Organization for Standardization, any other organization identified as a United States consensus standards organization or a foreign and international consensus standards organization in the Federal Register at 61 Fed. Reg. 50582–83 (","children":[{"tag":"date","attrib":{"date":"1996-09-26"},"text":"September 26, 1996","children":[],"tail":"), and any successor organizations thereto;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Director” means the Director of the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “distributor” means a person who purchases fasteners for the purpose of reselling them at wholesale to unaffiliated persons within the United States (an original equipment manufacturer and its dealers shall be considered affiliated persons for purposes of this chapter);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “fastener” means a metallic screw, nut, bolt, or stud having internal or external threads, with a nominal diameter of 6 millimeters or greater, in the case of such items described in metric terms, or ¼ inch or greater, in the case of such items described in terms of the English system of measurement, or a load-indicating washer, that is through-hardened or represented as meeting a consensus standard that calls for through-hardening, and that is grade identification marked or represented as meeting a consensus standard that requires grade identification marking, except that such term does not include any screw, nut, bolt, stud, or load-indicating washer that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4c0f05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part of an assembly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part that is ordered for use as a spare, substitute, service, or replacement part, unless that part is in a package containing more than 75 of any such part at the time of sale, or a part that is contained in an assembly kit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced and marked as ASTM A 307 Grade A, or a successor standard thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced in accordance with ASTM F 432, or a successor standard thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifically manufactured for use on an aircraft if the quality and suitability of those fasteners for that use has been approved—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4c0f0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Federal Aviation Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4c0f0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a foreign airworthiness authority as described in part 21.29, 21.500, 21.502, or 21.617 of title 14 of the Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactured in accordance with a fastener quality assurance system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactured to a proprietary standard, whether or not such proprietary standard directly or indirectly references a consensus standard or any portion thereof;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “fastener quality assurance system” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4c0f0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a system that meets the requirements, including revisions from time-to-time, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4c0f10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International Organization for Standardization (ISO) Standard 9000, 9001, 9002, or TS16949;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4c0f11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quality System (QS) 9000 Standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4c0f12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Verband der Automobilindustrie e. V. (VDA) 6.1 Standard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4c0f13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aerospace Basic Quality System Standard AS9000; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any fastener manufacturing system—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a4c0f15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has as a stated goal the prevention of defects through continuous improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4c0f16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that seeks to attain the goal stated in clause (i) by incorporating—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a4c0f17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced quality planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a4c0f18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and control of the manufacturing process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a4c0f19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product verification embodied in a comprehensive written control plan for product and process characteristics, and process controls (including process influence factors and statistical process control), tests, and measurement systems to be used in production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a4c0f1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation, maintenance, and retention of electronic, photographic, or paper records required by the control plan regarding the inspections, tests, and measurements performed pursuant to the control plan; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a4c0f1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a4c0f1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to certification in accordance with the requirements of ISO/IEC Guide 62 (or another document approved by the Director under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5411a/a"},"text":"section 5411a(a) of this title","children":[],"tail":"), including revisions from time-to-time, by a third party who is accredited by an accreditation body in accordance with the requirements of ISO/IEC Guide 61 (or another document approved by the Director under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5411a/b"},"text":"section 5411a(b) of this title","children":[],"tail":"), including revisions from time-to-time; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a4c0f1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/7/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undergoes regular or random evaluation and assessment by the end user or end users of the screws, nuts, bolts, studs, or load-indicating washers produced under such fastener manufacturing system to ensure that such system meets the requirements of clauses (i) and (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “grade identification marking” means any grade-mark or property class symbol appearing on a fastener purporting to indicate that the lot of fasteners conforms to a specific consensus standard, but such term does not include a manufacturer’s insignia or part number;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “importer” means a distributor located within the United States who contracts for the initial purchase of fasteners manufactured outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “lot” means a quantity of fasteners of one part number fabricated by the same production process from the same coil or heat number of metal as provided by the metal manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “manufacturer” means a person who fabricates fasteners for sale in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “proprietary standard” means the provisions of a document that describes characteristics of a screw, nut, bolt, stud, or load-indicating washer and is issued by a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4c0f23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses screws, nuts, bolts, studs, or load-indicating washers in the manufacture, assembly, or servicing of its products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to such screws, nuts, bolts, studs, or washers, is a developer and issuer of descriptions that have characteristics similar to consensus standards and that bear such user’s identification;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “record of conformance” means a record or records for each lot of fasteners sold or offered for sale that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4c0f26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the type of fastener;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lot number;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nominal dimensions of the fastener (including diameter and length of bolts or screws), thread form, and class of fit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consensus standard or specifications to which the lot of fasteners has been manufactured, including the date, number, revision, and other information sufficient to identify the particular consensus standard or specifications being referenced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chemistry and grade of material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coating material and characteristics and the applicable consensus standard or specifications for such coating; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4c0f2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/13/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results or a summary of results of any tests performed for the purpose of verifying that a lot of fasteners conforms to its grade identification marking or to the grade identification marking the lot of fasteners is represented to meet;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “represent” means to describe one or more of a fastener’s purported characteristics in a document or statement that is transmitted to a purchaser through any medium;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “specifications” means the required characteristics identified in the contractual agreement with the manufacturer or to which a fastener is otherwise produced, except that the term does not include proprietary standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0f31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5402/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “through-harden” means heating above the transformation temperature followed by quenching and tempering for the purpose of achieving uniform hardness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4c0f32-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s3"},"text":"Pub. L. 101–592, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2944"},"text":"104 Stat. 2944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b"},"text":"Pub. L. 104–113, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/780"},"text":"110 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/34/s3"},"text":"Pub. L. 106–34, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/118"},"text":"113 Stat. 118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4c0f33-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4c0f34-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4c0f35-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/34"},"text":"Pub. L. 106–34","children":[],"tail":" amended section catchline and text generally, restating certain definitions, adding new definitions, and striking out definitions of “alter”, “container”, “institute”, “original equipment manufacturer”, “private label distributor”, and “standards and specifications”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/1"},"text":"Pub. L. 104–113, § 11(b)(1)","children":[],"tail":", struck out “having a minimum tensile strength of 150,000 pounds per square inch” after “fasteners”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/2"},"text":"Pub. L. 104–113, § 11(b)(2)","children":[],"tail":", inserted “consensus” after “or any other”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/3"},"text":"Pub. L. 104–113, § 11(b)(3)","children":[],"tail":", inserted “or produced in accordance with ASTM F 432” after “307 Grade A” in closing provisions, inserted “or” at end of subpar. (B), struck out “or” at end of subpar. (C), and struck out subpar. (D) which read as follows: “any item within a category added by the Secretary in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5403/b"},"text":"section 5403(b) of this title","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/4"},"text":"Pub. L. 104–113, § 11(b)(4)","children":[],"tail":", substituted “government agency” for “other person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/5"},"text":"Pub. L. 104–113, § 11(b)(5)","children":[],"tail":", substituted “Standards” for “Standard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (11), (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/6"},"text":"Pub. L. 104–113, § 11(b)(6)","children":[],"tail":", redesignated pars. (12) and (13) as (11) and (12), respectively, and struck out former par. (11) which read as follows: “ ‘original equipment manufacturer’ means a person who uses fasteners in the manufacture or assembly of its products and sells fasteners to authorized dealers as replacement or service parts for its products;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/7"},"text":"Pub. L. 104–113, § 11(b)(7)","children":[],"tail":", substituted “or a government agency” for “, a government agency, or a major end-user of fasteners which defines or describes dimensional characteristics, limits of size, acceptable materials, processing, functional behavior, plating, baking, inspecting, testing, packaging, and required markings of any fastener”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/6"},"text":"Pub. L. 104–113, § 11(b)(6)","children":[],"tail":", redesignated par. (14) as (13). Former par. (13) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/8"},"text":"Pub. L. 104–113, § 11(b)(8)","children":[],"tail":", inserted “for the purpose of achieving a uniform hardness” after “quenching and tempering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/6"},"text":"Pub. L. 104–113, § 11(b)(6)","children":[],"tail":", redesignated par. (15) as (14). Former par. (14) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/b/6"},"text":"Pub. L. 104–113, § 11(b)(6)","children":[],"tail":", redesignated par. (15) as (14)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a4c0f36-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a4c0f37-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Comptroller General Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/34/s12"},"text":"Pub. L. 106–34, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/125"},"text":"113 Stat. 125","children":[],"tail":", provided that not later than 2 years after "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", the Comptroller General would transmit to the Congress a report describing any changes in industry practice resulting from or apparently resulting from the enactment of paragraph (6)(B) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
