{"tag":"section","attrib":{"id":"id7897a86d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278p"},"text":null,"children":[{"tag":"num","attrib":{"value":"278p"},"text":"§ 278p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7897a86e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of reprogramming","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any funds authorized for carrying out this chapter are subject to a reprogramming action that requires notice to be provided to the Appropriations Committees of the House of Representatives and the Senate, notice of such action shall concurrently be provided to the Committee on Science of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7897a86f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of reorganization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7897a870-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide notice to the Committees on Science and Appropriations of the House of Representatives, and the Committees on Commerce, Science, and Transportation and Appropriations of the Senate, not later than 15 days before any major reorganization of any program, project, or activity of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7897a871-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Major reorganization” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “major reorganization” means any reorganization of the Institute that involves the reassignment of more than 25 percent of the employees of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7897a872-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s31"},"text":"Mar. 3, 1901, ch. 872, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/309/s4/b"},"text":"Pub. L. 105–309, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2935"},"text":"112 Stat. 2935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7897a873-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7897a874-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7897a875-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Science of House of Representatives changed to Committee on Science and Technology of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Science and Technology of House of Representatives changed to Committee on Science, Space, and Technology of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, "},{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
