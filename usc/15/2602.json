{"tag":"section","attrib":{"id":"id79f16bd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602"},"text":null,"children":[{"tag":"num","attrib":{"value":"2602"},"text":"§ 2602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f16bd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ","children":[{"tag":"ref","attrib":{"idref":"fn002455"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002455"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" term “Administrator” means the Administrator of the Environmental Protection Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f16bd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), the term “chemical substance” means any organic or inorganic substance of a particular molecular identity, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f16bd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of such substances occurring in whole or in part as a result of a chemical reaction or occurring in nature, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any element or uncombined radical.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f16bdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such term does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f16bdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mixture,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pesticide (as defined in the Federal Insecticide, Fungicide, and Rodenticide Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"7 U.S.C. 136","children":[],"tail":" et seq.]) when manufactured, processed, or distributed in commerce for use as a pesticide,"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tobacco or any tobacco product,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any source material, special nuclear material, or byproduct material (as such terms are defined in the Atomic Energy Act of 1954 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.] and regulations issued under such Act),"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16be0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any article the sale of which is subject to the tax imposed by section 4181 of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4181"},"text":"26 U.S.C. 4181","children":[],"tail":"] (determined without regard to any exemptions from such tax provided by section 4182 or 4221 or any other provision of such Code) and any component of such an article (limited to shot shells, cartridges, and components of shot shells and cartridges), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16be1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any food, food additive, drug, cosmetic, or device (as such terms are defined in section 201 of the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"21 U.S.C. 321","children":[],"tail":"]) when manufactured, processed, or distributed in commerce for use as a food, food additive, drug, cosmetic, or device."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The term “food” as used in clause (vi) of this subparagraph includes poultry and poultry products (as defined in sections 4(e) and 4(f) of the Poultry Products Inspection Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s453/e"},"text":"21 U.S.C. 453(e)","children":[],"tail":" and (f)]), meat and meat food products (as defined in section 1(j) of the Federal Meat Inspection Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s601/j"},"text":"21 U.S.C. 601(j)","children":[],"tail":"]), and eggs and egg products (as defined in section 4 of the Egg Products Inspection Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1033"},"text":"21 U.S.C. 1033","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commerce” means trade, traffic, transportation, or other commerce (A) between a place in a State and any place outside of such State, or (B) which affects trade, traffic, transportation, or commerce described in clause (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “conditions of use” means the circumstances, as determined by the Administrator, under which a chemical substance is intended, known, or reasonably foreseen to be manufactured, processed, distributed in commerce, used, or disposed of.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “distribute in commerce” and “distribution in commerce” when used to describe an action taken with respect to a chemical substance or mixture or article containing a substance or mixture mean to sell, or the sale of, the substance, mixture, or article in commerce; to introduce or deliver for introduction into commerce, or the introduction or delivery for introduction into commerce of, the substance, mixture, or article; or to hold, or the holding of, the substance, mixture, or article after its introduction into commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “environment” includes water, air, and land and the interrelationship which exists among and between water, air, and land and all living things.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “guidance” means any significant written guidance of general applicability prepared by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health and safety study” means any study of any effect of a chemical substance or mixture on health or the environment or on both, including underlying information and epidemiological studies, studies of occupational exposure to a chemical substance or mixture, toxicological, clinical, and ecological studies of a chemical substance or mixture, and any test performed pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “manufacture” means to import into the customs territory of the United States (as defined in general note 2 of the Harmonized Tariff Schedule of the United States), produce, or manufacture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16be9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “mixture” means any combination of two or more chemical substances if the combination does not occur in nature and is not, in whole or in part, the result of a chemical reaction; except that such term does include any combination which occurs, in whole or in part, as a result of a chemical reaction if none of the chemical substances comprising the combination is a new chemical substance and if the combination could have been manufactured for commercial purposes without a chemical reaction at the time the chemical substances comprising the combination were combined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “new chemical substance” means any chemical substance which is not included in the chemical substance list compiled and published under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2607/b"},"text":"section 2607(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16beb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “potentially exposed or susceptible subpopulation” means a group of individuals within the general population identified by the Administrator who, due to either greater susceptibility or greater exposure, may be at greater risk than the general population of adverse health effects from exposure to a chemical substance or mixture, such as infants, children, pregnant women, workers, or the elderly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “process” means the preparation of a chemical substance or mixture, after its manufacture, for distribution in commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f16bed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the same form or physical state as, or in a different form or physical state from, that in which it was received by the person so preparing such substance or mixture, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f16bee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of an article containing the chemical substance or mixture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “processor” means any person who processes a chemical substance or mixture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “protocols and methodologies for the development of information” means a prescription of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79f16bf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f16bf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health and environmental effects, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to toxicity, persistence, and other characteristics which affect health and the environment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for which information for a chemical substance or mixture are to be developed and any analysis that is to be performed on such information, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79f16bf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent necessary to assure that information respecting such effects and characteristics are reliable and adequate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79f16bf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which such information are ","children":[{"tag":"ref","attrib":{"idref":"fn002456"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002456"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “is”."}],"tail":" to be developed,"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specification of any test protocol or methodology to be employed in the development of such information, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79f16bf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/15/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other requirements as are necessary to provide such assurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, the Canal Zone, American Samoa, the Northern Mariana Islands, or any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2602/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States”, when used in the geographic sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f16bfa-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tI/s3"},"text":"Pub. L. 94–469, title I, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2004"},"text":"90 Stat. 2004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/c/1"},"text":"Pub. L. 99–519, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2989"},"text":"100 Stat. 2989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tI/s1214/e/1"},"text":"Pub. L. 100–418, title I, § 1214(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1156"},"text":"102 Stat. 1156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tIII/s315"},"text":"Pub. L. 114–92, div. A, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/791"},"text":"129 Stat. 791","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI"},"text":"Pub. L. 114–182, title I","children":[],"tail":", §§ 3, 19(c), "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/448"},"text":"130 Stat. 448","children":[],"tail":", 505.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f16bfb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f16bfc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79f16bfd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Insecticide, Fungicide, and Rodenticide Act, referred to in par. (2)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/973"},"text":"86 Stat. 973","children":[],"tail":", which is classified generally to subchapter II (§ 136 et seq.) of chapter 6 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in par. (2)(B)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", and amended, which is classified principally to chapter 23 (§ 2011 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule of the United States, referred to in par. (9), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, Governor of the Canal Zone, and Panama Canal Company, referred to in par. (16), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f16bfe-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Pars. (4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s3/1"},"text":"Pub. L. 114–182, § 3(1)","children":[],"tail":"–(3), added pars. (4) and (7) and redesignated former pars. (4) and (5) as (5) and (6), respectively. Former pars. (6) and (7) redesignated (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s19/c/1"},"text":"Pub. L. 114–182, § 19(c)(1)","children":[],"tail":", substituted “information” for “data”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s3/1"},"text":"Pub. L. 114–182, § 3(1)","children":[],"tail":", redesignated par. (6) as (8). Former par. (8) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s3/1"},"text":"Pub. L. 114–182, § 3(1)","children":[],"tail":", (4), added par. (12) and redesignated former pars. (7) to (11) as (9), (10), (11), (13), and (14), respectively. Former pars. (12) to (14) redesignated (15) to (17), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s19/c/2/A"},"text":"Pub. L. 114–182, § 19(c)(2)(A)","children":[],"tail":", (B), in introductory provisions, substituted “protocols and methodologies for the development of information” for “standards for the development of test data”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s3/1"},"text":"Pub. L. 114–182, § 3(1)","children":[],"tail":", redesignated par. (12) as (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s19/c/2/C"},"text":"Pub