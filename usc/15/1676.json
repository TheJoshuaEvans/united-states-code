{"tag":"section","attrib":{"id":"id79a06639-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1676"},"text":null,"children":[{"tag":"num","attrib":{"value":"1676"},"text":"§ 1676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by Secretary of Labor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor, acting through the Wage and Hour Division of the Department of Labor, shall enforce the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79a0663a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s306"},"text":"Pub. L. 90–321, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/164"},"text":"82 Stat. 164","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
