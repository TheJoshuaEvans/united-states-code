{"tag":"section","attrib":{"id":"id77ae0b68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"§ 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts; duty of United States attorneys; procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several district courts of the United States are invested with jurisdiction to prevent and restrain violations of sections 1 to 7 of this title; and it shall be the duty of the several United States attorneys, in their respective districts, under the direction of the Attorney General, to institute proceedings in equity to prevent and restrain such violations. Such proceedings may be by way of petition setting forth the case and praying that such violation shall be enjoined or otherwise prohibited. When the parties complained of shall have been duly notified of such petition the court shall proceed, as soon as may be, to the hearing and determination of the case; and pending such petition and before final decree, the court may at any time make such temporary restraining order or prohibition as shall be deemed just in the premises.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ae0b69-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-02/ch647/s4"},"text":"July 2, 1890, ch. 647, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/209"},"text":"26 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s1"},"text":"June 25, 1948, ch. 646, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ae0b6a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ae0b6b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77ae0b6c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1911-03-03"},"text":"Mar. 3, 1911","children":[],"tail":", vested jurisdiction in “district” courts, instead of “circuit” courts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77ae0b6d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id77ae0b6e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", substituted “United States attorneys” for “district attorneys of the United States”. See section 541 et seq. of Title 28, Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
