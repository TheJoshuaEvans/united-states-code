{"tag":"section","attrib":{"id":"id7964bb8c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141"},"text":null,"children":[{"tag":"num","attrib":{"value":"1141"},"text":"§ 1141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7964bb8d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “basic application” means the application for the registration of a mark that has been filed with an Office of a Contracting Party and that constitutes the basis for an application for the international registration of that mark.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb8e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “basic registration” means the registration of a mark that has been granted by an Office of a Contracting Party and that constitutes the basis for an application for the international registration of that mark.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb8f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting Party","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Contracting Party” means any country or inter-governmental organization that is a party to the Madrid Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb90-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of recordal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “date of recordal” means the date on which a request for extension of protection, filed after an international registration is granted, is recorded on the International Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of bona fide intention to use the mark in commerce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “declaration of bona fide intention to use the mark in commerce” means a declaration that is signed by the applicant for, or holder of, an international registration who is seeking extension of protection of a mark to the United States and that contains a statement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7964bb92-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant or holder has a bona fide intention to use the mark in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7964bb93-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person making the declaration believes himself or herself, or the firm, corporation, or association in whose behalf he or she makes the declaration, to be entitled to use the mark in commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7964bb94-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no other person, firm, corporation, or association, to the best of his or her knowledge and belief, has the right to use such mark in commerce either in the identical form of the mark or in such near resemblance to the mark as to be likely, when used on or in connection with the goods of such other person, firm, corporation, or association, to cause confusion, mistake, or deception.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb95-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “extension of protection” means the protection resulting from an international registration that extends to the United States at the request of the holder of the international registration, in accordance with the Madrid Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holder of an international registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A “holder” of an international registration is the natural or juristic person in whose name the international registration is recorded on the International Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international application” means an application for international registration that is filed under the Madrid Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “International Bureau” means the International Bureau of the World Intellectual Property Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “International Register” means the official collection of data concerning international registrations maintained by the International Bureau that the Madrid Protocol or its implementing regulations require or permit to be recorded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international registration” means the registration of a mark granted under the Madrid Protocol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International registration date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international registration date” means the date assigned to the international registration by the International Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Madrid Protocol","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Madrid Protocol” means the Protocol Relating to the Madrid Agreement Concerning the International Registration of Marks, adopted at Madrid, Spain, on ","children":[{"tag":"date","attrib":{"date":"1989-06-27"},"text":"June 27, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of refusal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “notification of refusal” means the notice sent by the United States Patent and Trademark Office to the International Bureau declaring that an extension of protection cannot be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bb9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of a Contracting Party","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Office of a Contracting Party” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7964bb9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office, or governmental entity, of a Contracting Party that is responsible for the registration of marks; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7964bba0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the common office, or governmental entity, of more than 1 Contracting Party that is responsible for the registration of marks and is so recognized by the International Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bba1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of origin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “office of origin” means the Office of a Contracting Party with which a basic application was filed or by which a basic registration was granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7964bba2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opposition period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “opposition period” means the time allowed for filing an opposition in the United States Patent and Trademark Office, including any extension of time granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7964bba3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title XII, § 60, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13402"},"text":"Pub. L. 107–273, div. C, title III, § 13402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1913"},"text":"116 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7964bba4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7964bba5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7964bba6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13403"},"text":"Pub. L. 107–273, div. C, title III, § 13403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1920"},"text":"116 Stat. 1920","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/273/dC/tIII/s13403"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This subtitle [subtitle D (§§ 13401–13403) of title III of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", enacting this subchapter and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"] and the amendments made by this subtitle shall take effect on the later of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Madrid Protocol (as defined in section 60 of the Trademark Act of 1946 [this section]) enters into force with respect to the United States [","children":[{"tag":"date","attrib":{"date":"2003-11-02"},"text":"Nov. 2, 2003","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date occurring 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
