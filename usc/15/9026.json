{"tag":"section","attrib":{"id":"id7a9d3bd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026"},"text":null,"children":[{"tag":"num","attrib":{"value":"9026"},"text":"§ 9026.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary financing of short-time compensation payments in States with programs in law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a9d3bd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), there shall be paid to a State an amount equal to 100 percent of the amount of short-time compensation paid under a short-time compensation program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":") under the provisions of the State law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments made to a State under paragraph (1) shall be payable by way of reimbursement in such amounts as the Secretary estimates the State will be entitled to receive under this section for each calendar month, reduced or increased, as the case may be, by any amount by which the Secretary finds that the Secretary’s estimates for any prior calendar month were greater or less than the amounts which should have been paid to the State. Such estimates may be made on the basis of such statistical, sampling, or other method as may be agreed upon by the Secretary and the State agency of the State involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bd4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a9d3bd5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General payment limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payments shall be made to a State under this section for short-time compensation paid to an individual by the State during a benefit year in excess of 26 times the amount of regular compensation (including dependents’ allowances) under the State law payable to such individual for a week of total unemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a9d3bd6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employer limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payments shall be made to a State under this section for benefits paid to an individual by the State under a short-time compensation program if such individual is employed by the participating employer on a seasonal, temporary, or intermittent basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments to a State under subsection (a) shall be available for weeks of unemployment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on or after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on or before ","children":[{"tag":"date","attrib":{"date":"2021-09-06"},"text":"September 6, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b)(2), if at any point after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", the State enacts a State law providing for the payment of short-time compensation under a short-time compensation program that meets the definition of such a program under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306/v"},"text":"section 3306(v) of title 26","children":[],"tail":", the State shall be eligible for payments under this section after the effective date of such enactment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding and certifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are appropriated, out of moneys in the Treasury not otherwise appropriated, such sums as may be necessary for purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3bdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall from time to time certify to the Secretary of the Treasury for payment to each State the sums payable to such State under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a9d3bde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a9d3bdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a9d3be0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9026/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State; State agency; State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “State”, “State agency”, and “State law” have the meanings given those terms in section 205 of the Federal-State Extended Unemployment Compensation Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"26 U.S.C. 3304","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a9d3be1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tII/s2108"},"text":"Pub. L. 116–136, div. A, title II, § 2108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/328"},"text":"134 Stat. 328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tII/s207"},"text":"Pub. L. 116–260, div. N, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1956"},"text":"134 Stat. 1956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/2/tIX/s9017"},"text":"Pub. L. 117–2, title IX, § 9017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/120"},"text":"135 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a9d3be2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a9d3be3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a9d3be4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Federal-State Extended Unemployment Compensation Act of 1970, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/373/s205"},"text":"section 205 of Pub. L. 91–373","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a9d3be5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s2108"},"text":"section 2108 of Pub. L. 116–136","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s2108"},"text":"section 2108 of Pub. L. 116–136","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3306"},"text":"section 3306 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a9d3be6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2"},"text":"Pub. L. 117–2","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-09-06"},"text":"September 6, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2021-03-14"},"text":"March 14, 2021","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2021-03-14"},"text":"March 14, 2021","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
