{"tag":"section","attrib":{"id":"id79bd153d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693k"},"text":"§ 1693k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compulsory use of electronic fund transfers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd153e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" condition the extension of credit to a consumer on such consumer’s repayment by means of preauthorized electronic fund transfers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd153f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a consumer to establish an account for receipt of electronic fund transfers with a particular financial institution as a condition of employment or receipt of a government benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bd1540-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIX/s913"},"text":"Pub. L. 90–321, title IX, § 913","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXX/s2001"},"text":"Pub. L. 95–630, title XX, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3737"},"text":"92 Stat. 3737","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
