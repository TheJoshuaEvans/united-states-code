{"tag":"section","attrib":{"id":"id78a6000b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s382"},"text":null,"children":[{"tag":"num","attrib":{"value":"382"},"text":"§ 382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of net income taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a6000c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State, or political subdivision thereof, shall have power to assess, after ","children":[{"tag":"date","attrib":{"date":"1959-09-14"},"text":"September 14, 1959","children":[],"tail":", any net income tax which was imposed by such State or political subdivision, as the case may be, for any taxable year ending on or before such date, on the income derived within such State by any person from interstate commerce, if the imposition of such tax for a taxable year ending after such date is prohibited by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a6000d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of subsection (a) shall not be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a6000e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s382/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to invalidate the collection, on or before ","children":[{"tag":"date","attrib":{"date":"1959-09-14"},"text":"September 14, 1959","children":[],"tail":", of any net income tax imposed for a taxable year ending on or before such date, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a6000f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s382/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit the collection, after ","children":[{"tag":"date","attrib":{"date":"1959-09-14"},"text":"September 14, 1959","children":[],"tail":", of any net income tax which was assessed on or before such date for a taxable year ending on or before such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a60010-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/272/tI/s102"},"text":"Pub. L. 86–272, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/556"},"text":"73 Stat. 556","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
