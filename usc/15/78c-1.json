{"tag":"section","attrib":{"id":"id78018298-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"78c–1"},"text":"§ 78c–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swap agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78018299-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [Reserved]","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7801829a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-based swap agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7801829b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The definition of “security” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/10"},"text":"section 78c(a)(10) of this title","children":[],"tail":" does not include any security-based swap agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801829c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission is prohibited from registering, or requiring, recommending, or suggesting, the registration under this chapter of any security-based swap agreement. If the Commission becomes aware that a registrant has filed a registration application with respect to such a swap agreement, the Commission shall promptly so notify the registrant. Any such registration with respect to such a swap agreement shall be void and of no force or effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801829d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78p/a"},"text":"section 78p(a) of this title","children":[],"tail":" with respect to reporting requirements, the Commission is prohibited from—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7801829e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgating, interpreting, or enforcing rules; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801829f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing orders of general applicability;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"under this chapter in a manner that imposes or specifies reporting or recordkeeping requirements, procedures, or standards as prophylactic measures against fraud, manipulation, or insider trading with respect to any security-based swap agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id780182a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" References in this chapter to the “purchase” or “sale” of a security-based swap agreement shall be deemed to mean the execution, termination (prior to its scheduled maturity date), assignment, exchange, or similar transfer or conveyance of, or extinguishing of rights or obligations under, a security-based swap agreement, as the context may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id780182a1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 3A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tIII/s303/a"},"text":"Pub. L. 106–554, § 1(a)(5) [title III, § 303(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–452; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s762/d/1"},"text":"Pub. L. 111–203, title VII, § 762(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1760"},"text":"124 Stat. 1760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id780182a2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id780182a3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id780182a4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text