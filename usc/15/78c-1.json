"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the later of 360 days after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle B (§§ 761–774) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle B, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s774"},"text":"section 774 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
