{"tag":"section","attrib":{"id":"id7a82fd46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8222"},"text":null,"children":[{"tag":"num","attrib":{"value":"8222"},"text":"§ 8222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of reinsurer solvency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a82fd47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domiciliary State regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State of domicile of a reinsurer is an NAIC-accredited State or has financial solvency requirements substantially similar to the requirements necessary for NAIC accreditation, such State shall be solely responsible for regulating the financial solvency of the reinsurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a82fd48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondomiciliary States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a82fd49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8222/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on financial information requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State of domicile of a reinsurer is an NAIC-accredited State or has financial solvency requirements substantially similar to the requirements necessary for NAIC accreditation, no other State may require the reinsurer to provide any additional financial information other than the information the reinsurer is required to file with its domiciliary State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a82fd4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8222/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No provision of this section shall be construed as preventing or prohibiting a State that is not the State of domicile of a reinsurer from receiving a copy of any financial statement filed with its domiciliary State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a82fd4b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s532"},"text":"Pub. L. 111–203, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1595"},"text":"124 Stat. 1595","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
