{"tag":"section","attrib":{"id":"id7a49c5a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302"},"text":"§ 5302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c5a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “applicant” means:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c5a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of educational institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of an educational institution or educational institutions with one or more of the following: Government-owned laboratories, private research organizations, nonprofit institutions, or private firms;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that is located in a region where the metal casting industry is concentrated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “census region” means one of the four census regions (Northeast, South, Midwest, and West) that are designated as census regions by the Bureau of the Census as of ","children":[{"tag":"date","attrib":{"date":"1990-10-15"},"text":"October 15, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Department” means the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “educational institution” means a degree granting institution of at least a baccalaureate level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “non-Federal source” means the United States metal casting industry, related industries, industry-related associations, individuals, organizations, universities, State agencies, or other entities supporting the metal casting industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “metal casting industry” or “industry” means the industries identified by codes numbered 3321, 3322, 3324, 3325, 3363, 3364, 3365, 3366, and 3369, in the Standard Industrial Classification manual ","children":[{"tag":"ref","attrib":{"idref":"fn002541"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002541"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" published by the Office of Management and Budget in 1987;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c5ae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/425/s3"},"text":"Pub. L. 101–425, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/915"},"text":"104 Stat. 915","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
