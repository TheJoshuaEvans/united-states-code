{"tag":"section","attrib":{"id":"id7aa923fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9305"},"text":null,"children":[{"tag":"num","attrib":{"value":"9305"},"text":"§ 9305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, the Entity shall focus its support for sustainable chemistry activities on those that achieve, to the highest extent practicable, the goals outlined in the chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7aa923fb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s265"},"text":"Pub. L. 116–283, div. A, title II, § 265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3502"},"text":"134 Stat. 3502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa923fc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa923fd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aa923fe-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subtitle”, meaning subtitle E (§§ 261–267) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA"},"text":"Pub. L. 116–283, div. A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3497"},"text":"134 Stat. 3497","children":[],"tail":", which is classified principally to this chapter. For complete classification of subtitle E to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
