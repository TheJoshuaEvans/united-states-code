{"tag":"section","attrib":{"id":"id79c440e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1801"},"text":null,"children":[{"tag":"num","attrib":{"value":"1801"},"text":"§ 1801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the public interest of maintaining a newspaper press editorially and reportorially independent and competitive in all parts of the United States, it is hereby declared to be the public policy of the United States to preserve the publication of newspapers in any city, community, or metropolitan area where a joint operating arrangement has been heretofore entered into because of economic distress or is hereafter effected in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c440e5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/353/s2"},"text":"Pub. L. 91–353, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/466"},"text":"84 Stat. 466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c440e6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c440e7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79c440e8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/353/s1"},"text":"Pub. L. 91–353, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/466"},"text":"84 Stat. 466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/353/s1"},"text":"“This Act [enacting this chapter] may be cited as the ‘Newspaper Preservation Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id79c440e9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/353/s6"},"text":"Pub. L. 91–353, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/467"},"text":"84 Stat. 467","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/353/s6"},"text":"“If any provision of this Act [enacting this chapter] is declared unconstitutional, or the applicability thereof to any person or circumstance is held invalid, the validity of the remainder of this Act, and the applicability of such provision to any other person or circumstance, shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
