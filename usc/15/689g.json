{"tag":"section","attrib":{"id":"id79293a4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g"},"text":null,"children":[{"tag":"num","attrib":{"value":"689g"},"text":"§ 689g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational assistance grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79293a4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this section, the Administrator may make grants to New Markets Venture Capital companies and to other entities, as authorized by this part, to provide operational assistance to smaller enterprises financed, or expected to be financed, by such companies or other entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made under this subsection shall be made over a multiyear period not to exceed 10 years, under such other terms as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to specialized small business investment companies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293a53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this section, the Administrator may make grants to specialized small business investment companies to provide operational assistance to smaller enterprises financed, or expected to be financed, by such companies after the effective date of the New Markets Venture Capital Program Act of 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293a54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds of a grant made under this paragraph may be used by the company receiving such grant only to provide operational assistance in connection with an equity investment (made with capital raised after the effective date of the New Markets Venture Capital Program Act of 2000) in a business located in a low-income geographic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293a55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A specialized small business investment company shall be eligible for a grant under this section only if the company submits to the Administrator, in such form and manner as the Administrator may require, a plan for use of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293a57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Markets Venture Capital companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant made under this subsection to a New Markets Venture Capital company shall be equal to the resources (in cash or in kind) raised by the company under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s689c/d/2"},"text":"section 689c(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293a58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant made under this subsection to any entity other than a New Markets Venture Capital company shall be equal to the resources (in cash or in kind) raised by the entity in accordance with the requirements applicable to New Market Venture Capital companies set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s689c/d/2"},"text":"section 689c(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount made available to carry out this section is insufficient for the Administrator to provide grants in the amounts provided for in paragraph (4), the Administrator shall make pro rata reductions in the amounts otherwise payable to each company and entity under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make supplemental grants to New Markets Venture Capital companies and to other entities, as authorized by this part under such terms as the Administrator may require, to provide additional operational assistance to smaller enterprises financed, or expected to be financed, by the companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may require, as a condition of any supplemental grant made under this subsection, that the company or entity receiving the grant provide from resources (in a ","children":[{"tag":"ref","attrib":{"idref":"fn002259"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002259"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The article probably should not appear."}],"tail":" cash or in kind), other then "},{"tag":"ref","attrib":{"idref":"fn002260"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002260"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “than”."}],"tail":" those provided by the Administrator, a matching contribution equal to the amount of the supplemental grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the assistance made available under this section may be used for any overhead or general and administrative expense of a New Markets Venture Capital company or a specialized small business investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293a5e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s358"},"text":"Pub. L. 85–699, title III, § 358","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–660.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79293a5f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79293a60-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79293a61-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of the New Markets Venture Capital Program Act of 2000, referred to in subsec. (a)(3)(A), (B), probably means the date of enactment of section 1 of H.R. 5663, as enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8"},"text":"Pub. L. 106–554, § 1(a)(8)","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
