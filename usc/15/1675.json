{"tag":"section","attrib":{"id":"id79a06634-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1675"},"text":null,"children":[{"tag":"num","attrib":{"value":"1675"},"text":"§ 1675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for State-regulated garnishments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may by regulation exempt from the provisions of section 1673(a) and (b)(2) of this title garnishments issued under the laws of any State if he determines that the laws of that State provide restrictions on garnishment which are substantially similar to those provided in section 1673(a) and (b)(2) of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79a06635-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIII/s305"},"text":"Pub. L. 90–321, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/164"},"text":"82 Stat. 164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/30/tV/s501/e/4"},"text":"Pub. L. 95–30, title V, § 501(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-05-23"},"text":"May 23, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/162"},"text":"91 Stat. 162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a06636-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a06637-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a06638-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/30"},"text":"Pub. L. 95–30","children":[],"tail":" substituted “section 1673(a) and (b)(2) of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1673/a"},"text":"section 1673(a) of this title","children":[],"tail":"” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
