{"tag":"section","attrib":{"id":"id796be8b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232"},"text":null,"children":[{"tag":"num","attrib":{"value":"1232"},"text":"§ 1232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Label and entry requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Every manufacturer of new automobiles distributed in commerce shall, prior to the delivery of any new automobile to any dealer, or at or prior to the introduction date of new models delivered to a dealer prior to such introduction date, securely affix to the windshield, or side window of such automobile a label on which such manufacturer shall endorse clearly, distinctly and legibly true and correct entries disclosing the following information concerning such automobile—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796be8b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the make, model, and serial or identification number or numbers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final assembly point;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, and the location of the place of business, of the dealer to whom it is to be delivered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the city or town at which it is to be delivered to such dealer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of transportation used in making delivery of such automobile, if driven or towed from final assembly point to place of delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796be8bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retail price of such automobile suggested by the manufacturer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retail delivered price suggested by the manufacturer for each accessory or item of optional equipment, physically attached to such automobile at the time of its delivery to such dealer, which is not included within the price of such automobile as stated pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount charged, if any, to such dealer for the transportation of such automobile to the location at which it is delivered to such dealer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total of the amounts specified pursuant to paragraphs (1), (2), and (3);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if one or more safety ratings for such automobile have been assigned and formally published or released by the National Highway Traffic Safety Administration under the New Car Assessment Program, information about safety ratings that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796be8c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a graphic depiction of the number of stars, or other applicable rating, that corresponds to each such assigned safety rating displayed in a clearly differentiated fashion indicating the maximum possible safety rating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refers to safety rating categories that may include frontal impact crash tests, side impact crash tests, and rollover resistance tests (whether or not such automobile has been assigned a safety rating for such tests);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains information describing the nature and meaning of the crash test data presented and a reference to additional vehicle safety resources, including http://www.safecar.gov; ","children":[{"tag":"ref","attrib":{"idref":"fn002309"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002309"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “http://www.safercar.gov;”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is presented in a legible, visible, and prominent fashion and covers at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796be8c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 8 percent of the total area of the label; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796be8c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area with a minimum length of 4½ inches and a minimum height of 3½ inches; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1232/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an automobile has not been tested by the National Highway Traffic Safety Administration under the New Car Assessment Program, or safety ratings for such automobile have not been assigned in one or more rating categories, a statement to that effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796be8c7-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/506/s3"},"text":"Pub. L. 85–506, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/326"},"text":"72 Stat. 326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10307/a"},"text":"Pub. L. 109–59, title X, § 10307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1941"},"text":"119 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31314"},"text":"Pub. L. 112–141, div. C, title I, § 31314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/772"},"text":"126 Stat. 772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be8c8-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796be8c9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id796be8ca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" inserted “safety rating categories that may include” after “refers to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s10307/a/2"},"text":"Pub. L. 109–59, § 10307(a)(2)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s10307/a/1"},"text":"Pub. L. 109–59, § 10307(a)(1)","children":[],"tail":", (3), (4), added subsecs. (g) and (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be8cb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id796be8cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id796be8cd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of ","children":[{"tag":"date","attrib":{"date":"1958-10-01"},"text":"Oct. 1, 1958","children":[],"tail":", or the first day of the introduction of any new model of automobile in any line of automobile beginning after "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/506/s5"},"text":"section 5 of Pub. L. 85–506","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1231"},"text":"section 1231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id796be8ce-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10307/b"},"text":"Pub. L. 109–59, title X, § 10307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1942"},"text":"119 Stat. 1942","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tX/s10307/b"},"text":"“The Secretary of Transportation shall issue regulations to ensure that the labeling requirements under subsections (g) and (h) of section 3 of the Automobile Information Disclosure Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1232/g"},"text":"15 U.S.C. 1232(g)","children":[],"tail":", (h)], as added by subsection (a), are implemented by "},{"tag":"date","attrib":{"date":"2007-09-01"},"text":"September 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
