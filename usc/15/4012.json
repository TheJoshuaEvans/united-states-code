{"tag":"section","attrib":{"id":"id7a31d065-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012"},"text":null,"children":[{"tag":"num","attrib":{"value":"4012"},"text":"§ 4012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for issuance of certificate of review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a31d066-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written form; limitation to export trade; compliance with regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To apply for a certificate of review, a person shall submit to the Secretary a written application which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31d067-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies conduct limited to export trade, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d068-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a form and contains any information, including information pertaining to the overall market in which the applicant operates, required by rule or regulation promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4020"},"text":"section 4020 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a31d069-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of notice of application; transmittal to Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a31d06a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within ten days after an application submitted under subsection (a) is received by the Secretary, the Secretary shall publish in the Federal Register a notice that announces that an application for a certificate of review has been submitted, identifies each person submitting the application, and describes the conduct for which the application is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a31d06b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than seven days after an application submitted under subsection (a) is received by the Secretary, the Secretary shall transmit to the Attorney General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a31d06c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the application,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d06d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information submitted to the Secretary in connection with the application, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a31d06e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4012/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information (as determined by the Secretary) in the possession of the Secretary, including information regarding the market share of the applicant in the line of commerce to which the conduct specified in the application relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a31d06f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290/tIII/s302"},"text":"Pub. L. 97–290, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1240"},"text":"96 Stat. 1240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a31d070-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a31d071-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a31d072-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after effective date of rules and regulations first promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4020"},"text":"section 4020 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/290/s312/b"},"text":"section 312(b) of Pub. L. 97–290","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4011"},"text":"section 4011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
