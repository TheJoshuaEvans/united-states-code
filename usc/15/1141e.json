{"tag":"section","attrib":{"id":"id7964bbba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1141e"},"text":"§ 1141e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of protection of an international registration to the United States under the Madrid Protocol","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7964bbbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1141h"},"text":"section 1141h of this title","children":[],"tail":", the holder of an international registration shall be entitled to the benefits of extension of protection of that international registration to the United States to the extent necessary to give effect to any provision of the Madrid Protocol."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7964bbbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1141e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" If the United States is office of origin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where the United States Patent and Trademark Office is the office of origin for a trademark application or registration, any international registration based on such application or registration cannot be used to obtain the benefits of the Madrid Protocol in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7964bbbd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title XII, § 65, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13402"},"text":"Pub. L. 107–273, div. C, title III, § 13402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1916"},"text":"116 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
