{"tag":"section","attrib":{"id":"id7a87b7f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8512a"},"text":"§ 8512a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Learning excellence and good examples from new developers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b7f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b7f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administration” means the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Under Secretary of Commerce for Oceans and Atmosphere and Administrator of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earth Prediction Innovation Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Earth Prediction Innovation Center” means the community global weather research modeling system described in paragraph (5)(E) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8512/b"},"text":"section 8512(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “model” means any vetted numerical model and associated data assimilation of the Earth’s system or its components—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b7f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed, in whole or in part, by scientists and engineers employed by the Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b7f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise developed, in whole or in part, using Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “open license” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502/21"},"text":"section 3502(21) of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational model","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational model” means any model that has an output used by the Administration for operational functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suitable model","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “suitable model” means a model that meets the requirements described in paragraph (5)(E)(ii) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8512/b"},"text":"section 8512(b) of this title","children":[],"tail":", as determined by the Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b7fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support innovation in modeling by allowing interested stakeholders to have easy and complete access to operational model codes and to other models, as the Administrator determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use vetted innovations arising from access described in paragraph (1) to improve modeling by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan and implementation of plan to make certain models and data available to the public","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b800-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop and implement a plan to make available to the public, at no cost and with no restrictions on copying, publishing, distributing, citing, adapting, or otherwise using under an open license, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b801-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational models developed by the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b802-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Models that are not operational models, including experimental and developmental models, as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b803-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Applicable information and documentation for models described in subparagraphs (A) and (B), including a description of intended model outputs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b804-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (f), all data owned by the Federal Government and data that the Administrator has the legal right to redistribute that are associated with models made available to the public pursuant to the plan and used in operational forecasting by the Administration, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a87b805-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant metadata; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b806-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data used for operational models used by the Administration as of ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b807-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accommodations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and implementing the plan under paragraph (1), the Administrator may make such accommodations as the Administrator considers appropriate to ensure that the public release of any model, information, documentation, or data pursuant to the plan do ","children":[{"tag":"ref","attrib":{"idref":"fn002597"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002597"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “does”."}],"tail":" not jeopardize—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b808-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b809-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intellectual property or redistribution rights, including under titles 17 and 35;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b80a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trade secret or commercial or financial information subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b80b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any models or data that are otherwise restricted by contract or other written agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b80c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mission of the Administration to protect lives and property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b80d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and implementing the plan under paragraph (1), the Administrator shall prioritize making available to the public the models described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b80e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections for privacy and statistical information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and implementing the plan under subsection (a), the Administrator shall ensure that all requirements incorporated into any models described in paragraph (1)(A) ensure compliance with statistical laws and other relevant data protection requirements, including the protection of any personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b80f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain models","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and implementing the plan under paragraph (1), the Administrator may exclude models that the Administrator determines will be retired or superseded in fewer than 5 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b810-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Platforms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraphs (1) and (2), the Administrator may use government servers, contracts or agreements with a private vendor, or any other platform consistent with the purpose of this title.","children":[{"tag":"ref","attrib":{"idref":"fn002598"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002598"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b811-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall plan for and establish a program to support infrastructure, including telecommunications and technology infrastructure of the Administration and the platforms described in paragraph (6), relevant to making operational models and data available to the public pursuant to the plan under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b812-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b813-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to review models and leverage innovations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b814-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the mission of the Earth Prediction Innovation Center, periodically review innovations and improvements made by persons not employed by the Administration as Federal employees to the operational models made available to the public pursuant to the plan under subsection (c)(1) in order to improve the accuracy and timeliness of forecasts of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b815-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator identifies an innovation for a suitable model, develop and implement a plan to use the innovation to improve the model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b816-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b817-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Administrator shall submit to the appropriate congressional committees a report on the implementation of this section that includes a description of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b818-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of the plan required by subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b819-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the process of the Administration under subsection (d)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a87b81a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for engaging with interested stakeholders to learn what innovations those stakeholders have found;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b81b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for reviewing those innovations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a87b81c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for operationalizing innovations to improve suitable models; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b81d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any Federal financial assistance, including under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of this title","children":[],"tail":" "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" or the Crowdsourcing and Citizen Science Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3724"},"text":"15 U.S.C. 3724","children":[],"tail":"), in order to facilitate and incentivize the sharing of externally developed improvements for testing, evaluation, validation, and application to further improve the mission of the Administration, and any other Administration priorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b81e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a87b81f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a87b820-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Science, Space, and Technology and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b821-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of national security interests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b822-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, for models developed in whole or in part with the Department of Defense, the Administrator, in consultation with the Secretary of Defense, as appropriate, shall withhold any model or data if the Administrator or the Secretary of Defense determines doing so to be necessary to protect the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b823-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to supersede any other provision of law governing the protection of the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b824-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8512a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $2,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b825-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/tCVI/s10601"},"text":"Pub. L. 117–263, div. J, title CVI, § 10601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3995"},"text":"136 Stat. 3995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a87b826-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a87b827-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a87b828-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c)(6), means title CVI of div. J of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which enacted this section and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8512"},"text":"section 8512 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"Section 3719 of this title","children":[],"tail":", referred to in subsec. (e)(1)(C), was in the original “section 24 of the Stevenson-Wydler Technology Innovation Act of 1990” and was translated as reading “section 24 of the Stevenson-Wydler Technology Innovation Act of 1980”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Crowdsourcing and Citizen Science Act, referred to in subsec. (e)(1)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIV/s402"},"text":"section 402 of title IV of Pub. L. 114–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3019"},"text":"130 Stat. 3019","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3724"},"text":"section 3724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a87b829-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Weather Research and Forecasting Innovation Act of 2017 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/s10601"},"text":"section 10601 of div. J of Pub. L. 117–263","children":[],"tail":". Subsec. (c)(8) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dJ/s10601"},"text":"section 10601 of div. J of Pub. L. 117–263","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s8512"},"text":"section 8512 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
