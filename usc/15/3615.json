{"tag":"section","attrib":{"id":"id7a1ebd18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3615"},"text":null,"children":[{"tag":"num","attrib":{"value":"3615"},"text":"§ 3615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonexclusion of other statutory rights and remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The rights and remedies provided by this chapter shall be in addition to any and all other rights and remedies that may exist under Federal or State law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a1ebd19-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s616"},"text":"Pub. L. 96–399, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1680"},"text":"94 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
