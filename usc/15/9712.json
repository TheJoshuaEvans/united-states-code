{"tag":"section","attrib":{"id":"id7ab509b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9712"},"text":null,"children":[{"tag":"num","attrib":{"value":"9712"},"text":"§ 9712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to the public of flood-related data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab509b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make flood-related data available to the public on the website of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make the data under subsection (a) freely accessible or available at a cost that does not exceed the cost of preparing the data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab509ba-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s17"},"text":"Pub. L. 117–316, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4418"},"text":"136 Stat. 4418","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
