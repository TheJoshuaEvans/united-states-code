{"tag":"section","attrib":{"id":"id78f00161-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b"},"text":null,"children":[{"tag":"num","attrib":{"value":"637b"},"text":"§ 637b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78f00162-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any contract to be let by any Federal agency, such agency shall provide to any small business concern upon its request—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f00163-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of bid sets and specifications with respect to such contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f00164-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and telephone number of an employee of such agency to answer questions with respect to such contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f00165-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate citations to each major Federal law or agency rule with which such business concern must comply in performing such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78f00166-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to any contract or subcontract under such contract which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78f00167-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be performed entirely outside any State, territory, or possession of the United States, the District of Columbia, or the Commonwealth of Puerto Rico; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78f00168-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s637b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for services which are personal in nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78f00169-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/507/tII/s223"},"text":"Pub. L. 95–507, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-24"},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1772"},"text":"92 Stat. 1772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78f0016a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78f0016b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78f0016c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
