{"tag":"section","attrib":{"id":"id7a57f60a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6310"},"text":null,"children":[{"tag":"num","attrib":{"value":"6310"},"text":"§ 6310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of supervising boxing commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each promoter who intends to hold a professional boxing match in a State that does not have a boxing commission shall, not later than 14 days before the intended date of that match, provide written notification to the supervising boxing commission designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6303"},"text":"section 6303 of this title","children":[],"tail":". Such notification shall contain each of the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f60b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6310/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assurances that, with respect to that professional boxing match, all applicable requirements of this chapter will be met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f60c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6310/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The name of any person who, at the time of the submission of the notification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f60d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6310/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under suspension from a boxing commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f60e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6310/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be involved in organizing or participating in the event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f60f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6310/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any individual listed under paragraph (2), the identity of the boxing commission that issued the suspension described in paragraph (2)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f610-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s19"},"text":"Pub. L. 104–272, § 19","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3312"},"text":"110 Stat. 3312","children":[],"tail":"; renumbered § 19, "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/1"},"text":"Pub. L. 106–210, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f611-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a57f612-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a57f613-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"Jan. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23"},"text":"section 23 of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
