{"tag":"section","attrib":{"id":"id7a912e51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852"},"text":null,"children":[{"tag":"num","attrib":{"value":"8852"},"text":"§ 8852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Quantum Information Science Research Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912e52-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e53-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, acting through the Director of the Office of Science (referred to in this section as the “Director”), shall ensure that the Office of Science carries out a program, in consultation with other Federal departments and agencies, as appropriate, to establish and operate at least 2, but not more than 5, National Quantum Information Science Research Centers (referred to in this section as “Centers”) to conduct basic research to accelerate scientific breakthroughs in quantum information science and technology and to support research conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8851"},"text":"section 8851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e54-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e55-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive, merit-reviewed process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Centers shall be established through a competitive, merit-reviewed process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e56-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible applicant under this subsection shall submit to the Director an application at such time, in such manner, and containing such information as the Director determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e57-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall consider applications from National Laboratories, institutions of higher education, research centers, multi-institutional collaborations, and any other entity that the Secretary of Energy determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e58-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A collaboration that receives an award under this section may include multiple types of research institutions and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Centers developed, constructed, operated, or maintained under this section shall serve the needs of the Department of Energy, industry, the academic community, and other relevant entities to create and develop processes for the purpose of advancing basic research in quantum information science and improving the competitiveness of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e5a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall ensure the coordination, and avoid unnecessary duplication, of the activities of each Center with the activities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e5b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other research entities of the Department of Energy, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e5c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nanoscale Science Research Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e5d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Energy Frontier Research Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e5e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Energy Innovation Hubs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e5f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e60-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e61-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e62-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e63-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Center established under this section is authorized to carry out activities for a period of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e64-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reapplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An awardee may reapply for additional, subsequent periods of 5 years. The Director shall approve or disapprove of each reapplication on a competitive, merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e65-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the authorities of the Department of Energy, the Secretary of Energy may terminate an underperforming Center for cause during the performance period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e66-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8852/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall allocate up to $25,000,000 for each Center established under this section for each of fiscal years 2019 through 2023, subject to the availability of appropriations. Amounts made available to carry out this section shall be derived from amounts appropriated or otherwise made available to the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912e67-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tIV/s402"},"text":"Pub. L. 115–368, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5101"},"text":"132 Stat. 5101","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
