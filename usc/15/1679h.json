{"tag":"section","attrib":{"id":"id79a2d6bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679h"},"text":"§ 1679h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a2d6be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compliance with the requirements imposed under this subchapter with respect to credit repair organizations shall be enforced under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.] by the Federal Trade Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d6bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of this subchapter treated as violations of Federal Trade Commission Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d6c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of the exercise by the Federal Trade Commission of the Commission’s functions and powers under the Federal Trade Commission Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.], any violation of any requirement or prohibition imposed under this subchapter with respect to credit repair organizations shall constitute an unfair or deceptive act or practice in commerce in violation of section 5(a) of the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a"},"text":"15 U.S.C. 45(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority under other law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All functions and powers of the Federal Trade Commission under the Federal Trade Commission Act shall be available to the Commission to enforce compliance with this subchapter by any person subject to enforcement by the Federal Trade Commission pursuant to this subsection, including the power to enforce the provisions of this subchapter in the same manner as if the violation had been a violation of any Federal Trade Commission trade regulation rule, without regard to whether the credit repair organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d6c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets any other jurisdictional tests in the Federal Trade Commission Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a2d6c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State action for violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a2d6c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to such other remedies as are provided under State law, whenever the chief law enforcement officer of a State, or an official or agency designated by a State, has reason to believe that any person has violated or is violating this subchapter, the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d6c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may bring an action to enjoin such violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may bring an action on behalf of its residents to recover damages for which the person is liable to such residents under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679g"},"text":"section 1679g of this title","children":[],"tail":" as a result of the violation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any successful action under subparagraph (A) or (B), shall be awarded the costs of the action and reasonable attorney fees as determined by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a2d6ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall serve prior written notice of any civil action under paragraph (1) upon the Federal Trade Commission and provide the Commission with a copy of its complaint, except in any case where such prior notice is not feasible, in which case the State shall serve such notice immediately upon instituting such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a2d6cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall have the right—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a2d6cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to intervene in any action referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a2d6cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon so intervening, to be heard on all matters arising in the action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a2d6ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file petitions for appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigatory powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of bringing any action under this subsection, nothing in this subsection shall prevent the chief law enforcement officer, or an official or agency designated by a State, from exercising the powers conferred on the chief law enforcement officer or such official by the laws of such State to conduct investigations or to administer oaths or affirmations or to compel the attendance of witnesses or the production of documentary and other evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a2d6d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679h/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Federal Trade Commission has instituted a civil action for violation of this subchapter, no State may, during the pendency of such action, bring an action under this section against any defendant named in the complaint of the Commission for any violation of this subchapter that is alleged in that complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a2d6d1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s410"},"text":"Pub. L. 90–321, title IV, § 410","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-460"},"text":"110 Stat. 3009–460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a2d6d2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a2d6d3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a2d6d4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Trade Commission Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311"},"text":"act Sept. 26, 1914, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/717"},"text":"38 Stat. 717","children":[],"tail":", which is classified generally to subchapter I (§ 41 et seq.) of chapter 2 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a2d6d5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a2d6d6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after the end of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except with respect to contracts entered into by a credit repair organization before the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s413"},"text":"section 413 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
