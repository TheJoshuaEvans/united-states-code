{"tag":"section","attrib":{"id":"id7926c834-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s687c"},"text":null,"children":[{"tag":"num","attrib":{"value":"687c"},"text":"§ 687c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions and other orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7926c835-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s687c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds; jurisdiction of court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever, in the judgment of the Administration, a licensee or any other person has engaged or is about to engage in any acts or practices which constitute or will constitute a violation of any provision of this chapter, or of any rule or regulation under this chapter, or of any order issued under this chapter, the Administration may make application to the proper district court of the United States or a United States court of any place subject to the jurisdiction of the United States for an order enjoining such acts or practices, or for an order enforcing compliance with such provision, rule, regulation, or order, and such courts shall have jurisdiction of such actions and, upon a showing by the Administration that such licensee or other person has engaged or is about to engage in any such acts or practices, a permanent or temporary injunction, restraining order, or other order, shall be granted without bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7926c836-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s687c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity jurisdiction of licensee and assets thereof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any such proceeding the court as a court of equity may, to such extent as it deems necessary, take exclusive jurisdiction of the licensee or licensees and the assets thereof, wherever located; and the court shall have jurisdiction in any such proceeding to appoint a trustee or receiver to hold or administer under the direction of the court the assets so possessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7926c837-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s687c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusteeship or receivership over licensee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration shall have authority to act as trustee or receiver of the licensee. Upon request by the Administration, the court may appoint the Administration to act in such capacity unless the court deems such appointment inequitable or otherwise inappropriate by reason of the special circumstances involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7926c838-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s311"},"text":"Pub. L. 85–699, title III, § 311","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/341/s9"},"text":"Pub. L. 87–341, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-03"},"text":"Oct. 3, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/755"},"text":"75 Stat. 755","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/779/s6"},"text":"Pub. L. 89–779, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-06"},"text":"Nov. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1360"},"text":"80 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/15/C"},"text":"Pub. L. 98–620, title IV, § 402(15)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3358"},"text":"98 Stat. 3358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7926c839-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7926c83a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7926c83b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsec. (a), see References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7926c83c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out provision that the proceedings in such a case had to be made a preferred cause and had to be expedited in every way."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/779"},"text":"Pub. L. 89–779","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7926c83d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7926c83e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
