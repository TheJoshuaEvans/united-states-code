{"tag":"section","attrib":{"id":"id794f5f1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s791"},"text":null,"children":[{"tag":"num","attrib":{"value":"791"},"text":"§ 791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purposes of this chapter are (1) to provide for a means to assist in meeting the essential needs of the United States for fuels, in a manner which is consistent, to the fullest extent practicable, with existing national commitments to protect and improve the environment, and (2) to provide requirements for reports respecting energy resources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id794f5f1d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/319/s1/b"},"text":"Pub. L. 93–319, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/246"},"text":"88 Stat. 246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794f5f1e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id794f5f1f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id794f5f20-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/319"},"text":"Pub. L. 93–319","children":[],"tail":" which, in addition to enacting this chapter and provision set out as a note under this section, enacted sections 1857c–10 and 1857f–6f of Title 42, The Public Health and Welfare, and amended sections 1857b–1, 1857c–5, 1857c–8, 1857c–9, 1857d–1, 1857f–1, 1857f–6e, 1857f–7, 1857h–5, and 1857"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 42. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794f5f21-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id794f5f22-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/319/s1/a"},"text":"Pub. L. 93–319, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-22"},"text":"June 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/246"},"text":"88 Stat. 246","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/pl/93/319"},"text":"Pub. L. 93–319","children":[],"tail":" [enacting this chapter, enacting sections 1857c–10 and 1857f–6f of Title 42, The Public Health and Welfare, and amending sections 1857b–1, 1857c–5, 1857c–8, 1857c–9, 1857d–1, 1857f–1, 1857f–6e, 1857f–7, 1857h–5, and 1857"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 42] may be cited as the “Energy Supply and Environmental Coordination Act of 1974”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
