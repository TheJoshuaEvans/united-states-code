{"tag":"section","attrib":{"id":"id791d5336-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s"},"text":null,"children":[{"tag":"num","attrib":{"value":"657s"},"text":"§ 657s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on subcontracting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d5337-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If awarded a contract under section 637(a), 637(m), 644(a), 657a, or 657f of this title, a covered small business concern—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5338-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract for services, may not expend on subcontractors more than 50 percent of the amount paid to the concern under the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5339-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract for supplies (other than from a regular dealer in such supplies), may not expend on subcontractors more than 50 percent of the amount, less the cost of materials, paid to the concern under the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d533a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a contract described in paragraphs (1) and (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d533b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine for which category, services (as described in paragraph (1)) or supplies (as described in paragraph (2)), the greatest percentage of the contract is awarded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d533c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine the amount awarded under the contract for that category of services or supplies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d533d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not expend on subcontractors, with respect to the amount determined under subparagraph (B), more than 50 percent of that amount; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d533e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a contract which is principally for supplies from a regular dealer in such supplies, and which is not a contract principally for services or construction, shall supply the product of a domestic small business manufacturer or processor, unless a waiver of such requirement is granted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d533f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Administrator, after reviewing a determination by the applicable contracting officer that no small business manufacturer or processor can reasonably be expected to offer a product meeting the specifications (including period for performance) required by the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5340-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Administrator for a product (or class of products), after determining that no small business manufacturer or processor is available to participate in the Federal procurement market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5341-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Similarly situated entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contract amounts expended by a covered small business concern on a subcontractor that is a similarly situated entity shall not be considered subcontracted for purposes of determining whether the covered small business concern has violated a requirement established under subsection (a) or (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5342-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications of percentages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may change, by rule (after providing notice and an opportunity for public comment), a percentage specified in paragraphs (1) through (4) of subsection (a) if the Administrator determines that such change is necessary to reflect conventional industry practices among business concerns that are below the numerical size standard for businesses in that industry category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5343-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5344-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a category of contracts to which a requirement under subsection (a) does not apply, the Administrator is authorized to establish, by rule (after providing notice and an opportunity for public comment), a requirement that a covered small business concern may not expend on subcontractors more than a specified percentage of the amount paid to the concern under a contract in that category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5345-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniformity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A requirement established under paragraph (1) shall apply to all covered small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5346-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish, through public rulemaking, requirements similar to those specified in paragraph (1) to be applicable to contracts for general and specialty construction and to contracts for any other industry category not otherwise subject to the requirements of such paragraph. The percentage applicable to any such requirement shall be determined in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5347-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5348-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered small business concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered small business concern” means a business concern that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5349-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a contract awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"section 637(a) of this title","children":[],"tail":", is a small business concern eligible to receive contracts under that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d534a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a contract awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/m"},"text":"section 637(m) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id791d534b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a small business concern owned and controlled by women (as defined in that section); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d534c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a small business concern owned and controlled by women (as defined in that section) that is not less than 51 percent owned by 1 or more women who are economically disadvantaged (and such ownership is determined without regard to any community property law);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d534d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a contract awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s644/a"},"text":"section 644(a) of this title","children":[],"tail":", is a small business concern;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d534e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a contract awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657a"},"text":"section 657a of this title","children":[],"tail":", is a qualified HUBZone small business concern; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d534f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a contract awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657f"},"text":"section 657f of this title","children":[],"tail":", is a small business concern owned and controlled by service-disabled veterans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5350-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Similarly situated entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “similarly situated entity” means a subcontractor that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5351-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a subcontractor for a small business concern, is a small business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5352-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a subcontractor for a small business concern eligible to receive contracts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"section 637(a) of this title","children":[],"tail":", is such a concern;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5353-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a subcontractor for a small business concern owned and controlled by women (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/m"},"text":"section 637(m) of this title","children":[],"tail":"), is such a concern;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5354-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a subcontractor for a small business concern owned and controlled by women (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/m"},"text":"section 637(m) of this title","children":[],"tail":") that is not less than 51 percent owned by 1 or more women who are economically disadvantaged (and such ownership is determined without regard to any community property law), is such a concern;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5355-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a subcontractor for a qualified HUBZone small business concern, is such a concern; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5356-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657s/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a subcontractor for a small business concern owned and controlled by service-disabled veterans, is such a concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d5357-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s46"},"text":"Pub. L. 85–536, § 2[46]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1651"},"text":"Pub. L. 112–239, div. A, title XVI, § 1651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2079"},"text":"126 Stat. 2079","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s864/b"},"text":"Pub. L. 114–92, div. A, title VIII, § 864(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/927"},"text":"129 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791d5358-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791d5359-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id791d535a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “which is principally for supplies from a regular dealer in such supplies, and which is not a contract principally for services or construction” for “for supplies from a regular dealer in such supplies” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id791d535b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id791d535c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability of Requirement To Review and Justify Certain Contracts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVI/s1615"},"text":"Pub. L. 113–66, div. A, title XVI, § 1615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/950"},"text":"127 Stat. 950","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dA/tXVI/s1615"},"text":"“In the case of a contract to which the provisions of section 46 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657s"},"text":"15 U.S.C. 657s","children":[],"tail":") apply, the requirements under section 802 of the National Defense Authorization Act for Fiscal Year 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Public Law 112–239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/126/1824"},"text":"126 Stat. 1824","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304"},"text":"10 U.S.C. 2304","children":[],"tail":" note [now 10 U.S.C. note prec.]) do not apply.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
