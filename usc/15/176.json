{"tag":"section","attrib":{"id":"id7884958e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s176"},"text":null,"children":[{"tag":"num","attrib":{"value":"176"},"text":"§ 176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of commercial statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A purpose of the Bureau of Foreign and Domestic Commerce is the collection, arrangement, and classification of such statistical information as may be procured, showing, or tending to show, each year the condition of the manufactures, domestic trade, currency, and banks of the several States and Territories.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7884958f-552d-11f1-9071-ff305b7c3ff0"},"text":"(R.S. § 335; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-02-27/ch69/s1"},"text":"Feb. 27, 1877, ch. 69, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/241"},"text":"19 Stat. 241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/407"},"text":"37 Stat. 407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78849590-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78849591-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78849592-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 335 derived from Res. ","children":