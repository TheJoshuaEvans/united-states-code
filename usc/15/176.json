fer of functions of Bureau of Foreign and Domestic Commerce, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
