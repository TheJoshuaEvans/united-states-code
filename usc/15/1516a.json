{"tag":"section","attrib":{"id":"id7983dcb7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1516a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1516a"},"text":"§ 1516a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistics relating to social, health, and economic conditions of Americans of Spanish origin or descent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Commerce, the Department of Labor, the Department of Health and Human Services, and the Department of Agriculture shall each collect, and publish regularly, statistics which indicate the social, health, and economic condition of Americans of Spanish origin or descent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7983dcb8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/311/s2"},"text":"Pub. L. 94–311, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-16"},"text":"June 16, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/688"},"text":"90 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7983dcb9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7983dcba-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7983dcbb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted for “Department of Health, Education, and Welfare” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7983dcbc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Development of Program for the Collection, Analysis and Publication of Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/311/s3"},"text":"Pub. L. 94–311, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-16"},"text":"June 16, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/688"},"text":"90 Stat. 688","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/311/s3"},"text":"“The Director of the Office of Management and Budget, in cooperation with the Secretary of Commerce and with the heads of other data-gathering Federal agencies, shall develop a Government-wide program for the collection, analysis, and publication of data with respect to Americans of Spanish origin or descent.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
