{"tag":"section","attrib":{"id":"id79a0664e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679a"},"text":"§ 1679a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a0664f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer” means an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06650-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer credit transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer credit transaction” means any transaction in which credit is offered or extended to an individual for personal, family, or household purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06651-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit repair organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “credit repair organization”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06652-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any person who uses any instrumentality of interstate commerce or the mails to sell, provide, or perform (or represent that such person can or will sell, provide, or perform) any service, in return for the payment of money or other valuable consideration, for the express or implied purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a06653-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving any consumer’s credit record, credit history, or credit rating; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a06654-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing advice or assistance to any consumer with regard to any activity or service described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06655-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a06656-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonprofit organization which is exempt from taxation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a06657-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any creditor (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"), with respect to any consumer, to the extent the creditor is assisting the consumer to restructure any debt owed by the consumer to the creditor; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a06658-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any depository institution (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813"},"text":"section 1813 of title 12","children":[],"tail":") or any Federal or State credit union (as those terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of title 12","children":[],"tail":"), or any affiliate or subsidiary of such a depository institution or credit union."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06659-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “credit” has the meaning given to such term in section 1602(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002366"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002366"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a0665a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s403"},"text":"Pub. L. 90–321, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-455"},"text":"110 Stat. 3009–455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a0665b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a0665c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id79a0665d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602/e"},"text":"Section 1602(e) of this title","children":[],"tail":", referred to in par. (4), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602/f"},"text":"section 1602(f) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/1/A"},"text":"Pub. L. 111–203, title X, § 1100A(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/s