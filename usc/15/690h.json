{"tag":"section","attrib":{"id":"id792b8406-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h"},"text":null,"children":[{"tag":"num","attrib":{"value":"690h"},"text":"§ 690h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational assistance grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792b8407-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b8408-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants to Renewable Fuel Capital Investment companies to provide operational assistance to smaller enterprises financed, or expected to be financed, by such companies or other entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b8409-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection shall be made over a multiyear period not to exceed 10 years, under such other terms as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b840a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant made under this subsection to a Renewable Fuel Capital Investment company shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792b840b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the resources (in cash or in-kind) raised by the company under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690c/d/2"},"text":"section 690c(d)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b840c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b840d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount made available to carry out this section is insufficient for the Administrator to provide grants in the amounts provided for in paragraph (3), the Administrator shall make pro rata reductions in the amounts otherwise payable to each company and entity under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b840e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to conditionally approved companies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792b840f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B) and (C), upon the request of a company conditionally approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690c/c"},"text":"section 690c(c) of this title","children":[],"tail":", the Administrator shall make a grant to the company under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b8410-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment by companies not approved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a company receives a grant under this paragraph and does not enter into a participation agreement for final approval, the company shall, subject to controlling Federal law, repay the amount of the grant to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b8411-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction of grant to approved company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a company receives a grant under this paragraph and receives final approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690c/e"},"text":"section 690c(e) of this title","children":[],"tail":", the Administrator shall deduct the amount of the grant from the total grant amount the company receives for operational assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b8412-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No company may receive a grant of more than $100,000 under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b8413-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b8414-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make supplemental grants to Renewable Fuel Capital Investment companies and to other entities, as authorized by this part, under such terms as the Administrator may require, to provide additional operational assistance to smaller enterprises financed, or expected to be financed, by the companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b8415-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may require, as a condition of any supplemental grant made under this subsection, that the company or entity receiving the grant provide from resources (in a ","children":[{"tag":"ref","attrib":{"idref":"fn002266"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002266"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The article probably should not appear."}],"tail":" cash or in kind), other then "},{"tag":"ref","attrib":{"idref":"fn002267"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “than”."}],"tail":" those provided by the Administrator, a matching contribution equal to the amount of the supplemental grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b8416-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the assistance made available under this section may be used for any overhead or general and administrative expense of a Renewable Fuel Capital Investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b8417-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s389"},"text":"Pub. L. 85–699, title III, § 389","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1781"},"text":"121 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
