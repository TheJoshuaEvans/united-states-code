{"tag":"section","attrib":{"id":"id7ab299ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704"},"text":null,"children":[{"tag":"num","attrib":{"value":"9704"},"text":"§ 9704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service coordination hydrologists at River Forecast Centers of the National Weather Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab299ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of service coordination hydrologists","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Weather Service (in this section referred to as the “Director”) shall designate at least 1 service coordination hydrologist at each River Forecast Center of the National Weather Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance by other employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Performance of the responsibilities outlined in this section is not limited to the service coordination hydrologist position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary role of service coordination hydrologists","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The primary role of the service coordination hydrologist shall be to carry out the responsibilities required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), consistent with the analysis described in section 409 of the Weather Research and Forecasting Innovation Act of 2017 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25"},"text":"Public Law 115–25","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/131/112"},"text":"131 Stat. 112","children":[],"tail":"), and in order to increase impact-based decision support services, each service coordination hydrologist designated under subsection (a) shall, with respect to hydrology—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for providing service to the geographic area of responsibility covered by the River Forecast Center at which the service coordination hydrologist is employed to help ensure that users of products and services of the National Weather Service can respond effectively to improve outcomes from flood events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liaise with users of products and services of the National Weather Service, such as the public, academia, media outlets, users in the hydropower, transportation, recreation, and agricultural communities, and forestry, land, fisheries, and water management interests, to evaluate the adequacy and usefulness of the products and services of the National Weather Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with such River Forecast Centers and Weather Forecast Offices and Federal, State, local, and Tribal government agencies as the Director considers appropriate in developing, proposing, and implementing plans to develop, modify, or tailor products and services of the National Weather Service to improve the usefulness of such products and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in interagency partnerships with Federal, State, local, and Tribal government agencies to explore the use of forecast-informed reservoir operations to reduce flood risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the maintenance and accuracy of flooding call lists, appropriate office flooding policy or procedures, and other flooding information or dissemination methodologies or strategies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work closely with Federal, State, local, and Tribal emergency and floodplain management agencies, and other agencies relating to disaster management, to ensure a planned, coordinated, and effective preparedness and response effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may assign a responsibility set forth in paragraph (1) to such other staff as the Director considers appropriate to carry out such responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab299fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a service coordination hydrologist designated under subsection (a) may, with respect to hydrology—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with a State agency to develop plans for promoting more effective use of products and services of the National Weather Service throughout the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify priority community preparedness objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop plans to meet the objectives identified under subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab29a00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct flooding event preparedness planning and citizen education efforts with and through various State, local, and Tribal government agencies and other disaster management-related organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29a01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9704/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may assign a responsibility set forth in paragraph (1) to such other staff as the Director considers appropriate to carry out such responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab29a02-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s5"},"text":"Pub. L. 117–316, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4408"},"text":"136 Stat. 4408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab29a03-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab29a04-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab29a05-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 409 of the Weather Research and Forecasting Innovation Act of 2017, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s409"},"text":"section 409 of Pub. L. 115–25","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/112"},"text":"131 Stat. 112","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
