{"tag":"section","attrib":{"id":"id79bf5f96-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701"},"text":null,"children":[{"tag":"num","attrib":{"value":"1701"},"text":"§ 1701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bf5f97-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Director” means the Director of the Bureau of Consumer Financial Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f98-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual, or an unincorporated organization, partnership, association, corporation, trust, or estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f99-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “subdivision” means any land which is located in any State or in a foreign country and is divided or is proposed to be divided into lots, whether contiguous or not, for the purpose of sale or lease as part of a common promotional plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f9a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “common promotional plan” means a plan, undertaken by a single developer or a group of developers acting in concert, to offer lots for sale or lease; where such land is offered for sale by such a developer or group of developers acting in concert, and such land is contiguous or is known, designated, or advertised as a common unit or by a common name, such land shall be presumed, without regard to the number of lots covered by each individual offering, as being offered for sale or lease as part of a common promotional plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f9b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “developer” means any person who, directly or indirectly, sells or leases, or offers to sell or lease, or advertises for sale or lease any lots in a subdivision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f9c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agent” means any person who represents, or acts for or on behalf of, a developer in selling or leasing, or offering to sell or lease, any lot or lots in a subdivision; but shall not include an attorney at law whose representation of another person consists solely of rendering legal services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f9d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “blanket encumbrance” means a trust deed, mortgage, judgment, or any other lien or encumbrance, including an option or contract to sell or a trust agreement, affecting a subdivision or affecting more than one lot offered within a subdivision except that such term shall not include any lien or other encumbrance arising as the result of the imposition of any tax assessment by any public authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f9e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “interstate commerce” means trade or commerce among the several States or between any foreign country and any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5f9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” includes the several States, the District of Columbia, the Commonwealth of Puerto Rico, and the territories and possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5fa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “purchaser” means an actual or prospective purchaser or lessee of any lot in a subdivision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5fa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “offer” includes any inducement, solicitation, or attempt to encourage a person to acquire a lot in a subdivision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bf5fa2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1701/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Bureau” means the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bf5fa3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIV/s1402"},"text":"Pub. L. 90–448, title XIV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/590"},"text":"82 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVIII/s812/a"},"text":"Pub. L. 93–383, title VIII, § 812(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/736"},"text":"88 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/tIV/s401"},"text":"Pub. L. 96–153, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1122"},"text":"93 Stat. 1122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tX/s1089/a"},"text":"Pub. L. 100–628, title X, § 1089(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3283"},"text":"102 Stat. 3283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1098A/4"},"text":"Pub. L. 111–203, title X, § 1098A(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2105"},"text":"124 Stat. 2105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79bf5fa4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79bf5fa5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79bf5fa6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1098A/4/A"},"text":"Pub. L. 111–203, § 1098A(4)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “ ‘Secretary’ means the Secretary of Housing and Urban Development;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1098A/4/B"},"text":"Pub. L. 111–203, § 1098A(4)(B)","children":[],"tail":"–(D), added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/628"},"text":"Pub. L. 100–628","children":[],"tail":" inserted “and” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" substituted provisions defining “subdivision” as the division or proposed division of land into lots for the purpose of sale or lease as part of a common promotional plan, for provisions defining “subdivision” as the division or proposed division of land into fifty or more lots for the purpose of sale or lease as part of a common promotional plan and presumptions respecting activities as being deemed part of such common promotional plan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153"},"text":"Pub. L. 96–153","children":[],"tail":" added par. (4) and redesignated former pars. (4) to (10) as (5) to (11), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/s812/a/1"},"text":"Pub. L. 93–383, § 812(a)(1)","children":[],"tail":", inserted “, located in any State or in a foreign country” after “any land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/s812/a/2"},"text":"Pub. L. 93–383, § 812(a)(2)","children":[],"tail":", inserted “or between any foreign country and any State” after “States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79bf5fa7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79bf5fa8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79bf5fa9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/153/tIV/s410"},"text":"Pub. L. 96–153, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1132"},"text":"93 Stat. 1132","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/153/tIV/s410"},"text":"“The amendments made by this title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1719a"},"text":"section 1719a of this title","children":[],"tail":" and amending this section and sections 1702, 1703, 1708, 1709, 1711, 1715, and 1717 of this title] shall become effective on the effective date of regulations implementing such amendments, but in no case later than six months following the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":"], except that section 1403(b)(7) of the Interstate Land Sales Full Disclosure Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1702/b/7"},"text":"section 1702(b)(7) of this title","children":[],"tail":"], contained in the amendment made by section 402, shall become effective on the date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79bf5faa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIV/s1423"},"text":"Pub. L. 90–448, title XIV, § 1423","children":[],"tail":", formerly § 1422, "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/599"},"text":"82 Stat. 599","children":[],"tail":", as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/96/153/tIV/s409"},"text":"Pub. L. 96–153, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-21"},"text":"Dec. 21, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1132"},"text":"93 Stat. 1132","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/153/tIV/s409"},"text":"“This title [enacting this chapter] shall take effect upon the expiration of two hundred and seventy days after the date of its enactment [","children":[{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79bf5fab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXIV/s1401"},"text":"Pub. L. 90–448, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/590"},"text":"82 Stat. 590","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/448/tXIV/s1401"},"text":"“This title [enacting this chapter] may be cited as the ‘Interstate Land Sales Full Disclosure Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
