{"tag":"section","attrib":{"id":"id791d535d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t"},"text":null,"children":[{"tag":"num","attrib":{"value":"657t"},"text":"§ 657t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Credit Risk Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d535e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Administration the Office of Credit Risk Management (in this section referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d535f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall be responsible for supervising—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5360-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any lender making loans under section 7(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"15 U.S.C. 636(a)","children":[],"tail":"] (in this section referred to as a “7(a) lender”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5361-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Lending Partner or Intermediary participant of the Administration in a lending program of the Office of Capital Access of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5362-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any small business lending company or a non-Federally regulated lender without regard to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5363-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5364-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by the Director of the Office of Credit Risk Management (in this section referred to as the “Director”), who shall be a career appointee in the Senior Executive Service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5365-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be responsible for oversight of the lenders and participants described in subsection (b), including by conducting periodic reviews of the compliance and performance of such lenders and participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5366-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision duties for 7(a) lenders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5367-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to 7(a) lenders, an employee of the Office shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5368-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be present for and supervise any such review that is conducted by a contractor of the Office on the premise ","children":[{"tag":"ref","attrib":{"idref":"fn002248"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002248"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “premises”."}],"tail":" of the 7(a) lender; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5369-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise any such review that is not conducted on the premise ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the 7(a) lender."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d536a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review report timeline","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d536b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other requirements of the Office or the Administrator, the Administrator shall develop and implement a review report timeline which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d536c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the Administrator to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id791d536d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver a written report of the review to the 7(a) lender not later than 60 business days after the date on which the review is concluded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id791d536e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator expects to submit the report after the end of the 60-day period described in clause (i), notify the 7(a) lender of the expected date of submission of the report and the reason for the delay; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d536f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a response by the 7(a) lender is requested in a report submitted under subparagraph (A), require the 7(a) lender to submit responses to the Administrator not later than 45 business days after the date on which the 7(a) lender receives the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5370-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may extend the time frame described in subparagraph (A)(i)(II) with respect to a 7(a) lender as the Administrator determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5371-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement authority against 7(a) lenders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5372-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informal enforcement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may take an informal enforcement action against a 7(a) lender if the Director finds that the 7(a) lender has violated a statutory or regulatory requirement under section 7(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"15 U.S.C. 636(a)","children":[],"tail":"] or any requirement in a Standard Operating Procedures Manual or Policy Notice related to a program or function of the Office of Capital Access."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5373-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formal enforcement authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d5374-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the approval of the Lender Oversight Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657u"},"text":"section 657u of this title","children":[],"tail":", the Director may take a formal enforcement action against any 7(a) lender if the Director finds that the 7(a) lender has violated—"}],"tail":null},{"tag":"clause","attrib":{"id":"id791d5375-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statutory or regulatory requirement under section 7(a), including a requirement relating to credit elsewhere; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d5376-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement described in a Standard Operating Procedures Manual or Policy Notice, related to a program or function of the Office of Capital Access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5377-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An enforcement action imposed on a 7(a) lender by the Director under subparagraph (A) shall be based on the severity or frequency of the violation and may include assessing a civil monetary penalty against the 7(a) lender in an amount that is not greater than $250,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5378-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal by lender","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A 7(a) lender may appeal an enforcement action imposed by the Director described in this subsection to the Office of Hearings and Appeals established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s634/i"},"text":"section 634(i) of this title","children":[],"tail":" or to an appropriate district court of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5379-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", the Administrator shall issue regulations, after opportunity for notice and comment, to carry out subsection (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d537a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Servicing and liquidation responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During any period during which a 7(a) lender is suspended or otherwise prohibited from making loans under section 7(a) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"15 U.S.C. 636(a)","children":[],"tail":"], the 7(a) lender shall remain obligated to maintain all servicing and liquidation activities delegated to the lender by the Administrator, unless otherwise specified by the Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d537b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portfolio risk analysis of 7(a) loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d537c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall annually conduct a risk analysis of the portfolio of the Administration with respect to all loans guaranteed under section 7(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d537d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2018-12-01"},"text":"December 1, 2018","children":[],"tail":", and every December 1 thereafter, the Director shall submit to Congress a report containing the results of each portfolio risk analysis conducted under paragraph (1) during the fiscal year preceding the submission of the report, which shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791d537e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the overall program risk of loans guaranteed under section 7(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d537f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the program risk, set forth separately by industry concentration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5380-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without identifying individual 7(a) lenders by name, a consolidated analysis of the risk created by the individual 7(a) lenders responsible for not less than 1 percent of the gross loan approvals set forth separately for the year covered by the report by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id791d5381-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar value of the loans made by such 7(a) lenders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id791d5382-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of loans made by such 7(a) lenders;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5383-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken by the Administrator to mitigate the risks identified in subparagraphs (A), (B), and (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5384-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of 7(a) lenders, the number of loans made, and the gross and net dollar amount of loans made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5385-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and dollar amount of total losses, the number and dollar amount of total purchases, and the percentage and dollar amount of recoveries at the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5386-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of enforcement actions recommended by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5387-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of enforcement actions approved by the Lender Oversight Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657u"},"text":"section 657u of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5388-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of enforcement actions disapproved by the Lender Oversight Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791d5389-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/h/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and dollar amount of civil monetary penalties assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d538a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget submission and justification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall annually provide, in writing, a fiscal year budget submission for the Office and a justification for such submission to the Administrator. Such submission and justification shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d538b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include salaries and expenses of the Office and the charge for the lender oversight fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d538c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted at or about the time of the budget submission by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d538d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657t/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be maintained in an indexed form and made available for public review for a period of not less than 5 years beginning on the date of submission and justification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d538e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s47"},"text":"Pub. L. 85–536, § 2[47]","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/a/2"},"text":"Pub. L. 115–189, § 3(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1492"},"text":"132 Stat. 1492","children":[],"tail":", 1495.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791d538f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791d5390-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id791d5391-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2[47] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536"},"text":"Pub. L. 85–536","children":[],"tail":" was renumbered section 2[49] and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id791d5392-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/b"},"text":"Pub. L. 115–189, § 3(b)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “With respect to 7(a) lenders, an employee of the Office shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) be present for and supervise any such review that is conducted by a contractor of the Office on the premise of the 7(a) lender; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) supervise any such review that is not conducted on the premise of the 7(a) lender.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id791d5393-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id791d5394-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/d/1"},"text":"Pub. L. 115–189, § 3(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1496"},"text":"132 Stat. 1496","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/189/s3/d/1"},"text":"“Any reference in a law, regulation, guidance, document, paper, or other record of the United States to the Office of Credit Risk Management of the Small Business Administration shall be deemed a reference to the Office of Credit Risk Management, established under section 47 of the Small Business Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657t"},"text":"15 U.S.C. 657t","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id791d5395-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/b"},"text":"Pub. L. 115–189, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1495"},"text":"132 Stat. 1495","children":[],"tail":", provided that the amendment made by section 3(b) is effective "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id791d5396-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s3/c/1"},"text":"Pub. L. 115–189, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1496"},"text":"132 Stat. 1496","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/189/s3/c/1"},"text":"“All functions of the Office of Credit Risk Management of the Small Business Administration, including the personnel, assets, and obligation of the Office of Credit Risk Management, as in existence on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":"], shall be transferred to the Office of Credit Risk Management established under section 47 of the Small Business Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657t"},"text":"15 U.S.C. 657t","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id791d5397-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishing a Process for Waivers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s6"},"text":"Pub. L. 115–189, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1498"},"text":"132 Stat. 1498","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/189/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Administrator [of the Small Business Administration] exercises statutory or regulatory authority to waive a regulation or a requirement in the Standard Operating Procedures Manual or Policy Notice related to a program or function of the Office of Capital Access of the [Small Business] Administration, the waiver shall be in writing and be maintained in an indexed form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No New Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in subsection (a) shall be construed as creating new authority for the Administrator to waive regulations of the Administration.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id791d5398-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions of Terms Used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189"},"text":"Pub. L. 115–189","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189/s2"},"text":"Pub. L. 115–189, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1492"},"text":"132 Stat. 1492","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/189/s2"},"text":"“In this Act [see Short Title of 2018 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"], the terms ‘Administration’ and ‘Administrator’ mean the Small Business Administration and the Administrator thereof, respectively.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
