{"tag":"section","attrib":{"id":"id7a36b246-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Commission; publication of guidelines; report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a36b247-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a36b248-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and recommend an integrated national Arctic research policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b249-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Interagency Arctic Research Policy Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4106"},"text":"section 4106 of this title","children":[],"tail":", assist in establishing a national Arctic research program plan to implement the Arctic research policy;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b24a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate cooperation between the Federal Government and State and local governments with respect to Arctic research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b24b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review Federal research programs in the Arctic and recommend improvements in coordination among programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b24c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend methods to improve logistical planning and support for Arctic research as may be appropriate and in accordance with the findings and purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b24d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend methods for improving efficient sharing and dissemination of data and information on the Arctic among interested public and private institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b24e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer other recommendations and advice to the Interagency Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4106"},"text":"section 4106 of this title","children":[],"tail":" as it may find appropriate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b24f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the Governor of the State of Alaska and with agencies and organizations of that State which the Governor may designate with respect to the formulation of Arctic research policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b250-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Interagency Committee the means for developing international scientific cooperation in the Arctic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a36b251-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"1991-01-31"},"text":"January 31, 1991","children":[],"tail":", and every 2 years thereafter, publish a statement of goals and objectives with respect to Arctic research to guide the Interagency Committee established under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4106"},"text":"section 4106 of this title","children":[],"tail":" in the performance of its duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a36b252-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than January 31 of each year, the Commission shall submit to the President and to the Congress a report describing the activities and accomplishments of the Commission during the immediately preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a36b253-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/373/tI/s104"},"text":"Pub. L. 98–373, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-31"},"text":"July 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1244"},"text":"98 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/609/s4"},"text":"Pub. L. 101–609, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3125"},"text":"104 Stat. 3125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a36b254-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a36b255-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a36b256-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(4), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609/s4/a/1"},"text":"Pub. L. 101–609, § 4(a)(1)","children":[],"tail":", (2), substituted “recommend” for “suggest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609/s4/a/3"},"text":"Pub. L. 101–609, § 4(a)(3)","children":[],"tail":"–(5), added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/609/s4/b"},"text":"Pub. L. 101–609, § 4(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Not later than January 31 of each year, the Commission shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) publish a statement of goals and objectives with respect to Arctic research to guide the Interagency Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4106"},"text":"section 4106 of this title","children":[],"tail":" in the performance of its duties; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) submit to the President and to the Congress a report describing the activities and accomplishments of the Commission during the immediately preceding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a36b257-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a36b258-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b) of this section relating to submitting annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 155 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
