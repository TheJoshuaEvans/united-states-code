{"tag":"section","attrib":{"id":"id7a3440f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4052"},"text":null,"children":[{"tag":"num","attrib":{"value":"4052"},"text":"§ 4052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Department of Commerce to carry out export promotion programs such sums as are necessary for fiscal years 1995 and 1996.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a3440f5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/64/tII/s202"},"text":"Pub. L. 99–64, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-07-12"},"text":"July 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/158"},"text":"99 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/633/s2"},"text":"Pub. L. 99–633, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-07"},"text":"Nov. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3522"},"text":"100 Stat. 3522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2305/b/1"},"text":"Pub. L. 100–418, title II, § 2305(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1344"},"text":"102 Stat. 1344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/429/tII/s208"},"text":"Pub. L. 102–429, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-21"},"text":"Oct. 21, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2205"},"text":"106 Stat. 2205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/392/tIII/s301"},"text":"Pub. L. 103–392, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4099"},"text":"108 Stat. 4099","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3440f6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3440f7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a3440f8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Export Administration Amendments Act of 1985, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/290"},"text":"Pub. L. 97–290","children":[],"tail":" which enacted this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a3440f9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/392"},"text":"Pub. L. 103–392","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “There are authorized to be appropriated to the Department of Commerce—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to carry out export promotion programs—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $190,000,000 for fiscal year 1993; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $200,000,000 for fiscal year 1994; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4723"},"text":"section 4723 of this title","children":[],"tail":", $5,500,000 for each of fiscal years 1993 and 1994.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/429"},"text":"Pub. L. 102–429","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “There are authorized to be appropriated to the Department of Commerce to carry out export promotion programs $123,922,000 for the fiscal year 1988, and $146,400,000 for each of the fiscal years 1989 and 1990.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “There is authorized to be appropriated $123,922,000 for each of the fiscal years 1987 and 1988 to the Department of Commerce to carry out export promotion programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/633"},"text":"Pub. L. 99–633","children":[],"tail":" substituted provisions authorizing appropriations of $123,922,000 for each of the fiscal years 1987 and 1988 for provisions authorizing appropriations of $113,273,000 for each of the fiscal years 1985 and 1986."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
