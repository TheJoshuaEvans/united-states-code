{"tag":"section","attrib":{"id":"id7a108d29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935"},"text":null,"children":[{"tag":"num","attrib":{"value":"2935"},"text":"§ 2935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a108d2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall each year provide general guidance to each Federal agency or department participating in the Program with respect to the preparation of requests for appropriations for activities related to the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108d2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of reports with agency appropriations requests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Working in conjunction with the Committee, each Federal agency or department involved in global change research shall include with its annual request for appropriations submitted to the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1108"},"text":"section 1108 of title 31","children":[],"tail":" a report which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a108d2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each element of the proposed global change research activities of the agency or department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a108d2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies whether each element (i) contributes directly to the Program or (ii) contributes indirectly but in important ways to the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a108d2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the portion of its request for appropriations allocated to each element of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency or department that submits a report under paragraph (1) shall submit such report simultaneously to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a108d31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration in President’s budget","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall, in a timely fashion, provide the Committee with an opportunity to review and comment on the budget estimate of each agency and department involved in global change research in the context of the Plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2935/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall identify in each annual budget submitted to the Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" those items in each agency’s or department’s annual budget which are elements of the Program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108d34-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tI/s105"},"text":"Pub. L. 101–606, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3100"},"text":"104 Stat. 3100","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
