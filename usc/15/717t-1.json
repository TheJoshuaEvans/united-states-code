{"tag":"section","attrib":{"id":"id794107c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"717t–1"},"text":"§ 717t–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794107c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that violates this chapter, or any rule, regulation, restriction, condition, or order made or imposed by the Commission under authority of this chapter, shall be subject to a civil penalty of not more than $1,000,000 per day per violation for as long as the violation continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794107c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalty shall be assessed by the Commission after notice and opportunity for public hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794107c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s717t–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of a proposed penalty, the Commission shall take into consideration the nature and seriousness of the violation and the efforts to remedy the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794107c9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-21/ch556/s22"},"text":"June 21, 1938, ch. 556, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s314/b/1/B"},"text":"Pub. L. 109–58, title III, § 314(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/691"},"text":"119 Stat. 691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794107ca-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id794107cb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id794107cc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 22 of act ","children":[{"tag":"date","attrib":{"date":"1938-06-21"},"text":"June 21, 1938","children":[],"tail":", was renumbered section 24 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717u"},"text":"section 717u of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
