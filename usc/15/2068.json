{"tag":"section","attrib":{"id":"id79d7540d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068"},"text":null,"children":[{"tag":"num","attrib":{"value":"2068"},"text":"§ 2068.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d7540e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d7540f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell, offer for sale, manufacture for sale, distribute in commerce, or import into the United States any consumer product, or other product or substance that is regulated under this chapter or any other Act enforced by the Commission, that is not in conformity with an applicable consumer product safety rule under this chapter, or any similar rule, regulation, standard, or ban under any other Act enforced by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75410-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sell, offer for sale, manufacture for sale, distribute in commerce, or import into the United States any consumer product, or other product or substance that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d75411-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002430"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002430"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subpar. (A) has been enacted."}],"tail":" subject to voluntary corrective action taken by the manufacturer, in consultation with the Commission, of which action the Commission has notified the public or if the seller, distributor, or manufacturer knew or should have known of such voluntary corrective action;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d75412-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to an order issued under section 2061 or 2064 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d75413-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a banned hazardous substance within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261/q/1"},"text":"section 1261(q)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75414-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail or refuse to permit access to or copying of records, or fail or refuse to establish or maintain records, or fail or refuse to make reports or provide information, or fail or refuse to permit entry or inspection, as required under this chapter or rule thereunder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75415-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to furnish information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064/b"},"text":"section 2064(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75416-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with an order issued under section 2064(c) or (d) of this title (relating to notification, to repair, replacement, and refund, and to prohibited acts);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75417-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to furnish a certificate required by this chapter or any other Act enforced by the Commission, or to issue a false certificate if such person in the exercise of due care has reason to know that the certificate is false or misleading in any material respect; or to fail to comply with any requirement of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063"},"text":"section 2063 of this title","children":[],"tail":" (including the requirement for tracking labels) or any rule or regulation under such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75418-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with any rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2058/g/2"},"text":"section 2058(g)(2) of this title","children":[],"tail":" (relating to stockpiling);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75419-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with any rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2076/e"},"text":"section 2076(e) of this title","children":[],"tail":" (relating to provision of performance and technical data);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7541a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with any rule or requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2082"},"text":"section 2082 of this title","children":[],"tail":" (relating to labeling and testing of cellulose insulation);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7541b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to file a statement with the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2067/b"},"text":"section 2067(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7541c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to furnish information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2084"},"text":"section 2084 of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002431"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002431"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7541d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell, offer for sale, distribute in commerce, or import into the United States any consumer product bearing a registered safety certification mark owned by an accredited conformity assessment body, which mark is known, or should have been known, by such person to be used in a manner unauthorized by the owner of that certification mark;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7541e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misrepresent to any officer or employee of the Commission the scope of consumer products subject to an action required under section 2061 or 2064 of this title, or to make a material misrepresentation to such an officer or employee in the course of an investigation under this chapter or any other Act enforced by the Commission; or ","children":[{"tag":"ref","attrib":{"idref":"fn002432"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002432"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The word “or” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7541f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise, or attempt to exercise, undue influence on a third party conformity assessment body (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/f/2"},"text":"section 2063(f)(2) of this title","children":[],"tail":") with respect to the testing, or reporting of the results of testing, of any product for compliance under this chapter or any other Act enforced by the Commission, or to subdivide the production of any children’s product into small quantities that have the effect of evading any third party testing requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/a/2"},"text":"section 2063(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75420-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" export from the United States for purpose of sale any consumer product, or other product or substance regulated by the Commission (other than a consumer product or substance, the export of which is permitted by the Secretary of the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2066/e"},"text":"section 2066(e) of this title","children":[],"tail":") that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79d75421-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to an order issued under section 2061 or 2064 of this title or is a banned hazardous substance within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261/q/1"},"text":"section 1261(q)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79d75422-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to a voluntary corrective action taken by the manufacturer, in consultation with the Commission, of which action the Commission has notified the public; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75423-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate an order of the Commission issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2067/c"},"text":"section 2067(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d75424-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2068/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) of subsection (a) of this section shall not apply to any person (1) who holds a certificate issued in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/a"},"text":"section 2063(a) of this title","children":[],"tail":" to the effect that such consumer product conforms to all applicable consumer product safety rules, unless such person knows that such consumer product does not conform, or (2) who relies in good faith on the representation of the manufacturer or a distributor of such product that the product is not subject to an applicable product safety rule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d75425-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s19"},"text":"Pub. L. 92–573, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1224"},"text":"86 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/284"},"text":"Pub. L. 94–284","children":[],"tail":", §§ 12(b), 13(a), "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/508"},"text":"90 Stat. 508","children":[],"tail":", 509; "},{"tag":"ref","attrib":{"href":"/us/pl/95/319/s3/b"},"text":"Pub. L. 95–319, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-07-11"},"text":"July 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/390"},"text":"92 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/631/s6/b"},"text":"Pub. L. 95–631, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3745"},"text":"92 Stat. 3745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/414/s9/j/4"},"text":"Pub. L. 97–414, § 9(j)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-04"},"text":"Jan. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2064"},"text":"96 Stat. 2064","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/608/tI/s112/d"},"text":"Pub. L. 101–608, title I, § 112(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3117"},"text":"104 Stat. 3117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s216/a"},"text":"Pub. L. 110–314, title II, § 216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3056"},"text":"122 Stat. 3056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/28/s2/b"},"text":"Pub. L. 112–28, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-12"},"text":"Aug. 12, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/279"},"text":"125 Stat. 279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d75426-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d75427-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d75428-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28"},"text":"Pub. L. 112–28","children":[],"tail":" substituted “, or to subdivide the production of any children’s product into small quantities that have the effect of evading any third party testing requirements under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/a/2"},"text":"section 2063(a)(2) of this title","children":[],"tail":";” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s216/a/1"},"text":"Pub. L. 110–314, § 216(a)(1)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) manufacture for sale, offer for sale, distribute in commerce, or import into the United States any consumer product which is not in conformity with an applicable consumer product safety standard under this chapter;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) manufacture for sale, offer for sale, distribute in commerce, or import into the United States any consumer product which has been declared a banned hazardous product by a rule under this chapter;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s216/a/2"},"text":"Pub. L. 110–314, § 216(a)(2)","children":[],"tail":", amended par. (6) generally. Prior to amendment, par. (6) read as follows: “fail to furnish a certificate required by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063"},"text":"section 2063 of this title","children":[],"tail":" or issue a false certificate if such person in the exercise of due care has reason to know that such certificate is false or misleading in any material respect; or to fail to comply with any rule under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063/c"},"text":"section 2063(c) of this title","children":[],"tail":" (relating to labeling);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s216/a/3"},"text":"Pub. L. 110–314, § 216(a)(3)","children":[],"tail":"–(6), struck out “or” at end of par. (7) and “and” at end of par. (8) and substituted semicolon for period at end of pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12) to (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s216/a/7"},"text":"Pub. L. 110–314, § 216(a)(7)","children":[],"tail":", added pars. (12) to (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/608"},"text":"Pub. L. 101–608","children":[],"tail":" added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414/s9/j/4/A"},"text":"Pub. L. 97–414, § 9(j)(4)(A)","children":[],"tail":", substituted “section 2058(g)(2)” for “section 2058(d)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414/s9/j/4/B"},"text":"Pub. L. 97–414, § 9(j)(4)(B)","children":[],"tail":", redesignated par. (9) as (8) and struck out former par. (8) which made it unlawful for any person to fail to comply with any rule under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2062"},"text":"section 2062 of this title","children":[],"tail":" (relating to prior notice and description of new consumer products)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/414/s9/j/4/B"},"text":"Pub. L. 97–414, § 9(j)(4)(B)","children":[],"tail":", redesignated par. (10), as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/319"},"text":"Pub. L. 95–319","children":[],"tail":", as (9). Former par. (9) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/631"},"text":"Pub. L. 95–631","children":[],"tail":" added par. (10), providing that it be unlawful to fail to file a statement with the Commission pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2067/b"},"text":"section 2067(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/319"},"text":"Pub. L. 95–319","children":[],"tail":" added par. (10), providing that it be unlawful to fail to comply with any rule or requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2082"},"text":"section 2082 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/284"},"text":"Pub. L. 94–284","children":[],"tail":" substituted “to” for “and to” and inserted “, and to prohibited acts” after “refund” in par. (5), inserted “or fail or refuse to establish or maintain records,” after “copying of records,” in par. (3), and added pars. (8) and (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d75429-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79d7542a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314"},"text":"Pub. L. 110–314","children":[],"tail":" effective on the date that is 30 days after "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/s239/a"},"text":"section 239(a) of Pub. L. 110–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79d7542b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Eff