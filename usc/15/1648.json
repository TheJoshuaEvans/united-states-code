{"tag":"section","attrib":{"id":"id799bab2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648"},"text":null,"children":[{"tag":"num","attrib":{"value":"1648"},"text":"§ 1648.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reverse mortgages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id799bab2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the disclosures required under this subchapter, for each reverse mortgage, the creditor shall, not less than 3 days prior to consummation of the transaction, disclose to the consumer in conspicuous type a good faith estimate of the projected total cost of the mortgage to the consumer expressed as a table of annual interest rates. Each annual interest rate shall be based on a projected total future credit extension balance under a projected appreciation rate for the dwelling and a term for the mortgage. The disclosure shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" statements of the annual interest rates for not less than 3 projected appreciation rates and not less than 3 credit transaction periods, as determined by the Bureau, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id799bab2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a short-term reverse mortgage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a term equaling the actuarial life expectancy of the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id799bab2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such longer term as the Bureau deems appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that the consumer is not obligated to complete the reverse mortgage transaction merely because the consumer has received the disclosure required under this section or has signed an application for the reverse mortgage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id799bab31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projected total cost","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the projected total cost of the mortgage to be disclosed to the consumer under subsection (a), the creditor shall take into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id799bab32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any shared appreciation or equity that the lender will, by contract, be entitled to receive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all costs and charges to the consumer, including the costs of any associated annuity that the consumer elects or is required to purchase as part of the reverse mortgage transaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all payments to and for the benefit of the consumer, including, in the case in which an associated annuity is purchased (whether or not required by the lender as a condition of making the reverse mortgage), the annuity payments received by the consumer and financed from the proceeds of the loan, instead of the proceeds used to finance the annuity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id799bab35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1648/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any limitation on the liability of the consumer under reverse mortgage transactions (such as nonrecourse limits and equity conservation agreements).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id799bab36-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s138"},"text":"Pub. L. 90–321, title I, § 138","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s154/b"},"text":"Pub. L. 103–325, title I, § 154(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2196"},"text":"108 Stat. 2196","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799bab37-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id799bab38-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id799bab39-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799bab3a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id799bab3b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
