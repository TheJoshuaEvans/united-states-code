{"tag":"section","attrib":{"id":"id7a0e1bd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807"},"text":null,"children":[{"tag":"num","attrib":{"value":"2807"},"text":"§ 2807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on restriction of installation of renewable fuel pumps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0e1bda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0e1bdb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable fuel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “renewable fuel” means any fuel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0e1bdc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 85 percent of the volume of which consists of ethanol; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1bdd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mixture of biodiesel and diesel or renewable diesel (as defined in regulations adopted pursuant to section 7545(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of title 42 (40 CFR, part 80)), determined without regard to any use of kerosene and containing at least 20 percent biodiesel or renewable diesel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0e1bde-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Franchise-related document","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “franchise-related document” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0e1bdf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a franchise under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other contract or directive of a franchisor relating to terms or conditions of the sale of fuel by a franchisee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0e1be1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0e1be2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No franchise-related document entered into or renewed on or after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", shall contain any provision allowing a franchisor to restrict the franchisee or any affiliate of the franchisee from—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0e1be3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing on the marketing premises of the franchisee a renewable fuel pump or tank, except that the franchisee’s franchisor may restrict the installation of a tank on leased marketing premises of such franchisor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" converting an existing tank or pump on the marketing premises of the franchisee for renewable fuel use, so long as such tank or pump and the piping connecting them are either warranted by the manufacturer or certified by a recognized standards setting organization to be suitable for use with such renewable fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertising (including through the use of signage) the sale of any renewable fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selling renewable fuel in any specified area on the marketing premises of the franchisee (including any area in which a name or logo of a franchisor or any other entity appears);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing renewable fuel from sources other than the franchisor if the franchisor does not offer its own renewable fuel for sale by the franchisee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listing renewable fuel availability or prices, including on service station signs, fuel dispensers, or light poles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0e1be9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing for payment of renewable fuel with a credit card,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"so long as such activities described in subparagraphs (A) through (G) do not constitute mislabeling, misbranding, willful adulteration, or other trademark violations by the franchisee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0e1bea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preclude a franchisor from requiring the franchisee to obtain reasonable indemnification and insurance policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0e1beb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to 3-grade requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No franchise-related document that requires that 3 grades of gasoline be sold by the applicable franchisee shall prevent the franchisee from selling a renewable fuel in lieu of 1, and only 1, grade of gasoline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0e1bec-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/297/tI/s107"},"text":"Pub. L. 95–297, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s241/a"},"text":"Pub. L. 110–140, title II, § 241(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1538"},"text":"121 Stat. 1538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0e1bed-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a0e1bee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a0e1bef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
