{"tag":"section","attrib":{"id":"id7a87b7b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405"},"text":null,"children":[{"tag":"num","attrib":{"value":"8405"},"text":"§ 8405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by State attorneys general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a87b7b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (e), the attorney general of a State, or other authorized State officer, alleging a violation of this chapter or any regulation issued under this chapter that affects or may affect such State or its residents may bring an action on behalf of the residents of the State in any United States district court for the district in which the defendant is found, resides, or transacts business, or wherever venue is proper under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":", to obtain appropriate injunctive relief."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Commission required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall provide prior written notice to the Federal Trade Commission of any civil action under subsection (a) together with a copy of its complaint, except that if it is not feasible for the State to provide such prior notice, the State shall provide such notice immediately upon instituting such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention by the Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may intervene in such civil action and upon intervening—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b7b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be heard on all matters arising in such civil action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file petitions for appeal of a decision in such civil action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a87b7b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the attorney general of a State, or other authorized State officer, from exercising the powers conferred on the attorney general, or other authorized State officer, by the laws of such State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a87b7b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit the attorney general of a State, or other authorized State officer, from proceeding in State or Federal court on the basis of an alleged violation of any civil or criminal statute of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a87b7b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8405/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No separate suit shall be brought under this section if, at the time the suit is brought, the same alleged violation is the subject of a pending action by the Federal Trade Commission or the United States under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a87b7ba-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/345/s6"},"text":"Pub. L. 111–345, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3621"},"text":"124 Stat. 3621","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
