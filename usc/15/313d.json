{"tag":"section","attrib":{"id":"id78a1446a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d"},"text":null,"children":[{"tag":"num","attrib":{"value":"313d"},"text":"§ 313d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIDIS program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78a1446b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary, through the National Weather Service and other appropriate weather and climate programs in the National Oceanic and Atmospheric Administration, shall establish a National Integrated Drought Information System to better inform and provide for more timely decisionmaking to reduce drought related impacts and costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a1446c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Integrated Drought Information System shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a1446d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide an effective drought early warning system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a1446e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects and integrates information on the key indicators of drought and drought impacts, including precipitation, soil moisture, and evaporative demand, in order to make usable, reliable, and timely forecasts of drought and assessments of the severity of drought conditions and impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a1446f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such information, forecasts, and assessments on both national and regional levels;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a14470-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" communicate drought forecasts, drought conditions, and drought impacts on an ongoing basis to public and private entities engaged in drought planning and preparedness, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78a14471-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decisionmakers at the Federal, regional, State, tribal, and local levels of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a14472-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78a14473-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a14474-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely data, information, and products that reflect local, regional, watershed, and State differences in drought conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a14475-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, and integrate, through interagency agreements as practicable, Federal research and monitoring in support of a drought early warning information system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a14476-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize existing forecasting and assessment programs and partnerships, including forecast communication coordinators and cooperative institutes, and improvements in seasonal precipitation and temperature, subseasonal precipitation and temperature, and low flow water prediction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a14477-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue ongoing research and monitoring activities related to drought, including research activities relating to the prediction, length, severity, and impacts of drought and the role of extreme weather events and climate variability in drought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a14478-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Integrated Drought Information System may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78a14479-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with the private sector to improve drought monitoring, forecast, and communication if the Under Secretary determines the partnership is appropriate, cost-effective, and beneficial to the public and decisionmakers described in subsection (b)(2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a1447a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the development of 1 or more academic cooperative partnerships to assist with National Integrated Drought Information System functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78a1447b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize and support, as appropriate, monitoring by citizen scientists, including by developing best practices to facilitate maximum data integration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a1447c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall consult with relevant Federal, regional, State, tribal, and local government agencies, research institutions, and the private sector in the development and sustainment of the National Integrated Drought Information System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a1447d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation from other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency shall cooperate as appropriate with the Under Secretary in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78a1447e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s313d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soil moisture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-01-07"},"text":"January 7, 2019","children":[],"tail":", the Under Secretary, acting through the National Integrated Drought Information System, shall develop a strategy for a national coordinated soil moisture monitoring network."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78a1447f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/430/s3"},"text":"Pub. L. 109–430, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2918"},"text":"120 Stat. 2918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/86/s2"},"text":"Pub. L. 113–86, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-06"},"text":"Mar. 6, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1015"},"text":"128 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a"},"text":"Pub. L. 115–423, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5454"},"text":"132 Stat. 5454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a14480-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a14481-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78a14482-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (e), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/430"},"text":"Pub. L. 109–430","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2918"},"text":"120 Stat. 2918","children":[],"tail":", which enacted this section and provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s311"},"text":"section 311 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2006 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s311"},"text":"section 311 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78a14483-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/1/A"},"text":"Pub. L. 115–423, § 2(a)(1)(A)","children":[],"tail":", substituted “, including precipitation, soil moisture, and evaporative demand, in order to make usable, reliable, and timely forecasts of drought and” for “in order to make usable, reliable, and timely forecasts of drought, including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/1/B"},"text":"Pub. L. 115–423, § 2(a)(1)(B)","children":[],"tail":", inserted “watershed,” after “regional,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/1/C"},"text":"Pub. L. 115–423, § 2(a)(1)(C)","children":[],"tail":", inserted “, through interagency agreements” after “integrate”and “information” after “warning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/1/D"},"text":"Pub. L. 115–423, § 2(a)(1)(D)","children":[],"tail":", amended par. (5) generally. Prior to amendment, par. (5) read as follows: “build upon existing forecasting and assessment programs and partnerships, including through the designation of one or more cooperative institutes to assist with National Integrated Drought Information System functions; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/1/E"},"text":"Pub. L. 115–423, § 2(a)(1)(E)","children":[],"tail":", inserted “the prediction,” after “relating to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/3"},"text":"Pub. L. 115–423, § 2(a)(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/2"},"text":"Pub. L. 115–423, § 2(a)(2)","children":[],"tail":", (4), redesignated subsec. (c) as (d) and inserted “and sustainment” after “development”. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/2"},"text":"Pub. L. 115–423, § 2(a)(2)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/5"},"text":"Pub. L. 115–423, § 2(a)(5)","children":[],"tail":", added subsec. (f) and struck out former subsec. (f), which related to report by Under Secretary to congressional committees regarding National Integrated Drought Information System program not later than 18 months after "},{"tag":"date","attrib":{"date":"2014-03-06"},"text":"Mar. 6, 2014","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/a/2"},"text":"Pub. L. 115–423, § 2(a)(2)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/86/s2/1"},"text":"Pub. L. 113–86, § 2(1)","children":[],"tail":", inserted “to better inform and provide for more timely decisionmaking to reduce drought related impacts and costs” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/86/s2/2"},"text":"Pub. L. 113–86, § 2(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which set out required functions of the National Integrated Drought Information System."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/86/s2/3"},"text":"Pub. L. 113–86, § 2(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a14484-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78a14485-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/430/s4"},"text":"Pub. L. 109–430, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2919"},"text":"120 Stat. 2919","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/86/s3"},"text":"Pub. L. 113–86, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-03-06"},"text":"Mar. 6, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1016"},"text":"128 Stat. 1016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/423/s2/b"},"text":"Pub. L. 115–423, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5455"},"text":"132 Stat. 5455","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/423/s2/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“There are authorized to be appropriated to carry out this Act—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,500,000 for fiscal year 2019;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $13,750,000 for fiscal year 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $14,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $14,250,000 for fiscal year 2022; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $14,500,000 for fiscal year 2023.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id78a14486-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/430/s2"},"text":"Pub. L. 109–430, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2918"},"text":"120 Stat. 2918","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/430/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2006 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s311"},"text":"section 311 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Drought","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘drought’ means a deficiency in precipitation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that leads to a deficiency in surface or subsurface water supplies (including rivers, streams, wetlands, ground water, soil moisture, reservoir supplies, lake levels, and snow pack); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that causes or may cause—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial economic or social impacts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial physical damage or injury to individuals, property, or the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Under Secretary’ means the Under Secretary of Commerce for Oceans and Atmosphere.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
