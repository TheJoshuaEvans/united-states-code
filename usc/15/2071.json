{"tag":"section","attrib":{"id":"id79d7545b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071"},"text":null,"children":[{"tag":"num","attrib":{"value":"2071"},"text":"§ 2071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctive enforcement and seizure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79d7545c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States district courts shall have jurisdiction to take the following action:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d7545d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restrain any violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068"},"text":"section 2068 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7545e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restrain any person from manufacturing for sale, offering for sale, distributing in commerce, or importing into the United States a product in violation of an order in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064/d"},"text":"section 2064(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d7545f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restrain any person from distributing in commerce a product which does not comply with a consumer product safety rule.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such actions may be brought by the Commission (without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2076/b/7/A"},"text":"section 2076(b)(7)(A) of this title","children":[],"tail":") or by the Attorney General in any United States district court for a district wherein any act, omission, or transaction constituting the violation occurred, or in such court for the district wherein the defendant is found or transacts business. In any action under this section process may be served on a defendant in any other district in which the defendant resides or may be found."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79d75460-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Products liable to proceeding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any consumer product—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79d75461-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which fails to conform with an applicable consumer product safety rule, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79d75462-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacture for sale, offering for sale, distribution in commerce, or the importation into the United States of which has been prohibited by an order in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064/d"},"text":"section 2064(d) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"when introduced into or while in commerce or while held for sale after shipment in commerce shall be liable to be proceeded against on libel of information and condemned in any district court of the United States within the jurisdiction of which such consumer product is found. Proceedings in cases instituted under the authority of this subsection shall conform as nearly as possible to proceedings in rem in admiralty. Whenever such proceedings involving substantially similar consumer products are pending in courts of two or more judicial districts they shall be consolidated for trial by order of any such court upon application reasonably made by any party in interest upon notice to all other parties in interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79d75463-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s22"},"text":"Pub. L. 92–573, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1225"},"text":"86 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/284"},"text":"Pub. L. 94–284","children":[],"tail":", §§ 11(b), 12(c), "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/507"},"text":"90 Stat. 507","children":[],"tail":", 508.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79d75464-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79d75465-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79d75466-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/284"},"text":"Pub. L. 94–284","children":[],"tail":", §§ 11(b), 12(c)(1), designated existing provision as par. (1) and (3), added par. (2), and in provision following par. (3) substituted “(without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2076/b/7/A"},"text":"section 2076(b)(7)(A) of this title","children":[],"tail":")” for “(with the concurrence of the Attorney General)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/284/s12/c/2"},"text":"Pub. L. 94–284, § 12(c)(2)","children":[],"tail":", amended subsec. (b) generally, inserting provision designated as par. (2) which included within consumer products liable to proceedings, a product of which the manufacture for sale, offering for sale, distribution in commerce, or importation into the United States has been prohibited."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79d75467-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79d75468-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the sixtieth day following ","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/573/s34"},"text":"section 34 of Pub. L. 92–573","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
