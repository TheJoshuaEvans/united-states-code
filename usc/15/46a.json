{"tag":"section","attrib":{"id":"id77c8498e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s46a"},"text":null,"children":[{"tag":"num","attrib":{"value":"46a"},"text":"§ 46a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent resolution essential to authorize investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1933-06-16"},"text":"June 16, 1933","children":[],"tail":", no new investigations shall be initiated by the Commission as the result of a legislative resolution, except the same be a concurrent resolution of the two Houses of Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77c8498f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch101/s1"},"text":"June 16, 1933, ch. 101, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/291"},"text":"48 Stat. 291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c84990-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c84991-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77c84992-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Federal Trade Commission Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77c84993-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag"