{"tag":"section","attrib":{"id":"id7a096093-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2687"},"text":null,"children":[{"tag":"num","attrib":{"value":"2687"},"text":"§ 2687.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The regulations of the Administrator under this subchapter shall include such recordkeeping and reporting requirements as may be necessary to insure the effective implementation of this subchapter. The regulations may be amended from time to time as necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a096094-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tIV/s407"},"text":"Pub. L. 94–469, title IV, § 407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1021/a"},"text":"Pub. L. 102–550, title X, § 1021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3921"},"text":"106 Stat. 3921","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
