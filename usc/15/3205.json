{"tag":"section","attrib":{"id":"id7a179157-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a179158-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the authorities vested in the Secretary pursuant to any other provision of law, the Secretary, on his own motion, may intervene as a matter of right in any proceeding before a State regulatory authority which relates to gas utility rates or rate design. Such intervention shall be solely for the purpose of advocating policies or methods which carry out the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a179159-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the same rights as any other party to a proceeding before a State regulatory authority which relates to gas utility rates or rate design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a17915a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonregulated gas utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, on his own motion, may, to the same extent as provided in subsections (a) through (b), intervene as a matter of right in any proceeding which relates to rates or rate design of nonregulated gas utilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a17915b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIII/s305"},"text":"Pub. L. 95–617, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3152"},"text":"92 Stat. 3152","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a17915c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a17915d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a17915e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of Secretary in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of Title 16","children":[],"tail":", Conservation, applies to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
