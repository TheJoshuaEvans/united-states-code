{"tag":"section","attrib":{"id":"id797cb110-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459"},"text":null,"children":[{"tag":"num","attrib":{"value":"1459"},"text":"§ 1459.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id797cb111-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “consumer commodity”, except as otherwise specifically provided by this subsection, means any food, drug, device, or cosmetic (as those terms are defined by the Federal Food, Drug, and Cosmetic Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.]), and any other article, product, or commodity of any kind or class which is customarily produced or distributed for sale through retail sales agencies or instrumentalities for consumption by individuals, or use by individuals for purposes of personal care or in the performance of services ordinarily rendered within the household, and which usually is consumed or expended in the course of such consumption or use. Such term does not include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id797cb112-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any meat or meat product, poultry or poultry product, or tobacco or tobacco product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb113-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commodity subject to packaging or labeling requirements imposed by the Secretary of Agriculture pursuant to the Federal Insecticide, Fungicide, and Rodenticide Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"7 U.S.C. 136","children":[],"tail":" et seq.], or the provisions of the eighth paragraph under the heading “Bureau of Animal Industry” of the Act of "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"March 4, 1913","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/37/832-833"},"text":"37 Stat. 832–833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s151–157"},"text":"21 U.S.C. 151–157","children":[],"tail":"),"},{"tag":"ref","attrib":{"idref":"fn002324"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002324"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" commonly known as the Virus-Serum-Toxin Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb114-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any drug subject to the provisions of section 503(b)(1) or 506 of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s353/b/1"},"text":"21 U.S.C. 353(b)(1)","children":[],"tail":" and 356);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb115-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any beverage subject to or complying with packaging or labeling requirements imposed under the Federal Alcohol Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s201"},"text":"27 U.S.C. 201","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb116-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commodity subject to the provisions of the Federal Seed Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1551–161"},"text":"7 U.S.C. 1551–161","children":[],"tail":"0)."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb117-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “package” means any container or wrapping in which any consumer commodity is enclosed for use in the delivery or display of that consumer commodity to retail purchasers, but does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id797cb118-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipping containers or wrappings used solely for the transportation of any consumer commodity in bulk or in quantity to manufacturers, packers, or processors, or to wholesale or retail distributors thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb119-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipping containers or outer wrappings used by retailers to ship or deliver any commodity to retail customers if such containers and wrappings bear no printed matter pertaining to any particular commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id797cb11a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containers subject to the provisions of the Act of ","children":[{"tag":"date","attrib":{"date":"1912-08-03"},"text":"August 3, 1912","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/37/250"},"text":"37 Stat. 250","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s231–233"},"text":"15 U.S.C. 231–233","children":[],"tail":"), or the Act of "},{"tag":"date","attrib":{"date":"1915-03-04"},"text":"March 4, 1915","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/38/1186"},"text":"38 Stat. 1186","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s234–236"},"text":"15 U.S.C. 234–236","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb11b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “label” means any written, printed, or graphic matter affixed to any consumer commodity or affixed to or appearing upon a package containing any consumer commodity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb11c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes any firm, corporation, or association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb11d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commerce” means (1) commerce between any State, the District of Columbia, the Commonwealth of Puerto Rico, or any territory or possession of the United States, and any place outside thereof, and (2) commerce within the District of Columbia or within any territory or possession of the United States not organized with a legislative body, but shall not include exports to foreign countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id797cb11e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1459/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “principal display panel” means that part of a label that is most likely to be displayed, presented, shown, or examined under normal and customary conditions of display for retail sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id797cb11f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/755/s10"},"text":"Pub. L. 89–755, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1301"},"text":"80 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/628/s2"},"text":"Pub. L. 90–628, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id797cb120-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id797cb121-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id797cb122-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Insecticide, Fungicide, and Rodenticide Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/973"},"text":"86 Stat. 973","children":[],"tail":", which is classified generally to subchapter II (§ 136 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Virus-Serum-Toxin Act, referred to in subsec. (a)(2), is the eighth paragraph under the heading “Bureau of Animal Industry” of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch145"},"text":"act Mar. 4, 1913, ch. 145","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/832"},"text":"37 Stat. 832","children":[],"tail":", which is classified generally to chapter 5 (§ 151 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s151"},"text":"section 151 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Alcohol Administration Act, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"act Aug. 29, 1935, ch. 814","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/977"},"text":"49 Stat. 977","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 27, Intoxicating Liquors. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t27/s201"},"text":"section 201 of Title 27","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Seed Act, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"act Aug. 9, 1939, ch. 615","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1275"},"text":"53 Stat. 1275","children":[],"tail":", which is classified generally to chapter 37 (§ 1551 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1551"},"text":"section 1551 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id797cb123-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/628"},"text":"Pub. L. 90–628","children":[],"tail":" struck out reference to the Act of "},{"tag":"date","attrib":{"date":"1916-08-31"},"text":"August 31, 1916","children":[],"tail":", and the Act of "},{"tag":"date","attrib":{"date":"1928-05-21"},"text":"May 21, 1928","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id797cb124-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id797cb125-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/628"},"text":"Pub. L. 90–628","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/628/s3"},"text":"section 3 of Pub. L. 90–628","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
