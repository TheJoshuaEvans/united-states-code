{"tag":"section","attrib":{"id":"id7a475492-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906"},"text":null,"children":[{"tag":"num","attrib":{"value":"4906"},"text":"§ 4906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Data Bank","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a475493-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 2 years after ","children":[{"tag":"date","attrib":{"date":"1988-08-23"},"text":"August 23, 1988","children":[],"tail":", the Secretary of Commerce shall establish the Data Bank. The Secretary shall manage the Data Bank. The Data Bank shall consist of two data systems, to be designated the International Economic Data System, as described in subsection (b) and the Export Promotion Data System, as described in subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a475494-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Economic Data System","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The International Economic Data System shall include current and historical information determined by the Secretary to be useful (after the consultation required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4904"},"text":"section 4904 of this title","children":[],"tail":") to policymakers and analysts concerned with international economics and trade and which shall include data compiled or obtained by appropriate executive agencies. Such information shall not identify parties to transactions. Such information may include data for the United States and countries with which the United States has important economic relations including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a475495-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" data on imports and exports, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a475496-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aggregate import and export data for the United States and for each foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a475497-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry-specific import and export data for each foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a475498-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product and service specific import and export data for the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a475499-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market penetration information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47549a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign destinations for exports of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47549b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data on international service transactions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47549c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on international capital markets, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a47549d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a47549e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average exchange rates;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a47549f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on foreign direct investment in the United States economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4754a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" international labor market information, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4754a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wage rates for major industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4754a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international unemployment rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4754a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends in international labor productivity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4754a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on foreign government policies affecting trade, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4754a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4754a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" export financing policies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4754a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" import and export data for the United States on a State-by-State basis aggregated at the product level including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a4754a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data concerning the country shipping the import, the State of first destination, and the original part ","children":[{"tag":"ref","attrib":{"idref":"fn002538"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002538"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “port”."}],"tail":" of entry for imports of goods and, to the extent possible, services; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a4754a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data concerning the State of the exporter, the port of departure, and the country of first destination for export of goods and, to the extent possible, services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4754aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other economic and trade data collected by the Federal Government that the Secretary determines to be useful in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4754ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Export Promotion Data System","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The export promotion data system shall include data and information collected by the Federal Government on the industrial sectors and markets of foreign countries which are determined by the Secretary (after consultation required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4904"},"text":"section 4904 of this title","children":[],"tail":") to be of the greatest interest to United States business firms that are engaged in export-related activities and to Federal and State agencies that promote exports, while providing for the confidentiality of proprietary business information, and shall be designed to use the most effective means of disseminating data and information electronically through the Department, or Department-designated offices, or through other available data bases in an accurate and timely manner. Such data system shall monitor, organize, and disseminate selected information on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4754ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific business opportunities in foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4754ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specific industrial sectors within foreign countries with high export potential such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c4ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" size of the market;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribution of products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant applicable laws, regulations, specifications, and standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate government officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade associations and other contact points; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" foreign countries generally, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c4b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general economic conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" common business practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant tariff and trade barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c4b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other significant laws and regulations regarding imports, licensing, and the protection of intellectual property;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" export financing information, including the availability, through public sources of funds for United States exporters and foreign competitors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions involving barter and countertrade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c4bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4906/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other similar information, that the Secretary determines to be useful in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c4bc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5406"},"text":"Pub. L. 100–418, title V, § 5406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1464"},"text":"102 Stat. 1464","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
