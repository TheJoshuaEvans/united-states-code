{"tag":"section","attrib":{"id":"id77c5d8de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e"},"text":null,"children":[{"tag":"num","attrib":{"value":"45e"},"text":"§ 45e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office for the prevention of fraud targeting seniors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77c5d8df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Advisory Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Trade Commission (in this section referred to as the “Commission”) shall establish an office within the Bureau of Consumer Protection for the purpose of advising the Commission on the prevention of fraud targeting seniors and to assist the Commission with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77c5d8e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory office shall monitor the market for mail, television, internet, telemarketing, and recorded message telephone call (in this section referred to as “robocall”) fraud targeting seniors and shall coordinate with other relevant agencies regarding the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c5d8e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission, through the advisory office and in consultation with the Attorney General, the Secretary of Health and Human Services, the Postmaster General, the Chief Postal Inspector for the United States Postal Inspection Service, and other relevant agencies, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c5d8e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate to seniors and families and caregivers of seniors general information on mail, television, internet, telemarketing, and robocall fraud targeting seniors, including descriptions of the most common fraud schemes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c5d8e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate to seniors and families and caregivers of seniors information on reporting complaints of fraud targeting seniors either to the national toll-free telephone number established by the Commission for reporting such complaints, or to the Consumer Sentinel Network, operated by the Commission, where such complaints will become immediately available to appropriate law enforcement agencies, including the Federal Bureau of Investigation and the attorneys general of the States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c5d8e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in response to a specific request about a particular entity or individual, provide publicly available information of any enforcement action taken by the Commission for mail, television, internet, telemarketing, and robocall fraud against such entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c5d8e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a website to serve as a resource for information for seniors and families and caregivers of seniors regarding mail, television, internet, telemarketing, robocall, and other identified fraud targeting seniors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77c5d8e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission, through the advisory office and in consultation with the Attorney General, shall establish procedures to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77c5d8e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" log and acknowledge the receipt of complaints by individuals who believe they have been a victim of mail, television, internet, telemarketing, and robocall fraud in the Consumer Sentinel Network, and shall make those complaints immediately available to Federal, State, and local law enforcement authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77c5d8e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to individuals described in subparagraph (A), and to any other persons, specific and general information on mail, television, internet, telemarketing, and robocall fraud, including descriptions of the most common schemes using such methods of communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c5d8e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall commence carrying out the requirements of this section not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77c5d8ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s45e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No additional funds are authorized to be appropriated to carry out this section and the Commission shall carry out this section using amounts otherwise made available to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77c5d8eb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tI/s122"},"text":"Pub. L. 117–103, div. Q, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/811"},"text":"136 Stat. 811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77c5d8ec-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77c5d8ed-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id77c5d8ee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Seniors Fraud Prevention Act of 2022, the Fraud and Scam Reduction Act, and also as part of the Consolidated Appropriations Act, 2022, and not as part of the Federal Trade Commission Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77c5d8ef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77c5d8f0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senior Scams Prevention Advisory Group","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tI/s112/a"},"text":"Pub. L. 117–103, div. Q, title I, § 112(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/809"},"text":"136 Stat. 809","children":[],"tail":", 810, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dQ/tI/s112/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a Senior Scams Prevention Advisory Group (in this subtitle [subtitle A of div. Q of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21711"},"text":"section 21711 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s58"},"text":"section 58 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21711"},"text":"section 21711 of Title 34","children":[],"tail":"] referred to as the ‘Advisory Group’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Group shall be composed of stakeholders such as the following individuals or the designees of those individuals:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Bureau of Consumer Financial Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Representatives from each of the following sectors, including trade associations, to be selected by the Federal Trade Commission:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gift cards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Telecommunications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wire-transfer services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior peer advocates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumer advocacy organizations with efforts focused on preventing seniors from becoming the victims of scams.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial services, including institutions that engage in digital currency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prepaid cards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Board of Governors of the Federal Reserve System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prudential regulator, as defined in section 1002 of the Consumer Financial Protection Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5481"},"text":"12 U.S.C. 5481","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Financial Crimes Enforcement Network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other Federal, State, or local agency, industry representative, consumer advocate, or entity, as determined by the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Compensation for Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Advisory Group shall serve without compensation in addition to any compensation received for the service of the member as an officer or employee of the United States, if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Group shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect information on the existence, use, and success of educational materials and programs for retailers, financial services, and wire-transfer companies, which—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used as a guide to educate employees on how to identify and prevent scams that affect seniors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" useful information for retailers, financial services, and wire transfer companies for the purpose described in clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for employees on ways to identify and prevent senior scams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"     “(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for keeping employees up to date on current scams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"     “(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most effective signage and placement in retail locations to warn seniors about scammers’ use of gift cards, prepaid cards, and wire transfer services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"     “(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggestions on effective collaborative community education campaigns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"     “(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available technology to assist in identifying possible scams at the point of sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"     “(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information that would be helpful to retailers, wire transfer companies, financial institutions, and their employees as they work to prevent fraud affecting seniors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" based on the findings in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify inadequacies, omissions, or deficiencies in those educational materials and programs for the categories listed in subparagraph (A) and their execution in reaching employees to protect older adults; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create model materials, best practices guidance, or recommendations to fill those inadequacies, omissions, or deficiencies that may be used by industry and others to help protect older adults from scams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encouraged use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman of the Federal Trade Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the materials or guidance created by the Federal Trade Commission described in paragraph (1) publicly available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the use and distribution of the materials created under this subsection to prevent scams affecting seniors by governmental agencies and the private sector.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tI/s112/a"},"text":"Pub. L. 117–103, div. Q, title I, § 112(a)","children":[],"tail":"–(d), set out above, ceases to be effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dQ/tI/s112/f"},"text":"section 112(f) of title I of div. Q of Pub. L. 117–103","children":[],"tail":", set out as a Termination of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21711"},"text":"section 21711 of Title 34","children":[],"tail":", Crime Control and Law Enforcement.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
