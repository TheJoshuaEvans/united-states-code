{"tag":"section","attrib":{"id":"id7a4c0ee2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5308"},"text":null,"children":[{"tag":"num","attrib":{"value":"5308"},"text":"§ 5308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of proprietary rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4c0ee3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proprietary rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No trade secrets or commercial or financial information that is privileged or confidential, under the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", which is obtained from a company as a result of activities under this chapter shall be disclosed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0ee4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, for a period of up to 5 years after the development of information that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4c0ee5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results from research and development activities conducted under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4c0ee6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be a trade secret or commercial or financial information that is privileged or confidential, under the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", if the information had been obtained from a company,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may provide appropriate protection against the dissemination of such information, including exemption from subchapter II of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4c0ee7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patent rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to patent rights, the Institutes shall be treated in the same manner as are nonprofit organizations and small business firms under chapter 18 of title 35, notwithstanding any provisions to the contrary contained in that chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4c0ee8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/425/s9"},"text":"Pub. L. 101–425, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/919"},"text":"104 Stat. 919","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
