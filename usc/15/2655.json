{"tag":"section","attrib":{"id":"id7a047f42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655"},"text":null,"children":[{"tag":"num","attrib":{"value":"2655"},"text":"§ 2655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worker protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a047f43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the local educational agency with authority over a school has submitted a management plan (for the school) which the State Governor has not disapproved as of the end of the period for review and revision of the plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2645"},"text":"section 2645 of this title","children":[],"tail":", the local educational agency may not do either of the following in the school:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047f44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Perform, or direct an employee to perform, renovations or removal of building materials, except emergency repairs, in the school, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a047f45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the school is carrying out work under a grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of title 20","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a047f46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an inspection that complies with the requirements of regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643"},"text":"section 2643 of this title","children":[],"tail":" has been carried out in the school and the agency complies with the following sections of title 40 of the Code of Federal Regulations:"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a047f47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (g), (h), and (i) of section 763.90 (response actions).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a047f48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appendix D to subpart E of part 763 (transport and disposal of asbestos waste).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Perform, or direct an employee to perform, operations and maintenance activities in the school, unless the agency complies with the following sections of title 40 of the Code of Federal Regulations:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a047f4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 763.91 (operations and maintenance), including appendix B to subpart E of part 763.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a047f4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (a)(2) of section 763.92 (training and periodic surveillance).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047f4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee training and equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any school employee who is directed to conduct emergency repairs involving any building material containing asbestos or suspected of containing asbestos, or to conduct operations and maintenance activities, in a school—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047f4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided the proper training to safely conduct such work in order to prevent potential exposure to asbestos; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided the proper equipment and allowed to follow work practices that are necessary to safely conduct such work in order to prevent potential exposure to asbestos.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047f4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Emergency repair” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “emergency repair” means a repair in a school building that was not planned and was in response to a sudden, unexpected event that threatens either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a047f50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health or safety of building occupants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a047f51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2655/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the structural integrity of the building.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a047f52-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s215"},"text":"Pub. L. 94–469, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/368/s4/a"},"text":"Pub. L. 100–368, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/832"},"text":"102 Stat. 832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a047f53-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a047f54-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a047f55-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/368/s4/c"},"text":"Pub. L. 100–368, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-18"},"text":"July 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/833"},"text":"102 Stat. 833","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/368/s4/c"},"text":"“Section 215 of the Toxic Substances Control Act [this section], as added by subsection (a), shall take effect on ","children":[{"tag":"date","attrib":{"date":"1988-10-12"},"text":"October 12, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
