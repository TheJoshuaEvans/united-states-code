{"tag":"section","attrib":{"id":"id7887063c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s202"},"text":null,"children":[{"tag":"num","attrib":{"value":"202"},"text":"§ 202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repairs to standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Such necessary repairs and adjustments shall be made to the standards furnished to the several States and Territories as may be requested by the governors thereof, and also to standard weights and measures that have been or may be supplied to United States customhouses and other offices of the United States under Act of Congress, when requested by the Secretary of Commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7887063d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-11/ch667/s1"},"text":"July 11, 1890, ch. 667, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/242"},"text":"26 Stat. 242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552"},"text":"Feb. 14, 1903, ch. 552","children":[],"tail":", §§ 4, 10, "},{"tag":"ref","attrib":{"href":"/us/stat/32/826"},"text":"32 Stat. 826","children":[],"tail":", 829; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7887063e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7887063f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78870640-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", created Department of Labor and renamed Department of Commerce and Labor as Department of Commerce."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78870641-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", transferred National Bureau of Standards from Treasury Department to Department of Commerce and Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
