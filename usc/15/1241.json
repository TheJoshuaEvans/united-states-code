{"tag":"section","attrib":{"id":"id796be8de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1241"},"text":null,"children":[{"tag":"num","attrib":{"value":"1241"},"text":"§ 1241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796be8df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “interstate commerce” means commerce between any State, Territory, possession of the United States, or the District of Columbia, and any place outside thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be8e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “switchblade knife” means any knife having a blade which opens automatically—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796be8e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1241/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by hand pressure applied to a button or other device in the handle of the knife, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be8e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1241/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by operation of inertia, gravity, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796be8e3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623/s1"},"text":"Pub. L. 85–623, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/562"},"text":"72 Stat. 562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be8e4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796be8e5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id796be8e6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623"},"text":"Pub. L. 85–623","children":[],"tail":", which enacted sections 1241 to 1244 of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1716"},"text":"section 1716 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be8e7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id796be8e8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623/s6"},"text":"Pub. L. 85–623, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/563"},"text":"72 Stat. 563","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/623/s6"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1716"},"text":"section 1716 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] shall take effect on the sixtieth day after the date of its enactment ["},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id796be8e9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tX/s10001"},"text":"Pub. L. 99–570, title X, § 10001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-166"},"text":"100 Stat. 3207–166","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/570/tX/s10001"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1245"},"text":"section 1245 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1716"},"text":"section 1716 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1245"},"text":"section 1245 of this title","children":[],"tail":"] may be cited as the ‘Ballistic Knife Prohibition Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id796be8ea-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/623"},"text":"Pub. L. 85–623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-12"},"text":"Aug. 12, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/562"},"text":"72 Stat. 562","children":[],"tail":", which enacted this chapter, is popularly known as the “Federal Switchblade Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
