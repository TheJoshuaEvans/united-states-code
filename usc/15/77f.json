null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$485,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 2015","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$515,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 2016","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$550,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 2017","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$585,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 2018","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$620,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 2019","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$660,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" 2020","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$705,000,000","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" 2021 and each fiscal year thereafter","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"An amount that is equal to the target fee collection amount for the prior fiscal year, adjusted by the rate of inflation.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e0176f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77f/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline estimate of the aggregate maximum offering prices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The baseline estimate of the aggregate maximum offering prices for any fiscal year is the baseline estimate of the aggregate maximum offering price at which securities are proposed to be offered pursuant to registration statements filed with the Commission during such fiscal year as determined by the Commission, after consultation with the Congressional Budget Office and the Office of Management and Budget, using the methodology required for projections pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s907"},"text":"section 907 of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e01770-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time registration effective","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The filing with the Commission of a registration statement, or of an amendment to a registration statement, shall be deemed to have taken place upon the receipt thereof, but the filing of a registration statement shall not be deemed to have taken place unless it is accompanied by a United States postal money order or a certified bank check or cash for the amount of the fee required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e01771-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information available to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information contained in or filed with any registration statement shall be made available to the public under such regulations as the Commission may prescribe, and copies thereof, photostatic or otherwise, shall be furnished to every applicant at such reasonable charge as the Commission may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e01772-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging growth companies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e01773-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any emerging growth company, prior to its initial public offering date, may confidentially submit to the Commission a draft registration statement, for confidential nonpublic review by the staff of the Commission prior to public filing, provided that the initial confidential submission and all amendments thereto shall be publicly filed with the Commission not later than 15 days before the date on which the issuer conducts a road show, as such term is defined in section 230.433(h)(4) of title 17, Code of Federal Regulations, or any successor thereto. An issuer that was an emerging growth company at the time it submitted a confidential registration statement or, in lieu thereof, a publicly filed registration statement for review under this subsection but ceases to be an emerging growth company thereafter shall continue to be treated as an emerging market growth company for the purposes of this subsection through the earlier of the date on which the issuer consummates its initial public offering pursuant to such registrations statement or the end of the 1-year period beginning on the date the company ceases to be an emerging growth company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e01774-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, the Commission shall not be compelled to disclose any information provided to or obtained by the Commission pursuant to this subsection. For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", this subsection shall be considered a statute described in subsection (b)(3)(B) of such section 552. Information described in or obtained pursuant to this subsection shall be deemed to constitute confidential information for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78x/b/2"},"text":"section 78x(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e01775-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/48/78"},"text":"48 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/289/s1"},"text":"Pub. L. 89–289, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1051"},"text":"79 Stat. 1051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/tII/s205"},"text":"Pub. L. 100–181, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1252"},"text":"101 Stat. 1252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/290/tIV/s404"},"text":"Pub. L. 104–290, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3441"},"text":"110 Stat. 3441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/123/s4"},"text":"Pub. L. 107–123, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2393"},"text":"115 Stat. 2393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s991/b/1"},"text":"Pub. L. 111–203, title IX, § 991(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1951"},"text":"124 Stat. 1951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/106/tI/s106/a"},"text":"Pub. L. 112–106, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-04-05"},"text":"Apr. 5, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/312"},"text":"126 Stat. 312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXI"},"text":"Pub. L. 114–94, div. G, title LXXI","children":[],"tail":", §§ 71001, 71002, "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1783"},"text":"129 Stat. 1783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e01776-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e01777-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77e01778-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 78m(e) and 78n(g) of this title, referred to in subsec. (b)(5), were in the original, “sections 13(e) and 14(g)” and were translated as meaning sections 13(e) and 14(g) of the Securities Exchange Act of 1934 to reflect the probable intent of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e01779-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “15 days” for “21 days” and inserted at end “An issuer that was an emerging growth company at the time it submitted a confidential registration statement or, in lieu thereof, a publicly filed registration statement for review under this subsection but ceases to be an emerging growth company thereafter shall continue to be treated as an emerging market growth company for the purposes of this subsection through the earlier of the date on which the issuer consummates its initial public offering pursuant to such registrations statement or the end of the 1-year period beginning on the date the company ceases to be an emerging growth company.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/106"},"text":"Pub. L. 112–106","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s991/b/1/A"},"text":"Pub. L. 111–203, § 991(b)(1)(A)","children":[],"tail":"–(G), in par. (5), substituted “target fee” for “target offsetting” and, in par. (11)(A), substituted “Target fee” for “Target offsetting” in heading and table and “target fee” for “target offsetting” in introductory provisions, redesignated pars. (2), (5), (7), (10), and (11) as (1), (2), (3), (5), and (6), respectively, and struck out former pars. (1), (3), (4), (6), (8), and (9) which related to recovery of cost of services, offsetting collections, prohibition of treatment of fees as general revenues, final rate adjustment, review and effective date of rates, and rate during lapse of appropriation, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s991/b/1/H"},"text":"Pub. L. 111–203, § 991(b)(1)(H)","children":[],"tail":", substituted “paragraph (2).” for “paragraph (5) or (6).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s991/b/1/I"},"text":"Pub. L. 111–203, § 991(b)(1)(I)","children":[],"tail":", substituted “For each fiscal year” for “For each of the fiscal years 2003 through 2011” and “paragraph (1)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s991/b/1/J"},"text":"Pub. L. 111–203, § 991(b)(1)(J)","children":[],"tail":", added par. (4). Former par. (4) struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s991/b/1/K"},"text":"Pub. L. 111–203, § 991(b)(1)(K)","children":[],"tail":", substituted “August 31” for “April 30”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s991/b/1/L"},"text":"Pub. L. 111–203, § 991(b)(1)(L)","children":[],"tail":", substituted “each fiscal year” for “each of the fiscal years 2002 through 2011” in introductory provisions and, in table, added items for fiscal years 2012 to 2021 and each fiscal year thereafter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123"},"text":"Pub. L. 107–123","children":[],"tail":" added pars. (2) to (11) and struck out former pars. (2) to (5), which required fee payment, set out rates for general revenue and offsetting collection fees, and required pro rata rates for amounts and balances equal to less than $1,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/290"},"text":"Pub. L. 104–290","children":[],"tail":" inserted heading and amended text of subsec. (b) generally. Prior to amendment, text read as follows: “At the time of filing a registration statement the applicant shall pay to the Commission a fee of one-fiftieth of 1 per centum of the maximum aggregate price at which such securities are proposed to be offered, but in no case shall such fee be less than $100.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/181"},"text":"Pub. L. 100–181","children":[],"tail":" struck out subsec. (e) which provided that no registration statement should be filed within the first 40 days following "},{"tag":"date","attrib":{"date":"1933-05-27"},"text":"May 27, 1933","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/289"},"text":"Pub. L. 89–289","children":[],"tail":" substituted “one-fiftieth” for “one one-hundredth” and “$100” for “$25”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e0177a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDat