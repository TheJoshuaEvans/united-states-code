"tag":"ref","attrib":{"href":"/us/pl/107/123/s11"},"text":"section 11 of Pub. L. 107–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78ee"},"text":"section 78ee of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e0177d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/289/s2"},"text":"Pub. L. 89–289, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1051"},"text":"79 Stat. 1051","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/289/s2"},"text":"“The amendment made by the first section of this Act [amending this section] shall take effect ","children":[{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e0177e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increase in Registration Fees and Deposit Into Treasury","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/46/s113"},"text":"Pub. L. 105–46, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"Sept. 30, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1156"},"text":"111 Stat. 1156","children":[],"tail":", provided that the amount made available to the Securities and Exchange Commission, under the heading Salaries and Expenses, was to include, in addition to direct appropriations, the amount collected under the fee rate and offsetting collection authority contained in "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Public Law 104–208","children":[],"tail":", which fee rate and offsetting collection authority was to remain in effect during the period of "},{"tag":"ref","attrib":{"href":"/us/pl/105/46"},"text":"Pub. L. 105–46","children":[],"tail":" which provided continuing appropriations for fiscal year 1998."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tV"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title V]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–61, which provided in part that on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", the rate of fees under subsec. (b) of this section were increased from one-fiftieth of one percentum to one-thirty-third of one percentum, and such increase was to be deposited as an offsetting collection to this appropriation, to remain available until expended, to recover costs of services of the securities registration process, was from the Departments of Commerce, Justice, and State, the Judiciary, and Related Agencies Appropriations Act, 1997, and was not repeated in subsequent appropriations acts. Similar provisions were contained in the following prior appropriation acts:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title V], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–60; renumbered title I, "},{"tag":"ref","attrib":{"href":