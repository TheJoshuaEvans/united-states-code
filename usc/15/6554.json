{"tag":"section","attrib":{"id":"id7a5a672c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554"},"text":null,"children":[{"tag":"num","attrib":{"value":"6554"},"text":"§ 6554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Online Safety and Technology working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5a672d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 90 days after ","children":[{"tag":"date","attrib":{"date":"2008-10-10"},"text":"October 10, 2008","children":[],"tail":", the Assistant Secretary of Commerce for Communications and Information shall establish an Online Safety and Technology working group comprised of representatives of relevant sectors of the business community, public interest groups, and other appropriate groups and Federal agencies to review and evaluate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a672e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of industry efforts to promote online safety through educational efforts, parental control technology, blocking and filtering software, age-appropriate labels for content or other technologies or initiatives designed to promote a safe online environment for children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a672f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of industry efforts to promote online safety among providers of electronic communications services and remote computing services by reporting apparent child pornography under section 13032 ","children":[{"tag":"ref","attrib":{"idref":"fn002553"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002553"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42, including any obstacles to such reporting;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6730-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the practices of electronic communications service providers and remote computing service providers related to record retention in connection with crimes against children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6731-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of technologies to help parents shield their children from inappropriate material on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a6732-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after the working group is first convened, it shall submit a report to the Assistant Secretary, the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Energy and Commerce of the House of Representatives that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a6733-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes in detail its findings, including any information related to the effectiveness of such strategies and technologies and any information about the prevalence within industry of educational campaigns, parental control technologies, blocking and filtering software, labeling, or other technologies to assist parents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a6734-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes recommendations as to what types of incentives could be used or developed to increase the effectiveness and implementation of such strategies and technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a6735-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5 not to apply to working group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the working group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a6736-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/385/tII/s214"},"text":"Pub. L. 110–385, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-10"},"text":"Oct. 10, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4103"},"t