{"tag":"section","attrib":{"id":"id7a6feb59-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7231"},"text":null,"children":[{"tag":"num","attrib":{"value":"7231"},"text":"§ 7231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board may, on a case by case basis, exempt any person, issuer, public accounting firm, or transaction from the prohibition on the provision of services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j–1/g"},"text":"section 78j–1(g) of this title","children":[],"tail":", to the extent that such exemption is necessary or appropriate in the public interest and is consistent with the protection of investors, and subject to review by the Commission in the same manner as for rules of the Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7217"},"text":"section 7217 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a6feb5a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tII/s201/b"},"text":"Pub. L. 107–204, title II, § 201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/772"},"text":"116 Stat. 772","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
