{"tag":"section","attrib":{"id":"id796be87a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1214"},"text":null,"children":[{"tag":"num","attrib":{"value":"1214"},"text":"§ 1214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Interstate commerce” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “interstate commerce” includes commerce between one State, Territory, possession, the District of Columbia, or the Commonwealth of Puerto Rico and another State, Territory, possession, the District of Columbia, or the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id796be87b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-02/ch890/s4"},"text":"Aug. 2, 1956, ch. 890, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/953"},"text":"70 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be87c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id796be87d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id796be87e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Secretary of Commerce and Federal Trade Commission under this chapter transferred to Consumer Product Safety Commission, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079"},"text":"section 2079 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
