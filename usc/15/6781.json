{"tag":"section","attrib":{"id":"id7a640491-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781"},"text":null,"children":[{"tag":"num","attrib":{"value":"6781"},"text":"§ 6781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of regulation for motor vehicle rentals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a640492-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against retroactive application of regulatory and legal action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), during the 3-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1999-11-12"},"text":"November 12, 1999","children":[],"tail":", it shall be a presumption that no State law imposes any licensing, appointment, or education requirements on any person who solicits the purchase of or sells insurance connected with, and incidental to, the lease or rental of a motor vehicle."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640493-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preeminence of State insurance law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No provision of this section shall be construed as altering the validity, interpretation, construction, or effect of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640494-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State statute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640495-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospective application of any court judgment interpreting or applying any State statute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640496-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prospective application of any final State regulation, order, bulletin, or other statutorily authorized interpretation or action,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which, by its specific terms, expressly regulates or exempts from regulation any person who solicits the purchase of or sells insurance connected with, and incidental to, the short-term lease or rental of a motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640497-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640498-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lease or rental of a motor vehicle for a total period of 90 consecutive days or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640499-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance which is provided in connection with, and incidentally to, such lease or rental for a period of consecutive days not exceeding the lease or rental period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a64049a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6781/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “motor vehicle” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13102"},"text":"section 13102 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a64049b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s341"},"text":"Pub. L. 106–102, title III, § 341","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1434"},"text":"113 Stat. 1434","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
