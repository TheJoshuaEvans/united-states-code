{"tag":"section","attrib":{"id":"id7a179175-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207"},"text":null,"children":[{"tag":"num","attrib":{"value":"3207"},"text":"§ 3207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a179176-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of Federal jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a179177-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, no court of the United States shall have jurisdiction over any action arising under any provision of this chapter except for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a179178-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action over which a court of the United States has jurisdiction under paragraph (2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a179179-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review in the Supreme Court of the United States in accordance with sections 1257 and 1258 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a17917a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may bring an action in any appropriate court of the United States to enforce his right to intervene under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3205"},"text":"section 3205 of this title","children":[],"tail":", and such court shall have jurisdiction to grant appropriate relief."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a17917b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a17917c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person may bring an action to enforce the requirements of this chapter in the appropriate State court. Such action in a State court shall be pursuant to applicable State procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a17917d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3207/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall authorize the Secretary to appeal or otherwise seek judicial review of the decisions of a State regulatory authority or nonregulated gas utility or to become a party to any action to obtain such review or appeal. The Secretary may participate as an amicus curiae in any judicial review of an action arising under the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a17917e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tIII/s307"},"text":"Pub. L. 95–617, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3153"},"text":"92 Stat. 3153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a17917f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a179180-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id7a179181-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions of Secretary and State in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602"},"text":"section 2602 of Title 16","children":[],"tail":", Conservation, apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
