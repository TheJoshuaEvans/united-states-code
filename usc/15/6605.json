{"tag":"section","attrib":{"id":"id7a5a67c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605"},"text":null,"children":[{"tag":"num","attrib":{"value":"6605"},"text":"§ 6605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportionate liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5a67c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in a Y2K action that is a contract action, and except as provided in subsections (b) through (g), a person against whom a final judgment is entered in a Y2K action shall be liable solely for the portion of the judgment that corresponds to the relative and proportionate responsibility of that person. In determining the percentage of responsibility of any defendant, the trier of fact shall determine that percentage as a percentage of the total fault of all persons, including the plaintiff, who caused or contributed to the total loss incurred by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proportionate liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a67c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any Y2K action that is not a contract action, the court shall instruct the jury to answer special interrogatories, or, if there is no jury, the court shall make findings with respect to each defendant, including defendants who have entered into settlements with the plaintiff or plaintiffs, concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of responsibility, if any, of each defendant, measured as a percentage of the total fault of all persons who caused or contributed to the loss incurred by the plaintiff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if alleged by the plaintiff, whether the defendant (other than a defendant who has entered into a settlement agreement with the plaintiff)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a67c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acted with specific intent to injure the plaintiff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a67c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly committed fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of special interrogatories or findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The responses to interrogatories or findings under paragraph (1) shall specify the total amount of damages that the plaintiff is entitled to recover and the percentage of responsibility of each defendant found to have caused or contributed to the loss incurred by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors for consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the percentage of responsibility under this subsection, the trier of fact shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the conduct of each person found to have caused or contributed to the loss incurred by the plaintiff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and extent of the causal relationship between the conduct of each such person and the damages incurred by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint liability for specific intent or fraud","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a67cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), the liability of a defendant in a Y2K action that is not a contract action is joint and several if the trier of fact specifically determines that the defendant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acted with specific intent to injure the plaintiff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly committed fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud; recklessness","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowing commission of fraud described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b)(1)(B)(ii) and paragraph (1)(B) of this subsection, a defendant knowingly committed fraud if the defendant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a67d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made an untrue statement of a material fact, with actual knowledge that the statement was false;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a67d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" omitted a fact necessary to make the statement not be misleading, with actual knowledge that, as a result of the omission, the statement was false; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5a67d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knew that the plaintiff was reasonably likely to rely on the false statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5a67d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recklessness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (b)(1)(B) and paragraph (1) of this subsection, reckless conduct by the defendant does not constitute either a specific intent to injure, or the knowing commission of fraud, by the defendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a67d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to contribution not affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section affects the right, under any other law, of a defendant to contribution with respect to another defendant found under subsection (b)(1)(B), or determined under paragraph (1)(B) of this subsection, to have acted with specific intent to injure the plaintiff or to have knowingly committed fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a67d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a67da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uncollectible share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5a67db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), if, upon motion made not later than 6 months after a final judgment is entered in any Y2K action that is not a contract action, the court determines that all or part of the share of the judgment against a defendant for compensatory damages is not collectible against that defendant, then each other defendant in the action is liable for the uncollectible share as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5a67dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage of net worth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The other defendants are jointly and severally liable for the uncollectible share if the plaintiff establishes that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a5a67dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plaintiff is an individual whose recoverable damages under the final judgment are equal to more than 10 percent of the net worth of the plaintiff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5a67de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net worth of the plaintiff is less than $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5cd7df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other plaintiffs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a plaintiff not described in clause (i), each of the other defendants is liable for the uncollectible share in proportion to the percentage of responsibility of that defendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5cd7e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For a plaintiff not described in clause (i), in addition to the share identified in clause (ii), the defendant is liable for an additional portion of the uncollectible share in an amount equal to 50 percent of the amount determined under clause (ii) if the plaintiff demonstrates by a preponderance of the evidence that the defendant acted with reckless disregard for the likelihood that its acts would cause injury of the sort suffered by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total payments required under subparagraph (A) from all defendants may not exceed the amount of the uncollectible share.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A defendant against whom judgment is not collectible is subject to contribution and to any continuing liability to the plaintiff on the judgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suits by consumers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a5cd7e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subparagraph (A), the other defendants are jointly and severally liable for the uncollectible share if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a5cd7e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plaintiff is a consumer whose suit alleges or arises out of a defect in a consumer product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5cd7e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plaintiff is suing as an individual and not as part of a class action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a5cd7e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subparagraph:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a5cd7e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “class action” means—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7a5cd7e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single lawsuit in which: (1) damages are sought on behalf of more than 10 persons or prospective class members; or (2) one or more named parties seek to recover damages on a representative basis on behalf of themselves and other unnamed parties similarly situated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7a5cd7ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any group of lawsuits filed in or pending in the same court in which: (1) damages are sought on behalf of more than 10 persons; and (2) the lawsuits are joined, consolidated, or otherwise proceed as a single action for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5cd7eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer” means an individual who acquires a consumer product for purposes other than resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a5cd7ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/1/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer product” means any personal property or service which is normally used for personal, family, or household purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd7ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special right of contribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent that a defendant is required to make an additional payment under paragraph (1), that defendant may recover contribution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5cd7ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the defendant originally liable to make the payment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other defendant that is jointly and severally liable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other defendant held proportionately liable who is liable to make the same payment and has paid less than that other defendant’s proportionate share of that payment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other person responsible for the conduct giving rise to the payment that would have been liable to make the same payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd7f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure to jury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standard for allocation of damages under subsection (a) and subsection (b)(1), and the procedure for reallocation of uncollectible shares under paragraph (1) of this subsection, shall not be disclosed to members of the jury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd7f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement discharge","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd7f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A defendant who settles a Y2K action that is not a contract action at any time before final verdict or judgment shall be discharged from all claims for contribution brought by other persons. Upon entry of the settlement by the court, the court shall enter an order constituting the final discharge of all obligations to the plaintiff of the settling defendant arising out of the action. The order shall bar all future claims for contribution arising out of the action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5cd7f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any person against the settling defendant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the settling defendant against any person other than a person whose liability has been extinguished by the settlement of the settling defendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd7f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a defendant enters into a settlement with the plaintiff before the final verdict or judgment, the verdict or judgment shall be reduced by the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a5cd7f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that corresponds to the percentage of responsibility of that defendant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a5cd7f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid to the plaintiff by that defendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd7fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General right of contribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd7fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A defendant who is jointly and severally liable for damages in any Y2K action that is not a contract action may recover contribution from any other person who, if joined in the original action, would have been liable for the same damages. A claim for contribution shall be determined based on the percentage of responsibility of the claimant and of each person against whom a claim for contribution is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd7fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations for contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action for contribution in connection with a Y2K action that is not a contract action shall be brought not later than 6 months after the entry of a final, nonappealable judgment in the Y2K action, except that an action for contribution brought by a defendant who was required to make an additional payment under subsection (d)(1) may be brought not later than 6 months after the date on which such payment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5cd7fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" More protective State law not preempted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section preempts or supersedes any provision of State law that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5cd7fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the liability of a defendant in a Y2K action to a lesser amount than the amount determined under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5cd7ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6605/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise affords a greater degree of protection from joint or several liability than is afforded by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5cd800-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s6"},"text":"Pub. L. 106–37, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/192"},"text":"113 Stat. 192","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
