{"tag":"section","attrib":{"id":"id7a533b68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152"},"text":null,"children":[{"tag":"num","attrib":{"value":"6152"},"text":"§ 6152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telemarketing Sales Rule; do-not-call registry fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a533b69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Trade Commission shall assess and collect an annual fee pursuant to this section in order to implement and enforce the “do-not-call” registry as provided for in section 310.4(b)(1)(iii) of title 16, Code of Federal Regulations, or any other regulation issued by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6102"},"text":"section 6102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall charge each person who accesses the “do-not-call” registry an annual fee that is equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $54 for each area code of data accessed from the registry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $14,850 for access to every area code of data contained in the registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall not charge a fee to any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for accessing the first 5 area codes of data; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for accessing area codes of data in the registry if the person is permitted to access, but is not required to access, the “do-not-call” registry under section ","children":[{"tag":"ref","attrib":{"idref":"fn002546"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002546"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “part”."}],"tail":" 310 of title 16, Code of Federal Regulations, section 64.1200 of title 47, Code of Federal Regulations, or any other Federal regulation or law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of access","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall allow each person who pays the annual fee described in paragraph (1), each person excepted under paragraph (2) from paying the annual fee, and each person excepted from paying an annual fee under section 310.4(b)(1)(iii)(B) of title 16, Code of Federal Regulations, to access the area codes of data in the “do-not-call” registry for which the person has paid during that person’s annual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “annual period” means the 12-month period beginning on the first day of the month in which a person pays the fee described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall charge a person required to pay an annual fee under subsection (b) an additional fee for each additional area code of data the person wishes to access during that person’s annual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each additional area code of data to be accessed during the person’s annual period, the Commission shall charge—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $54 for access to such data if access to the area code of data is first requested during the first 6 months of the person’s annual period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $27 for access to such data if access to the area code of data is first requested after the first 6 months of the person’s annual period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2009","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The dollar amount described in subsection (b) or (c) is the amount to be charged for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal years after 2009","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year beginning after fiscal year 2009, each dollar amount in subsection (b)(1) and (c)(2) shall be increased by an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a533b7d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar amount in paragraph (b)(1) or (c)(2), whichever is applicable, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a533b7e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage (if any) by which the CPI for the most recently ended 12-month period ending on June 30 exceeds the baseline CPI.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b7f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rounding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any increase under subparagraph (B) shall be rounded to the nearest dollar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b80-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes less than 1 percent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall not adjust the fees under this section if the change in the CPI is less than 1 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b81-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than September 1 of each year the Commission shall publish in the Federal Register the adjustments to the applicable fees, if any, made under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b82-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a533b83-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CPI","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “CPI” means the average of the monthly consumer price index (for all urban consumers published by the Department of Labor).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a533b84-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline CPI","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “baseline CPI” means the CPI for the 12-month period ending ","children":[{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b85-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against fee sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may enter into or participate in an arrangement (as such term is used in section 310.8(c) of the Commission’s regulations (16 C.F.R. 310.8(c))) to share any fee required by subsection (b) or (c), including any arrangement to divide the costs to access the registry among various clients of a telemarketer or service provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a533b86-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handling of fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a533b87-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall deposit and credit as offsetting collections any fee collected under this section in the account “Federal Trade Commission—Salaries and Expenses”, and such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a533b88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6152/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amount shall be collected as a fee under this section for any fiscal year except to the extent provided in advance by appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a533b89-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/10/s2"},"text":"Pub. L. 108–10, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-03-11"},"text":"Mar. 11, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/557"},"text":"117 Stat. 557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/188/s2"},"text":"Pub. L. 110–188, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-02-15"},"text":"Feb. 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/635"},"text":"122 Stat. 635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a533b8a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a533b8b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a533b8c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/188"},"text":"Pub. L. 110–188","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Federal Trade Commission may promulgate regulations establishing fees sufficient to implement and enforce the provisions relating to the ‘do-not-call’ registry of the Telemarketing Sales Rule (16 CFR 310.4(b)(1)(iii)), promulgated under the Telemarketing and Consumer Fraud and Abuse Prevention Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6101"},"text":"15 U.S.C. 6101","children":[],"tail":" et seq.). Such regulations shall be promulgated in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code. Fees may be collected pursuant to this section for fiscal years 2003 through 2007, and shall be deposited and credited as offsetting collections to the account, Federal Trade Commission—Salaries and Expenses, and shall remain available until expended. No amounts shall be collected as fees pursuant to this section for such fiscal years except to the extent provided in advance in appropriations Acts. Such amounts shall be available for expenditure only to offset the costs of activities and services related to the implementation and enforcement of the Telemarketing Sales Rule, and other activities resulting from such implementation and enforcement.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ab8d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a55ab8e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/188/s4"},"text":"Pub. L. 110–188, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-02-15"},"text":"Feb. 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/637"},"text":"122 Stat. 637","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/188/s4"},"text":"“The Federal Trade Commission may issue rules, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code, as necessary and appropriate to carry out the amendments to the Do-Not-Call Implementation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6101"},"text":"15 U.S.C. 6101","children":[],"tail":" note) [now this chapter] made by this Act [amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6154"},"text":"section 6154 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
