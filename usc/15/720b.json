{"tag":"section","attrib":{"id":"id7948336c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b"},"text":null,"children":[{"tag":"num","attrib":{"value":"720b"},"text":"§ 720b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7948336d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with NEPA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuance of a certificate of public convenience and necessity authorizing the construction and operation of any Alaska natural gas transportation project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s720a"},"text":"section 720a of this title","children":[],"tail":" shall be treated as a major Federal action significantly affecting the quality of the human environment within the meaning of section 102(2)(C) of the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"42 U.S.C. 4332(2)(C)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7948336e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of lead agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7948336f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79483370-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be the lead agency for purposes of complying with the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79483371-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be responsible for preparing the environmental impact statement required by section 102(2)(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002282"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002282"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “102(2)(C)”."}],"tail":" of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"42 U.S.C. 4332(2)(C)","children":[],"tail":"] with respect to an Alaska natural gas transportation project under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s720a"},"text":"section 720a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483372-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Commission shall prepare a single environmental impact statement, which shall consolidate the environmental reviews of all Federal agencies considering any aspect of the Alaska natural gas transportation project covered by the environmental impact statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79483373-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483374-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal agency considering an aspect of the construction and operation of an Alaska natural gas transportation project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s720a"},"text":"section 720a of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79483375-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79483376-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with deadlines established by the Commission in the preparation of the environmental impact statement under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79483377-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfaction of NEPA requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The environmental impact statement prepared under this section shall be adopted by each Federal agency described in paragraph (1) in satisfaction of the responsibilities of the Federal agency under section 102(2)(C) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"42 U.S.C. 4332(2)(C)","children":[],"tail":") with respect to the Alaska natural gas transportation project covered by the environmental impact statement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79483378-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79483379-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the Commission determines that the application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s720a"},"text":"section 720a of this title","children":[],"tail":" with respect to an Alaska natural gas transportation project is complete, issue a draft environmental impact statement under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7948337a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s720b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date of issuance of the draft environmental impact statement, issue a final environmental impact statement, unless the Commission for good cause determines that additional time is needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7948337b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/dC/s104"},"text":"Pub. L. 108–324, div. C, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1257"},"text":"118 Stat. 1257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7948337c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7948337d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7948337e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
