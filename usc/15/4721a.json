{"tag":"section","attrib":{"id":"id7a429985-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4721a"},"text":"§ 4721a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State trade coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a429986-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a429987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal and State export promotion coordination plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a429988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, acting through the Trade Promotion Coordinating Committee and in coordination with representatives of State trade promotion agencies, shall develop a comprehensive plan to integrate the resources and strategies of State trade promotion agencies into the overall Federal trade promotion program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a42998a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the role of State trade promotion agencies in assisting exporters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42998b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An outline of the role of State trade promotion agencies and how it is different from Federal agencies located within or providing services within the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42998c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan on how to utilize State trade promotion agencies in the Federal trade promotion program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42998d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of how Federal and State agencies will share information and resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42998e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how Federal and State agencies will coordinate education and trade events in the United States and abroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a42998f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the efforts to increase efficiency and reduce duplication.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429990-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A clear identification of where businesses can receive appropriate international trade information under the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429991-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan required under paragraph (1) shall be finalized and submitted to Congress not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a429992-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Federal-State export strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a429993-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, acting through the head of the United States Foreign and Commercial Service,","children":[{"tag":"ref","attrib":{"idref":"fn002532"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002532"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “United States and Foreign Commercial Service,”."}],"tail":" shall develop an annual Federal-State export strategy for each State that submits to the Secretary of Commerce its export strategy for the upcoming calendar year. In developing an annual Federal-State export strategy under this paragraph, the Secretary of Commerce shall take into account the Federal and State export promotion coordination plan developed under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429994-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters to be included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal-State export strategy required under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a429995-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State’s export strategy and economic goals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429996-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State’s key sectors and industries of focus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429997-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Possible foreign and domestic trade events.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a429998-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to increase efficiencies and reduce duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a429999-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal-State export strategy required under paragraph (1) shall be submitted to the Trade Promotion Coordinating Committee not later than ","children":[{"tag":"date","attrib":{"date":"2017-02-01"},"text":"February 1, 2017","children":[],"tail":", and February 1 of each year thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a42999a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinated metrics and information sharing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a42999b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce, in coordination with representatives of State trade promotion agencies, shall develop a framework to share export success information, and develop a coordinated set of reporting metrics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a42999c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2016-02-24"},"text":"February 24, 2016","children":[],"tail":", the Secretary of Commerce shall submit to Congress a report that contains the framework and reporting metrics required under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a42999d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4721a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a42999e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/tV/s505"},"text":"Pub. L. 114–125, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/179"},"text":"130 Stat. 179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a42999f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4299a0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a4299a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Small Business Trade Enhancement Act of 2015 or the State Trade Coordination Act, and also as part of the Trade Facilitation and Trade Enforcement Act of 2015, and not as part of the Export Enhancement Act of 1988 which enacted this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s505"},"text":"section 505 of Pub. L. 114–125","children":[],"tail":". Subsecs. (a) and (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s505"},"text":"section 505 of Pub. L. 114–125","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s4727"},"text":"section 4727 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
