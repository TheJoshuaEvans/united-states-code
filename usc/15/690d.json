{"tag":"section","attrib":{"id":"id792b83da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d"},"text":null,"children":[{"tag":"num","attrib":{"value":"690d"},"text":"§ 690d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debentures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792b83db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may guarantee the timely payment of principal and interest, as scheduled, on debentures issued by any Renewable Fuel Capital Investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may make guarantees under this section on such terms and conditions as it determines appropriate, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b83dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of any debenture guaranteed under this section shall not exceed 15 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a debenture guaranteed under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792b83df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall carry no front-end or annual fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b83e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be issued at a discount;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b83e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require no interest payments during the 5-year period beginning on the date the debenture is issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b83e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be prepayable without penalty after the end of the 1-year period beginning on the date the debenture is issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792b83e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require semiannual interest payments after the period described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to pay all amounts that may be required to be paid under any guarantee under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b83e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum guarantee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792b83e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under this section, the Administrator may guarantee the debentures issued by a Renewable Fuel Capital Investment company only to the extent that the total face amount of outstanding guaranteed debentures of such company does not exceed 150 percent of the private capital of the company, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792b83e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of paragraph (1), private capital shall include capital that is considered to be Federal funds, if such capital is contributed by an investor other than a department or agency of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b83e8-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s385"},"text":"Pub. L. 85–699, title III, § 385","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1778"},"text":"121 Stat. 1778","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
