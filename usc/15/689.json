{"tag":"section","attrib":{"id":"id792939c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689"},"text":null,"children":[{"tag":"num","attrib":{"value":"689"},"text":"§ 689.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792939c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developmental venture capital","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developmental venture capital” means capital in the form of equity capital investments in businesses made with a primary objective of fostering economic development in low-income geographic areas. For the purposes of this paragraph, the term “equity capital” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s683/g/4"},"text":"section 683(g)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “low-income individual” means an individual whose income (adjusted for family size) does not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792939c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for metropolitan areas, 80 percent of the area median income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792939ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for nonmetropolitan areas, the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792939cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the area median income; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792939cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the statewide nonmetropolitan area median income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income geographic area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"the ","children":[{"tag":"ref","attrib":{"idref":"fn002254"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002254"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" term “low-income geographic area” means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792939ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any population census tract (or in the case of an area that is not tracted for population census tracts, the equivalent county division, as defined by the Bureau of the Census of the Department of Commerce for purposes of defining poverty areas), if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792939cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the poverty rate for that census tract is not less than 20 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792939d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a tract—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id792939d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located within a metropolitan area, 50 percent or more of the households in that census tract have an income equal to less than 60 percent of the area median gross income; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id792939d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not located within a metropolitan area, the median household income for such tract does not exceed 80 percent of the statewide median household income; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792939d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the Administrator based on objective criteria, a substantial population of low-income individuals reside, an inadequate access to investment capital exists, or other indications of economic distress exist in that census tract; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792939d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any area located within—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id792939d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a HUBZone (as defined in section 632(p) ","children":[{"tag":"ref","attrib":{"idref":"fn002255"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002255"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title and the implementing regulations issued under that section);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792939d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an urban empowerment zone or urban enterprise community (as designated by the Secretary of Housing and Urban Development); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id792939d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rural empowerment zone or rural enterprise community (as designated by the Secretary of Agriculture).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Markets Venture Capital company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “New Markets Venture Capital company” means a company that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792939d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been granted final approval by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s689c/e"},"text":"section 689c(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792939da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into a participation agreement with the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational assistance” means management, marketing, and other technical assistance that assists a small business concern with business development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “participation agreement” means an agreement, between the Administrator and a company granted final approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s689c/e"},"text":"section 689c(e) of this title","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792939dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details the company’s operating plan and investment criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792939de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the company to make investments in smaller enterprises at least 80 percent of which are located in low-income geographic areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialized small business investment company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specialized small business investment company” means any small business investment company that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id792939e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invests solely in small business concerns that contribute to a well-balanced national economy by facilitating ownership in such concerns by persons whose participation in the free enterprise system is hampered because of social or economic disadvantages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792939e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized or chartered under State business or nonprofit corporations statutes, or formed as a limited partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id792939e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s681/d"},"text":"section 681(d) of this title","children":[],"tail":", as in effect before "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792939e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means such ","children":[{"tag":"ref","attrib":{"idref":"fn002256"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002256"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “each”."}],"tail":" of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and any other commonwealth, territory, or possession of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792939e4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s351"},"text":"Pub. L. 85–699, title III, § 351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–653.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792939e5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792939e6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id792939e7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/p"},"text":"Section 632(p) of this title","children":[],"tail":", referred to in par. (3)(B)(i), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657a/b"},"text":"section 657a(b) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVII/s1701/a/2"},"text":"Pub. L. 115–91, div. A, title XVII, § 1701(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1795"},"text":"131 Stat. 1795","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
