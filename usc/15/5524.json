{"tag":"section","attrib":{"id":"id7a50f059-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524"},"text":null,"children":[{"tag":"num","attrib":{"value":"5524"},"text":"§ 5524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Commerce activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a50f05a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the Program described in subchapter I—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f05b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the National Institute of Standards and Technology shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f05c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct basic and applied measurement research needed to support various networking and information technology systems and capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f05d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and propose standards and guidelines, and develop measurement techniques and test methods, for the interoperability and usability of networking and information technology systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f05e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for developing benchmark tests and standards for networking and information technology systems and software; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f05f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Oceanic and Atmospheric Administration shall conduct basic and applied research in weather prediction and ocean sciences, particularly in development of new forecast models, in computational fluid dynamics, and in the incorporation of evolving computer architectures and networks into the systems that carry out agency missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f060-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Networking and information technology security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Institute of Standards and Technology shall be responsible for developing and proposing standards and guidelines needed to assure the cost-effective security and privacy of Federal agency information and information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f061-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/194/tII/s204"},"text":"Pub. L. 102–194, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1601"},"text":"105 Stat. 1601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105/m"},"text":"Pub. L. 114–329, title I, § 105(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2984"},"text":"130 Stat. 2984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a50f062-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a50f063-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a50f064-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/m/1/A"},"text":"Pub. L. 114–329, § 105(m)(1)(A)","children":[],"tail":", substituted “networking and information technology systems and capabilities” for “high-performance computing systems and networks”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/m/1/B"},"text":"Pub. L. 114–329, § 105(m)(1)(B)","children":[],"tail":", substituted “interoperability and usability of networking and information technology systems” for “interoperability of high-performance computing systems in networks and for common user interfaces to systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/m/1/C"},"text":"Pub. L. 114–329, § 105(m)(1)(C)","children":[],"tail":", substituted “networking and information technology” for “high-performance computing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/m/2"},"text":"Pub. L. 114–329, § 105(m)(2)","children":[],"tail":", in heading, substituted “Networking and information technology” for “High-performance computing and network” and, in text, substituted “The National Institute” for “Pursuant to the Computer Security Act of 1987 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/235"},"text":"Public Law 100–235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/101/1724"},"text":"101 Stat. 1724","children":[],"tail":"), the National Institute” and “Federal agency information and information systems” for “sensitive information in Federal computer systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/s105/m/3"},"text":"Pub. L. 114–329, § 105(m)(3)","children":[],"tail":", struck out subsecs. (c) and (d) which required a study of the impact of Federal procurement regulations and authorized appropriations for fiscal years 1992 to 1996."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
