{"tag":"section","attrib":{"id":"id79293a25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d"},"text":null,"children":[{"tag":"num","attrib":{"value":"689d"},"text":"§ 689d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debentures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79293a26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may guarantee the timely payment of principal and interest, as scheduled, on debentures issued by any New Markets Venture Capital company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make guarantees under this section on such terms and conditions as it deems appropriate, except that the term of any debenture guaranteed under this section shall not exceed 15 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The full faith and credit of the United States is pledged to pay all amounts that may be required to be paid under any guarantee under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum guarantee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under this section, the Administrator may guarantee the debentures issued by a New Markets Venture Capital company only to be ","children":[{"tag":"ref","attrib":{"idref":"fn002258"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002258"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “the”."}],"tail":" extent that the total face amount of outstanding guaranteed debentures of such company does not exceed 150 percent of the private capital of the company, as determined by the Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain Federal funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of paragraph (1), private capital shall include capital that is considered to be Federal funds, if such capital is contributed by an investor other than an agency or department of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered New Markets Venture Capital company” means a New Markets Venture Capital company—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293a2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" granted final approval by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s689c/e"},"text":"section 689c(e) of this title","children":[],"tail":" on or after "},{"tag":"date","attrib":{"date":"2002-03-01"},"text":"March 1, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293a2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has obtained a financing from the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79293a30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent approved by the Administrator, a covered New Markets Venture Capital company may not acquire or issue commitments for securities under this subchapter for any single enterprise in an aggregate amount equal to more than 10 percent of the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293a31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulatory capital of the covered New Markets Venture Capital company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293a32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689d/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of leverage projected in the participation agreement of the covered New Markets Venture Capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293a33-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s355"},"text":"Pub. L. 85–699, title III, § 355","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–658; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/240/tI/s1115"},"text":"Pub. L. 111–240, title I, § 1115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2508"},"text":"124 Stat. 2508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79293a34-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79293a35-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79293a36-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240"},"text":"Pub. L. 111–240","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
