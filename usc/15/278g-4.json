{"tag":"section","attrib":{"id":"id7892edc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"278g–4"},"text":"§ 278g–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information Security and Privacy Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7892edc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established a ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" Information Security and Privacy Advisory Board within the Department of Commerce. The Secretary of Commerce shall appoint the chairman of the Board. The Board shall be composed of twelve additional members appointed by the Secretary of Commerce as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892edc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members from outside the Federal Government who are eminent in the information technology industry, at least one of whom is representative of small or medium sized companies in such industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892edc5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members from outside the Federal Government who are eminent in the fields of information technology, or related disciplines, but who are not employed by or representative of a producer of information technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892edc6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members from the Federal Government who have information system management experience, including experience in information security and privacy, at least one of whom shall be from the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edc7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Board shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892edc8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify emerging managerial, technical, administrative, and physical safeguard issues relative to information security and privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892edc9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advise the Institute, the Secretary of Homeland Security, and the Director of the Office of Management and Budget on information security and privacy issues pertaining to Federal Government information systems, including through review of proposed standards and guidelines developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892edca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report annually its findings to the Secretary of Commerce, the Secretary of Homeland Security, the Director of the Office of Management and Budget, the Director of the National Security Agency, and the appropriate committees of the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edcb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of office of each member of the Board shall be four years, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7892edcc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the initial members, three shall be appointed for terms of one year, three shall be appointed for terms of two years, three shall be appointed for terms of three years, and three shall be appointed for terms of four years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7892edcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member appointed to fill a vacancy in the Board shall serve for the remainder of the term for which his predecessor was appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall not act in the absence of a quorum, which shall consist of seven members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board, other than full-time employees of the Federal Government, while attending meetings of such committees or while otherwise performing duties at the request of the Board Chairman while away from their homes or a regular place of business, may be allowed travel expenses in accordance with subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall hold meetings at such locations and at such time and place as determined by a majority of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff services and utilization of Federal personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To provide the staff services necessary to assist the Board in carrying out its functions, the Board may utilize personnel from the Institute or any other agency of the Federal Government with the consent of the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7892edd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278g–4/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":" As used in this section, the terms “information system” and “information technology” have the meanings given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7892edd3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s21"},"text":"Mar. 3, 1901, ch. 872, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/235/s3/2"},"text":"Pub. L. 100–235, § 3(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1727"},"text":"101 Stat. 1727","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/a/1"},"text":"Pub. L. 100–418, title V, § 5115(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tX/s1004"},"text":"Pub. L. 107–296, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2271"},"text":"116 Stat. 2271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/tIII/s304"},"text":"Pub. L. 107–347, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2959"},"text":"116 Stat. 2959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/f/2"},"text":"Pub. L. 113–283, § 2(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3087"},"text":"128 Stat. 3087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7892edd4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7892edd5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7892edd6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/f/2/A"},"text":"Pub. L. 113–283, § 2(f)(2)(A)","children":[],"tail":", inserted “, the Secretary of Homeland Security,” after “the Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/f/2/B"},"text":"Pub. L. 113–283, § 2(f)(2)(B)","children":[],"tail":", inserted “the Secretary of Homeland Security,” after “the Secretary of Commerce,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/1"},"text":"Pub. L. 107–296, § 1004(1)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/1"},"text":"Pub. L. 107–347, § 304(1)","children":[],"tail":", amended subsec. (a) identically, substituting “Information Security and Privacy Advisory Board” for “Computer System Security and Privacy Advisory Board” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/2"},"text":"Pub. L. 107–296, § 1004(2)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/2"},"text":"Pub. L. 107–347, § 304(2)","children":[],"tail":", amended par. (1) identically, substituting “information technology” for “computer or telecommunications”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/3"},"text":"Pub. L. 107–296, § 1004(3)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/3"},"text":"Pub. L. 107–347, § 304(3)","children":[],"tail":", amended par. (2) identically, substituting “information technology” for “computer or telecommunications technology” and for “computer or telecommunications equipment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/4"},"text":"Pub. L. 107–296, § 1004(4)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/4"},"text":"Pub. L. 107–347, § 304(4)","children":[],"tail":", amended par. (3) identically, substituting “information system” for “computer systems” and “information security” for “computer systems security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/5"},"text":"Pub. L. 107–296, § 1004(5)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/5"},"text":"Pub. L. 107–347, § 304(5)","children":[],"tail":", amended par. (1) identically, substituting “information security” for “computer systems security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/6"},"text":"Pub. L. 107–347, § 304(6)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “to advise the Institute and the Secretary of Commerce on security and privacy issues pertaining to Federal computer systems; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/6"},"text":"Pub. L. 107–296, § 1004(6)","children":[],"tail":", added par. (2) and struck out former par. (2), as added by "},{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":", which read as follows: “to advise the Institute, the Secretary of Commerce, and the Director of the Office of Management and Budget on information security and privacy issues pertaining to Federal Government information systems, including through review of proposed standards and guidelines developed under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/7"},"text":"Pub. L. 107–296, § 1004(7)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/7"},"text":"Pub. L. 107–347, § 304(7)","children":[],"tail":", amended par. (3) identically, inserting “annually” after “report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/8"},"text":"Pub. L. 107–296, § 1004(8)","children":[],"tail":", (9), and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/8"},"text":"Pub. L. 107–347, § 304(8)","children":[],"tail":", (9), amended section identically, adding subsec. (f) and redesignating former subsec. (f) as (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/10"},"text":"Pub. L. 107–296, § 1004(10)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/10"},"text":"Pub. L. 107–347, § 304(10)","children":[],"tail":", amended section identically, adding subsec. (h) and striking out former subsec. (h) which read as follows: “As used in this section, the terms ‘computer system’ and ‘Federal computer system’ have the meanings given in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s278g–3"},"text":"section 278g–3 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1004/9"},"text":"Pub. L. 107–296, § 1004(9)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s304/9"},"text":"Pub. L. 107–347, § 304(9)","children":[],"tail":", amended section identically, redesignating subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", which directed that this chapter be amended by substituting “Institute” for “National Bureau of Standards”, “Bureau”, or “bureau”, wherever appearing, was executed to par. (2) by substituting “Institute” for “Bureau of Standards”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “Institute” for “National Bureau of Standards”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7892edd7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7892edd8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/b"},"text":"section 402(b) of Pub. L. 107–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3504"},"text":"section 3504 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7892edd9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards in existence on ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period following "},{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by the Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
