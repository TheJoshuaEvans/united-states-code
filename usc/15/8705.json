{"tag":"section","attrib":{"id":"id7a8c73bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705"},"text":null,"children":[{"tag":"num","attrib":{"value":"8705"},"text":"§ 8705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8c73c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that assessments shall be paid by a manufacturer if the manufacturer has manufactured concrete masonry products during a period of at least 180 days prior to the date the assessment is to be remitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assessments required under the order shall be remitted by the manufacturer to the Board in the manner prescribed by the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that assessments required under the order shall be remitted to the Board not less frequently than quarterly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the remittance of assessments, manufacturers shall identify the total amount due in assessments on all sales receipts, invoices or other commercial documents of sale as a result of the sale of concrete masonry units in a manner as prescribed by the Board to ensure compliance with the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment rates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to assessment rates, the order shall contain the following terms:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment rate on concrete masonry products shall be $0.01 per concrete masonry unit sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in the rate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c73c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to change rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall have the authority to change the assessment rate. A two-thirds majority of voting members of the Board shall be required to approve a change in the assessment rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on increases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An increase or decrease in the assessment rate with respect to concrete masonry products may not exceed $0.01 per concrete masonry unit sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment rate shall not be in excess of $0.05 per concrete masonry unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on frequency of changes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assessment rate may not be increased or decreased more than once annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late-payment and interest charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Late-payment and interest charges may be levied on each person subject to the order who fails to remit an assessment in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rate for late-payment and interest charges shall be specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pending disbursement of assessments under a budget approved by the Secretary, the Board may invest assessments collected under this section in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations of the United States or any agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general obligations of any State or any political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest-bearing accounts or certificates of deposit of financial institutions that are members of the Federal Reserve System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations fully guaranteed as to principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c73d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment funds for regional initiatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c73d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that not less than 50 percent of the assessments (less administration expenses) paid by a manufacturer shall be used to support research, education, and promotion programs and projects in support of the geographic region of the manufacturer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic regions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall provide for the following geographic regions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c73d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Region I shall comprise Connecticut, Delaware, the District of Columbia, Maine, Maryland, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, Vermont, and West Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Region II shall comprise Alabama, Florida, Georgia, Mississippi, North Carolina, South Carolina, Tennessee, and Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Region III shall comprise Illinois, Indiana, Iowa, Kentucky, Michigan, Minnesota, Nebraska, North Dakota, Ohio, South Dakota, and Wisconsin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Region IV shall comprise Arizona, Arkansas, Kansas, Louisiana, Missouri, New Mexico, Oklahoma, and Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c73db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Region V shall comprise Alaska, California, Colorado, Hawaii, Idaho, Montana, Nevada, Oregon, Utah, Washington, and Wyoming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c73dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8705/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of geographic regions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Secretary may, upon recommendation of the Board, modify the composition of the geographic regions described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8c73dd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1306"},"text":"Pub. L. 115–254, div. E, § 1306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3478"},"text":"132 Stat. 3478","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
