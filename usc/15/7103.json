{"tag":"section","attrib":{"id":"id7a6b08e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103"},"text":null,"children":[{"tag":"num","attrib":{"value":"7103"},"text":"§ 7103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of the Interagency Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6b08e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b08e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Committee shall be composed of 1 representative from each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b08e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board of Governors of the Federal Reserve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive staff of the President engaged in policymaking activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b08ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the head of each department and agency listed in paragraph (1) shall, not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"1997-12-02"},"text":"December 2, 1997","children":[],"tail":", designate a representative who shall be a policymaking official within the department or agency, and who shall report directly to the head of the agency on the status of the activities of the Interagency Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b08ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Business Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the Small Business Administration, the representative shall be the Assistant Administrator of the Office of Women’s Business Ownership, who also shall serve as the vice chairperson of the Interagency Committee and shall report directly to the Administrator on the status of the activities on the Interagency Committee and shall serve as the Interagency Committee Liaison to the National Women’s Business Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7105"},"text":"section 7105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Other representatives of the Federal Government not listed in paragraph (1) may participate in the meetings and functions of the Interagency Committee on a temporary basis as needed to carry out specific Interagency Committee goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"1997-12-02"},"text":"December 2, 1997","children":[],"tail":", the President, in consultation with the Administrator of the Small Business Administration, shall appoint 1 of the members of the Interagency Committee to serve as chairperson."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Interagency Committee shall serve without additional pay for such membership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request by the chairperson of the Interagency Committee, the head of any Federal department or agency may detail any of the personnel of such agency to assist the Interagency Committee in carrying out its duties under this chapter without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3341"},"text":"section 3341 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b08f4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s403"},"text":"Pub. L. 100–533, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tIV/s413"},"text":"Pub. L. 103–403, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4194"},"text":"108 Stat. 4194","children":[],"tail":"; amended "},{"tag":"ref","attr