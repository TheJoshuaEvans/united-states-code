{"tag":"section","attrib":{"id":"id789a1978-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u"},"text":null,"children":[{"tag":"num","attrib":{"value":"278u"},"text":"§ 278u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Xylazine detection and analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id789a1979-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789a197a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a197b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal laboratory” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3703"},"text":"section 3703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a197c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Institute” means the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a197d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a197e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit organization” means an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a197f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Xylazine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “xylazine” means the nonopioid tranquilizer methyl benzene compound frequently used in veterinary medicine as an emetic and sedative with analgesic and muscle relaxant properties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789a1980-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id789a1981-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support intramural basic measurement science and research of the Institute to advance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789a1982-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytical methods to identify, understand, differentiate, and categorize substances containing xylazine, novel synthetic opioids, or other new psychoactive substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1983-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurement technologies to shorten analysis timelines and enhance narcotic and opioid detection and analysis capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1984-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new data tools, techniques, and processes to identify and publicly disclose relevant information concerning substances containing xylazine, novel synthetic opioids, or other new psychoactive substances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1985-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other areas as the Director determines to be critical to the development and deployment of technologies to measure and analyze the presence of xylazine, novel synthetic opioids, and other new psychoactive substances;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a1986-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support activities to inform and expand the development of near-real time spectrometry capabilities regarding xylazine, novel synthetic opioids, and other new psychoactive substances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a1987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" convene and consult with organizations engaged in the analysis of new psychoactive substances to develop coordinated strategies and voluntary best practices for the safe handling, transport, data-sharing, and analysis of substances containing xylazine, novel synthetic opioids, or other new psychoactive substances, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id789a1988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Drug Enforcement Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a198a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institute on Drug Abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a198b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a198c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States and territories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a198d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State fusion centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a198e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a198f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intergovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1990-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education,","children":[{"tag":"ref","attrib":{"idref":"fn002161"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id789a1991-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789a1992-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or expand collaborative partnerships or consortia with other government agencies and persons engaged in related research and development, such as institutions of higher education, Federal laboratories, public health agencies, intergovernmental organizations, and the private sector, to enhance narcotic and opioid detection and analysis capabilities regarding xylazine, novel synthetic opioids, and other new psychoactive substances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id789c8993-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage graduate and post-graduate research to include detection and identification of xylazine and other new psychoactive substances in relevant course studies when practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789c8994-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out activities under this section, the Director shall ensure proper security controls are implemented to protect sensitive information, as the Director considers appropriate and consistent with applicable provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id789c8995-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s278u/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2023-12-19"},"text":"December 19, 2023","children":[],"tail":", the Director shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report on the implementation of this section. Such report may include recommendations for legislative action to improve the ability of the Director to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id789c8996-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/23/s2"},"text":"Pub. L. 118–23, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-19"},"text":"Dec. 19, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/125"},"text":"137 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id789c8997-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id789c8998-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id789c8999-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Testing, Rapid Analysis, and Narcotic Quality Research Act of 2023, also known as the TRANQ Research Act of 2023, and not as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
