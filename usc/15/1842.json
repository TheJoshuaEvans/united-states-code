{"tag":"section","attrib":{"id":"id79c68b6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1842"},"text":null,"children":[{"tag":"num","attrib":{"value":"1842"},"text":"§ 1842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for loan guarantees; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board, on such terms and conditions as it deems appropriate, may guarantee, or make commitments to guarantee, lenders against loss of principal or interest on loans that meet the requirements of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c68b6d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/70/s3"},"text":"Pub. L. 92–70, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-09"},"text":"Aug. 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/178"},"text":"85 Stat. 178","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
