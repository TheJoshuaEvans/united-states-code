{"tag":"section","attrib":{"id":"id78b1e6f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b"},"text":null,"children":[{"tag":"num","attrib":{"value":"631b"},"text":"§ 631b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress; state of small business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78b1e6f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on Small Business and Competition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall transmit to the Congress not later than January 20 of each year a Report on Small Business and Competition which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b1e6f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the current role of small business in the economy on an industry-by-industry basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e6f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present current and historical data on production, employment, investment, population, job creation and retention, annual business failures, annual business startups, and other economic variables for small business in the economy as a whole and for small business in each sector of the economy, with, to the extent practicable, specific statistics divided as to urban, suburban, and rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e6f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify economic trends which will or may affect the small business sector and the state of competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e6f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the effects on small business and competition of policies, programs, and activities, including, but not limited to the Internal Revenue Code [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.], the Employee Retirement Income Security Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"29 U.S.C. 1001","children":[],"tail":" et seq.], the Securities Act of 1933 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.], and the Securities Exchange Act of 1934 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.], and regulations promulgated thereunder; identify problems generated by such policies, programs, and activities; and recommend legislative and administrative solutions to such problems; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e6f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend a program for carrying out the policy declared in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631a"},"text":"section 631a of this title","children":[],"tail":", together with such recommendations for legislation as he may deem necessary or desirable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e6fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appendix to report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President also shall transmit simultaneously as an appendix to such annual report, a report, by agency and department, on the total dollar value of all Federal contracts exceeding $10,000 in amount and the dollar amount (including the subcontracts thereunder in excess of $10,000) awarded to small, minority-owned, female-owned, and veteran-owned businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e6fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplementary reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may transmit from time to time to the Congress reports supplementary to the Report on Small Business and Competition, each of which shall include such supplementary or revised recommendations as he may deem necessary or desirable to achieve the policy declared in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631a"},"text":"section 631a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e6fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Report on Small Business and Competition and all supplementary reports transmitted under subsections (b) and (c) of this section shall, when transmitted to Congress, be referred to the Senate Select Committee on Small Business and the Committee on Small Business of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78b1e6fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concerns owned by disadvantaged individuals and by women ","children":[{"tag":"ref","attrib":{"idref":"fn002168"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002168"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See 1988 Amendment note below."}],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information and data required to be reported pursuant to subsection (a) shall separately detail those portions of such information and data that are relevant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78b1e6fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns owned and controlled by socially and economically disadvantaged individuals, by gender, as defined pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"section 637(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e6ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns owned and controlled by women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e700-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Two pars. (3) have been enacted."}],"tail":" qualified HUBZone small business concern (as defined in section 632(p) "},{"tag":"ref","attrib":{"idref":"fn002170"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78b1e701-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s631b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" small business concerns owned and controlled by veterans, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/q"},"text":"section 632(q) of this title","children":[],"tail":", and small business concerns owned and controlled by service-disabled veterans, as defined in such "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/q"},"text":"section 632(q) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78b1e702-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/302/tIII/s303"},"text":"Pub. L. 96–302, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-02"},"text":"July 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/848"},"text":"94 Stat. 848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/533/tV/s503"},"text":"Pub. L. 100–533, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2697"},"text":"102 Stat. 2697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/590/tI/s124"},"text":"Pub. L. 100–590, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-03"},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3000"},"text":"102 Stat. 3000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/574/tIII/s305"},"text":"Pub. L. 101–574, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2829"},"text":"104 Stat. 2829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tVI/s604/c"},"text":"Pub. L. 105–135, title VI, § 604(c)","children":[],"tail":", title VII, § 705, "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2633"},"text":"111 Stat. 2633","children":[],"tail":", 2637; "},{"tag":"ref","attrib":{"href":"/us/pl/106/50/tVI/s602"},"text":"Pub. L. 106–50, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-17"},"text":"Aug. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/248"},"text":"113 Stat. 248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78b1e703-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78b1e704-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78b1e705-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code, referred to in subsec. (a)(4), is classified to Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Employee Retirement Income Security Act, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/829"},"text":"88 Stat. 829","children":[],"tail":", which is classified principally to chapter 18 (§ 1001 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Act of 1933, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38/tI"},"text":"act May 27, 1933, ch. 38, title I","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in subsec. (a)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/p"},"text":"Section 632(p) of this title","children":[],"tail":", referred to in subsec. (e)(3), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657a/b"},"text":"section 657a(b) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVII/s1701/a/2"},"text":"Pub. L. 115–91, div. A, title XVII, § 1701(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1795"},"text":"131 Stat. 1795","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78b1e706-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Small Business Economic Policy Act of 1980, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78b1e707-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/50/s602/1"},"text":"Pub. L. 106–50, § 602(1)","children":[],"tail":", which directed amendment of par. (1) by striking “and” after the semicolon, could not be executed because the word “and” did not appear after the semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/50/s602/2"},"text":"Pub. L. 106–50, § 602(2)","children":[],"tail":", which directed amendment of par. (2) by substituting “; and” for the period, could not be executed because par. (2) did not contain a period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/50/s602/3"},"text":"Pub. L. 106–50, § 602(3)","children":[],"tail":", added par. (3) relating to small business concerns owned and controlled by veterans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s705"},"text":"Pub. L. 105–135, § 705","children":[],"tail":", substituted “, female-owned, and veteran-owned businesses” for “and female-owned businesses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s604/c"},"text":"Pub. L. 105–135, § 604(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/574"},"text":"Pub. L. 101–574","children":[],"tail":" added par. (2) and struck out former par. (2) which read as follows: “present current and historical data on production, employment, investment, and other economic variables for small business in the economy as a whole and for small business in each sector of the economy;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533"},"text":"Pub. L. 100–533","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/590"},"text":"Pub. L. 100–590","children":[],"tail":" added subsecs. (e) which were identical, except that the subsec. (e) added by "},{"tag":"ref","attrib":{"href":"/us/pl/100/533"},"text":"Pub. L. 100–533","children":[],"tail":", which is set out as text of this section, contained the phrase “, by gender,” in par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78b1e708-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78b1e709-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Small Business of Senate changed to Committee on Small Business and Entrepreneurship of Senate. See Senate Resolution No. 123, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-06-29"},"text":"June 29, 2001","children":[],"tail":". Previously, Select Committee on Small Business of Senate became Committee on Small Business of Senate. See Senate Resolution No. 101, Ninety-Seventh Congress, "},{"tag":"date","attrib":{"date":"1981-03-25"},"text":"Mar. 25, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78b1e70a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135"},"text":"Pub. L. 105–135","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/s3"},"text":"section 3 of Pub. L. 105–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78b1e70b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/302/s507"},"text":"section 507 of Pub. L. 96–302","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id78b1e70c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in subsecs. (a) and (b) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and pages 17 and 34 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
