{"tag":"section","attrib":{"id":"id7aa4413f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063"},"text":null,"children":[{"tag":"num","attrib":{"value":"9063"},"text":"§ 9063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa44140-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), on ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", the authority provided under this part to make loans, loan guarantees, or other investments shall terminate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44141-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outstanding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44142-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), any loan or loan guarantee made under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":" outstanding on the date described in subsection (a)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa44143-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified, restructured, or otherwise amended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa44144-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be forgiven.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44145-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The duration of any loan or loan guarantee made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b/1"},"text":"section 9042(b)(1) of this title","children":[],"tail":" that is modified, restructured, or otherwise amended under paragraph (1) shall not be extended beyond 5 years from the initial origination date of the loan or loan guarantee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44146-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve programs or facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44147-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", the Board of Governors of the Federal Reserve System and the Federal Reserve banks shall not make any loan, purchase any obligation, asset, security, or other interest, or make any extension of credit through any program or facility established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of title 12","children":[],"tail":" in which the Secretary made a loan, loan guarantee, or other investment pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b/4"},"text":"section 9042(b)(4) of this title","children":[],"tail":", other than a loan submitted, on or before "},{"tag":"date","attrib":{"date":"2020-12-14"},"text":"December 14, 2020","children":[],"tail":", to the Main Street Lending Program’s lender portal for the sale of a participation interest in such loan, provided that the Main Street Lending Program purchases a participation interest in such loan on or before "},{"tag":"date","attrib":{"date":"2021-01-08"},"text":"January 8, 2021","children":[],"tail":" and under the terms and conditions of the Main Street Lending Program as in effect on the date the loan was submitted to the Main Street Lending Program’s lender portal for the sale of a participation interest in such loan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44148-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No modification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", the Board of Governors of the Federal Reserve System and the Federal Reserve banks—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa44149-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not modify the terms and conditions of any program or facility established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of title 12","children":[],"tail":" in which the Secretary made a loan, loan guarantee, or other investment pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b/4"},"text":"section 9042(b)(4) of this title","children":[],"tail":", including by authorizing transfer of such funds to a new program or facility established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of title 12","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa4414a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may modify or restructure a loan, obligation, asset, security, other interest, or extension of credit made or purchased through any such program or facility provided that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa4414b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan, obligation, asset, security, other interest, or extension of credit is an eligible asset or for an eligible business, including an eligible nonprofit organization, each as defined by such program or facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa4414c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification or restructuring relates to an eligible asset or single and specific eligible business, including an eligible nonprofit organization, each as defined by such program or facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa4414d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification or restructuring is necessary to minimize costs to taxpayers that could arise from a default on the loan, obligation, asset, security, other interest, or extension of credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4414e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa4414f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary is permitted to use the fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":" for any purpose permitted under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa44150-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9063/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":" shall not be available for any program or facility established under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s343/3"},"text":"section 343(3) of title 12","children":[],"tail":" that is the same as any such program or facility in which the Secretary made an investment pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b/4"},"text":"section 9042(b)(4) of this title","children":[],"tail":", except the Term Asset-Backed Securities Loan Facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa44151-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4029"},"text":"Pub. L. 116–136, div. A, title IV, § 4029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/497"},"text":"134 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tX/s1005"},"text":"Pub. L. 116–260, div. N, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2146"},"text":"134 Stat. 2146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa44152-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa44153-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aa44154-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (a), was in the original “this subtitle”, meaning subtitle A (§§ 4001–4029) of title IV of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":", known as the Coronavirus Economic Stabilization Act of 2020, which is classified principally to this part. For complete classification of subtitle A to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s4001"},"text":"section 4001 of Pub. L. 116–136","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9001"},"text":"section 9001 of this title","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7aa44155-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1005/1"},"text":"Pub. L. 116–260, § 1005(1)","children":[],"tail":", struck out “new” after “make”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1005/2"},"text":"Pub. L. 116–260, § 1005(2)","children":[],"tail":", substituted “or loan guarantee made under paragraph (1), (2), or (3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9042/b"},"text":"section 9042(b) of this title","children":[],"tail":"” for “, loan guarantee, or other investment” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s1005/3"},"text":"Pub. L. 116–260, § 1005(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
