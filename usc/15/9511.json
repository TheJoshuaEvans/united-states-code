{"tag":"section","attrib":{"id":"id7ab04f0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511"},"text":null,"children":[{"tag":"num","attrib":{"value":"9511"},"text":"§ 9511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Under Secretary shall, whenever the Under Secretary determines such action is necessary or appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab04f10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide Federal assistance to minority business enterprises operating in domestic and foreign markets by making available to those business enterprises, either directly or in cooperation with private sector entities, including community-based organizations and national nonprofit organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources relating to management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technological and technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial, legal, and marketing services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services relating to workforce development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage minority business enterprises to establish joint ventures and projects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab04f16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with other minority business enterprises; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab04f17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with public sector entities or private sector entities, including community-based organizations and national nonprofit organizations, to increase the share of any market activity being performed by minority business enterprises; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab04f18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9511/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the efforts of private sector entities and Federal agencies to advance the growth of minority business enterprises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab04f19-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tI/s100101"},"text":"Pub. L. 117–58, div. K, title I, § 100101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1449"},"text":"135 Stat. 1449","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
