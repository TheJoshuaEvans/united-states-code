{"tag":"section","attrib":{"id":"id78253751-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78o–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"78o–2"},"text":"§ 78o–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liabilities arising prior to amendment unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this Act shall be deemed to extinguish any liability which may have arisen prior to the effective date of this Act by reason of any violation of section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title or of any rule or regulation thereunder."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78253752-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-27/ch462/s11"},"text":"May 27, 1936, ch. 462, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1380"},"text":"49 Stat. 1380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78253753-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78253754-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78253755-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-27/ch462"},"text":"act May 27, 1936, ch. 462","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1375"},"text":"49 Stat. 1375","children":[],"tail":", popularly known as the Unlisted Securities Trading Act, which enacted sections 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1, 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1, 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–2, and 78hh–1 of this title, and amended sections 78"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":", 78q, 78r, 78t, 78u, 78w, and 78ff of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Effective date of this Act, referred to in text, is ","children":[{"tag":"date","attrib":{"date":"1934-07-01"},"text":"July 1, 1934","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78hh–1"},"text":"section 78hh–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78253756-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of the Securities Exchange Act of 1934 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
