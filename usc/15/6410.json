{"tag":"section","attrib":{"id":"id7a57f67f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6410"},"text":null,"children":[{"tag":"num","attrib":{"value":"6410"},"text":"§ 6410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to preempt or supersede any other program relating to propane education and research organized and operated under the laws of the United States or any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a57f680-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/284/s11"},"text":"Pub. L. 104–284, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3375"},"text":"110 Stat. 3375","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
