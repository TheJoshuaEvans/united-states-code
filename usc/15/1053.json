{"tag":"section","attrib":{"id":"id79568b32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1053"},"text":null,"children":[{"tag":"num","attrib":{"value":"1053"},"text":"§ 1053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service marks registrable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions relating to the registration of trademarks, so far as they are applicable, service marks shall be registrable, in the same manner and with the same effect as are trademarks, and when registered they shall be entitled to the protection provided in this chapter in the case of trademarks. Applications and procedure under this section shall conform as nearly as practicable to those prescribed for the registration of trademarks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79568b33-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title I, § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/60/429"},"text":"60 Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/tI/s105"},"text":"Pub. L. 100–667, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3938"},"text":"102 Stat. 3938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/43/s6/b"},"text":"Pub. L. 106–43, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-08-05"},"text":"Aug. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/220"},"text":"113 Stat. 220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79568b34-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79568b35-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79568b36-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/43"},"text":"Pub. L. 106–43","children":[],"tail":" substituted “trademarks” for “trade-marks” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667"},"text":"Pub. L. 100–667","children":[],"tail":" struck out “used in commerce” after “applicable, service marks” and “, except when used so as to represent falsely that the owner thereof makes or sells the goods on which such mark is used. The Commissioner may establish a separate register for such service marks” after “case of trade-marks”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79568b37-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79568b38-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667"},"text":"Pub. L. 100–667","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/s136"},"text":"section 136 of Pub. L. 100–667","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79568b39-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal and Effect on Existing Rights","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Repeal of inconsistent provisions, effect of this chapter on pending proceedings and existing registrations and rights under prior acts, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79568b3a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id79568b3b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of other officers, employees, and agencies of Department of Commerce, with certain exceptions, to Secretary of Commerce, with power to delegate, see Reorg. Plan No. 5 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3174, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1263"},"text":"64 Stat. 1263","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
