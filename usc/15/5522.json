{"tag":"section","attrib":{"id":"id7a4e804b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5522"},"text":null,"children":[{"tag":"num","attrib":{"value":"5522"},"text":"§ 5522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Aeronautics and Space Administration activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As part of the Program described in subchapter I, the National Aeronautics and Space Administration shall conduct basic and applied research in networking and information technology, particularly in the field of computational science, with emphasis on aerospace sciences, earth and space sciences, and remote exploration and experimentation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a4e804c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/194/tII/s202"},"text":"Pub. L. 102–194, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1600"},"text":"105 Stat. 1600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tI/s105/k"},"text":"Pub. L. 114–329, title I, § 105(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2983"},"text":"130 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4e804d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4e804e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4e804f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329"},"text":"Pub. L. 114–329","children":[],"tail":" struck out subsec. (a) designation and heading “General responsibilities”, substituted “networking and information technology” for “high-performance computing”, and struck out subsec. (b) which authorized appropriations for fiscal years 1992 to 1996."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
