{"tag":"section","attrib":{"id":"id78824ba5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80b–18c"},"text":null,"children":[{"tag":"num","attrib":{"value":"80b–18c"},"text":"§ 80b–18c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction relating to the Commodities Exchange Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall relieve any person of any obligation or duty, or affect the availability of any right or remedy available to the Commodity Futures Trading Commission or any private party, arising under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.) governing commodity pools, commodity pool operators, or commodity trading advisors."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78824ba6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title II, § 224, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIV/s414"},"text":"Pub. L. 111–203, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1578"},"text":"124 Stat. 1578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824ba7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78824ba8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id78824ba9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78824baa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78824bab-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except that any investment adviser may, at the discretion of the investment adviser, register with the Commission under the Investment Advisers Act of 1940 during that 1-year period, subject to the rules of the Commission, and except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s419"},"text":"section 419 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2"},"text":"section 80b–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tai