{"tag":"section","attrib":{"id":"id7a0960ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695"},"text":null,"children":[{"tag":"num","attrib":{"value":"2695"},"text":"§ 2695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for healthy school environments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a0960ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Secretary of Education, may provide grants to States for use in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0960af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance for programs of the Environmental Protection Agency (including the Tools for Schools Program and the Healthy School Environmental Assessment Tool) to schools for use in addressing environmental issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" development and implementation of State school environmental health programs that include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a0960b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for school building design, construction, and renovation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a0960b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of ongoing school building environmental problems, including contaminants, hazardous substances, and pollutant emissions, in the State and recommended solutions to address those problems, including assessment of information on the exposure of children to environmental hazards in school facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a0960b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Administrator to carry out this section shall expire 5 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0960b4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tV/s501"},"text":"Pub. L. 94–469, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s461/a"},"text":"Pub. L. 110–140, title IV, § 461(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1640"},"text":"121 Stat. 1640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a0960b5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a0960b6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a0960b7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
