{"tag":"section","attrib":{"id":"id79bd1543-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693l–1"},"text":"§ 1693l–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General-use prepaid cards, gift certificates, and store gift cards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79bd1544-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1545-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dormancy fee; inactivity charge or fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “dormancy fee” and “inactivity charge or fee” mean a fee, charge, or penalty for non-use or inactivity of a gift certificate, store gift card, or general-use prepaid card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1546-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General use ","children":[{"tag":"ref","attrib":{"idref":"fn002409"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002409"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “General-use”."}],"tail":" prepaid card, gift certificate, and store gift card"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd1547-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General-use prepaid card","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “general-use prepaid card” means a card or other payment code or device issued by any person that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79bd1548-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeemable at multiple, unaffiliated merchants or service providers, or automated teller machines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1549-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued in a requested amount, whether or not that amount may, at the option of the issuer, be increased in value or reloaded if requested by the holder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd154a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchased or loaded on a prepaid basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd154b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" honored, upon presentation, by merchants for goods or services, or at automated teller machines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd154c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gift certificate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “gift certificate” means an electronic promise that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79bd154d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeemable at a single merchant or an affiliated group of merchants that share the same name, mark, or logo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd154e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued in a specified amount that may not be increased or reloaded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd154f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchased on a prepaid basis in exchange for payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1550-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" honored upon presentation by such single merchant or affiliated group of merchants for goods or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1551-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Store gift card","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “store gift card” means an electronic promise, plastic card, or other payment code or device that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79bd1552-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeemable at a single merchant or an affiliated group of merchants that share the same name, mark, or logo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1553-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued in a specified amount, whether or not that amount may be increased in value or reloaded at the request of the holder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1554-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchased on a prepaid basis in exchange for payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1555-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" honored upon presentation by such single merchant or affiliated group of merchants for goods or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1556-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “general-use prepaid card”, “gift certificate”, and “store gift card” do not include an electronic promise, plastic card, or payment code or device that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79bd1557-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used solely for telephone services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1558-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reloadable and not marketed or labeled as a gift card or gift certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd1559-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loyalty, award, or promotional gift card, as defined by the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd155a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not marketed to the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd155b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued in paper form only (including for tickets and events); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd155c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" redeemable solely for admission to events or venues at a particular location or group of affiliated locations, which may also include services or goods obtainable—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id79bd155d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the event or venue after admission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id79bd155e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/2/D/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with admission to such events or venues, at specific locations affiliated with and in geographic proximity to the event or venue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd155f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service fee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd1560-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “service fee” means a periodic fee, charge, or penalty for holding or use of a gift certificate, store gift card, or general-use prepaid card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1561-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a general-use prepaid card, the term “service fee” does not include a one-time initial issuance fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1562-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on imposition of fees or charges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1563-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under paragraphs (2) through (4), it shall be unlawful for any person to impose a dormancy fee, an inactivity charge or fee, or a service fee with respect to a gift certificate, store gift card, or general-use prepaid card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1564-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dormancy fee, inactivity charge or fee, or service fee may be charged with respect to a gift certificate, store gift card, or general-use prepaid card, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd1565-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been no activity with respect to the certificate or card in the 12-month period ending on the date on which the charge or fee is imposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1566-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure requirements of paragraph (3) have been met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1567-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than one fee may be charged in any given month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1568-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional requirements that the Bureau may establish through rulemaking under subsection (d) have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1569-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The disclosure requirements of this paragraph are met if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd156a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the gift certificate, store gift card, or general-use prepaid card clearly and conspicuously states—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79bd156b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a dormancy fee, inactivity charge or fee, or service fee may be charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd156c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of such fee or charge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd156d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how often such fee or charge may be assessed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79bd156e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such fee or charge may be assessed for inactivity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd156f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuer or vendor of such certificate or card informs the purchaser of such charge or fee before such certificate or card is purchased, regardless of whether the certificate or card is purchased in person, over the Internet, or by telephone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1570-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under paragraph (1) shall not apply to any gift certificate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd1571-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is distributed pursuant to an award, loyalty, or promotional program, as defined by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1572-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which, there is no money or other value exchanged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1573-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on sale of gift cards with expiration dates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1574-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under paragraph (2), it shall be unlawful for any person to sell or issue a gift certificate, store gift card, or general-use prepaid card that is subject to an expiration date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1575-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A gift certificate, store gift card, or general-use prepaid card may contain an expiration date if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd1576-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration date is not earlier than 5 years after the date on which the gift certificate was issued, or the date on which card funds were last loaded to a store gift card or general-use prepaid card; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd1577-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of expiration are clearly and conspicuously stated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1578-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional rulemaking","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1579-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd157a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations to carry out this section, in addition to any other rules or regulations required by this subchapter, including such additional requirements as appropriate relating to the amount of dormancy fees, inactivity charges or fees, or service fees that may be assessed and the amount of remaining value of a gift certificate, store gift card, or general-use prepaid card below which such charges or fees may be assessed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd157b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ","children":[{"tag":"ref","attrib":{"idref":"fn002410"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002410"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “shall” probably should not appear."}],"tail":" determine the extent to which the individual definitions and provisions of this subchapter or Regulation E should apply to general-use prepaid cards, gift certificates, and store gift cards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd157c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing regulations under this subsection, the Bureau shall consult with the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd157d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693l–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing; effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations required by this subsection shall be issued in final form not later than 9 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bd157e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIX/s915"},"text":"Pub. L. 90–321, title IX, § 915","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tIV/s401/2"},"text":"Pub. L. 111–24, title IV, § 401(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1751"},"text":"123 Stat. 1751","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1084/1"},"text":"Pub. L. 111–203, title X, § 1084(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2081"},"text":"124 Stat. 2081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79bd157f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79bd1580-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79bd1581-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s915"},"text":"section 915 of Pub. L. 90–321","children":[],"tail":" was renumbered section 916 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693m"},"text":"section 1693m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79bd1582-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79bd1583-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79bd1584-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79bd1585-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/tIV/s403"},"text":"Pub. L. 111–24, title IV, § 403","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/209/s1"},"text":"Pub. L. 111–209, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-27"},"text":"July 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2254"},"text":"124 Stat. 2254","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/209/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under subsection (b) of this section, this title [enacting this section and amending sections 1693m to 1693r of this title and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"section 1693 of this title","children":[],"tail":"] and the amendments made by this title shall become effective 15 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a gift certificate, store gift card, or general-use prepaid card that was produced prior to ","children":[{"tag":"date","attrib":{"date":"2010-04-01"},"text":"April 1, 2010","children":[],"tail":", the effective date of the disclosure requirements described in sections 915(b)(3) and (c)(2)(B) of the Electronic Funds [probably should be “Fund”] Transfer Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1(b)(3), (c)(2)(B)] shall be "},{"tag":"date","attrib":{"date":"2011-01-31"},"text":"January 31, 2011","children":[],"tail":", provided that an issuer of such a certificate or card shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with paragraphs (1) and (2) of section 915(b) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1(b)(1), (2)];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any such certificate or card for which funds expire to have no expiration date with respect to the underlying funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a consumer’s request, replace such certificate or card that has funds remaining at no cost to the consumer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the disclosure requirements of paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The disclosure requirements of this subsection are met by providing notice to consumers, via in-store signage, messages during customer service calls, Web sites, and general advertising, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such certificate or card for which funds expire shall be deemed to have no expiration date with respect to the underlying funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumers holding such certificate or card shall have a right to a free replacement certificate or card that includes the packaging and materials, typically associated with such a certificate or card; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dormancy fee, inactivity fee, or service fee for such certificates or cards that might otherwise be charged shall not be charged if such fees do not comply with section 915 of the Electronic Funds [probably should be “Fund”] Transfer Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693"},"text":"15 U.S.C. 1693","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period for disclosure requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notice requirements in paragraph (2) of this subsection shall continue until ","children":[{"tag":"date","attrib":{"date":"2013-01-31"},"text":"January 31, 2013","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/24/tIV/s403"},"text":"Pub. L. 111–24, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1754"},"text":"123 Stat. 1754","children":[],"tail":", which provided that title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/111/24"},"text":"Pub. L. 111–24","children":[],"tail":" was to become effective 15 months after "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/209/s1"},"text":"Pub. L. 111–209, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-27"},"text":"July 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2254"},"text":"124 Stat. 2254","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
