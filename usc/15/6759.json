{"tag":"section","attrib":{"id":"id7a640454-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6759"},"text":null,"children":[{"tag":"num","attrib":{"value":"6759"},"text":"§ 6759.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a640455-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6759/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines that the Association is acting in a manner contrary to the interests of the public or the purposes of this subchapter or has failed to perform its duties under this subchapter, the President may remove the entire existing Board for the remainder of the term to which the Board members were appointed and appoint, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6754"},"text":"section 6754 of this title","children":[],"tail":" and with the advice and consent of the Senate, in accordance with the procedures established under Senate Resolution 116 of the 112th Congress, new Board members to fill the vacancies on the Board for the remainder of the terms."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640456-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6759/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of Board member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may remove a Board member only for neglect of duty or malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a640457-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6759/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of bylaws and standards and prohibition of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following notice to the Board, the President, or a person designated by the President for such purpose, may suspend the effectiveness of any bylaw or standard, or prohibit any action, of the Association that the President or the designee determines is contrary to the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a640458-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s329"},"text":"Pub. L. 106–102, title III, § 329","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/25"},"text":"129 Stat. 25","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a640459-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a64045a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a64045b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Senate Resolution 116 of the 112th Congress, referred to in subsec. (a), which was agreed to ","children":[{"tag":"date","attrib":{"date":"2011-06-29"},"text":"June 29, 2011","children":[],"tail":", provided for expedited Senate consideration of certain nominations subject to advice and consent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a64045c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6762/b/2/C"},"text":"section 6762(b)(2)(C) of this title","children":[],"tail":", prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 6759, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s329"},"text":"Pub. L. 106–102, title III, § 329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1430"},"text":"113 Stat. 1430","children":[],"tail":", related to assessments, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/114/1"},"text":"Pub. L. 114–1","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6756/1"},"text":"section 6756(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
