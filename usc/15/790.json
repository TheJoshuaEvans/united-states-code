{"tag":"section","attrib":{"id":"id794ceea8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790"},"text":null,"children":[{"tag":"num","attrib":{"value":"790"},"text":"§ 790.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office of Energy Information and Analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794ceea9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director; appointment; qualifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794ceeaa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the Federal Energy Administration an Office of Energy Information and Analysis (hereinafter in this chapter referred to as the “Office”) which shall be headed by a Director who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794ceeab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall be a person who, by reason of professional background and experience, is specially qualified to manage an energy information system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794ceeac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority by Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall delegate (which delegation may be on a nonexclusive basis as the Administrator may determine may be necessary to assure the faithful execution of his authorities and responsibilities under law) the authority vested in him under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s796"},"text":"section 796 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s772"},"text":"section 772 of this title","children":[],"tail":" and the Director may act in the name of the Administrator under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s797"},"text":"section 797 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s772"},"text":"section 772 of this title","children":[],"tail":" for the purpose of obtaining enforcement of the authorities delegated to him."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794ceead-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Energy information” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this chapter the term “energy information” shall have the meaning described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s796"},"text":"section 796 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794ceeae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s51"},"text":"Pub. L. 93–275, § 51","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s142"},"text":"Pub. L. 94–385, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1135"},"text":"90 Stat. 1135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794ceeaf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794ceeb0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id794ceeb1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s143"},"text":"Pub. L. 94–385, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1140"},"text":"90 Stat. 1140","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/385/tI/s143"},"text":"“The amendments made by this part C to the Federal Energy Administration Act of 1974 [enacting this subchapter] shall take effect 150 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":"], except that section 56(c) of the Federal Energy Administration Act of 1974 (as added by this part) ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s790e/c"},"text":"section 790e(c) of this title","children":[],"tail":"] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794ceeb2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Energy Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions assigned to Director of Office of Energy Information and Analysis under this subchapter vested in Administrator of Energy Information Administration within Department of Energy by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7135/c"},"text":"section 7135(c) of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id794ceeb3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s141"},"text":"Pub. L. 94–385, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1135"},"text":"90 Stat. 1135","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/385/tI/s141"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress finds that the public interest requires that decisionmaking, with respect to this Nation’s energy requirements and the sufficiency and availability of energy resources and supplies, be based on adequate, accurate, comparable, coordinated, and credible energy information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of this title [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s761"},"text":"section 761 of this title","children":[],"tail":"] is to establish within the Federal Energy Administration an Office of Energy Information and Analysis and a National Energy Information System to assure the availability of adequate, comparable, accurate, and credible energy information to the Federal Energy Administration, to other Government agencies responsible for energy-related policy decisions, to the Congress, and to the public.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
