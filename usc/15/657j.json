{"tag":"section","attrib":{"id":"id791ae253-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j"},"text":null,"children":[{"tag":"num","attrib":{"value":"657j"},"text":"§ 657j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information tracking and follow-up system for disaster assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791ae254-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop, implement, or maintain a centralized information system to track communications between personnel of the Administration and applicants for disaster assistance. The system shall ensure that whenever an applicant for disaster assistance communicates with such personnel on a matter relating to the application, the following information is recorded:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae255-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The method of communication.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae256-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of communication.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae257-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identity of the personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae258-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of the subject matter of the communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae259-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Follow-up required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall ensure that an applicant for disaster assistance receives, by telephone, mail, or electronic mail, follow-up communications from the Administration at all critical stages of the application process, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae25a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Administration determines that additional information or documentation is required to process the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae25b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Administration determines whether to approve or deny the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae25c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the primary contact person managing the loan application has changed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791ae25d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on web portal for disaster loan application status","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791ae25e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", the Administrator shall submit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a report relating to the creation of a web portal to the "},{"tag":"ref","attrib":{"idref":"fn002246"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002246"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" track the status of applications for disaster assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b"},"text":"section 636(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791ae25f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id791ae260-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the progress of the Administration in implementing the information system under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae261-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations from the Administration relating to the creation of a web portal for applicants to check the status of an application for disaster assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b"},"text":"section 636(b) of this title","children":[],"tail":", including a review of best practices and web portal models from the private sector;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae262-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on any related costs or staffing needed to implement such a web portal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae263-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on whether such a web portal can maintain high standards for data privacy and data security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae264-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on whether such a web portal will minimize redundancy among Administration disaster programs, improve management of the number of inquiries made by disaster applicants to employees located in the area affected by the disaster and to call centers, and reduce paperwork burdens on disaster victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id791ae265-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657j/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as is determined necessary by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791ae266-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s38"},"text":"Pub. L. 85–536, § 2[38]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12067"},"text":"Pub. L. 110–234, title XII, § 12067","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1410"},"text":"122 Stat. 1410","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12067, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2172; "},{"tag":"ref","attrib":{"href":"/us/pl/114/88/dB/tIII/s2303"