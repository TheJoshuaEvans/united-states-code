{"tag":"section","attrib":{"id":"id7a6b090d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106"},"text":null,"children":[{"tag":"num","attrib":{"value":"7106"},"text":"§ 7106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6b090e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall advise and consult with the Interagency Committee on matters relating to the activities, functions, and policies of the Interagency Committee, as provided in this chapter. The Council shall meet jointly with the Interagency Committee at the discretion of the chairperson of the Council and the chairperson of the Interagency Committee, but not less than biannually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b090f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet separately at such times as the Council deems necessary. A majority of the members of the Council shall constitute a quorum for the approval of recommendations or reports issued pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0910-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall make annual recommendations for consideration by the Interagency Committee. The Council shall also provide reports and make such other recommendations as it deems appropriate to the Interagency Committee, to the President, to the Administrator (through the Assistant Administrator of the Office of Women’s Business Ownership), and to the Committees on Small Business of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b0911-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b0912-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, coordinate, and monitor plans and programs developed in the public and private sectors, which affect the ability of women-owned business enterprises to obtain capital and credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0913-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and assist in the development of a women’s business census and other surveys of women-owned businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0914-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and promote the plans, programs, and operations of the departments and agencies of the Federal Government which may contribute to the establishment and growth of women’s business enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0915-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and promote new initiatives, policies, programs, and plans designed to foster women’s business enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0916-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and consult with the Interagency Committee in the design of a comprehensive plan for a joint public-private sector effort to facilitate growth and development of women’s business enterprise; ","children":[{"tag":"ref","attrib":{"idref":"fn002567"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002567"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Semicolon probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b0917-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 90 days after the last day of each fiscal year, submit to the President and to the Committee on Small Business of the Senate and the Committee on Small Business of the House of Representatives, a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a6b0918-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the activities of the council,","children":[{"tag":"ref","attrib":{"idref":"fn002568"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002568"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" including a status report on the Council’s progress toward meeting its duties outlined in subsections (a) and (d) of this section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b0919-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings, conclusions, and recommendations of the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a6b091a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council’s recommendations for such legislation and administrative actions as the Council considers appropriate to promote the development of small business concerns owned and controlled by women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b091b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of transmittal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information included in each report under subsection (d) that is described in subparagraphs (A) through (C) of subsection (d)(6), shall be reported verbatim, together with any separate additional, concurring, or dissenting views of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b091c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s406"},"text":"Pub. L. 100–533, title IV, § 406","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tIV/s413"},"text":"Pub. L. 103–403, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4195"},"text":"108 Stat. 4195","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tIII/s303"},"text":"Pub. L. 105–135, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2609"},"text":"111 Stat. 2609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6b091d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6b091e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a6b091f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/s406"},"text":"section 406 of Pub. L. 100–533","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2696"},"text":"102 Stat. 2696","children":[],"tail":", related to requirement of reports to the President and Congress by the National Women’s Business Council, prior to the general amendment of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/100/533"},"text":"Pub. L. 100–533","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/403"},"text":"Pub. L. 103–403","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a6b0920-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s303/1"},"text":"Pub. L. 105–135, § 303(1)","children":[],"tail":", inserted “(through the Assistant Administrator of the Office of Women’s Business Ownership)” after “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s303/2"},"text":"Pub. L. 105–135, § 303(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s303/2"},"text":"Pub. L. 105–135, § 303(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a6b0921-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7a6b0922-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Small Business of Senate changed to Committee on Small Business and Entrepreneurship of Senate. See Senate Resolution No. 123, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-06-29"},"text":"June 29, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a6b0923-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135"},"text":"Pub. L. 105–135","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/s3"},"text":"section 3 of Pub. L. 105–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
