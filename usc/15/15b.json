{"tag":"section","attrib":{"id":"id77b2c622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s15b"},"text":null,"children":[{"tag":"num","attrib":{"value":"15b"},"text":"§ 15b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any action to enforce any cause of action under section 15, 15a, or 15c of this title shall be forever barred unless commenced within four years after the cause of action accrued. No cause of action barred under existing law on the effective date of this Act shall be revived by this Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77b2c623-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-10-15/ch323/s4B"},"text":"Oct. 15, 1914, ch. 323, § 4B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-07-07/ch283/s1"},"text":"July 7, 1955, ch. 283, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/283"},"text":"69 Stat. 283","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/435/tIII/s302/1"},"text":"Pub. L. 94–435, title III, § 302(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1396"},"text":"90 Stat. 1396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77b2c624-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77b2c625-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id77b2c62