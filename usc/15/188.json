{"tag":"section","attrib":{"id":"id788495e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s188"},"text":null,"children":[{"tag":"num","attrib":{"value":"188"},"text":"§ 188.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of commercial information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall publish official notifications, from time to time, of such commercial information communicated to him by diplomatic and consular officers, as he may deem important to the public interests, in such newspapers, not to exceed three in number, as he may select.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788495e4-552d-11f1-9071-ff305b7c3ff0"},"text":"(R.S. § 211; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s10"},"text":"Feb. 14, 1903, ch. 552, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788495e5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788495e6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788495e7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 211 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch127/s2"},"text":"act Aug. 18, 1856, ch. 127, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/60"},"text":"11 Stat. 60","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788495e8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id788495e9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", substituted “Secretary of Commerce” for “Secretary of Commerce and Labor”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788495ea-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", transferred Bureau of Statistics from Treasury Department to Department of Commerce and Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
