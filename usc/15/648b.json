{"tag":"section","attrib":{"id":"id790efa72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b"},"text":null,"children":[{"tag":"num","attrib":{"value":"648b"},"text":"§ 648b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for SBDCs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id790efa73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants to small business development centers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648"},"text":"section 648 of this title","children":[],"tail":" to provide targeted technical assistance to small business concerns seeking access to capital or credit, Federal procurement opportunities, energy efficiency audits to reduce energy bills, opportunities to export products or provide services to foreign customers, adopting, making innovations in, and using broadband technologies, or other assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790efa74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id790efa75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), and notwithstanding the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/4/C/iii"},"text":"section 648(a)(4)(C)(iii) of this title","children":[],"tail":", the amount appropriated to carry out this section shall be allocated under the formula under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/4/C/i"},"text":"section 648(a)(4)(C)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790efa76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount made available under this section to each State shall be not less than $325,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id790efa77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount of the grants awarded by the Administrator under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id790efa78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 80 percent shall be used for counseling of small business concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id790efa79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 20 percent may be used for classes or seminars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790efa7a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No non-Federal share required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/4/A"},"text":"section 648(a)(4)(A) of this title","children":[],"tail":", the recipient of a grant made under this section shall not be required to provide non-Federal matching funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790efa7b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the date on which amounts are appropriated to carry out this section, the Administrator shall disburse the total amount appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790efa7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s648b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Administrator $50,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id790efa7d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/tI/s1402"},"text":"Pub. L. 111–240, title I, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2550"},"text":"124 Stat. 2550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id790efa7e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id790efa7f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id790efa80-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Small Business Jobs Act of 2010, and not as part of the Small Business Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id790efa81-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id790efa82-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Administrator” and “small business concern” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/240/s1001"},"text":"section 1001 of Pub. L. 111–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
