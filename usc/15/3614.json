{"tag":"section","attrib":{"id":"id7a1ebd16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3614"},"text":null,"children":[{"tag":"num","attrib":{"value":"3614"},"text":"§ 3614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of rights as void","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any condition, stipulation, or provision binding any person to waive compliance with any provisions of this chapter shall be void.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a1ebd17-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s615"},"text":"Pub. L. 96–399, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1680"},"text":"94 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
