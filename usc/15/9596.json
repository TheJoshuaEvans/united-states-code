{"tag":"section","attrib":{"id":"id7ab299a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596"},"text":null,"children":[{"tag":"num","attrib":{"value":"9596"},"text":"§ 9596.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If a provision of this chapter, or the application of a provision of this chapter to any person or circumstance, is held by a court of competent jurisdiction to be invalid, that judgment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab299a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not affect, impair, or invalidate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of this chapter to any other person or circumstance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab299a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be confined in its operation to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab299a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of this chapter with respect to which the judgment is rendered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab299aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9596/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of the provision of this chapter to each person or circumstance directly involved in the controversy in which the judgment is rendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab299ab-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tVII/s100706"},"text":"Pub. L. 117–58, div. K, title VII, § 100706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1467"},"text":"135 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab299ac-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab299ad-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab299ae-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this division”, meaning div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1445"},"text":"135 Stat. 1445","children":[],"tail":", which is classified principally to this chapter. For complete classification of division K to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
