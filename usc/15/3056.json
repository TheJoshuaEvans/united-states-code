{"tag":"section","attrib":{"id":"id7a1546d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056"},"text":null,"children":[{"tag":"num","attrib":{"value":"3056"},"text":"§ 3056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racetrack safety program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1546d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and considerations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1546d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the program effective date, and after notice and an opportunity for public comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":", the Authority shall establish a racetrack safety program applicable to all covered horses, covered persons, and covered horseraces in accordance with the registration of covered persons under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3054/d"},"text":"section 3054(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations in development of safety program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the development of the horseracing safety program for covered horses, covered persons, and covered horseraces, the Authority and the Commission shall take into consideration existing safety standards including the National Thoroughbred Racing Association Safety and Integrity Alliance Code of Standards, the International Federation of Horseracing Authority’s International Agreement on Breeding, Racing, and Wagering, and the British Horseracing Authority’s Equine Health and Welfare program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1546d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of horseracing safety program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The horseracing safety program shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1546d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A set of training and racing safety standards and protocols taking into account regional differences and the character of differing racing facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A uniform set of training and racing safety standards and protocols consistent with the humane treatment of covered horses, which may include lists of permitted and prohibited practices or methods (such as crop use).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A racing surface quality maintenance system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1546da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account regional differences and the character of differing racing facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include requirements for track surface design and consistency and established standard operating procedures related to track surface, monitoring, and maintenance (such as standardized seasonal assessment, daily tracking, and measurement).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A uniform set of track safety standards and protocols, that may include rules governing oversight and movement of covered horses and human and equine injury reporting and prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs for injury and fatality data analysis, that may include pre- and post-training and race inspections, use of a veterinarian’s list, and concussion protocols.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The undertaking of investigations at racetrack and non-racetrack facilities related to safety violations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for investigating, charging, and adjudicating violations and for the enforcement of civil sanctions for violations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A schedule of civil sanctions for violations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disciplinary hearings, which may include binding arbitration, civil sanctions, and research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Management of violation results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs relating to safety and performance research and education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation and accreditation program that ensures that racetracks in the United States meet the standards described in the elements of the Horseracing Safety Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1546e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following activities shall be carried out under the racetrack safety program:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1546e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for racetrack safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The development, by the racetrack safety standing committee of the Authority in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3052/c/2"},"text":"section 3052(c)(2) of this title","children":[],"tail":" of uniform standards for racetrack and horseracing safety."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for safety and performance accreditation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1546e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days before the program effective date, the Authority, in consultation with the racetrack safety standing committee, shall issue, by rule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7a1546e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety and performance standards of accreditation for racetracks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1546ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process by which a racetrack may achieve and maintain accreditation by the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifications","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a1546ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may modify rules establishing the standards issued under subparagraph (A), as the Authority considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a1546ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall publish in the Federal Register any proposed rule of the Authority, and provide an opportunity for public comment with respect to, any modification under clause (i) in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of provisional or interim accreditation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority may, by rule in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":", extend provisional or interim accreditation to a racetrack accredited by the National Thoroughbred Racing Association Safety and Integrity Alliance on a date before the program effective date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1546ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nationwide safety and performance database","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a1546f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after the program effective date, and after notice and an opportunity for public comment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3053"},"text":"section 3053 of this title","children":[],"tail":", the Authority, in consultation with the Commission, shall develop and maintain a nationwide database of racehorse safety, performance, health, and injury information for the purpose of conducting an epidemiological study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a1546f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3056/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the registration of covered persons under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3054/d"},"text":"section 3054(d) of this title","children":[],"tail":", the Authority may require covered persons to collect and submit to the database described in subparagraph (A) such information as the Authority may require to further the goal of increased racehorse welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1546f2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tXII/s1207"},"text":"Pub. L. 116–260, div. FF, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3267"},"text":"134 Stat. 3267","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
