{"tag":"section","attrib":{"id":"id78a60011-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s383"},"text":null,"children":[{"tag":"num","attrib":{"value":"383"},"text":"§ 383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Net income tax” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this chapter, the term “net income tax” means any tax imposed on, or measured by, net income.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a60012-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/272/tI/s103"},"text":"Pub. L. 86–272, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-14"},"text":"Sept. 14, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/556"},"text":"73 Stat. 556","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
