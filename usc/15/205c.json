{"tag":"section","attrib":{"id":"id78870676-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c"},"text":null,"children":[{"tag":"num","attrib":{"value":"205c"},"text":"§ 205c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78870677-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the United States Metric Board, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s205d"},"text":"section 205d of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78870678-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “engineering standard” means a standard which prescribes (A) a concise set of conditions and requirements that must be satisfied by a material, product, process, procedure, convention, or test method; and (B) the physical, functional, performance and/or conformance characteristics thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78870679-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “international standard or recommendation” means an engineering standard or recommendation which is (A) formulated and promulgated by an international organization and (B) recommended for adoption by individual nations as a national standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7887067a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “metric system of measurement” means the International System of Units as established by the General Conference of Weights and Measures in 1960 and as interpreted or modified for the United States by the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7887067b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “full and open competition” has the same meaning as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s107"},"text":"section 107 of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7887067c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “total installed price” means the price of purchasing a product or material, trimming or otherwise altering some or all of that product or material, if necessary to fit with other building components, and then installing that product or material into a Federal facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7887067d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “hard-metric” means measurement, design, and manufacture using the metric system of measurement, but does not include measurement, design, and manufacture using English system measurement units which are subsequently reexpressed in the metric system of measurement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7887067e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “cost or pricing data or price analysis” has the meaning given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3501/a"},"text":"section 3501(a) of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7887067f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Federal facility” means any public building (as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3301/a"},"text":"section 3301(a) of title 40","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":" and shall include any Federal building or construction project—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78870680-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on lands in the public domain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78870681-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on lands used in connection with Federal programs for agriculture research, recreation, and conservation programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78870682-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or used in connection with river, harbor, flood control, reclamation, or power projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78870683-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or used in connection with housing and residential projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78870684-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on military installations (including any fort, camp, post, naval training station, airfield, proving ground, military supply depot, military school, or any similar facility of the Department of Defense);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78870685-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on installations of the Department of Veteran ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Veterans”."}],"tail":" Affairs used for hospital or domiciliary purposes; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78870686-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s205c/9/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on lands used in connection with Federal prisons,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include (i) any Federal building or construction project the exclusion of which the President deems to be justified in the public interest, or (ii) any construction project or building owned or controlled by a State government, local government, Indian tribe, or any private entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78870687-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/168/s4"},"text":"Pub. L. 94–168, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-23"},"text":"Dec. 23, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1007"},"text":"89 Stat. 1007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/289/s3"},"text":"Pub. L. 104–289, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3411"},"text":"110 Stat. 3411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78870688-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78870689-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7887068a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (5), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s107"},"text":"section 107 of title 41","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/6"},"text":"section 403(6) of title 41","children":[],"tail":", United States Code” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (8), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3501/a"},"text":"section 3501(a) of title 41","children":[],"tail":"” substituted for “section 304A of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s254b"},"text":"41 U.S.C. 254b","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (9), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3301/a"},"text":"section 3301(a) of title 40","children":[],"tail":"” substituted for “section 13 of the Public Buildings Act of 1959 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s612"},"text":"40 U.S.C. 612","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s5/c"},"text":"Pub. L. 107–217, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1303"},"text":"116 Stat. 1303","children":[],"tail":", the first section of which enacted Title 40, Public Buildings, Property, and Works."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7887068b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Pars. (5) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/289"},"text":"Pub. L. 104–289","children":[],"tail":" added pars. (5) to (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7887068c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7887068d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/289/s6"},"text":"Pub. L. 104–289, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3415"},"text":"110 Stat. 3415","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/289/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act [See Short Title of 1996 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s205a"},"text":"section 205a of this title","children":[],"tail":"] and the amendments made by this Act shall take effect 90 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act shall not apply to contracts awarded and solicitations issued on or before the effective date of this Act, unless the head of a Federal agency makes a written determination in his or her sole discretion that it would be in the public interest to apply one or more provisions of this Act or its amendments to these existing contracts or solicitations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
