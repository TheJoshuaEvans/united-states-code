{"tag":"section","attrib":{"id":"id7a912eba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911"},"text":null,"children":[{"tag":"num","attrib":{"value":"8911"},"text":"§ 8911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and detection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912ebb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring program for unregulated contaminants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912ebc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall include each substance described in paragraph (2) in the fifth publication of the list of unregulated contaminants to be monitored under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–4/a/2/B/i"},"text":"section 300j–4(a)(2)(B)(i) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ebd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substances described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The substances referred to in paragraph (1) are perfluoroalkyl and polyfluoroalkyl substances and classes of perfluoroalkyl and polyfluoroalkyl substances—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912ebe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a method to measure the level in drinking water has been validated by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ebf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are not subject to a national primary drinking water regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ec0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The perfluoroalkyl and polyfluoroalkyl substances and classes of perfluoroalkyl and polyfluoroalkyl substances included in the list of unregulated contaminants to be monitored under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–4/a/2/B/i"},"text":"section 300j–4(a)(2)(B)(i) of title 42","children":[],"tail":" under paragraph (1) shall not count towards the limit of 30 unregulated contaminants to be monitored by public water systems under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912ec1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912ec2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912ec3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require public water systems serving more than 10,000 persons to monitor for the substances described in subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ec4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2) and the availability of appropriations, require public water systems serving not fewer than 3,300 and not more than 10,000 persons to monitor for the substances described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ec5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2) and the availability of appropriations, ensure that only a representative sample of public water systems serving fewer than 3,300 persons are required to monitor for the substances described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ec6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that there is not sufficient laboratory capacity to carry out the monitoring required under subparagraphs (B) and (C) of paragraph (1), the Administrator may waive the monitoring requirements in those subparagraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912ec7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall pay the reasonable cost of such testing and laboratory analysis as is necessary to carry out the monitoring required under subparagraphs (B) and (C) of paragraph (1) using—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912ec8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds made available pursuant to subsection (a)(2)(H) or subsection (j)(5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–4"},"text":"section 300j–4 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912ec9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8911/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other funds made available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912eca-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7311"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2276"},"text":"133 Stat. 2276","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
