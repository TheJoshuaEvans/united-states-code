{"tag":"section","attrib":{"id":"id791d5292-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n"},"text":null,"children":[{"tag":"num","attrib":{"value":"657n"},"text":"§ 657n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate Disaster Assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id791d5293-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall carry out a program, to be known as the Immediate Disaster Assistance program, under which the Administration participates on a deferred (guaranteed) basis in 85 percent of the balance of the financing outstanding at the time of disbursement of the loan if such balance is less than or equal to $25,000 for businesses affected by a disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5294-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive a loan guaranteed under subsection (a), the applicant shall also apply for, and meet basic eligibility standards for, a loan under subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5295-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who receives a loan under subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":" shall use the proceeds of that loan to repay all loans guaranteed under subsection (a), if any, before using the proceeds for any other purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5296-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id791d5297-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prepayment penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be no prepayment penalty on a loan guaranteed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id791d5298-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who receives a loan guaranteed under subsection (a) and who is disapproved for a loan under subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":", as the case may be, shall repay the loan guaranteed under subsection (a) not later than the date established by the Administrator, which may not be earlier than 10 years after the date on which the loan guaranteed under subsection "},{"tag":"ref","attrib":{"idref":"fn002247"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002247"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (a)”."}],"tail":" is disbursed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id791d5299-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s657n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that each applicant for a loan under the program receives a decision approving or disapproving of the application within 36 hours after the Administration receives the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id791d529a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s42"},"text":"Pub. L. 85–536, § 2[42]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12084"},"text":"Pub. L. 110–234, title XII, § 12084","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1420"},"text":"122 Stat. 1420","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12084, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2182.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id791d529b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id791d529c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id791d529d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id791d529e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id791d529f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234