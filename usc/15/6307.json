{"tag":"section","attrib":{"id":"id7a55ac91-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6307"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307"},"text":"§ 6307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 48 business hours after the conclusion of a professional boxing match, the supervising boxing commission shall report the results of such boxing match and any related suspensions to each boxer registry.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a55ac92-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s8"},"text":"Pub. L. 104–272, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3311"},"text":"110 Stat. 3311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a55ac93-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a55ac94-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a55ac95-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23/2"},"text":"section 23(2) of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"t