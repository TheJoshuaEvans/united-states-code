{"tag":"section","attrib":{"id":"id7a6b08d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102"},"text":null,"children":[{"tag":"num","attrib":{"value":"7102"},"text":"§ 7102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Interagency Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a6b08d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Interagency Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a6b08d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor, coordinate, and promote the plans, programs, and operations of the departments and agencies of the Federal Government that may contribute to the establishment and growth of women’s business enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and promote new public sector initiatives, policies, programs, and plans designed to foster women’s business enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, monitor, and coordinate plans and programs, developed in the public sector, which affect the ability of women-owned businesses to obtain capital and credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote and assist, as appropriate, in the development of surveys of women-owned business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a6b08d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design a comprehensive plan for a joint public-private sector effort to facilitate growth and development of women’s business enterprise, which plan shall, not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1994-10-22"},"text":"October 22, 1994","children":[],"tail":", be submitted to the President for review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Interagency Committee shall meet not less than biannually at such times as the Interagency Committee determines to be necessary to perform the duties under subsection (a). A majority of the members of the Committee shall constitute a quorum for the approval of recommendations or reports issued pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a6b08db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interaction with Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In performing its duties under subsection (a), the Interagency Committee shall consult with the Council. The Interagency Committee may meet jointly with the Council at the discretion of the chairperson of the Interagency Committee and the chairperson of the Council, but not less frequently than twice annually. The chairperson of the Interagency Committee shall serve as chairperson of any joint meetings of the Interagency Committee and the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a6b08dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/tIV/s402"},"text":"Pub. L. 100–533, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/403/tIV/s413"},"text":"Pub. L. 103–403, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4193"},"text":"108 Stat. 4193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a6b08dd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a6b08de-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a6b08df-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/533/s402"},"text":"section 402 of Pub. L. 100–533","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2694"},"text":"102 Stat. 2694","children":[],"tail":", related to duties of the National Women’s Business Council, prior to the general amendment of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/100/533"},"text":"Pub. L. 100–533","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/103/403"},"text":"Pub. L. 103–403","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7106"},"text":"section 7106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
