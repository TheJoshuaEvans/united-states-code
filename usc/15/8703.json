{"tag":"section","attrib":{"id":"id7a8c7344-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703"},"text":null,"children":[{"tag":"num","attrib":{"value":"8703"},"text":"§ 8703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8c7345-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c7346-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, subject to the procedures provided in subsection (b), shall issue orders under this chapter applicable to manufacturers of concrete masonry products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7347-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any order shall be national in scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7348-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 1 order shall be in effect at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c7349-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8c734a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development or receipt of proposed order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposed order with respect to the generic research, education, and promotion with regards to concrete masonry products may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c734b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed by the Secretary at any time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c734c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requested by or submitted to the Secretary by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a8c734d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an existing national organization of concrete masonry product manufacturers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a8c734e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person that may be affected by the issuance of an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c734f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of proposed order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a proposed order received in accordance with paragraph (1)(B) is consistent with and will effectuate the purpose of this chapter, the Secretary shall publish such proposed order in the Federal Register not later than 90 days after receiving the order, and give not less than 30 days notice and opportunity for public comment on the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8c7350-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8c7351-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are provided in accordance with paragraph (2), the Secretary shall issue the order, taking into consideration the comments received and including in the order such provisions as are necessary to ensure that the order is in conformity with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8c7352-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is an affirmative vote in a referendum as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8706"},"text":"section 8706 of this title","children":[],"tail":", the Secretary shall issue the order and such order shall be effective not later than 140 days after publication of the proposed order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8c7353-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, from time to time, amend an order. The provisions of this chapter applicable to an order shall be applicable to any amendment to an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8c7354-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dE/s1304"},"text":"Pub. L. 115–254, div. E, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3471"},"text":"132 Stat. 3471","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
