{"tag":"section","attrib":{"id":"id7a68bf01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6907"},"text":null,"children":[{"tag":"num","attrib":{"value":"6907"},"text":"§ 6907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An application for assistance under this chapter shall be submitted in such form and in accordance with such procedures as the Administrator shall establish.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a68bf02-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s178"},"text":"Pub. L. 103–325, title I, § 178","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1474"},"text":"113 Stat. 1474","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
