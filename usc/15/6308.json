{"tag":"section","attrib":{"id":"id7a57f5db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308"},"text":null,"children":[{"tag":"num","attrib":{"value":"6308"},"text":"§ 6308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a57f5dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member or employee of a boxing commission, no person who administers or enforces State boxing laws, and no member of the Association of Boxing Commissions may belong to, contract with, or receive any compensation from, any person who sanctions, arranges, or promotes professional boxing matches or who otherwise has a financial interest in an active boxer currently registered with a boxer registry. For purposes of this section, the term “compensation” does not include funds held in escrow for payment to another person in connection with a professional boxing match. The prohibition set forth in this section shall not apply to any contract entered into, or any reasonable compensation received, by a boxing commission to supervise a professional boxing match in another State as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6303"},"text":"section 6303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Firewall between promoters and managers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is unlawful for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a promoter to have a direct or indirect financial interest in the management of a boxer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a manager—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a57f5e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have a direct or indirect financial interest in the promotion of a boxer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a57f5e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be employed by or receive compensation or other benefits from a promoter, except for amounts received as consideration under the manager’s contract with the boxer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not prohibit a boxer from acting as his own promoter or manager; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only applies to boxers participating in a boxing match of 10 rounds or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f5e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctioning organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f5e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no officer or employee of a sanctioning organization may receive any compensation, gift, or benefit, directly or indirectly, from a promoter, boxer, or manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f5e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f5e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of payment by a promoter, boxer, or manager of a sanctioning organization’s published fee for sanctioning a professional boxing match or reasonable expenses in connection therewith if the payment is reported to the responsible boxing commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f5ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6308/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of a gift or benefit of de minimis value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f5eb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s17"},"text":"Pub. L. 104–272, § 17","children":[],"tail":", formerly § 9, "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3311"},"text":"110 Stat. 3311","children":[],"tail":"; renumbered § 17 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/210"},"text":"Pub. L. 106–210","children":[],"tail":", §§ 4(1), 5, "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":", 325.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f5ec-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a57f5ed-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a57f5ee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/210/s5"},"text":"Pub. L. 106–210, § 5","children":[],"tail":", designated existing provisions as subsec. (a), inserted subsec. heading, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a57f5ef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a57f5f0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", and not applicable to an otherwise authorized boxing commission in the Commonwealth of Virginia until "},{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":", see section 23(1), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/272"},"text":"Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
