{"tag":"section","attrib":{"id":"id7a5cd87a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6616"},"text":null,"children":[{"tag":"num","attrib":{"value":"6616"},"text":"§ 6616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admissible evidence ultimate issue in State courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any party to a Y2K action in a State court in a State that has not adopted a rule of evidence substantially similar to Rule 704 of the Federal Rules of Evidence may introduce in such action evidence that would be admissible if Rule 704 applied in that jurisdiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a5cd87b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s17"},"text":"Pub. L. 106–37, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/202"},"text":"113 Stat. 202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a5cd87c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a5cd87d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a5cd87e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Rule 704 of the Federal Rules of Evidence, referred to in text, is set out in the Appendix to Title 28, Judiciary and Judicial Procedure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
