{"tag":"section","attrib":{"id":"id7a8a2987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545"},"text":null,"children":[{"tag":"num","attrib":{"value":"8545"},"text":"§ 8545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warning coordination meteorologists at weather forecast offices of National Weather Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8a2988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of warning coordination meteorologists","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8a2989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Weather Service shall designate at least one warning coordination meteorologist at each weather forecast office of the National Weather Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a298a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional employees authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to authorize or require a change in the authorized number of full time equivalent employees in the National Weather Service or otherwise result in the employment of any additional employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a298b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance by other employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Performance of the responsibilities outlined in this section is not limited to the warning coordination meteorologist position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a298c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary role of warning coordination meteorologists","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The primary role of the warning coordination meteorologist shall be to carry out the responsibilities required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a298d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8a298e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), consistent with the analysis described in section 409,","children":[{"tag":"ref","attrib":{"idref":"fn002605"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002605"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and in order to increase impact-based decision support services, each warning coordination meteorologist designated under subsection (a) shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8a298f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for providing service to the geographic area of responsibility covered by the weather forecast office at which the warning coordination meteorologist is employed to help ensure that users of products of the National Weather Service can respond effectively to improve outcomes from weather events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a2990-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liaise with users of products and services of the National Weather Service, such as the public, media outlets, users in the aviation, marine, and agricultural communities, and forestry, land, and water management interests, to evaluate the adequacy and usefulness of the products and services of the National Weather Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a2991-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with such weather forecast offices and State, local, and tribal government agencies as the Director considers appropriate in developing, proposing, and implementing plans to develop, modify, or tailor products and services of the National Weather Service to improve the usefulness of such products and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a2992-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the maintenance and accuracy of severe weather call lists, appropriate office severe weather policy or procedures, and other severe weather or dissemination methodologies or strategies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a2993-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work closely with State, local, and tribal emergency management agencies, and other agencies related to disaster management, to ensure a planned, coordinated, and effective preparedness and response effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a2994-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may assign a responsibility set forth in paragraph (1) to such other staff as the Director considers appropriate to carry out such responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a2995-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8a2996-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), a warning coordination meteorologist designated under subsection (a) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a8a2997-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with a State agency to develop plans for promoting more effective use of products and services of the National Weather Service throughout the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a2998-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify priority community preparedness objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a2999-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop plans to meet the objectives identified under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a8a299a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct severe weather event preparedness planning and citizen education efforts with and through various State, local, and tribal government agencies and other disaster management-related organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a299b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may assign a responsibility set forth in paragraph (1) to such other staff as the Director considers appropriate to carry out such responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a299c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Placement with State and local emergency managers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8a299d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Director of the National Weather Service may place a warning coordination meteorologist designated under subsection (a) with a State or local emergency manager if the Director considers doing so is necessary or convenient to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a299e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8545/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director determines that the placement of a warning coordination meteorologist placed with a State or local emergency manager under paragraph (1) is near a weather forecast office of the National Weather Service, such placement shall be treated as designation of the warning coordination meteorologist at such weather forecast office for purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8a299f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tIV/s405"},"text":"Pub. L. 115–25, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/107"},"text":"131 Stat. 107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8a29a0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a8a29a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a8a29a2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 409, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/s409"},"text":"section 409 of Pub. L. 115–25","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/112"},"text":"131 Stat. 112","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
