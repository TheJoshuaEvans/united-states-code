{"tag":"section","attrib":{"id":"id79ef21b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416"},"text":null,"children":[{"tag":"num","attrib":{"value":"2416"},"text":"§ 2416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and other funding arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ef21b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualification of contracts or arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No contracts or other funding arrangements may be entered into under this chapter unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ef21b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contracts or other funding arrangements will be consistent with the policies and purposes of this chapter and of potential benefit to other users in the public or private sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef21b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions are made to evaluate the demonstration program and maintain improvement data, such evaluation either to be implemented by the participating parties in accordance with specifications established by the Center, or to be implemented by or on behalf of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ef21b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating parties agree that all information relating to any innovation or achievement generated in the course of any Center-funded demonstration program shall be public information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ef21ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of contracts or arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No contract or other funding arrangement shall be made or entered into pursuant to the provisions of this chapter for a period of more than three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ef21bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share of project in cash or in kind","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any non-Federal share of a project may be in cash or in kind, fairly evaluated, including, but not limited to, plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ef21bc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/136/tII/s206"},"text":"Pub. L. 94–136, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/739"},"text":"89 Stat. 739","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
