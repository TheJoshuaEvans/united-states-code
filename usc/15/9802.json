{"tag":"section","attrib":{"id":"id7ab509c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802"},"text":null,"children":[{"tag":"num","attrib":{"value":"9802"},"text":"§ 9802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this subtitle are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the travel and tourism industry, which produces economic impacts that are vital to our national economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish national goals for international visitors to the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab509ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for achieving such goals and timelines for implementing such recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination between Federal and State agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources needed by each Government agency to achieve such goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9802/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of international visitors and the value of national travel exports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab509ce-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tVI/s602"},"text":"Pub. L. 117–328, div. BB, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5566"},"text":"136 Stat. 5566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab509cf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab509d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab509d1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subtitle, referred to in text, is subtitle A (§§ 601–609) of title VI of div. BB of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5566"},"text":"136 Stat. 5566","children":[],"tail":", which enacted sections 9802 to 9805 of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1546"},"text":"section 1546 of this title","children":[],"tail":", enacted provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9801"},"text":"section 9801 of this title","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2171"},"text":"section 2171 of Title 19","children":[],"tail":", Customs Duties. For complete classification of this title to the Code, see Short Title of 2022 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9801"},"text":"section 9801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7ab509d2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7ab509d3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tVI/s603"},"text":"Pub. L. 117–328, div. BB, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5566"},"text":"136 Stat. 5566","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dBB/tVI/s603"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of Congress that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting a national goal for the number of international visitors to the United States is vital for aligning Federal tourism policy to support American jobs and economic growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting a national goal for travel exports is vital for aligning Federal tourism policy to support American jobs, increase travel exports, and improve our Nation’s balance of trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the travel industry is an essential part of the United States services exports with respect to business, education, medical, and leisure travel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of travel and visitation by the Corporation for Travel Promotion (doing business as ‘Brand USA’) is vital to increasing visitation and articulating the visitation laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an urgent need for a coordinated travel and tourism industry response and strategy to respond to the current state of such industry and future unforeseen circumstances that may impact the travel and tourism industry.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
