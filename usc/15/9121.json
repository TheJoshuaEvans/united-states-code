{"tag":"section","attrib":{"id":"id7aa6b2e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121"},"text":null,"children":[{"tag":"num","attrib":{"value":"9121"},"text":"§ 9121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief for airports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa6b2e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa6b2e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2021, out of any funds in the Treasury not otherwise appropriated, $8,000,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":", for assistance to sponsors of airports, as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":", to be made available to prevent, prepare for, and respond to coronavirus."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa6b2e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa6b2ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used for any purpose not directly related to the airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa6b2eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be provided to any airport that was allocated in excess of 4 years of operating funds to prevent, prepare for, and respond to coronavirus in fiscal year 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa6b2ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following terms shall apply to the amounts made available under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa6b2ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating expenses and debt service payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa6b2ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $6,492,000,000 shall be made available for primary airports, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":", and certain cargo airports, for costs related to operations, personnel, cleaning, sanitization, janitorial services, combating the spread of pathogens at the airport, and debt service payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa6b2ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts made available under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa6b2f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be subject to the reduced apportionments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114/f"},"text":"section 47114(f) of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa6b2f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall first be apportioned as set forth in sections 47114(c)(1)(A), 47114(c)(1)(C)(i),","children":[{"tag":"ref","attrib":{"idref":"fn002648"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002648"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 47114(c)(1)(C)(ii),"},{"tag":"ref","attrib":{"idref":"fn002648"},"text":"1","children":[],"tail":" 47114(c)(2)(A), 47114(c)(2)(B), and 47114(c)(2)(E) "},{"tag":"ref","attrib":{"idref":"fn002648"},"text":"1","children":[],"tail":" of title 49; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa6b2f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be subject to a maximum apportionment limit set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114/c/1/B"},"text":"section 47114(c)(1)(B) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa6b2f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount remaining after distribution under subparagraph (B) shall be distributed to the sponsor of each primary airport (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":") based on each such primary airport’s passenger enplanements compared to the total passenger enplanements of all such primary airports in calendar year 2019."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa6b2f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share for development projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa6b2f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $608,000,000 allocated under subsection (a)(1) shall be available to pay a Federal share of 100 percent of the costs for any grant awarded in fiscal year 2021, or in fiscal year 2020 with less than a 100-percent Federal share, for an airport development project (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa6b2f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount remaining under this paragraph shall be distributed as described in paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa922f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprimary airports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa922f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $100,000,000 shall be made available for general aviation and commercial service airports that are not primary airports (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":") for costs related to operations, personnel, cleaning, sanitization, janitorial services, combating the spread of pathogens at the airport, and debt service payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa922f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available under this paragraph shall be apportioned to each non-primary airport based on the categories published in the most current National Plan of Integrated Airport Systems, reflecting the percentage of the aggregate published eligible development costs for each such category, and then dividing the allocated funds evenly among the eligible airports in each category, rounding up to the nearest thousand dollars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa922fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount remaining under this paragraph shall be distributed as described in paragraph (1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa922fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airport concessions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa922fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $800,000,000 shall be made available for sponsors of primary airports to provide relief from rent and minimum annual guarantees to airport concessions, of which at least $640,000,000 shall be available to provide relief to eligible small airport concessions and of which at least $160,000,000 shall be available to provide relief to eligible large airport concessions located at primary airports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa922fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts made available for each set-aside in this paragraph shall be distributed to the sponsor of each primary airport (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":") based on each such primary airport’s passenger enplanements compared to the total passenger enplanements of all such primary airports in calendar year 2019."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa922fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of approving a grant under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa922ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor shall provide such relief from ","children":[{"tag":"date","attrib":{"date":"2021-03-21"},"text":"March 21, 2021","children":[],"tail":", until the sponsor has provided relief equaling the total grant amount, to the extent practicable and to the extent permissible under State laws, local laws, and applicable trust indentures; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa92300-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each set-aside, the sponsor shall provide relief from rent and minimum annual guarantee obligations to each eligible airport concession in an amount that reflects each eligible airport concession’s proportional share of the total amount of the rent and minimum annual guarantees of those eligible airport concessions at such airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa92301-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa92302-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Federal Aviation Administration may retain up to 0.1 percent of the funds provided under this section to fund the award of, and oversight by the Administrator of, grants made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa92303-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce retention requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa92304-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required retention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition for receiving funds provided under this section, an airport shall continue to employ, through ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":", at least 90 percent of the number of individuals employed (after making adjustments for retirements or voluntary employee separations) by the airport as of "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa92305-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of retention requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall waive the workforce retention requirement if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa92306-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the airport is experiencing economic hardship as a direct result of the requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa92307-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement reduces aviation safety or security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa92308-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The workforce retention requirement shall not apply to nonhub airports or nonprimary airports receiving funds under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa92309-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any financial assistance provided under this section to an airport that fails to comply with the workforce retention requirement described in subparagraph (A), and does not otherwise qualify for a waiver or exception under this paragraph, shall be subject to clawback by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa9230a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa9230b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible large airport concession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible large airport concession” means a concession (as defined in section 23.3 of title 49, Code of Federal Regulations), that is in-terminal and has maximum gross receipts, averaged over the previous three fiscal years, of more than $56,420,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa9230c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible small airport concession","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible small airport concession” means a concession (as defined in section 23.3 of title 49, Code of Federal Regulations), that is in-terminal and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa9230d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business with maximum gross receipts, averaged over the previous 3 fiscal years, of less than $56,420,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa9230e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9121/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a joint venture (as defined in section 23.3 of title 49, Code of Federal Regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa9230f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tVII/s7102"},"text":"Pub. L. 117–2, title VII, § 7102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/96"},"text":"135 Stat. 96","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa92310-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa92311-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aa92312-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 47114(c)(1)(C)(i) and 47114(c)(1)(C)(ii) of title 49, referred to in subsec. (b)(1)(B)(ii), were omitted in the general amendment of subsec. (c)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114"},"text":"section 47114 of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s712/a/1"},"text":"Pub. L. 118–63, title VII, § 712(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1254"},"text":"138 Stat. 1254","children":[],"tail":". The new subsec. (c)(1)(C) of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114"},"text":"section 47114 of title 49","children":[],"tail":" does not contain any clauses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114/c/2/E"},"text":"Section 47114(c)(2)(E) of title 49","children":[],"tail":", referred to in subsec. (b)(1)(B)(ii), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114/c/2/D"},"text":"section 47114(c)(2)(D) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s712/a/2/C"},"text":"Pub. L. 118–63, title VII, § 712(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1255"},"text":"138 Stat. 1255","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7aa92313-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Rescue Plan Act of 2021, and not as part of the CARES Act which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
