{"tag":"section","attrib":{"id":"id7a3b6dea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4625"},"text":null,"children":[{"tag":"num","attrib":{"value":"4625"},"text":"§ 4625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Department of Energy resources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3b6deb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4625/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary of Energy may make available to the Department of Defense, to any other department or agency of the Federal Government, and to any consortium that has entered into an agreement in furtherance of the Initiative any facilities, personnel, equipment, services, and other resources of the Department of Energy for the purpose of conducting research and development projects under the Initiative consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4623/a"},"text":"section 4623(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6dec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4625/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make facilities available under this section only to the extent that the cost of the use of such facilities is reimbursed by the user.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3b6ded-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tI/s3145"},"text":"Pub. L. 100–180, div. C, title I, § 3145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1243"},"text":"101 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
