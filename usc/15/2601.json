{"tag":"section","attrib":{"id":"id79f16bbb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601"},"text":null,"children":[{"tag":"num","attrib":{"value":"2601"},"text":"§ 2601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings, policy, and intent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79f16bbc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f16bbd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human beings and the environment are being exposed each year to a large number of chemical substances and mixtures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bbe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among the many chemical substances and mixtures which are constantly being developed and produced, there are some whose manufacture, processing, distribution in commerce, use, or disposal may present an unreasonable risk of injury to health or the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bbf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective regulation of interstate commerce in such chemical substances and mixtures also necessitates the regulation of intrastate commerce in such chemical substances and mixtures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f16bc0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79f16bc1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate information should be developed with respect to the effect of chemical substances and mixtures on health and the environment and that the development of such information should be the responsibility of those who manufacture and those who process such chemical substances and mixtures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bc2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate authority should exist to regulate chemical substances and mixtures which present an unreasonable risk of injury to health or the environment, and to take action with respect to chemical substances and mixtures which are imminent hazards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79f16bc3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority over chemical substances and mixtures should be exercised in such a manner as not to impede unduly or create unnecessary economic barriers to technological innovation while fulfilling the primary purpose of this chapter to assure that such innovation and commerce in such chemical substances and mixtures do not present an unreasonable risk of injury to health or the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79f16bc4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the intent of Congress that the Administrator shall carry out this chapter in a reasonable and prudent manner, and that the Administrator shall consider the environmental, economic, and social impact of any action the Administrator takes or proposes as provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79f16bc5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tI/s2"},"text":"Pub. L. 94–469, title I, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2003"},"text":"90 Stat. 2003","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/c/1"},"text":"Pub. L. 99–519, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2989"},"text":"100 Stat. 2989","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI"},"text":"Pub. L. 114–182, title I","children":[],"tail":", §§ 2, 19(b), "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/448"},"text":"130 Stat. 448","children":[],"tail":", 505.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79f16bc6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79f16bc7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79f16bc8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s19/b"},"text":"Pub. L. 114–182, § 19(b)","children":[],"tail":", substituted “information” for “data” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/s2"},"text":"Pub. L. 114–182, § 2","children":[],"tail":", substituted “proposes as provided” for “proposes to take”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79f16bc9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79f16bca-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tI/s31"},"text":"Pub. L. 94–469, title I, § 31","children":[],"tail":", "},{"tag":"date","attr