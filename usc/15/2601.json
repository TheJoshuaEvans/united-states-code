tle 42","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s254"},"text":"section 254 of Title 47","children":[],"tail":", Telecommunications, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2624"},"text":"section 2624 of this title","children":[],"tail":", and enacting provisions set out as notes under this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–17"},"text":"section 280g–17 of Title 42","children":[],"tail":", and sections 254 and 609 of Title 47] may be cited as the ‘Frank R. Lautenberg Chemical Safety for the 21st Century Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79f16bcc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/199/s1"},"text":"Pub. L. 111–199, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-07"},"text":"July 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1359"},"text":"124 Stat. 1359","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/199/s1"},"text":"“This Act [enacting subchapter VI of this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2697"},"text":"section 2697 of this title","children":[],"tail":"] may be cited as the ‘Formaldehyde Standards for Composite Wood Products Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79f16bcd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/414/s1"},"text":"Pub. L. 110–414, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4341"},"text":"122 Stat. 4341","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/414/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6939f"},"text":"section 6939f of Title 42","children":[],"tail":", The Public Health and Welfare, amending sections 2605 and 2611 of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2611"},"text":"section 2611 of this title","children":[],"tail":"] may be cited as the ‘Mercury Export Ban Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79f16bce-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1021/c"},"text":"Pub. L. 102–550, title X, § 1021(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3924"},"text":"106 Stat. 3924","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/550/tX/s1021/c"},"text":"“This subtitle [subtitle B (§ 1021) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", enacting sections 2681 to 2692 of this title and amending sections 2606, 2610, 2612, 2615, 2616, 2618, and 2619 of this title] may be cited as the ‘Lead-Based Paint Exposure Reduction Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79f16bcf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/519/s1"},"text":"Pub. L. 99–519, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2970"},"text":"100 Stat. 2970","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/519/s1"},"text":"“This Act [enacting sections 2641 to 2654 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s4022"},"text":"section 4022 of Title 20","children":[],"tail":", Education, amending sections 2614, 2618, and 2619 of this title and sections 4014 and 4021 of Title 20, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s4014"},"text":"section 4014 of Title 20","children":[],"tail":"] may be cited as the ‘Asbestos Hazard Emergency Response Act of 1986’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79f16bd0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/s1"},"text":"Pub. L. 94–469, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2003"},"text":"90 Stat. 2003","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s3/c"},"text":"Pub. L. 99–519, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2989"},"text":"100 Stat. 2989","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/519/s3/c"},"text":"“This Act [enacting this chapter and provisions set out as notes under this section] may be cited as the ‘Toxic Substances Control Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f16bd1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification of Definition of Sport Fishing Equipment Under Toxic Substances Control Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/188/tI/s108"},"text":"Pub. L. 116–188, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/920"},"text":"134 Stat. 920","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/198/tI/s107"},"text":"Pub. L. 118–198, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2680"},"text":"138 Stat. 2680","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/198/tI/s107"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During the period beginning on the date of enactment of the America’s Conservation Enhancement Reauthorization Act of 2024 [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"] and ending on "},{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":", the Administrator of the Environmental Protection Agency shall not take any action to regulate the lead content of sport fishing equipment or sport fishing equipment components under the Toxic Substances Control Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"15 U.S.C. 2601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Sport Fishing Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘sport fishing equipment’ means any sport fishing equipment (as such term is defined in section 4162(a) of the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4162/a"},"text":"26 U.S.C. 4162(a)","children":[],"tail":"]) the sale of which is subject to the tax imposed by section 4161(a) of such Code ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4161/a"},"text":"26 U.S.C. 4161(a)","children":[],"tail":"] (determined without regard to any exemptions from such tax provided by section 4162 or 4221 or any other provision of such Code ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s4162"},"text":"26 U.S.C. 4162","children":[],"tail":", 4221]).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f16bd2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Retroactivity of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182"},"text":"Pub. L. 114–182","children":[],"tail":" Amendments"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/182/tI/s20"},"text":"Pub. L. 114–182, title I, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/510"},"text":"130 Stat. 510","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/182/tI/s20"},"text":"“Nothing in sections 1 through 19 [amending this section, sections 2602 to 2611, 2613 to 2615, 2617 to 2620, 2623, 2625 to 2627, and 2629 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6939f"},"text":"section 6939f of Title 42","children":[],"tail":", The Public Health and Welfare, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2624"},"text":"section 2624 of this title","children":[],"tail":", and enacting provisions set out as a note under this section], or the amendments made by sections 1 through 19, shall be interpreted to apply retroactively to any State, Federal, or maritime legal action filed before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id79f16bd3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79f16bd4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Compliance With Pollution Control Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to the responsibility of the head of each Executive agency for compliance with applicable pollution control standards, see Ex. Ord. No. 12088, ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", 43 F.R. 47707, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
