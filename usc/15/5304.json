{"tag":"section","attrib":{"id":"id7a49c5b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304"},"text":null,"children":[{"tag":"num","attrib":{"value":"5304"},"text":"§ 5304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a49c5b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within one year after ","children":[{"tag":"date","attrib":{"date":"1990-10-15"},"text":"October 15, 1990","children":[],"tail":", the Secretary shall solicit and, subject to available appropriations, select proposals on a competitive basis from applicants to carry out the program under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5303"},"text":"section 5303 of this title","children":[],"tail":". In order for a proposal to be considered by the Secretary, the applicant shall have in existence at the time the proposal is submitted the following qualifications:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c5b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical capability to enable it to make use of existing research support and facilities in carrying out its research objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multidisciplinary research staff experienced in metal casting or other directly related technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilities and equipment capable of conducting at least laboratory scale testing or demonstration of metal casting or related processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c5b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each proposal shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c5ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate the support of the metal casting industry by describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c5bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how industry has participated in deciding what research activities will be undertaken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how industry will participate in the evaluation of the applicant’s progress in research and development activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which industry funds are committed to the applicant’s proposal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have a commitment for matching funds from non-Federal sources, which shall consist of:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c5bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the Secretary, the fair market value of equipment, services, materials, appropriate technology transfer activities, and other assets directly related to the proposal’s cost;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a single or multiyear management plan that outlines how the research and development activities will be administered and carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the annual cost of the proposal and a breakdown of those costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the technology transfer mechanisms the applicant will use to make available research results to industry and to other researchers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c5c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan set forth in subsection (b)(3) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c5c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline the basic research and development activities expected to be performed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline who will conduct those research activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the time frame over which the research activities will take place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" define the overall program management and direction by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c5c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying managerial, organizational and administrative procedures and responsibilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlining how the coordination of research and development between the individuals and organizations involved will be achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating how implementation and monitoring of the progress of research projects after receipt of funding from the Secretary will be achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating how recommendations and implementations on modifications to the plan will be achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5cd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing sufficient rationale to support the plan’s costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c5ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the proposals submitted, the Secretary shall select proposals for funding. The Secretary shall attempt to select at least four proposals. The Secretary shall select the proposals that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a49c5cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will best result in carrying out needed metal casting research and development in one or more of the following general areas—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a49c5d0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solidification and casting technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5d1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computational modeling and design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing technologies and design for energy efficiency, material conservation, environmental protection, or industrial productivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a49c5d3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas of research, which in the judgment of the Secretary, after consulting with the Board established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5306"},"text":"section 5306 of this title","children":[],"tail":", further the purposes of this chapter;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent research and development in specific areas identified in the “Metal Casting Research Priorities” developed annually by the Board pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s5306/b/1"},"text":"section 5306(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the greatest extent possible and subject to available appropriations, ensure that at least one applicant is selected from each of the four census regions of the country where the metal casting industry is concentrated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate strong industry support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the timely transfer of technology to industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a49c5d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise best carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c5d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available in separate appropriation Acts, the Secretary shall provide to each applicant selected the financial and technical assistance and other incentives that are necessary and appropriate to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a49c5da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5304/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Metal Casting Research Institute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of financial assistance under subsection (d) shall be known as a “National Metal Casting Research Institute”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a49c5db-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/425/s5"},"text":"Pub. L. 101–425, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/916"},"text":"104 Stat. 916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
