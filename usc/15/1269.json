{"tag":"section","attrib":{"id":"id7970c9d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1269"},"text":null,"children":[{"tag":"num","attrib":{"value":"1269"},"text":"§ 1269.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7970c9d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1269/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to promulgate regulations for the efficient enforcement of this chapter, except as otherwise provided in this section, is vested in the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7970c9d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1269/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury and the Commission shall jointly prescribe regulations for the efficient enforcement of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1273"},"text":"section 1273 of this title","children":[],"tail":", except as otherwise provided therein. Such regulations shall be promulgated in such manner and take effect at such time, after due notice, as the Commission shall determine."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7970c9d9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/613/s10"},"text":"Pub. L. 86–613, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"tex