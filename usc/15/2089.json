{"tag":"section","attrib":{"id":"id79de58e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089"},"text":null,"children":[{"tag":"num","attrib":{"value":"2089"},"text":"§ 2089.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All-terrain vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79de58ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de58eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory standard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, within 90 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Commission shall publish in the Federal Register as a mandatory consumer product safety standard the American National Standard for Four Wheel All-Terrain Vehicles Equipment Configuration, and Performance Requirements developed by the Specialty Vehicle Institute of America (American National Standard ANSI/SVIA–1–2007). The standard shall take effect 150 days after it is published."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the standard takes effect, it shall be unlawful for any manufacturer or distributor to import into or distribute in commerce in the United States any new assembled or unassembled all-terrain vehicle unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de58ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the all-terrain vehicle complies with each applicable provision of the standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de58ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ATV is subject to an ATV action plan filed with the Commission before ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", or subsequently filed with and approved by the Commission, and bears a label certifying such compliance and identifying the manufacturer, importer or private labeler and the ATV action plan to which it is subject; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de58ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer or distributor is in compliance with all provisions of the applicable ATV action plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The failure to comply with any requirement of paragraph (2) shall be deemed to be a failure to comply with a consumer product safety standard under this chapter and subject to all of the penalties and remedies available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliant models with additional features","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (2) shall not be construed to prohibit the distribution in commerce of new all-terrain vehicles that comply with the requirements of that paragraph but also incorporate characteristics or components that are not covered by those requirements. Any such characteristics or components shall be subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064"},"text":"section 2064 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de58f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of standard","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de58f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ANSI revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the American National Standard ANSI/SVIA–1–2007 is revised through the applicable consensus standards development process after the date on which the product safety standard for all-terrain vehicles is published in the Federal Register, the American National Standards Institute shall notify the Commission of the revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 120 days after it receives notice of such a revision by the American National Standards Institute, the Commission shall issue a notice of proposed rulemaking in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" to amend the product safety standard for all-terrain vehicles to include any such revision that the Commission determines is reasonably related to the safe performance of all-terrain vehicles, and notify the Institute of any provision it has determined not to be so related. The Commission shall promulgate an amendment to the standard for all-terrain vehicles within 180 days after the date on which the notice of proposed rulemaking for the amendment is published in the Federal Register."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unreasonable risk of injury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Commission may, pursuant to sections 2056 and 2058 of this title, amend the product safety standard for all-terrain vehicles to include any additional provision that the Commission determines is reasonably necessary to reduce an unreasonable risk of injury associated with the performance of all-terrain vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain provisions not applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 2056 and 2058 of this title shall not apply to promulgation of any amendment of the product safety standard under paragraph (2). Judicial review of any amendment of the standard under paragraph (2) shall be in accordance with chapter 7 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de58f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for 3-wheeled all-terrain vehicles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until a mandatory consumer product safety standard applicable to 3-wheeled all-terrain vehicles promulgated pursuant to this chapter is in effect, new 3-wheeled all-terrain vehicles may not be imported into or distributed in commerce in the United States. Any violation of this subsection shall be considered to be a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068/a/1"},"text":"section 2068(a)(1) of this title","children":[],"tail":" and may also be enforced under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2066"},"text":"section 2066 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de58f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further proceedings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de58f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall issue a final rule in its proceeding entitled “Standards for All Terrain Vehicles and Ban of Three-wheeled All Terrain Vehicles”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de58fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categories of youth ATVs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the final rule, the Commission, in consultation with the National Highway Traffic Safety Administration, may provide for a multiple factor method of categorization that, at a minimum, takes into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de58fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the weight of the ATV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de58fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum speed of the ATV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de58fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the velocity at which an ATV of a given weight is traveling at the maximum speed of the ATV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de58fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of children for whose operation the ATV is designed or who may reasonably be expected to operate the ATV; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de58ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average weight of children for whose operation the ATV is designed or who may reasonably be expected to operate the ATV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de5900-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional safety standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the final rule, the Commission, in consultation with the National Highway Traffic Safety Administration, shall review the standard published under subsection (a)(1) and establish additional safety standards for all-terrain vehicles to the extent necessary to protect the public health and safety. As part of its review, the Commission shall consider, at a minimum, establishing or strengthening standards on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de5901-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5902-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brake performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5903-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speed governors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5904-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warning labels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5905-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de5906-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dynamic stability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79de5907-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79de5908-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All-terrain vehicle or ATV","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “all-terrain vehicle” or “ATV” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79de5909-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any motorized, off-highway vehicle designed to travel on 3 or 4 wheels, having a seat designed to be straddled by the operator and handlebars for steering control; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79de590a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a prototype of a motorized, off-highway, all-terrain vehicle or other motorized, off-highway, all-terrain vehicle that is intended exclusively for research and development purposes unless the vehicle is offered for sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79de590b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2089/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ATV action plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ATV action plan” means a written plan or letter of undertaking that describes actions the manufacturer or distributor agrees to take to promote ATV safety, including rider training, dissemination of safety information, age recommendations, other policies governing marketing and sale of the ATVs, the monitoring of such sales, and other safety related measures, and that is substantially similar to the plans described under the heading “The Undertakings of the Companies in the Commission Notice” published in the Federal Register on ","children":[{"tag":"date","attrib":{"date":"1998-09-09"},"text":"September 9, 1998","children":[],"tail":" (63 FR 48199–48204)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79de590c-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s42"},"text":"Pub. L. 92–573, § 42","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s232/a"},"text":"Pub. L. 110–314, title II, § 232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3071"},"text":"122 Stat. 3071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79de590d-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79de590e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79de590f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", referred to in subsec. (a)(2)(B), was in the original “the date of enactment of the Act” and was translated as reading “the date of enactment of the Consumer Product Safety Improvement Act of 2008”, which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79de5910-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79de5911-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective on the date that is 30 days after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/314/s239/a"},"text":"section 239(a) of Pub. L. 110–314","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2051"},"text":"section 2051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79de5912-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Rule by Consumer Product Safety Commission on Standards for All Terrain Vehicles","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/28/s9"},"text":"Pub. L. 112–28, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-12"},"text":"Aug. 12, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/282"},"text":"125 Stat. 282","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/28/s9"},"text":"“The Commission shall issue the final rule described in section 42(d) of the Consumer Product Safety Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2089/d"},"text":"15 U.S.C. 2089(d)","children":[],"tail":") not later than 1 year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-08-12"},"text":"Aug. 12, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
