{"tag":"section","attrib":{"id":"id78195082-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"78m–1"},"text":"§ 78m–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and recordkeeping for certain security-based swaps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78195083-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required reporting of security-based swaps not accepted by any clearing agency or derivatives clearing organization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78195084-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each security-based swap that is not accepted for clearing by any clearing agency or derivatives clearing organization shall be reported to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78195085-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a security-based swap data repository described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/n"},"text":"section 78m(n) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78195086-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case in which there is no security-based swap data repository that would accept the security-based swap, to the Commission pursuant to this section within such time period as the Commission may by rule or regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78195087-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition rule for preenactment security-based swaps","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78195088-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-based swaps entered into before ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":null}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each security-based swap entered into before ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the terms of which have not expired as of "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", shall be reported to a registered security-based swap data repository or the Commission by a date that is not later than—"}],"tail":null},{"tag":"clause","attrib":{"id":"id78195089-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days after issuance of the interim final rule; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7819508a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other period as the Commission determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7819508b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate an interim final rule within 90 days of ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", providing for the reporting of each security-based swap entered into before "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", as referenced in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7819508c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reporting provisions described in this section shall be effective upon ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7819508d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting obligations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7819508e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-based swaps in which only 1 counterparty is a security-based swap dealer or major security-based swap participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a security-based swap in which only 1 counterparty is a security-based swap dealer or major security-based swap participant, the security-based swap dealer or major security-based swap participant shall report the security-based swap as required under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7819508f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-based swaps in which 1 counterparty is a security-based swap dealer and the other a major security-based swap participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a security-based swap in which 1 counterparty is a security-based swap dealer and the other a major security-based swap participant, the security-based swap dealer shall report the security-based swap as required under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78195090-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other security-based swaps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to any other security-based swap not described in subparagraph (A) or (B), the counterparties to the security-based swap shall select a counterparty to report the security-based swap as required under paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78195091-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of certain individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual or entity that enters into a security-based swap shall meet each requirement described in subsection (c) if the individual or entity did not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78195092-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clear the security-based swap in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c–3/a/1"},"text":"section 78c–3(a)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78195093-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the data regarding the security-based swap accepted by a security-based swap data repository in accordance with rules (including timeframes) adopted by the Commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78195094-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual or entity described in subsection (b) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78195095-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon written request from the Commission, provide reports regarding the security-based swaps held by the individual or entity to the Commission in such form and in such manner as the Commission may request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id781bc096-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain books and records pertaining to the security-based swaps held by the individual or entity in such form, in such manner, and for such period as the Commission may require, which shall be open to inspection by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id781bc097-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any representative of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781bc098-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate prudential regulator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781bc099-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commodity Futures Trading Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781bc09a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Financial Stability Oversight Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id781bc09b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id781bc09c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78m–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identical data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing rules under this section, the Commission shall require individuals and entities described in subsection (b) to submit to the Commission a report that contains data that is not less comprehensive than the data required to be collected by security-based swap data repositories under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id781bc09d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 13A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s766/a"},"text":"Pub. L. 111–203, title VII, § 766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1797"},"text":"124 Stat. 1797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id781bc09e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id781bc09f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id781bc0a0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(2) and (d), was in the original “this title”. See References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id781bc0a1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id781bc0a2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of 360 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle B (§§ 761–774) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle B, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s774"},"text":"section 774 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
