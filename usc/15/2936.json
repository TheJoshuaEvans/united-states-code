{"tag":"section","attrib":{"id":"id7a108d35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2936"},"text":null,"children":[{"tag":"num","attrib":{"value":"2936"},"text":"§ 2936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific assessment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On a periodic basis (not less frequently than every 4 years), the Council, through the Committee, shall prepare and submit to the President and the Congress an assessment which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a108d36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2936/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates, evaluates, and interprets the findings of the Program and discusses the scientific uncertainties associated with such findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2936/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes the effects of global change on the natural environment, agriculture, energy production and use, land and water resources, transportation, human health and welfare, human social systems, and biological diversity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a108d38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2936/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes current trends in global change, both human-inducted ","children":[{"tag":"ref","attrib":{"idref":"fn002476"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002476"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “human-induced”."}],"tail":" and natural, and projects major trends for the subsequent 25 to 100 years."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a108d39-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/606/tI/s106"},"text":"Pub. L. 101–606, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3101"},"text":"104 Stat. 3101","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
