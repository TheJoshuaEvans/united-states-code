{"tag":"section","attrib":{"id":"id7a50f149-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721"},"text":null,"children":[{"tag":"num","attrib":{"value":"5721"},"text":"§ 5721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a50f14a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f14b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall, in accordance with the requirements of this section, prescribe rules establishing procedures for the correction of billing errors with respect to telephone-billed purchases. The rules prescribed by the Commission shall also include provisions to prohibit unfair or deceptive acts or practices that evade such rules or undermine the rights provided to customers under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f14c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial similarity to credit billing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall promulgate rules under this section that impose requirements that are substantially similar to the requirements imposed, with respect to the resolution of credit disputes, under the Truth in Lending and Fair Credit Billing Acts [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"15 U.S.C. 1601","children":[],"tail":" et seq., 1666 et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f14d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rule issued under paragraph (1) shall be treated as a rule issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57a/a/1/B"},"text":"section 57a(a)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f14e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking schedule and procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall prescribe the rules under subsection (a) within 270 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":". Such rules shall be prescribed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f14f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any violation of any rule prescribed under subsection (a) shall be treated as a violation of a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":" regarding unfair or deceptive acts or practices. Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/a/2"},"text":"section 45(a)(2) of this title","children":[],"tail":", communications common carriers shall be subject to the jurisdiction of the Commission for purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a50f150-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of billing errors and correction of credit reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing rules under this section, the Commission shall consider, with respect to telephone-billed purchases, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f151-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The initiation of a billing review by a customer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f152-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Responses by billing entities and providing carriers to the initiation of a billing review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f153-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investigations concerning delivery of telephone-billed purchases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f154-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Limitations upon providing carrier responsibilities, including limitations on a carrier’s responsibility to verify delivery of audio information or entertainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f155-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Requirements on actions by billing entities to set aside charges from a customer’s billing statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f156-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Limitations on collection actions by billing entities and vendors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f157-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulation of credit reports on billing disputes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f158-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The prompt notification of credit to an account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f159-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rights of customers and telephone common carriers regarding claims and defenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f15a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5721/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the regulations should diverge from requirements under the Truth in Lending and Fair Credit Billing Acts [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"15 U.S.C. 1601","children":[],"tail":" et seq., 1666 et seq.] in order to protect customers, and in order to be cost effective to billing entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f15b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/556/tIII/s301"},"text":"Pub. L. 102–556, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4191"},"text":"106 Stat. 4191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a50f15c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a50f15d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a50f15e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Truth in Lending Act, referred to in subsecs. (a)(2) and (d)(10), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/146"},"text":"82 Stat. 146","children":[],"tail":", which is classified generally to subchapter I (§ 1601 et seq.) of chapter 41 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Credit Billing Act, referred to in subsecs. (a)(2) and (d)(10), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/495"},"text":"Pub. L. 93–495","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-28"},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1511"},"text":"88 Stat. 1511","children":[],"tail":", which is classified principally to part D (§ 1666 et seq.) of subchapter I of chapter 41 of this title. For complete classification of this Act to the Code, see Short Title of 1974 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
