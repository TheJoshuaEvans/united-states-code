{"tag":"section","attrib":{"id":"id78897705-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s207"},"text":null,"children":[{"tag":"num","attrib":{"value":"207"},"text":"§ 207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of standards by Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is authorized and required to prepare suitable standards in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s206"},"text":"section 206 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78897706-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-03/ch221/s2"},"text":"Mar. 3, 1893, ch. 221, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/746"},"text":"27 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s10"},"text":"Feb. 14, 1903, ch. 552, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78897707-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78897708-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78897709-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","childr