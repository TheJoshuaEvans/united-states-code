{"tag":"section","attrib":{"id":"id78824bd7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"80c–3"},"text":"§ 80c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of costs of small securities issues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78824bd8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Securities and Exchange Commission shall use its best efforts to identify and reduce the costs of raising capital in connection with the issuance of securities by firms whose aggregate outstanding securities and other indebtedness have a market value of $25,000,000 or less, through such means as studies, giving appropriate publicity to improved technology developments in fields such as printing, communications, and filing, and giving special attention to the effect of existing and proposed regulatory changes upon the small companies wishing to raise capital and independent broker-dealers which are in a key position with respect to the costs of underwriting and making markets in the securities of smaller companies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78824bd9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall report on these efforts at the annual Government-business forum required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80c–1"},"text":"section 80c–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78824bda-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/477/tV/s506"},"text":"Pub. L. 96–477, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2293"},"text":"94 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78824bdb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78824bdc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id78824bdd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-01-01"},"text":"Jan. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/477/s507"},"text":"section 507 of Pub. L. 96–477","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80c"},"text":"section 80c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
