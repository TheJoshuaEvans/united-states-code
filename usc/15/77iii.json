{"tag":"section","attrib":{"id":"id77ee6fcc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"77iii"},"text":"§ 77iii.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective time of qualification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77ee6fcd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective time of registration or application for qualification of indenture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The indenture under which a security has been or is to be issued shall be deemed to have been qualified under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77ee6fce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when registration becomes effective as to such security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ee6fcf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when an application for the qualification of such indenture becomes effective, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77ggg"},"text":"section 77ggg of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77ee6fd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stop orders after effective time of qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After qualification has become effective as to the indenture under which a security has been or is to be issued, no stop order shall be issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77h/d"},"text":"section 77h(d) of this title","children":[],"tail":", suspending the effectiveness of the registration statement relating to such security or of the application for qualification of such indenture, except on one or more of the grounds specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77h"},"text":"section 77h of this title","children":[],"tail":", or the failure of the issuer to file an application as provided for by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77eee/b/2"},"text":"section 77eee(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77ee6fd1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subsequent rule or regulation on qualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The making, amendment, or rescission of a rule, regulation, or order under the provisions of this subchapter (except to the extent authorized by subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77nnn"},"text":"section 77nnn of this title","children":[],"tail":" with respect to rules and regulations prescribed pursuant to such subsection) shall not affect the qualification, form, or interpretation of any indenture as to which qualification became effective prior to the making, amendment, or rescission of such rule, regulation, or order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77ee6fd2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of trustee under qualified indenture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No trustee under an indenture which has been qualified under this subchapter shall be subject to any liability because of any failure of such indenture to comply with any of the provisions of this subchapter, or any rule, regulation, or order thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77ee6fd3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77iii/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power of Commission to conduct investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed as empowering the Commission to conduct an investigation or other proceeding for the purpose of determining whether the provisions of an indenture which has been qualified under this subchapter are being complied with, or to enforce such provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77ee6fd4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title III, § 309, as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-03/ch411"},"text":"Aug. 3, 1939, ch. 411","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1157"},"text":"53 Stat. 1157","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/550/tIV/s405"},"text":"Pub. L. 101–550, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2723"},"text":"104 Stat. 2723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ee6fd5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ee6fd6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77ee6fd7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/550"},"text":"Pub. L. 101–550","children":[],"tail":" inserted before period at end “, or the failure of the issuer to file an application as provided for by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77eee/b/2"},"text":"section 77eee(b)(2) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77ee6fd8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77ee6fd9-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Securities and Exchange Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 10 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
