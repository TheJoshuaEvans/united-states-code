{"tag":"section","attrib":{"id":"id7a239ef3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3704b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"3704b–1"},"text":"§ 3704b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of operating costs through fee collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Operating costs for the National Technical Information Service associated with the acquisition, processing, storage, bibliographic control, and archiving of information and documents shall be recovered primarily through the collection of fees.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a239ef4-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/245/tI/s103/c"},"text":"Pub. L. 102–245, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-02-14"},"text":"Feb. 14, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/8"},"text":"106 Stat. 8","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a239ef5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a239ef6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7a239ef7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Technology Preeminence Act of 1991, and not as part of the Stevenson-Wydler Technology Innovation Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
