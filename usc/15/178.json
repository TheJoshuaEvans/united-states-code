{"tag":"section","attrib":{"id":"id788495ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s178"},"text":null,"children":[{"tag":"num","attrib":{"value":"178"},"text":"§ 178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of statistics of foreign and interstate commerce and transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the duty of the officer in charge of the Bureau of Foreign and Domestic Commerce to gather and collate statistics and facts relating to commerce with foreign nations and among the several States, the railroad systems of this and other countries, the construction and operation of railroads, the actual cost of such construction and operation of railroads, the actual cost of transporting freight and passengers on railroads, and on canals, rivers, and other navigable waters of the United States, the charges imposed for such transportation of freight and passengers, and the tonnage transported.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788495ae-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/ch129/s1"},"text":"Mar. 3, 1875, ch. 129, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/352"},"text":"18 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s10"},"text":"Feb. 14, 1903, ch. 552, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/407"},"text":"37 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch901/s1/105"},"text":"May 29, 1928, ch. 901, § 1(105)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/994"},"text":"45 Stat. 994","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788495af-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788495b0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788495b1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-29"},"text":"May 29, 1928","children":[],"tail":", discontinued the report of Bureau of Foreign and Domestic Commerce to Congress on commercial relations of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id788495b2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788495b3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1912-08-23"},"text":"Aug. 23, 1912","children":[],"tail":", transferred certain duties of Department or Bureau of Labor to Bureau of Foreign and Domestic Commerce."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", transferred Bureau of Statistics from Treasury Department to Department of Commerce and Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id788495b4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id788495b5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Bureau of Foreign and Domestic Commerce, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s172"},"text":"section 172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
