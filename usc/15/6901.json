{"tag":"section","attrib":{"id":"id7a68bec8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901"},"text":null,"children":[{"tag":"num","attrib":{"value":"6901"},"text":"§ 6901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a68bec9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administration” means the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68becb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity building services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “capacity building services” means services provided to an organization that is, or that is in the process of becoming, a microenterprise development organization or program, for the purpose of enhancing its ability to provide training and services to disadvantaged entrepreneurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68becc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “collaborative” means 2 or more nonprofit entities that agree to act jointly as a qualified organization under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68becd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disadvantaged entrepreneur","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disadvantaged entrepreneur” means a microentrepreneur that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bece-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a low-income person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68becf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a very low-income person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bed0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entrepreneur that lacks adequate access to capital or other resources essential for business success, or is economically disadvantaged, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702"},"text":"section 4702 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intermediary” means a private, nonprofit entity that seeks to serve microenterprise development organizations and programs as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6904"},"text":"section 6904 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “low-income person” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702"},"text":"section 4702 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microentrepreneur","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “microentrepreneur” means the owner or developer of a microenterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microenterprise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “microenterprise” means a sole proprietorship, partnership, or corporation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a68bed6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has fewer than 5 employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a68bed7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally lacks access to conventional loans, equity, or other banking services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microenterprise development organization or program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “microenterprise development organization or program” means a nonprofit entity, or a program administered by such an entity, including community development corporations or other nonprofit development organizations and social service organizations, that provides services to disadvantaged entrepreneurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68bed9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “training and technical assistance” means services and support provided to disadvantaged entrepreneurs, such as assistance for the purpose of enhancing business planning, marketing, management, financial management skills, and assistance for the purpose of accessing financial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a68beda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6901/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Very low-income person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “very low-income person” means having an income, adjusted for family size, of not more than 150 percent of the poverty line (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of title 42","children":[],"tail":", including any revision required by that section)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a68bedb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s172"},"text":"Pub. L. 103–325, title I, § 172","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1472"},"text":"113 Stat. 1472","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a68bedc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a68bedd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7a68bede-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tI/s171"},"text":"Pub. L. 103–325, title I, § 171","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s725"},"text":"Pub. L. 106–102, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1471"},"text":"113 Stat. 1471","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/102/tVII/s725"},"text":"“This subtitle [subtitle C (§§ 171–181) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":", enacting this chapter] may be cited as the ‘Program for Investment in Microentrepreneurs Act of 1999’, also referred to as the ‘PRIME Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
