{"tag":"section","attrib":{"id":"id797a4064-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1362"},"text":null,"children":[{"tag":"num","attrib":{"value":"1362"},"text":"§ 1362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish such policies, standards, criteria, and procedures and to prescribe such rules and regulations as he may deem necessary or appropriate for the administration of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id797a4065-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/182/s12"},"text":"Pub. L. 89–182, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-14"},"text":"Sept. 14, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/683"},"text":"79 Stat. 683","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
