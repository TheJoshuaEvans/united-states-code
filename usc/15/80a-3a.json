{"tag":"section","attrib":{"id":"id7863513d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–3a"},"text":"§ 80a–3a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of philanthropy under State law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7863513e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A security issued by or any interest or participation in any pooled income fund, collective trust fund, collective investment fund, or similar fund that is excluded from the definition of an investment company under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3/c/10/B"},"text":"section 80a–3(c)(10)(B) of this title","children":[],"tail":", and the offer or sale thereof, shall be exempt from any statute or regulation of a State that requires registration or qualification of securities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7863513f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of charitable organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No charitable organization, or any trustee, director, officer, employee, or volunteer of a charitable organization acting within the scope of such person’s employment or duties, shall be required to register as, or be subject to regulation as, a dealer, broker, agent, or investment adviser under the securities laws of any State because such organization or person buys, holds, sells, or trades in securities for its own account in its capacity as trustee or administrator of, or otherwise on behalf of or for the account of one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78635140-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charitable organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78635141-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fund that is excluded from the definition of an investment company under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3/c/10/B"},"text":"section 80a–3(c)(10)(B) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78635142-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trust or other donative instrument described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3/c/10/B"},"text":"section 80a–3(c)(10)(B) of this title","children":[],"tail":", or the settlors (or potential settlors) or beneficiaries of any such trusts or other instruments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78635143-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsections (a) and (b), during the 3-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1995-12-08"},"text":"December 8, 1995","children":[],"tail":", a State may enact a statute that specifically refers to this section and provides prospectively that this section shall not preempt the laws of that State referred to in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78635144-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78635145-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “charitable organization” means an organization described in paragraphs (1) through (5) of section 170(c) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78635146-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “security” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78635147-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–3a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78635148-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/62/s6"},"text":"Pub. L. 104–62, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-08"},"text":"Dec. 8, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/685"},"text":"109 Stat. 685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78635149-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7863514a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7863514b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Philanthropy Protection Act of 1995, and not as part of the Investment Company Act of 1940 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7863514c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7863514d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable as defense to any claim in administrative and judicial actions pending on or commenced after ","children":[{"tag":"date","attrib":{"date":"1995-12-08"},"text":"Dec. 8, 1995","children":[],"tail":", that any person, security, interest, or participation of type described in "},{"tag":"ref","attrib":{"href":"/us/pl/104/62"},"text":"Pub. L. 104–62","children":[],"tail":" is subject to the Securities Act of 1933, the Securities Exchange Act of 1934, the Investment Company Act of 1940, the Investment Advisers Act of 1940, or any State statute or regulation preempted as provided in this section, except as specifically provided in such statutes, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/62/s7"},"text":"section 7 of Pub. L. 104–62","children":[],"tail":", set out as an Effective Date of 1995 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c"},"text":"section 77c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
