{"tag":"section","attrib":{"id":"id790a3f9f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s647"},"text":null,"children":[{"tag":"num","attrib":{"value":"647"},"text":"§ 647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duplication of activities of other Federal departments or agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id790a3fa0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s647/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General prohibition; exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration shall not duplicate the work or activity of any other department or agency of the Federal Government,,","children":[{"tag":"ref","attrib":{"idref":"fn002230"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002230"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and nothing contained in this chapter shall be construed to authorize any such duplication unless such work or activity is expressly provided for in this chapter. If loan applications are being refused or loans denied by such other department or agency responsible for such work or activity due to administrative withholding from obligation or withholding from apportionment, or due to administratively declared moratorium, then, for purposes of this section, no duplication shall be deemed to have occurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id790a3fa1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s647/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Agricultural enterprises” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “agricultural enterprises” means those small business concerns engaged in the production of food and fiber, ranching, and raising of livestock, aquaculture, and all other farming and agricultural-related industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id790a3fa2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2/s18"},"text":"Pub. L. 85–536, § 2[18]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/396"},"text":"72 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/386/s5"},"text":"Pub. L. 93–386, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-23"},"text":"Aug. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/746"},"text":"88 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/305/tI/s112/e"},"text":"Pub. L. 94–305, title I, § 112(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-04"},"text":"June 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/667"},"text":"90 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/38/tI/s101/c"},"text":"Pub. L. 96–38, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/119"},"text":"93 Stat. 119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/302/tI/s119/c"},"text":"Pub. L. 96–302, title I, § 119(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-02"},"text":"July 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/841"},"text":"94 Stat. 841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/270/tIII/s303"},"text":"Pub. L. 98–270, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-04-18"},"text":"Apr. 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/160"},"text":"98 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tIV/s2401"},"text":"Pub. L. 98–369, div. B, title IV, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1116"},"text":"98 Stat. 1116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXVIII/s18006/a/3"},"text":"Pub. L. 99–272, title XVIII, § 18006(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/366"},"text":"100 Stat. 366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXVIII/s1831/a"},"text":"Pub. L. 114–328, div. A, title XVIII, § 1831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2657"},"text":"130 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/189/s4/b"},"text":"Pub. L. 115–189, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-21"},"text":"June 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1497"},"text":"132 Stat. 1497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id790a3fa3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id790a3fa4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id790a3fa5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior similar provisions were contained in section 225, of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-07-30/ch282"},"text":"act July 30, 1953, ch. 282","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch628/s14"},"text":"act Aug. 9, 1955, ch. 628, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/551"},"text":"69 Stat. 551","children":[],"tail":", which was previously classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s651"},"text":"section 651 of this title","children":[],"tail":". The provisions of section 218 of act "},{"tag":"date","attrib":{"date":"1953-07-30"},"text":"July 30, 1953","children":[],"tail":", formerly classified to this section, were transferred to section 2[12] of "},{"tag":"ref","attrib":{"href":"/us/pl/85/536"},"text":"Pub. L. 85–536","children":[],"tail":", and are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s641"},"text":"section 641 of this title","children":[],"tail":". See Codification note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id790a3fa6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/189"},"text":"Pub. L. 115–189","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, text read as follows: “As used in this chapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ‘agricultural enterprises’ means those small business concerns engaged in the production of food and fiber, ranching, and raising of livestock, aquaculture, and all other farming and agricultural related industries; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ‘credit elsewhere’ means the availability of sufficient credit from non-Federal sources at reasonable rates and terms, taking into consideration prevailing private rates and terms in the community in or near where the concern transacts business for similar purposes and periods of time.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “small business concerns” for “businesses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" struck out agricultural enterprises exception and proviso that, prior to "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"Oct. 1, 1987","children":[],"tail":", an agricultural enterprise not be eligible for loan assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/b/1"},"text":"section 636(b)(1) of this title","children":[],"tail":" to repair or replace property other than residences and/or personal property unless it is declined for, or would be declined for, emergency loan assistance at substantially similar interest rates from the Farmers Home Administration under subchapter III of the Consolidated Farm and Rural Development Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/270"},"text":"Pub. L. 98–270","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/302/s119/c/1"},"text":"Pub. L. 96–302, § 119(c)(1)","children":[],"tail":", inserted proviso relating to eligibility for loan assistance prior to "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/302/s119/c/2"},"text":"Pub. L. 96–302, § 119(c)(2)","children":[],"tail":", added par. (1) and designated as par. (2) existing definition of “credit elsewhere”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/38"},"text":"Pub. L. 96–38","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/305"},"text":"Pub. L. 94–305","children":[],"tail":" inserted reference to those enterprises engaged in the production of food and fiber, ranching, and raising of livestock, aquaculture, and all other farming and agricultural related industries."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/386"},"text":"Pub. L. 93–386","children":[],"tail":" inserted provision authorizing the refusal of loan applications and the denial of loans, for purposes of this section, to be deemed nonduplication of activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id790a3fa7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id790a3fa8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/270"},"text":"Pub. L. 98–270","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/270/s313"},"text":"section 313 of Pub. L. 98–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id790a3fa9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/302"},"text":"Pub. L. 96–302","children":[],"tail":" inapplicable to disasters commencing on or before "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/302/s119/d"},"text":"section 119(d) of Pub. L. 96–302","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636"},"text":"section 636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id790a3faa-