{"tag":"section","attrib":{"id":"id7a7e1afe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7708"},"text":null,"children":[{"tag":"num","attrib":{"value":"7708"},"text":"§ 7708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Do-Not-E-Mail registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7e1aff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"December 16, 2003","children":[],"tail":", the Commission shall transmit to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Energy and Commerce a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7e1b00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth a plan and timetable for establishing a nationwide marketing Do-Not-E-Mail registry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an explanation of any practical, technical, security, privacy, enforceability, or other concerns that the Commission has regarding such a registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an explanation of how the registry would be applied with respect to children with e-mail accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7e1b03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to implement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may establish and implement the plan, but not earlier than 9 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"December 16, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7e1b04-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/187/s9"},"text":"Pub. L. 108–187, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2716"},"text":"117 Stat. 2716","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
