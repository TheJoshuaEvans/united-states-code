{"tag":"section","attrib":{"id":"id7a0960b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2695a"},"text":"§ 2695a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model guidelines for siting of school facilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator, in consultation with the Secretary of Education and the Secretary of Health and Human Services, shall issue voluntary school site selection guidelines that account for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0960b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the special vulnerability of children to hazardous substances or pollution exposures in any case in which the potential for contamination at a potential school site exists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modes of transportation available to students and staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficient use of energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0960bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2695a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential use of a school at the site as an emergency shelter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0960bd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tV/s502"},"text":"Pub. L. 94–469, title V, § 502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s461/a"},"text":"Pub. L. 110–140, title IV, § 461(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1640"},"text":"121 Stat. 1640","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
