{"tag":"section","attrib":{"id":"id7983dcd0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1519"},"text":null,"children":[{"tag":"num","attrib":{"value":"1519"},"text":"§ 1519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual and special reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall annually, at the close of each fiscal year, make a report in writing to Congress, giving an account of all moneys received and disbursed by him and his Department, and describing the work done by the Department in fostering, promoting, and developing the foreign and domestic commerce, the mining, manufacturing, and fishery industries; of the United States, and making such recommendations as he shall deem necessary for the effective performance of the duties and purposes of the Department. He shall also from time to time make such special investigations and reports as he may be required to do by the President, or by either House of Congress, or which he himself may deem necessary and urgent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7983dcd1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s8"},"text":"Feb. 14, 1903, ch. 552, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/31/s12/7"},"text":"Pub. L. 97–31, § 12(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-06"},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/154"},"text":"95 Stat. 154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7983dcd2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7983dcd3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7983dcd4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s604"},"text":"section 604 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7983dcd5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/31"},"text":"Pub. L. 97–31","children":[],"tail":" struck out references to shipping and transportation facilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7983dcd6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id7983dcd7-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141"},"text":"Act Mar. 4, 1913, ch. 141","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":", provided that the Department of Commerce and Labor and Secretary of Commerce and Labor were to be thereafter called the Department of Commerce and Secretary of Commerce and that the act creating the Department of Commerce and Labor (act "},{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":") was amended accordingly."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
