{"tag":"section","attrib":{"id":"id7a4c0f6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5409"},"text":null,"children":[{"tag":"num","attrib":{"value":"5409"},"text":"§ 5409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Manufacturers and importers shall retain the record of conformance for fasteners for 5 years, on paper or in photographic or electronic format in a manner that allows for verification of authenticity. Upon request of a distributor who has purchased a fastener, or a person who has purchased a fastener for use in the production of a commercial product, the manufacturer or importer of the fastener shall make available information in the record of conformance to the requester.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a4c0f6d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s7"},"text":"Pub. L. 101–592, § 7","children":[],"tail":", formerly § 10, "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2951"},"text":"104 Stat. 2951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/h"},"text":"Pub. L. 104–113, § 11(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/782"},"text":"110 Stat. 782","children":[],"tail":"; renumbered § 7 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/34/s7"},"text":"Pub. L. 106–34, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-08"},"text":"June 8, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/123"},"text":"113 Stat. 123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4c0f6e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a4c0f6f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a4c0f70-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/592/s7"},"text":"section 7 of Pub. L. 101–592","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5406"},"text":"section 5406 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/106/34"},"text":"Pub. L. 106–34","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a4c0f71-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/34"},"text":"Pub. L. 106–34","children":[],"tail":" substituted present provisions for former provisions which consisted of subsecs. (a) and (b) relating to retention and availability of records concerning inspections, testing, and certifications of fasteners under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5404"},"text":"section 5404 of this title","children":[],"tail":" by laboratories, manufacturers, importers, private label distributors and persons who make significant alterations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/h/1"},"text":"Pub. L. 104–113, § 11(h)(1)","children":[],"tail":", substituted “5 years” for “10 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s11/h"},"text":"Pub. L. 104–113, § 11(h)","children":[],"tail":", substituted “5 years” for “10 years” and “the subsequent purchaser” for “any subsequent purchaser”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
