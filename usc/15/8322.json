{"tag":"section","attrib":{"id":"id7a85473d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8322"},"text":null,"children":[{"tag":"num","attrib":{"value":"8322"},"text":"§ 8322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of FERC","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in the Wall Street Transparency and Accountability Act of 2010 or the amendments to the Commodity Exchange Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.] made by such Act shall limit or affect any statutory enforcement authority of the Federal Energy Regulatory Commission pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s824v"},"text":"section 824v of title 16","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s717c–1"},"text":"section 717c–1 of this title","children":[],"tail":" that existed prior to "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a85473e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s722/g"},"text":"Pub. L. 111–203, title VII, § 722(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1674"},"text":"124 Stat. 1674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a85473f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a854740-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","att