{"tag":"section","attrib":{"id":"id7876645c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–59"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–59"},"text":"§ 80a–59.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions and activities of business development companies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the exemption set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–6/f"},"text":"section 80a–6(f) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–12"},"text":"section 80a–12 of this title","children":[],"tail":" shall apply to a business development company to the same extent as if it were a registered closed-end investment company, except that the Commission shall not prescribe any rule, regulation, or order pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–12/a/1"},"text":"section 80a–12(a)(1) of this title","children":[],"tail":" governing the circumstances in which a business development company may borrow from a bank in order to purchase any security."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7876645d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 60, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/477/tI/s105"},"text":"Pub. L. 96–477, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2285"},"text":"94 Stat. 2285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
