{"tag":"section","attrib":{"id":"id79293a6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k"},"text":null,"children":[{"tag":"num","attrib":{"value":"689k"},"text":"§ 689k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79293a6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each New Markets Venture Capital company that participates in the program established under this part shall be subject to examinations made at the direction of the Investment Division of the Small Business Administration in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance of private sector entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Examinations under this section may be conducted with the assistance of a private sector entity that has both the qualifications and the expertise necessary to conduct such examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79293a70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002261"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002261"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Assessment"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79293a71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may assess the cost of examinations under this section, including compensation of the examiners, against the company examined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79293a72-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any company against which the Administrator assesses costs under this paragraph shall pay such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79293a73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s689k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds collected under this section shall be deposited in the account for salaries and expenses of the Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79293a74-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s362"},"text":"Pub. L. 85–699, title III, § 362","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/8/s1/b/3"},"text":"Pub. L. 106–554, § 1(a)(8) [§ 1(b)(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–662.)"}],"tail":"\n"}],"tail":null}
