{"tag":"section","attrib":{"id":"id77ae0b73-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6a"},"text":"§ 6a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct involving trade or commerce with foreign nations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 1 to 7 of this title shall not apply to conduct involving trade or commerce (other than import trade or import commerce) with foreign nations unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77ae0b74-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such conduct has a direct, substantial, and reasonably foreseeable effect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77ae0b75-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on trade or commerce which is not trade or commerce with foreign nations, or on import trade or import commerce with foreign nations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77ae0b76-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on export trade or export commerce with foreign nations, of a person engaged in such trade or commerce in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ae0b77-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such effect gives rise to a claim under the provisions of sections 1 to 7 of this title, other than this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If sections 1 to 7 of this title apply to such conduct only because of the operation of paragraph (1)(B), then sections 1 to 7 of this title shall apply to such conduct only for injury to export business in the United States.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77ae0b78-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-02/ch647/s7"},"text":"July 2, 1890, ch. 647, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/290/tIV/s402"},"text":"Pub. L. 97–290, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-08"},"text":"Oct. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1246"},"text":"96 Stat. 1246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ae0b79-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77ae0b7a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id77ae0b7b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-02/ch647"},"text":"act July 2, 1890, ch. 647","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/210"},"text":"26 Stat. 210","children":[],"tail":", related to suits by persons injured by acts in violation of sections 1 to 7 of this title and was classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s15"},"text":"section 15 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1955-07-07/ch283/s3"},"text":"act July 7, 1955, ch. 283, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/283"},"text":"69 Stat. 283","children":[],"tail":", effective six months after "},{"tag":"date","attrib":{"date":"1955-07-07"},"text":"July 7, 1955","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
