trib":{"id":"id7aa9236a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/a/5/D/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any officer or employee of the contractor whose total compensation exceeded $3,000,000 in calendar year 2019 during any 12 consecutive months of such period total compensation in excess of the sum of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id7aa9236b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/a/5/D/iv/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id7aa9236c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/a/5/D/iv/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the excess over $3,000,000 of the total compensation received by the officer or employee from the contractor in calendar year 2019.","children":[{"tag":"ref","attrib":{"idref":"fn002651"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002651"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The period probably should be “; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa9236d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa9236e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payroll support grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa9236f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make available to eligible air carriers and eligible contractors, financial assistance exclusively for the continuation of payment of employee wages, salaries, and benefits to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa92370-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible air carriers, in an aggregate amount of $14,000,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa92371-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible contractors, in an aggregate amount of $1,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa92372-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa92373-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apportion funds to eligible air carriers and eligible contractors in accordance with the requirements of this section not later than ","children":[{"tag":"date","attrib":{"date":"2021-04-15"},"text":"April 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa92374-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible air carriers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall apportion funds made available under paragraph (1)(A) to each eligible air carrier in the ratio that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aa92375-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount received by the air carrier pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9093/a"},"text":"section 9093(a) of this title","children":[],"tail":" bears to"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aa92376-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa92377-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall apportion, to each eligible contractor, an amount equal to the total amount such contractor received pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9093/a"},"text":"section 9093(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa92378-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa92379-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide financial assistance to an eligible air carrier or eligible contractor under this section in the same form and on the same terms and conditions as determined by pursuant to ","children":[{"tag":"ref","attrib":{"idref":"fn002652"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002652"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original."}],"tail":" "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9093/b/1/A"},"text":"section 9093(b)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa9237a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish streamlined and expedited procedures not later than 5 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", for eligible air carriers and eligible contractors to submit requests for financial assistance under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa9237b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for immediate payroll assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after ","children":[{"tag":"date","attrib":{"date":"2021-03-11"},"text":"March 11, 2021","children":[],"tail":", the Secretary shall make initial payments to air carriers and contractors that submit requests for financial assistance approved by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa9237c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall receive financial instruments issued by recipients of financial assistance under this section in the same form and amount, and under the same terms and conditions, as determined by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9098"},"text":"section 9098 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa9237d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available under paragraph (1)(A), $10,000,000 shall be made available to the Secretary for costs and administrative expenses associated with providing financial assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa9237e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2021, out of any money in the Treasury not otherwise appropriated, $15,000,000,000, to remain available until expended, to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa9237f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tVII/s7301"},"text":"Pub. L. 117–2, title VII, § 7301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/104"},"text":"135 Stat. 104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa92380-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa92381-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7aa92382-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Rescue Plan Act of 2021, and not as part of the CARES Act which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
