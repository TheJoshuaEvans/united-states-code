{"tag":"section","attrib":{"id":"id7aa4416a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9072"},"text":null,"children":[{"tag":"num","attrib":{"value":"9072"},"text":"§ 9072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pandemic relief for aviation workers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa4416b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance for employee wages, salaries, and benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, to preserve aviation jobs and compensate air carrier industry workers, the Secretary shall provide financial assistance that shall exclusively be used for the continuation of payment of employee wages, salaries, and benefits to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa4416c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9072/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger air carriers, in an aggregate amount up to $25,000,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4416d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9072/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cargo air carriers, in the aggregate amount up to $4,000,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4416e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9072/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contractors, in an aggregate amount up to $3,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa4416f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary, may use $67,000,000 of the funds made available under section 9080(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002645"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002645"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no subsec. (a) in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9080"},"text":"section 9080 of this title","children":[],"tail":"."}],"tail":" of this title for costs and administrative expenses associated with providing financial assistance under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa44170-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4112"},"text":"Pub. L. 116–136, div. A, title IV, § 4112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/498"},"text":"134 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dLL/s102/d/1/B"},"text":"Pub. L. 117–328, div. LL, § 102(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6103"},"text":"136 Stat. 6103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa44171-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa44172-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7aa44173-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “$67,000,000” for “$100,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7aa44174-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7aa44175-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" effective upon issuance of guidance or the promulgation of a rule by the Secretary of the Treasury, in consultation with the Secretary of Transportation, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/s102/c"},"text":"section 102(c) of Pub. L. 117–328","children":[],"tail":", set out as a note under secton 802 of Title 42, The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
