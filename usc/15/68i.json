{"tag":"section","attrib":{"id":"id77d4312d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s68i"},"text":null,"children":[{"tag":"num","attrib":{"value":"68i"},"text":"§ 68i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provision of this subchapter shall be held to be in addition to, and not in substitution for or limitation of, the provisions of any other Act of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d4312e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch871/s11"},"text":"Oct. 14, 1940, ch. 871, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1133"},"text":"54 Stat. 1133","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
