{"tag":"section","attrib":{"id":"id77f59bb4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77xxx"},"text":null,"children":[{"tag":"num","attrib":{"value":"77xxx"},"text":"§ 77xxx.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful representations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person in offering, selling or issuing any security to represent or imply in any manner whatsoever that any action or failure to act by the Commission in the administration of this subchapter means that the Commission has in any way passed upon the merits of, or given approval to, any trustee, indenture or security, or any transaction or transactions therein, or that any such action or failure to act with regard to any statement or report filed with or examined by the Commission pursuant to this subchapter or any rule, regulation, or order thereunder, has the effect of a finding by the Commission that such statement or report is true and accurate on its face or that it is not false or misleading.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f59bb5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title III, § 324, as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-03/ch411"},"text":"Aug. 3, 1939, ch. 411","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1176"},"text":"53 Stat. 1176","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-10/ch667"},"text":"Aug. 10, 1954, ch. 667","children":[],"tail":", title III, § 305, "},{"tag":"ref","attrib":{"href":"/us/stat/68/688"},"text":"68 Stat. 688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f59bb6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77f59bb7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77f59bb8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", substituted “offering, selling, or issuing” for “issuing or selling”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77f59bb9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77f59bba-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1954 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", effective 60 days after "},{"tag":"date","attrib":{"date":"1954-08-10"},"text":"Aug. 10, 1954","children":[],"tail":", see note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77f59bbb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77f59bbc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Securities and Exchange Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 10 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
