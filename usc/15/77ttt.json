{"tag":"section","attrib":{"id":"id77f32a88-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77ttt"},"text":null,"children":[{"tag":"num","attrib":{"value":"77ttt"},"text":"§ 77ttt.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Hearings may be public and may be held before the Commission, any member or members thereof, or any officer or officers of the Commission designated by it, and appropriate records thereof shall be kept.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77f32a89-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title III, § 320, as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-03/ch411"},"text":"Aug. 3, 1939, ch. 411","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1174"},"text":"53 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77f32a8a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77f32a8b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77f32a8c-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Securities and Exchange Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 10 of 1950, §§ 1, 2, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1265"},"text":"64 Stat. 1265","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
