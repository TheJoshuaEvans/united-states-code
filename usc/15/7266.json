{"tag":"section","attrib":{"id":"id7a7234e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266"},"text":null,"children":[{"tag":"num","attrib":{"value":"7266"},"text":"§ 7266.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced review of periodic disclosures by issuers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a7234e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular and systematic review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall review disclosures made by issuers reporting under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/a"},"text":"section 78m(a) of this title","children":[],"tail":" (including reports filed on Form 10–K), and which have a class of securities listed on a national securities exchange or traded on an automated quotation facility of a national securities association, on a regular and systematic basis for the protection of investors. Such review shall include a review of an issuer’s financial statement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of scheduling the reviews required by subsection (a), the Commission shall consider, among other factors—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7234e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuers that have issued material restatements of financial results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuers that experience significant volatility in their stock price as compared to other issuers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuers with the largest market capitalization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emerging companies with disparities in price to earning ratios;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuers whose operations significantly affect any material sector of the economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7234ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other factors that the Commission may consider relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a7234ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7266/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum review period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no event shall an issuer required to file reports under section 78m(a) or 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title be reviewed under this section less frequently than once every 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7234ef-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/204/tIV/s408"},"text":"Pub. L. 107–204, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/790"},"text":"116 Stat. 790","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
