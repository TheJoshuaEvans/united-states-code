{"tag":"section","attrib":{"id":"id792b8402-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690g"},"text":null,"children":[{"tag":"num","attrib":{"value":"690g"},"text":"§ 690g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee contribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792b8403-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that amounts are made available to the Administrator for the purpose of fee contributions, the Administrator shall contribute to fees paid by the Renewable Fuel Capital Investment companies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s690f"},"text":"section 690f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792b8404-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fee contribution under subsection (a) shall be effective for 1 fiscal year and shall be adjusted as necessary for each fiscal year thereafter to ensure that amounts under subsection (a) are fully used. The fee contribution for a fiscal year shall be based on the outstanding commitments made and the guarantees and grants that the Administrator projects will be made during that fiscal year, given the program level authorized by law for that fiscal year and any other factors that the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792b8405-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s388"},"text":"Pub. L. 85–699, title III, § 388","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1780"},"text":"121 Stat. 1780","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
