{"tag":"section","attrib":{"id":"id78063d40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"78d–3"},"text":"§ 78d–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appearance and practice before the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id78063d41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to censure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may censure any person, or deny, temporarily or permanently, to any person the privilege of appearing or practicing before the Commission in any way, if that person is found by the Commission, after notice and opportunity for hearing in the matter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to possess the requisite qualifications to represent others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be lacking in character or integrity, or to have engaged in unethical or improper professional conduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have willfully violated, or willfully aided and abetted the violation of, any provision of the securities laws or the rules and regulations issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78063d45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any registered public accounting firm or associated person, for purposes of this section, the term “improper professional conduct” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78063d46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentional or knowing conduct, including reckless conduct, that results in a violation of applicable professional standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78063d47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" negligent conduct in the form of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78063d48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single instance of highly unreasonable conduct that results in a violation of applicable professional standards in circumstances in which the registered public accounting firm or associated person knows, or should know, that heightened scrutiny is warranted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78063d49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78d–3/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repeated instances of unreasonable conduct, each resulting in a violation of applicable professional standards, that indicate a lack of competence to practice before the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id78063d4a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 4C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/204/tVI/s602"},"text":"Pub. L. 107–204, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-30"},"text":"July 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/794"},"text":"116 Stat. 794","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
