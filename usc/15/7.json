{"tag":"section","attrib":{"id":"id77ae0b7c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"§ 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Person” or “persons” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The word “person”, or “persons”, wherever used in sections 1 to 7 of this title shall be deemed to include corporations and associations existing under or authorized by the laws of either the United States, the laws of any of the Territories, the laws of any State, or the laws of any foreign country.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77ae0b7d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-02/ch647/s8"},"text":"July 2, 1890, ch. 647, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/210"},"text":"26 Stat. 210","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
