{"tag":"section","attrib":{"id":"id79a06640-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679"},"text":"§ 1679.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a06641-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a06642-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consumers have a vital interest in establishing and maintaining their credit worthiness and credit standing in order to obtain and use credit. As a result, consumers who have experienced credit problems may seek assistance from credit repair organizations which offer to improve the credit standing of such consumers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06643-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Certain advertising and business practices of some companies engaged in the business of credit repair services have worked a financial hardship upon consumers, particularly those of limited economic means and who are inexperienced in credit matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a06644-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a06645-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that prospective buyers of the services of credit repair organizations are provided with the information necessary to make an informed decision regarding the purchase of such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06646-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the public from unfair or deceptive advertising and business practices by credit repair organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a06647-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s402"},"text":"Pub. L. 90–321, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-455"},"text":"110 Stat. 3009–455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a06648-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a06649-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79a0664a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-05-29"},"text":"May 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/164"},"text":"82 Stat. 164","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/91/344"},"text":"Pub. L. 91–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-20"},"text":"July 20, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/440"},"text":"84 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/321"},"text":"Pub. L. 92–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-30"},"text":"June 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/382"},"text":"86 Stat. 382","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":", established a bipartisan National Commission on Consumer Finance to study the functioning and structure of the consumer finance industry as well as consumer credit transactions generally. The Commission was to submit a final report by "},{"tag":"date","attrib":{"date":"1972-12-31"},"text":"Dec. 31, 1972","children":[],"tail":", and was to cease to exist thereafter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a0664b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a0664c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s413"},"text":"Pub. L. 90–321, title IV, § 413","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-462"},"text":"110 Stat. 3009–462","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tII/s2451"},"text":"“This title [enacting this subchapter] shall apply after the end of the 6-month period beginning on the date of the enactment of the Credit Repair Organizations Act [","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"], except with respect to contracts entered into by a credit repair organization before the end of such period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79a0664d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter known as the “Credit Repair Organizations Act”, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
