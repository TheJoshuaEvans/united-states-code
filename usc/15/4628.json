{"tag":"section","attrib":{"id":"id7a3b6df8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4628"},"text":null,"children":[{"tag":"num","attrib":{"value":"4628"},"text":"§ 4628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Energy oversight of cooperative agreements relating to Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3b6df9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions relating to disapproval and modification of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of Energy desires an opportunity to disapprove or require the modification of any agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4627"},"text":"section 4627 of this title","children":[],"tail":", the agreement shall provide a 90-day period within which such action may be taken, beginning on the date the agreement is submitted to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6dfa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each national laboratory shall maintain a record of all agreements entered into under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3b6dfb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dC/tI/s3148"},"text":"Pub. L. 100–180, div. C, title I, § 3148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1244"},"text":"101 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
