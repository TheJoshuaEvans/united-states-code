{"tag":"section","attrib":{"id":"id7a8ee46b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811"},"text":null,"children":[{"tag":"num","attrib":{"value":"8811"},"text":"§ 8811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Quantum Initiative Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee46c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall implement a National Quantum Initiative Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee46d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the President, acting through Federal agencies, councils, working groups, subcommittees, and the Coordination Office, as the President considers appropriate, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee46e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the goals, priorities, and metrics for a 10-year plan to accelerate development of quantum information science and technology applications in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee46f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest in fundamental Federal quantum information science and technology research, development, demonstration, and other activities to achieve the goals established under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee470-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest in activities to develop a quantum information science and technology workforce pipeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee471-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for interagency planning and coordination of Federal quantum information science and technology research, development, demonstration, standards engagement, and other activities under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee472-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with industry and universities to leverage knowledge and resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee473-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8811/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage existing Federal investments efficiently to advance Program goals and priorities established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a8ee474-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tI/s101"},"text":"Pub. L. 115–368, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5094"},"text":"132 Stat. 5094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a8ee475-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id7a8ee476-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8815"},"text":"section 8815 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
