{"tag":"section","attrib":{"id":"id7aa1f791-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9058b"},"text":"§ 9058b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for water assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa1f792-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary of Health and Human Services (in this section referred to as the “Secretary”) for fiscal year 2021, out of any amounts in the Treasury not otherwise appropriated, $500,000,000, to remain available until expended, for grants to States and Indian Tribes to assist low-income households, particularly those with the lowest incomes, that pay a high proportion of household income for drinking water and wastewater services, by providing funds to owners or operators of public water systems or treatment works to reduce arrearages of and rates charged to such households for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f793-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa1f794-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allot amounts appropriated in this section to a State or Indian Tribe based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa1f795-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of households in the State, or under the jurisdiction of the Indian Tribe, with income equal or less than 150 percent of the Federal poverty line; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa1f796-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of households in the State, or under the jurisdiction of the Indian Tribe, that spend more than 30 percent of monthly income on housing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa1f797-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserve up to 3 percent of the amount appropriated in this section for Indian Tribes and tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa1f798-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9058b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “State” means each of the 50 States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, Guam, the United States Virgin Islands, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa1f799-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/2/tII/s2912"},"text":"Pub. L. 117–2, title II, § 2912","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-03-11"},"text":"Mar. 11, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/51"},"text":"135 Stat. 51","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aa1f79a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aa1f79b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7aa1f79c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Rescue Plan Act of 2021, and not as part of the CARES Act which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
