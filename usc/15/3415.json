{"tag":"section","attrib":{"id":"id7a1c735c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415"},"text":null,"children":[{"tag":"num","attrib":{"value":"3415"},"text":"§ 3415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c735d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to intervene","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c735e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention as matter of right","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy may intervene as a matter of right in any proceeding relating to the prorationing of, or other limitations upon, natural gas production which is conducted by any State agency having regulatory jurisdiction over the production of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c735f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of right to intervene","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may bring an action in any appropriate court of the United States to enforce his right to intervene under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7360-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As an intervenor in a proceeding described in subsection (a), the Secretary shall have access to information available to other parties to the proceeding if such information is relevant to the issues to which his participation in such proceeding relates. Such information may be obtained through reasonable rules relating to discovery of information prescribed by the State agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c7361-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to State courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a1c7362-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review in State courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may obtain review of any determination made in any proceeding described in subsection (a)(1) in the appropriate State court if the Secretary intervened or otherwise participated in the original proceeding or if State law otherwise permits such review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a1c7363-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3415/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation as amicus curiae","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to his authority to obtain review under paragraph (1), the Secretary may also participate an ","children":[{"tag":"ref","attrib":{"idref":"fn002494"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002494"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “as”."}],"tail":" amicus curiae in any judicial review of any proceeding described in subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c7364-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tV/s505"},"text":"Pub. L. 95–621, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3403"},"text":"92 Stat. 3403","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
