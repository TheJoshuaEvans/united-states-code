{"tag":"section","attrib":{"id":"id7945c1fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h"},"text":null,"children":[{"tag":"num","attrib":{"value":"719h"},"text":"§ 719h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7945c1fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusiveness of remedy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the actions of Federal officers or agencies taken pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719g"},"text":"section 719g of this title","children":[],"tail":", shall not be subject to judicial review except as provided in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7945c1fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations for filing claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7945c1fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims alleging the invalidity of this chapter may be brought not later than the 60th day following the date a decision takes effect pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719f"},"text":"section 719f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7945c1ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Claims alleging that an action will deny rights under the Constitution of the United States, or that an action is in excess of statutory jurisdiction, authority, or limitations, or short of statutory right may be brought not later than the 60th day following the date of such action, except that if a party shows that he did not know of the action complained of, and a reasonable person acting in the circumstances would not have known, he may bring a claim alleging the invalidity of such action on the grounds stated above not later than the 60th day following the date of his acquiring actual or constructive knowledge of such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7945c200-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7945c201-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Courts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7945c202-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A claim under subsection (b) shall be barred unless a complaint is filed prior to the expiration of such time limits in the United States Court of Appeals for the District of Columbia acting as a Special Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7945c203-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Special Court shall have exclusive jurisdiction to determine such proceeding in accordance with the procedures hereinafter provided, and no other court of the United States, or any State, territory, or possession of the United States, or of the District of Columbia, shall have jurisdiction of any such claim in any proceeding instituted prior to or on or after ","children":[{"tag":"date","attrib":{"date":"1976-10-22"},"text":"October 22, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7945c204-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Special Court shall set any action brought under this section for expedited consideration, taking into account the national interest described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719"},"text":"section 719 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7945c205-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The enactment of a joint resolution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719f"},"text":"section 719f of this title","children":[],"tail":" approving the decision of the President shall be conclusive as to the legal and factual sufficiency of the environmental impact statements submitted by the President relative to the approved transportation system and no court shall have jurisdiction to consider questions respecting the sufficiency of such statements under the National Environmental Policy Act of 1969 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7945c206-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s10"},"text":"Pub. L. 94–586, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2913"},"text":"90 Stat. 2913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/16"},"text":"Pub. L. 98–620, title IV, § 402(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3358"},"text":"98 Stat. 3358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/324/dC/s107/d"},"text":"Pub. L. 108–324, div. C, § 107(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-13"},"text":"Oct. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1261"},"text":"118 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7945c207-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7945c208-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7945c209-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7945c20a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/s107/d/1"},"text":"Pub. L. 108–324, § 107(d)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/s107/d/1"},"text":"Pub. L. 108–324, § 107(d)(1)","children":[],"tail":", (2), designated first sentence as subpar. (A) and inserted par. and subpar. headings and designated last sentence as subpar. (B), inserted subpar. heading, and substituted “The Special Court shall have” for “Such court shall have”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/s107/d/3"},"text":"Pub. L. 108–324, § 107(d)(3)","children":[],"tail":", added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/324/s107/d/4"},"text":"Pub. L. 108–324, § 107(d)(4)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out par. (2) which required that any such proceeding had to be assigned for hearing and completed at the earliest possible date, would, to the greatest extent practicable, take precedence over all other matters pending on the docket of the court at that time, and had to be expedited in every way by such court and such court had to render its decision relative to any claim within 90 days from the date such claim was brought unless such court determined that a longer period of time was required to satisfy requirements of the United States Constitution."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7945c20b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7945c20c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7945c20d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7945c20e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Enforcement functions authorized by, and supplemental enforcement authority created by this chapter with respect to pre-construction, construction, and initial operation of transportation system for Canadian and Alaskan natural gas transferred to Federal Inspector, Office of Federal Inspector for Alaska Natural Gas Transportation System, until first anniversary of date of initial operation of Alaska Natural Gas Transportation System, see Reorg. Plan No. 1 of 1979, §§ 102(h)(1), 203(a), 44 F.R. 33663, 33666, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/93/1373"},"text":"93 Stat. 1373","children":[],"tail":", 1376, effective "},{"tag":"date","attrib":{"date":"1979-07-01"},"text":"July 1, 1979","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s719e"},"text":"section 719e of this title","children":[],"tail":". Office of Federal Inspector for the Alaska Natural Gas Transportation System abolished and functions and authority vested in Inspector transferred to Secretary of Energy by "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/s3012/b"},"text":"section 3012(b) of Pub. L. 102–486","children":[],"tail":", set out as an Abolition of Office of Federal Inspector note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s719e"},"text":"section 719e of this title","children":[],"tail":". Functions and authority vested in Secretary of Energy subsequently transferred to Federal Coordinator for Alaska Natural Gas Transportation Projects by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s720d/f"},"text":"section 720d(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
