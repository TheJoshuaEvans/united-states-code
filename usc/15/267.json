{"tag":"section","attrib":{"id":"id788bc196-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s267"},"text":null,"children":[{"tag":"num","attrib":{"value":"267"},"text":"§ 267.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this Act, the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, Guam, the Commonwealth of the Northern Mariana Islands, or any possession of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788bc197-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/387/s7"},"text":"Pub. L. 89–387, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-13"},"text":"Apr. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/109"},"text":"80 Stat. 109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/564/s1/c"},"text":"Pub. L. 106–564, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-23"},"text":"Dec. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2811"},"text":"114 Stat. 2811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788bc198-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788bc199-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id788bc19a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/387"},"text":"Pub. L. 89–387","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-04-13"},"text":"Apr. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/107"},"text":"80 Stat. 107","children":[],"tail":", known as the “Uniform Time Act of 1966”. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s260"},"text":"section 260 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id788bc19b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/564"},"text":"Pub. L. 106–564","children":[],"tail":" inserted “Guam, the Commonwealth of the Northern Mariana Islands,” after “Puerto Rico,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
