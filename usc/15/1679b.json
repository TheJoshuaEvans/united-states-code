{"tag":"section","attrib":{"id":"id79a06661-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1679b"},"text":"§ 1679b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a06662-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79a06663-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make any statement, or counsel or advise any consumer to make any statement, which is untrue or misleading (or which, upon the exercise of reasonable care, should be known by the credit repair organization, officer, employee, agent, or other person to be untrue or misleading) with respect to any consumer’s credit worthiness, credit standing, or credit capacity to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06664-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any consumer reporting agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a/f"},"text":"section 1681a(f) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a06665-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a06666-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has extended credit to the consumer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a06667-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom the consumer has applied or is applying for an extension of credit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a06668-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make any statement, or counsel or advise any consumer to make any statement, the intended effect of which is to alter the consumer’s identification to prevent the display of the consumer’s credit record, history, or rating for the purpose of concealing adverse information that is accurate and not obsolete to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79a06669-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any consumer reporting agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79a0666a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id79a0666b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has extended credit to the consumer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id79a0666c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom the consumer has applied or is applying for an extension of credit;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a0666d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make or use any untrue or misleading representation of the services of the credit repair organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79a0666e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage, directly or indirectly, in any act, practice, or course of business that constitutes or results in the commission of, or an attempt to commit, a fraud or deception on any person in connection with the offer or sale of the services of the credit repair organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a0666f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1679b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment in advance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No credit repair organization may charge or receive any money or other valuable consideration for the performance of any service which the credit repair organization has agreed to perform for any consumer before such service is fully performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a06670-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIV/s404"},"text":"Pub. L. 90–321, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2451"},"text":"Pub. L. 104–208, div. A, title II, § 2451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-456"},"text":"110 Stat. 3009–456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a06671-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a06672-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id79a06673-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For a prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/s404"},"text":"section 404 of Pub. L. 90–321","children":[],"tail":", see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a06674-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79a06675-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable after the end of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except with respect to contracts entered into by a credit repair organization before the end of such period, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/321/s413"},"text":"section 413 of Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1679"},"text":"section 1679 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
