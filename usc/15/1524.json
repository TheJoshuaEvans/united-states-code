{"tag":"section","attrib":{"id":"id7983dcf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1524"},"text":null,"children":[{"tag":"num","attrib":{"value":"1524"},"text":"§ 1524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment and reinvestments of moneys; credit and disbursement of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the request of the Secretary of Commerce, the Secretary of the Treasury may invest and reinvest in securities of the United States or in securities guaranteed as to principal and interest by the United States any moneys contained in the fund authorized herein. Income accruing from such securities, and from any other property accepted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1522"},"text":"section 1522 of this title","children":[],"tail":", shall be deposited to the credit of the fund authorized herein, and shall be disbursed upon order of the Secretary of Commerce."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7983dcf9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/611/s3"},"text":"Pub. L. 88–611, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-02"},"text":"Oct. 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/991"},"text":"78 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7983dcfa-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7983dcfb-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7983dcfc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s608c"},"text":"section 608c of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
