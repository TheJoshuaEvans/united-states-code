{"tag":"section","attrib":{"id":"id79410872-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719b"},"text":null,"children":[{"tag":"num","attrib":{"value":"719b"},"text":"§ 719b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79410873-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Alaska natural gas” means natural gas derived from the area of the State of Alaska generally known as the North Slope of Alaska, including the Continental Shelf thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410874-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Commission” means the Federal Power Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410875-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410876-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “provision of law” means any provision of a Federal statute or rule, regulation, or order issued thereunder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410877-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “approved transportation system” means the system for the transportation of Alaska natural gas designated by the President pursuant to section 719e(a) or 719f(b) of this title and approved by joint resolution of the Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719f"},"text":"section 719f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79410878-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s4"},"text":"Pub. L. 94–586, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2904"},"text":"90 Stat. 2904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79410879-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7941087a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id7941087b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Power Commission was terminated, and its functions, personnel, property, funds, etc., were transferred to the Secretary of Energy (except for certain functions which were transferred to the Federal Energy Regulatory Commission) by sections 7151(b), 7171(a), 7172(a)(1), 7291, and 7293 of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
