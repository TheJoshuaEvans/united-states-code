{"tag":"section","attrib":{"id":"id7a285a3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3712"},"text":null,"children":[{"tag":"num","attrib":{"value":"3712"},"text":"§ 3712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, the Secretary of Energy, and the Director of the National Science Foundation, jointly, shall establish a program to foster the exchange of scientific and technical personnel among academia, industry, and Federal laboratories. Such program shall include both (1) federally supported exchanges and (2) efforts to stimulate exchanges without Federal funding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a285a3b-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s20"},"text":"Pub. L. 96–480, § 20","children":[],"tail":", formerly § 13, "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2320"},"text":"94 Stat. 2320","children":[],"tail":"; renumbered § 17, "},{"tag":"ref","attrib":{"href":"/us/pl/99/502/s2"},"text":"Pub. L. 99–502, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1785"},"text":"100 Stat. 1785","children":[],"tail":"; renumbered § 16, "},{"tag":"ref","attrib":{"href":"/us/pl/99/502/s9/e/1"},"text":"Pub. L. 99–502, § 9(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-20"},"text":"Oct. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1797"},"text":"100 Stat. 1797","children":[],"tail":"; renumbered § 17, "},{"tag":"ref","attrib":{"href":"/us/pl/100/107/s3/a"},"text":"Pub. L. 100–107, § 3(a)","children":[],"tail":", "},{"t