{"tag":"section","attrib":{"id":"id7a023562-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644"},"text":null,"children":[{"tag":"num","attrib":{"value":"2644"},"text":"§ 2644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements if EPA fails to promulgate regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a023563-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a023564-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to promulgate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Administrator fails to promulgate within the prescribed period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a023565-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/b"},"text":"section 2643(b) of this title","children":[],"tail":" (relating to inspection);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023566-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations described in section 2643(c), (d), (e), (f), (g), and (i) of this title (relating to responding to asbestos); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023567-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/h"},"text":"section 2643(h) of this title","children":[],"tail":" (relating to transportation and disposal);"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"each local educational agency shall carry out the requirements described in this section in subsection (b); subsections (c), (d), and (e); or subsection (f); respectively, in accordance with the Environmental Protection Agency’s most current guidance document.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a023568-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay by court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator has promulgated regulations described in paragraph (1)(A), (B), or (C) within the prescribed period, but the effective date of such regulations has been stayed by a court for a period of more than 30 days, a local educational agency shall carry out the pertinent requirements described in this subsection in accordance with the Environmental Protection Agency’s most current guidance document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a023569-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall be in effect until such time as the Administrator promulgates the pertinent regulations or until the stay is lifted (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a02356a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a02356b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the local educational agency, within 540 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", shall conduct an inspection for asbestos-containing material, using personnel accredited under section 2646(b) or (c) of this title and laboratories accredited under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2646/d"},"text":"section 2646(d) of this title","children":[],"tail":", in each school building under its authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a02356c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The local educational agency may exclude from the inspection requirement in paragraph (1) any school building, or portion of a school building, if (A) an inspection of such school building (or portion) was completed before the date on which this section goes into effect, and (B) the inspection meets the inspection requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a02356d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local educational agency shall, within 720 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", develop and begin implementation of an operation and maintenance plan with respect to friable asbestos-containing material in a school building under its authority. Such plan shall provide for the education of school service and maintenance personnel about safety procedures with respect to asbestos-containing material, including friable asbestos-containing material."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a02356e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a02356f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The local educational agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a023570-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a management plan for responding to asbestos-containing material in each school building under its authority and submit such plan to the Governor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2645"},"text":"section 2645 of this title","children":[],"tail":" within 810 days after "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023571-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin implementation of such plan within 990 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023572-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete implementation of such plan in a timely fashion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a023573-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management plan shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a023574-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the elements listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/i/1"},"text":"section 2643(i)(1) of this title","children":[],"tail":", including an inspection statement as described in paragraph (3) of this section,"},{"tag":"ref","attrib":{"idref":"fn002466"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002466"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection,”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023575-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the attachment of warning labels as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2643/i/3"},"text":"section 2643(i)(3) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023576-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prepared in accordance with the most current guidance document,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023577-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the standard described in paragraph (4) for actions described in that paragraph, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023578-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted to the State Governor under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2645"},"text":"section 2645 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a023579-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The local educational agency shall complete an inspection statement, covering activities carried out before ","children":[{"tag":"date","attrib":{"date":"1986-10-22"},"text":"October 22, 1986","children":[],"tail":", which meets the following requirements:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a02357a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The statement shall include the following information:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a02357b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dates of inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a02357c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name, address, and qualifications of each inspector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a02357d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the specific areas inspected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a02357e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of the laboratories that analyzed any bulk samples of asbestos-containing material or air samples of asbestos found in any school building and a statement describing the qualifications of each laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a02357f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The results of the inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023580-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The statement shall state whether any actions were taken with respect to any asbestos-containing material found to be present, including a specific reference to whether any actions were taken in the boiler room of the building. If any such action was taken, the following items of information shall be included in the statement:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a023581-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location or locations at which the action was taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a023582-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the method of action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a023583-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The qualifications of the persons who conducted the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a023584-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ambient interior concentration of asbestos after the completion of actions described in the most current guidance document, other than the type of action described in sections 2643(f) of this title and subsection (c) of this section, shall not exceed the ambient exterior concentration, discounting any contribution from any local stationary source. Either a scanning electron microscope or a transmission electron microscope shall be used to determine the ambient interior concentration. In the absence of reliable measurements, the ambient exterior concentration shall be deemed to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a023585-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 0.003 fibers per cubic centimeter if a scanning electron microscope is used, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a023586-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 0.005 fibers per cubic centimeter if a transmission electron microscope is used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a023587-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A copy of the management plan shall be available in the administrative offices of the local educational agency for inspection by the public, including teachers, other school personnel, and parents. The local educational agency shall notify parent, teacher, and employee organizations of the availability of such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047e78-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Building occupant protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local educational agency shall provide for the protection of building occupants during each phase of activity described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a047e79-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2644/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation and disposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The local educational agency shall provide for the transportation and disposal of asbestos in accordance with the most recent version of the Environmental Protection Agency’s “Asbestos Waste Management Guidance” (or any successor to such document).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a047e7a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tII/s204"},"text":"Pub. L. 94–469, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/519/s2"},"text":"Pub. L. 99–519, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2977"},"text":"100 Stat. 2977","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
