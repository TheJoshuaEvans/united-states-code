{"tag":"section","attrib":{"id":"id7ab509d4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803"},"text":null,"children":[{"tag":"num","attrib":{"value":"9803"},"text":"§ 9803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Assistant Secretary of Commerce for Travel and Tourism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab509d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visitation goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary of Commerce for Travel and Tourism (referred to in this section as the “Assistant Secretary”) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after consultation with the travel and tourism industry, work with the Travel Promotion Committee and the United States Travel and Tourism Advisory Board to establish an annual goal, consistent with the goals of the travel and tourism strategy developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9804/1"},"text":"section 9804(1) of this title","children":[],"tail":", for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab509d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of international visitors to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of travel and tourism commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations for achieving the annual goals established pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that travel and tourism policy is developed in consultation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab509db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tourism Policy Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation for Travel Promotion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Travel and Tourism Advisory Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel and tourism industry representatives, including public and private destination marketing organizations, travel and tourism suppliers, gig economy representatives, and labor representatives from these industries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish short, medium, and long-term timelines for implementing the recommendations developed pursuant to paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct Federal agency needs assessments, in consultation with the Office of Management and Budget and other relevant Federal agencies, to identify the resources, statutory or regulatory changes, and private sector engagement needed to achieve the annual visitation goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509e3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide assessments and recommendations to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab509e4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509e5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509e6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public through a publicly accessible website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509e7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic travel and tourism","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, to the extent feasible, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509e8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate, on an ongoing basis, domestic policy options for supporting competitiveness with respect to the strengths, weaknesses, and growth of the domestic travel industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations and goals to support and enhance domestic tourism, separated by business and leisure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509ea-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage public and private stakeholders to support domestic tourism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509eb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workforce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509ec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Labor to develop strategies and best practices for improving the timeliness and reliability of travel and tourism workforce data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509ed-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the Secretary of Labor and the Bureau of Economic Analysis to improve travel and tourism industry data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509ee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations for policy enhancements and efficiencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide policy recommendations regarding the gig economy as it relates to travel and tourism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation of international business travel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, in coordination with relevant Federal agencies, shall strive to increase and facilitate international business travel to the United States and ensure competitiveness by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating large meetings, incentives, conferences, and exhibitions in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasizing rural and other destinations in the United States that are rich in cultural heritage or ecological tourism, among other uniquely American destinations, as locations for hosting international meetings, incentives, conferences, and exhibitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating sports and recreation events and activities in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery strategies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after amounts are appropriated to the Department of Commerce to accomplish the purposes of this section, the Assistant Secretary, in consultation with the entities referred to in subsection (a)(3), shall develop recovery strategies for the travel and tourism industry in response to the economic impacts of the COVID–19 pandemic and in anticipation of other unpredictable catastrophic events that would significantly affect the travel and tourism industry, such as hurricanes, floods, tsunamis, tornadoes, wildfires, terrorist attacks, and pandemics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-benefit analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the recovery strategies under paragraph (1), the Assistant Secretary shall conduct cost-benefit analyses that take into account the health and economic effects of public health mitigation measures on the travel and tourism industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, subject to the availability of appropriations, shall produce an annual forecasting report on the travel and tourism industry, which shall include current and anticipated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab509f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic employment needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international inbound volume and spending, taking into account the lasting effects of the COVID–19 public health emergency and the impact of the recovery strategy implemented pursuant to subsection (e)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic volume and spending, including Federal and State public land travel and tourism data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Economic Analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Economic Analysis, subject to the availability of appropriations and to the extent feasible, should make quarterly updates to the Travel and Tourism Satellite Accounts, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab509fd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State-level travel and tourism spending data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509fe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel and tourism workforce data for full-time and part-time employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab509ff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State public lands outdoor recreational activity and tourism spending data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab50a00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Travel and Tourism Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Travel and Tourism Office—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7ab50a01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in partnership with the Bureau of Economic Analysis and other relevant Federal agencies, shall provide a monthly report on international arrival and spending data to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7ab50a02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Travel and Tourism Advisory Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7ab50a03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public through a publicly accessible website; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7ab50a04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9803/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include questions in the Survey of International Air Travelers regarding wait-times, visits to public lands, and State data, to the extent applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab50a05-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tVI/s605"},"text":"Pub. L. 117–328, div. BB, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5567"},"text":"136 Stat. 5567","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
