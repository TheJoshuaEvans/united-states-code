{"tag":"section","attrib":{"id":"id7a8a29bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8548"},"text":null,"children":[{"tag":"num","attrib":{"value":"8548"},"text":"§ 8548.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weather enterprise outreach","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8a29bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8548/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary may establish mechanisms for outreach to the weather enterprise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8a29bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8548/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the weather forecasts and forecast products provided by the National Oceanic and Atmospheric Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8a29be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8548/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the highest priority weather forecast needs of the community described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8a29bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8548/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting outreach under subsection (a), the Under Secretary shall contact leading expert