{"tag":"section","attrib":{"id":"id792457b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s686"},"text":null,"children":[{"tag":"num","attrib":{"value":"686"},"text":"§ 686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aggregate limitations on amount of assistance to any single enterprise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id792457b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s686/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage limitation on private capital","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any small business investment company has obtained financing from the Administrator and such financing remains outstanding, the aggregate amount of securities acquired and for which commitments may be issued by such company under the provisions of this subchapter for any single enterprise shall not, without the approval of the Administrator, exceed 10 percent of the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id792457b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s686/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private capital of such company; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id792457b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s686/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of leverage projected by the company in the company’s business plan that was approved by the Administrator at the time of the grant of the company’s license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s686/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/595/s2/f"},"text":"Pub. L. 92–595, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1316"},"text":"86 Stat. 1316","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id792457b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s686/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of provisions to commitments incurred prior to effective date of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to obligations or securities acquired prior to the effective date of the Small Business Investment Act Amendments of 1967, and with respect to legally binding commitments issued prior to such date, the provisions of this section as in effect immediately prior to such effective date shall continue to apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id792457ba-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s306"},"text":"Pub. L. 85–699, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/694"},"text":"72 Stat. 694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/341/s7/a"},"text":"Pub. L. 87–341, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-03"},"text":"Oct. 3, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/753"},"text":"75 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/273/s4"},"text":"Pub. L. 88–273, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-02-28"},"text":"Feb. 28, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/146"},"text":"78 Stat. 146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/104/tII/s207"},"text":"Pub. L. 90–104, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-10-11"},"text":"Oct. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/271"},"text":"81 Stat. 271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/595/s2/f"},"text":"Pub. L. 92–595, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1316"},"text":"86 Stat. 1316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/366/tIV/s408/a"},"text":"Pub. L. 102–366, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-04"},"text":"Sept. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1016"},"text":"106 Stat. 1016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tV/s505/b"},"text":"Pub. L. 111–5, div. A, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/156"},"text":"123 Stat. 156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id792457bb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id792457bc-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id792457bd-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of the Small Business Investment Act Amendments of 1967, referred to in subsec. (c), see Effective Date of 1967 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s681"},"text":"section 681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id792457be-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5"},"text":"Pub. L. 111–5","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “If any small business investment company has obtained financing from the Administration and such financing remains outstanding, the aggregate amount of obligations and securities acquired and for which commitments may be issued by such company under the provisions of this subchapter for any single enterprise shall not exceed 20 per centum of the private capital of such company, without the approval of the Administration.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/366"},"text":"Pub. L. 102–366","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Without the approval of the Administration, the aggregate amount of obligations and securities acquired and for which commitments may be issued by any small business investment company under the provisions of this chapter for any single enterprise shall not exceed 20 percent of the combined private paid-in capital and paid-in surplus of such company.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/595/s2/f/1"},"text":"Pub. L. 92–595, § 2(f)(1)","children":[],"tail":", substituted “combined private paid-in capital” for “combined paid-in capital”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/595/s2/f/2"},"text":"Pub. L. 92–595, § 2(f)(2)","children":[],"tail":", repealed subsec. (b) which enumerated the items making up the combined paid-in capital and paid-in surplus of companies licensed prior to "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/104"},"text":"Pub. L. 90–104","children":[],"tail":" substituted “paid-in capital and paid-in surplus of such company” for “capital and surplus of such small business investment company authorized by this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/104"},"text":"Pub. L. 90–104","children":[],"tail":" added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/273"},"text":"Pub. L. 88–273","children":[],"tail":" struck out the $500,000 limitation on amount of assistance to any single enterprise."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/341"},"text":"Pub. L. 87–341","children":[],"tail":" inserted “or (2) $500,000, whichever is the lesser”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id792457bf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id792457c0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/104"},"text":"Pub. L. 90–104","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"Jan. 1, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/104/s211"},"text":"section 211 of Pub. L. 90–104","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s681"},"text":"section 681 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id792457c1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1961 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/341/s7/b"},"text":"Pub. L. 87–341, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-03"},"text":"Oct. 3, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/753"},"text":"75 Stat. 753","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/341/s7/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply only with respect to obligations and securities acquired by a small business investment company on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1961-10-03"},"text":"Oct. 3, 1961","children":[],"tail":"]; except that such amendment shall not apply with respect to any obligations or securities so acquired pursuant to a commitment issued before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id792457c2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect of Small Business Equity Enhancement Act of 1992 on Securities Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/366"},"text":"Pub. L. 102–366","children":[],"tail":" to be construed to affect applicability of securities laws or to otherwise supersede or limit jurisdiction of Securities and Exchange Commission, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/366/s418"},"text":"section 418 of Pub. L. 102–366","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
