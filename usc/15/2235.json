{"tag":"section","attrib":{"id":"id79ea4083-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235"},"text":null,"children":[{"tag":"num","attrib":{"value":"2235"},"text":"§ 2235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79ea4084-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a major fire, the Administrator may send incident investigators, which may include safety specialists, fire protection engineers, codes and standards experts, researchers, and fire training specialists, to the site of the fire to conduct a fire safety investigation as described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4085-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fire safety investigation conducted under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ea4086-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted in coordination and cooperation with appropriate Federal, State, local, Tribal, and territorial authorities, including Federal agencies that are authorized to investigate any fire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4087-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall examine the previously determined cause and origin of the fire and assess broader systematic matters to include use of codes and standards, demographics, structural characteristics, smoke and fire dynamics (movement) during the event, and costs of associated injuries and deaths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4088-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ea4089-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), upon concluding any fire safety investigation under this section, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ea408a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a public report to the appropriate Federal, State, local, Tribal, and territorial authorities on the findings of such investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ea408b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with another investigating Federal, State, local, Tribal, or territorial agency on the report of that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea408c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator, in consultation with appropriate Federal, State, local, Tribal, and territorial authorities determines that issuing a report under paragraph (1) would have a negative impact on a potential or ongoing criminal investigation, the Administrator is not required to issue such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea408d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each public report issued under paragraph (1) shall include recommendations on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79ea408e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other buildings with similar characteristics that may bear similar fire risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ea408f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving tactical response to similar fires;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ea4090-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving civilian safety practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ea4091-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the costs and benefits to the community of adding fire safety features; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79ea4092-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to mitigate the causes of the fire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4093-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to a fire safety investigation conducted pursuant to subsection (a), provided doing so would not have a negative impact on a potential or ongoing criminal investigation, the Administrator may send fire investigators to conduct a fire safety investigation at the site of any fire with unusual or remarkable context that results in losses less severe than those occurring as a result of a major fire, in coordination and cooperation with the appropriate Federal, State, local, Tribal, and territorial authorities, including Federal agencies that are authorized to investigate the fire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4094-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ea4095-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect or otherwise diminish the authorities or the mandates vested in other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4096-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant the Administrator authority to investigate a major fire for the purpose of an enforcement action or criminal prosecution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ea4097-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Administrator to send investigators or issue a report for a major fire when the Administrator, in coordination and cooperation with the appropriate Federal, State, local, Tribal, and territorial authorities, determine that it may compromise a potential or ongoing criminal investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79ea4098-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2235/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major fire defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “major fire” shall have the meaning given such term under regulations to be issued by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ea4099-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498/s38"},"text":"Pub. L. 93–498, § 38","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/246/s2"},"text":"Pub. L. 117–246, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2345"},"text":"136 Stat. 2345","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
