{"tag":"section","attrib":{"id":"id789c89e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s290f"},"text":null,"children":[{"tag":"num","attrib":{"value":"290f"},"text":"§ 290f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this chapter, $1.86 million for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":". Notwithstanding the provisions of any other law, no appropriations for any fiscal year may be made for the purpose of this chapter after fiscal year 1969 unless previously authorized by legislation hereafter enacted by the Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id789c89ea-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/396/s7"},"text":"Pub. L. 90–396, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-11"},"text":"July 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/340"},"text":"82 Stat. 340","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
