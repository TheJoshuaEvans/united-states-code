{"tag":"section","attrib":{"id":"id79568b4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1056"},"text":null,"children":[{"tag":"num","attrib":{"value":"1056"},"text":"§ 1056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer of unregistrable matter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79568b50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compulsory and voluntary disclaimers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may require the applicant to disclaim an unregistrable component of a mark otherwise registrable. An applicant may voluntarily disclaim a component of a mark sought to be registered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79568b51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prejudice of rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No disclaimer, including those made under subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1057"},"text":"section 1057 of this title","children":[],"tail":", shall prejudice or affect the applicant’s or registrant’s rights then existing or thereafter arising in the disclaimed matter, or his right of registration on another application if the disclaimed matter be or shall have become distinctive of his goods or services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79568b52-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title I, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/60/429"},"text":"60 Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/772/s3"},"text":"Pub. L. 87–772, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-09"},"text":"Oct. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/769"},"text":"76 Stat. 769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/tI/s108"},"text":"Pub. L. 100–667, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3938"},"text":"102 Stat. 3938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7958d543-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7958d544-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7958d545-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “Director” for “Commissioner”."}]