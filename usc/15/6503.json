{"tag":"section","attrib":{"id":"id7a5a66d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503"},"text":null,"children":[{"tag":"num","attrib":{"value":"6503"},"text":"§ 6503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a5a66d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An operator may satisfy the requirements of regulations issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502/b"},"text":"section 6502(b) of this title","children":[],"tail":" by following a set of self-regulatory guidelines, issued by representatives of the marketing or online industries, or by other persons, approved under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a66d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a5a66d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-regulatory incentives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In prescribing regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502"},"text":"section 6502 of this title","children":[],"tail":", the Commission shall provide incentives for self-regulation by operators to implement the protections afforded children under the regulatory requirements described in subsection (b) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deemed compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such incentives shall include provisions for ensuring that a person will be deemed to be in compliance with the requirements of the regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502"},"text":"section 6502 of this title","children":[],"tail":" if that person complies with guidelines that, after notice and comment, are approved by the Commission upon making a determination that the guidelines meet the requirements of the regulations issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6502"},"text":"section 6502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a5a66da-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited response to requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall act upon requests for safe harbor treatment within 180 days of the filing of the request, and shall set forth in writing its conclusions with regard to such requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a5a66db-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Final action by the Commission on a request for approval of guidelines, or the failure to act within 180 days on a request for approval of guidelines, submitted under subsection (b) may be appealed to a district court of the United States of appropriate jurisdiction as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a5a66dc-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tXIII/s1304"},"text":"Pub. L. 105–277, div. C, title XIII, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-732"},"text":"112 Stat. 2681–732","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
