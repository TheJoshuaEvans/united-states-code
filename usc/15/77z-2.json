{"tag":"section","attrib":{"id":"id77e9b58b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"77z–2"},"text":"§ 77z–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of safe harbor for forward-looking statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e9b58c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall apply only to a forward-looking statement made by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e9b58d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an issuer that, at the time that the statement is made, is subject to the reporting requirements of section 78m(a) or section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b58e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting on behalf of such issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b58f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an outside reviewer retained by such issuer making a statement on behalf of such issuer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b590-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an underwriter, with respect to information provided by such issuer or information derived from information provided by the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b591-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent otherwise specifically provided by rule, regulation, or order of the Commission, this section shall not apply to a forward-looking statement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e9b592-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is made with respect to the business or operations of the issuer, if the issuer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e9b593-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the 3-year period preceding the date on which the statement was first made—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e9b594-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was convicted of any felony or misdemeanor described in clauses (i) through (iv) of section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(b)(4)(B) of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e9b595-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been made the subject of a judicial or administrative decree or order arising out of a governmental action that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77e9b596-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits future violations of the antifraud provisions of the securities laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e9b597-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires that the issuer cease and desist from violating the antifraud provisions of the securities laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e9b598-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the issuer violated the antifraud provisions of the securities laws;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b599-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the forward-looking statement in connection with an offering of securities by a blank check company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b59a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues penny stock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b59b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the forward-looking statement in connection with a rollup transaction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b59c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the forward-looking statement in connection with a going private transaction; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b59d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e9b59e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included in a financial statement prepared in accordance with generally accepted accounting principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b59f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contained in a registration statement of, or otherwise issued by, an investment company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5a0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in connection with a tender offer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5a1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in connection with an initial public offering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5a2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in connection with an offering by, or relating to the operations of, a partnership, limited liability company, or a direct participation investment program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5a3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made in a disclosure of beneficial ownership in a report required to be filed with the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/d"},"text":"section 78m(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5a4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe harbor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e9b5a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), in any private action arising under this subchapter that is based on an untrue statement of a material fact or omission of a material fact necessary to make the statement not misleading, a person referred to in subsection (a) shall not be liable with respect to any forward-looking statement, whether written or oral, if and to the extent that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e9b5a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the forward-looking statement is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e9b5a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified as a forward-looking statement, and is accompanied by meaningful cautionary statements identifying important factors that could cause actual results to differ materially from those in the forward-looking statement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e9b5a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immaterial; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5a9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the plaintiff fails to prove that the forward-looking statement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e9b5aa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if made by a natural person, was made with actual knowledge by that person that the statement was false or misleading; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e9b5ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if made by a business entity, was—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id77e9b5ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made by or with the approval of an executive officer of that entity, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id77e9b5ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made or approved by such officer with actual knowledge by that officer that the statement was false or misleading.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral forward-looking statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an oral forward-looking statement made by an issuer that is subject to the reporting requirements of section 78m(a) or section 78","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"(d) of this title, or by a person acting on behalf of such issuer, the requirement set forth in paragraph (1)(A) shall be deemed to be satisfied—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e9b5af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the oral forward-looking statement is accompanied by a cautionary statement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e9b5b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the particular oral statement is a forward-looking statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e9b5b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the actual results could differ materially from those projected in the forward-looking statement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77e9b5b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the oral forward-looking statement is accompanied by an oral statement that additional information concerning factors that could cause actual results to differ materially from those in the forward-looking statement is contained in a readily available written document, or portion thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e9b5b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accompanying oral statement referred to in clause (i) identifies the document, or portion thereof, that contains the additional information about those factors relating to the forward-looking statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77e9b5b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information contained in that written document is a cautionary statement that satisfies the standard established in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5b6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any document filed with the Commission or generally disseminated shall be deemed to be readily available for purposes of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5b7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other safe harbors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The exemption provided for in paragraph (1) shall be in addition to any exemption that the Commission may establish by rule or regulation under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5b8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall impose upon any person a duty to update a forward-looking statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5b9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositive motion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On any motion to dismiss based upon subsection (c)(1), the court shall consider any statement cited in the complaint and cautionary statement accompanying the forward-looking statement, which are not subject to material dispute, cited by the defendant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5ba-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay pending decision on motion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any private action arising under this subchapter, the court shall stay discovery (other than discovery that is specifically directed to the applicability of the exemption provided for in this section) during the pendency of any motion by a defendant for summary judgment that is based on the grounds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e9b5bb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statement or omission upon which the complaint is based is a forward-looking statement within the meaning of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5bc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exemption provided for in this section precludes a claim for relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5bd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the exemptions provided for in this section, the Commission may, by rule or regulation, provide exemptions from or under any provision of this subchapter, including with respect to liability that is based on a statement or that is based on projections or other forward-looking information, if and to the extent that any such exemption is consistent with the public interest and the protection of investors, as determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5be-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authority of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section limits, either expressly or by implication, the authority of the Commission to exercise similar authority or to adopt similar rules and regulations with respect to forward-looking statements under any other statute under which the Commission exercises rulemaking authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5bf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e9b5c0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forward-looking statement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “forward-looking statement” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77e9b5c1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement containing a projection of revenues, income (including income loss), earnings (including earnings loss) per share, capital expenditures, dividends, capital structure, or other financial items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5c2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the plans and objectives of management for future operations, including plans or objectives relating to the products or services of the issuer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5c3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of future economic performance, including any such statement contained in a discussion and analysis of financial condition by the management or in the results of operations included pursuant to the rules and regulations of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5c4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any statement of the assumptions underlying or relating to any statement described in subparagraph (A), (B), or (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5c5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any report issued by an outside reviewer retained by an issuer, to the extent that the report assesses a forward-looking statement made by the issuer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77e9b5c6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement containing a projection or estimate of such other items as may be specified by rule or regulation of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5c7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “investment company” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–3/a"},"text":"section 80a–3(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5c8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penny stock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “penny stock” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/51"},"text":"section 78c(a)(51) of this title","children":[],"tail":", and the rules and regulations, or orders issued pursuant to that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5c9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Going private transaction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “going private transaction” has the meaning given that term under the rules or regulations of the Commission issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m/e"},"text":"section 78m(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “securities laws” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5cb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person acting on behalf of an issuer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person acting on behalf of an issuer” means an officer, director, or employee of the issuer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77e9b5cc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2/i/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “blank check company”, “rollup transaction”, “partnership”, “limited liability company”, “executive officer of an entity” and “direct participation investment program”, have the meanings given those terms by rule or regulation of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77e9b5cd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 27A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/tI/s102/a"},"text":"Pub. L. 104–67, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/749"},"text":"109 Stat. 749","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/353/tIII/s301/a/5"},"text":"Pub. L. 105–353, title III, § 301(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3235"},"text":"112 Stat. 3235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s985/a/4"},"text":"Pub. L. 111–203, title IX, § 985(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1933"},"text":"124 Stat. 1933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77e9b5ce-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77e9b5cf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77e9b5d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted comma for semicolon after “entity” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/353"},"text":"Pub. L. 105–353","children":[],"tail":" made technical correction relating to placement of section in subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77e9b5d1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77e9b5d2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id77e9b5d3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not to affect or apply to any private action arising under this subchapter or title I of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.), commenced before and pending on "},{"tag":"date","attrib":{"date":"1995-12-22"},"text":"Dec. 22, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/s108"},"text":"section 108 of Pub. L. 104–67","children":[],"tail":", set out as an Effective Date of 1995 Amendment note under section 77"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id77e9b5d4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in section deemed to create or ratify any implied right of action, or to prevent Commission, by rule or regulation, from restricting or otherwise regulating private actions under Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/67/s203"},"text":"section 203 of Pub. L. 104–67","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78j–1"},"text":"section 78j–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
