{"tag":"section","attrib":{"id":"id7801833e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"78c–4"},"text":"§ 78c–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-based swap execution facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7801833f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78018340-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may operate a facility for the trading or processing of security-based swaps, unless the facility is registered as a security-based swap execution facility or as a national securities exchange under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018341-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dual registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that is registered as a security-based swap execution facility under this section shall register with the Commission regardless of whether the person also is registered with the Commodity Futures Trading Commission as a swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78018342-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trading and trade processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A security-based swap execution facility that is registered under subsection (a) may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78018343-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available for trading any security-based swap; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018344-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate trade processing of any security-based swap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78018345-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of facility used to trade security-based swaps by national securities exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A national securities exchange shall, to the extent that the exchange also operates a security-based swap execution facility and uses the same electronic trade execution system for listing and executing trades of security-based swaps on or through the exchange and the facility, identify whether electronic trading of such security-based swaps is taking place on or through the national securities exchange or the security-based swap execution facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id78018346-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core principles for security-based swap execution facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id78018347-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with core principles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78018348-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be registered, and maintain registration, as a security-based swap execution facility, the security-based swap execution facility shall comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018349-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the core principles described in this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7801834a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement that the Commission may impose by rule or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801834b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable discretion of security-based swap execution facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise determined by the Commission, by rule or regulation, a security-based swap execution facility described in subparagraph (A) shall have reasonable discretion in establishing the manner in which it complies with the core principles described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801834c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with rules","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A security-based swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7801834d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and enforce compliance with any rule established by such security-based swap execution facility, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7801834e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions of the security-based swaps traded or processed on or through the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7801834f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any limitation on access to the facility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018350-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and enforce trading, trade processing, and participation rules that will deter abuses and have the capacity to detect, investigate, and enforce those rules, including means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018351-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide market participants with impartial access to the market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78018352-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to capture information that may be used in establishing whether rule violations have occurred; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018353-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish rules governing the operation of the facility, including rules specifying trading procedures to be used in entering and executing orders traded or posted on the facility, including block trades.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018354-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-based swaps not readily susceptible to manipulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The security-based swap execution facility shall permit trading only in security-based swaps that are not readily susceptible to manipulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018355-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of trading and trade processing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The security-based swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78018356-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and enforce rules or terms and conditions defining, or specifications detailing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018357-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trading procedures to be used in entering and executing orders traded on or through the facilities of the security-based swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78018358-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for trade processing of security-based swaps on or through the facilities of the security-based swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018359-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor trading in security-based swaps to prevent manipulation, price distortion, and disruptions of the delivery or cash settlement process through surveillance, compliance, and disciplinary practices and procedures, including methods for conducting real-time monitoring of trading and comprehensive and accurate trade reconstructions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801835a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability to obtain information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The security-based swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7801835b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and enforce rules that will allow the facility to obtain any necessary information to perform any of the functions described in this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801835c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the information to the Commission on request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801835d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the capacity to carry out such international information-sharing agreements as the Commission may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801835e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial integrity of transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The security-based swap execution facility shall establish and enforce rules and procedures for ensuring the financial integrity of security-based swaps entered on or through the facilities of the security-based swap execution facility, including the clearance and settlement of security-based swaps pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c–3/a/1"},"text":"section 78c–3(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801835f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The security-based swap execution facility shall adopt rules to provide for the exercise of emergency authority, in consultation or cooperation with the Commission, as is necessary and appropriate, including the authority to liquidate or transfer open positions in any security-based swap or to suspend or curtail trading in a security-based swap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018360-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely publication of trading information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78018361-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The security-based swap execution facility shall make public timely information on price, trading volume, and other trading data on security-based swaps to the extent prescribed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018362-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity of security-based swap execution facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The security-based swap execution facility shall be required to have the capacity to electronically capture and transmit and disseminate trade information with respect to transactions executed on or through the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018363-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78018364-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A security-based swap execution facility shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018365-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain records of all activities relating to the business of the facility, including a complete audit trail, in a form and manner acceptable to the Commission for a period of 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78018366-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Commission, in a form and manner acceptable to the Commission, such information as the Commission determines to be necessary or appropriate for the Commission to perform the duties of the Commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018367-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall adopt data collection and reporting requirements for security-based swap execution facilities that are comparable to corresponding requirements for clearing agencies and security-based swap data repositories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018368-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless necessary or appropriate to achieve the purposes of this chapter, the security-based swap execution facility shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78018369-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt any rules or taking ","children":[{"tag":"ref","attrib":{"idref":"fn002041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “take”."}],"tail":" any actions that result in any unreasonable restraint of trade; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801836a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any material anticompetitive burden on trading or clearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801836b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The security-based swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7801836c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and enforce rules to minimize conflicts of interest in its decision-making process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801836d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for resolving the conflicts of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7801836e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial resources","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7801836f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The security-based swap execution facility shall have adequate financial, operational, and managerial resources to discharge each responsibility of the security-based swap execution facility, as determined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018370-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of resource adequacy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The financial resources of a security-based swap execution facility shall be considered to be adequate if the value of the financial resources—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018371-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables the organization to meet its financial obligations to its members and participants notwithstanding a default by the member or participant creating the largest financial exposure for that organization in extreme but plausible market conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78018372-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceeds the total amount that would enable the security-based swap execution facility to cover the operating costs of the security-based swap execution facility for a 1-year period, as calculated on a rolling basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id78018373-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" System safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The security-based swap execution facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id78018374-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and maintain a program of risk analysis and oversight to identify and minimize sources of operational risk, through the development of appropriate controls and procedures, and automated systems, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018375-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are reliable and secure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78018376-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have adequate scalable capacity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id78018377-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and maintain emergency procedures, backup facilities, and a plan for disaster recovery that allow for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id78018378-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely recovery and resumption of operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id78018379-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fulfillment of the responsibilities and obligations of the security-based swap execution facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7801837a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodically conduct tests to verify that the backup resources of the security-based swap execution facility are sufficient to ensure continued—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7801837b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order processing and trade matching;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7801837c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price reporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7801837d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" market surveillance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7801837e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/13/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of a comprehensive and accurate audit trail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7803f37f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of chief compliance officer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7803f380-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each security-based swap execution facility shall designate an individual to serve as a chief compliance officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7803f381-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief compliance officer shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7803f382-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the board or to the senior officer of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f383-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review compliance with the core principles in this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f384-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the board of the facility, a body performing a function similar to that of a board, or the senior officer of the facility, resolve any conflicts of interest that may arise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f385-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for establishing and administering the policies and procedures required to be established pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f386-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure compliance with this chapter and the rules and regulations issued under this chapter, including rules prescribed by the Commission pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f387-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish procedures for the remediation of noncompliance issues found during—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7803f388-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance office reviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7803f389-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" look backs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7803f38a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internal or external audit findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7803f38b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-reported errors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7803f38c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vi/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through validated complaints; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f38d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and follow appropriate procedures for the handling, management response, remediation, retesting, and closing of noncompliance issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7803f38e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7803f38f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with rules prescribed by the Commission, the chief compliance officer shall annually prepare and sign a report that contains a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7803f390-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compliance of the security-based swap execution facility with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7803f391-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies and procedures, including the code of ethics and conflict of interest policies, of the security-based security-based ","children":[{"tag":"ref","attrib":{"idref":"fn002042"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002042"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" swap execution facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7803f392-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief compliance officer shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7803f393-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit each report described in clause (i) with the appropriate financial report of the security-based swap execution facility that is required to be submitted to the Commission pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7803f394-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/d/14/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the report a certification that, under penalty of law, the report is accurate and complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803f395-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may exempt, conditionally or unconditionally, a security-based swap execution facility from registration under this section if the Commission finds that the facility is subject to comparable, comprehensive supervision and regulation on a consolidated basis by the Commodity Futures Trading Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7803f396-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s78c–4/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall prescribe rules governing the regulation of security-based swap execution facilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7803f397-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"June 6, 1934, ch. 404","children":[],"tail":", title I, § 3D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s763/c"},"text":"Pub. L. 111–203, title VII, § 763(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1769"},"text":"124 Stat. 1769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7803f398-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7803f399-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7803f39a-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(9)(A)(ii), (10), (14)(B)(v), (C)(i)(I), was in the original “this title”. See References in Text note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7803f39b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7803f39c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of 360 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle B (§§ 761–774) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle B, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s774"},"text":"section 774 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b"},"text":"section 77b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
