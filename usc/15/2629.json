{"tag":"section","attrib":{"id":"id7a0234dc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629"},"text":null,"children":[{"tag":"num","attrib":{"value":"2629"},"text":"§ 2629.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall prepare and submit to the President and the Congress on or before ","children":[{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":", and on or before January 1 of each succeeding year a comprehensive report on the administration of this chapter during the preceding fiscal year. Such reports shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a0234dd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the testing required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2603"},"text":"section 2603 of this title","children":[],"tail":" during the year for which the report is made and an estimate of the costs incurred during such year by the persons required to perform such tests;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0234de-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of notices received during such year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2604"},"text":"section 2604 of this title","children":[],"tail":", the number of such notices received during such year under such section for chemical substances subject to a section 2603 rule, order, or consent agreement, and a summary of any action taken during such year under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2604/g"},"text":"section 2604(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0234df-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of rules issued during such year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2605"},"text":"section 2605 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0234e0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list, with a brief statement of the issues, of completed or pending judicial actions under this chapter and administrative actions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2615"},"text":"section 2615 of this title","children":[],"tail":" during such year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0234e1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of major problems encountered in the administration of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a0234e2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2629/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such recommendations for additional legislation as the Administrator deems necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a0234e3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children"