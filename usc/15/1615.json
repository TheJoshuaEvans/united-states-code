{"tag":"section","attrib":{"id":"id798d5239-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615"},"text":null,"children":[{"tag":"num","attrib":{"value":"1615"},"text":"§ 1615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of “Rule of 78’s” in connection with mortgage refinancings and other consumer loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id798d523a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt refund of unearned interest required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798d523b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a consumer prepays in full the financed amount under any consumer credit transaction, the creditor shall promptly refund any unearned portion of the interest charge to the consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d523c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for refund of de minimus ","children":[{"tag":"ref","attrib":{"idref":"fn002335"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002335"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “de minimis”."}],"tail":" amount"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No refund shall be required under paragraph (1) with respect to the prepayment of any consumer credit transaction if the total amount of the refund would be less than $1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d523d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to refinanced transactions and acceleration by the creditor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply with respect to any prepayment of a consumer credit transaction described in paragraph (1) without regard to the manner or the reason for the prepayment, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798d523e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any prepayment made in connection with the refinancing, consolidation, or restructuring of the transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d523f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any prepayment made as a result of the acceleration of the obligation to repay the amount due with respect to the transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d5240-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of “Rule of 78’s” prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of calculating any refund of interest required under subsection (a) for any precomputed consumer credit transaction of a term exceeding 61 months which is consummated after ","children":[{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":", the creditor shall compute the refund based on a method which is at least as favorable to the consumer as the actuarial method."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d5241-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of prepayment amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798d5242-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the end of the 5-day period beginning on the date an oral or written request is received by a creditor from a consumer for the disclosure of the amount due on any precomputed consumer credit account, the creditor or assignee shall provide the consumer with a statement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798d5243-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount necessary to prepay the account in full; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d5244-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the amount disclosed pursuant to subparagraph (A) includes an amount which is required to be refunded under this section with respect to such prepayment, the amount of such refund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5245-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written statement required if request is in writing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the customer’s request is in writing, the statement under paragraph (1) shall be in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5246-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1 free annual statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A consumer shall be entitled to obtain 1 statement under paragraph (1) each year without charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d5247-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional statements subject to reasonable fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any creditor may impose a reasonable fee to cover the cost of providing any statement under paragraph (1) to any consumer in addition to the 1 free annual statement required under paragraph (3) if the amount of the charge for such additional statement is disclosed to the consumer before furnishing such statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id798d5248-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id798d5249-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actuarial method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “actuarial method” means the method of allocating payments made on a debt between the amount financed and the finance charge pursuant to which a payment is applied first to the accumulated finance charge and any remainder is subtracted from, or any deficiency is added to, the unpaid balance of the amount financed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d524a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer, credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “consumer” and “creditor” have the meanings given to such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id798d524b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creditor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “creditor”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id798d524c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id798d524d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1615/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any assignee of any creditor with respect to credit extended in connection with any consumer credit transaction and any subsequent assignee with respect to such credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id798d524e-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tIX/s933"},"text":"Pub. L. 102–550, title IX, § 933","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3891"},"text":"106 Stat. 3891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id798d524f-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id798d5250-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id798d5251-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Community Development Act of 1992, and not as part of the Consumer Credit Protection Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
