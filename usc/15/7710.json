{"tag":"section","attrib":{"id":"id7a7e1b11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710"},"text":null,"children":[{"tag":"num","attrib":{"value":"7710"},"text":"§ 7710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving enforcement by providing rewards for information about violations; labeling","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall transmit to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Energy and Commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a7e1b12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a report, within 9 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"December 16, 2003","children":[],"tail":", that sets forth a system for rewarding those who supply information about violations of this chapter, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a7e1b13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures for the Commission to grant a reward of not less than 20 percent of the total civil penalty collected for a violation of this chapter to the first person that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a7e1b14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the person in violation of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a7e1b15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies information that leads to the successful collection of a civil penalty by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a7e1b16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to minimize the burden of submitting a complaint to the Commission concerning violations of this chapter, including procedures to allow the electronic submission of complaints to the Commission; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a7e1b17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7710/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report, within 18 months after ","children":[{"tag":"date","attrib":{"date":"2003-12-16"},"text":"December 16, 2003","children":[],"tail":", that sets forth a plan for requiring commercial electronic mail to be identifiable from its subject line, by means of compliance with Internet Engineering Task Force Standards, the use of the characters “ADV” in the subject line, or other comparable identifier, or an explanation of any concerns the Commission has that cause the Commission to recommend against the plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a7e1b18-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/187/s11"},"text":"Pub. L. 108–187, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-16"},"text":"Dec. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2717"},"t