{"tag":"section","attrib":{"id":"id79a065ef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1667e"},"text":"§ 1667e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of State laws; exemptions by Bureau from leasing requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79a065f0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This part does not annul, alter, or affect, or exempt any person subject to the provisions of this part from complying with, the laws of any State with respect to consumer leases, except to the extent that those laws are inconsistent with any provision of this part, and then only to the extent of the inconsistency. The Bureau is authorized to determine whether such inconsistencies exist. The Bureau may not determine that any State law is inconsistent with any provision of this part if the Bureau determines that such law gives greater protection and benefit to the consumer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79a065f1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1667e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau shall by regulation exempt from the requirements of this part any class of lease transactions within any State if it determines that under the law of that State that class of transactions is subject to requirements substantially similar to those imposed under this part or that such law gives greater protection and benefit to the consumer, and that there is adequate provision for enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79a065f2-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s186"},"text":"Pub. L. 90–321, title I, § 186","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/240/s3"},"text":"Pub. L. 94–240, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-03-23"},"text":"Mar. 23, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/260"},"text":"90 Stat. 260","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1100A/2"},"text":"Pub. L. 111–203, title X, § 1100A(2)","children":[],"tail":", (10), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2107"},"text":"124 Stat. 2107","children":[],"tail":", 2109.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79a065f3-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79a065f4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79a065f5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100A/2"},"text":"Pub. L. 111–203, § 1100A(2)","children":[],"tail":", (10), substituted “Bureau” for “Board”, “the Bureau” for “the Board”, and “The Bureau” for “The Board” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79a065f6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79a065f7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
