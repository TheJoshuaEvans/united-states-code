{"tag":"section","attrib":{"id":"id7a1c7322-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3411"},"text":null,"children":[{"tag":"num","attrib":{"value":"3411"},"text":"§ 3411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rulemaking authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a1c7323-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where expressly provided otherwise, the Commission shall administer this chapter. The Commission, or any other Federal officer or agency in which any function under this chapter is vested or delegated, is authorized to perform any and all acts (including any appropriate enforcement activity), and to prescribe, issue, amend, and rescind such rules and orders as it may find necessary or appropriate to carry out its functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a1c7324-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to define terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except where otherwise expressly provided, the Commission is authorized to define, by rule, accounting, technical, and trade terms used in this chapter. Any such definition shall be consistent with the definitions set forth in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a1c7325-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/621/tV/s501"},"text":"Pub. L. 95–621, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3396"},"text":"92 Stat. 3396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b/4"},"text":"Pub. L. 101–60, § 3(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-07-26"},"text":"July 26, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/159"},"text":"103 Stat. 159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a1c7326-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a1c7327-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a1c7328-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60"},"text":"Pub. L. 101–60","children":[],"tail":" struck out subsec. (c) which authorized Commission to delegate to any State agency (with consent of such agency) any of its functions with respect to sections 3315, 3316(b), and 3319(a)(1) and (3) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a1c7329-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7a1c732a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/60"},"text":"Pub. L. 101–60","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/60/s3/b"},"text":"section 3(b) of Pub. L. 101–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3372"},"text":"section 3372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
