{"tag":"section","attrib":{"id":"id79410865-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719"},"text":null,"children":[{"tag":"num","attrib":{"value":"719"},"text":"§ 719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79410866-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural gas supply shortage exists in the contiguous States of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410867-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" large reserves of natural gas in the State of Alaska could help significantly to alleviate this supply shortage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410868-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expeditious construction of a viable natural gas transportation system for delivery of Alaska natural gas to United States markets is in the national interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79410869-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s719/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determinations whether to authorize a transportation system for delivery of Alaska natural gas to the contiguous States and, if so, which system to select, involve questions of the utmost importance respecting national energy policy, international relations, national security, and economic and environmental impact, and therefore should appropriately be addressed by the Congress and the President in addition to those Federal officers and agencies assigned functions under law pertaining to the selection, construction, and initial operation of such a system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7941086a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s2"},"text":"Pub. L. 94–586, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2903"},"text":"90 Stat. 2903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7941086b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7941086c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7941086d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expiration Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s20"},"text":"Pub. L. 94–586, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2916"},"text":"90 Stat. 2916","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/586/s20"},"text":"“This Act [this chapter] shall terminate in the event that no decision of the President takes effect under section 8 of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s719f"},"text":"section 719f of this title","children":[],"tail":"], such termination to occur at the end of the last day on which a decision could be, but is not, approved under such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7941086e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s1"},"text":"Pub. L. 94–586, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2903"},"text":"90 Stat. 2903","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/586/s1"},"text":"“This Act [enacting this chapter and provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1651"},"text":"section 1651 of Title 43","children":[],"tail":", Public Lands] may be cited as the ‘Alaska Natural Gas Transportation Act of 1976’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7941086f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Antitrust Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/586/s19"},"text":"Pub. L. 94–586, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2916"},"text":"90 Stat. 2916","children":[],"tail":", directed Attorney General of United States to conduct a thorough study of antitrust issues and problems relating to production and transportation of Alaska natural gas and, not later than six months after "},{"tag":"date","attrib":{"date":"1976-10-22"},"text":"Oct. 22, 1976","children":[],"tail":", to complete such study and submit to Congress a report containing his findings and recommendations with respect thereto."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
