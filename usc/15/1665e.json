{"tag":"section","attrib":{"id":"id799df506-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1665e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1665e"},"text":"§ 1665e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of ability to repay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A card issuer may not open any credit card account for any consumer under an open end consumer credit plan, or increase any credit limit applicable to such account, unless the card issuer considers the ability of the consumer to make the required payments under the terms of such account.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id799df507-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tI/s150"},"text":"Pub. L. 90–321, title I, § 150","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/tI/s109/a"},"text":"Pub. L. 111–24, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1743"},"text":"123 Stat. 1743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id799df508-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id799df509-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id799df50a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/24/s3"},"text":"section 3 of Pub. L. 111–24","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
