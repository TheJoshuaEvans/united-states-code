{"tag":"section","attrib":{"id":"id788495cf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s183"},"text":null,"children":[{"tag":"num","attrib":{"value":"183"},"text":"§ 183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of statistics","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall make a report to Congress on the first Monday of January in each year, containing the results of the information collected during the preceding year, by the Bureau of Foreign and Domestic Commerce, upon the condition of the manufactures, domestic trade, currency, and banks of the several States and Territories.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788495d0-552d-11f1-9071-ff305b7c3ff0"},"text":"(R.S. § 259; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1877-02-27/ch69/s1"},"text":"Feb. 27, 1877, ch. 69, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/19/241"},"text":"19 Stat. 241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s9"},"text":"Feb. 14, 1903, ch. 552, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/407"},"text":"37 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788495d1-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788495d2-552d-11f1-907