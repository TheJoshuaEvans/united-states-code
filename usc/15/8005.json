{"tag":"section","attrib":{"id":"id7a808c1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005"},"text":null,"children":[{"tag":"num","attrib":{"value":"8005"},"text":"§ 8005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum State law requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a808c20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State meets the minimum State law requirements of this section if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State requires by statute—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a808c23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the enclosure of all outdoor residential pools and spas by barriers to entry that will effectively prevent small children from gaining unsupervised and unfettered access to the pool or spa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a808c24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that pools and spas built more than 1 year after the date of the enactment of such statute have—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7a808c25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 1 drain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a808c26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more unblockable drains; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7a808c27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no main drain; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State meets such additional State law requirements for pools and spas as the Commission may establish after public notice and a 30-day public comment period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of minimum State law requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use the minimum State law requirements under paragraph (1) solely for the purpose of determining the eligibility of a covered entity for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8004"},"text":"section 8004 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not enforce any requirement under paragraph (1) except for the purpose of determining the eligibility of a covered entity for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8004"},"text":"section 8004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements to reflect national performance standards and Commission guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing minimum State law requirements under paragraph (1)(B), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider current or revised national performance standards on pool and spa barrier protection and entrapment prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any such requirements are consistent with the guidelines contained in the Commission’s publication 362, entitled “Safety Barrier Guidelines for Home Pools”, the Commission’s publication entitled “Guidelines for Entrapment Hazards: Making Pools and Spas Safer”, and any other pool safety guidelines established by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prevents the Commission from promulgating standards regulating pool and spa safety or from relying on an applicable national performance standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic access-related safety devices and equipment requirements to be considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing minimum State law requirements for swimming pools and spas under subsection (a)(1), the Commission shall consider the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A safety pool cover.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A gate with direct access to the swimming pool or spa that is equipped with a self-closing, self-latching device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Doors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any door with direct access to the swimming pool or spa that is equipped with an audible alert device or alarm which sounds when the door is opened.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pool alarm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A device designed to provide rapid detection of an entry into the water of a swimming pool or spa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrapment, entanglement, and evisceration prevention standards to be required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a808c36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing additional minimum State law requirements for swimming pools and spas under subsection (a)(1), the Commission shall require, at a minimum, 1 or more of the following (except for pools constructed without a single main drain):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a808c37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety vacuum release system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A safety vacuum release system which ceases operation of the pump, reverses the circulation flow, or otherwise provides a vacuum release at a suction outlet when a blockage is detected, that has been tested by an independent third party and found to conform to ASME/ANSI standard A112.19.17 or ASTM standard F2387, or any successor standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suction-limiting vent system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A suction-limiting vent system with a tamper-resistant atmospheric opening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gravity drainage system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A gravity drainage system that utilizes a collector tank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic pump shut-off system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An automatic pump shut-off system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drain disablement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A device or system that disables the drain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a808c3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any other system determined by the Commission to be equally effective as, or better than, the systems described in subparagraphs (A) through (E) of this paragraph at preventing or eliminating the risk of injury or death associated with pool drainage systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a808c3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any device or system described in subparagraphs (B) through (E) of paragraph (1) shall meet the requirements of any ASME/ANSI or ASTM performance standard if there is such a standard for such a device or system, or any applicable consumer product safety standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a808c3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8005/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “State” includes an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a808c3f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXIV/s1406"},"text":"Pub. L. 110–140, title XIV, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1797"},"text":"121 Stat. 1797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dE/tV/s501/2"},"text":"Pub. L. 113–76, div. E, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/209"},"text":"128 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dBB/tIV/s402/b"},"text":"Pub. L. 117–328, div. BB, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5563"},"text":"136 Stat. 5563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a808c40-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a808c41-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a808c42-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s402/b/1"},"text":"Pub. L. 117–328, § 402(b)(1)","children":[],"tail":", substituted “the eligibility of a covered entity” for “the eligibility of a State” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s402/b/2"},"text":"Pub. L. 117–328, § 402(b)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/s501/2/A"},"text":"Pub. L. 113–76, § 501(2)(A)","children":[],"tail":", inserted “and” at end of cl. (i), redesignated cl. (iii) as (ii) and inserted “and” at end, and struck out former cl. (ii) and cls. (iv) and (v) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) that all pools and spas be equipped with devices and systems designed to prevent entrapment by pool or spa drains;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) every swimming pool and spa that has a main drain, other than an unblockable drain, be equipped with a drain cover that meets the consumer product safety standard established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8003"},"text":"section 8003 of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(v) that periodic notification is provided to owners of residential swimming pools or spas about compliance with the entrapment protection standards of the ASME/ANSI A112.19.8 performance standard, or any successor standard; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/s501/2/B"},"text":"Pub. L. 113–76, § 501(2)(B)","children":[],"tail":", (C), redesignated pars. (3) and (4) as (2) and (3), respectively, substituted “paragraph (1)(B)” for “paragraph (1)” in introductory provisions of par. (3), and struck out former par. (2) which read as follows: “The minimum State law notification requirement under paragraph (1)(A)(v) shall not be construed to imply any liability on the part of a State related to that requirement.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a808c43-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a808c44-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
