{"tag":"section","attrib":{"id":"id7a285a3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713"},"text":null,"children":[{"tag":"num","attrib":{"value":"3713"},"text":"§ 3713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a285a40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a285a41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated to the Secretary for the purposes of carrying out sections 3710(g) and 3711 of this title not to exceed $3,400,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a285a42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amount authorized under paragraph (1) of this subsection, $2,400,000 is authorized only for the Office of Productivity, Technology, and Innovation; and $500,000 is authorized only for the patent licensing activities of the National Technical Information Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a285a43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the authorization of appropriations provided under subsection (a) of this section, there is authorized to be appropriated to the Secretary for the purposes of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3704a"},"text":"section 3704a of this title","children":[],"tail":" not to exceed $500,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":", $1,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"September 30, 1989","children":[],"tail":", and $1,500,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a285a44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such sums as may be appropriated under subsections (a) and (b) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a285a45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enable the National Science Foundation to carry out its powers and duties under this chapter only such sums may be appropriated as the Congress may authorize by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a285a46-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480/s21"},"text":"Pub. L. 96–480, § 21","children":[],"tail":", formerly § 14, "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2320"},"text":"94 Stat. 2320","children":[],"tail":"; renumbered § 18, "},{"tag":"ref