{"tag":"section","attrib":{"id":"id77cabaf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56"},"text":null,"children":[{"tag":"num","attrib":{"value":"56"},"text":"§ 56.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement, defense, intervention and supervision of litigation and appeal by Commission or Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77cabaf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for exercise of authority to litigate or appeal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cabaf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in paragraph (2) or (3), if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77cabaf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before commencing, defending, or intervening in, any civil action involving this subchapter (including an action to collect a civil penalty) which the Commission, or the Attorney General on behalf of the Commission, is authorized to commence, defend, or intervene in, the Commission gives written notification and undertakes to consult with the Attorney General with respect to such action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabaf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General fails within 45 days after receipt of such notification to commence, defend, or intervene in, such action;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commission may commence, defend, or intervene in, and supervise the litigation of, such action and any appeal of such action in its own name by any of its attorneys designated by it for such purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabafa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in paragraph (3), in any civil action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77cabafb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s53"},"text":"section 53 of this title","children":[],"tail":" (relating to injunctive relief);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabafc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57b"},"text":"section 57b of this title","children":[],"tail":" (relating to consumer redress);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabafd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain judicial review of a rule prescribed by the Commission, or a cease and desist order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45"},"text":"section 45 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabafe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the second paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s49"},"text":"section 49 of this title","children":[],"tail":" (relating to enforcement of a subpena) and under the fourth paragraph of such section (relating to compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s46"},"text":"section 46 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabaff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s57b–2a"},"text":"section 57b–2a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Commission shall have exclusive authority to commence or defend, and supervise the litigation of, such action and any appeal of such action in its own name by any of its attorneys designated by it for such purpose, unless the Commission authorizes the Attorney General to do so. The Commission shall inform the Attorney General of the exercise of such authority and such exercise shall not preclude the Attorney General from intervening on behalf of the United States in such action and any appeal of such action as may be otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabb00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77cabb01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Commission makes a written request to the Attorney General, within the 10-day period which begins on the date of the entry of the judgment in any civil action in which the Commission represented itself pursuant to paragraph (1) or (2), to represent itself through any of its attorneys designated by it for such purpose before the Supreme Court in such action, it may do so, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id77cabb02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General concurs with such request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id77cabb03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General, within the 60-day period which begins on the date of the entry of such judgment—","children":[],"tail":null},{"tag":"level","attrib":{"id":"id77cabb04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/A/ii/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses to appeal or file a petition for writ of certiorari with respect to such civil action, in which case he shall give written notification to the Commission of the reasons for such refusal within such 60-day period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"id77cabb05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/A/ii/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General fails to take any action with respect to the Commission’s request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabb06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the Attorney General represents the Commission before the Supreme Court in any civil action in which the Commission represented itself pursuant to paragraph (1) or (2), the Attorney General may not agree to any settlement, compromise, or dismissal of such action, or confess error in the Supreme Court with respect to such action, unless the Commission concurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77cabb07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph (with respect to representation before the Supreme Court), the term “Attorney General” includes the Solicitor General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabb08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, prior to the expiration of the 45-day period specified in paragraph (1) of this section or a 60-day period specified in paragraph (3), any right of the Commission to commence, defend, or intervene in, any such action or appeal may be extinguished due to any procedural requirement of any court with respect to the time in which any pleadings, notice of appeal, or other acts pertaining to such action or appeal may be taken, the Attorney General shall have one-half of the time required to comply with any such procedural requirement of the court (including any extension of such time granted by the court) for the purpose of commencing, defending, or intervening in the civil action pursuant to paragraph (1) or for the purpose of refusing to appeal or file a petition for writ of certiorari and the written notification or failing to take any action pursuant to paragraph 3(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabb09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this subsection shall apply notwithstanding chapter 31 of title 28, or any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cabb0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by Commission to Attorney General for criminal proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Commission has reason to believe that any person, partnership, or corporation is liable for a criminal penalty under this subchapter, the Commission shall certify the facts to the Attorney General, whose duty it shall be to cause appropriate criminal proceedings to be brought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77cabb0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign litigation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77cabb0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission attorneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the concurrence of the Attorney General, the Commission may designate Commission attorneys to assist the Attorney General in connection with litigation in foreign courts on particular matters in which the Commission has an interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabb0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for foreign counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission is authorized to expend appropriated funds, upon agreement with the Attorney General, to reimburse the Attorney General for the retention of foreign counsel for litigation in foreign courts and for expenses related to litigation in foreign courts in which the Commission has an interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabb0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection authorizes the payment of claims or judgments from any source other than the permanent and indefinite appropriation authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77cabb0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s56/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by this subsection is in addition to any other authority of the Commission or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77cabb10-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s16"},"text":"Sept. 26, 1914, ch. 311, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1938-03-21/ch49/s4"},"text":"Mar. 21, 1938, ch. 49, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/114"},"text":"52 Stat. 114","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/153/tIV/s408/g"},"text":"Pub. L. 93–153, title IV, § 408(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/592"},"text":"87 Stat. 592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/637/tII/s204/a"},"text":"Pub. L. 93–637, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2199"},"text":"88 Stat. 2199","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/455"},"text":"Pub. L. 109–455","children":[],"tail":", §§ 5, 7(b), 13, "},{"tag":"date","attrib":{"date":"2006-12-22"},"text":"Dec. 22, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3375"},"text":"120 Stat. 3375","children":[],"tail":", 3379, 3382; "},{"tag":"ref","attrib":{"href":"/us/pl/112/203/s1"},"text":"Pub. L. 112–203, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-04"},"text":"Dec. 4, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1484"},"text":"126 Stat. 1484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77cabb11-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id77cabb12-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":", see Termination Date of 2006 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77cabb13-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id77cabb14-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/203/s1"},"text":"Pub. L. 112–203, § 1","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"Pub. L. 109–455, § 13","children":[],"tail":". See 2006 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455/s7/b"},"text":"Pub. L. 109–455, § 7(b)","children":[],"tail":", which added subpar. (E) reading “under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57b–2a"},"text":"section 57b–2a of this title","children":[],"tail":";”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"Pub. L. 109–455, § 13","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/203/s1"},"text":"Pub. L. 112–203, § 1","children":[],"tail":". See Termination Date of 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455/s5"},"text":"Pub. L. 109–455, § 5","children":[],"tail":", which added subsec. (c) relating to attorneys used and money expended for foreign litigation, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"Pub. L. 109–455, § 13","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/203/s1"},"text":"Pub. L. 112–203, § 1","children":[],"tail":". See Termination Date of 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/637"},"text":"Pub. L. 93–637","children":[],"tail":" substituted provisions authorizing the Commission at its election to appear in court by its own name and designate its attorneys for such purpose, for provisions relating to the certification of facts by the Commission to the Attorney General who brought the appropriate proceedings, or, after compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/m"},"text":"section 45(m) of this title","children":[],"tail":", itself brought the appropriate proceedings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/153"},"text":"Pub. L. 93–153","children":[],"tail":" inserted provisions authorizing the Federal Trade Commission to itself cause appropriate proceedings to be brought after compliance with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/m"},"text":"section 45(m) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77cabb15-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id77cabb16-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 5 and 7(b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/455"},"text":"Pub. L. 109–455","children":[],"tail":" repealed effective "},{"tag":"date","attrib":{"date":"2027-09-30"},"text":"Sept. 30, 2027","children":[],"tail":", and provisions amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/455"},"text":"Pub. L. 109–455","children":[],"tail":" to be amended to read as if "},{"tag":"ref","attrib":{"href":"/us/pl/109/455"},"text":"Pub. L. 109–455","children":[],"tail":" had not been enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/455/s13"},"text":"section 13 of Pub. L. 109–455","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s44"},"text":"section 44 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id77cabb17-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/637/tII/s204/c"},"text":"Pub. L. 93–637, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2200"},"text":"88 Stat. 2200","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/637/tII/s204/c"},"text":"“The amendment and repeal made by this section [amending this section and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s45/m"},"text":"section 45(m) of this title","children":[],"tail":"] shall not apply to any civil action commenced before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id77cabb18-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id77cabb19-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Federal Trade Commission, with certain exceptions, to Chairman of such Commission, see Reorg. Plan No. 8 of 1950, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", 15 F.R. 3175, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1264"},"text":"64 Stat. 1264","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
