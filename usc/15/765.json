{"tag":"section","attrib":{"id":"id794aa48d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765"},"text":null,"children":[{"tag":"num","attrib":{"value":"765"},"text":"§ 765.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794aa48e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Secretary and Department of the Interior","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are hereby transferred to and vested in the Administrator all functions of the Secretary of the Interior, the Department of the Interior, and officers and components of that Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794aa48f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as relate to or are utilized by the Office of Petroleum Allocation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794aa490-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as relate to or are utilized by the Office of Energy Conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794aa491-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as relate to or are utilized by the Office of Energy Data and Analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794aa492-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as relate to or are utilized by the Office of Oil and Gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794aa493-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s765/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Chairman and Executive Director of Cost of Living Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are hereby transferred to and vested in the Administrator all functions of the Chairman of the Cost of Living Council, the Executive Director of the Cost of Living Council, and the Cost of Living Council, and officers and components thereof, as relate to or are utilized by the Energy Division of the Cost of Living Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794aa494-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s6"},"text":"Pub. L. 93–275, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-07"},"text":"May 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/100"},"text":"88 Stat. 100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794aa495-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794aa496-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794aa497-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Energy Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id794aa498-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id794aa499-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Cost of Living Council","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Cost of Living Council abolished ","children":[{"tag":"date","attrib":{"date":"1974-07-01"},"text":"July 1, 1974","children":[],"tail":", by Ex. Ord. No. 11788, § 1, "},{"tag":"date","attrib":{"date":"1974-06-18"},"text":"June 18, 1974","children":[],"tail":", 39 F.R. 22113."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
