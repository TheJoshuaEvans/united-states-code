{"tag":"section","attrib":{"id":"id7884956e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s162"},"text":null,"children":[{"tag":"num","attrib":{"value":"162"},"text":"§ 162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of China corporations restricted","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No corporation for the purpose of engaging in business within China shall be created under any law of the United States other than this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7884956f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch346/s29"},"text":"Sept. 19, 1922, ch. 346, § 29","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-26/ch345/s13"},"text":"Feb. 26, 1925, ch. 345, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/997"},"text":"43 Stat. 997","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
