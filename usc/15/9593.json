{"tag":"section","attrib":{"id":"id7ab29986-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593"},"text":null,"children":[{"tag":"num","attrib":{"value":"9593"},"text":"§ 9593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab29987-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of assistance under this chapter shall keep such records as the Under Secretary shall prescribe, including records that fully disclose, with respect to the assistance received by the recipient under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab29988-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and nature of that assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab29989-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition by the recipient of the proceeds of that assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2998a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the undertaking for which the assistance is given or used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2998b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and nature of the portion of the cost of the undertaking described in paragraph (3) that is supplied by a source other than the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2998c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return on investment, as defined by the Under Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab2998d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other record that will facilitate an effective audit with respect to the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab2998e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access by government officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary, the Inspector General of the Department of Commerce, and the Comptroller General of the United States, or any duly authorized representative of any such individual, shall have access, for the purpose of audit, investigation, and examination, to any book, document, paper, record, or other material of the Agency or an MBDA Business Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab2998f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tVII/s100703"},"text":"Pub. L. 117–58, div. K, title VII, § 100703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1466"},"text":"135 Stat. 1466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7ab29990-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7ab29991-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7ab29992-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this division”, meaning div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1445"},"text":"135 Stat. 1445","children":[],"tail":", which is classified principally to this chapter. For complete classification of division K to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s9501"},"text":"section 9501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
