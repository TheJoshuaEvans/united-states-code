{"tag":"section","attrib":{"id":"id7a7bd1ce-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s7605"},"text":null,"children":[{"tag":"num","attrib":{"value":"7605"},"text":"§ 7605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of advertisements and other representations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person that engages in the manufacture, processing, assembly, sale, offering for sale, or distribution of contact lenses may not represent, by advertisement, sales presentation, or otherwise, that contact lenses may be obtained without a prescription.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a7bd1cf-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/164/s6"},"text":"Pub. L. 108–164, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2026"},"text":"117 Stat. 2026","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a7bd1d0-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a7bd1d1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a7bd1d2-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/164/s12"},"text":"section 12 of Pub. L. 108–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7601"},"text":"section 7601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
