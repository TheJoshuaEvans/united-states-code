{"tag":"section","attrib":{"id":"id79862681-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1543"},"text":null,"children":[{"tag":"num","attrib":{"value":"1543"},"text":"§ 1543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force on job repatriation and manufacturing growth","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall maintain a task force on job repatriation and manufacturing growth and shall produce an annual report on related incentive strategies, implementation plans and program results.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79862682-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dB/tI"},"text":"Pub. L. 113–235, div. B, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2180"},"text":"128 Stat. 2180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79862683-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79862684-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id79862685-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the appropriation act cited as the credit to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79862686-552d-11f1-9071-ff305b7c3ff0"},"text":null,"childre