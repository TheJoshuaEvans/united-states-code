{"tag":"section","attrib":{"id":"id78a144ca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s327"},"text":null,"children":[{"tag":"num","attrib":{"value":"327"},"text":"§ 327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees for conduct of meteorological investigations in Arctic region; appointment and compensation; extra compensation to other Government employees for taking observations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is authorized to (a) appoint employees for the conduct of meteorological investigations in the Arctic region without regard to the civil service laws and fix their compensation without regard to chapter 51 and subchapter III of chapter 53 of title 5, and sections 5542, 5543, 5545, and 5546 of title 5, at base rates not to exceed the maximum scheduled rate for GS–12, and (b) grant extra compensation to employees of other Government agencies for taking and transmitting meteorological observations without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5533"},"text":"section 5533 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78a144cb-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-02/ch373/s3"},"text":"June 2, 1948, ch. 373, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/286"},"text":"62 Stat. 286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/397/s2"},"text":"Pub. L. 86–397, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-03-28"},"text":"Mar. 28, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/11"},"text":"74 Stat. 11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/448/tIV/s401/m"},"text":"Pub. L. 88–448, title IV, § 401(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-19"},"text":"Aug. 19, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/491"},"text":"78 Stat. 491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78a144cc-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78a144cd-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id78a144ce-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, “chapter 51 and subchapter III of chapter 53 of title 5”, “sections 5542, 5543, 5545, and 5546 of title 5”, and “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5533"},"text":"section 5533 of title 5","children":[],"tail":"” substituted for “the Classification Act of 1949, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1071"},"text":"5 U.S.C. 1071","children":[],"tail":" and the following)”, “titles II and III of the Federal Employees Pay Act of 1945, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s911"},"text":"5 U.S.C. 911","children":[],"tail":" and the following)”, and “section 301 of the Dual Compensation Act”, respectively, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78a144cf-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/448"},"text":"Pub. L. 88–448","children":[],"tail":" inserted “without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5533"},"text":"section 5533 of title 5","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/397"},"text":"Pub. L. 86–397","children":[],"tail":" substituted “Secretary of Commerce” for “Weather Bureau”, authorized the Secretary to fix the compensation of the employees, and limited the base rates to not more than the maximum scheduled rate for GS–12."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78a144d0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id78a144d1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/448"},"text":"Pub. L. 88–448","children":[],"tail":" effective on first day of first month which begins later than ninetieth day following "},{"tag":"date","attrib":{"date":"1964-08-19"},"text":"Aug. 19, 1964","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/448/s403"},"text":"section 403 of Pub. L. 88–448","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
