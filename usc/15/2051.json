usc/t15/s2056c"},"text":"section 2056c of this title","children":[],"tail":" and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2056c"},"text":"section 2056c of this title","children":[],"tail":"] may be cited as the ‘Drywall Safety Act of 2012’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c8fc3e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s1/a"},"text":"Pub. L. 110–314, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3016"},"text":"122 Stat. 3016","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/314/s1/a"},"text":"“This Act [enacting sections 1278a, 1477, 2053a, 2055a, 2056a, 2056b, 2057c, 2076b, 2086 to 2089, and 8008 of this title, amending sections 1191, 1193, 1194, 1196, 1201 to 1204, 1261 to 1266, 1269 to 1276, 1278, 1472, 2052, 2054, 2055, 2058, 2060, 2063 to 2070, 2073, 2076, 2077 to 2079, 2081, 2082, 8002, and 8003 of this title, enacting provisions set out as notes under this section and sections 1194, 2053, 2060, 2063, 2066, 2069, and 2076 of this title, amending provisions set out as notes under sections 401 and 1261 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2053"},"text":"section 2053 of this title","children":[],"tail":"] may be cited as the ‘Consumer Product Safety Improvement Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c8fc3f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/608/s1"},"text":"Pub. L. 101–608, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3110"},"text":"104 Stat. 3110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/608/s1"},"text":"“This Act [enacting sections 2076a and 2084 of this title, amending sections 1193, 1194, 1262, 1274, 2053, 2055, 2056, 2058, 2061, 2064, 2066, 2069, 2077, and 2081 of this title, and enacting provisions set out as notes under sections 2053, 2054, 2056, 2076, and 2084 of this title] may be cited as the ‘Consumer Product Safety Improvement Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c8fc40-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXII/s1201/a"},"text":"Pub. L. 97–35, title XII, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/703"},"text":"95 Stat. 703","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tXII/s1201/a"},"text":"“This subtitle [subtitle A (§§ 1201–1215) of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", enacting sections 1204, 1276, 2077, and 2083 of this title, amending sections 1193, 1201, 1262, 1263, 1274, 2052, 2054 to 2058, 2060, 2061, 2064, 2069, 2072, 2073, 2076, 2080, and 2081 of this title, repealing sections 1204, 1475, 2059, 2062, and 2077 of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052"},"text":"section 2052 of this title","children":[],"tail":"] may be cited as the ‘Consumer Product Safety Amendments of 1981’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c8fc41-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/319/s1"},"text":"Pub. L. 95–319, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-07-11"},"text":"July 11, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/386"},"text":"92 Stat. 386","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/319/s1"},"text":"“That this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2082"},"text":"section 2082 of this title","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2068"},"text":"section 2068 of this title","children":[],"tail":", and enacting provision set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2082"},"text":"section 2082 of this title","children":[],"tail":"] may be cited as the ‘Emergency Interim Consumer Product Safety Standard Act of 1978’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c8fc42-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/284/s1"},"text":"Pub. L. 94–284, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/503"},"text":"90 Stat. 503","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/284/s1"},"text":"“This Act [amending sections 1193, 1203, 1204, 1261, 1471, 1476, 2052, 2053, 2056, 2058 to 2060, 2064, 2068, 2069, 2071 to 2073, 2075, 2076, 2078, 2079, and 2081 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1114"},"text":"section 1114 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and enacting provisions set out as notes under sections 1193, 1261, and 2080 of this title] may be cited as the ‘Consumer Product Safety Commission Improvements Act of 1976’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id79c8fc43-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s1"},"text":"Pub. L. 92–573, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1207"},"text":"86 Stat. 1207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/573/s1"},"text":"“This Act [enacting this chapter, amending sections 5314 and 5315 of Title 5, Government Organization and Employees, and enacting provisions set out as notes under this section] may be cited as the ‘Consumer Product Safety Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79c8fc44-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Issue Implementing Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s3"},"text":"Pub. L. 110–314, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3017"},"text":"122 Stat. 3017","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/314/s3"},"text":"“The Commission may issue regulations, as necessary, to implement this Act [see Short Title of 2008 Amendment note above] and the amendments made by this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id79c8fc45-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s239/b"},"text":"Pub. L. 110–314, title II, § 239(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3076"},"text":"122 Stat. 3076","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/314/tII/s239/b"},"text":"“If any provision of this Act [see Short Title of 2008 Amendment note above] or the amendments made by this Act, or the application of such provision to any person or circumstance, is held invalid, the remainder of this Act and the amendments made by this Act, and the application of such provision to other persons not similarly situated or to other circumstances, shall not be affected by such invalidation.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s33"},"text":"Pub. L. 92–573, § 33","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1233"},"text":"86 Stat. 1233","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/573/s33"},"text":"“If any provision of this Act [see Short Title note above], or the application of such provision to any person or circumstance, shall be held invalid, the remainder of this Act, or the application of such provisions to persons or circumstances other than those as to which it is held invalid, shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id79c8fc46-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Preemption","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s231"},"text":"Pub. L. 110–314, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3070"},"text":"122 Stat. 3070","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/314/tII/s231"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule With Regard to Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of sections 25 and 26 of the Consumer Product Safety Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2074"},"text":"15 U.S.C. 2074","children":[],"tail":" and 2075, respectively), section 18 of the Federal Hazardous Substances Act (["},{"tag":"ref","attrib":{"href":"/us/pl/86/613"},"text":"Pub. L. 86–613","children":[],"tail":"] "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"15 U.S.C. 1261","children":[],"tail":" note), section 16 of the Flammable Fabrics Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1203"},"text":"15 U.S.C. 1203","children":[],"tail":"), and section 7 of the Poison Packaging Prevention Act of 1970 [Poison Prevention Packaging Act of 1970] ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1476"},"text":"15 U.S.C. 1476","children":[],"tail":") establishing the extent to which those Acts preempt, limit, or otherwise affect any other Federal, State, or local law, any rule, procedure, or regulation, or any cause of action under State or local law may not be expanded or contracted in scope, or limited, modified or extended in application, by any rule or regulation thereunder, or by reference in any preamble, statement of policy, executive branch statements, or other matter associated with the publication of any such rule or regulation. In accordance with the provisions of those Acts, the Commission may not construe any such Act as preempting any cause of action under State or local common law or State statutory law regarding damage claims."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Certain State Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this Act [see Short Title of 2008 Amendment note above] or the Federal Hazardous Substances Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1261"},"text":"15 U.S.C. 1261","children":[],"tail":" et seq.] shall be construed to preempt or otherwise affect any warning requirement relating to consumer products or substances that is established pursuant to State law that was in effect on "},{"tag":"date","attrib":{"date":"2003-08-31"},"text":"August 31, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id79c8fc47-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/s2/a"},"text":"Pub. L. 110–314, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3017"},"text":"122 Stat. 3017","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/314/s2/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this Act [see Short Title of 2008 Amendment note above]—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘appropriate Congressional committees’ means the Committee on Energy and Commerce of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Commission’ means the Consumer Product Safety Commission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
