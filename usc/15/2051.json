{"tag":"section","attrib":{"id":"id79c8fc2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051"},"text":null,"children":[{"tag":"num","attrib":{"value":"2051"},"text":"§ 2051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79c8fc2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c8fc2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unacceptable number of consumer products which present unreasonable risks of injury are distributed in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complexities of consumer products and the diverse nature and abilities of consumers using them frequently result in an inability of users to anticipate risks and to safeguard themselves adequately;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public should be protected against unreasonable risks of injury associated with consumer products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control by State and local governments of unreasonable risks of injury associated with consumer products is inadequate and may be burdensome to manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Federal authority to protect consumers from exposure to consumer products presenting unreasonable risks of injury is inadequate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulation of consumer products the distribution or use of which affects interstate or foreign commerce is necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79c8fc32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79c8fc33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the public against unreasonable risks of injury associated with consumer products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist consumers in evaluating the comparative safety of consumer products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop uniform safety standards for consumer products and to minimize conflicting State and local regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79c8fc36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2051/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote research and investigation into the causes and prevention of product-related deaths, illnesses, and injuries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79c8fc37-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s2"},"text":"Pub. L. 92–573, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1207"},"text":"86 Stat. 1207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79c8fc38-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79c8fc39-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79c8fc3a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/314/tII/s239/a"},"text":"Pub. L. 110–314, title II, § 239(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3076"},"text":"122 Stat. 3076","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/314/tII/s239/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise specifically provided in this Act [see Short Title of 2008 Amendment note below], this Act and the amendments made by this Act shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain delayed effective dates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by sections 103(c) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2063"},"text":"section 2063 of this title","children":[],"tail":"] and 214(a)(2) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2064"},"text":"section 2064 of this title","children":[],"tail":"] shall take effect on the date that is 60 days after the date of enactment of this Act. Subsection (c) of section 42 of the Consumer Product Safety Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2089/c"},"text":"section 2089(c) of this title","children":[],"tail":"], as added by section 232 of this Act, and the amendments made by sections 216 [amending sections 2066 and 2068 of this title] and 223(b) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2066"},"text":"section 2066 of this title","children":[],"tail":"] shall take effect on the date that is 30 days after the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id79c8fc3b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/573/s34"},"text":"Pub. L. 92–573, § 34","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1233"},"text":"86 Stat. 1233","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/573/s34"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This Act [enacting this chapter] shall take effect on the sixtieth day following the date of its enactment [","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":"], except—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 4 and 32 [sections 2053 and 2081 of this title] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 30 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2079"},"text":"section 2079 of this title","children":[],"tail":"] shall take effect on the later of (A) 150 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":"], or (B) the date on which at least three members of the Commission first take office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id79c8fc3c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/171/s1"},"text":"Pub. L. 117–171, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2094"},"text":"136 Stat. 2094","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/171/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2056e"},"text":"section 2056e of this title","children":[],"tail":" and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2056e"},"text":"section 2056e of this title","children":[],"tail":"] may be cited as ‘Reese’s Law’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/126/s1"},"text":"Pub. L. 117–126, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-05-16"},"text":"May 16, 2022","children":[],"tail":", "},{