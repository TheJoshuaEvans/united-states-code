{"tag":"section","attrib":{"id":"id796be890-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226"},"text":null,"children":[{"tag":"num","attrib":{"value":"1226"},"text":"§ 1226.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle franchise contract dispute resolution process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id796be891-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of arbitration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id796be892-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id796be893-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “motor vehicle” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30102/6"},"text":"section 30102(6) of title 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002308"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002308"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id796be894-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “motor vehicle franchise contract” means a contract under which a motor vehicle manufacturer, importer, or distributor sells motor vehicles to any other person for resale to an ultimate purchaser and authorizes such other person to repair and service the manufacturer’s motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be895-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, whenever a motor vehicle franchise contract provides for the use of arbitration to resolve a controversy arising out of or relating to such contract, arbitration may be used to settle such controversy only if after such controversy arises all parties to such controversy consent in writing to use arbitration to settle such controversy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id796be896-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, whenever arbitration is elected to settle a dispute under a motor vehicle franchise contract, the arbitrator shall provide the parties to such contract with a written explanation of the factual and legal basis for the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id796be897-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1226/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply to contracts entered into, amended, altered, modified, renewed, or extended after ","children":[{"tag":"date","attrib":{"date":"2002-11-02"},"text":"November 2, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id796be898-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11028"},"text":"Pub. L. 107–273, div. C, title I, § 11028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1835"},"text":"116 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id796be899-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id796be89a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id796be89b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30102/6"},"text":"Section 30102(6) of title 49","children":[],"tail":", referred to in subsec. (a)(1)(A), probably should be “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30102/a/6"},"text":"section 30102(a)(6) of title 49","children":[],"tail":"”, which was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30102/a/7"},"text":"section 30102(a)(7) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24109/b/2"},"text":"section 24109(b)(2) of Pub. L. 114–94","children":[],"tail":", div. B, title XXIV, "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1706"},"text":"129 Stat. 1706","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id796be89c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the 21st Century Department of Justice Appropriations Authorization Act, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-08/ch1038"},"text":"act Aug. 8, 1956, ch. 1038","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
