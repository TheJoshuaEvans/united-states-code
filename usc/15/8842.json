{"tag":"section","attrib":{"id":"id7a8ee535-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842"},"text":null,"children":[{"tag":"num","attrib":{"value":"8842"},"text":"§ 8842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multidisciplinary centers for quantum research and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a8ee536-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation, in consultation with other Federal departments and agencies, as appropriate, shall award grants to institutions of higher education or eligible nonprofit organizations (or consortia thereof) to establish at least 2, but not more than 5, Multidisciplinary Centers for Quantum Research and Education (referred to in this section as “Centers”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee537-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A collaboration receiving an award under this subsection may include institutions of higher education, nonprofit organizations, and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee538-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Centers shall be to conduct basic research and education activities in support of the goals and priorities established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s8813/d/2"},"text":"section 8813(d)(2) of this title","children":[],"tail":", including by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee539-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing to advance quantum information science and engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee53a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting curriculum and workforce development in quantum information science and engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a8ee53b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering innovation by bringing industry perspectives to quantum research and workforce development, including by leveraging industry knowledge and resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a8ee53c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a8ee53d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of higher education or an eligible nonprofit organization (or a consortium thereof) seeking funding under this section shall submit an application to the Director of the National Science Foundation at such time, in such manner, and containing such information as the Director may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application under paragraph (1) shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will work with other research institutions and industry partners to leverage expertise in quantum science, education and curriculum development, and technology transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will promote active collaboration among researchers in multiple disciplines involved in quantum research, including physics, engineering, mathematics, computer science, chemistry, and material science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center will support long-term and short-term workforce development in the quantum field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Center can support an innovation ecosystem to work with industry to translate Center research into applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a long-term plan to become self-sustaining after the expiration of funding under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and duration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Center established under this section is authorized to carry out activities for a period of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reapplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An awardee may reapply for additional, subsequent periods of 5 years on a competitive, merit-reviewed basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the authorities of the National Science Foundation, the Director of the National Science Foundation may terminate an underperforming Center for cause during the performance period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8842/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall allocate up to $10,000,000 for each Center established under this section for each of fiscal years 2019 through 2023, subject to the availability of appropriations. Amounts made available to carry out this section shall be derived from amounts appropriated or otherwise made available to the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912e39-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/368/tIII/s302"},"text":"Pub. L. 115–368, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5100"},"text":"132 Stat. 5100","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
