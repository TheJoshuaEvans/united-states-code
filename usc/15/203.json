{"tag":"section","attrib":{"id":"id78870642-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s203"},"text":null,"children":[{"tag":"num","attrib":{"value":"203"},"text":"§ 203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacing lost standard weights and measures; cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce is authorized and directed to furnish precise copies of standard weights and measures, bearing the seal of the National Institute of Standards and Technology and accompanied by a suitable certificate, to any State, Territory, or institution heretofore furnished with the same, upon application in writing by the governor in the case of a State or Territory, or by the official head in the case of an institution, setting forth that the copies of standards applied for are to replace similar ones heretofore furnished, in accordance with law, which have been lost or destroyed: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the applicant shall, before the said standards are delivered, first deposit with the Secretary of Commerce the amount of money necessary to defray all expenses incurred by the National Institute of Standards and Technology in furnishing the same, which amount shall be covered into the Treasury of the United States to the credit of miscellaneous receipts as soon as the weights or measures are delivered for transportation into the hands of such persons as are designated by the officers ordering the same."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id78870643-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-08-18/ch301/s1"},"text":"Aug. 18, 1894, ch. 301, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/383"},"text":"28 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch872/s1"},"text":"Mar. 3, 1901, ch. 872, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1449"},"text":"31 Stat. 1449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1903-02-14/ch552/s10"},"text":"Feb. 14, 1903, ch. 552, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/829"},"text":"32 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id78870644-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id78870645-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78870646-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “National Institute of Standards and Technology” for “Bureau of Standards” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id78870647-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id78870648-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"Mar. 4, 1913","children":[],"tail":", created Department of Labor and renamed Department of Commerce and Labor as Department of Commerce."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1901-03-03"},"text":"Mar. 3, 1901","children":[],"tail":", provided that Office of Standard Weights and Measures should thereafter be known as National Bureau of Standards."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id78870649-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"Feb. 14, 1903","children":[],"tail":", transferred National Bureau of Standards from Treasury Department to Department of Commerce and Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
