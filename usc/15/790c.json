{"tag":"section","attrib":{"id":"id794f5ed7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c"},"text":null,"children":[{"tag":"num","attrib":{"value":"790c"},"text":"§ 790c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis and evaluation of energy information; establishment and maintenance by Director of professional, etc., capability; specific capabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id794f5ed8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall establish and maintain the scientific, engineering, statistical, or other technical capability to perform analysis of energy information to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id794f5ed9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify the accuracy of items of energy information submitted to the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5eda-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insure the coordination and comparability of the energy information in possession of the Office and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id794f5edb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall establish and maintain the professional and analytic capability to evaluate independently the adequacy and comprehensiveness of the energy information in possession of the Office and other agencies of the Federal Government in relation to the purposes of this chapter and for the performance of the analyses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s790a"},"text":"section 790a of this title","children":[],"tail":". Such analytic capability shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id794f5edc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise in economics, finance, and accounting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5edd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability to evaluate estimates of reserves of mineral fuels and nonmineral energy resources utilizing alternative methodologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5ede-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and evaluation of energy flow and accounting models describing the production, distribution, and consumption of energy by the various sectors of the economy and lines of commerce in the energy industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5edf-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and evaluation of alternative forecasting models describing the short- and long-term relationships between energy supply and consumption and appropriate variables; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id794f5ee0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s790c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other capabilities as the Director deems necessary to achieve the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id794f5ee1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/275/s54"},"text":"Pub. L. 93–275, § 54","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/tI/s142"},"text":"Pub. L. 94–385, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1137"},"text":"90 Stat. 1137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id794f5ee2-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id794f5ee3-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id794f5ee4-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 150 days after ","children":[{"tag":"date","attrib":{"date":"1976-08-14"},"text":"Aug. 14, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/385/s143"},"text":"section 143 of Pub. L. 94–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s790"},"text":"section 790 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id794f5ee5-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions assigned to Director of Office of Energy Information and Analysis under this subchapter vested in Administrator of the Energy Information Administration within Department of Energy by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7135/c"},"text":"section 7135(c) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Federal Energy Administration terminated and functions vested by law in Administrator thereof transferred to Secretary of Energy (unless otherwise specifically provided) by sections 7151(a) and 7293 of Title 42.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
