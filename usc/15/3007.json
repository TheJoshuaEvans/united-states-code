{"tag":"section","attrib":{"id":"id7a12d6a5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and venue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a12d6a6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District court jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the district courts of the United States shall have jurisdiction over any civil action under this chapter, without regard to the citizenship of the parties or the amount in controversy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6a7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue; service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A civil action under this chapter may be brought in any district court of the United States for a district located in the host State or the off-track State, and all process in any such civil action may be served in any judicial district of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a12d6a8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent State court jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The jurisdiction of the district courts of the United States pursuant to this section shall be concurrent with that of any State court of competent jurisdiction located in the host State or the off-track State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a12d6a9-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/515/s8"},"text":"Pub. L. 95–515, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1814"},"text":"92 Stat. 1814","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
