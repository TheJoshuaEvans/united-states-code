{"tag":"section","attrib":{"id":"id79c68ba0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1849"},"text":null,"children":[{"tag":"num","attrib":{"value":"1849"},"text":"§ 1849.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve banks as fiscal agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal Reserve bank which is requested to do so shall act as fiscal agent for the Board. Each such fiscal agent shall be reimbursed by the Board for all expenses and losses incurred by it in acting as agent on behalf of the Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id79c68ba1-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/70/s10"},"text":"Pub. L. 92–70, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-09"},"text":"Aug. 9, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/181"},"text":"85 Stat. 181","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
