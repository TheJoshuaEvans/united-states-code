{"tag":"section","attrib":{"id":"id79bd1516-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1693h"},"text":"§ 1693h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of financial institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id79bd1517-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action or failure to act proximately causing damages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (c), a financial institution shall be liable to a consumer for all damages proximately caused by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1518-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the financial institution’s failure to make an electronic fund transfer, in accordance with the terms and conditions of an account, in the correct amount or in a timely manner when properly instructed to do so by the consumer, except where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id79bd1519-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consumer’s account has insufficient funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd151a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds are subject to legal process or other encumbrance restricting such transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd151b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such transfer would exceed an established credit limit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd151c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic terminal has insufficient cash to complete the transaction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id79bd151d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise provided in regulations of the Bureau;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd151e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial institution’s failure to make an electronic fund transfer due to insufficient funds when the financal ","children":[{"tag":"ref","attrib":{"idref":"fn002408"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002408"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “financial”."}],"tail":" institution failed to credit, in accordance with the terms and conditions of an account, a deposit of funds to the consumer’s account which would have provided sufficient funds to make the transfer, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd151f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial institution’s failure to stop payment of a preauthorized transfer from a consumer’s account when instructed to do so in accordance with the terms and conditions of the account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1520-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acts of God and technical malfunctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A financial institution shall not be liable under subsection (a)(1) or (2) if the financial institution shows by a preponderance of the evidence that its action or failure to act resulted from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79bd1521-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of God or other circumstance beyond its control, that it exercised reasonable care to prevent such an occurrence, and that it exercised such diligence as the circumstances required; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79bd1522-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a technical malfunction which was known to the consumer at the time he attempted to initiate an electronic fund transfer or, in the case of a preauthorized transfer, at the time such transfer should have occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1523-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a failure described in subsection (a) which was not intentional and which resulted from a bona fide error, notwithstanding the maintenance of procedures reasonably adapted to avoid any such error, the financial institution shall be liable for actual damages proved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id79bd1524-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1693h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for damaged notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the notice required to be posted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693b/d/3/B/i"},"text":"section 1693b(d)(3)(B)(i) of this title","children":[],"tail":" by an automated teller machine operator has been posted by such operator in compliance with such section and the notice is subsequently removed, damaged, or altered by any person other than the operator of the automated teller machine, the operator shall have no liability under this section for failure to comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693b/d/3/B/i"},"text":"section 1693b(d)(3)(B)(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79bd1525-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321/tIX/s910"},"text":"Pub. L. 90–321, title IX, § 910","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/630/tXX/s2001"},"text":"Pub. L. 95–630, title XX, § 2001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-10"},"text":"Nov. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3735"},"text":"92 Stat. 3735","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/102/tVII/s705"},"text":"Pub. L. 106–102, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1465"},"text":"113 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tX/s1084/1"},"text":"Pub. L. 111–203, title X, § 1084(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2081"},"text":"124 Stat. 2081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id79bd1526-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id79bd1527-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id79bd1528-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Bureau” for “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102"},"text":"Pub. L. 106–102","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id79bd1529-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id79bd152a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the designated transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s1100H"},"text":"section 1100H of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
