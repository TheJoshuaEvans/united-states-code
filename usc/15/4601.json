{"tag":"section","attrib":{"id":"id7a3b6d68-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601"},"text":null,"children":[{"tag":"num","attrib":{"value":"4601"},"text":"§ 4601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings, purposes, and definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a3b6d69-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that it is in the national economic and security interests of the United States for the Department of Defense to provide financial assistance to the industry consortium known as Sematech for research and development activities in the field of semiconductor manufacturing technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6d6a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6d6b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to encourage the semiconductor industry in the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a3b6d6c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research on advanced semiconductor manufacturing techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a3b6d6d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop techniques to use manufacturing expertise for the manufacture of a variety of semiconductor products; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d6e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to achieve the purpose set out in paragraph (1), to provide a grant program for the financial support of semiconductor research activities conducted by Sematech.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a3b6d6f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a3b6d70-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “Semiconductor Technology Council” and “Council” mean the advisory council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s4603"},"text":"section 4603 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a3b6d71-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Sematech” means a consortium of firms in the United States semiconductor industry established for the purposes of (A) conducting research concerning advanced semiconductor manufacturing techniques, and (B) developing techniques to adapt manufacturing expertise to a variety of semiconductor products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a3b6d72-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tII/s271"},"text":"Pub. L. 100–180, div. A, title II, § 271","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1068"},"text":"101 Stat. 1068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tII/s263/c/1"},"text":"Pub. L. 103–160, div. A, title II, § 263(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1610"},"text":"107 Stat. 1610","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a3b6d73-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a3b6d74-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7a3b6d75-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “Semiconductor Technology Council” for “Advisory Council on Federal Participation in Sematech”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
