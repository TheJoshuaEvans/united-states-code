{"tag":"section","attrib":{"id":"id7aadddec-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451"},"text":null,"children":[{"tag":"num","attrib":{"value":"9451"},"text":"§ 9451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Artificial intelligence research and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aaddded-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"the ","children":[{"tag":"ref","attrib":{"idref":"fn002661"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002661"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" Director of the National Science Foundation shall fund research and education activities in artificial intelligence systems and related fields, including competitive awards or grants to institutions of higher education or eligible nonprofit organizations (or consortia thereof)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aadddee-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the activities under subsection (a), the Director of the National Science Foundation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aadddef-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support research, including interdisciplinary research, on artificial intelligence systems and related areas, including fields and research areas that will contribute to the development and deployment of trustworthy artificial intelligence systems, and fields and research areas that address the application of artificial intelligence systems to scientific discovery and societal challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use the existing programs of the National Science Foundation, in collaboration with other Federal departments and agencies, as appropriate to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadddf1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the teaching and learning of topics related to artificial intelligence systems in K-12 education and postsecondary educational programs, including workforce training and career and technical education programs, undergraduate and graduate education programs, and in informal settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadddf2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase participation in artificial intelligence related fields, including by individuals identified in sections 1885a and 1885b of title 42;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support partnerships among institutions of higher education, Federal laboratories, nonprofit organizations, State, local, and Tribal governments, industry, and potential users of artificial intelligence systems that facilitate collaborative research, personnel exchanges, and workforce development and identify emerging research needs with respect to artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure adequate access to research and education infrastructure with respect to artificial intelligence systems, which may include the development of new computing resources and partnership with the private sector for the provision of cloud-based computing services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct prize competitions, as appropriate, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate research efforts funded through existing programs across the directorates of the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance on data sharing by grantees to public and private sector organizations consistent with the standards and guidelines developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278h–1/e"},"text":"section 278h–1(e) of this title","children":[],"tail":" (as added by section 5301 of this division); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadddf8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate opportunities for international collaboration with strategic allies on artificial intelligence research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aadddf9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engineering support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In general, the Director shall permit applicants to include in their proposed budgets funding for software engineering support to assist with the proposed research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aadddfa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ethics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aadddfb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadddfc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a number of emerging areas of research, including artificial intelligence, have potential ethical, social, safety, and security risks that might be apparent as early as the basic research stage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadddfd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incorporation of ethical, social, safety, and security considerations into the research design and review process for Federal awards may help mitigate potential harms before they happen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadddfe-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation’s agreement with the National Academies of Sciences, Engineering, and Medicine to conduct a study and make recommendations with respect to governance of research in computing and computing technologies is a positive step toward accomplishing this goal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadddff-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation should continue to work with stakeholders to understand and adopt policies that promote best practices for governance of research in emerging technologies at every stage of research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde00-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on ethics statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than 6 months after publication of the study described in paragraph (1)(C), the Director shall report to Congress on options for requiring an ethics or risk statement as part of all or a subset of applications for research funding to the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aadde01-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aadde02-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Science Foundation shall award grants for artificial intelligence education research, development and related activities to support K-12 and postsecondary education programs and activities, including workforce training and career and technical education programs and activities, undergraduate, graduate, and postdoctoral education, and informal education programs and activities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadde03-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of a diverse workforce pipeline for science and technology with respect to artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde04-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase awareness of potential ethical, social, safety, and security risks of artificial intelligence systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde05-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote curriculum development for teaching topics related to artificial intelligence, including in the field of technology ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde06-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support efforts to achieve equitable access to K-12 artificial intelligence education in diverse geographic areas and for populations historically underrepresented in science, engineering, and artificial intelligence fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde07-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the widespread understanding of artificial intelligence principles and methods to create an educated workforce and general public able to use products enabled by artificial intelligence systems and adapt to future societal and economic changes caused by artificial intelligence systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde08-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Artificial intelligence faculty fellowships","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadde09-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Faculty recruitment fellowships","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aadde0a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall establish a program to award grants to eligible institutions of higher education to recruit and retain tenure-track or tenured faculty in artificial intelligence and related fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde0b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An institution of higher education shall use grant funds provided under clause (i) for the purposes of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7aadde0c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting new tenure-track or tenured faculty members that conduct research and teaching in artificial intelligence and related fields and research areas, including technology ethics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aadde0d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying salary and benefits for the academic year of newly recruited tenure-track or tenured faculty members for a duration of up to three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institutions of higher education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subparagraph, an eligible institution of higher education is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id7aadde0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Historically Black College and University (within the meaning of the term “part B institution” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061"},"text":"section 1061 of title 20","children":[],"tail":"), Tribal College or University, or other minority-serving institution, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aadde10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution classified under the Carnegie Classification of Institutions of Higher Education as a doctorate-granting university with a high level of research activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id7aadde11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution located in a State jurisdiction eligible to participate in the National Science Foundation’s Established Program to Stimulate Competitive Research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Faculty technology ethics fellowships","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aadde13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall establish a program to award fellowships to tenure-track and tenured faculty in social and behavioral sciences, ethics, law, and related fields to develop new research projects and partnerships in technology ethics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purposes of such fellowships are to enable researchers in social and behavioral sciences, ethics, law, and related fields to establish new research and education partnerships with researchers in artificial intelligence and related fields; learn new techniques and acquire systematic knowledge in artificial intelligence and related fields; and mentor and advise graduate students and postdocs pursuing research in technology ethics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fellowship may include salary and benefits for up to one academic year, expenses to support coursework or equivalent training in artificial intelligence systems, and additional such expenses that the Director deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde16-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde17-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update to advanced technological education program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadde18-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Artificial intelligence centers of excellence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Science Foundation shall establish national centers of scientific and technical education to advance education and workforce development in areas related to artificial intelligence pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862i"},"text":"section 1862i of title 42","children":[],"tail":". Activities of such centers may include—"}],"tail":null},{"tag":"clause","attrib":{"id":"id7aadde1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, dissemination, and evaluation of curriculum and other educational tools and methods in artificial intelligence related fields and research areas, including technology ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and evaluation of artificial intelligence related certifications for 2-year programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interdisciplinary science and engineering research in employment-based adult learning and career retraining related to artificial intelligence fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aadde1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Foundation pilot program of grants for research in rapidly evolving, high priority topics","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aadde1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall establish a pilot program to assess the feasibility and advisability of awarding grants for the conduct of research in rapidly evolving, high priority topics using funding mechanisms that require brief project descriptions and internal merit review, and that may include accelerated external review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadde20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out the pilot program required by paragraph (1) during the 5-year period beginning on Janaury 1, 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and continuation authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the period set forth in paragraph (2)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aadde22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director shall assess the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Director determines that it is both feasible and advisable to do so, the Director may continue the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the pilot program, the Director shall award grants for the conduct of research in topics selected by the Director in accordance with paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topic selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall select topics for research under the pilot program in accordance with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aadde26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall select artificial intelligence as the initial topic for the pilot program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aadde27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director may select additional topics that the Director determines are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7aadde28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rapidly evolving; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7aadde29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of high importance to the economy and security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aadde2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the National Science Foundation to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aadde2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $868,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $911,400,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $956,970,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,004,820,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aadde2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9451/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,055,060,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aadde30-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dE/tLIV/s5401"},"text":"Pub. L. 116–283, div. E, title LIV, § 5401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4540"},"text":"134 Stat. 4540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7aadde31-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7aadde32-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7aadde33-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1885a and 1885b of title 42, referred to in subsec. (b)(2)(B), were in the original sections 33 and 34 of the Science and Engineering Equal Opportunity Act and were translated as meaning sections 33 and 34 of the Science and Engineering Equal Opportunities Act to reflect the probable intent of Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5301 of this division, referred to in subsec. (b)(7), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dE/s5301"},"text":"section 5301 of div. E of Pub. L. 116–283","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4536"},"text":"134 Stat. 4536","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id7aadde34-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s5401"},"text":"section 5401 of Pub. L. 116–283","children":[],"tail":". Subsec. (e)(2)(C) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s5401"},"text":"section 5401 of Pub. L. 116–283","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n–1"},"text":"section 1862n–1 of Title 42","children":[],"tail":", The Public Health and Welfare. Subsec. (e)(3)(A) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s5401"},"text":"section 5401 of Pub. L. 116–283","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862i"},"text":"section 1862i of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
