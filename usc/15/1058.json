{"tag":"section","attrib":{"id":"id7958d565-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058"},"text":null,"children":[{"tag":"num","attrib":{"value":"1058"},"text":"§ 1058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration, affidavits and fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7958d566-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time periods for required affidavits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each registration shall remain in force for 10 years, except that the registration of any mark shall be canceled by the Director unless the owner of the registration files in the United States Patent and Trademark Office affidavits that meet the requirements of subsection (b), within the following time periods:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7958d567-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the 1-year period immediately preceding the expiration of 6 years following the date of registration under this chapter or the date of the publication under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1062/c"},"text":"section 1062(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7958d568-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within the 1-year period immediately preceding the expiration of 10 years following the date of registration, and each successive 10-year period following the date of registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7958d569-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner may file the affidavit required under this section within the 6-month grace period immediately following the expiration of the periods established in paragraphs (1) and (2), together with the fee described in subsection (b) and the additional grace period surcharge prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d56a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for affidavit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The affidavit referred to in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7958d56b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7958d56c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that the mark is in use in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7958d56d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the goods and services recited in the registration on or in connection with which the mark is in use in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7958d56e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accompanied by such number of specimens or facsimiles showing current use of the mark in commerce as may be required by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7958d56f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accompanied by the fee prescribed by the Director; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7958d570-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7958d571-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the goods and services recited in the registration on or in connection with which the mark is not in use in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7958d572-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a showing that any nonuse is due to special circumstances which excuse such nonuse and is not due to any intention to abandon the mark; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7958d573-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accompanied by the fee prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d574-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficient affidavit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any submission filed within the period set forth in subsection (a) is deficient, including that the affidavit was not filed in the name of the owner of the registration, the deficiency may be corrected after the statutory time period, within the time prescribed after notification of the deficiency. Such submission shall be accompanied by the additional deficiency surcharge prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d575-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Special notice of the requirement for such affidavit shall be attached to each certificate of registration and notice of publication under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1062/c"},"text":"section 1062(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d576-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of acceptance or refusal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall notify any owner who files any affidavit required by this section of the Director’s acceptance or refusal thereof and, in the case of a refusal, the reasons therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7958d577-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1058/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of resident for service of process and notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the owner is not domiciled in the United States, the owner may designate, by a document filed in the United States Patent and Trademark Office, the name and address of a person resident in the United States on whom may be served notices or process in proceedings affecting the mark. Such notices or process may be served upon the person so designated by leaving with that person or mailing to that person a copy thereof at the address specified in the last designation so filed. If the person so designated cannot be found at the last designated address, or if the owner does not designate by a document filed in the United States Patent and Trademark Office the name and address of a person resident in the United States on whom may be served notices or process in proceedings affecting the mark, such notices or process may be served on the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7958d578-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"July 5, 1946, ch. 540","children":[],"tail":", title I, § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/60/431"},"text":"60 Stat. 431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s1"},"text":"Pub. L. 93–596, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s8"},"text":"Pub. L. 97–247, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/320"},"text":"96 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/tI/s110"},"text":"Pub. L. 100–667, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3939"},"text":"102 Stat. 3939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/tI/s105"},"text":"Pub. L. 105–330, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3066"},"text":"112 Stat. 3066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(1)(B), (C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIII/s13207/b/3"},"text":"Pub. L. 107–273, div. C, title III, § 13207(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1906"},"text":"116 Stat. 1906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/146/s3/d/1"},"text":"Pub. L. 111–146, § 3(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-17"},"text":"Mar. 17, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/67"},"text":"124 Stat. 67","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7958d579-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7958d57a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7958d57b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1905-02-20/ch592/s12"},"text":"Act Feb. 20, 1905, ch. 592, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/727"},"text":"33 Stat. 727","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7958d57c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/146"},"text":"Pub. L. 111–146","children":[],"tail":" amended section generally. Prior to amendment, section related to duration of registrations, affidavits of continuing use, grace period for submissions and correction of deficiencies, certain notice requirements related to affidavits, and designation of resident for service of process and notices."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, text read as follows: “If the registrant is not domiciled in the United States, the registrant shall designate by a written document filed in the Patent and Trademark Office the name and address of some person resident in the United States on whom may be served notices or process in proceedings affecting the mark. Such notices or process may be served upon the person so designated by leaving with that person or mailing to that person a copy thereof at the address specified in the last designation so filed. If the person so designated cannot be found at the address given in the last designation, such notice or process may be served upon the Director.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", substituted “Director” for “Commissioner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(b)(1)(B), (C)]","children":[],"tail":", amended subsec. (e) identically, substituting “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/9/tIV/s4732/b/1/B"},"text":"Pub. L. 106–113, § 1000(a)(9) [title IV, § 4732(b)(1)(B)]","children":[],"tail":", substituted “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) to (c) relating to affidavits of continuing use, registrations published under other provisions of law, and notification of acceptance or refusal of affidavits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667"},"text":"Pub. L. 100–667","children":[],"tail":" substituted “ten” for “twenty” and “setting forth those goods or services recited in the registration on or in connection with which the mark is in use in commerce and attaching to the affidavit a specimen or facsimile showing current use of the mark, or showing that any” for “showing that said mark is in use in commerce or showing that its”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" struck out “still” after “showing that said mark is”, and inserted “in commerce” after “use”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":" substituted “Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7958d57d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d57e-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d57f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" effective on the date that is 1 year after "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s110"},"text":"section 110 of Pub. L. 105–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330/tI/s109/a"},"text":"Pub. L. 105–330, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3069"},"text":"112 Stat. 3069","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/330/tI/s109/a"},"text":"“The provisions of section 8 of the Trademark Act of 1946 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1058"},"text":"15 U.S.C. 1058","children":[],"tail":"], as amended by section 105 of this Act, shall apply to a registration for trademark issued or renewed for a 20-year term, if the expiration date of the registration is on or after the effective date of this Act [probably should be “this title”, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s110"},"text":"section 110 of Pub. L. 105–330","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions relating to applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330"},"text":"Pub. L. 105–330","children":[],"tail":" to applications for registration of trademarks, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s109/b"},"text":"section 109(b) of Pub. L. 105–330","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/330/tI/s109/c"},"text":"Pub. L. 105–330, title I, § 109(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3069"},"text":"112 Stat. 3069","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/330/tI/s109/c"},"text":"“The provisions of section 8 of the Trademark Act of 1946 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1058"},"text":"15 U.S.C. 1058","children":[],"tail":"], as amended by section 105 of this Act, shall apply to the filing of an affidavit if the sixth or tenth anniversary of the registration, or the sixth anniversary of publication of the registration under section 12(c) of the Trademark Act of 1946 ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1062/c"},"text":"15 U.S.C. 1062(c)","children":[],"tail":"], for which the affidavit is filed is on or after the effective date of this Act [probably should be “this title”, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/330/s110"},"text":"section 110 of Pub. L. 105–330","children":[],"tail":", set out as an Effective Date of 1998 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d580-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/667"},"text":"Pub. L. 100–667","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1988-11-16"},"text":"Nov. 16, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/667/s136"},"text":"section 136 of Pub. L. 100–667","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7958d581-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/247"},"text":"Pub. L. 97–247","children":[],"tail":" effective six months after "},{"tag":"date","attrib":{"date":"1982-08-27"},"text":"Aug. 27, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/247/s17/c"},"text":"section 17(c) of Pub. L. 97–247","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s294"},"text":"section 294 of Title 35","children":[],"t