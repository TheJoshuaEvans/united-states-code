{"tag":"section","attrib":{"id":"id7ab509ab-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711"},"text":null,"children":[{"tag":"num","attrib":{"value":"9711"},"text":"§ 9711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gap analysis on availability of snow-related data to assess and predict flood and flood impacts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab509ac-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Department of Agriculture, the Department of the Interior, and the Army Corps of Engineers, shall conduct an analysis of gaps in the availability of snow-related data to assess and predict floods and flood impacts, including data on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509ad-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snow water equivalent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509ae-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snow depth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509af-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snowpack temperature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509b0-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snow and mixed-phase precipitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509b1-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snow melt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509b2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rain-snow line.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab509b3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", the Administrator shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7ab509b4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the gap analysis required by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7ab509b5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities for additional collaboration among Federal agencies to collect snow-related data to better assess and predict floods and flood impacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab509b6-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/316/s16"},"text":"Pub. L. 117–316, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4417"},"text":"136 Stat. 4417","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
