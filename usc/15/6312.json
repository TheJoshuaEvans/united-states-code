{"tag":"section","attrib":{"id":"id7a57f61c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312"},"text":null,"children":[{"tag":"num","attrib":{"value":"6312"},"text":"§ 6312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional boxing matches conducted on Indian reservations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a57f61d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f61e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f61f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “reservation” means the geographically defined area over which a tribal organization exercises governmental jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f620-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal organization” has the same meaning as in section 5304(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 25."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a57f621-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a57f622-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a tribal organization of an Indian tribe may, upon the initiative of the tribal organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f623-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate professional boxing matches held within the reservation under the jurisdiction of that tribal organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f624-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out that regulation or enter into a contract with a boxing commission to carry out that regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a57f625-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and licensing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a tribal organization regulates professional boxing matches pursuant to paragraph (1), the tribal organization shall, by tribal ordinance or resolution, establish and provide for the implementation of health and safety standards, licensing requirements, and other requirements relating to the conduct of professional boxing matches that are at least as restrictive as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a57f626-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the otherwise applicable standards and requirements of a State in which the reservation is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a57f627-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6312/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recently published version of the recommended regulatory guidelines certified and published by the Association of Boxing Commissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a57f628-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/272/s21"},"text":"Pub. L. 104–272, § 21","children":[],"tail":", formerly § 13, "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3313"},"text":"110 Stat. 3313","children":[],"tail":"; renumbered § 21, "},{"tag":"ref","attrib":{"href":"/us/pl/106/210/s4/1"},"text":"Pub. L. 106–210, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-05-26"},"text":"May 26, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/322"},"text":"114 Stat. 322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a57f629-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a57f62a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id7a57f62b-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"Jan. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/272/s23"},"text":"section 23 of Pub. L. 104–272","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
