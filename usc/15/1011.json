{"tag":"section","attrib":{"id":"id7951a8d2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s1011"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011"},"text":"§ 1011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Congress hereby declares that the continued regulation and taxation by the several States of the business of insurance is in the public interest, and that silence on the part of the Congress shall not be construed to impose any barrier to the regulation or taxation of such business by the several States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7951a8d3-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-03-09/ch20/s1"},"text":"Mar. 9, 1945, ch. 20, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/33"},"text":"59 Stat. 33","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7951a8d4-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7951a8d5-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id7951a8d6-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/327/s1"},"text":"Pub. L. 116–327, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-13"},"text":"Jan. 13, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/5097"},"text":"134 Stat. 5097","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/327/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1013"},"text":"section 1013 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1013"},"text":"section 1013 of this title","children":[],"tail":"] may be cited as the ‘Competitive Health Insurance Reform Act of 2020’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id7951a8d7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1945-03-09/ch20"},"text":"Act Mar. 9, 1945, ch. 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/33"},"text":"59 Stat. 33","children":[],"tail":", which is classified to this chapter, is popularly known as the “McCarran-Ferguson Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id7951a8d8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1945-03-09/ch20/s6"},"text":"Act Mar. 9, 1945, ch. 20, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/34"},"text":"59 Stat. 34","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1945-03-09/ch20/s6"},"text":"“If any provision of this Act [this chapter], or the application of such provision to any person or circumstances, shall be held invalid, the remainder of the Act, and the application of such provision to persons or circumstances other than those as to which it is held invalid, shall not be affected.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
