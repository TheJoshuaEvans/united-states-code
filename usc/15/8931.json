{"tag":"section","attrib":{"id":"id7a912f0e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931"},"text":null,"children":[{"tag":"num","attrib":{"value":"8931"},"text":"§ 8931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912f0f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912f10-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highly fluorinated compound","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912f11-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “highly fluorinated compound” means a perfluoroalkyl substance or a polyfluoroalkyl substance with at least one fully fluorinated carbon atom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912f12-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a912f13-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fully fluorinated carbon atom","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “fully fluorinated carbon atom” means a carbon atom on which all the hydrogen substituents have been replaced by fluorine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perfluoroalkyl substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “perfluoroalkyl substance” means a chemical of which all of the carbon atoms are fully fluorinated carbon atoms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a912f15-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8931/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Polyfluoroalkyl substance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “polyfluoroalkyl substance” means a chemical containing at least one fully fluorinated carbon atom and at least one carbon atom that is not a fully fluorinated carbon atom.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a912f16-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXIII/s7331"},"text":"Pub. L. 116–92, div. F, title LXXIII, § 7331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2281"},"text":"133 Stat. 2281","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
