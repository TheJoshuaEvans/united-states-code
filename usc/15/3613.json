{"tag":"section","attrib":{"id":"id7a1ebd14-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s3613"},"text":null,"children":[{"tag":"num","attrib":{"value":"3613"},"text":"§ 3613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No action shall be maintained to enforce any right or liability created by this chapter unless brought within six years after such cause of action accrued, except that an action pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3608"},"text":"section 3608 of this title","children":[],"tail":" must be brought within four years after "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"October 8, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a1ebd15-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/tVI/s614"},"text":"Pub. L. 96–399, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1680"},"text":"94 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
