{"tag":"section","attrib":{"id":"id787663e9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s80a–52"},"text":null,"children":[{"tag":"num","attrib":{"value":"80a–52"},"text":"§ 80a–52.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The effective date of the provisions of this subchapter, so far as the same relate to face-amount certificates or to face-amount certificate companies, is ","children":[{"tag":"date","attrib":{"date":"1941-01-01"},"text":"January 1, 1941","children":[],"tail":". The effective date of provisions hereof, insofar as the same do not apply to face-amount certificates or face-amount certificate companies is "},{"tag":"date","attrib":{"date":"1940-11-01"},"text":"November 1, 1940","children":[],"tail":". Except as herein otherwise provided, every provision of this subchapter shall take effect on "},{"tag":"date","attrib":{"date":"1940-11-01"},"text":"November 1, 1940","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id787663ea-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-08-22/ch686"},"text":"Aug. 22, 1940, ch. 686","children":[],"tail":", title I, § 53, "},{"tag":"ref","attrib":{"href":"/us/stat/54/847"},"text":"54 Stat. 847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/181/tVI/s624"},"text":"Pub. L. 100–181, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1262"},"text":"101 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id787663eb-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id787663ec-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id787663ed-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/181"},"text":"Pub. L. 100–181","children":[],"tail":" struck out at end of first sentence “: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any such face-amount certificate company may register prior to said date, as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–8"},"text":"section 80a–8 of this title","children":[],"tail":", and such registration shall not operate to change or affect said effective date as to any such company or any face-amount certificates issued by it”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id787663ee-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id787663ef-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/547/s30"},"text":"Pub. L. 91–547, § 30","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1436"},"text":"84 Stat. 1436","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/547/s30"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This Act [see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–51"},"text":"section 80a–51 of this title","children":[],"tail":"] shall take effect on the date of its enactment ["},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":"], except that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections (5)(a), (b), and (c); 8; 9(a); 11; 18; 24(a); and 25 (amending sections 10(a), (b), and (c) [section 80a–10(a), (b), and (c)]; 15 [section 80a–15]; 17(f) [section 80a–17(f)]; 19 [section 80a–19]; and 32(a) of the Investment Company Act of 1940 [section 80a–31(a)]; and sections 203(b) and 205 of the Investment Advisers Act of 1940 [sections 80b–3(b) and 80b–5 of this title], respectively) shall take effect upon the expiration of one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that part of section 5(d) which substitutes ‘interested persons’ for ‘affiliated persons’ in section 10(d) of the Investment Company Act of 1940 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–10/d"},"text":"section 80a–10(d) of this title","children":[],"tail":"] shall take effect upon the expiration of one year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 16 and 17 (amending section 27 and 28 of the Investment Company Act of 1940 [sections 80a–27 and 80a–28 of this title]) shall take effect upon the expiration of six months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that part of section 20 which adds a subsection (b) to section 36 of the Investment Company Act of 1940 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–35"},"text":"section 80a–35 of this title","children":[],"tail":"] shall take effect upon the expiration of eighteen months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
