{"tag":"section","attrib":{"id":"id7a4299f2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725"},"text":null,"children":[{"tag":"num","attrib":{"value":"4725"},"text":"§ 4725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States and Foreign Commercial Service Pacific Rim initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a4299f3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to encourage the export of United States goods and services to Japan, South Korea, and Taiwan, the United States and Foreign Commercial Service shall make a special effort to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299f4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify United States goods and services which are not being exported to the markets of Japan, South Korea, and Taiwan but which could be exported to these markets under competitive market conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299f5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and notify United States persons who sell or provide such goods or services of potential opportunities identified under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299f6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present, periodically, a list of the goods and services identified under paragraph (1), together with a list of any impediments to the export of such goods and services, to appropriate authorities in Japan, South Korea, and Taiwan, with a view toward liberalizing markets to such goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299f7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the entrance into such markets by United States persons identified and notified under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299f8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and evaluate the results of efforts to increase the sale of goods and services in such markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299f9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Commerce shall report periodically to the Congress on activities carried out under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a4299fa-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “United States person” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term “United States person” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a4299fb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a4299fc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s4725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other association created under the laws of the United States or any State (including the District of Columbia or any commonwealth, territory, or possession of the United States).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a4299fd-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tII/s2306"},"text":"Pub. L. 100–418, title II, § 2306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1344"},"text":"102 Stat. 1344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a4299fe-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7a4299ff-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7a429a00-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which a report required under subsec. (b) of this section is listed on page 51), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
