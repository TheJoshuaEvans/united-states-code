{"tag":"section","attrib":{"id":"id7a640438-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756"},"text":null,"children":[{"tag":"num","attrib":{"value":"6756"},"text":"§ 6756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to all the powers conferred upon a nonprofit corporation by the District of Columbia Nonprofit Corporation Act, the Association shall have the power to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a640439-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and collect such membership fees as the Association finds necessary to impose to cover the costs of its operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64043a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt, amend, and repeal bylaws, procedures, or standards governing the conduct of Association business and performance of its duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64043b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for providing notice and opportunity for comment pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s6755/a"},"text":"section 6755(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64043c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into and perform such agreements as necessary to carry out the duties of the Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64043d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire employees, professionals, or specialists, and elect or appoint officers, and to fix their compensation, define their duties and give them appropriate authority to carry out the purposes of this subchapter, and determine their qualification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64043e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish personnel policies of the Association and programs relating to, among other things, conflicts of interest, rates of compensation, where applicable, and qualifications of personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a64043f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a640440-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6756/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure funding for such amounts as the Association determines to be necessary and appropriate to organize and begin operations of the Association, which shall be treated as loans to be repaid by the Association with interest at market rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a640441-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/tIII/s326"},"text":"Pub. L. 106–102, title III, § 326","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/1/tII/s202/a"},"text":"Pub. L. 114–1, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-01-12"},"text":"Jan. 12, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/24"},"text":"129 Stat. 24","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a640442-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a640443-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a640444-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The District of Columbia Nonprofit Corporation Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/569"},"text":"Pub. L. 87–569","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-06"},"text":"Aug. 6, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/265"},"text":"76 Stat. 265","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7a640445-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A p