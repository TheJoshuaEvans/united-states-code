{"tag":"section","attrib":{"id":"id792b8435-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s690q"},"text":null,"children":[{"tag":"num","attrib":{"value":"690q"},"text":"§ 690q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The program under this part shall terminate at the end of the second full fiscal year after the date that the Administrator establishes the program under this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id792b8436-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699/tIII/s398"},"text":"Pub. L. 85–699, title III, § 398","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXII/s1207"},"text":"Pub. L. 110–140, title XII, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1783"},"text":"121 Stat. 1783","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
