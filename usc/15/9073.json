{"tag":"section","attrib":{"id":"id7aa44176-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073"},"text":null,"children":[{"tag":"num","attrib":{"value":"9073"},"text":"§ 9073.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for providing payroll support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7aa44177-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awardable amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide financial assistance under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa44178-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an air carrier in an amount equal to the salaries and benefits reported by the air carrier to the Department of Transportation pursuant to part 241 of title 14, Code of Federal Regulations, for the period from ","children":[{"tag":"date","attrib":{"date":"2019-04-01"},"text":"April 1, 2019","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44179-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an air carrier that does not transmit reports under such part 241, in an amount that such air carrier certifies, using sworn financial statements or other appropriate data, as the amount of wages, salaries, benefits, and other compensation that such air carrier paid the employees of such air carrier during the period from ","children":[{"tag":"date","attrib":{"date":"2019-04-01"},"text":"April 1, 2019","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4417a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a contractor, in an amount that the contractor certifies, using sworn financial statements or other appropriate data, as the amount of wages, salaries, benefits, and other compensation that such contractor paid the employees of such contractor during the period from ","children":[{"tag":"date","attrib":{"date":"2019-04-01"},"text":"April 1, 2019","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa4417b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadlines and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7aa4417c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7aa4417d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms; terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance provided to an air carrier or contractor under this part shall be in such form, on such terms and conditions (including requirements for audits and the clawback of any financial assistance provided upon failure by a passenger air carrier, cargo air carrier, or contractor to honor the assurances specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9074"},"text":"section 9074 of this title","children":[],"tail":"), as the Secretary determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7aa4417e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish streamlined and expedited procedures not later than 5 days after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", for air carriers and contractors to submit requests for financial assistance under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa4417f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for immediate payroll assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 days after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", the Secretary shall make initial payments to air carriers and contractors that submit requests for financial assistance approved by to the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7aa44180-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine an appropriate method for timely distribution of payments to air carriers and contractors with approved requests for financial assistance from any funds remaining available after providing initial financial assistance payments under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44181-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall have the authority to reduce, on a pro rata basis, the amounts due to air carriers and contractors under the applicable paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s9072"},"text":"section 9072 of this title","children":[],"tail":" in order to address any shortfall in assistance that would otherwise be provided under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7aa44182-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9073/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of the Treasury shall audit certifications made under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7aa44183-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIV/s4113"},"text":"Pub. L. 116–136, div. A, title IV, § 4113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/498"},"text":"134 Stat. 498","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
