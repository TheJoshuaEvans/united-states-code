{"tag":"section","attrib":{"id":"id7a939f19-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002"},"text":null,"children":[{"tag":"num","attrib":{"value":"9002"},"text":"§ 9002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entrepreneurial development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a939f1a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f1b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered small business concern” means a small business concern that has experienced, as a result of COVID–19—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f1c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supply chain disruptions, including changes in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f1d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantity and lead time, including the number of shipments of components and delays in shipments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f1e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality, including shortages in supply for quality control reasons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology, including a compromised payment network;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f20-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staffing challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f21-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decrease in gross receipts or customers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f22-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a closure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f23-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “resource partner” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f24-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business development center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f25-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a women’s business center;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f26-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business development center” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f27-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “women’s business center” means a women’s business center described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s656"},"text":"section 656 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f28-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education, training, and advising grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f29-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration may provide financial assistance in the form of grants to resource partners to provide education, training, and advising to covered small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f2a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this subsection shall be used for the education, training, and advising of covered small business concerns and their employees on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f2b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessing and applying for resources provided by the Administration and other Federal resources relating to access to capital and business resiliency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f2c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hazards and prevention of the transmission and communication of COVID–19 and other communicable diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f2d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential effects of COVID–19 on the supply chains, distribution, and sale of products of covered small business concerns and the mitigation of those effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f2e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and practice of telework to reduce possible transmission of COVID–19;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f2f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and practice of remote customer service by electronic or other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f30-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risks of and mitigation of cyber threats in remote customer service or telework practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mitigation of the effects of reduced travel or outside activities on covered small business concerns during COVID–19 or similar occurrences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f32-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant business practices necessary to mitigate the economic effects of COVID–19 or similar occurrences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f33-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f34-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business development centers","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f35-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration shall award 80 percent of funds authorized to carry out this subsection to small business development centers, which shall be awarded pursuant to a formula jointly developed, negotiated, and agreed upon, with full participation of both parties, between the association formed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a/3/A"},"text":"section 648(a)(3)(A) of this title","children":[],"tail":" and the Administration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f36-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards made under clause (i) shall be in addition to, and separate from, any amounts appropriated to make grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s648/a"},"text":"section 648(a) of this title","children":[],"tail":" and such an award may be used to complement and support such a grant, except that priority with respect to the receipt of that assistance shall be given to small business development centers that have been affected by issues described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f37-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Women’s business centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administration shall award 20 percent of funds authorized to carry out this subsection to women’s business centers, which shall be awarded pursuant to a process established by the Administration in consultation with recipients of assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f38-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No matching funds required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Matching funds shall not be required for any grant under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f39-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals and metrics","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f3a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Goals and metrics for the funds made available under this subsection shall be jointly developed, negotiated, and agreed upon, with full participation of both parties, between the resource partners and the Administrator, which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the extent of the circumstances relating to the spread of COVID–19, or similar occurrences, that affect covered small business concerns located in the areas covered by the resource partner, particularly in rural areas or economically distressed areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generally follow the use of funds outlined in paragraph (2), but shall not restrict the activities of resource partners in responding to unique situations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage resource partners to develop and provide services to covered small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make publicly available the methodology by which the Administrator and resource partners jointly develop the metrics and goals described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource partner association grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may provide grants to an association or associations representing resource partners under which the association or associations shall establish a single centralized hub for COVID–19 information, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 online platform that consolidates resources and information available across multiple Federal agencies for small business concerns related to COVID–19; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a training program to educate resource partner counselors, members of the Service Corps of Retired Executives established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/b/1/B"},"text":"section 637(b)(1)(B) of this title","children":[],"tail":", and counselors at veterans business outreach centers described in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657b"},"text":"section 657b of this title","children":[],"tail":" on the resources and information described in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals and metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Goals and metrics for the funds made available under this subsection shall be jointly developed, negotiated, and agreed upon, with full participation of both parties, between the association or associations receiving a grant under this subsection and the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a939f44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2020-03-27"},"text":"March 27, 2020","children":[],"tail":", and annually thereafter, the Administrator shall submit to the Committee on Small Business and Entrepreneurship of the Senate and the Committee on Small Business of the House of Representatives a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a939f45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the initial year covered by the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs and services developed and provided by the Administration and resource partners under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial efforts to provide those services under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the online platform and training developed and provided by the Administration and the association or associations under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a939f49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the subsequent years covered by the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a939f4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the grant program under subsection (b)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Administrator and resource partners to develop services to assist covered small business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f4c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the challenges faced by owners of covered small business concerns in accessing services provided by the Administration and resource partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f4d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of unique covered small business concerns that were served by the Administration and resource partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f4e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant outcome performance data with respect to covered small business concerns, including the number of employees affected, the effect on sales, the disruptions of supply chains, and the efforts made by the Administration and resource partners to mitigate these effects; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a939f4f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the grant program under subsection (c)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a939f50-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Administrator and the association or associations to develop and evolve an online resource for small business concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a939f51-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9002/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Administrator and the association or associations to develop a training program for resource partner counselors, including the number of counselors trained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a939f52-552d-11f1-9071-ff305b7c