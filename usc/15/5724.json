{"tag":"section","attrib":{"id":"id7a50f16b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724"},"text":null,"children":[{"tag":"num","attrib":{"value":"5724"},"text":"§ 5724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a50f16c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “telephone-billed purchase” means any purchase that is completed solely as a consequence of the completion of the call or a subsequent dialing, touch tone entry, or comparable action of the caller. Such term does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f16d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a purchase by a caller pursuant to a preexisting agreement with the vendor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f16e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" local exchange telephone services or interexchange telephone services or any service that the Federal Communications Commission determines, by rule—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7a50f16f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is closely related to the provision of local exchange telephone services or interexchange telephone services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7a50f170-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to billing dispute resolution procedures required by Federal or State statute or regulation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f171-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of goods or services which is otherwise subject to billing dispute resolution procedures required by Federal statute or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f172-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A “billing error” consists of any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a50f173-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reflection on a billing statement for a telephone-billed purchase which was not made by the customer or, if made, was not in the amount reflected on such statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f174-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reflection on a billing statement of a telephone-billed purchase for which the customer requests additional clarification, including documentary evidence thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f175-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reflection on a billing statement of a telephone-billed purchase that was not accepted by the customer or not provided to the customer in accordance with the stated terms of the transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f176-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reflection on a billing statement of a telephone-billed purchase for a call made to an 800 or other toll free telephone number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f177-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure to reflect properly on a billing statement a payment made by the customer or a credit issued to the customer with respect to a telephone-billed purchase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f178-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A computation error or similar error of an accounting nature on a statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f179-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to transmit the billing statement to the last known address of the customer, unless that address was furnished less than twenty days before the end of the billing cycle for which the statement is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a50f17a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other error described in regulations prescribed by the Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f17b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commission” means the Federal Trade Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f17c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “providing carrier” means a local exchange or interexchange common carrier providing telephone services (other than local exchange services) to a vendor for a telephone-billed purchase that is the subject of a billing error complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f17d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “vendor” means any person who, through the use of the telephone, offers goods or services for a telephone-billed purchase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a50f17e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s5724/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “customer” means any person who acquires or attempts to acquire goods or services in a telephone-billed purchase.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7a50f17f-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/556/tIII/s304"},"text":"Pub. L. 102–556, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4193"},"text":"106 Stat. 4193","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
