{"tag":"section","attrib":{"id":"id793c4ca2-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s715h"},"text":null,"children":[{"tag":"num","attrib":{"value":"715h"},"text":"§ 715h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and investigation by boards; appointment of board and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id793c4ca3-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s715h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any board established under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s715d"},"text":"section 715d of this title","children":[],"tail":", and any agency designated under authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s715j"},"text":"section 715j of this title","children":[],"tail":", may hold and conduct such hearings, investigations, and proceedings as may be necessary for the purposes of this chapter, and for such purposes those provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78u"},"text":"section 78u of this title","children":[],"tail":" relating to the administering of oaths and affirmations, and to the attendance and testimony of witnesses and the production of evidence (including penalties), shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id793c4ca4-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s715h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of any board established under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s715d"},"text":"section 715d of this title","children":[],"tail":" shall be appointed by the President, subject to chapter 51 and subchapter III of chapter 53 of title 5; and any such board may appoint, subject to chapter 51 and subchapter III of chapter 53 of title 5, such employees as may be necessary for the execution of its functions under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id793c4ca5-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-02-22/ch18/s9"},"text":"Feb. 22, 1935, ch. 18, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/33"},"text":"49 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id793c4ca6-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id793c4ca7-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id793c4ca8-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of subsec. (b) that authorized appointments “without regard to the civil service laws” omitted as obsolete and superseded. Such appointments are now subject to the civil service laws unless specifically excepted by those laws or by laws enacted subsequent to Executive Order 8743, ","children":[{"tag":"date","attrib":{"date":"1941-04-23"},"text":"Apr. 23, 1941","children":[],"tail":", issued by the President pursuant to the "},{"tag":"ref","attrib":{"href":"/us/act/1940-11-26/ch919/tI/s1"},"text":"Act of Nov. 26, 1940, ch. 919, title I, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1211"},"text":"54 Stat. 1211","children":[],"tail":", which covered most excepted positions into the classified (competitive) civil service. The Order is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3301"},"text":"section 3301 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Chapter 51 and subchapter III of chapter 53 of title 5” substituted in subsec. (b) for “the Classification Act of 1949, as amended” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id793c4ca9-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1949—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1949-10-28"},"text":"Oct. 28, 1949","children":[],"tail":", substituted “Classification Act of 1949” for “Classification Act of 1923”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id793c4caa-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeal