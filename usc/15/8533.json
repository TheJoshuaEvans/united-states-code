{"tag":"section","attrib":{"id":"id7a8a2964-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8533"},"text":null,"children":[{"tag":"num","attrib":{"value":"8533"},"text":"§ 8533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unnecessary duplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In meeting the requirements under this subchapter, the Under Secretary shall avoid unnecessary duplication between public and private sources of data and the corresponding expenditure of funds and employment of personnel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a8a2965-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/25/tIII/s303"},"text":"Pub. L. 115–25, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-04-18"},"text":"Apr. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/105"},"text":"131 Stat. 105","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
