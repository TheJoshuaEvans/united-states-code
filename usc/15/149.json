{"tag":"section","attrib":{"id":"id78849529-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s149"},"text":null,"children":[{"tag":"num","attrib":{"value":"149"},"text":"§ 149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The bylaws may provide—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7884952a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s149/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The time, place, manner of calling, giving notice, and conduct of, and determination of a quorum for, the meetings, annual or special, of the stockholders or directors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7884952b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s149/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number, qualifications, and manner of choosing and fixing the tenure of office and compensation of all directors; but the number of such directors shall be not less than three, and a majority of the directors, and the president and the treasurer, or each officer holding a corresponding office, shall, during their tenure of office, be citizens of the United States resident in China.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7884952c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s149/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner of calling for and collecting payments upon shares of stock, the penalties and forfeitures for nonpayment, the preparation of certificates of the shares, the manner of recording their sale or transfer, and the manner of their representation at stockholders’ meetings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7884952d-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch346/s9"},"text":"Sept. 19, 1922, ch. 346, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/852"},"text":"42 Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-26/ch345/s8"},"text":"Feb. 26, 1925, ch. 345, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/996"},"text":"43 Stat. 996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7884952e-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7884952f-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id78849530-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1925—Par. (b). Act ","children":[{"tag":"date","attrib":{"date":"1925-02-26"},"text":"Feb. 26, 1925","children":[],"tail":", amended par. (b) generally."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
