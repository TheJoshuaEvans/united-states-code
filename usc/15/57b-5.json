{"tag":"section","attrib":{"id":"id77d1c067-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"57b–5"},"text":"§ 57b–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural cooperatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77d1c068-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall not have any authority to conduct any study, investigation, or prosecution of any agricultural cooperative for any conduct which, because of the provisions of sections 291 and 292 of title 7, is not a violation of any of the antitrust Acts or this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77d1c069-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s57b–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall not have any authority to conduct any study or investigation of any agricultural marketing orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77d1c06a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-09-26/ch311/s24"},"text":"Sept. 26, 1914, ch. 311, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/312/s2"},"text":"Pub. L. 103–312, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1691"},"text":"108 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77d1c06b-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id77d1c06c-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id77d1c06d-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 24 of act ","children":[{"tag":"date","attrib":{"date":"1914-09-26"},"text":"Sept. 26, 1914","children":[],"tail":", was renumbered section 25 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s57c"},"text":"section 57c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
