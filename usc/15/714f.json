{"tag":"section","attrib":{"id":"id7939db1f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s714f"},"text":null,"children":[{"tag":"num","attrib":{"value":"714f"},"text":"§ 714f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Corporation is authorized to use in the conduct of its business all its funds and other assets, including capital and net earnings therefrom, and all funds and other assets which have been or may hereafter be transferred or allocated to, borrowed by, or otherwise acquired by it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7939db20-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-29/ch704/s8"},"text":"June 29, 1948, ch. 704, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1072"},"text":"62 Stat. 1072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7939db21-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id7939db22-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7939db23-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exceptions From Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For exception of functions of corporations of Department of Agriculture from transfer of functions to Secretary of Agriculture by Reorg. Plan No. 2 of 1953, see Exceptions From Transfer of Functions note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s712a"},"text":"section 712a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
