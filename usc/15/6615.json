{"tag":"section","attrib":{"id":"id7a5cd878-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s6615"},"text":null,"children":[{"tag":"num","attrib":{"value":"6615"},"text":"§ 6615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect the applicability of any State law that provides stricter limits on damages and liabilities, affording greater protection to defendants in Y2K actions, than are provided in this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a5cd879-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/37/s16"},"text":"Pub. L. 106–37, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-07-20"},"text":"July 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/202"},"text":"113 Stat. 202","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
