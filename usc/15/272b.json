{"tag":"section","attrib":{"id":"id788e3226-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s272b"},"text":null,"children":[{"tag":"num","attrib":{"value":"272b"},"text":"§ 272b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual budget submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The National Institute of Standards and Technology shall annually submit to the Congress, at the time of the release of the President’s budget, a three year budget estimate for the Institute, including funding estimates for each major account and new initiative.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id788e3227-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/519/tI/s111"},"text":"Pub. L. 100–519, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2592"},"text":"102 Stat. 2592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id788e3228-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id788e3229-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id788e322a-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Institute of Standards and Technology Authorization Act for Fiscal Year 1989, and not as part of the National Institute of Standards and Technology Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
