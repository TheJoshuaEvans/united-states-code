{"tag":"section","attrib":{"id":"id7ab29946-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9572"},"text":null,"children":[{"tag":"num","attrib":{"value":"9572"},"text":"§ 9572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition and term","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7ab29947-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall be composed of 9 members of the private sector and 1 representative from each of not fewer than 10 Federal agencies that support or otherwise have duties that relate to business formation, including duties relating to labor development, monetary policy, national security, energy, agriculture, transportation, and housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29948-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall designate 1 of the private sector members of the Council as the Chair of the Council for a 1-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7ab29949-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s9572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall meet at the request of the Under Secretary and members shall serve for a term of 2 years. Members of the Council may be reappointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7ab2994a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dK/tV/s100502"},"text":"Pub. L. 117–58, div. K, title V, § 100502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1463"},"text":"135 Stat. 1463","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
