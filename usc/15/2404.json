{"tag":"section","attrib":{"id":"id79ecb165-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2404"},"text":null,"children":[{"tag":"num","attrib":{"value":"2404"},"text":"§ 2404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id79ecb166-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2404/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Center” means the National Center for Productivity and Quality of Working Life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ecb167-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2404/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Board of Directors of the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ecb168-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2404/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “productivity growth” and “improved productivity” shall be interpreted to include, but not be limited to, improvements in technology, management techniques, and the quality of working life; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id79ecb169-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2404/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “quality of working life” shall be interpreted to mean the conditions of work relating to the role of the worker in the production process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id79ecb16a-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/136/tI/s104"},"text":"Pub. L. 94–136, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/735"},"text":"89 Stat. 735","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
