{"tag":"section","attrib":{"id":"id77d8ec31-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s70k"},"text":null,"children":[{"tag":"num","attrib":{"value":"70k"},"text":"§ 70k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall be held to be in addition to, and not in substitution for or limitation of, the provisions of any other Act of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id77d8ec32-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/897/s14"},"text":"Pub. L. 85–897, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1724"},"text":"72 Stat. 1724","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
