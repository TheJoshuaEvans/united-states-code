{"tag":"section","attrib":{"id":"id7a912e3b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851"},"text":null,"children":[{"tag":"num","attrib":{"value":"8851"},"text":"§ 8851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantum information science research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7a912e3c-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall carry out a basic research program on quantum information science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7a912e3d-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary of Energy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7a912e3e-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate goals for quantum information science research to be supported by the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e3f-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage the collective body of knowledge from existing quantum information science research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e40-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide research experiences and training for additional undergraduate and graduate students in quantum information science, including in the fields of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e41-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum information theory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e42-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum physics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e43-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum computational science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e44-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied mathematics and algorithm development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e45-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum networking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e46-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantum sensing and detection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e47-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials science and engineering;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7a912e48-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate research efforts funded through existing programs across the Department of Energy, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7a912e49-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nanoscale Science Research Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e4a-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Energy Frontier Research Centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7a912e4b-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s8851/b/4/C"},"te