{"tag":"section","attrib":{"id":"id7a06f044-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s2683"},"text":null,"children":[{"tag":"num","attrib":{"value":"2683"},"text":"§ 2683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of dangerous levels of lead","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within 18 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", the Administrator shall promulgate regulations which shall identify, for purposes of this subchapter and the Residential Lead-Based Paint Hazard Reduction Act of 1992 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4851"},"text":"42 U.S.C. 4851","children":[],"tail":" et seq.], lead-based paint hazards, lead-contaminated dust, and lead-contaminated soil."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7a06f045-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469/tIV/s403"},"text":"Pub. L. 94–469, title IV, § 403","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1021/a"},"text":"Pub. L. 102–550, title X, § 1021(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3916"},"text":"106 Stat. 3916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7a06f046-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7a06f047-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7a06f048-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Residential Lead-Based Paint Hazard Reduction Act of 1992, referred to in text, is title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3897"},"text":"106 Stat. 3897","children":[],"tail":", which is classified principally to chapter 63A (§ 4851 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4851"},"text":"section 4851 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
