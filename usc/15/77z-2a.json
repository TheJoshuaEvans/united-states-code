{"tag":"section","attrib":{"id":"id77e9b5d5-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a"},"text":null,"children":[{"tag":"num","attrib":{"value":"77z–2a"},"text":"§ 77z–2a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest relating to certain securitizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id77e9b5d6-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An underwriter, placement agent, initial purchaser, or sponsor, or any affiliate or subsidiary of any such entity, of an asset-backed security (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of this title","children":[],"tail":", which for the purposes of this section shall include a synthetic asset-backed security), shall not, at any time for a period ending on the date that is one year after the date of the first closing of the sale of the asset-backed security, engage in any transaction that would involve or result in any material conflict of interest with respect to any investor in a transaction arising out of such activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5d7-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", the Commission shall issue rules for the purpose of implementing subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77e9b5d8-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibitions of subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id77e9b5d9-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk-mitigating hedging activities in connection with positions or holdings arising out of the underwriting, placement, initial purchase, or sponsorship of an asset-backed security, provided that such activities are designed to reduce the specific risks to the underwriter, placement agent, initial purchaser, or sponsor associated with positions or holdings arising out of such underwriting, placement, initial purchase, or sponsorship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id77ebfeca-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" purchases or sales of asset-backed securities made pursuant to and consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id77ebfecb-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commitments of the underwriter, placement agent, initial purchaser, or sponsor, or any affiliate or subsidiary of any such entity, to provide liquidity for the asset-backed security, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id77ebfecc-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bona fide market-making in the asset backed security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id77ebfecd-552d-11f1-9071-ff305b7c3ff0","identifier":"/us/usc/t15/s77z–2a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" shall not otherwise limit the application of section 78"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–11 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id77ebfece-552d-11f1-9071-ff305b7c3ff0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"May 27, 1933, ch. 38","children":[],"tail":", title I, § 27B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s621/a"},"text":"Pub. L. 111–203, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1631"},"text":"124 Stat. 1631","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id77ebfecf-552d-11f1-9071-ff305b7c3ff0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id77ebfed0-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id77ebfed1-552d-11f1-9071-ff305b7c3ff0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVI/s621/b"},"text":"Pub. L. 111–203, title VI, § 621(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1632"},"text":"124 Stat. 1632","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/203/tVI/s621/b"},"text":"“Section 27B of the Securities Act of 1933 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77z–2a"},"text":"15 U.S.C. 77z–2a","children":[],"tail":"], as added by this section, shall take effect on the effective date of final rules issued by the [Securities and Exchange] Commission under subsection (b) of such section 27B, except that subsections (b) and (d) of such section 27B shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
