{"tag":"section","attrib":{"id":"idf182f8a8-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s219"},"text":null,"children":[{"tag":"num","attrib":{"value":"219"},"text":"§ 219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction proceedings; compromise of liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf182f8a9-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s219/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The several district courts of the United States are vested with jurisdiction, for cause shown, to prevent and restrain violations of this subchapter upon the application of the Attorney General of the United States acting through the several United States attorneys in their several districts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf185429a-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s219/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized, with respect to any violation of this subchapter, to compromise the liability arising with respect to such violation upon payment of a sum for each offense, to be collected by the Secretary and to be paid into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf185429b-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"Aug. 29, 1935, ch. 814","children":[],"tail":", title II, § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVIII/s8001/a/3"},"text":"Pub. L. 100–690, title VIII, § 8001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4520"},"text":"102 Stat. 4520","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
