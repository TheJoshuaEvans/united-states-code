{"tag":"section","attrib":{"id":"idf17e15d2-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124"},"text":null,"children":[{"tag":"num","attrib":{"value":"124"},"text":"§ 124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct shipment of wine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf17e15d3-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for transporting certain wine","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During any period in which the Federal Aviation Administration has in effect restrictions on airline passengers to ensure safety, the direct shipment of wine shall be permitted from States where wine is purchased from a winery, to another State or the District of Columbia, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17e15d4-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wine was purchased while the purchaser was physically present at the winery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e15d5-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchaser of the wine provided the winery verification of legal age to purchase alcohol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e15d6-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipping container in which the wine is shipped is marked to require an adult’s signature upon delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e15d7-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wine is for personal use only and not for resale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e15d8-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchaser could have carried the wine lawfully into the State or the District of Columbia to which the wine is shipped.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17e15d9-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any person fails to meet any of the conditions under subsection (a), the attorney general of any State may bring a civil action under the same terms as those set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s122a"},"text":"section 122a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17e15da-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2002-11-02"},"text":"November 2, 2002","children":[],"tail":", and at 2-year intervals thereafter, the Attorney General of the United States, in consultation with the Administrator of the Federal Aviation Administration, shall prepare and submit to the Committee on the Judiciary of the Senate and to the Committee on the Judiciary of the House of Representatives a report on the implementation of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf17e15db-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11022"},"text":"Pub. L. 107–273, div. C, title I, § 11022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1829"},"text":"116 Stat. 1829","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
