{"tag":"section","attrib":{"id":"idf182f8a2-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s216"},"text":null,"children":[{"tag":"num","attrib":{"value":"216"},"text":"§ 216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No statement relating to alcoholic beverages and health, other than the statement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s215"},"text":"section 215 of this title","children":[],"tail":", shall be required under State law to be placed on any container of an alcoholic beverage, or on any box, carton, or other package, irrespective of the material from which made, that contains such a container."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf182f8a3-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"Aug. 29, 1935, ch. 814","children":[],"tail":", title II, § 205, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVIII/s8001/a/3"},"text":"Pub. L. 100–690, title VIII, § 8001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4520"},"text":"102 Stat. 4520","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
