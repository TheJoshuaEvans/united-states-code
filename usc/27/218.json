{"tag":"section","attrib":{"id":"idf182f8a6-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s218"},"text":null,"children":[{"tag":"num","attrib":{"value":"218"},"text":"§ 218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who violates the provisions of this subchapter shall be subject to a civil penalty of not more than $10,000, and each day shall constitute a separate offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf182f8a7-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"Aug. 29, 1935, ch. 814","children":[],"tail":", title II, § 207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVIII/s8001/a/3"},"text":"Pub. L. 100–690, title VIII, § 8001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4520"},"text":"102 Stat. 4520","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
