{"tag":"section","attrib":{"id":"idf17bccac-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a"},"text":null,"children":[{"tag":"num","attrib":{"value":"122a"},"text":"§ 122a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctive relief in Federal district court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf17bccad-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17bccae-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “attorney general” means the attorney general or other chief law enforcement officer of a State or the designee thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccaf-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intoxicating liquor” means any spirituous, vinous, malted, fermented, or other intoxicating liquor of any kind;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccb0-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means any individual and any partnership, corporation, company, firm, society, association, joint stock company, trust, or other entity capable of holding a legal or beneficial interest in property, but does not include a State or agency thereof; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccb1-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17bccb2-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by State attorney general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the attorney general has reasonable cause to believe that a person is engaged in, or has engaged in, any act that would constitute a violation of a State law regulating the importation or transportation of any intoxicating liquor, the attorney general may bring a civil action in accordance with this section for injunctive relief (including a preliminary or permanent injunction) against the person, as the attorney general determines to be necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17bccb3-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrain the person from engaging, or continuing to engage, in the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccb4-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce compliance with the State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17bccb5-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17bccb6-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction over any action brought under this section by an attorney general against any person, except one licensed or otherwise authorized to produce, sell, or store intoxicating liquor in such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccb7-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action under this section may be brought only in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of title 28","children":[],"tail":" or in the district in which the recipient of the intoxicating liquor resides or is found."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccb8-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action under this section is limited to actions seeking injunctive relief (a preliminary and/or permanent injunction).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccb9-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No right to jury trial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action under this section shall be tried before the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17bccba-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for injunctions and orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17bccbb-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action brought under this section, upon a proper showing by the attorney general of the State, the court may issue a preliminary or permanent injunction to restrain a violation of this section. A proper showing under this paragraph shall require that a State prove by a preponderance of the evidence that a violation of State law as described in subsection (b) has taken place or is taking place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccbc-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional showing for preliminary injunction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No preliminary injunction may be granted except upon—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf17bccbd-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence demonstrating the probability of irreparable injury if injunctive relief is not granted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf17bccbe-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence supporting the probability of success on the merits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccbf-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No preliminary or permanent injunction may be issued under paragraph (1) without notice to the adverse party and an opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccc0-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and scope of order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any preliminary or permanent injunction entered in an action brought under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf17bccc1-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the reasons for the issuance of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf17bccc2-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be specific in terms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf17bccc3-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe in reasonable detail, and not by reference to the complaint or other document, the act or acts sought to be restrained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf17bccc4-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be binding upon—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf17bccc5-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties to the action and the officers, agents, employees, and attorneys of those parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf17bccc6-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons in active concert or participation with the parties to the action who receive actual notice of the order by personal service or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccc7-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admissibility of evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a hearing on an application for a permanent injunction, any evidence previously received on an application for a preliminary injunction in connection with the same civil action and that would otherwise be admissible, may be made a part of the record of the hearing on the permanent injunction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17bccc8-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall be construed only to extend the jurisdiction of Federal courts in connection with State law that is a valid exercise of power vested in the States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17bccc9-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the twenty-first article of amendment to the Constitution of the United States as such article of amendment is interpreted by the Supreme Court of the United States including interpretations in conjunction with other provisions of the Constitution of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bccca-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s122"},"text":"section 122 of this title","children":[],"tail":" as such section is interpreted by the Supreme Court of the United States; but shall not be construed to grant to States any additional power."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17bcccb-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional remedies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17bcccc-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A remedy under this section is in addition to any other remedies provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17bcccd-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s122a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State court proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to prohibit an authorized State official from proceeding in State court on the basis of an alleged violation of any State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf17bccce-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-01/ch90/s2"},"text":"Mar. 1, 1913, ch. 90, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dC/s2004/a"},"text":"Pub. L. 106–386, div. C, § 2004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1546"},"text":"114 Stat. 1546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf17bcccf-d790-11f0-bdae-a8987afac842"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf17bccd0-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf17bccd1-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dC/s2004/b"},"text":"Pub. L. 106–386, div. C, § 2004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1548"},"text":"114 Stat. 1548","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/386/dC/s2004/b"},"text":"“This section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s122b"},"text":"section 122b of this title","children":[],"tail":" and provisions set out as a note under this section] and the amendments made by this section shall become effective 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf17bccd2-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Impact Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dC/s2004/c"},"text":"Pub. L. 106–386, div. C, § 2004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1548"},"text":"114 Stat. 1548","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/386/dC/s2004/c"},"text":"“The Attorney General shall carry out the study to determine the impact of this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s122b"},"text":"section 122b of this title","children":[],"tail":" and provisions set out as a note under this section] and shall submit the results of such study not later than 180 days after the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
