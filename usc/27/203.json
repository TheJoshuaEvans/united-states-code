{"tag":"section","attrib":{"id":"idf17e1601-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203"},"text":null,"children":[{"tag":"num","attrib":{"value":"203"},"text":"§ 203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful businesses without permit; application to State agency","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order effectively to regulate interstate and foreign commerce in distilled spirits, wine, and malt beverages, to enforce the twenty-first amendment, and to protect the revenue and enforce the postal laws with respect to distilled spirits, wine, and malt beverages:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf17e1602-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful, except pursuant to a basic permit issued under this subchapter by the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17e1603-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in the business of importing into the United States distilled spirits, wine, or malt beverages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e1604-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person so engaged to sell, offer or deliver for sale, contract to sell, or ship, in interstate or foreign commerce, directly or indirectly or through an affiliate, distilled spirits, wine, or malt beverages so imported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17e1605-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful, except pursuant to a basic permit issued under this subchapter by the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17e1606-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in the business of distilling distilled spirits, producing wine, rectifying or blending distilled spirits or wine, or bottling, or warehousing and bottling, distilled spirits; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e1607-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person so engaged to sell, offer or deliver for sale, contract to sell, or ship, in interstate or foreign commerce, directly or indirectly or through an affiliate, distilled spirits or wine so distilled, produced, rectified, blended, or bottled, or warehoused and bottled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf17e1608-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful, except pursuant to a basic permit issued under this subchapter by the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf17e1609-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in the business of purchasing for resale at wholesale distilled spirits, wine, or malt beverages; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf17e160a-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person so engaged to receive or to sell, offer or deliver for sale, contract to sell, or ship, in interstate or foreign commerce, directly or indirectly or through an affiliate, distilled spirits, wine, or malt beverages so purchased.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall take effect ","children":[{"tag":"date","attrib":{"date":"1936-07-01"},"text":"July 1, 1936","children":[],"tail":"."}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This section shall not apply to any agency of a State or political subdivision thereof or any officer or employee of any such agency, and no such agency or officer or employee shall be required to obtain a basic permit under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf17e160b-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"Aug. 29, 1935, ch. 814","children":[],"tail":", title I, § 103, formerly § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/49/978"},"text":"49 Stat. 978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-02-29/ch105/s1"},"text":"Feb. 29, 1936, ch. 105, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1152"},"text":"49 Stat. 1152","children":[],"tail":"; 1940 Reorg. Plan No. III, § 2, eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", 5 F.R. 2108, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1232"},"text":"54 Stat. 1232","children":[],"tail":"; renumbered title I, § 103, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVIII/s8001/a/1"},"text":"Pub. L. 100–690, title VIII, § 8001(a)(1)","children":[],"tail":", (2), (b)(2), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4517"},"text":"102 Stat. 4517","children":[],"tail":", 4521.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf17e160c-d790-11f0-bdae-a8987afac842"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf17e160d-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf17e160e-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the original, subsections (a) and (b) of this section contained a final paragraph which provided as follows: “This subsection shall take effect sixty days after the date upon which the Administrator first appointed under this title takes office.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf17e160f-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s8001/b/2"},"text":"Pub. L. 100–690, § 8001(b)(2)","children":[],"tail":", substituted “subchapter” for “chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1936—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1936-02-29"},"text":"Feb. 29, 1936","children":[],"tail":", extended the effective date from "},{"tag":"date","attrib":{"date":"1936-03-01"},"text":"March 1, 1936","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1936-07-01"},"text":"July 1, 1936","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idf17e1610-d790-11f0-bdae-a8987afac842"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf17e1611-d790-11f0-bdae-a8987afac842"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of the Treasury” was substituted in text for “Administrator”, meaning the Administrator of the Federal Alcohol Administration, pursuant to Reorg. Plan No. III of 1940, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t27/s201"},"text":"section 201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
