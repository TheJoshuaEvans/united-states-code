{"tag":"section","attrib":{"id":"idf185429c-d790-11f0-bdae-a8987afac842","identifier":"/us/usc/t27/s219a"},"text":null,"children":[{"tag":"num","attrib":{"value":"219a"},"text":"§ 219a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this subchapter or the application thereof to any person or circumstance is held invalid, the validity of the remainder of this subchapter and this chapter and of the application of such provision to other persons and circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf185429d-d790-11f0-bdae-a8987afac842"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch814"},"text":"Aug. 29, 1935, ch. 814","children":[],"tail":", title II, § 209, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVIII/s8001/a/3"},"text":"Pub. L. 100–690, title VIII, § 8001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4521"},"text":"102 Stat. 4521","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
