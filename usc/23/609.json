{"tag":"section","attrib":{"id":"id2ec0a0f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ec0a0f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2012-06-01"},"text":"June 1, 2012","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to Congress a report summarizing the financial performance of the projects that are receiving, or have received, assistance under the TIFIA program, including a recommendation as to whether the objectives of the TIFIA program are best served by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing the program under the authority of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a Federal corporation or federally sponsored enterprise to administer the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" phasing out the program and relying on the capital markets to fund the types of infrastructure investments assisted by the TIFIA program without Federal participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application Process Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-12-01"},"text":"December 1, 2012","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report that includes a list of all of the letters of interest and applications received from project sponsors for assistance under the TIFIA program during the preceding fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a0f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall include, at a minimum, a description of, with respect to each letter of interest and application included in the report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec0a0fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the letter of interest or application was received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec0a0fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a notification was provided to the project sponsor regarding whether the application was complete or incomplete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec311fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a revised and completed application was submitted (if applicable);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec311fd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a notification was provided to the project sponsor regarding whether the project was approved or disapproved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec311fe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the project was not approved, the reason for the disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec311ff-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Correspondence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report under paragraph (1) shall include copies of any correspondence provided to the project sponsor in accordance with section 602(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec31200-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec31201-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall publish on the website for the TIFIA program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31202-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a monthly basis, a current status report on all submitted letters of interest and applications received for assistance under the TIFIA program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31203-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a quarterly basis, a current status report on all approved applications for assistance under the TIFIA program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec31204-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each monthly and quarterly status report under paragraph (1) shall include, at a minimum, with respect to each project included in the status report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31205-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the party submitting the letter of interest or application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31206-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31207-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the letter of interest or application was received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31208-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated project eligible costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31209-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of credit assistance sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3120a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s609/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated fiscal year and quarter for closing of the credit assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ec3120b-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1503/a"},"text":"Pub. L. 105–178, title I, § 1503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/250"},"text":"112 Stat. 250","children":[],"tail":