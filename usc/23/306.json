{"tag":"section","attrib":{"id":"id2e8e93db-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mapping","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e8e93dc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the provisions of this title, the Secretary shall, wherever practicable, authorize the use of photogrammetric methods in mapping, and the utilization of commercial enterprise for such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e93dd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue guidance to encourage States to utilize, to the maximum extent practicable, private sector sources for surveying and mapping services for projects under this title. In carrying out this subsection, the Secretary shall recommend appropriate roles for State government and private mapping and surveying activities, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8e93de-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of standards and specifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e93df-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research in surveying and mapping instrumentation and procedures and technology transfer to the private sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e93e0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical guidance, coordination, and administration of State surveying and mapping activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e93e1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending methods for increasing the use by the States of private sector sources for surveying and mapping activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e93e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop a process for the oversight and monitoring, on an annual basis, of the compliance of each State with the guidance issued under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e8e93e3-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":