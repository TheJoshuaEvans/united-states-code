{"tag":"section","attrib":{"id":"id2e7df2b5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174"},"text":null,"children":[{"tag":"num","attrib":{"value":"174"},"text":"§ 174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State human capital plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e7df2b6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this section, the Secretary shall encourage each State to develop a voluntary plan, to be known as a “human capital plan”, that provides for the immediate and long-term personnel and workforce needs of the State with respect to the capacity of the State to deliver transportation and public infrastructure eligible under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2b7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Contents.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df2b8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A human capital plan developed by a State under subsection (a) shall, to the maximum extent practicable, take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df2b9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant transportation workforce trends, needs, issues, and challenges with respect to the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2ba-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the human capital policies, strategies, and performance measures that will guide the transportation-related workforce investment decisions of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2bb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with educational institutions, industry, organized labor, workforce boards, and other agencies or organizations to address the human capital transportation needs of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2bc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a workforce planning strategy that identifies current and future human capital needs, including the knowledge, skills, and abilities needed to recruit and retain skilled workers in the transportation industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2bd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a human capital management strategy that is aligned with the transportation mission, goals, and organizational objectives of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2be-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation system for workforce goals focused on addressing continuity of leadership and knowledge sharing across the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2bf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an implementation system that addresses workforce competency gaps, particularly in mission-critical occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2c0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of public-private partnerships or other alternative project delivery methods to carry out the transportation program of the State, a description of workforce needs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df2c1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the transportation mission, goals, and organizational objectives of the State are fully carried out; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df2c2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that procurement methods provide the best public value;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2c3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system for analyzing and evaluating the performance of the State department of transportation with respect to all aspects of human capital management policies, programs, and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2c4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the plan will improve the ability of the State to meet the national policy in support of performance management established under section 150.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2c5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a State develops a human capital plan under subsection (a), the plan shall address a 5-year forecast period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2c6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a State develops a human capital plan under subsection (a), the State shall update the plan not less frequently than once every 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2c7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Long-range Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df2c8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), a human capital plan developed by a State under subsection (a) may be developed separately from, or incorporated into, the long-range statewide transportation plan required under section 135.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2c9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of section","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section requires a State, or authorizes the Secretary to require a State, to incorporate a human capital plan into the long-range statewide transportation plan required under section 135.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2ca-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State that develops a human capital plan under subsection (a) shall make a copy of the plan available to the public in a user-friendly format on the website of the State department of transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2cb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section prevents a State from carrying out transportation workforce planning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df2cc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not described in this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2cd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s174/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7df2ce-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11203/a"},"text":"Pub. L. 117–58, div. A, title I, § 11203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/519"},"text":"135 Stat. 519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e7df2cf-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e7df2d0-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e7df2d1-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7df2d2-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e7df2d3-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
