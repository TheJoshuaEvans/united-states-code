{"tag":"section","attrib":{"id":"id2e910547-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s316"},"text":null,"children":[{"tag":"num","attrib":{"value":"316"},"text":"§ 316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent by United States to conveyance of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this title the consent of the United States is given to any railroad or canal company to convey to the State transportation department of any State, or its nominee, any part of its right-of-way or other property in that State acquired by grant from the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2e910548-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/915"},"text":"72 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1212/a/2/A/i"},"text":"Pub. L. 105–178, title I, § 1212(a)(2)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/193"},"text":"112 Stat. 193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e910549-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e91054a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e91054b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “State transportation department” for “State highway department”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
