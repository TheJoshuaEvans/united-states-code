 title I, § 1104(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1332"},"text":"129 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e63b351-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e63b352-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e63b353-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4481 of the Internal Revenue Code of 1986, referred to in subsec. (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s4481"},"text":"section 4481 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e63b354-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 141, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/495/s35/a"},"text":"Pub. L. 90–495, § 35(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-23"},"text":"Aug. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/836"},"text":"82 Stat. 836","children":[],"tail":", related to real property acquisition policies, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/646/tIII/s306"},"text":"Pub. L. 91–646, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1907"},"text":"84 Stat. 1907","children":[],"tail":", such repeal becoming effective as to all States after "},{"tag":"date","attrib":{"date":"1972-07-01"},"text":"July 1, 1972","children":[],"tail":", the date on which sections 4630 and 4655 of Title 42, The Public Health and Welfare, covering similar subject matter, became applicable to all States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e63b355-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “paragraphs (1) through (6) of section 104(b)” for “paragraphs (1) through (5) of section 104(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1404/c"},"text":"Pub. L. 112–141, § 1404(c)","children":[],"tail":", substituted “7 percent” for “10 per centum” and “paragraphs (1) through (5) of section 104(b)” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1404/d"},"text":"Pub. L. 112–141, § 1404(d)","children":[],"tail":", substituted “section 104(b)(1)” for “section 104(b)(4)” in two places and substituted “8 percent” for “25 per centum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “section 104(b)(4)” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b/5"},"text":"section 104(b)(5) of this title","children":[],"tail":"” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59"},"text":"Pub. L. 104–59","children":[],"tail":" redesignated subsecs. (b) to (d) as (a) to (c), respectively, and struck out former subsec. (a) which read as follows: “Each State shall certify to the Secretary before January 1 of each year that it is enforcing all speed limits on public highways in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s154"},"text":"section 154 of this title","children":[],"tail":". The Secretary shall not approve any project under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s106"},"text":"section 106 of this title","children":[],"tail":" in any State which has failed to certify in accordance with this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31112"},"text":"section 31112 of title 49","children":[],"tail":"” for “section 411(j) of the Surface Transportation Assistance Act of 1982 (49 U.S.C. App. 2311(j))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" inserted at end “Each State shall also certify that it is enforcing and complying with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s127/d"},"text":"section 127(d) of this title","children":[],"tail":" and section 411(j) of the Surface Transportation Assistance Act of 1982 (49 U.S.C. App. 2311(j)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/599"},"text":"Pub. L. 95–599","children":[],"tail":" designated existing provisions as subsecs. (a) and (b) and added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e63b356-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e63b357-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e63b358-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e63b359-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59/tII/s205/d/3"},"text":"Pub. L. 104–59, title II, § 205(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/577"},"text":"109 Stat. 577","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/59/tII/s205/d/3"},"text":"“The amendments made by paragraph (1) [amending this section and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s154"},"text":"section 154 of this title","children":[],"tail":"] shall be applicable to a State on the 10th day following the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":"]; except that if the legislature of a State is not in session on such date of enactment and the chief executive officer of the State declares, before such 10th day, that the legislature is not in session and that the State prefers an applicability date for such amendments that is after the date on which the legislature will convene, such amendments shall be applicable to the State on the 60th day following the date on which the legislature next convenes.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e63b35a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", and applicable to funds authorized to be appropriated or made available after "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", and, with certain exceptions, not applicable to funds appropriated or made available on or before "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1100"},"text":"section 1100 of Pub. L. 102–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e63b35b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/599/tI/s123/e"},"text":"Pub. L. 95–599, title I, § 123(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2702"},"text":"92 Stat. 2702","children":[],"tail":", provided that subsec. (c)(2) and (3) of this section be applicable to certifications required by this section to be filed on or after "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/106/s12"},"text":"Pub. L. 96–106, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-09"},"text":"Nov. 9, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/798"},"text":"93 Stat. 798","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id2e63b35c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enforcement of Vehicle Weight Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/599/tI/s123/a"},"text":"Pub. L. 95–599, title I, § 123(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2701"},"text":"92 Stat. 2701","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s133/c/4"},"text":"Pub. L. 100–17, title I, § 133(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/173"},"text":"101 Stat. 173","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/17/tI/s133/c/4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than the one-hundred-eightieth day after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":"], the Secretary of Transportation, hereunder referred to as the ‘Secretary’, in consultation with each State shall inventory the existing system of penalties for violations of vehicle weight laws, rules, and regulations on any portion of any Federal-aid system in such State. Each State shall annually thereafter report to the Secretary its current inventory."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than the one-hundred-eightieth day after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":"], the Secretary, in consultation with each State, shall inventory the existing system in such State for the issuance of special permits. Each State shall annually thereafter report to the Secretary its current inventory."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term ‘special permit’ means a license or permit issued pursuant to State law, rule, or regulation which authorizes a vehicle to exceed the weight limitation for such vehicle established under State law, rule, or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than January 1 of the second calendar year which begins after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":"] and each calendar year thereafter the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Public Works and Transportation [now Committee on Transportation and Infrastructure] of the House of Representatives an annual report together with such recommendations as the Secretary deems necessary on (1) the latest annual inventory of State systems of penalties required by subsection (a) of this section; (2) the latest annual inventory of State systems for the issuance of special permits required by subsection (b) of this section; (3) the annual certification submitted by each State required by "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s141/b"},"text":"section 141(b) of title 23","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in "},{"tag":"ref","attrib":{"href":"/us/pl/95/599/s123/c"},"text":"section 123(c) of Pub. L. 95–599","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 135 of House Document No. 103–7.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
