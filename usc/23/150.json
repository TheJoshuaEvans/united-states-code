{"tag":"section","attrib":{"id":"id2e6f99d5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150"},"text":null,"children":[{"tag":"num","attrib":{"value":"150"},"text":"§ 150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National goals and performance management measures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e6f99d6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Declaration of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Performance management will transform the Federal-aid highway program and provide a means to the most efficient investment of Federal transportation funds by refocusing on national transportation goals, increasing the accountability and transparency of the Federal-aid highway program, and improving project decisionmaking through performance-based planning and programming.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e6f99d7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is in the interest of the United States to focus the Federal-aid highway program on the following national goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e6f99d8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To achieve a significant reduction in traffic fatalities and serious injuries on all public roads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99d9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Infrastructure condition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To maintain the highway infrastructure asset system in a state of good repair.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99da-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congestion reduction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To achieve a significant reduction in congestion on the National Highway System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99db-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System reliability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To improve the efficiency of the surface transportation system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99dc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight movement and economic vitality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To improve the National Highway Freight Network, strengthen the ability of rural communities to access national and international trade markets, and support regional economic development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99dd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental sustainability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To enhance the performance of the transportation system while protecting and enhancing the natural environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99de-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reduced project delivery delays","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To reduce project costs, promote jobs and the economy, and expedite the movement of people and goods by accelerating project completion through eliminating delays in the project development and delivery process, including reducing regulatory burdens and improving agencies’ work practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e6f99df-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Performance Measures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e6f99e0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of the MAP–21, the Secretary, in consultation with State departments of transportation, metropolitan planning organizations, and other stakeholders, shall promulgate a rulemaking that establishes performance measures and standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99e1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e6f99e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide States, metropolitan planning organizations, and other stakeholders not less than 90 days to comment on any regulation proposed by the Secretary under that paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e6f99e3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration any comments relating to a proposed regulation received during that comment period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e6f99e4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit performance measures only to those described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National highway performance program.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e6f99e6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), for the purpose of carrying out section 119, the Secretary shall establish—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e6f99e7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimum standards for States to use in developing and operating bridge and pavement management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e6f99e8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" measures for States to use to assess—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e6f99e9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of pavements on the Interstate system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e6f99ea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of pavements on the National Highway System (excluding the Interstate);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e6f99eb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of bridges on the National Highway System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e6f99ec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of the Interstate System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e6f99ed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of the National Highway System (excluding the Interstate System);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e6f99ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimum levels for the condition of pavement on the Interstate System, only for the purposes of carrying out section 119(f)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e6f99ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data elements that are necessary to collect and maintain standardized data to carry out a performance-based approach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e6f99f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing minimum condition levels under subparagraph (A)(iii), if the Secretary determines that various geographic regions of the United States experience disparate factors contributing to the condition of pavement on the Interstate System in those regions, the Secretary may establish different minimum levels for each region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Highway safety improvement program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out section 148, the Secretary shall establish measures for States to use to assess—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e6f99f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serious injuries and fatalities per vehicle mile traveled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e6f99f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of serious injuries and fatalities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congestion mitigation and air quality program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out section 149, the Secretary shall establish measures for States to use to assess—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e6f99f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traffic congestion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e6f99f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-road mobile source emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National freight movement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish measures for States to use to assess freight movement on the Interstate System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e6f99f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Performance Targets.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e6f99f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the Secretary has promulgated the final rulemaking under subsection (c), each State shall set performance targets that reflect the measures identified in paragraphs (3), (4), (5), and (6) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Different approaches for urban and rural areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the development and implementation of any performance target, a State may, as appropriate, provide for different performance targets for urbanized and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e6f99fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting on Performance Targets","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after the date of enactment of the MAP–21 and biennially thereafter, a State shall submit to the Secretary a report that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e6f99fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition and performance of the National Highway System in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99fd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the investment strategy document in the State asset management plan for the National Highway System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99fe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress in achieving performance targets identified under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e6f99ff-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s150/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ways in which the State is addressing congestion at freight bottlenecks, including those identified in the national freight strategic plan, within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e6f9a00-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1203/a"},"text":"Pub. L. 112–141, div. A, title I, § 1203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/524"},"text":"126 Stat. 524","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1446/a/4"},"text":"Pub. L. 114–94, div. A, title I, § 1446(a)(4)","children":[],"tail":"–(6), (d)(2)(A), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1437"},"text":"129 Stat. 1437","children":[],"tail":", 1438.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e6f9a01-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e6f9a02-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e6f9a03-3a70-11f1-8334-895c8eef5d79