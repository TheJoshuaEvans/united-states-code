{"tag":"section","attrib":{"id":"id2eb99c43-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520"},"text":null,"children":[{"tag":"num","attrib":{"value":"520"},"text":"§ 520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation Resilience and Adaptation Centers of Excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb99c44-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Center of Excellence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Center of Excellence” means a Center of Excellence for Resilience and Adaptation designated under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c45-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate 10 regional Centers of Excellence for Resilience and Adaptation and 1 national Center of Excellence for Resilience and Adaptation, which shall serve as a coordinator for the regional Centers, to receive grants to advance research and development that improves the resilience of regions of the United States to natural disasters and extreme weather by promoting the resilience of surface transportation infrastructure and infrastructure dependent on surface transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c46-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to be designated as a Center of Excellence is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c47-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in section 102 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c48-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of nonprofit organizations led by an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c49-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to be designated as a Center of Excellence, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a proposal that includes a description of the activities to be carried out with a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c4a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c4b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional centers of excellence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate 1 regional Center of Excellence in each of the 10 Federal regions that comprise the Standard Federal Regions established by the Office of Management and Budget in the document entitled “Standard Federal Regions” and dated April 1974 (circular A–105).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c4c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National center of excellence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate 1 national Center of Excellence to coordinate the activities of all 10 regional Centers of Excellence to minimize duplication and promote coordination and dissemination of research among the Centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c4d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible entities to designate as a Center of Excellence, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99c4e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the past experience and performance of the eligible entity in carrying out activities described in subsection (g);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99c4f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the merits of the proposal of an eligible entity and the extent to which the proposal would—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2eb99c50-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance the state of practice in resilience planning and identify innovative resilience solutions for transportation assets and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2eb99c51-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support activities carried out under the PROTECT program under section 176;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2eb99c52-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support and build on work being carried out by another Federal agency relating to resilience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ebbe543-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform transportation decisionmaking at all levels of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ebbe544-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage local, regional, Tribal, State, and national stakeholders, including, if applicable, stakeholders representing transportation, transit, urban, and land use planning, natural resources, environmental protection, hazard mitigation, and emergency management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ebbe545-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage community groups and other stakeholders that will be affected by transportation decisions, including underserved, economically disadvantaged, rural, and predominantly minority communities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ebbe546-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local, regional, Tribal, State, and national impacts of the proposal of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ebbe547-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall provide to each Center of Excellence a grant of not less than $5,000,000 for each of fiscal years 2022 through 2031 to carry out the activities described in subsection (g).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ebbe548-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall ensure that a Center of Excellence uses the funds from a grant under subsection (f) to promote resilient transportation infrastructure, including through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ebbe549-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting climate vulnerability assessments informed by climate change science, including national climate assessments produced by the United States Global Change Research Program under section 106 of the Global Change Research Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2936"},"text":"15 U.S.C. 2936","children":[],"tail":"), relevant feasibility analyses of resilient transportation improvements, and transportation resilience planning;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe54a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of new design, operations, and maintenance standards for transportation infrastructure that can inform Federal and State decisionmaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe54b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development of new materials and technologies that could be integrated into existing and new transportation infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe54c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development, refinement, and piloting of new and emerging resilience improvements and strategies, including natural infrastructure approaches and relocation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe54d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of and investment in new approaches for facilitating meaningful engagement in transportation decisionmaking by local, Tribal, regional, or national stakeholders and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe54e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" technical capacity building to facilitate the ability of local, regional, Tribal, State, and national stakeholders—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ebbe54f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the vulnerability of transportation infrastructure assets and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ebbe550-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop community response strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ebbe551-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meaningfully engage with community stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ebbe552-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop strategies and improvements for enhancing transportation infrastructure resilience under current conditions and a range of potential future conditions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe553-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce development and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe554-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and dissemination of data, tools, techniques, assessments, and information that informs Federal, State, Tribal, and local government decisionmaking, policies, planning, and investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe555-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and outreach regarding transportation infrastructure resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ebbe556-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/g/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology transfer and commercialization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ebbe557-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s520/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity under this section, including the costs of establishing and operating a Center of Excellence, shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ebbe558-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tIII/s13009/a"},"text":"Pub. L. 117–58, div. A, title III, § 13009(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/642"},"text":"135 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ebbe559-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2ebbe55a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2ebbe55b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
