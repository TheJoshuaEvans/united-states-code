{"tag":"section","attrib":{"id":"id2e7b8203-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172"},"text":null,"children":[{"tag":"num","attrib":{"value":"172"},"text":"§ 172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife-vehicle collision reduction and habitat connectivity improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e7b8204-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8205-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a study (referred to in this subsection as the “study”) of the state, as of the date of the study, of the practice of methods to reduce collisions between motorists and wildlife (referred to in this section as “wildlife-vehicle collisions”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8206-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8207-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Areas of study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b8208-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" update and expand on, as appropriate—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b8209-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report entitled “Wildlife Vehicle Collision Reduction Study: 2008 Report to Congress”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b820a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the document entitled “Wildlife Vehicle Collision Reduction Study: Best Practices Manual” and dated October 2008; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b820b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b820c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment, as of the date of the study, of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id2e7b820d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the causes of wildlife-vehicle collisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e7b820e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of wildlife-vehicle collisions on motorists and wildlife; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e7b820f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of roads and traffic on habitat connectivity for terrestrial and aquatic species; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b8210-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" solutions and best practices for—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id2e7b8211-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e7b8212-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8213-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b8214-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct a thorough review of research and data relating to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b8215-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b8216-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat fragmentation that results from transportation infrastructure;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8217-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survey current practices of the Department of Transportation and State departments of transportation to reduce wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8218-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b8219-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate experts in the field of wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b821a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate experts on the effects of roads and traffic on habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b821b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b821c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of the Surface Transportation Reauthorization Act of 2021, the Secretary shall submit to Congress a report on the results of the study.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b821d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b821e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b821f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the causes of wildlife-vehicle collisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b8220-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b8221-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impacts of roads and traffic on—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id2e7b8222-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species listed as threatened species or endangered species under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e7b8223-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species identified by States as species of greatest conservation need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e7b8224-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species identified in State wildlife plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e7b8225-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/i/III/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medium and small terrestrial and aquatic species;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8226-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic evaluation of the costs and benefits of installing highway infrastructure and other measures to mitigate damage to terrestrial and aquatic species, including the effect on jobs, property values, and economic growth to society, adjacent communities, and landowners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8227-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for preventing wildlife-vehicle collisions, including recommended best practices, funding resources, or other recommendations for addressing wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8228-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidance, developed in consultation with Federal land management agencies and State departments of transportation, State fish and wildlife agencies, and Tribal governments that agree to participate, for developing, for each State that agrees to participate, a voluntary joint statewide transportation and wildlife action plan—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b8229-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b822a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/a/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b822b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Workforce Development and Technical Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b822c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date of enactment of the Surface Transportation Reauthorization Act of 2021, the Secretary shall, based on the study conducted under subsection (a), develop a series of in-person and online workforce development and technical training courses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b822d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b822e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b822f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8230-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the series of courses developed under paragraph (1) available for transportation and fish and wildlife professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8231-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the series of courses not less frequently than once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8232-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standardization of Wildlife Collision and Carcass Data.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8233-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standardized methodology.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8234-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Administrator of the Federal Highway Administration (referred to in this subsection as the “Secretary”), shall develop a quality standardized methodology for collecting and reporting spatially accurate wildlife collision and carcass data for the National Highway System, considering the practicability of the methodology with respect to technology and cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8235-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methodology","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the standardized methodology under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b8236-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survey existing methodologies and sources of data collection, including the Fatality Analysis Reporting System, the General Estimates System of the National Automotive Sampling System, and the Highway Safety Information System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8237-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, identify and correct limitations of those existing methodologies and sources of data collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8238-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the standardized methodology under subparagraph (A), the Secretary shall consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b8239-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b823a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, acting through the Chief of the Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b823b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal, State, and local transportation and wildlife authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b823c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" metropolitan planning organizations (as defined in section 134(b));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b823d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the American Association of State Highway Transportation Officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b823e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Association of Fish and Wildlife Agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b823f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in the field of wildlife-vehicle collisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8240-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8241-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/1/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other interested stakeholders, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8242-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standardized national data system with voluntary template implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8243-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a template for State implementation of a standardized national wildlife collision and carcass data system for the National Highway System that is based on the standardized methodology developed under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8244-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the voluntary implementation of the template developed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8245-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8246-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methodology","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to Congress a report describing the standardized methodology developed under paragraph (1) not later than the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b8247-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 18 months after the date of enactment of the Surface Transportation Reauthorization Act of 2021; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8248-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 180 days after the date on which the Secretary completes the development of the standardized methodology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8249-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after the date of enactment of the Surface Transportation Reauthorization Act of 2021, the Secretary shall submit to Congress a report describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b824a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the voluntary implementation of the standardized methodology developed under paragraph (1) and the template developed under paragraph (2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b824b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether the implementation of the standardized methodology developed under paragraph (1) and the template developed under paragraph (2)(A) has impacted efforts by States, units of local government, and other entities—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b824c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the number of wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b824d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve habitat connectivity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b824e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of the impact described in clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b824f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Secretary, including recommendations for further study aimed at reducing motorist collisions involving wildlife and improving habitat connectivity for terrestrial and aquatic species on the National Highway System, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8250-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Threshold Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8251-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish guidance, to be carried out by States on a voluntary basis, that contains a threshold for determining whether a highway shall be evaluated for potential mitigation measures to reduce wildlife-vehicle collisions and increase habitat connectivity for terrestrial and aquatic species, taking into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8252-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of wildlife-vehicle collisions on the highway that pose a human safety risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8253-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" highway-related mortality and the effects of traffic on the highway on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b8254-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species listed as endangered species or threatened species under the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8255-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species identified by a State as species of greatest conservation need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8256-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" species identified in State wildlife plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b8257-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medium and small terrestrial and aquatic species; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8258-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s172/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" habitat connectivity values for terrestrial and aquatic species and the barrier effect of the highway on the movements and migrations of those species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7b8259-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11123/c/1"},"text":"Pub. L. 117–58, div. A, title I, § 11123(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/502"},"text":"135 Stat. 502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e7b825a-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e7b825b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e7b825c-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Surface Transportation Reauthorization Act of 2021, referred to in subsecs. (a)(3)(A), (b)(1), and (c)(3), is the date of enactment of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsecs. (a)(3)(B)(i)(III)(aa) and (d)(1)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified principally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7b825d-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e7b825e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
