{"tag":"section","attrib":{"id":"id2e8e941b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buy America","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e8e941c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary of Transportation shall not obligate any funds authorized to be appropriated to carry out the Surface Transportation Assistance Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/96/2097"},"text":"96 Stat. 2097","children":[],"tail":") or this title and administered by the Department of Transportation, unless steel, iron, and manufactured products used in such project are produced in the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e941d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of subsection (a) of this section shall not apply where the Secretary finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8e941e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that their application would be inconsistent with the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e941f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such materials and products are not produced in the United States in sufficient and reasonably available quantities and of a satisfactory quality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e9420-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that inclusion of domestic material will increase the cost of the overall project contract by more than 25 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e9421-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, in calculating components’ costs, labor costs involved in final assembly shall not be included in the calculation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e9422-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall not impose any limitation or condition on assistance provided under the Surface Transportation Assistance Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/96/2097"},"text":"96 Stat. 2097","children":[],"tail":") or this title that restricts any State from imposing more stringent requirements than this section on the use of articles, materials, and supplies mined, produced, or manufactured in foreign countries in projects carried out with such assistance or restricts any recipient of such assistance from complying with such State imposed requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e9423-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intentional Violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If it has been determined by a court or Federal agency that any person intentionally—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8e9424-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affixed a label bearing a “Made in America” inscription, or any inscription with the same meaning, to any product used in projects to which this section applies, sold in or shipped to the United States that was not made in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e9425-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represented that any product used in projects to which this section applies, sold in or shipped to the United States that was not produced in the United States, was produced in the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that person shall be ineligible to receive any contract or subcontract made with funds authorized under the Intermodal Surface Transportation Efficiency Act of 1991 pursuant to the debarment, suspension, and ineligibility procedures in subpart 9.4 of chapter 1 of title 48, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e9426-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Applicability of Waivers to Products Produced in Certain Foreign Countries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary, in consultation with the United States Trade Representative, determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8e9427-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign country is a party to an agreement with the United States and pursuant to that agreement the head of an agency of the United States has waived the requirements of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e9428-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign country has violated the terms of the agreement by discriminating against products covered by this section that are produced in the United States and are covered by the agreement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the provisions of subsection (b) shall not apply to products produced in that foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e9429-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8e942a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 15 days before issuing a waiver under this section, the Secretary shall provide to the public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e8e942b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the proposed waiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e8e942c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity for comment on the proposed waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e8e942d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the proposed waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e942e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than annually, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the waivers provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e942f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s313/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Highway Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements under this section shall apply to all contracts eligible for assistance under this chapter for a project carried out within the scope of the applicable finding, determination, or decision under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), regardless of the funding source of such contracts, if at least 1 contract for the project is funded with amounts made available to carry out this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e910530-3a70-11f1-8334-895c8eef5d79"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1903/a"},"text":"Pub. L. 109–59, title I, § 1903(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1464"},"text":"119 Stat. 1464","children":[],"tail":", 1465; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1518"},"text":"Pub. L. 112–141, div. A, title I, § 1518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/574"},"text":"126 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11513"},"text":"Pub. L. 117–58, div. A, title I, § 11513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/595"},"text":"135 Stat. 595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e910531-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e910532-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e910533-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Surface Transportation Assistance Act of 1982, referred to in subsecs. (a) and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2097"},"text":"96 Stat. 2097","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1983 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Intermodal Surface Transportation Efficiency Act of 1991, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1914"},"text":"105 Stat. 1914","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1991 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s101"},"text":"section 101 of Title 49","children":[],"tail":", Transportation, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id2e910534-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", consists of text of "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tI/s165"},"text":"Pub. L. 97–424, title I, § 165","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2136"},"text":"96 Stat. 2136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/229/s10"},"text":"Pub. L. 98–229, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-09"},"text":"Mar. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/57"},"text":"98 Stat. 57","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI"},"text":"Pub. L. 100–17, title I","children":[],"tail":", §§ 133(a)(6), 337(a)(1), (b), (c), "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/171"},"text":"101 Stat. 171","children":[],"tail":", 241; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1048"},"text":"Pub. L. 102–240, title I, § 1048","children":[],"tail":", title III, § 3003(b), "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1999"},"text":"105 Stat. 1999","children":[],"tail":", 2088; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/r"},"text":"Pub. L. 103–272, § 4(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1371"},"text":"108 Stat. 1371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s7/a/3/E"},"text":"Pub. L. 103–429, § 7(a)(3)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4389"},"text":"108 Stat. 4389","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1903/d"},"text":"Pub. L. 109–59, title I, § 1903(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1465"},"text":"119 Stat. 1465","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e910535-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 313, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/915"},"text":"72 Stat. 915","children":[],"tail":", authorized the Secretary to cooperate with State highway departments and other agencies in the promotion of highway safety and authorized the expenditure of $150,000 out of the administrative funds made available in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/a"},"text":"section 104(a) of this title","children":[],"tail":" for the purposes of this section, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/564/tI/s102/a"},"text":"Pub. L. 89–564, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-09"},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/734"},"text":"80 Stat. 734","children":[],"tail":". See section 401 et seq. of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e910536-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added subsec. (g) and redesignated former subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1903/c/1"},"text":"Pub. L. 109–59, § 1903(c)(1)","children":[],"tail":", substituted “to carry out the Surface Transportation Assistance Act of 1982 ("},{"tag":"ref","attrib":{"href":"/us/stat/96/2097"},"text":"96 Stat. 2097","children":[],"tail":") or this title” for “by this Act or by any Act amended by this Act or, after the date of enactment of this Act, any funds authorized to be appropriated to carry out this Act, title 23, United States Code, or the Surface Transportation Assistance Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1903/c/2"},"text":"Pub. L. 109–59, § 1903(c)(2)","children":[],"tail":", redesignated par. (4) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1903/c/3"},"text":"Pub. L. 109–59, § 1903(c)(3)","children":[],"tail":", substituted “the Surface Transportation Assistance Act of 1982 ("},{"tag":"ref","attrib":{"href":"/us/stat/96/2097"},"text":"96 Stat. 2097","children":[],"tail":") or this title that” for “this Act, the Surface Transportation Assistance Act of 1978 or title 23, United States Code, which”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1903/c/4"},"text":"Pub. L. 109–59, § 1903(c)(4)","children":[],"tail":", (5), which directed amendment of this section by striking subsec. (e) and redesignating subsecs. (f) and (g) as (e) and (f), respectively, was executed by making the redesignations and by striking out two subsecs. (e), to reflect the probable intent of Congress. The first subsec. (e) based on subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/s165"},"text":"section 165 of Pub. L. 97–424","children":[],"tail":", as originally enacted, repealed section 401 of the Surface Transportation Assistance Act of 1978, "},{"tag":"ref","attrib":{"href":"/us/pl/95/599"},"text":"Pub. L. 95–599","children":[],"tail":". The second subsec. (e) based on subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/s165"},"text":"section 165 of Pub. L. 97–424","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1048/b"},"text":"Pub. L. 102–240, § 1048(b)","children":[],"tail":", related to report on purchases from foreign entities waived under subsec. (b) in fiscal years 1992 and 1993."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e910537-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e910538-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e910539-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effectiv