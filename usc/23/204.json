{"tag":"section","attrib":{"id":"id2e851ed8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204"},"text":null,"children":[{"tag":"num","attrib":{"value":"204"},"text":"§ 204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal lands access program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e851ed9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e851eda-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under the Federal lands access program shall be used by the Secretary of Transportation and the Secretary of the appropriate Federal land management agency to pay the cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e851edb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transportation planning, research, engineering, preventive maintenance, rehabilitation, restoration, context-sensitive solutions, construction, and reconstruction of Federal lands access transportation facilities located on or adjacent to, or that provide access to, Federal land, and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e851edc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjacent vehicular parking areas, including interpretive panels in or adjacent to those areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851edd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of necessary scenic easements and scenic or historic sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851ede-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for pedestrians and bicycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851edf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental mitigation in or adjacent to Federal land to improve public safety and reduce vehicle-caused wildlife mortality while maintaining habitat connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851ee0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction and reconstruction of roadside rest areas, including sanitary and water facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851ee1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contextual wayfinding markers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851ee2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landscaping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851ee3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative mitigation of visual blight, including screening or removal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e851ee4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate public road facilities, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e851ee5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation and maintenance of transit facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e851ee6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transportation project eligible for assistance under this title that is within or adjacent to, or that provides access to, Federal land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e851ee7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with an activity described in paragraph (1), the Secretary and the Secretary of the appropriate Federal land management agency may enter into a contract or other appropriate agreement with respect to the activity with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e851ee8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State (including a political subdivision of a State); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e851ee9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e851eea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All appropriations for the construction and improvement of Federal lands access transportation facilities shall be administered in conformity with regulations and agreements approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e851eeb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e851eec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The cooperation of States, counties, or other local subdivisions may be accepted in construction and improvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e851eed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds received","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any funds received from a State, county, or local subdivision for a Federal lands access transportation facility project shall be credited to appropriations available under the Federal lands access program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e851eee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive bidding.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e851eef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraph (B), construction of each project shall be performed by contract awarded by competitive bidding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e851ef0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) shall not apply if the Secretary or the Secretary of the appropriate Federal land management agency affirmatively finds that, under the circumstances relating to the project, a different method is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e851ef1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native plant materials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out an activity described in paragraph (1), the Secretary shall ensure that the entity carrying out the activity considers, to the maximum extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e8767e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of locally adapted native plant materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e8767e3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designs that minimize runoff and heat generation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8767e4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Distributions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8767e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funding made available to carry out the Federal lands access program shall be allocated among those States that have Federal land, in accordance with the following formula:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e8767e6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 80 percent of the available funding for use in those States that contain at least 1 ½ percent of the total public land in the United States managed by the agencies described in paragraph (2), to be distributed as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e8767e7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 30 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767e8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreational visitation within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767e9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recreational visitation within all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8767ea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767eb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal land area within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767ec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal land area in all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8767ed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 55 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal public road miles within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal public road miles in all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8767f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 10 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal public bridges within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal public bridges in all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e8767f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 20 percent of the available funding for use in those States that do not contain at least 1 ½ percent of the total public land in the United States managed by the agencies described in paragraph (2), to be distributed as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e8767f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 30 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recreational visitation within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recreational visitation within all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8767f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal land area within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal land area in all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8767fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 55 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal public road miles within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal public road miles in all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8767fd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 10 percent in the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e8767fe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal public bridges within each such State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e8767ff-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of Federal public bridges in all such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e876800-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data source","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Data necessary to distribute funding under paragraph (1) shall be provided by the following Federal land management agencies:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e876801-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Park Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e876802-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e876803-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e876804-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Land Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e876805-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e876806-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programming Decisions Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e876807-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Programming decisions shall be made within each State by a committee comprised of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e876808-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the Federal Highway Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e876809-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of the State Department of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e87680a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of any appropriate political subdivision of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e87680b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The committee described in paragraph (1) shall cooperate with each applicable Federal agency in each State before any joint discussion or final programming decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e87680c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s204/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making a programming decision under paragraph (1), the committee shall give preference to projects that provide access to, are adjacent to, or are located within high-use Federal recreation sites or Federal economic generators, as identified by the Secretaries of the appropriate Federal land management agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e87680d-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1119/a"},"text":"Pub. L. 112–141, div. A, title I, § 1119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/489"},"text":"126 Stat. 489","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11113/b"},"text":"Pub. L. 117–58, div. A, title I, § 11113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/479"},"text":"135 Stat. 479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e87680e-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e87680f-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e876810-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 204, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 