{"tag":"section","attrib":{"id":"id2e910540-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s315"},"text":null,"children":[{"tag":"num","attrib":{"value":"315"},"text":"§ 315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules, regulations, and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 202(a)(5), 203(a)(3), and 205(a) of this title, the Secretary is authorized to prescribe and promulgate all needful rules and regulations for the carrying out of the provisions of this title. The Secretary may make such recommendations to the Congress and State transportation departments as he deems necessary for preserving and protecting the highways and insuring the safety of traffic thereon.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2e910541-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/915"},"text":"72 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s133/b/18"},"text":"Pub. L. 100–17, title I, § 133(b)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/172"},"text":"101 Stat. 172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1212/a/2/A/ii"},"text":"Pub. L. 105–178, title I, § 1212(a)(2)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/193"},"text":"112 Stat. 193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1119/c/3"},"text":"Pub. L. 112–141, div. A, title I, § 1119(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/492"},"text":"126 Stat. 492","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e910542-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e910543-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e910544-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “202(a)(5), 203(a)(3),” for “204(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “State transportation departments” for “State highway departments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" which directed that this section be amended by substituting “204(f) and 205(a)” for “204(d), 205(a), 207(b), and 208(c)” was executed by substituting “204(f) and 205(a)” for “204(d), 205(a), 206(b), 207(b), and 208(c)”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e910545-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":