{"tag":"section","attrib":{"id":"id2e8e9416-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Army, Navy, and Air Force officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense, upon request of the Secretary, is authorized to make temporary details to the Federal Highway Administration of officers of the Army, the Navy, and the Air Force, without additional compensation, for technical advice and for consultation regarding highway needs for the national defense. Travel and subsistence expenses of officers so detailed shall be paid from appropriations available to the Department of Transportation on the same basis as authorized by law and by regulations of the Department of Defense for such officers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2e8e9417-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/915"},"text":"72 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/87/tI/s152/5"},"text":"Pub. L. 93–87, title I, § 152(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/276"},"text":"87 Stat. 276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e8e9418-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e8e9419-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e8e941a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87"},"text":"Pub. L. 93–87","children":[],"tail":" substituted “Federal Highway Administration” for “Bureau of Public Roads” and “Department of Transportation” for “Department of Commerce”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
