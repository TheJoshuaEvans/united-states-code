{"tag":"section","attrib":{"id":"id2e63b37f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143"},"text":null,"children":[{"tag":"num","attrib":{"value":"143"},"text":"§ 143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highway use tax evasion projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e63b380-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “State” means the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e63b381-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e63b382-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out highway use tax evasion projects in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b383-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e63b384-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From administrative funds made available under section 104(a), the Secretary may deduct such sums as are necessary, not to exceed $4,000,000 for each of fiscal years 2022 through 2026, to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b385-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available to carry out this section may be allocated to the Internal Revenue Service and the States at the discretion of the Secretary, except that of funds so made available for each fiscal year, $2,000,000 shall be available only to carry out intergovernmental enforcement efforts, including research and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b386-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions on funds allocated to internal revenue service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, the Secretary shall not impose any condition on the use of funds allocated to the Internal Revenue Service under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b387-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available to carry out this section shall be used only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e63b388-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand efforts to enhance motor fuel tax enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b389-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund additional Internal Revenue Service staff, but only to carry out functions described in this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b38a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supplement motor fuel tax examinations and criminal investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b38b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop automated data processing tools to monitor motor fuel production and sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b38c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate and implement registration and reporting requirements for motor fuel taxpayers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b38d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse State expenses that supplement existing fuel tax compliance efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b38e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to analyze and implement programs to reduce tax evasion associated with other highway use taxes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b38f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support efforts between States and Indian tribes to address issues relating to State motor fuel taxes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b390-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to analyze and implement programs to reduce tax evasion associated with foreign imported fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b391-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of effort","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not make an allocation to a State under this subsection for a fiscal year unless the State certifies that the aggregate expenditure of funds of the State, exclusive of Federal funds, for motor fuel tax enforcement activities will be maintained at a level that does not fall below the average level of such expenditure for the preceding 2 fiscal years of the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b392-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out under this subsection shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b393-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds authorized to carry out this section shall remain available for obligation for a period of 3 years after the last day of the fiscal year for which the funds are authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b394-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of surface transportation block grant program funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to funds made available to carry out this section, a State may expend up to ¼ of 1 percent of the funds apportioned to the State for a fiscal year under section 104(b)(2) on initiatives to halt the evasion of payment of motor fuel taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b395-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commissioner of the Internal Revenue Service and each State shall submit to the Secretary, the Committee on Transportation and Infrastructure of the House of Representatives, and the Committee on Environment and Public Works of the Senate an annual report that describes the projects, examinations, and criminal investigations funded by and carried out under this section. Such report shall specify the estimated annual yield from such projects, examinations, and criminal investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e63b396-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excise Tax Fuel Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e63b397-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of the SAFETEA–LU, the Secretary shall enter into a memorandum of understanding with the Commissioner of the Internal Revenue Service for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e63b398-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the additional development of capabilities needed to support new reporting requirements and databases established under such Act and the American Jobs Creation Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Public Law 108–357","children":[],"tail":"), and such other reporting requirements and database development as may be determined by the Secretary, in consultation with the Commissioner of the Internal Revenue Service, to be useful in the enforcement of fuel excise taxes, including provisions recommended by the Fuel Tax Enforcement Advisory Committee,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b399-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the completion of requirements needed for the electronic reporting of fuel transactions from carriers and terminal operators,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b39a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation and maintenance of an excise summary terminal activity reporting system and other systems used to provide strategic analyses of domestic and foreign motor fuel distribution trends and patterns,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b39b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection, analysis, and sharing of information on fuel distribution and compliance or noncompliance with fuel taxes, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b39c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, completion, operation, and maintenance of an electronic claims filing system and database and an electronic database of heavy vehicle highway use payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b39d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of memorandum of understanding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The memorandum of understanding shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e63b39e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Internal Revenue Service shall develop and maintain any system under paragraph (1) through contracts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b39f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any system under paragraph (1) shall be under the control of the Internal Revenue Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e63b3a0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any system under paragraph (1) shall be made available for use by appropriate State and Federal revenue, tax, and law enforcement authorities, subject to section 6103 of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b3a1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available to carry out this section for each fiscal year, the Secretary shall make available to the Internal Revenue Service such funds as may be necessary to complete, operate, and maintain the systems under paragraph (1) in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e63b3a2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s143/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than September 30 of each year, the Commissioner of the Internal Revenue Service shall provide reports to the Secretary on the status of the Internal Revenue Service projects funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e63b3a3-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/605/tI/s127/a"},"text":"Pub. L. 91–605, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1729"},"text":"84 Stat. 1729","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/87/tI/s122"},"text":"Pub. L. 93–87, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/261"},"text":"87 Stat. 261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1114/a"},"text":"Pub. L. 105–178, title I, § 1114(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/152"},"text":"112 Stat. 152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9002/h"},"text":"Pub. L. 105–206, title IX, § 9002(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/836"},"text":"112 Stat. 836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1115/a"},"text":"Pub. L. 109–59, title I, § 1115(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1175"},"text":"119 Stat. 1175","children":[],"tail":", 1176; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1110"},"text":"Pub. L. 112–141, div. A, title I, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/444"},"text":"126 Stat. 444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1110"},"text":"Pub. L. 114–94, div. A, title I, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1344"},"text":"129 Stat. 1344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11120"},"text":"Pub. L. 117–58, div. A, title I, § 11120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/497"},"text":"135 Stat. 497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e6624a4-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e6624a5-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e6624a6-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The SAFETEA–LU, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1144"},"text":"119 Stat. 1144","children":[],"tail":", also known as the Safe, Accountable, Flexible, Efficient Transportation Equity Act: A Legacy for Users. For complete classification of this Act to the Code, see Short Title of 2005 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The American Jobs Creation Act of 2004, referred to in subsec. (c)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-22"},"text":"Oct. 22, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1418"},"text":"118 Stat. 1418","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2004 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"section 1 of Title 26","children":[],"tail":", Internal Revenue Code, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6103 of the Internal Revenue Code of 1986, referred to in subsec. (c)(2)(C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e6624a7-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1040"},"text":"Pub. L. 102–240, title I, § 1040","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1992"},"text":"105 Stat. 1992","children":[],"tail":", as amended, which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1114/b/2"},"text":"Pub. L. 105–178, § 1114(b)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e6624a8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “fiscal years 2022 through 2026” for “fiscal years 2016 through 2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1110/1"},"text":"Pub. L. 114–94, § 1110(1)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “From administrative funds made available under section 104(a), the Secretary shall deduct such sums as are necessary, not to exceed $10,000,000 for each of fiscal years 2013 and 2014, to carry out this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1110/2"},"text":"Pub. L. 114–94, § 1110(2)","children":[],"tail":", inserted “block grant” after “surface transportation” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1110/3"},"text":"Pub. L. 114–94, § 1110(3)","children":[],"tail":", inserted “, the Committee on Transportation and Infrastructure of the House of Representatives, and the Committee on Environment and Public Works of the Senate” after “the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1110/1/A"},"text":"Pub. L. 112–141, § 1110(1)(A)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “Funds made available to carry out this section may be allocated to the Internal Revenue Service and the States at the discretion of the Secretary; except that of funds so made available for each of fiscal years 2005 through 2009, $2,000,000 shall be available only to carry out intergovernmental enforcement efforts, including research and training.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1110/1/B"},"text":"Pub. L. 112–141, § 1110(1)(B)","children":[],"tail":", substituted “section 104(b)(2)” for “section 104(b)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1110/2"},"text":"Pub. L. 112–141, § 1110(2)","children":[],"tail":", substituted “for each fiscal year,” for “for each of fiscal years 2005 through 2009,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1115/a/1"},"text":"Pub. L. 109–59, § 1115(a)(1)","children":[],"tail":", inserted before period at end “; except that of funds so made available for each of fiscal years 2005 through 2009, $2,000,000 shall be available only to carry out intergovernmental enforcement efforts, including research and training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1115/a/2"},"text":"Pub. L. 109–59, § 1115(a)(2)","children":[],"tail":", substituted “Except as otherwise provided in this section, the” for “The”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(H), (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1115/a/3"},"text":"Pub. L. 109–59, § 1115(a)(3)","children":[],"tail":", added subpars. (H) and (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1115/a/4"},"text":"Pub. L. 109–59, § 1115(a)(4)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1115/b"},"text":"Pub. L. 109–59, § 1115(b)","children":[],"tail":", amended heading and text of subsec. (c) generally, substituting provisions relating to memorandum of understanding to be entered into by the Secretary with the Commissioner of the Internal Revenue Service not later than 90 days after the date of enactment of the SAFETEA–LU for provisions relating to memorandum of understanding to be entered into by the Secretary with the Commissioner of the Internal Revenue Service not later than "},{"tag":"date","attrib":{"date":"1998-08-01"},"text":"August 1, 1998","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to highway use tax evasion projects for provisions relating to economic growth center development highways."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1114/c/1"},"text":"Pub. L. 105–178, § 1114(c)(1)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s9002/h"},"text":"Pub. L. 105–206, § 9002(h)","chi