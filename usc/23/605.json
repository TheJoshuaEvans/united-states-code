{"tag":"section","attrib":{"id":"id2ec0a0ac-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605"},"text":null,"children":[{"tag":"num","attrib":{"value":"605"},"text":"§ 605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ec0a0ad-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a uniform system to service the Federal credit instruments made available under the TIFIA program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0ae-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may collect and spend fees, contingent on authority being provided in appropriations Acts, at a level that is sufficient to cover—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0af-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of services of expert firms retained pursuant to subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0b0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all or a portion of the costs to the Federal Government of servicing the Federal credit instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0b1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Servicer.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0b2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may appoint a financial entity to assist the Secretary in servicing the Federal credit instruments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0b3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A servicer appointed under paragraph (1) shall act as the agent for the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0b4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A servicer appointed under paragraph (1) shall receive a servicing fee, subject to approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0b5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance From Expert Firms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may retain the services of expert firms, including counsel, in the field of municipal and project finance to assist in the underwriting and servicing of Federal credit instruments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0b6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Processing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall implement procedures and measures to economize the time and cost involved in obtaining approval and the issuance of credit assistance under the TIFIA program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0b7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance to Small Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0b8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reservation of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the funds made available to carry out the TIFIA program for each fiscal year, and after the set aside under section 608(a)(6), not less than $2,000,000 shall be made available for the Secretary to use in lieu of fees collected under subsection (b) for projects under the TIFIA program having eligible project costs that are reasonably anticipated not to equal or exceed $75,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0b9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s605/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any funds not used under paragraph (1) in a fiscal year shall be made available on October 1 of the following fiscal year to provide credit assistance to any project under the TIFIA program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ec0a0ba-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1503/a"},"text":"Pub. L. 105–178, title I, § 1503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/249"},"text":"112 Stat. 249","children":[],"tail":", § 185; renumbered § 605 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI"},"text":"Pub. L. 109–59, title I","children":[],"tail":", §§ 1601(f), 1602(b)(5), (d), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1241"},"text":"119 Stat. 1241","children":[],"tail":", 1247; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tII/s2002"},"text":"Pub. L. 112–141, div. A, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/619"},"text":"126 Stat. 619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tII/s2001/d"},"text":"Pub. L. 114–94, div. A, title II, § 2001(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1443"},"text":"129 Stat. 1443","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tII/s12001/i/2"},"text":"Pub. L. 117–58, div. A, title II, § 12001(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/621"},"text":"135 Stat. 621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ec0a0bb-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2ec0a0bc-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2ec0a0bd-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “section 608(a)(6)” for “section 608(a)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsecs. (a), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s2001/d/1"},"text":"Pub. L. 114–94, § 2001(d)(1)","children":[],"tail":", substituted “the TIFIA program” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s2001/d/2"},"text":"Pub. L. 114–94, § 2001(d)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended section generally. Prior to amendment, section related to program administration, consisting of subsecs. (a) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1602/d"},"text":"Pub. L. 109–59, § 1602(d)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s185"},"text":"section 185 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/f"},"text":"Pub. L. 109–59, § 1601(f)","children":[],"tail":", amended section catchline and text generally, substituting provisions relating to establishment by the Secretary of a uniform system to service the Federal credit instruments made available under this subchapter for provisions authorizing a State to identify a local servicer to assist the Secretary in servicing the Federal credit instrument made available under this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1602/b/5"},"text":"Pub. L. 109–59, § 1602(b)(5)","children":[],"tail":", substituted “this chapter” for “this subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2ec0a0be-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"tex