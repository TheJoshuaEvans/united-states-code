{"tag":"section","attrib":{"id":"id2ec3125f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611"},"text":null,"children":[{"tag":"num","attrib":{"value":"611"},"text":"§ 611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset concessions and innovative finance assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ec31260-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec31261-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approved infrastructure asset","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “approved infrastructure asset” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31262-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project (as defined in section 601(a)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31263-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of projects (as defined in section 601(a)) considered together in a single asset concession or long-term lease to a concessionaire by 1 or more eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec31264-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Asset concession","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “asset concession” means a contract between an eligible entity and a concessionaire—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31265-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec31266-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity agrees to enter into a concession agreement or long-term lease with the concessionaire relating to an approved infrastructure asset owned, controlled, or maintained by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec31267-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as consideration for the agreement or lease described in clause (i), the concessionaire agrees—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2ec31268-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide to the eligible entity 1 or more asset concession payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec31269-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain or exceed the condition, performance, and service level of the approved infrastructure asset, as compared to that condition, performance, and service level on the date of execution of the agreement or lease; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec3126a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity and the concessionaire agree that the costs for a fiscal year of the agreement or lease, and any project carried out under the agreement or lease, shall not be shifted to any taxpayer the annual household income of whom is less than $400,000 per year, including through taxes, user fees, tolls, or any other measure, for use of an approved infrastructure asset; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3126b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of which do not include any noncompete or exclusivity restriction (or any other, similar restriction) on the approval of another project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec3126c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Asset concession payment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “asset concession payment” means a payment that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec3126d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by a concessionaire to an eligible entity for fair market value that is determined as part of the asset concession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3126e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec3126f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment made at the financial close of an asset concession; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec31270-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a series of payments scheduled to be made for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2ec31271-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fixed period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec31272-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of an asset concession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec31273-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concessionaire","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “concessionaire” means a private individual or a private or publicly chartered corporation or entity that enters into an asset concession with an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec31274-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31275-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means an entity described in subparagraph (B) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec31276-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, controls, or maintains an approved infrastructure asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec31277-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the legal authority to enter into a contract to transfer ownership, maintenance, operations, revenues, or other benefits and responsibilities for an approved infrastructure asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31278-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entities described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity referred to in subparagraph (A) is any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec31279-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec3127a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Tribal government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec3127b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A unit of local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec3127c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency or instrumentality of a State, Tribal government, or unit of local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec3127d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/a/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A special purpose district or public authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec3127e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a program to facilitate access to expert services for, and to provide grants to, eligible entities to enhance the technical capacity of eligible entities to facilitate and evaluate public-private partnerships in which the private sector partner could assume a greater role in project planning, development, financing, construction, maintenance, and operation, including by assisting eligible entities in entering into asset concessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec3127f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under this section, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec31280-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec31281-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use amounts made available from a grant under this section for technical assistance to build the organizational capacity of the eligible entity to develop, review, or enter into an asset concession, including for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31282-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying appropriate assets or projects for asset concessions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31283-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soliciting and negotiating asset concessions, including hiring staff in public agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31284-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a value-for-money analysis, or a comparable analysis, to evaluate the comparative benefits of asset concessions and public debt or other procurement methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31285-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating options for the structure and use of asset concession payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31286-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating and publicly presenting the risks and benefits of all contract provisions for the purpose of transparency and accountability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31287-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying best practices to protect the public interest and priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31288-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying best practices for managing transportation demand and mobility along a corridor, including through provisions of the asset concession, to facilitate transportation demand management strategies along the corridor that is subject to the asset concession; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31289-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating and coordinating pricing, data, and fare collection with other regional operators that exist or may be developed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec3128a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expert services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity seeking to leverage public and private funding in connection with the development of an early-stage approved infrastructure asset, including in the development of alternative approaches to project delivery or procurement, may use amounts made available from a grant under this section to retain the services of an expert firm to provide to the eligible entity direct project level assistance, which services may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec3128b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project planning, feasibility studies, revenue forecasting, economic assessments and cost-benefit analyses, public benefit studies, value-for-money analyses, business case development, lifecycle cost analyses, risk assessment, financing and funding options analyses, procurement alternatives analyses, statutory and regulatory framework analyses and other pre-procurement and pre-construction activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3128c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial and legal planning (including the identification of statutory authorization, funding, and financing options);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3128d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early assessment of permitting, environmental review, and regulatory processes and costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3128e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with entering into an asset concession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec3128f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec31290-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31291-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum amount of a technical assistance grant under subsection (d)(1) shall be $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31292-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expert services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum amount of the value of expert services retained by an eligible entity under subsection (d)(2) shall be $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec31293-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost sharing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31294-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the Federal share of the cost of an activity carried out under this section may be up to 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec31295-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the amount of the grant provided to an eligible entity under this section is more than $1,000,000, the Federal share of the cost of an activity carried out using grant amounts in excess of $1,000,000 shall be 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec31296-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statewide maximum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The aggregate amount made available under this section to eligible entities within a State shall not exceed, on a cumulative basis for all eligible entities within the State during any 3-year period, $4,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec31297-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec31298-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that, as a condition of receiving a grant under this section, for any asset concession for which the grant provides direct assistance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec31299-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the asset concession shall not prohibit, discourage, or make it more difficult for an eligible entity to construct new infrastructure, to provide or expand transportation services, or to manage associated infrastructure in publicly beneficial ways, along a transportation corridor or in the proximity of a transportation facility that was a part of the asset concession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3129a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity shall have adopted binding rules to publish all major business terms of the proposed asset concession not later than the date that is 30 days before entering into the asset concession, to enable public review, including a certification of public interest based on the results of an assessment under subparagraph (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3129b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the asset concession shall not result in displacement, job loss, or wage reduction for the existing workforce of the eligible entity or other public entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3129c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity or the concessionaire shall carry out a value-for-money analysis, or similar assessment, to compare the aggregate costs and benefits to the eligible entity of the asset concession against alternative options to determine whether the asset concession generates additional public benefits and serves the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3129d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full amount of any asset concession payment received by the eligible entity under the asset concession, less any amount paid for transaction costs relating to the asset concession, shall be used to pay infrastructure costs of the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec3129e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of the asset concession shall not result in any increase in costs under the asset concession being shifted to taxpayers the annual household income of whom is less than $400,000 per year, including through taxes, user fees, tolls, or any other measure, for use of an approved infrastructure asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec3129f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date on which an eligible entity enters into an asset concession as a result of a grant under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec312a0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity shall hire an independent auditor to evaluate the performance of the concessionaire based on the requirements described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec312a1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent auditor shall submit to the eligible entity, and make publicly available, a report describing the results of the audit under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec312a2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise provided under paragraph (1), the Secretary shall not, as a condition of receiving a grant under this section, prohibit or otherwise prevent an eligible entity from entering into, or receiving any asset concession payment under, an asset concession for an approved infrastructure asset owned, controlled, or maintained by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec312a3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of federal laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section exempts a concessionaire or an eligible entity from a compliance obligation with respect to any applicable Federal or State law that would otherwise apply to the concessionaire, the eligible entity, or an approved infrastructure asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec312a4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec312a5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":", and on each October 1 thereafter through "},{"tag":"date","attrib":{"date":"2025-10-01"},"text":"October 1, 2025","children":[],"tail":", out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary to carry out this section $20,000,000, to remain available until expended."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec312a6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s611/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receipt and acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall be entitled to receive, shall accept, and shall use to carry out this section the funds transferred under paragraph (1), without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ec312a7-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tX/s71001/a/1"},"text":"Pub. L. 117–58, div. G, title X, § 71001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1316"},"text":"135 Stat. 1316","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
