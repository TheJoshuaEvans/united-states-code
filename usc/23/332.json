{"tag":"section","attrib":{"id":"id2e95c101-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332"},"text":null,"children":[{"tag":"num","attrib":{"value":"332"},"text":"§ 332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pollinator-friendly practices on roadsides and highway rights-of-way","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e95c102-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a program to provide grants to eligible entities to carry out activities to benefit pollinators on roadsides and highway rights-of-way, including the planting and seeding of native, locally-appropriate grasses and wildflowers, including milkweed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e95c103-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to receive a grant under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e95c104-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State department of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e95c105-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e95c106-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal land management agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e95c107-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under this section, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a pollinator-friendly practices plan described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e95c108-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pollinator-friendly Practices Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e95c109-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall include in the application under subsection (c) a plan that describes the pollinator-friendly practices that the eligible entity has implemented or plans to implement, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e95c10a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" practices relating to mowing strategies that promote early successional vegetation and limit disturbance during periods of highest use by target pollinator species on roadsides and highway rights-of-way, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e95c10b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the mowing swath outside of the State-designated safety zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c10c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the mowing height;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c10d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the mowing frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c10e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refraining from mowing monarch and other pollinator habitat during periods in which monarchs or other pollinators are present;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c10f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of a flushing bar and cutting at reduced speeds to reduce pollinator deaths due to mowing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c110-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing raking along roadsides and highway rights-of-way;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c111-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of an integrated vegetation management plan that includes approaches such as mechanical tree and brush removal, targeted and judicious use of herbicides, and mowing, to address weed issues on roadsides and highway rights-of-way;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c112-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planting or seeding of native, locally-appropriate grasses and wildflowers, including milkweed, on roadsides and highway rights-of-way to enhance pollinator habitat, including larval host plants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c113-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removing nonnative grasses from planting and seeding mixes, except for use as nurse or cover crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c114-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtaining expert training or assistance on pollinator-friendly practices, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e95c115-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" native plant identification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c116-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment and management of locally-appropriate native plants that benefit pollinators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e983117-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land management practices that benefit pollinators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e983118-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pollinator-focused integrated vegetation management; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e983119-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other pollinator-friendly practices the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e98311a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing a plan under paragraph (1), an eligible entity that is a State department of transportation or a Federal land management agency shall coordinate with applicable State agencies, including State agencies with jurisdiction over agriculture and fish and wildlife.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e98311b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing a plan under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e98311c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible entity that is a State department of transportation or a Federal land management agency shall consult with affected or interested Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e98311d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any eligible entity may consult with nonprofit organizations, institutions of higher education, metropolitan planning organizations, and any other relevant entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e98311e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e98311f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide a grant to each eligible entity that submits an application under subsection (c), including a plan under subsection (d), that the Secretary determines to be satisfactory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e983120-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e983121-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be based on the number of pollinator-friendly practices the eligible entity has implemented or plans to implement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e983122-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not exceed $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983123-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible entity that receives a grant under this section shall use the funds for the implementation, improvement, or further development of the plan under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983124-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity carried out with a grant under this section shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983125-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop and make available to eligible entities best practices for, and a priority ranking of, pollinator-friendly practices on roadsides and highway rights-of-way.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983126-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of an eligible entity that receives a grant under this section, the Secretary shall provide technical assistance with the implementation, improvement, or further development of a plan under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983127-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, the Secretary may use not more than 2 percent of the amounts made available to carry out this section for the administrative costs of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983128-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date on which the first grant is provided under this section, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the implementation of the program under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e983129-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e98312a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $2,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e98312b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s332/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available under this section shall remain available for a period of 3 years after the last day of the fiscal year for which the funds are authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e98312c-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11528/a"},"text":"Pub. L. 117–58, div. A, title I, § 11528(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/610"},"text":"135 Stat. 610","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e98312d-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e98312e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e98312f-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
