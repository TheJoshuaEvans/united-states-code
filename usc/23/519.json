{"tag":"section","attrib":{"id":"id2eb99c3c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s519"},"text":null,"children":[{"tag":"num","attrib":{"value":"519"},"text":"§ 519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure development","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Funds made available to carry out this chapter for operational tests of intelligent transportation systems—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c3d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s519/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used primarily for the development of intelligent transportation system infrastructure, equipment, and systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c3e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s519/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, shall not be used for the construction of physical surface transportation infrastructure unless the construction is incidental and critically necessary to the implementation of an intelligent transportation system project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb99c3f-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6010/a"},"text":"Pub. L. 114–94, div. A, title VI, § 6010(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1567"},"text":"129 Stat. 1567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb99c40-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2eb99c41-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2eb99c42-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
