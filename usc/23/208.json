{"tag":"section","attrib":{"id":"id2e89d915-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208"},"text":null,"children":[{"tag":"num","attrib":{"value":"208"},"text":"§ 208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe routes to school","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e89d916-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e89d917-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In the vicinity of schools","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “in the vicinity of schools”, with respect to a school, means the approximately 2-mile area within bicycling and walking distance of the school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d918-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary, middle, and high schools","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “primary, middle, and high schools” means schools providing education from kindergarten through 12th grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d919-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of this section, the Secretary shall establish and carry out a safe routes to school program for the benefit of children in primary, middle, and high schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d91a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program established under subsection (b) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e89d91b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable and encourage children, including those with disabilities, to walk and bicycle to school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d91c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make bicycling and walking to school a safer and more appealing transportation alternative, thereby encouraging a healthy and active lifestyle from an early age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d91d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the planning, development, and implementation of projects and activities that will improve safety and reduce traffic, fuel consumption, and air pollution in the vicinity of schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d91e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Apportionment of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e89d91f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2), (3), and (4), amounts made available to carry out this section for a fiscal year shall be apportioned among the States so that each State receives the amount equal to the proportion that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e89d920-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total student enrollment in primary, middle, and high schools in each State; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e89d921-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total student enrollment in primary, middle, and high schools in all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d922-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum apportionment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No State shall receive an apportionment under this section for a fiscal year of less than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d923-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Set-aside for administrative expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before apportioning under this subsection amounts made available to carry out this section for a fiscal year, the Secretary shall set aside not more than $3,000,000 of those amounts for the administrative expenses of the Secretary in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d924-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of student enrollments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Determinations under this subsection relating to student enrollments shall be made by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d925-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts apportioned to a State under this section shall be administered by the State department of transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d926-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts apportioned to a State under this section shall be used by the State to provide financial assistance to State, local, Tribal, and regional agencies, including nonprofit organizations, that demonstrate an ability to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d927-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects and Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e89d928-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Infrastructure-related projects.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e89d929-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts apportioned to a State under this section may be used for the planning, design, and construction of infrastructure-related projects that will substantially improve the ability of students to walk and bicycle to school, including sidewalk improvements, traffic calming and speed reduction improvements, pedestrian and bicycle crossing improvements, on-street bicycle facilities, off-street bicycle and pedestrian facilities, secure bicycle parking facilities, and traffic diversion improvements in the vicinity of schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e89d92a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Infrastructure-related projects under subparagraph (A) may be carried out on any public road or any bicycle or pedestrian pathway or trail in the vicinity of schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d92b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noninfrastructure-related activities.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e89d92c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to projects described in paragraph (1), amounts apportioned to a State under this section may be used for noninfrastructure-related activities to encourage walking and bicycling to school, including public awareness campaigns and outreach to press and community leaders, traffic education and enforcement in the vicinity of schools, student sessions on bicycle and pedestrian safety, health, and environment, and funding for training, volunteers, and managers of safe routes to school programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e89d92d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 10 percent and not more than 30 percent of the amount apportioned to a State under this section for a fiscal year shall be used for noninfrastructure-related activities under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d92e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safe routes to school coordinator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State shall use a sufficient amount of the apportionment of the State for each fiscal year to fund a full-time position of coordinator of the safe routes to school program of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d92f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clearinghouse.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e89d930-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to a national nonprofit organization engaged in promoting safe routes to schools—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e89d931-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate a national safe routes to school clearinghouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e89d932-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop information and educational programs on safe routes to school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e89d933-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance and disseminate techniques and strategies used for successful safe routes to school programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e89d934-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out this subsection using amounts set aside for administrative expenses under subsection (d)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e89d935-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s208/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a project assisted under this section shall be treated as a project on a Federal-aid highway under chapter 1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e89d936-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11119/a"},"text":"Pub. L. 117–58, div. A, title I, § 11119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/495"},"text":"135 Stat. 495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e89d937-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e89d938-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e89d939-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 208, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/908"},"text":"72 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/282"},"text":"Pub. L. 87–282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/584"},"text":"75 Stat. 584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/643/s102/c"},"text":"Pub. L. 93–643, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2281"},"text":"88 Stat. 2281","children":[],"tail":", provided for use of funds for construction and improvement of Indian reservation roads and bridges, supervision of such projects by the Secretary, that such funds be only supplementary to funds apportioned under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of this title","children":[],"tail":", for use of Indian labor in such projects, and for cooperation with States and localities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tI/s126/d"},"text":"Pub. L. 97–424, title I, § 126(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2115"},"text":"96 Stat. 2115","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e89d93a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e89d93b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
