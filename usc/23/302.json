{"tag":"section","attrib":{"id":"id2e8e93c1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"§ 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State transportation department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e8e93c2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State desiring to avail itself of the provisions of this title shall have a State transportation department which shall have adequate powers, and be suitably equipped and organized to discharge to the satisfaction of the Secretary the duties required by this title. In meeting the provisions of this subsection, a State may engage, to the extent necessary or desirable, the services of private engineering firms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e93c3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Compliance with subsection (a) shall have no effect on the eligibility of costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e8e93c4-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/912"},"text":"72 Stat. 912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/574/s11"},"text":"Pub. L. 89–574, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-13"},"text":"Sept. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/770"},"text":"80 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1212/a/1"},"text":"Pub. L. 105–178, title I, § 1212(a)(1)","children":[],"tail":", (2)(A)(i), (B)(ii), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/193"},"text":"112 Stat. 193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e8e93c5-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e8e93c6-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e8e93c7-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1212/a/2/B/ii"},"text":"Pub. L. 105–178, § 1212(a)(2)(B)(ii)","children":[],"tail":", substituted “State transportation department” for “State highway department” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1212/a/1/A"},"text":"Pub. L. 105–178, § 1212(a)(1)(A)","children":[],"tail":", (2)(A)(i), substituted “State transportation department” for “State highway department” and struck out after first sentence “Among other things, the organization shall include a secondary road unit.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1212/a/1/B"},"text":"Pub. L. 105–178, § 1212(a)(1)(B)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “The State highway department may arrange with a county or group of counties for competent highway engineering personnel suitably organized and equipped to the satisfaction of the State highway department, to supervise construction and maintenance on a county-unit or group-unit basis, for the construction of proj­ects on the Federal-aid secondary system, financed with secondary funds, and for the maintenance thereof.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
