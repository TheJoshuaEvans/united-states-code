{"tag":"section","attrib":{"id":"id2e803c0d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177"},"text":null,"children":[{"tag":"num","attrib":{"value":"177"},"text":"§ 177.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Neighborhood access and equity grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e803c0e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $1,893,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to the Administrator of the Federal Highway Administration for competitive grants to eligible entities described in subsection (b)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c0f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve walkability, safety, and affordable transportation access through projects that are context-sensitive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c10-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to remove, remediate, or reuse a facility described in subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c11-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to replace a facility described in subsection (c)(1) with a facility that is at-grade or lower speed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c12-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to retrofit or cap a facility described in subsection (c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c13-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build or improve complete streets, multiuse trails, regional greenways, or active transportation networks and spines; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c14-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide affordable access to essential destinations, public spaces, or transportation links and hubs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c15-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to mitigate or remediate negative impacts on the human or natural environment resulting from a facility described in subsection (c)(2) in a disadvantaged or underserved community through—","children":[],"tail":null},{"tag":"subpara