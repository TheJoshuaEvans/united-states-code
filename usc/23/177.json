t":" safety improvements for vulnerable road users; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c1b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for planning and capacity building activities in disadvantaged or underserved communities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c1c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify, monitor, or assess local and ambient air quality, emissions of transportation greenhouse gases, hot spot areas of extreme heat or elevated air pollution, gaps in tree canopy coverage, or flood prone transportation infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c1d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess transportation equity or pollution impacts and develop local anti-displacement policies and community benefit agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c1e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct predevelopment activities for projects eligible under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c1f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand public participation in transportation planning by individuals and organizations in disadvantaged or underserved communities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c20-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer or obtain technical assistance related to activities described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c21-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity referred to in subsection (a) is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c22-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c23-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c24-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c25-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in section 207(m)(1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c26-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c27-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special purpose district or public authority with a transportation function;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c28-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization (as defined in section 134(b)(2)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c29-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a grant described in subsection (a)(3), in addition to an eligible entity described in paragraphs (1) through (7), a nonprofit organization or institution of higher education that has entered into a partnership with an eligible entity described in paragraphs (1) through (7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c2a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facility Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A facility referred to in subsection (a) is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c2b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surface transportation facility for which high speeds, grade separation, or other design factors create an obstacle to connectivity within a community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c2c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surface transportation facility which is a source of air pollution, noise, stormwater, or other burden to a disadvantaged or underserved community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c2d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment in Economically Disadvantaged Communities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c2e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $1,262,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to the Administrator of the Federal Highway Administration to provide grants for projects in communities described in paragraph (2) for the same purposes and administered in the same manner as described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c2f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communities described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A community referred to in paragraph (1) is a community that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c30-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is economically disadvantaged, underserved, or located in an area of persistent poverty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c31-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered or will enter into a community benefits agreement with representatives of the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c32-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an anti-displacement policy, a community land trust, or a community advisory board in effect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c33-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated a plan for employing local residents in the area impacted by the activity or project proposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c34-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c35-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A project carried out under subsection (a) or (d) shall be treated as a project on a Federal-aid highway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c36-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with existing requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available for a grant under this section and administered by or through a State department of transportation shall be expended in compliance with the U.S. Department of Transportation’s Disadvantaged Business Enterprise Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c37-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity carried out using a grant awarded under this section shall be not more than 80 percent, except that the Federal share of the cost of a project in a disadvantaged or underserved community may be up to 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c38-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $50,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to the Administrator of the Federal Highway Administration for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c39-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance, technical assistance, templates, training, or tools to facilitate efficient and effective contracting, design, and project delivery by units of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c3a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subgrants to units of local government to build capacity of such units of local government to assume responsibilities to deliver surface transportation projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c3b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operations and administration of the Federal Highway Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c3c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available under this section shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c3d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to any restriction or limitation on the total amount of funds available for implementation or execution of programs authorized for Federal-aid highways; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c3e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s177/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be used for a project for additional through travel lanes for single-occupant passenger vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e803c3f-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60501/a"},"text":"Pub. L. 117–169, title VI, § 60501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2080"},"text":"136 Stat. 2080","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
