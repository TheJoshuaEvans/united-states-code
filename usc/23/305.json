{"tag":"section","attrib":{"id":"id2e8e93d5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Archeological and paleontological salvage","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds authorized to be appropriated to carry out this title to the extent approved as necessary by the highway department of any State, may be used for archeological and paleontological salvage in that State in compliance with the Act entitled “An Act for the preservation of American antiquities”, approved ","children":[{"tag":"date","attrib":{"date":"1906-06-08"},"text":"June 8, 1906","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/34/225"},"text":"34 Stat. 225","children":[],"tail":"), and State laws where applicable,"}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2e8e93d6-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/913"},"text":"72 Stat. 913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/657/s8/e"},"text":"Pub. L. 86–657, § 8(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/525"},"text":"74 Stat. 525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e8e93d7-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e8e93d8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e8e93d9-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"An Act for the preservation of American antiquities, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-08/ch3060"},"text":"act June 8, 1906, ch. 3060","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/225"},"text":"34 Stat. 225","children":[],"tail":", popularly known as the Antiquities Act of 1906. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e8e93da-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/657"},"text":"Pub. L. 86–657","children":[],"tail":" substituted “appropriated to carry out this title to the extent approved” for “appropriated under the Federal-Aid Highway Act of 1956, to the extent approved”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
