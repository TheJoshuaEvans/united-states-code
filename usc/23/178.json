{"tag":"section","attrib":{"id":"id2e803c40-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178"},"text":null,"children":[{"tag":"num","attrib":{"value":"178"},"text":"§ 178.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental review implementation funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e803c41-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise available, for fiscal year 2022, there is appropriated to the Administrator, out of any money in the Treasury not otherwise appropriated, $100,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", for the purpose of facilitating the development and review of documents for the environmental review process for proposed projects through—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c42-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of guidance, technical assistance, templates, training, or tools to facilitate an efficient and effective environmental review process for surface transportation projects and any administrative expenses of the Federal Highway Administration to conduct activities described in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c43-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing funds made available under this subsection to eligible entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c44-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build capacity of such eligible entities to conduct environmental review processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c45-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to facilitate the environmental review process for proposed projects by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e803c46-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining the scope or study areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c47-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying impacts, mitigation measures, and reasonable alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c48-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing planning and environmental studies and other documents prior to and during the environmental review process, for potential use in the environmental review process in accordance with applicable statutes and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c49-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting public engagement activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c4a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out permitting or other activities, as the Administrator determines to be appropriate, to support the timely completion of an environmental review process required for a proposed project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c4b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administrative expenses of the eligible entity to conduct any of the activities described in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c4c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Share.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c4d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity carried out under this section by an eligible entity shall be not more than 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c4e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The non-Federal share of the cost of an activity carried out under this section by an eligible entity may be satisfied using funds made available to the eligible entity under any other Federal, State, or local grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c4f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c50-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of the Federal Highway Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c51-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c52-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c53-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c54-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c55-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c56-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in section 207(m)(1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c57-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recipient of funds under section 203; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c58-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization (as defined in section 134(b)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c59-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental review process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “environmental review process” has the meaning given the term in section 139(a)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c5a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s178/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposed project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “proposed project” means a surface transportation project for which an environmental review process is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e803c5b-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60505/a"},"text":"Pub. L. 117–169, title VI, § 60505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2083"},"text":"136 Stat. 2083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
