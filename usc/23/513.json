{"tag":"section","attrib":{"id":"id2eb99b8b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513"},"text":null,"children":[{"tag":"num","attrib":{"value":"513"},"text":"§ 513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for ITS activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb99b8c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99b8d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible entity” means a State or local government, tribal government, transit agency, public toll authority, metropolitan planning organization, other political subdivision of a State or local government, or a multistate or multijurisdictional group applying through a single lead applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99b8e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multijurisdictional group","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “multijurisdictional group” means a combination of State governments, local governments, metropolitan planning agencies, transit agencies, or other political subdivisions of a State that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99b8f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have signed a written agreement to implement an activity that meets the grant criteria under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99b90-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comprised of at least 2 members, each of whom is an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99b91-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section is to develop, administer, communicate, and promote the use of products of research, technology, and technology transfer programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99b92-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"ITS Adoption","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99b93-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innovative technologies and strategies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall encourage the deployment of ITS technologies that will improve the performance of the National Highway System in such areas as traffic operations, emergency response, incident management, surface transportation network management, freight management, traffic flow information, and congestion management by accelerating the adoption of innovative technologies through the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99b94-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99b95-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99b96-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentives to eligible entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99b97-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other tools, strategies, or methods that will result in the deployment of innovative ITS technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99b98-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensive plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out this section, the Secretary shall develop a detailed and comprehensive plan that addresses the manner in which incentives may be adopted, as appropriate, through the existing deployment activities carried out by surface transportation modal administrations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb99b99-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tV/s5302/a"},"text":"Pub. L. 109–59, title V, § 5302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1805"},"text":"119 Stat. 1805","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tIII/s53001"},"text":"Pub. L. 112–141, div. E, title III, § 53001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/897"},"text":"126 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb99b9a-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb99b9b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb99b9c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—For each fiscal year, not more than $250,000 of the funds made available to carry out this subtitle C of title V of the SAFETEA–LU shall be used for intelligent transportation system outreach, public relations, displays, tours, and brochures."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—Subsection (a) shall not apply to intelligent transportation system training, scholarships, or the publication or distribution of research findings, technical guidance, or similar documents.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2eb99b9d-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb99b9e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
