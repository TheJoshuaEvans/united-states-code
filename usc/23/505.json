{"tag":"section","attrib":{"id":"id2eb72b13-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State planning and research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb72b14-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Two percent of the sums apportioned to a State for fiscal year 1998 and each fiscal year thereafter under paragraphs (1) through (5) of section 104(b) shall be available for expenditure by the State, in consultation with the Secretary, only for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b15-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engineering and economic surveys and investigations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b16-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning of future highway programs and local public transportation systems and the planning of the financing of such programs and systems, including metropolitan and statewide planning under sections 134 and 135.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b17-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and implementation of management systems, plans, and processes under sections 119, 148, 149, and 167.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b18-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Studies of the economy, safety, and convenience of surface transportation systems and the desirable regulation and equitable taxation of such systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b19-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research, development, and technology transfer activities necessary in connection with the planning, design, construction, management, and maintenance of highway, public transportation, and intermodal transportation systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b1a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Study, research, and training on the engineering standards and construction materials for transportation systems described in paragraph (5), including the evaluation and accreditation of inspection and testing and the regulation and taxation of their use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b1b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conduct of activities relating to the planning of real-time monitoring elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b1c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Expenditures on Research, Development, and Technology Transfer Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b1d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), not less than 25 percent of the funds subject to subsection (a) that are apportioned to a State for a fiscal year shall be expended by the State for research, development, and technology transfer activities described in subsection (a), relating to highway, public transportation, and intermodal transportation systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b1e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the application of paragraph (1) with respect to a State for a fiscal year if the State certifies to the Secretary for the fiscal year that total expenditures by the State for transportation planning under sections 134 and 135 will exceed 75 percent of the funds described in paragraph (1) and the Secretary accepts such certification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b1f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds expended under paragraph (1) shall not be considered to be part of the extramural budget of the agency for the purpose of section 9 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"15 U.S.C. 638","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b20-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of Future Strategic Highway Research Program Findings and Results","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b21-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State shall make available to the Secretary to carry out section 503(c)(2)(C) a percentage of funds subject to subsection (a) that are apportioned to that State, that is agreed to by ¾ of States for each of fiscal years 2013 and 2014.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b22-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds expended under paragraph (1) shall not be considered to be part of the extramural budget of the agency for the purpose of section 9 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"15 U.S.C. 638","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b23-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out using funds subject to subsection (a) shall be 80 percent unless the Secretary determines that the interests of the Federal-aid highway program would be best served by decreasing or eliminating the non-Federal share.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b24-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Sums","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds subject to subsection (a) shall be combined and administered by the Secretary as a single fund and shall be available for obligation for the period described in section 118(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb72b25-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tV/s5105"},"text":"Pub. L. 105–178, title V, § 5105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/432"},"text":"112 Stat. 432","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tV/s5205"},"text":"Pub. L. 109–59, title V, § 5205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1795"},"text":"119 Stat. 1795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52005"},"text":"Pub. L. 112–141, div. E, title II, § 52005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/882"},"text":"126 Stat. 882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1104/e/6"},"text":"Pub. L. 114–94, div. A, title I, § 1104(e)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1332"},"text":"129 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb72b26-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb72b27-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2eb72b28-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 505, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/495/s30"},"text":"Pub. L. 90–495, § 30","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-23"},"text":"Aug. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/831"},"text":"82 Stat. 831","children":[],"tail":", related to highway relocation assistance payments, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/646/tII/s220/a/10"},"text":"Pub. L. 91–646, title II, § 220(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1903"},"text":"84 Stat. 1903","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb72b29-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “through (5)” for “through (4)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s52005/1/A"},"text":"Pub. L. 112–141, § 52005(1)(A)","children":[],"tail":", substituted “paragraphs (1) through (4) of section 104(b)” for “section 104 (other than sections 104(f) and 104(h)) and under section 144” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s52005/1/B"},"text":"Pub. L. 112–141, § 52005(1)(B)","children":[],"tail":", substituted “, plans, and processes under sections 119, 148, 149, and 167” for “under section 303”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s52005/2"},"text":"Pub. L. 112–141, § 52005(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s52005/2"},"text":"Pub. L. 112–141, § 52005(2)","children":[],"tail":", (4), redesignated subsec. (d) as (e) and substituted “section 118(b)” for “section 118(b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s5205/1"},"text":"Pub. L. 109–59, § 5205(1)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s5205/2"},"text":"Pub. L. 109–59, § 5205(2)","children":[],"tail":", substituted “for the period described in section 118(b)(2)” for “for the same period as funds apportioned under section 104(b)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2eb72b2a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb72b2b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb72b2c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id2eb72b2d-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alaska Highway Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/866/s13"},"text":"Pub. L. 87–866, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-23"},"text":"Oct. 23, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1149"},"text":"76 Stat. 1149","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/449/s2/a"},"text":"Pub. L. 97–449, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2439"},"text":"96 Stat. 2439","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/449/s2/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation, in cooperation with the State of Alaska, is hereby authorized to make engineering studies and estimates and planning surveys relative to a highway construction program for the State of Alaska, and, in accordance with treaties or other agreements to be negotiated with Canada by the Secretary of State in consultation with the Secretary of Transportation, engineering studies, estimates, and planning surveys relative to connecting Alaskan roads with Canadian roads at the International boundary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On or before ","children":[{"tag":"date","attrib":{"date":"1964-05-15"},"text":"May 15, 1964","children":[],"tail":", the Secretary of Transportation shall submit a report to the Congress which shall include—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the adequacy of the Federal-aid highway program to provide for a satisfactory program in both the populated and the undeveloped areas in Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific recommendations as to the construction of roads through undeveloped areas of Alaska and connection of such roads with Canadian roads at the International boundary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a feasible program for implementing such specific recommendations, including cost estimates, recommendations as to the sharing of cost responsibilities, and other pertinent matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From time to time, either before or after submission of the report provided for in subsection (b) of this section, the Secretary of Transportation may submit recommendations to the Congress with respect to the construction of particular highways to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed as creating any obligation in the Congress, express or implied, to carry out the recommendations referred to in subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, to be available until expended, the sum of $800,000 for the purpose of making the studies, surveys, and report authorized by subsections (a) and (b) hereof.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
