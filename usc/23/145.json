"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/113"},"text":"112 Stat. 113","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e686e35-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/d/5/B"},"text":"Pub. L. 114–94, § 1446(d)(5)(B)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1519/c"},"text":"Pub. L. 112–141, § 1519(c)","children":[],"tail":". See 2012 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1519/c/9"},"text":"Pub. L. 112–141, § 1519(c)(9)","children":[],"tail":", formerly § 1519(c)(10), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/d/5/B"},"text":"Pub. L. 114–94, § 1446(d)(5)(B)","children":[],"tail":", struck out “"},{"tag":"ref","attrib":{"href":"/us/usc/t23/s117"},"text":"section 117 of this title","children":[],"tail":",” after “21st Century,” second time appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" inserted “section 1702 of the SAFETEA–LU,” after “described in” and “section 1101(a)(16) of the SAFETEA–LU,” after “for such projects by” and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t23/s117"},"text":"section 117 of this title","children":[],"tail":",” for “117 of title 23, United States Code,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" designated existing provisions as subsec. (a), inserted headin