{"tag":"section","attrib":{"id":"id2e7df2d4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175"},"text":null,"children":[{"tag":"num","attrib":{"value":"175"},"text":"§ 175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon reduction program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e7df2d5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df2d6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Metropolitan planning organization; urbanized area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “metropolitan planning organization” and “urbanized area” have the meaning given those terms in section 134(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2d7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation emissions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transportation emissions” means carbon dioxide emissions from on-road highway sources of those emissions within a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2d8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation management area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transportation management area” means a transportation management area identified or designated by the Secretary under section 134(k)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2d9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a carbon reduction program to reduce transportation emissions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2da-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df2db-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), funds apportioned to a State under section 104(b)(7) may be obligated for projects to support the reduction of transportation emissions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df2dc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project described in section 149(b)(4) to establish or operate a traffic monitoring, management, and control facility or program, including advanced truck stop electrification systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2dd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public transportation project that is eligible for assistance under section 142;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2de-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project described in section 101(a)(29) (as in effect on the day before the date of enactment of the FAST Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Public Law 114–94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/1312"},"text":"129 Stat. 1312","children":[],"tail":")), including the construction, planning, and design of on-road and off-road trail facilities for pedestrians, bicyclists, and other nonmotorized forms of transportation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2df-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project described in section 503(c)(4)(E) for advanced transportation and congestion management technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project for the deployment of infrastructure-based intelligent transportation systems capital improvements and the installation of vehicle-to-infrastructure communications equipment, including retrofitting dedicated short-range communications (DSRC) technology deployed as part of an existing pilot program to cellular vehicle-to-everything (C–V2X) technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to replace street lighting and traffic control devices with energy-efficient alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a carbon reduction strategy in accordance with subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project or strategy that is designed to support congestion pricing, shifting transportation demand to nonpeak hours or other transportation modes, increasing vehicle occupancy rates, or otherwise reducing demand for roads, including electronic toll collection, and travel demand management strategies and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to reduce the environmental and community impacts of freight movement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a project to support deployment of alternative fuel vehicles, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df2e6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, installation, or operation of publicly accessible electric vehicle charging infrastructure or hydrogen, natural gas, or propane vehicle fueling infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df2e7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or lease of zero-emission construction equipment and vehicles, including the acquisition, construction, or leasing of required supporting facilities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project described in section 149(b)(8) for a diesel engine retrofit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2e9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project described in section 149(b)(5) that does not result in the construction of new capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2ea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project that reduces transportation emissions at port facilities, including through the advancement of port electrification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2eb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flexibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the eligible projects under paragraph (1), a State may use funds apportioned under section 104(b)(7) for a project eligible under section 133(b) if the Secretary certifies that the State has demonstrated a reduction in transportation emissions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df2ec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as estimated on a per capita basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2ed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as estimated on a per unit of economic output basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carbon Reduction Strategy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df2ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of the Surface Transportation Reauthorization Act of 2021, a State, in consultation with any metropolitan planning organization designated within the State, shall develop a carbon reduction strategy in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The carbon reduction strategy of a State developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df2f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support efforts to reduce transportation emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify projects and strategies to reduce transportation emissions, which may include projects and strategies for safe, reliable, and cost-effective options—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df2f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce traffic congestion by facilitating the use of alternatives to single-occupant vehicle trips, including public transportation facilities, pedestrian facilities, bicycle facilities, and shared or pooled vehicle trips within the State or an area served by the applicable metropolitan planning organization, if any;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df2f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the use of vehicles or modes of travel that result in lower transportation emissions per person-mile traveled as compared to existing vehicles and modes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df2f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate approaches to the construction of transportation assets that result in lower transportation emissions as compared to existing approaches;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the reduction of transportation emissions of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the State, quantify the total carbon emissions from the production, transport, and use of materials used in the construction of transportation facilities within the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appropriate to the population density and context of the State, including any metropolitan planning organization designated within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The carbon reduction strategy of a State developed under paragraph (1) shall be updated not less frequently than once every 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which a State submits a request for the approval of a carbon reduction strategy developed by the State under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df2fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the process used to develop the carbon reduction strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df2fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df2fd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the carbon reduction strategy meets the requirements of paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df2fe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny certification of the carbon reduction strategy and specify the actions necessary for the State to take to correct the deficiencies in the process of the State in developing the carbon reduction strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df2ff-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of a State, the Secretary shall provide technical assistance in the development of the carbon reduction strategy under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df300-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suballocation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7df301-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, of the funds apportioned to the State under section 104(b)(7)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df302-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 65 percent shall be obligated, in proportion to their relative shares of the population of the State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df303-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in urbanized areas of the State with an urbanized area population of more than 200,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df304-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in urbanized areas of the State with an urbanized population of not less than 50,000 and not more than 200,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df305-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in urban areas of the State with a population of not less than 5,000 and not more than 49,999; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df306-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in other areas of the State with a population of less than 5,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df307-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remainder may be obligated in any area of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df308-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Metropolitan areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds attributed to an urbanized area under paragraph (1)(A)(i) may be obligated in the metropolitan area established under section 134 that encompasses the urbanized area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df309-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution among urbanized areas of over 50,000 population.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df30a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the amounts that a State is required to obligate under clauses (i) and (ii) of paragraph (1)(A) shall be obligated in urbanized areas described in those clauses based on the relative population of the areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df30b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State may obligate the funds described in subparagraph (A) based on other factors if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df30c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State and the relevant metropolitan planning organizations jointly apply to the Secretary for the permission to base the obligation on other factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df30d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary grants the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df30e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination in urbanized areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before obligating funds for an eligible project under subsection (c) in an urbanized area that is not a transportation management area, a State shall coordinate with any metropolitan planning organization that represents the urbanized area prior to determining which activities should be carried out under the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df30f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation in rural areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before obligating funds for an eligible project under subsection (c) in a rural area, a State shall consult with any regional transportation planning organization or metropolitan planning organization that represents the rural area prior to determining which activities should be carried out under the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7df310-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7df311-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that is required to obligate in an urbanized area with an urbanized area population of 50,000 or more under this subsection funds apportioned to the State under section 104(b)(7) shall make available during the period of fiscal years 2022 through 2026 an amount of obligation authority distributed to the State for Federal-aid highways and highway safety construction programs for use in the area that is equal to the amount obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7df312-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of funds that the State is required to obligate in the area under this subsection during the period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7df313-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7df314-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of obligation authority distributed to the State for Federal-aid highways and highway safety construction programs during the period; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7df315-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total of the sums apportioned to the State for Federal-aid highways and highway safety construction programs (excluding sums not subject to an obligation limitation) during the period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7df316-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State, each affected metropolitan planning organization, and the Secretary shall jointly ensure compliance with subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df317-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out using funds apportioned to a State under section 104(b)(7) shall be determined in accordance with section 120.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df318-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s175/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a project assisted under this section shall be treated as a project on a Federal-aid highway under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7df319-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11403/a"},"text":"Pub. L. 117–58, div. A, title I, § 11403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/555"},"text":"135 Stat. 555","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e7df31a-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e7df31b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e7df31c-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the FAST Act, referred to in subsec. (c)(1)(C), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Surface Transportation Reauthorization Act of 2021, referred to in subsec. (d)(1), is the date of enactment of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7df31d-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e7df31e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
