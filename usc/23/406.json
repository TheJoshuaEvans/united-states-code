{"tag":"section","attrib":{"id":"id2ea68934-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406"},"text":null,"children":[{"tag":"num","attrib":{"value":"406"},"text":"§ 406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements for Federal assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ea68935-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Funded Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “funded project” means a project funded, in whole or in part, by a grant provided under section 402 or 405.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68936-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulatory Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each funded project shall be carried out in accordance with applicable regulations promulgated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68937-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Matching Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a grant provided under this chapter requires any State to share in the cost of a funded project, the aggregate of the expenditures made by the State (including any political subdivision of the State) for highway safety activities during a fiscal year, exclusive of Federal funds, for carrying out the funded project (other than expenditures for planning or administration) shall be credited toward the non-Federal share of the cost of any other funded project (other than planning and administration) during that fiscal year, regardless of whether those expenditures were made in connection with the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68938-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Application and Deadline.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea68939-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under this chapter, a State shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea6893a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a single deadline for the submission of applications under paragraph (1) to enable the provision of grants under this chapter early in each applicable fiscal year beginning after the date of submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea6893b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Funds to States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the later of the start of a fiscal year or the date of enactment of any appropriations Act making funds available to carry out this chapter for that fiscal year, the Secretary shall distribute to each State the portion of those funds to which the State is entitled for the applicable fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ea6893c-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24101/d/1/B"},"text":"Pub. L. 117–58, div. B, title IV, § 24101(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/784"},"text":"135 Stat. 784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ea6893d-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2ea6893e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2ea6893f-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 406, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/643/s126/a"},"text":"Pub. L. 93–643, § 126(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2291"},"text":"88 Stat. 2291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/280/tII/s205"},"text":"Pub. L. 94–280, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-05"},"text":"May 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/453"},"text":"90 Stat. 453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/599/tI/s129/g"},"text":"Pub. L. 95–599, title I, § 129(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2708"},"text":"92 Stat. 2708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tII/s2005/a"},"text":"Pub. L. 109–59, title II, § 2005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1524"},"text":"119 Stat. 1524","children":[],"tail":", related to safety belt performance grants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"Pub. L. 112–141, § 3(a)","children":[],"tail":", div. C, title I, § 31109(b), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/413"},"text":"126 Stat. 413","children":[],"tail":", 756, effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
