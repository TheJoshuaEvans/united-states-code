{"tag":"section","attrib":{"id":"id2e74553b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158"},"text":null,"children":[{"tag":"num","attrib":{"value":"158"},"text":"§ 158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National minimum drinking age","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e74553c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding of Funds for Noncompliance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e74553d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e74553e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal years before 2012","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall withhold 10 per centum of the amount required to be apportioned to any State under each of sections 104(b)(1), 104(b)(3), and 104(b)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title on the first day of each fiscal year after the second fiscal year beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", in which the purchase or public possession in such State of any alcoholic beverage by a person who is less than twenty-one years of age is lawful."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74553f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year 2012 and thereafter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For fiscal year 2012 and each fiscal year thereafter, the amount to be withheld under this section shall be an amount equal to 8 percent of the amount apportioned to the noncompliant State, as described in subparagraph (A), under paragraphs (1) and (2) of section 104(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745540-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State grandfather law as complying","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, before the later of (A) ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":", or (B) the tenth day following the last day of the first session the legislature of a State convenes after the date of the enactment of this paragraph, such State has in effect a law which makes unlawful the purchase and public possession in such State of any alcoholic beverage by a person who is less than 21 years of age (other than any person who is 18 years of age or older on the day preceding the effective date of such law and at such time could lawfully purchase or publicly possess any alcoholic beverage in such State), such State shall be deemed to be in compliance with paragraph (1) in each fiscal year in which such law is in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e745541-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Withholding of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No funds withheld under this section from apportionment to any State after ","children":[{"tag":"date","attrib":{"date":"1988-09-30"},"text":"September 30, 1988","children":[],"tail":", shall be available for apportionment to that State."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e745542-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alcoholic Beverage Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term “alcoholic beverage” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e745543-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beer as defined in section 5052(a) of the Internal Revenue Code of 1986,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745544-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wine of not less than one-half of 1 per centum of alcohol by volume, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745545-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s158/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distilled spirits as defined in section 5002(a)(8) of such Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e745546-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/363/s6/a"},"text":"Pub. L. 98–363, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/437"},"text":"98 Stat. 437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tIV/s4104"},"text":"Pub. L. 99–272, title IV, § 4104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/114"},"text":"100 Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1103"},"text":"Pub. L. 105–178, title I, § 1103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/125"},"text":"112 Stat. 125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1404/f"},"text":"Pub. L. 112–141, div. A, title I, § 1404(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/558"},"text":"126 Stat. 558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e745547-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e745548-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e745549-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"Section 104 of this title","children":[],"tail":", referred to in subsec. (a)(1)(A), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1105/a"},"text":"Pub. L. 112–141, div. A, title I, § 1105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/427"},"text":"126 Stat. 427","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (a)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (c), is set out in Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e74554a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" designated existing provisions as subpar. (A), inserted subpar. heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1103"},"text":"Pub. L. 105–178, § 1103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(A)(i)–(iii), redesignated par. (2) as (1), substituted “In general” for “After the first year” in heading and “104(b)(3), and 104(b)(4)” for “104(b)(2), 104(b)(5), and 104(b)(6)” in text, and struck out former par. (1) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"First year","children":[],"tail":".—The Secretary shall withhold 5 per centum of the amount required to be apportioned to any State under each of sections 104(b)(1), 104(b)(2), 104(b)(5), and 104(b)(6) of this title on the first day of the fiscal year succeeding the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", in which the purchase or public possession in such State of any alcoholic beverage by a person who is less than twenty-one years of age is lawful.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1103"},"text":"Pub. L. 105–178, § 1103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(A)(ii), (iv), redesignated par. (3) as (2) and substituted “paragraph (1)” for “paragraphs (1) and (2) of this subsection”. Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1103"},"text":"Pub. L. 105–178, § 1103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B), added subsec. (b) and struck out heading and text of former subsec. (b) which related to period of availability for apportionment to State of funds withheld by the Secretary pending State enactment of federally-prescribed minimum drinking age."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4104/d/1"},"text":"Pub. L. 99–272, § 4104(d)(1)","children":[],"tail":", added subsection heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4104/d/2"},"text":"Pub. L. 99–272, § 4104(d)(2)","children":[],"tail":"–(4), added paragraph heading, aligned margins, and inserted “first” before “fiscal year beginning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4104/a"},"text":"Pub. L. 99–272, § 4104(a)","children":[],"tail":", (d)(3), (5), added paragraph heading, realigned margins, and substituted “each fiscal year after” for “the fiscal year succeeding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4104/b"},"text":"Pub. L. 99–272, § 4104(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4104/c"},"text":"Pub. L. 99–272, § 4104(c)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The Secretary shall promptly apportion to a State any funds which have been withheld from apportionment under subsection (a) of this section in fiscal year if in any succeeding fiscal year such State makes unlawful the purchase or public possession of any alcoholic beverage by a person who is less than twenty-one years of age.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/s4104/d/6"},"text":"Pub. L. 99–272, § 4104(d)(6)","children":[],"tail":", added subsection heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e74554b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e74554c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id2e74554d-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Minimum Drinking Age","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424/tII/s209"},"text":"Pub. L. 97–424, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2140"},"text":"96 Stat. 2140","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/424/tII/s209"},"text":"“The Congress strongly encourages each State to prohibit the sale of alcoholic beverages to persons who are less than 21 years of age.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
