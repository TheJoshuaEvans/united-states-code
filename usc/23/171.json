{"tag":"section","attrib":{"id":"id2e7b81c1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171"},"text":null,"children":[{"tag":"num","attrib":{"value":"171"},"text":"§ 171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildlife crossings pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e7b81c2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that greater adoption of wildlife-vehicle collision safety countermeasures is in the public interest because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81c3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to the report of the Federal Highway Administration entitled “Wildlife-Vehicle Collision Reduction Study”, there are more than 1,000,000 wildlife-vehicle collisions every year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81c4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" wildlife-vehicle collisions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b81c5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" present a danger to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b81c6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b81c7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife survival; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81c8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent a persistent concern that results in tens of thousands of serious injuries and hundreds of fatalities on the roadways of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81c9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total annual cost associated with wildlife-vehicle collisions has been estimated to be $8,388,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81ca-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wildlife-vehicle collisions are a major threat to the survival of species, including birds, reptiles, mammals, and amphibians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81cb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a competitive wildlife crossings pilot program (referred to in this section as the “pilot program”) to provide grants for projects that seek to achieve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81cc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in the number of wildlife-vehicle collisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81cd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the purpose described in paragraph (1), improved habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81ce-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to apply for a grant under the pilot program is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81cf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State highway agency, or an equivalent of that agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization (as defined in section 134(b));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional transportation authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special purpose district or public authority with a transportation function, including a port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in section 207(m)(1)), including a Native village and a Native Corporation (as those terms are defined in section 3 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"43 U.S.C. 1602","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal land management agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of any of the entities described in paragraphs (1) through (7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81d7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81d8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under the pilot program, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81d9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an application under paragraph (1) is submitted by an eligible entity other than an eligible entity described in paragraph (1) or (7) of subsection (c), the application shall include documentation that the State highway agency, or an equivalent of that agency, of the State in which the eligible entity is located was consulted during the development of the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81da-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To enhance consideration of current and reliable data, eligible entities may obtain guidance from an agency in the State with jurisdiction over fish and wildlife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81db-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting grant recipients under the pilot program, the Secretary shall take into consideration the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81dc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Primarily, the extent to which the proposed project of an eligible entity is likely to protect motorists and wildlife by reducing the number of wildlife-vehicle collisions and improve habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81dd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Secondarily, the extent to which the proposed project of an eligible entity is likely to accomplish the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b81de-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leveraging Federal investment by encouraging non-Federal contributions to the project, including projects from public-private partnerships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81df-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting local economic development and improvement of visitation opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81e0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incorporation of innovative technologies, including advanced design techniques and other strategies to enhance efficiency and effectiveness in reducing wildlife-vehicle collisions and improving habitat connectivity for terrestrial and aquatic species.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81e1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of educational and outreach opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring and research to evaluate, compare effectiveness of, and identify best practices in, selected projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81e3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other criteria relevant to reducing the number of wildlife-vehicle collisions and improving habitat connectivity for terrestrial and aquatic species, as the Secretary determines to be appropriate, subject to the condition that the implementation of the pilot program shall not be delayed in the absence of action by the Secretary to identify additional criteria under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81e4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that a grant received under the pilot program is used for a project to reduce wildlife-vehicle collisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81e6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant administration.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b81e7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant received under the pilot program shall be administered by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b81e8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant to a Federal land management agency or an Indian tribe (as defined in section 207(m)(1), including a Native village and a Native Corporation (as those terms are defined in section 3 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"43 U.S.C. 1602","children":[],"tail":"))), the Federal Highway Administration, through an agreement; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b81e9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant to an eligible entity other than an eligible entity described in clause (i), the State highway agency, or an equivalent of that agency, for the State in which the project is to be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81ea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnerships.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b81eb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant received under the pilot program may be used to provide funds to eligible partners of the project for which the grant was received described in clause (ii), in accordance with the terms of the project agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b81ec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible partners described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The eligible partners referred to in clause (i) include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7b81ed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization (as defined in section 134(b));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional transportation authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special purpose district or public authority with a transportation function, including a port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in section 207(m)(1)), including a Native village and a Native Corporation (as those terms are defined in section 3 of the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"43 U.S.C. 1602","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal land management agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foundation, nongovernmental organization, or institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal, Tribal, regional, or State government entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7b81f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/2/B/ii/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of any of the entities described in subclauses (I) through (VIII).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible entity that receives a grant under the pilot program and enters into a partnership described in paragraph (2) shall establish measures to verify that an eligible partner that receives funds from the grant complies with the conditions of the pilot program in using those funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that not less than 60 percent of the amounts made available for grants under the pilot program each fiscal year are for projects located in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b81f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 31 of each calendar year, the Secretary shall submit to Congress, and make publicly available, a report describing the activities under the pilot program for the fiscal year that ends during that calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b81fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b81fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the activities carried out under the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of the pilot program in meeting the purposes described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b81fd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy recommendations to improve the effectiveness of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b81fe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s171/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a project assisted under this section shall be treated as a project on a Federal-aid highway under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7b81ff-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11123/b/1"},"text":"Pub. L. 117–58, div. A, title I, § 11123(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/499"},"text":"135 Stat. 499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e7b8200-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7b8201-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e7b8202-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
