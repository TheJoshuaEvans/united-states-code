{"tag":"section","attrib":{"id":"id2e31a722-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing rate of wage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e31a723-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take such action as may be necessary to insure that all laborers and mechanics employed by contractors or subcontractors on the construction work performed on highway projects on the Federal-aid highways authorized under the highway laws providing for the expenditure of Federal funds upon Federal-aid highways, shall be paid wages at rates not less than those prevailing on the same type of work on similar construction in the immediate locality as determined by the Secretary of Labor in accordance with sections 3141–3144, 3146, and 3147 of title 40.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e31a724-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the duties of subsection (a) of this section, the Secretary of Labor shall consult with the highway department of the State in which a project on any Federal-aid highway is to be performed. After giving due regard to the information thus obtained, he shall make a predetermination of the minimum wages to be paid laborers and mechanics in accordance with the provisions of subsection (a) of this section which shall be set out in each project advertisement for bids and in each bid proposal form and shall be made a part of the contract covering the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e31a725-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of the section shall not be applicable to employment pursuant to apprenticeship and skill training programs which have been certified by the Secretary of Transportation as promoting equal employment opportunity in connection with Federal-aid highway construction programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e31a726-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/895"},"text":"72 Stat. 895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/495/s12/a"},"text":"Pub. L. 90–495, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-23"},"text":"Aug. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/821"},"text":"82 Stat. 821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/424/tI/s149"},"text":"Pub. L. 97–424, title I, § 149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-06"},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2131"},"text":"96 Stat. 2131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s133/b/5"},"text":"Pub. L. 100–17, title I, § 133(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/171"},"text":"101 Stat. 171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1006/g/2"},"text":"Pub. L. 102–240, title I, § 1006(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1927"},"text":"105 Stat. 1927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/e/2"},"text":"Pub. L. 107–217, § 3(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1299"},"text":"116 Stat. 1299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1104/c/2"},"text":"Pub. L. 112–141, div. A, title I, § 1104(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/427"},"text":"126 Stat. 427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e31a727-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e31a728-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e31a729-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1104/c/2/A"},"text":"Pub. L. 112–141, § 1104(c)(2)(A)","children":[],"tail":", substituted “Federal-aid highways” for “the Federal-aid systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1104/c/2/B"},"text":"Pub. L. 112–141, § 1104(c)(2)(B)","children":[],"tail":", substituted “Federal-aid highway” for “of the Federal-aid systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “sections 3141–3144, 3146, and 3147 of title 40” for “the Act of "},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":", known as the Davis-Bacon Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":", which directed substitution of “highways” for “systems, the primary and secondary, as well as their extension in urban areas, and the Interstate system,” was executed by making the substitution for the quoted words which in the original contained the word “extensions” rather than “extension”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1935-08-30"},"text":"August 30, 1935","children":[],"tail":"” and “276a” for “267a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/424"},"text":"Pub. L. 97–424","children":[],"tail":" struck out “initial” after “subcontractors on the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/495"},"text":"Pub. L. 90–495","children":[],"tail":" extended wage rate provisions to the construction of all Federal-aid highway projects by amending provisions limiting them only to the Interstate System."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/495"},"text":"Pub. L. 90–495","children":[],"tail":" substituted “any of the Federal-aid systems” for “the Interstate System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/495"},"text":"Pub. L. 90–495","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e31a72a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e31a72b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e31a72c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–24