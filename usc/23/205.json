{"tag":"section","attrib":{"id":"id2e876815-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s205"},"text":null,"children":[{"tag":"num","attrib":{"value":"205"},"text":"§ 205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest development roads and trails","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e876816-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds available for forest development roads and trails shall be used by the Secretary of Agriculture to pay for the costs of construction and maintenance thereof, including roads and trails on experimental and other areas under Forest Service administration. In connection therewith, the Secretary of Agriculture may enter into contracts with a State or civil subdivision thereof, and issue such regulations as he deems advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e876817-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperation of States, counties, or other local subdivisions may be accepted but shall not be required by the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e876818-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction estimated to cost $50,000 or more per mile or $50,000 or more per project for projects with a length of less than one mile, exclusive of bridges and engineering, shall be advertised and let to contract. If such estimated cost is less than $50,000 per mile or $50,000 per project for projects with a length of less than one mile or if, after proper advertising, no acceptable bid is received or the bids are deemed excessive, the work may be done by the Secretary of Agriculture on his own account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e876819-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds available for forest development roads and trails shall be available for adjacent vehicular parking areas, which may include electric vehicle charging stations or natural gas vehicle refueling stations, and for sanitary, water, and fire control facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e87681a-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/907"},"text":"72 Stat. 907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/657/s8/c"},"text":"Pub. L. 86–657, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-14"},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/524"},"text":"74 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/423/s4/d"},"text":"Pub. L. 88–423, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-13"},"text":"Aug. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/398"},"text":"78 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/495/s9"},"text":"Pub. L. 90–495, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-23"},"text":"Aug. 23, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/820"},"text":"82 Stat. 820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1032/c"},"text":"Pub. L. 102–240, title I, § 1032(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1975"},"text":"105 Stat. 1975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1513/c"},"text":"Pub. L. 112–141, div. A, title I, § 1513(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/572"},"text":"126 Stat. 572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e87681b-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e87681c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e87681d-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" inserted “, which may include electric vehicle charging stations or natural gas vehicle refueling stations,” after “parking areas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" substituted “$50,000” for “$15,000” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (c). Pub L. 90–495 increased from $10,000 to $15,000 the cost limitation on construction per mile, or per project for projects of less than a mile, which the Forest Service may construct on its own account and struck out provisions spelling out the functions which the Secretary of Agriculture is authorized to perform in carrying out such construction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/423"},"text":"Pub. L. 88–423","children":[],"tail":" inserted “and other” after “experimental”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/657"},"text":"Pub. L. 86–657","children":[],"tail":" substituted “may enter into contracts” for “may enter into construction contracts”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e87681e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e87681f-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e876820-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", and applicable to funds authorized to be appropriated or made available after "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", and, with certain exceptions, not applicable to funds appropriated or made available on or before "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1100"},"text":"section 1100 of Pub. L. 102–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e876821-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/495"},"text":"Pub. L. 90–495","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-08-23"},"text":"Aug. 23, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/495/s37"},"text":"section 37 of Pub. L. 90–495","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
