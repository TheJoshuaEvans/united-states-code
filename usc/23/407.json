{"tag":"section","attrib":{"id":"id2ea68940-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s407"},"text":null,"children":[{"tag":"num","attrib":{"value":"407"},"text":"§ 407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery and admission as evidence of certain reports and surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, reports, surveys, schedules, lists, or data compiled or collected for the purpose of identifying, evaluating, or planning the safety enhancement of potential accident sites, hazardous roadway conditions, or railway-highway crossings, pursuant to sections 130, 144, and 148 of this title or for the purpose of developing any highway safety construction improvement project which may be implemented utilizing Federal-aid highway funds shall not be subject to discovery or admitted into evidence in a Federal or State court proceeding or considered for other purposes in any action for damages arising from any occurrence at a location mentioned or addressed in such reports, surveys, schedules, lists, or data.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2ea68941-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s132/a"},"text":"Pub. L. 100–17, title I, § 132(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/170"},"text":"101 Stat. 170","children":[],"tail":", § 409; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1035/a"},"text":"Pub. L. 102–240, title I, § 1035(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1978"},"text":"105 Stat. 1978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tIII/s323"},"text":"Pub. L. 104–59, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/591"},"text":"109 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1401/a/3/C"},"text":"Pub. L. 109–59, title I, § 1401(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1225"},"text":"119 Stat. 1225","children":[],"tail":"; renumbered § 407, "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24101/d/1/A"},"text":"Pub. L. 117–58, div. B, title IV, § 24101(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/784"},"text":"135 Stat. 784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ea68942-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2ea68943-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2ea68944-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 407, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/599/tII/s208/a"},"text":"Pub. L. 95–599, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2732"},"text":"92 Stat. 2732","children":[],"tail":", related to innovative project grants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"Pub. L. 112–141, § 3(a)","children":[],"tail":", div. C, title I, § 31109(c), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/413"},"text":"126 Stat. 413","children":[],"tail":", 756, effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2ea68945-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which directed the amendment of this chapter by renumbering section 409 “and” section 407, was executed by renumbering section 409 as this section as if “and” had read “as”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
