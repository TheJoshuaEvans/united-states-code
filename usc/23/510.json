{"tag":"section","attrib":{"id":"id2eb72b42-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510"},"text":null,"children":[{"tag":"num","attrib":{"value":"510"},"text":"§ 510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future strategic highway research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb72b43-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the American Association of State Highway and Transportation Officials, shall establish and carry out, acting through the National Research Council of the National Academy of Sciences, the future strategic highway research program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b44-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make grants to, and enter into cooperative agreements with, the American Association of State Highway and Transportation Officials and the National Academy of Sciences to carry out such activities under this section as the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b45-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Priorities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b46-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under this section shall be based on the National Research Council Special Report 260, entitled “Strategic Highway Research: Saving Lives, Reducing Congestion, Improving Quality of Life” and the results of the detailed planning work subsequently carried out in 2002 and 2003 to identify the research areas through National Cooperative Research Program Project 20–58. The research program shall include an analysis of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb72b47-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renewal of aging highway infrastructure with minimal impact to users of the facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b48-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Driving behavior and likely crash causal factors to support improved countermeasures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b49-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing highway congestion due to nonrecurring congestion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b4a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning and designing new road capacity to meet mobility, economic, environmental, and community needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b4b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissemination of results","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The research results of the program, expressed in terms of technologies, methodologies, and other appropriate categorizations, shall be disseminated to practicing engineers for their use, as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b4c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under this section, the National Research Council shall ensure, to the maximum extent practicable, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b4d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects and researchers are selected to conduct research for the program on the basis of merit and open solicitation of proposals and review by panels of appropriate experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b4e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State department of transportation officials and other stakeholders, as appropriate, are involved in the governance of the program at the overall program level and technical level through the use of expert panels and committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b4f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council acquires a qualified, permanent core staff with the ability and expertise to manage the program and multiyear budget; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b50-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no duplication of research effort between the program and any other research effort of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b51-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Implementation of Results.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b52-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Transportation Research Board of the National Research Council shall complete a report on the strategies and administrative structure to be used for implementation of the results of the future strategic highway research program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b53-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Components","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include with respect to the program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb72b54-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the most promising results of research under the program (including the persons most likely to use the results);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b55-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of potential incentives for, impediments to, and methods of, implementing those results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b56-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of costs of implementation of those results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b57-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on methods by which implementation of those results should be conducted, coordinated, and supported in future years, including a discussion of the administrative structure and organization best suited to carry out those recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b58-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the report, the Transportation Research Board shall consult with a wide variety of stakeholders, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb72b59-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Highway Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b5a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Highway Traffic Safety Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb72b5b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American Association of State Highway and Transportation Officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b5c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-02-01"},"text":"February 1, 2009","children":[],"tail":", the report shall be submitted to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b5d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b5e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity carried out using amounts made available under a grant or cooperative agreement under this section shall be 100 percent, and such funds shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b5f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advance payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make advance payments as necessary to carry out the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b60-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Remedies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb72b61-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Same remedy as if united states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy against the United States provided by sections 1346(b) and 2672 of title 28 for injury, loss of property, personal injury, or death shall apply to any claim against the National Academy of Sciences for money damages for injury, loss of property, personal injury, or death caused by any negligent or wrongful act or omission by employees and individuals described in paragraph (3) arising from activities conducted under or in connection with this section. Any such claim shall be subject to the limitations and exceptions which would be applicable to such claim if such claim were against the United States. With respect to any such claim, the Secretary shall be treated as the head of the appropriate Federal agency for purposes of sections 2672 and 2675 of title 28.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b62-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusiveness of remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy referred to in paragraph (1) shall be exclusive of any other civil action or proceeding for the purpose of determining liability arising from any such act or omission without regard to when the act or omission occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b63-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Employees of the National Academy of Sciences and other individuals appointed by the president of the National Academy of Sciences and acting on its behalf in connection with activities carried out under this section shall be treated as if they are employees of the Federal Government under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2671"},"text":"section 2671 of title 28","children":[],"tail":" for purposes of a civil action or proceeding with respect to a claim described in paragraph (1). The civil action or proceeding shall proceed in the same manner as any proceeding under chapter 171 of title 28 or action against the United States filed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/b"},"text":"section 1346(b) of title 28","children":[],"tail":" and shall be subject to the limitations and exceptions applicable to such a proceeding or action."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb72b64-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payment of any award, compromise, or settlement of a civil action or proceeding with respect to a claim described in paragraph (1) shall be paid first out of insurance maintained by the National Academy of Sciences, second from funds made available to carry out this section, and then from sums made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":". For purposes of such section, such an award, compromise, or settlement shall be deemed to be a judgment, award, or settlement payable under section 2414 or 2672 of title 28. The Secretary may establish a reserve of funds to carry out this section for making payments under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b65-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s510/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this section, the Secretary may use funds made available to carry out this section for implementation of research products related to the future strategic highway research program, including development, demonstration, evaluation, and technology transfer activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb72b66-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tV/s5210/a"},"text":"Pub. L. 109–59, title V, § 5210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1801"},"text":"119 Stat. 1801","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/322/tII/s2203/d"},"text":"Pub. L. 111–322, title II, § 2203(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3526"},"text":"124 Stat. 3526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb72b67-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb72b68-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2eb72b69-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 510, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/605/tI/s117/b"},"text":"Pub. L. 91–605, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1724"},"text":"84 Stat. 1724","children":[],"tail":", related to construction of replacement housing, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/646/tII/s220/a/10"},"text":"Pub. L. 91–646, title II, § 220(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1903"},"text":"84 Stat. 1903","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 510 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s511"},"text":"section 511 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb72b6a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/322"},"text":"Pub. L. 111–322","children":[],"tail":" added subsec. (h)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
