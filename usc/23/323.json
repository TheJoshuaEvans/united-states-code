{"tag":"section","attrib":{"id":"id2e9375cc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323"},"text":null,"children":[{"tag":"num","attrib":{"value":"323"},"text":"§ 323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations and credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e9375cd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Donations of Property Being Acquired","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title, or in any other provision of law, shall be construed to prevent a person whose real property is being acquired in connection with a project under this title, after he has been fully informed of his right to receive just compensation for the acquisition of his property, from making a gift or donation of such property, or any part thereof, or of any of the compensation paid therefor, to a Federal agency, a State or a State agency, or a political subdivision of a State, as said person shall determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e9375ce-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit for Acquired Lands.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e9375cf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this title, the State share of the cost of a project with respect to which Federal assistance is provided from the Highway Trust Fund (other than the Mass Transit Account) may be credited in an amount equal to the fair market value of any land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e9375d0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is lawfully obtained by the State or a unit of local government in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e9375d1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated into the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e9375d2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not land described in section 138; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e9375d3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines will not influence the environmental assessment of the project, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e9375d4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision as to the need to construct the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e9375d5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consideration of alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e9375d6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of a specific location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e9375d7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of fair market value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fair market value of land incorporated into a project and credited under paragraph (1) shall be established in the manner determined by the Secretary, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e9375d8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value shall not include any increase or decrease in the value of donated property caused by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e9375d9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the fair market value of donated land shall be established as of the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e9375da-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the donation becomes effective; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e9375db-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which equitable title to the land vests in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e9375dc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall not apply to donations made by an agency of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e9375dd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on amount of credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The credit received by a State pursuant to this subsection may not exceed the State’s matching share for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e9375de-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit for Donations of Funds, Materials, or Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title or any other law shall prevent a person from offering to donate funds, materials, or services, or a local government from offering to donate funds, materials, or services performed by local government employees, in connection with a project eligible for assistance under this title. In the case of such a project with respect to which the Federal Government and the State share in paying the cost, any donated funds, or the fair market value of any donated materials or services, that are accepted and incorporated into the project by the State transportation department shall be credited against the State share.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e9375df-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A gift or donation in accordance with subsection (a) may be made at any time during the development of a project. Any document executed as part of such donation prior to the approval of an environmental document prepared pursuant to the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) shall clearly indicate that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e9375e0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all alternatives to a proposed alignment will be studied and considered pursuant to such Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e9375e1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition of property under this section shall not influence the environmental assessment of a project including the decision relative to the need to construct the project or the selection of a specific location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e9375e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s323/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any property acquired by gift or donation shall be revested in the grantor or successors in interest if such property is not required for the alignment chosen after public hearings, if required, and completion of the environmental document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e9375e3-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87/tI/s145/a"},"text":"Pub. L. 93–87, title I, § 145(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/273"},"text":"87 Stat. 273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/643/s112"},"text":"Pub. L. 93–643, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2285"},"text":"88 Stat. 2285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s146/a"},"text":"Pub. L. 100–17, title I, § 146(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/179"},"text":"101 Stat. 179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tIII/s322"},"text":"Pub. L. 104–59, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/591"},"text":"109 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI"},"text":"Pub. L. 105–178, title I","children":[],"tail":", §§ 1212(a)(2)(A)(i), 1301(b)–(d)(1), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/193"},"text":"112 Stat. 193","children":[],"tail":", 225, 226; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1902"},"text":"Pub. L. 109–59, title I, § 1902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1464"},"text":"119 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11525/q"},"text":"Pub. L. 117–58, div. A, title I, § 11525(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/608"},"text":"135 Stat. 608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e9375e4-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e9375e5-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e9375e6-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e9375e7-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)” after “National Environmental Policy Act of 1969” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1902/1"},"text":"Pub. L. 109–59, § 1902(1)","children":[],"tail":", inserted “, or a local government from offering to donate funds, materials, or services performed by local government employees,” before “in connection with a project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1902/2"},"text":"Pub. L. 109–59, § 1902(2)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “A contribution by a unit of local government of real property, funds, or material in connection with a project eligible for assistance under this title shall be credited against the State share of the project at the fair market value of the real property, funds, or material.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1301/d/1"},"text":"Pub. L. 105–178, § 1301(d)(1)","children":[],"tail":", substituted “Donations and credits” for “Donations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1301/b/1"},"text":"Pub. L. 105–178, § 1301(b)(1)","children":[],"tail":", substituted “Acquired” for “Donated” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1301/b/2"},"text":"Pub. L. 105–178, § 1301(b)(2)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—Notwithstanding any provision of this title, the State matching share for a project with respect to which Federal assistance is provided out of the Highway Trust Fund (other than the Mass Transit Account) may be credited by the fair market value of land incorporated into the project and lawfully donated to the State after the date of the enactment of this subsection."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Establishment of fair market value","children":[],"tail":".—The fair market value of the donated land shall be established as determined by the Secretary. Fair market value shall not include increases and decreases in the value of donated property caused by the project. For purposes of this subsection, the fair market value of donated land shall be established as of the date the donation becomes effective or when equitable title to the land vests in the State, whichever is earlier.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1301/b/3"},"text":"Pub. L. 105–178, § 1301(b)(3)","children":[],"tail":", substituted “agency of the Federal Government” for “agency of a Federal, State, or local government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1301/b/4"},"text":"Pub. L. 105–178, § 1301(b)(4)","children":[],"tail":", struck out “to which the donation is applied” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1212/a/2/A/i"},"text":"Pub. L. 105–178, § 1212(a)(2)(A)(i)","children":[],"tail":", substituted “State transportation department” for “State highway department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s1301/c"},"text":"Pub. L. 105–178, § 1301(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59"},"text":"Pub. L. 104–59","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/643"},"text":"Pub. L. 93–643","children":[],"tail":" substituted “after he has been fully informed of his right to receive just compensation for the acquisition of his property” for “after he has been tendered the full amount of the estimated just compensation as established by an approved appraisal of the fair market value of the subject real property”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e9375e8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e9375e9-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
