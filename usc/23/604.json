{"tag":"section","attrib":{"id":"id2ec0a077-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604"},"text":null,"children":[{"tag":"num","attrib":{"value":"604"},"text":"§ 604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lines of credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ec0a078-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a079-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) through (4), the Secretary may enter into agreements to make available to 1 or more obligors lines of credit in the form of direct loans to be made by the Secretary at future dates on the occurrence of certain events for any project selected under section 602.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a07a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The proceeds of a line of credit made available under this section shall be available to pay debt service on project obligations issued to finance eligible project costs, extraordinary repair and replacement costs, operation and maintenance expenses, and costs associated with unexpected Federal or State environmental restrictions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a07b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entering into an agreement under this subsection, the Secretary, in consultation with the Director of the Office of Management and Budget and each rating agency providing a preliminary rating opinion letter under section 602(b)(3), shall determine an appropriate capital reserve subsidy amount for each line of credit, taking into account the rating opinion letter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a07c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment-grade rating requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The funding of a line of credit under this section shall be contingent on the senior obligations of the project receiving an investment-grade rating from 2 rating agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a07d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a07e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A line of credit under this section with respect to a project shall be on such terms and conditions and contain such covenants, representations, warranties, and requirements (including requirements for audits) as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a07f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount of a line of credit under this section shall not exceed 33 percent of the reasonably anticipated eligible project costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a080-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Draws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any draw on a line of credit under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a081-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent a direct loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a082-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made only if net revenues from the project (including capitalized interest, but not including reasonably required financing reserves) are insufficient to pay the costs specified in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a083-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraphs (B) and (C) of section 603(b)(4), the interest rate on a direct loan resulting from a draw on the line of credit shall be not less than the yield on 30-year United States Treasury securities, as of the date of execution of the line of credit agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a084-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A line of credit issued under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a085-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec0a086-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be payable, in whole or in part, from—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2ec0a087-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tolls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec0a088-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec0a089-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments owing to the obligor under a public-private partnership; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec0a08a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other dedicated revenue sources that also secure the senior project obligations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec0a08b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a rate covenant, coverage requirement, or similar security feature supporting the project obligations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a08c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may have a lien on revenues described in subparagraph (A), subject to any lien securing project obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a08d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The full amount of a line of credit under this section, to the extent not drawn upon, shall be available during the 10-year period beginning on the date of substantial completion of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a08e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights of third-party creditors","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a08f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Against federal government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A third-party creditor of the obligor shall not have any right against the Federal Government with respect to any draw on a line of credit under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a090-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An obligor may assign a line of credit under this section to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec0a091-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more lenders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec0a092-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trustee on the behalf of such a lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a093-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonsubordination","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a094-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), a direct loan under this section shall not be subordinated to the claims of any holder of project obligations in the event of bankruptcy, insolvency, or liquidation of the obligor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a095-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pre-existing indenture","children":[],"tail":".—"}],"tail":null},{"tag":"clause","attrib":{"id":"id2ec0a096-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall waive the requirement of subparagraph (A) for a public agency borrower that is financing ongoing capital programs and has outstanding senior bonds under a preexisting indenture, if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2ec0a097-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the line of credit is rated in the A category or higher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec0a098-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the TIFIA program loan resulting from a draw on the line of credit is payable from pledged revenues not affected by project performance, such as a tax-backed revenue pledge or a system-backed pledge of project revenues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec0a099-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the TIFIA program share of eligible project costs is 33 percent or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec0a09a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary waives the nonsubordination requirement under this subparagraph—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2ec0a09b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum credit subsidy to be paid by the Federal Government shall be not more than 10 percent of the principal amount of the secured loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2ec0a09c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/8/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligor shall be responsible for paying the remainder of the subsidy cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a09d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish fees at a level sufficient to cover all or a portion of the costs to the Federal Government of providing a line of credit under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a09e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to other credit instruments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A project that receives a line of credit under this section also shall not receive a secured loan or loan guarantee under section 603 in an amount that, combined with the amount of the line of credit, exceeds 49 percent of eligible project costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a09f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0a0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish repayment terms and conditions for each direct loan under this section based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a0a1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cash flow from project revenues and other repayment sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a0a2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the useful life of the asset being financed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0a3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All repayments of principal or interest on a direct loan under this section shall be scheduled—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a0a4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to commence not later than 5 years after the end of the period of availability specified in subsection (b)(6); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a0a5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s604/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conclude, with full repayment of principal and interest, by the date that is 25 years after the end of the period of availability specified in subsection (b)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ec0a0a6-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1503/a"},"text":"Pub. L. 105–178, title I, § 1503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/247"},"text":"112 Stat. 247","children":[],"tail":", § 184; renumbered § 604 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI"},"text":"Pub. L. 109–59, title I","children":[],"tail":", §§ 1601(e), 1602(b)(4), (d), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1241"},"text":"119 Stat. 1241","children":[],"tail":", 1247; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tII/s2002"},"text":"Pub. L. 112–141, div. A, title II, § 2002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/617"},"text":"126 Stat. 617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ec0a0a7-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2ec0a0a8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2ec0a0a9-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended section generally. Prior to amendment, section related to lines of credit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1602/d"},"text":"Pub. L. 109–59, § 1602(d)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s184"},"text":"section 184 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1602/b/4/A"},"text":"Pub. L. 109–59, § 1602(b)(4)(A)","children":[],"tail":", substituted “602” for “182”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1602/b/4/B"},"text":"Pub. L. 109–59, § 1602(b)(4)(B)","children":[],"tail":", substituted “602(b)(2)(B)” for “182(b)(2)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/1/A"},"text":"Pub. L. 109–59, § 1601(e)(1)(A)","children":[],"tail":", added par. (2) and struck out heading and text of former par. (2). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) ","children":[{"tag":"inline","attrib":{},"text":"Total amount","children":[],"tail":".—The total amount of the line of credit shall not exceed 33 percent of the reasonably anticipated eligible project costs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) 1-","children":[{"tag":"inline","attrib":{},"text":"year draws","children":[],"tail":".—The amount drawn in any 1 year shall not exceed 20 percent of the total amount of the line of credit.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/1/B"},"text":"Pub. L. 109–59, § 1601(e)(1)(B)","children":[],"tail":", substituted “but not including reasonably required financing reserves” for “, any debt service reserve fund, and any other available reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/1/C"},"text":"Pub. L. 109–59, § 1601(e)(1)(C)","children":[],"tail":", struck out “marketable” before “United States Treasury securities” and substituted “date of execution of the line of credit agreement” for “date on which the line of credit is obligated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/1/D"},"text":"Pub. L. 109–59, § 1601(e)(1)(D)","children":[],"tail":", inserted “that also secure the senior project obligations” after “sources”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/1/E"},"text":"Pub. L. 109–59, § 1601(e)(1)(E)","children":[],"tail":", substituted “The full amount of the line of credit, to the extent not drawn upon,” for “The line of credit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1602/b/4/C"},"text":"Pub. L. 109–59, § 1602(b)(4)(C)","children":[],"tail":", substituted “603” for “183”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/2/A"},"text":"Pub. L. 109–59, § 1601(e)(2)(A)","children":[],"tail":", struck out “scheduled” before “repayments”, inserted “be scheduled to” after “shall”, and substituted “to conclude, with full repayment of principal and interest,” for “be fully repaid, with interest,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1601/e/2/B"},"text":"Pub. L. 109–59, § 1601(e)(2)(B)","children":[],"tail":", struck out heading and text of par. (3). Text read as follows: “The sources of funds for scheduled loan repayments under this section shall include tolls, user fees, or other dedicated revenue sources.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2ec0a0aa-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2ec0a0ab-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
