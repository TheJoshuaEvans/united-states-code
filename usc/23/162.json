{"tag":"section","attrib":{"id":"id2e745584-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162"},"text":null,"children":[{"tag":"num","attrib":{"value":"162"},"text":"§ 162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National scenic byways program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e745585-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Roads.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e745586-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a national scenic byways program that recognizes roads having outstanding scenic, historic, cultural, natural, recreational, and archaeological qualities by designating the roads as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e745587-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Scenic Byways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745588-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All-American Roads; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745589-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" America’s Byways.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74558a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate roads to be recognized under the national scenic byways program in accordance with criteria developed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74558b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e74558c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be considered for a designation, a road must be nominated by a State, an Indian tribe, or a Federal land management agency and must first be designated as a State scenic byway, an Indian tribe scenic byway, or, in the case of a road on Federal land, as a Federal land management agency byway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74558d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nomination by indian tribes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Indian tribe may nominate a road as a National Scenic Byway, an All-American Road, or one of America’s Byways under paragraph (1) only if a Federal land management agency (other than the Bureau of Indian Affairs), a State, or a political subdivision of a State does not have—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e74558e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jurisdiction over the road; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e74558f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsibility for managing the road.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745590-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An Indian tribe shall maintain the safety and quality of roads nominated by the Indian tribe under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745591-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reciprocal notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"States, Indian tribes, and Federal land management agencies shall notify each other regarding nominations made under this subsection for roads that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e745592-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are within the jurisdictional boundary of the State, Federal land management agency, or Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745593-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly connect to roads for which the State, Federal land management agency, or Indian tribe is responsible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e745594-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants and Technical Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e745595-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants and provide technical assistance to States and Indian tribes to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e745596-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement projects on highways designated as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e745597-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Scenic Byways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e745598-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All-American Roads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e745599-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" America’s Byways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e74559a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State scenic byways; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e74559b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribe scenic byways; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74559c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan, design, and develop a State or Indian tribe scenic byway program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74559d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants, the Secretary shall give priority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e74559e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each eligible project that is associated with a highway that has been designated as a National Scenic Byway, All-American Road, or 1 of America’s Byways and that is consistent with the corridor management plan for the byway;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74559f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each eligible project along a State or Indian tribe scenic byway that is consistent with the corridor management plan for the byway, or is intended to foster the development of such a plan, and is carried out to make the byway eligible for designation as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7455a0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National Scenic Byway;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7455a1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an All-American Road; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7455a2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 of America’s Byways; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7455a3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each eligible project that is associated with the development of a State or Indian tribe scenic byway program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7455a4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following are projects that are eligible for Federal assistance under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7455a5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An activity related to the planning, design, or development of a State or Indian tribe scenic byway program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455a6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and implementation of a corridor management plan to maintain the scenic, historical, recreational, cultural, natural, and archaeological characteristics of a byway corridor while providing for accommodation of increased tourism and development of related amenities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455a7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Safety improvements to a State scenic byway, Indian tribe scenic byway, National Scenic Byway, All-American Road, or one of America’s Byways to the extent that the improvements are necessary to accommodate increased traffic and changes in the types of vehicles using the highway as a result of the designation as a State scenic byway, Indian tribe scenic byway, National Scenic Byway, All-American Road, or one of America’s Byways.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455a8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction along a scenic byway of a facility for pedestrians and bicyclists, rest area, turnout, highway shoulder improvement, overlook, or interpretive facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455a9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An improvement to a scenic byway that will enhance access to an area for the purpose of recreation, including water-related recreation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455aa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protection of scenic, historical, recreational, cultural, natural, and archaeological resources in an area adjacent to a scenic byway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455ab-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and provision of tourist information to the public, including interpretive information about a scenic byway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7455ac-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and implementation of a scenic byway marketing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7455ad-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not make a grant under this section for any project that would not protect the scenic, historical, recreational, cultural, natural, and archaeological integrity of a highway and adjacent areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7455ae-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not withhold any grant or impose any requirement on a State or Indian tribe as a condition of providing a grant or technical assistance for any scenic byway unless the requirement is consistent with the authority provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7455af-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s162/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of carrying out a project under this section shall be 80 percent, except that, in the case of any scenic byway project along a public road that provides access to or within Federal or Indian land, a Federal land management agency may use funds authorized for use by the agency as the non-Federal share.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e76c6b0-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1219/a"},"text":"Pub. L. 105–178, title I, § 1219(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/219"},"text":"112 Stat. 219","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1802"},"text":"Pub. L. 109–59, title I, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1456"},"text":"119 Stat. 1456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tI/s101"},"text":"Pub. L. 110–244, title I, § 101","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1576"},"text":"122 Stat. 1576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e76c6b1-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e76c6b2-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e76c6b3-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s101"},"text":"Pub. L. 110–244, § 101","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), substituted “a National Scenic Byway, an All-American Road, or one of America’s Byways under paragraph (1)” for “a National Scenic Byway under subparagraph (A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s101"},"text":"Pub. L. 110–244, § 101","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(2), substituted “All-American Road, or one of America’s Byways” for “or All-American Road” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/a/1"},"text":"Pub. L. 109–59, § 1802(a)(1)","children":[],"tail":", substituted “the roads as—” and subpars. (A) to (C) for “the roads as National Scenic Byways or All-American Roads.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/a/2"},"text":"Pub. L. 109–59, § 1802(a)(2)","children":[],"tail":", added pars. (3) and (4) and struck out heading and text of former par. (3). Text read as follows: “To be considered for the designation, a road must be nominated by a State or a Federal land management agency and must first be designated as a State scenic byway or, in the case of a road on Federal land, as a Federal land management agency byway.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/b/1"},"text":"Pub. L. 109–59, § 1802(b)(1)","children":[],"tail":", inserted “and Indian tribes” after “States” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/b/2"},"text":"Pub. L. 109–59, § 1802(b)(2)","children":[],"tail":", substituted “designated as—” and cls. (i) to (v) for “designated as National Scenic Byways or All-American Roads, or as State scenic byways; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/b/3"},"text":"Pub. L. 109–59, § 1802(b)(3)","children":[],"tail":", inserted “or Indian tribe” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/b/4"},"text":"Pub. L. 109–59, § 1802(b)(4)","children":[],"tail":", substituted “Byway, All-American Road, or 1 of America’s Byways” for “Byway or All-American Road”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/b/5"},"text":"Pub. L. 109–59, § 1802(b)(5)","children":[],"tail":", substituted “State or Indian tribe” for “State-designated” and “designation as—” and cls. (i) to (iii) for “designation as a National Scenic Byway or All-American Road; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/b/6"},"text":"Pub. L. 109–59, § 1802(b)(6)","children":[],"tail":", inserted “or Indian tribe” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/c/1"},"text":"Pub. L. 109–59, § 1802(c)(1)","children":[],"tail":", inserted “or Indian tribe” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/c/2"},"text":"Pub. L. 109–59, § 1802(c)(2)","children":[],"tail":", inserted “Indian tribe scenic byway,” after “improvements to a State scenic byway,” and “designation as a State scenic byway,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/c/3"},"text":"Pub. L. 109–59, § 1802(c)(3)","children":[],"tail":", struck out “passing lane,” before “overlook,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s1802/d"},"text":"Pub. L. 109–59, § 1802(d)","children":[],"tail":", inserted “or Indian tribe” after “State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e76c6b4-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id2e76c6b5-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reviving America’s Scenic Byways","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/57"},"text":"Pub. L. 116–57","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-09-22"},"text":"Sept. 22, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1090"},"text":"133 Stat. 1090","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/57"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Reviving America’s Scenic Byways Act of 2019’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NATIONAL SCENIC BYWAYS PROGRAM.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Nominations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-09-22"},"text":"Sept. 22, 2019","children":[],"tail":"], the Secretary of Transportation shall issue a request for nominations with respect to roads to be designated under the national scenic byways program, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s162/a"},"text":"section 162(a) of title 23","children":[],"tail":", United States Code. The Secretary shall make the request for nominations available on the appropriate website of the Department of Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date on which the request for nominations required under subsection (a) is issued, the Secretary shall make publicly available on the appropriate website of the Department of Transportation a list specifying the roads, nominated pursuant to such request, to be designated under the national scenic byways program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
