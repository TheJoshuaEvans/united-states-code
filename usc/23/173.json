{"tag":"section","attrib":{"id":"id2e7b825f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173"},"text":null,"children":[{"tag":"num","attrib":{"value":"173"},"text":"§ 173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural surface transportation grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e7b8260-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8261-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “program” means the program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8262-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rural area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “rural area” means an area that is outside an urbanized area with a population of over 200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8263-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8264-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a rural surface transportation grant program to provide grants, on a competitive basis, to eligible entities to improve and expand the surface transportation infrastructure in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8265-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the program shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8266-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8267-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the safety and reliability of the movement of people and freight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8268-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to generate regional economic growth and improve quality of life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8269-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b826a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain not more than a total of 2 percent of the funds made available to carry out the program and to review applications for grants under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b826b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer portions of the funds retained under subparagraph (A) to the relevant Administrators to fund the award and oversight of grants provided under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b826c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a grant under the program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b826d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b826e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional transportation planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b826f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8270-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal government or a consortium of Tribal governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8271-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multijurisdictional group of entities described in paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8272-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under the program, an eligible entity shall submit to the Secretary an application in such form, at such time, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8273-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8274-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the Secretary may make a grant under the program only for a project that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b8275-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a highway, bridge, or tunnel project eligible under section 119(d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8276-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a highway, bridge, or tunnel project eligible under section 133(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8277-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project eligible under section 202(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8278-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a highway freight project eligible under section 167(h)(5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8279-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a highway safety improvement project, including a project to improve a high risk rural road (as those terms are defined in section 148(a));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b827a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project on a publicly-owned highway or bridge that provides or increases access to an agricultural, commercial, energy, or intermodal facility that supports the economy of a rural area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b827b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to develop, establish, or maintain an integrated mobility management system, a transportation demand management system, or on-demand mobility services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b827c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bundling of eligible projects.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b827d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may bundle 2 or more similar eligible projects under the program that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b827e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included as a bundled project in a statewide transportation improvement program under section 135; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b827f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awarded to a single contractor or consultant pursuant to a contract for engineering and design or construction between the contractor and the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8280-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Itemization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law (including regulations), a bundling of eligible projects under this paragraph may be considered to be a single project, including for purposes of section 135.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8281-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Project Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use funds from a grant under the program for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8282-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development phase activities, including planning, feasibility analysis, revenue forecasting, environmental review, preliminary engineering and design work, and other preconstruction activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8283-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, reconstruction, rehabilitation, acquisition of real property (including land related to the project and improvements to the land), environmental mitigation, construction contingencies, acquisition of equipment, and operational improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8284-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a grant under the program to an eligible project only if the Secretary determines that the project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8285-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will generate regional economic, mobility, or safety benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8286-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be cost effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8287-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will contribute to the accomplishment of 1 or more of the national goals under section 150;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8288-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the results of preliminary engineering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8289-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is reasonably expected to begin construction not later than 18 months after the date of obligation of funds for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b828a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants under the program, the Secretary shall consider the extent to which an eligible project will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b828b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the state of good repair of existing highway, bridge, and tunnel facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b828c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the capacity or connectivity of the surface transportation system and improve mobility for residents of rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b828d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address economic development and job creation challenges, including energy sector job losses in energy communities as identified in the report released in April 2021 by the interagency working group established by section 218 of Executive Order 14008 (86 Fed. Reg. 7628 (","children":[{"tag":"date","attrib":{"date":"2021-02-01"},"text":"February 1, 2021","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b828e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance recreational and tourism opportunities by providing access to Federal land, national parks, national forests, national recreation areas, national wildlife refuges, wilderness areas, or State parks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b828f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to geographic diversity among grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8290-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize innovative project delivery approaches or incorporate transportation technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8291-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with projects to address broadband infrastructure needs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8292-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/h/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve access to emergency care, essential services, healthcare providers, or drug and alcohol treatment and rehabilitation resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8293-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (k)(1), a grant under the program shall be in an amount that is not less than $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8294-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8295-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Federal share of the cost of a project carried out with a grant under the program may not exceed 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8296-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share for certain projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an eligible project that furthers the completion of a designated segment of the Appalachian Development Highway System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14501"},"text":"section 14501 of title 40","children":[],"tail":", or addresses a surface transportation infrastructure need identified for the Denali access system program under section 309 of the Denali Commission Act of 1998 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"42 U.S.C. 3121","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":") shall be up to 100 percent, as determined by the State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8297-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of other federal assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal assistance other than a grant under the program may be used to satisfy the non-Federal share of the cost of a project carried out with a grant under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8298-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Set Asides.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8299-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall use not more than 10 percent of the amounts made available for the program for each fiscal year to provide grants for eligible projects in an amount that is less than $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b829a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appalachian development highway system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall reserve 25 percent of the amounts made available for the program for each fiscal year for eligible projects that further the completion of designated routes of the Appalachian Development Highway System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s14501"},"text":"section 14501 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b829b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rural roadway lane departures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall reserve 15 percent of the amounts made available for the program for each fiscal year to provide grants for eligible projects located in States that have rural roadway fatalities as a result of lane departures that are greater than the average of rural roadway fatalities as a result of lane departures in the United States, based on the latest available data from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b829c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any fiscal year in which qualified applications for grants under this subsection do not allow for the amounts reserved under paragraphs (1), (2), or (3) to be fully utilized, the Secretary shall use the unutilized amounts to make other grants under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b829d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Review.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b829e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than 60 days before providing a grant under the program, the Secretary shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b829f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all applications determined to be eligible for a grant by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b82a0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each application proposed to be selected for a grant, including a justification for the selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b82a1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed grant amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b82a2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the last day of the 60-day period described in paragraph (1), each Committee described in paragraph (1) shall review the list of proposed projects submitted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b82a3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional disapproval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not make a grant or any other obligation or commitment to fund a project under the program if a joint resolution is enacted disapproving funding for the project before the last day of the 60-day period described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b82a4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b82a5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after providing a grant for a project under the program, the Secretary shall provide to all applicants, and publish on the website of the Department of Transportation, the information described in subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b82a6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide, on the request of an eligible entity, the opportunity to receive a briefing to explain any reasons the eligible entity was not selected to receive a grant under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b82a7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b82a8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make available on the website of the Department of Transportation at the end of each fiscal year an annual report that lists each project for which a grant has been provided under the program during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b82a9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b82aa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General of the United States shall conduct an assessment of the administrative establishment, solicitation, selection, and justification process with respect to the awarding of grants under the program for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b82ab-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each fiscal year, the Comptroller General shall submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that describes, for the fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7b82ac-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy and fairness of the process by which each project was selected, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7b82ad-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/n/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification and criteria used for the selection of each project, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7df2ae-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s173/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a project assisted under this section shall be treated as a project on a Federal-aid highway under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7df2af-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11132/a"},"text":"Pub. L. 117–58, div. A, title I, § 11132(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/510"},"text":"135 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e7df2b0-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e7df2b1-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e7df2b2-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 14008, referred to in subsec. (h)(3), is Ex. Ord. No. 14008, ","children":[{"tag":"date","attrib":{"date":"2021-01-27"},"text":"Jan. 27, 2021","children":[],"tail":", 86 F.R. 7619, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7df2b3-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e7df2b4-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
