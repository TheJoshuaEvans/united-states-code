{"tag":"section","attrib":{"id":"id2e91053b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief of employees in hazardous work","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized in an emergency to use appropriations to the Department of Transportation for carrying out the provisions of this title for medical supplies, services, and other assistance necessary for the immediate relief of employees of the Federal Highway Administration engaged in hazardous work.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2e91053c-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/915"},"text":"72 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/87/tI/s152/5"},"text":"Pub. L. 93–87, title I, § 152(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/276"},"text":"87 Stat. 276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e91053d-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e91053e-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e91053f-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87"},"text":"Pub. L. 93–87","children":[],"tail":" substituted “Department of Transportation” for “Department of Commerce” and “Federal Highway Administration” for “Bureau of Public Roads”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
