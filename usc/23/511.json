{"tag":"section","attrib":{"id":"id2eb72b6b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s511"},"text":null,"children":[{"tag":"num","attrib":{"value":"511"},"text":"§ 511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate corridor operations and management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb72b6c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall encourage multistate cooperative agreements, coalitions, or other arrangements to promote regional cooperation, planning, and shared project implementation for programs and projects to improve transportation system management and operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb72b6d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interstate Route","children":[],"tail":" 95 "},{"tag":"inline","attrib":{},"text":"Corridor Coalition Transportation Systems Management and Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make grants under this subsection to States to continue intelligent transportation system management and operations in the Interstate Route 95 corridor coalition region initiated under the Intermodal Surface Transportation Efficiency Act of 1991 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Public Law 102–240","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb