{"tag":"section","attrib":{"id":"id2e686e47-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147"},"text":null,"children":[{"tag":"num","attrib":{"value":"147"},"text":"§ 147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of ferry boats and ferry terminal facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e686e48-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a program for construction of ferry boats and ferry terminal facilities in accordance with section 129(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e49-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of construction of ferry boats, ferry terminals, and ferry maintenance facilities under this section shall be 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e4a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available to ferry systems and public entities responsible for developing ferries under this section for a fiscal year, 100 percent shall be allocated in accordance with the formula set forth in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e4b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formula","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts allocated under subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e686e4c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 35 percent shall be allocated among eligible entities in the proportion that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e686e4d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of ferry passengers, including passengers in vehicles, carried by each ferry system in the most recent calendar year for which data is available; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e686e4e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of ferry passengers, including passengers in vehicles, carried by all ferry systems in the most recent calendar year for which data is available;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e4f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 35 percent shall be allocated among eligible entities in the proportion that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e686e50-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of vehicles carried by each ferry system in the most recent calendar year for which data is available; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e686e51-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of vehicles carried by all ferry systems in the most recent calendar year for which data is available; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e52-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 30 percent shall be allocated among eligible entities in the proportion that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e686e53-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total route nautical miles serviced by each ferry system in the most recent calendar year for which data is available; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e686e54-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total route nautical miles serviced by all ferry systems in the most recent calendar year for which data is available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e55-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redistribution of Unobligated Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e686e56-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw amounts allocated to an eligible entity under subsection (c) that remain unobligated by the end of the third fiscal year following the fiscal year for which the amounts were allocated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e57-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the subsequent fiscal year, redistribute the amounts referred to in paragraph (1) in accordance with the formula under subsection (d) among eligible entities for which no amounts were withdrawn under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e58-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (c), a State with an eligible entity that meets the requirements of this section shall receive not less than $100,000 under this section for a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e59-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e686e5a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data collection.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e686e5b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National ferry database","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available for a fiscal year under this section shall be allocated using the most recent data available, as collected and imputed in accordance with the national ferry database established under section 1801(e) of SAFETEA–LU (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s129"},"text":"23 U.S.C. 129","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e686e5c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive funds under subsection (c), data shall have been submitted in the most recent collection of data for the national ferry database under section 1801(e) of SAFETEA–LU (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s129"},"text":"23 U.S.C. 129","children":[],"tail":" note) for at least 1 ferry service within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e5d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On review of the data submitted under paragraph (1)(B), the Secretary may make adjustments to the data as the Secretary determines necessary to correct misreported or inconsistent data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e5e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated out of the Highway Trust Fund (other than the Mass Transit Account) to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e686e5f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $110,000,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e60-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $112,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e61-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $114,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e62-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $116,000,000 for fiscal year 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e686e63-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $118,000,000 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e64-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 118(b), funds made available to carry out this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e65-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All provisions of this chapter that are applicable to the National Highway System, other than provisions relating to apportionment formula and Federal share, shall apply to funds made available to carry out this section, except as determined by the Secretary to be inconsistent with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e686e66-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s147/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Uses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, in addition to other uses of funds under this section, an eligible entity may use amounts made available under this section to pay the operating costs of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e686e67-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87/tI/s126/a"},"text":"Pub. L. 93–87, title I, § 126(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/263"},"text":"87 Stat. 263","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/280/tI/s130"},"text":"Pub. L. 94–280, title I, § 130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-05"},"text":"May 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/440"},"text":"90 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1212/a/2/A/i"},"text":"Pub. L. 105–178, title I, § 1212(a)(2)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/193"},"text":"112 Stat. 193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1801/a"},"text":"Pub. L. 109–59, title I, § 1801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1455"},"text":"119 Stat. 1455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1121/a"},"text":"Pub. L. 112–141, div. A, title I, § 1121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/493"},"text":"126 Stat. 493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1112/a"},"text":"Pub. L. 114–94, div. A, title I, § 1112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1345"},"text":"129 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11121"},"text":"Pub. L. 117–58, div. A, title I, § 11121","children":[],"tail":", div. G, title XI, § 71103(g)(1), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/497"},"text":"135 Stat. 497","children":[],"tail":", 1326.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e686e68-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e686e69-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e686e6a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11121"},"text":"Pub. L. 117–58, § 11121","children":[],"tail":", added subsec. (h) and struck out former subsec. (h). Prior to amendment, text read as follows: “There is authorized to be appropriated out of the Highway Trust Fund (other than the Mass Transit Account) to carry out this section $80,000,000 for each of fiscal years 2016 through 2020.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s71103/g/1"},"text":"Pub. L. 117–58, § 71103(g)(1)","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1112/a/1"},"text":"Pub. L. 114–94, § 1112(a)(1)","children":[],"tail":", substituted “Program” for “In General” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1112/a/2"},"text":"Pub. L. 114–94, § 1112(a)(2)","children":[],"tail":", added subsecs. (d) to (j) and struck out former subsecs. (d) to (g) which related to formula for determining allocation amounts, authorization of appropriations, period of availability of funds, and applicability of chapter, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" added subsecs. (c) to (e), redesignated former subsecs. (e) and (f) as (f) and (g), respectively, and struck out former subsecs. (c) and (d) which related to allocation of funds and set-aside for projects on National Highway System, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to program for construction of ferry boats and ferry terminal facilities for provisions relating to selection of high traffic sections of highways as priority primary routes for priority of improvement to supplement the service provided by the Interstate System by furnishing needed adequate traffic collector and distributor facilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “State transportation department” for “State highway department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/280"},"text":"Pub. L. 94–280","children":[],"tail":" amended subsec. (b) generally, striking out apportionment provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e686e6b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e686e6c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"head