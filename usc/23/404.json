{"tag":"section","attrib":{"id":"id2ea1a6a9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404"},"text":null,"children":[{"tag":"num","attrib":{"value":"404"},"text":"§ 404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-visibility enforcement program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ea1a6aa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish and administer a program under which not less than 3 campaigns will be carried out in each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea1a6ab-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of each campaign carried out under this section shall be to achieve outcomes related to not less than 1 of the following objectives:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea1a6ac-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reduce alcohol-impaired or drug-impaired operation of motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea1a6ad-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increase use of seatbelts by occupants of motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea1a6ae-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advertising","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use, or authorize the use of, funds available to carry out this section to pay for the development, production, and use of broadcast and print media advertising and Internet-based outreach in carrying out campaigns under this section. In allocating such funds, consideration shall be given to advertising directed at non-English speaking populations, including those who listen to, read, or watch nontraditional media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea1a6af-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate with States in carrying out the campaigns under this section, including advertising funded under subsection (c), with consideration given to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea1a6b0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relying on States to provide law enforcement resources for the campaigns out of funding made available under sections 402 and 405; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea1a6b1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing, out of National Highway Traffic Safety Administration resources, most of the means necessary for national advertising and education efforts associated with the campaigns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea1a6b2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available to carry out this section may be used only for activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea1a6b3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea1a6b4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Campaign","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “campaign” means a high-visibility traffic safety law enforcement campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea1a6b5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s404/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” has the meaning given that term in section 401.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ea1a6b6-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/564/tI/s101"},"text":"Pub. L. 89–564, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-09"},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/733"},"text":"80 Stat. 733","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/150"},"text":"Pub. L. 90–150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-24"},"text":"Nov. 24, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/507"},"text":"81 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/87/tII/s223"},"text":"Pub. L. 93–87, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/292"},"text":"87 Stat. 292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/280/tII/s209"},"text":"Pub. L. 94–280, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-05"},"text":"May 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/455"},"text":"90 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tII/s2019"},"text":"Pub. L. 109–59, title II, § 2019","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1543"},"text":"119 Stat. 1543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tIV/s4004/a"},"text":"Pub. L. 114–94, div. A, title IV, § 4004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1500"},"text":"129 Stat. 1500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24104"},"text":"Pub. L. 117–58, div. B, title IV, § 24104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/795"},"text":"135 Stat. 795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ea1a6b7-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2ea1a6b8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2ea1a6b9-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “each of fiscal years 2022 through 2026” for “each of fiscal years 2016 through 2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" amended section generally, substituting provisions relating to the high-visibility enforcement program for provisions relating to the National Highway Safety Advisory Committee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “Transportation” for “Commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/280"},"text":"Pub. L. 94–280","children":[],"tail":" substituted provision for selection by the Secretary of the Chairman of the Committee from among the Committee members for prior provision making the Secretary or an officer of the Department appointed by him the Chairman of the Committee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87"},"text":"Pub. L. 93–87","children":[],"tail":" added the National Highway Traffic Safety Administrator to the membership of the National Highway Safety Advisory Committee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/150/s1/1"},"text":"Pub. L. 90–150, § 1(1)","children":[],"tail":", substituted “Department of Transportation” for “Department of Commerce”, increased number of Committee appointees from twenty-nine to thirty-five, and provided for selection of members from representatives of national organizations of passenger car, bus, and truck owners."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/150/s1/2"},"text":"Pub. L. 90–150, § 1(2)","children":[],"tail":", substituted provisions for expirations of term of office of initial appointees one, two, and three years after date of appointment for twelve, twelve, and eleven members, respectively, for former provisions for such expiration one, two, and three years following enactment date of "},{"tag":"date","attrib":{"date":"1966-09-09"},"text":"Sept. 9, 1966","children":[],"tail":", for ten, ten, and nine members, respectively, and prohibited reappointment within one year after end of preceding term of member serving a three-year term of office."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2ea1a6ba-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2ea1a6bb-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
