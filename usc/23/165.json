{"tag":"section","attrib":{"id":"id2e76c70a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165"},"text":null,"children":[{"tag":"num","attrib":{"value":"165"},"text":"§ 165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territorial and Puerto Rico highway program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e76c70b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Division of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of funds made available in a fiscal year for the territorial and Puerto Rico highway program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e76c70c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the Puerto Rico highway program under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c70d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $173,010,000 shall be for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c70e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $176,960,000 shall be for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c70f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $180,120,000 shall be for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c710-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $183,675,000 shall be for fiscal year 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c711-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $187,230,000 shall be for fiscal year 2026; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c712-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the territorial highway program under subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c713-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,990,000 shall be for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c714-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $47,040,000 shall be for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c715-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $47,880,000 shall be for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c716-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $48,825,000 shall be for fiscal year 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c717-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $49,770,000 shall be for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e76c718-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Puerto Rico Highway Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e76c719-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall allocate funds made available to carry out this subsection to the Commonwealth of Puerto Rico to carry out a highway program in the Commonwealth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c71a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available to carry out this subsection for a fiscal year shall be administered as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c71b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Apportionment.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c71c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of imposing any penalty under this title or title 49, the amounts shall be treated as being apportioned to Puerto Rico under sections 104(b) and 144 (as in effect for fiscal year 1997) for each program funded under those sections in an amount determined by multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e76c71d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate of the amounts for the fiscal year; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e76c71e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proportion that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id2e76c71f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds apportioned to Puerto Rico for each such program for fiscal year 1997; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id2e76c720-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of funds apportioned to Puerto Rico for all such programs for fiscal year 1997.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c721-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds identified under clause (i) as having been apportioned for the national highway system, the surface transportation block grant program, and the Interstate maintenance program shall be deemed to have been apportioned 50 percent for the national highway performance program and 50 percent for the surface transportation program for purposes of imposing such penalties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c722-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amounts treated as being apportioned to Puerto Rico under each section referred to in subparagraph (A) shall be deemed to be required to be apportioned to Puerto Rico under that section for purposes of the imposition of any penalty under this title or title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c723-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible uses of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts allocated to Puerto Rico for the Puerto Rico Highway Program for a fiscal year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c724-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent shall be available only for purposes eligible under section 119;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c725-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 25 percent shall be available only for purposes eligible under section 148; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c726-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any remaining funds may be obligated for activities eligible under chapter 1 and preventative maintenance on the National Highway System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c727-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on apportionments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise specifically provided, Puerto Rico shall not be eligible to receive funds apportioned to States under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e76c728-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Territorial Highway Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e76c729-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Territory defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “territory” means any of the following territories of the United States:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c72a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c72b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c72c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c72d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c72e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c72f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recognizing the mutual benefits that will accrue to the territories and the United States from the improvement of highways in the territories, the Secretary may carry out a program to assist each government of a territory in the construction and improvement of a system of arterial and collector highways, and necessary inter-island connectors, that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c730-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designated by the Governor or chief executive officer of each territory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c731-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c732-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of Federal financial assistance provided to territories under this subsection shall be in accordance with section 120(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c733-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c734-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To continue a long-range highway development program, the Secretary may provide technical assistance to the governments of the territories to enable the territories, on a continuing basis—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c735-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in highway planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c736-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct environmental evaluations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c737-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer right-of-way acquisition and relocation assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c738-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to design, construct, operate, and maintain a system of arterial and collector highways, including necessary inter-island connectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c739-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form and terms of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Technical assistance provided under subparagraph (A), and the terms for the sharing of information among territories receiving the technical assistance, shall be included in the agreement required by paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c73a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of certain provisions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c73b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except to the extent that provisions of this chapter are determined by the Secretary to be inconsistent with the needs of the territories and the intent of this subsection, this chapter (other than provisions of this chapter relating to the apportionment and allocation of funds) shall apply to funds made available under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c73c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement required by paragraph (5) for each territory shall identify the sections of this chapter that are applicable to that territory and the extent of the applicability of those sections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c73d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c73e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (D), none of the funds made available under this subsection shall be available for obligation or expenditure with respect to any territory until the chief executive officer of the territory has entered into an agreement (including an agreement entered into under section 215 as in effect on the day before the enactment of this section) with the Secretary providing that the government of the territory shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c73f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the program in accordance with applicable provisions of this chapter and paragraph (4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c740-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" design and construct a system of arterial and collector highways, including necessary inter-island connectors, in accordance with standards that are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e76c741-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate for each territory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e76c742-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c743-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the maintenance of facilities constructed or operated under this subsection in a condition to adequately serve the needs of present and future traffic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c744-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement standards for traffic operations and uniform traffic control devices that are approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c745-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement required by subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c746-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the kind of technical assistance to be provided under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c747-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include appropriate provisions regarding information sharing among the territories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c748-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delineate the oversight role and responsibilities of the territories and the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c749-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and revision of agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agreement entered into under subparagraph (A) shall be reevaluated and, as necessary, revised, at least every 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c74a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an agreement under this subsection or an agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s215"},"text":"section 215 of this title","children":[],"tail":" as in effect on the day before the date of enactment of this subsection—"}],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c74b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement shall continue in force until replaced by an agreement entered into in accordance with subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c74c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts made available under this subsection under the existing agreement shall be available for obligation or expenditure so long as the agreement, or the existing agreement entered into under subparagraph (A), is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c74d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible uses of funds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e76c74e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under this subsection may be used only for the following projects and activities carried out in a territory:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e76c74f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eligible surface transportation block grant program projects described in section 133(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c750-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost-effective, preventive maintenance consistent with section 116(e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c751-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ferry boats, terminal facilities, and approaches, in accordance with subsections (b) and (c) of section 129.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c752-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engineering and economic surveys and investigations for the planning, and the financing, of future highway programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c753-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Studies of the economy, safety, and convenience of highway use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c754-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulation and equitable taxation of highway use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e76c755-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such research and development as are necessary in connection with the planning, design, and maintenance of the highway system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e76c756-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on use of funds for routine maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"None of the funds made available under this subsection shall be obligated or expended for routine maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e76c757-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s165/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Territorial highway program projects (other than those described in paragraphs (1), (2), (3), and (5) of section 133(c) and section 133(b)(13)) may not be undertaken on roads functionally classified as local.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e76c758-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1120/a"},"text":"Pub. L. 109–59, title I, § 1120(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1191"},"text":"119 Stat. 1191","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1114/a"},"text":"Pub. L. 112–141, div. A, title I, § 1114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/464"},"text":"126 Stat. 464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI"},"text":"Pub. L. 114–94, div. A, title I","children":[],"tail":", §§ 1109(c)(5), 1115, 1446(a)(11), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1343"},"text":"129 Stat. 1343","children":[],"tail":", 1349, 1438; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11126"},"text":"Pub. L. 117–58, div. A, title I, § 11126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/506"},"text":"135 Stat. 506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e76c759-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e76c75a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e76c75b-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 215 as in effect on the day before the enactment of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s215"},"text":"section 215 of this title","children":[],"tail":" as in effect on the day before the date of enactment of this subsection, referred to in subsec. (c)(5)(A), (D), probably mean "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s215"},"text":"section 215 of this title","children":[],"tail":" as in effect on the day before the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", and which amended this section generally and repealed section 215."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e76c75c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11126/1"},"text":"Pub. L. 117–58, § 11126(1)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $158,000,000 shall be for the Puerto Rico highway program under subsection (b); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $42,000,000 shall be for the territorial highway program under subsection (c).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11126/2"},"text":"Pub. L. 117–58, § 11126(2)","children":[],"tail":", inserted “and preventative maintenance on the National Highway System” after “chapter 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11126/3"},"text":"Pub. L. 117–58, § 11126(3)","children":[],"tail":", substituted “paragraphs (1), (2), (3), and (5) of section 133(c) and section 133(b)(13)” for “paragraphs (1) through (4) of section 133(c) and section 133(b)(12)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1115/1"},"text":"Pub. L. 114–94, § 1115(1)","children":[],"tail":", substituted “$158,000,000” for “$150,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1115/2"},"text":"Pub. L. 114–94, § 1115(2)","children":[],"tail":", substituted “$42,000,000” for “$40,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(2)(A)(ii), (c)(6)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1109/c/5"},"text":"Pub. L. 114–94, § 1109(c)(5)","children":[],"tail":", substituted “surface transportation block grant program” for “surface transport