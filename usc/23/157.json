{"tag":"section","attrib":{"id":"id2e745513-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157"},"text":null,"children":[{"tag":"num","attrib":{"value":"157"},"text":"§ 157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Environmental Policy Act of 1969 reporting program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e745514-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e745515-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Categorical exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “categorical exclusion” has the meaning given the term in section 771.117(c) of title 23, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745516-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documented categorical exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “documented categorical exclusion” has the meaning given the term in section 771.117(d) of title 23, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745517-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “environmental assessment” has the meaning given the term in section 1508.1 of title 40, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745518-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental impact statement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “environmental impact statement” means a detailed statement required under section 102(2)(C) of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"42 U.S.C. 4332(2)(C)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745519-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal agency” includes a State that has assumed responsibility under section 327.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74551a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"NEPA process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “NEPA process” means the entirety of the development and documentation of the analysis required under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), including the assessment and analysis of any impacts, alternatives, and mitigation of a proposed action, and any interagency participation and public involvement required to be carried out before the Secretary undertakes a proposed action."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74551b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposed action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “proposed action” means an action (within the meaning of the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)) under this title that the Secretary proposes to carry out."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74551c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “reporting period” means the fiscal year prior to the fiscal year in which a report is issued under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e74551d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” includes the governor or head of an applicable State agency of a State that has assumed responsibility under section 327.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e74551e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on NEPA Data.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e74551f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out a process to track, and annually submit to the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report containing, the information described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745520-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time to complete","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (3), the NEPA process—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e745521-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for an environmental impact statement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e745522-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins on the date on which the Notice of Intent is published in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e745523-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends on the date on which the Secretary issues a record of decision, including, if necessary, a revised record of decision; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745524-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for an environmental assessment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e745525-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins on the date on which the Secretary makes a determination to prepare an environmental assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e745526-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends on the date on which the Secretary issues a finding of no significant impact or determines that preparation of an environmental impact statement is necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e745527-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information referred to in paragraph (1) is, with respect to the Department of Transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e745528-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions for which a categorical exclusion was issued during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745529-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions for which a documented categorical exclusion was issued by the Department of Transportation during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74552a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions pending on the date on which the report is submitted for which the issuance of a documented categorical exclusion by the Department of Transportation is pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74552b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions for which an environmental assessment was issued by the Department of Transportation during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74552c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time the Department of Transportation took to complete each environmental assessment described in subparagraph (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74552d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions pending on the date on which the report is submitted for which an environmental assessment is being drafted by the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74552e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions for which an environmental impact statement was completed by the Department of Transportation during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e74552f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time that the Department of Transportation took to complete each environmental impact statement described in subparagraph (G);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745530-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of proposed actions pending on the date on which the report is submitted for which an environmental impact statement is being drafted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e745531-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the proposed actions reported under subparagraphs (F) and (I), the percentage of those proposed actions for which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e745532-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding has been identified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e745533-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s157/b/3/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other Federal, State, and local activities that are required to allow the proposed action to proceed are completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e745534-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11312/a"},"text":"Pub. L. 117–58, div. A, title I, § 11312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/538"},"text":"135 Stat. 538","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e745535-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e745536-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e745537-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (a)(6), (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"