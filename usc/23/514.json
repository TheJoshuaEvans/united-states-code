{"tag":"section","attrib":{"id":"id2eb99b9f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514"},"text":null,"children":[{"tag":"num","attrib":{"value":"514"},"text":"§ 514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb99ba0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the intelligent transportation system program include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99ba1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of surface transportation efficiency and facilitation of intermodalism and international trade to enable existing facilities to meet a significant portion of future transportation needs, including public access to employment, goods, and services and to reduce regulatory, financial, and other transaction costs to public agencies and system users;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99ba2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achievement of national transportation safety goals, including enhancement of safe operation of motor vehicles and nonmotorized vehicles and improved emergency response to collisions, with particular emphasis on decreasing the number and severity of collisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99ba3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection and enhancement of the natural environment and communities affected by surface transportation, with particular emphasis on assisting State and local governments to achieve national environmental goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99ba4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accommodation of the needs of all users of surface transportation systems, including operators of commercial motor vehicles, passenger motor vehicles, motorcycles, bicycles, and pedestrians (including individuals with disabilities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99ba5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of national defense mobility and improvement of the ability of the United States to respond to security-related or other manmade emergencies and natural disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99ba6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of the national freight system and support to national freight policy goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99ba7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall implement activities under the intelligent transportation system program, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99ba8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expedite, in both metropolitan and rural areas, deployment and integration of intelligent transportation systems for consumers of passenger and freight transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99ba9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that Federal, State, and local transportation officials have adequate knowledge of intelligent transportation systems for consideration in the transportation planning process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99baa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve regional cooperation and operations planning for effective intelligent transportation system deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bab-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the innovative use of private resources in support of intelligent transportation system development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bac-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate, in cooperation with the motor vehicle industry, the introduction of vehicle-based safety enhancing systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bad-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the application of intelligent transportation systems that increase the safety and efficiency of commercial motor vehicle operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bae-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a workforce capable of developing, operating, and maintaining intelligent transportation systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99baf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide continuing support for operations and maintenance of intelligent transportation systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bb0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure a systems approach that includes cooperation among vehicles, infrastructure, and users; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bb1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s514/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the development of cybersecurity research in cooperation with relevant modal administrations of the Department of Transportation and other Federal agencies to help prevent hacking, spoofing, and disruption of connected and automated transportation vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb99bb2-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tIII/s53002/a"},"text":"Pub. L. 112–141, div. E, title III, § 53002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/898"},"text":"126 Stat. 898","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI"},"text":"Pub. L. 114–94, div. A, title VI","children":[],"tail":", §§ 6005, 6006, "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1567"},"text":"129 Stat. 1567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb99bb3-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb99bb4-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb99bb5-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s6005"},"text":"Pub. L. 114–94, § 6005","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s6006"},"text":"Pub. L. 114–94, § 6006","children":[],"tail":", added par. (10)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2eb99bb6-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb99bb7-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2eb99bb8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
