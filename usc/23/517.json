{"tag":"section","attrib":{"id":"id2eb99c17-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517"},"text":null,"children":[{"tag":"num","attrib":{"value":"517"},"text":"§ 517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National architecture and standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb99c18-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c19-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development, implementation, and maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with section 12(d) of the National Technology Transfer and Advancement Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s272"},"text":"15 U.S.C. 272","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/110/783"},"text":"110 Stat. 783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/1241"},"text":"115 Stat. 1241","children":[],"tail":"), the Secretary shall develop and maintain a national ITS architecture and supporting ITS standards and protocols to promote the use of systems engineering methods in the widespread deployment and evaluation of intelligent transportation systems as a component of the surface transportation systems of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c1a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interoperability and efficiency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent practicable, the national ITS architecture and supporting ITS standards and protocols shall promote interoperability among, and efficiency of, intelligent transportation systems and technologies implemented throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c1b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of standards development organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary shall support the development and maintenance of standards and protocols using the services of such standards development organizations as the Secretary determines to be necessary and whose memberships include representatives of the surface transportation and intelligent transportation systems industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c1c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for National Policy Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary finds that a standard is necessary for implementation of a nationwide policy relating to user fee collection or other capability requiring nationwide uniformity, the Secretary, after consultation with stakeholders, may establish and require the use of that standard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c1d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisional Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c1e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary finds that the development or balloting of an intelligent transportation system standard jeopardizes the timely achievement of the objectives described in subsection (a), the Secretary may establish a provisional standard, after consultation with affected parties, using, to the maximum extent practicable, the work product of appropriate standards development organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c1f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of effectiveness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A provisional standard established under paragraph (1) shall be published in the Federal Register and remain in effect until the appropriate standards development organization adopts and publishes a standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c20-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conformity With National Architecture","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c21-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Secretary shall ensure that intelligent transportation system projects carried out using amounts made available from the Highway Trust Fund, including amounts made available to deploy intelligent transportation systems, conform to the appropriate regional ITS architecture, applicable standards, and protocols developed under subsection (a) or (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c22-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s517/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretion of the secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, at the discretion of the Secretary, may offer an exemption from paragraph (1) for projects designed to achieve specific research objectives outlined in the national intelligent transportation system program plan or the surface transportation research and development strategic plan developed under section 508.","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb99c23-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tIII/s53005/a"},"text":"Pub. L. 112–141, div. E, title III, § 53005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/902"},"text":"126 Stat. 902","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6008"},"text":"Pub. L. 114–94, div. A, title VI, § 6008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1567"},"text":"129 Stat. 1567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb99c24-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb99c25-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2eb99c26-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 12(d) of the National Technology Transfer and Advancement Act of 1995, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113/s12/d"},"text":"section 12(d) of Pub. L. 104–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/783"},"text":"110 Stat. 783","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s272"},"text":"section 272 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 508, referred to in subsec. (d)(2), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6019/d/1/A"},"text":"Pub. L. 114–94, div. A, title VI, § 6019(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1581"},"text":"129 Stat. 1581","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb99c27-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “memberships include representatives of” for “memberships are comprised of, and represent,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2eb99c28-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb99c29-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"