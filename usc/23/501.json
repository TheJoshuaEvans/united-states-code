{"tag":"section","attrib":{"id":"id2ea8d263-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501"},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"§ 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea8d264-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal laboratory","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal laboratory” includes a Government-owned, Government-operated laboratory and a Government-owned, contractor-operated laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d265-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incident","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “incident” means a crash, natural disaster, workzone activity, special event, or other emergency road user occurrence that adversely affects or impedes the normal flow of traffic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d266-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innovation lifecycle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “innovation lifecycle” means the process of innovating through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ea8d267-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of a need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d268-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of the scope of research to address that need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d269-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting an agenda;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d26a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out research, development, deployment, and testing of the resulting technology or innovation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d26b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out an evaluation of the costs and benefits of the resulting technology or innovation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d26c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligent transportation infrastructure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “intelligent transportation infrastructure” means fully integrated public sector intelligent transportation system components, as defined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d26d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligent transportation system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “intelligent transportation system” and “ITS” mean electronics, photonics, communications, or information processing used singly or in combination to improve the efficiency or safety of a surface transportation system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d26e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National architecture","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the term “national architecture” means the common framework for interoperability that defines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ea8d26f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the functions associated with intelligent transportation system user services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d270-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physical entities or subsystems within which the functions reside;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d271-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data interfaces and information flows between physical subsystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d272-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communications requirements associated with the information flows.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d273-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “project” means an undertaking to research, develop, or operationally test intelligent transportation systems or any other undertaking eligible for assistance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d274-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “safety” includes highway and traffic safety systems, research, and development relating to vehicle, highway, driver, passenger, bicyclist, and pedestrian characteristics, accident investigations, communications, emergency medical care, and transportation of the injured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea8d275-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “standard” means a document that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ea8d276-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains technical specifications or other precise criteria for intelligent transportation systems that are to be used consistently as rules, guidelines, or definitions of characteristics so as to ensure that materials, products, processes, and services are fit for the intended purposes of the materials, products, processes, and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea8d277-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may support the national architecture and promote—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ea8d278-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the widespread use and adoption of intelligent transportation system technology as a component of the surface transportation systems of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ea8d279-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s501/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperability among intelligent transportation system technologies implemented throughout the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ea8d27a-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tV/s5101/2"},"text":"Pub. L. 105–178, title V, § 5101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/422"},"text":"112 Stat. 422","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52001"},"text":"Pub. L. 112–141, div. E, title II, § 52001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/865"},"text":"126 Stat. 865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ea8d27b-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2ea8d27c-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag"