{"tag":"section","attrib":{"id":"id2eb99c2b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518"},"text":null,"children":[{"tag":"num","attrib":{"value":"518"},"text":"§ 518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicle-to-vehicle and vehicle-to-infrastructure communications systems deployment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb99c2c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-07-06"},"text":"July 6, 2016","children":[],"tail":", the Secretary shall make available to the public on a Department of Transportation website a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99c2d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the status of dedicated short-range communications technology and applications developed through research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c2e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes the known and potential gaps in short-range communications technology and applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c2f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" defines a recommended implementation path for dedicated short-range communications technology and applications that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99c30-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the assessment described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99c31-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account the analysis described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c32-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes guidance on the relationship of the proposed deployment of dedicated short-range communications to the National ITS Architecture and ITS Standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99c33-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures competition by not preferencing the use of any particular frequency for vehicle to infrastructure operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99c34-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into agreements with the National Research Council and an independent third party with subject matter expertise for the review of the report described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb99c35-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tIII/s53006/a"},"text":"Pub. L. 112–141, div. E, title III, § 53006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/904"},"text":"126 Stat. 904","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6009"},"text":"Pub. L. 114–94, div. A, title VI, § 6009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1567"},"text":"129 Stat. 1567","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb99c36-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb99c37-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb99c38-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", i