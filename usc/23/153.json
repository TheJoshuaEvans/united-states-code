{"tag":"section","attrib":{"id":"id2e720ba8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153"},"text":null,"children":[{"tag":"num","attrib":{"value":"153"},"text":"§ 153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of safety belts and motorcycle helmets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e720ba9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to a State in a fiscal year in accordance with this section if the State has in effect in such fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720baa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law which makes unlawful throughout the State the operation of a motorcycle if any individual on the motorcycle is not wearing a motorcycle helmet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bab-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law which makes unlawful throughout the State the operation of a passenger vehicle whenever an individual in a front seat of the vehicle (other than a child who is secured in a child restraint system) does not have a safety belt properly fastened about the individual’s body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bac-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant made to a State under this section shall be used to adopt and implement a traffic safety program to carry out the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720bad-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To educate the public about motorcycle and passenger vehicle safety and motorcycle helmet, safety belt, and child restraint system use and to involve public health education agencies and other related agencies in these efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bae-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To train law enforcement officers in the enforcement of State laws described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720baf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To monitor the rate of compliance with State laws described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bb0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To enforce State laws described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bb1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Effort","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant may not be made to a State under this section in any fiscal year unless the State enters into such agreements with the Secretary as the Secretary may require to ensure that the State will maintain its aggregate expenditures from all other sources for any traffic safety program described in subsection (b) at or above the average level of such expenditures in the State’s 2 fiscal years preceding the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bb2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may not receive a grant under this section in more than 3 fiscal years. The Federal share payable for a grant under this section shall not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720bb3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the first fiscal year the State receives a grant, 75 percent of the cost of implementing in such fiscal year a traffic safety program described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bb4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the second fiscal year the State receives a grant, 50 percent of the cost of implementing in such fiscal year such traffic safety program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bb5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the third fiscal year the State receives a grant, 25 percent of the cost of implementing in such fiscal year such traffic safety program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bb6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Aggregate Amount of Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The aggregate amount of grants made to a State under this section shall not exceed 90 percent of the amount apportioned to such State for fiscal year 1990 under section 402.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bb7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720bb8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State is eligible in a fiscal year for a grant under this section only if the State enters into such agreements with the Secretary as the Secretary may require to ensure that the State implements in such fiscal year a traffic safety program described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bb9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Second-year grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State is eligible for a grant under this section in a fiscal year succeeding the first fiscal year in which a State receives a grant under this section only if the State in the preceding fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720bba-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had in effect at all times a State law described in subsection (a)(1) and achieved a rate of compliance with such law of not less than 75 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720bbb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had in effect at all times a State law described in subsection (a)(2) and achieved a rate of compliance with such law of not less than 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bbc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Third-year grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State is eligible for a grant under this section in a fiscal year succeeding the second fiscal year in which a State receives a grant under this section only if the State in the preceding fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720bbd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had in effect at all times a State law described in subsection (a)(1) and achieved a rate of compliance with such law of not less than 85 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720bbe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had in effect at all times a State law described in subsection (a)(2) and achieved a rate of compliance with such law of not less than 70 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bbf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Measurements of Rates of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of subsections (f)(2) and (f)(3), a State shall measure compliance with State laws described in subsection (a) using methods which conform to guidelines issued by the Secretary ensuring that such measurements are accurate and representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bc0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720bc1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior to fiscal year 2012","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, at any time in a fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":", a State does not have in effect a law described in subsection (a)(2), the Secretary shall transfer 3 percent of the funds apportioned to the State for the succeeding fiscal year under each of subsections (b)(1), (b)(2), and (b)(3) of section 104 "},{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to the apportionment of the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s402"},"text":"section 402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bc2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year 2012 and thereafter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, at any time in a fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":", a State does not have in effect a law described in subsection (a)(2), the Secretary shall transfer an amount equal to 2 percent of the funds apportioned to the State for the succeeding fiscal year under each of paragraphs (1), (2), and (4) of section 104(b) to the apportionment of the State under section 402."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bc3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of any project carried out under section 402 with funds transferred to the apportionment of section 402 shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bc4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of obligation authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary transfers under this subsection any funds to the apportionment of a State under section 402 for a fiscal year, the Secretary shall allocate an amount of obligation authority distributed for such fiscal year to the State for Federal-aid highways and highway safety construction programs for carrying out only projects under section 402 which is determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720bc5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds transferred to the apportionment of section 402 of the State under section 402 for such fiscal year; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720bc6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ratio of the amount of obligation authority distributed for such fiscal year to the State for Federal-aid highways and highway safety construction programs to the total of the sums apportioned to the State for Federal-aid highways and highway safety construction (excluding sums not subject to any obligation limitation) for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bc7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on applicability of highway safety obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, no limitation on the total of obligations for highway safety programs carried out by the Federal Highway Administration under section 402 shall apply to funds transferred under this subsection to the apportionment of section 402.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bc8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720bc9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motorcycle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motorcycle” means a motor vehicle which is designed to travel on not more than 3 wheels in contact with the surface.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bca-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motor vehicle” has the meaning such term has under section 154 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bcb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Passenger vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “passenger vehicle” means a motor vehicle which is designed for transporting 10 individuals or less, including the driver, except that such term does not include a vehicle which is constructed on a truck chassis, a motorcycle, a trailer, or any motor vehicle which is not required on the date of the enactment of this section under a Federal motor vehicle safety standard to be equipped with a belt system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bcc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety belt","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “safety belt” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720bcd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to open-body passenger vehicles, including convertibles, an occupant restraint system consisting of a lap belt or a lap belt and a detachable shoulder belt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720bce-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to other passenger vehicles, an occupant restraint system consisting of integrated lap shoulder belts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bcf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated out of the Highway Trust Fund (other than the Mass Transit Account) to carry out this section $17,000,000 for fiscal year 1992. From sums made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s402"},"text":"section 402 of this title","children":[],"tail":", the Secretary shall make available $17,000,000 for fiscal year 1992 and $24,000,000 for each of fiscal years 1993 and 1994 to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bd0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s153/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Chapter","children":[],"tail":" 1 "},{"tag":"inline","attrib":{},"text":"Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All provisions of this chapter that are applicable to National Highway System funds, other than provisions relating to the apportionment formula and provisions limiting the expenditures of such funds to Federal-aid systems, shall apply to funds authorized to be appropriated to carry out this section, except as determined by the Secretary to be inconsistent with this section and except that sums authorized by this section shall remain available until ex­pended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e720bd1-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1031/a/1"},"text":"Pub. L. 102–240, title I, § 1031(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1970"},"text":"105 Stat. 1970","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tII/s205/e"},"text":"Pub. L. 104–59, title II, § 205(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/577"},"text":"109 Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1404/e"},"text":"Pub. L. 112–141, div. A, title I, § 1404(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/558"},"text":"126 Stat. 558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1446/a/7"},"text":"Pub. L. 114–94, div. A, title I, § 1446(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1437"},"text":"129 Stat. 1437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e720bd2-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e720bd3-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e720bd4-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (c) and (i)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"Section 104 of this title","children":[],"tail":", referred to in subsec. (h)(1), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1105/a"},"text":"Pub. L. 112–141, div. A, title I, § 1105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/427"},"text":"126 Stat. 427","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s154"},"text":"Section 154 of this title","children":[],"tail":", referred to in subsec. (i)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tII/s205/d/1/B"},"text":"Pub. L. 104–59, title II, § 205(d)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/577"},"text":"109 Stat. 577","children":[],"tail":". A new section 154, containing a similar definition of “motor vehicle”, was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1405/a"},"text":"Pub. L. 105–178, title I, § 1405(a)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9005/a"},"text":"Pub. L. 105–206, title IX, § 9005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/843"},"text":"112 Stat. 843","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e720bd5-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 153, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87/tII/s210/a"},"text":"Pub. L. 93–87, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/287"},"text":"87 Stat. 287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/280/tI/s131"},"text":"Pub. L. 94–280, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-05"},"text":"May 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/441"},"text":"90 Stat. 441","children":[],"tail":", related to a program for the elimination of roadside obstacles, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/599/tI/s168/b"},"text":"Pub. L. 95–599, title I, § 168(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2723"},"text":"92 Stat. 2723","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e720bd6-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “paragraphs (1), (2), and (4)” for “paragraphs (1) through (3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (h)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" redesignated par. (2) as (1), substituted “"},{"tag":"inline","attrib":{},"text":"Prior to fiscal year 2012","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Thereafter","children":[],"tail":"” in par. heading, inserted “and before "},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":",” after “"},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":",” in text, added par. (2), and struck out former par. (1). Prior to amendment, text of par. (1) read as follows: “If, at any time in fiscal year 1994, a State does not have in effect a law described in subsection (a)(2), the Secretary shall transfer 1½ percent of the funds apportioned to the State for fiscal year 1995 under each of subsections (b)(1), (b)(2), and (b)(3) of "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of this title","children":[],"tail":" to the apportionment of the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s402"},"text":"section 402 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (h)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59"},"text":"Pub. L. 104–59","children":[],"tail":" struck out “a law described in subsection (a)(1) and” after “have in effect”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e720bd7-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e720bd8-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e720bd9-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e720bda-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59/tII/s205/e"},"text":"Pub. L. 104–59, title II, § 205(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/577"},"text":"109 Stat. 577","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"Sept. 30, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e720bdb-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", and applicable to funds authorized to be appropriated or made available after "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", and, with certain exceptions, not applicable to funds appropriated or made available on or before "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1100"},"text":"section 1100 of Pub. L. 102–240","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id2e720bdc-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Stop Motorcycle Checkpoint Funding","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tIV/s4007"},"text":"Pub. L. 114–94, div. A, title IV, § 4007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1510"},"text":"129 Stat. 1510","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tIV/s4007"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s153"},"text":"section 153 of title 23","children":[],"tail":", United States Code, the Secretary [of Transportation] may not provide a grant or any funds to a State, county, town, township, Indian tribe, municipality, or other local government that may be used for any program—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to check helmet usage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create checkpoints that specifically target motorcycle operators or motorcycle passengers.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id2e720bdd-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Benefits of Safety Belts and Motorcycle Helmets to Individuals Involved in Crashes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1031/b"},"text":"Pub. L. 102–240, title I, § 1031(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1973"},"text":"105 Stat. 1973","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/240/tI/s1031/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a study or studies to determine the benefits of safety belt use and motorcycle helmet use for individuals involved in motor vehicle crashes and motorcycle crashes, collecting and analyzing data from regional trauma systems regarding differences in the following: the severity of injuries; acute, rehabilitative and long-term medical costs, including the sources of reimbursement and the extent to which these sources cover actual costs; government, employer, and other costs; and mortality and morbidity outcomes. The study shall cover a representative period after ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make public a proposed report on the results of the study or studies conducted under this subsection, provide a period of 90 days for public comment on such report, consider such comments, and transmit to Congress a report on the results of such study or studies, together with a summary of such comments, not later than 40 months after the funds for such study are made available by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts authorized to be appropriated for fiscal year 1992 or 1993 (or both) to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s153"},"text":"section 153 of title 23","children":[],"tail":", United States Code, the Secretary shall make available $5,000,000 in the aggregate in such fiscal years to carry out this subsection. Such funds shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
