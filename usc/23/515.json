{"tag":"section","attrib":{"id":"id2eb99bb9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515"},"text":null,"children":[{"tag":"num","attrib":{"value":"515"},"text":"§ 515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorities and requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2eb99bba-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of sections 512 through 518, the Secretary shall conduct an ongoing intelligent transportation system program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99bbb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to research, develop, and operationally test intelligent transportation systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bbc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance in the nationwide application of those systems as a component of the surface transportation systems of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bbd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Intelligent transportation system research projects and operational tests funded pursuant to sections 512 through 518 shall encourage and not displace public-private partnerships or private sector investment in those tests and projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bbe-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With Governmental, Private, and Educational Entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall carry out the intelligent transportation system program in cooperation with State and local governments and other public entities, the private sector firms of the United States, the Federal laboratories, and institutions of higher education, including historically Black colleges and universities and other minority institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bbf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Federal Officials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the intelligent transportation system program, the Secretary shall consult with the heads of other Federal agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bc0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance, Training, and Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide technical assistance, training, and information to State and local governments seeking to implement, operate, maintain, or evaluate intelligent transportation system technologies and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bc1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation Planning","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide funding to support adequate consideration of transportation systems management and operations, including intelligent transportation systems, within metropolitan and statewide transportation planning processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bc2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Clearinghouse.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99bc3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bc4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a repository for technical and safety data collected as a result of federally sponsored projects carried out under sections 512 through 518; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bc5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make, on request, that information (except for proprietary information and data) readily available to all users of the repository at an appropriate cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bc6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bc7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into an agreement with a third party for the maintenance of the repository for technical and safety data under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bc8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal financial assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary enters into an agreement with an entity for the maintenance of the repository, the entity shall be eligible for Federal financial assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bc9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information in the repository shall not be subject to sections 552 and 555 of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bca-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99bcb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish an Advisory Committee (referred to in this subsection as the “Advisory Committee”) to advise the Secretary on carrying out sections 512 through 518.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bcc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall have no more than 25 members, be balanced between metropolitan and rural interests, and include, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bcd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a State highway department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bce-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a local highway department who is not from a metropolitan planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bcf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a State, local, or regional transit agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a State, local, or regional wildlife, land use, or resource management agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a metropolitan planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of a national transit association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of a national, State, or local transportation agency or association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private sector user of intelligent transportation system technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private sector developer of intelligent transportation system technologies, which may include emerging vehicle technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic researcher with expertise in computer science or another information science field related to intelligent transportation systems, and who is not an expert on transportation issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic researcher who is a civil engineer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic researcher who is a social scientist with expertise in transportation issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bd9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an academic researcher who is a biological or ecological scientist with expertise in transportation issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bda-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a nonprofit group representing the intelligent transportation system industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bdb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a public interest group concerned with safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bdc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of a labor organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bdd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative of a mobility-providing entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bde-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert in traffic management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bdf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a public interest group concerned with the impact of the transportation system on land use and residential patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99be0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/T"},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from a public interest group concerned with the impact of the transportation system on terrestrial and aquatic species and the habitat of those species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99be1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/U"},"text":null,"children":[{"tag":"num","attrib":{"value":"U"},"text":"(U)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members with expertise in planning, safety, telecommunications, and operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99be2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert in cybersecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99be3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/2/W"},"text":null,"children":[{"tag":"num","attrib":{"value":"W"},"text":"(W)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an automobile manufacturer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99be4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99be5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of a member of the Advisory Committee shall be 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99be6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Renewal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On expiration of the term of a member of the Advisory Committee, the member—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2eb99be7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be reappointed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2eb99be8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the member is not reappointed under clause (i), may serve until a new member is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99be9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall convene not less frequently than twice each year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99beb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may convene with the use of remote video conference technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall, at a minimum, perform the following duties:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide input into the development of the intelligent transportation system aspects of the strategic plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s6503"},"text":"section 6503 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Review, at least annually, areas of intelligent transportation systems programs and research being considered for funding by the Department, to determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2eb99bef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether these activities are likely to advance either the state-of-the-practice or state-of-the-art in intelligent transportation systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2eb99bf0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the intelligent transportation system technologies are likely to be deployed by users, and if not, to determine the barriers to deployment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2eb99bf1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate roles for government and the private sector in investing in the programs, research, and technologies being considered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bf2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than May 1 of each year, the Secretary shall make available to the public on a Department of Transportation website a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bf3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all recommendations made by the Advisory Committee during the preceding calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bf4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the manner in which the Secretary has implemented those recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bf5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for recommendations not implemented, the reasons for rejecting the recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bf6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of chapter 10 of title 5, united states code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall be subject to chapter 10 of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2eb99bf7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2eb99bf8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines and requirements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2eb99bf9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue guidelines and requirements for the reporting and evaluation of operational tests and deployment projects carried out under sections 512 through 518.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bfa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectivity and independence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The guidelines and requirements issued under subparagraph (A) shall include provisions to ensure the objectivity and independence of the reporting entity so as to avoid any real or apparent conflict of interest or potential influence on the outcome by parties to any such test or deployment project or by any other formal evaluation carried out under sections 512 through 518.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2eb99bfb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The guidelines and requirements issued under subparagraph (A) shall establish reporting funding levels based on the size and scope of each test or project that ensure adequate reporting of the results of the test or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2eb99bfc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s515/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any survey, questionnaire, or interview that the Secretary considers necessary to carry out the reporting of any test, deployment project, or program assessment activity under sections 512 through 518 shall not be subject to chapter 35 of title 44, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2eb99bfd-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tIII/s53003/a"},"text":"Pub. L. 112–141, div. E, title III, § 53003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/899"},"text":"126 Stat. 899","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1446/a/14"},"text":"Pub. L. 114–94, div. A, title I, § 1446(a)(14)","children":[],"tail":", title VI, § 6007, "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1438"},"text":"129 Stat. 1438","children":[],"tail":", 1567; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tIII/s13008/a"},"text":"Pub. L. 117–58, div. A, title III, § 13008(a)","children":[],"tail":", div. B, title V, § 25001, "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/641"},"text":"135 Stat. 641","children":[],"tail":", 836; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/178"},"text":"Pub. L. 117–286, § 4(a)(178)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4325"},"text":"136 Stat. 4325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2eb99bfe-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2eb99bff-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2eb99c00-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", which directed amendment of subsec. (h)(5) by substituting “"},{"tag":"inline","attrib":{},"text":"chapter 10 of title 5, united states code","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"federal advisory committee act","children":[],"tail":"” in heading and “chapter 10 of title 5, United States Code.” for “the Federal Advisory Committee Act (5 U.S.C. App.).” in text, was executed by making the substitutions in subsec. (h)(7) to reflect the probable intent of Congress and the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/4"},"text":"Pub. L. 117–58, § 25001(4)","children":[],"tail":". See 2021 Amendment note, below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/1"},"text":"Pub. L. 117–58, § 25001(1)","children":[],"tail":", inserted “(referred to in this subsection as the ‘Advisory Committee’)” after “an Advisory Committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/A"},"text":"Pub. L. 117–58, § 25001(2)(A)","children":[],"tail":", substituted “25 members” for “20 members” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(D) to (W). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s13008/a"},"text":"Pub. L. 117–58, § 13008(a)","children":[],"tail":" and § 25001(2)(D)–(G), added various subpars. and successively redesignated existing subpars., resulting in ultimate redesignations of original subpars. as follows: (D) as (E), (E) as (H), (F) as (J), (G) as (K), (H) as (L), (I) as (N), (J) as (O), (K) as (S), and (L) as (U). For newly added subpars., see notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s13008/a/3"},"text":"Pub. L. 117–58, § 13008(a)(3)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(F), (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/D"},"text":"Pub. L. 117–58, § 25001(2)(D)","children":[],"tail":", added subpars. (F) and (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/E"},"text":"Pub. L. 117–58, § 25001(2)(E)","children":[],"tail":", added subpar. (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s13008/a/4"},"text":"Pub. L. 117–58, § 13008(a)(4)","children":[],"tail":", added subpar. (J), which was subsequently redesignated (M) by "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/C"},"text":"Pub. L. 117–58, § 25001(2)(C)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(N). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s13008/a/5"},"text":"Pub. L. 117–58, § 13008(a)(5)","children":[],"tail":", added subpar. (N), which was subsequently redesignated (T) by "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/C"},"text":"Pub. L. 117–58, § 25001(2)(C)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(O). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/B"},"text":"Pub. L. 117–58, § 25001(2)(B)","children":[],"tail":", prior to redesignation of subpar. (O) as (U), struck out “utilities,” after “telecommunications,” and substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(P) to (R). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/F"},"text":"Pub. L. 117–58, § 25001(2)(F)","children":[],"tail":", added subpars. (P) to (R)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2)(V), (W). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/2/G"},"text":"Pub. L. 117–58, § 25001(2)(G)","children":[],"tail":", added subpars. (V) and (W)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/5"},"text":"Pub. L. 117–58, § 25001(5)","children":[],"tail":", added par. (3). Former par. (3) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/3/A"},"text":"Pub. L. 117–58, § 25001(3)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s6503"},"text":"section 6503 of title 49","children":[],"tail":"” for “section 508”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/3/B/i"},"text":"Pub. L. 117–58, § 25001(3)(B)(i)","children":[],"tail":", inserted “programs and” before “research” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/3/B/ii"},"text":"Pub. L. 117–58, § 25001(3)(B)(ii)","children":[],"tail":", substituted “programs, research, and” for “research and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/5"},"text":"Pub. L. 117–58, § 25001(5)","children":[],"tail":", added par. (4). Former par. (4) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25001/4"},"text":"Pub. L. 117–58, § 25001(4)","children":[],"tail":", redesignated pars. (3) to (5) as (5) to (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/a/14"},"text":"Pub. L. 114–94, § 1446(a)(14)","children":[],"tail":", substituted “sections 512 through 518” for “this chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s6007"},"text":"Pub. L. 114–94, § 6007","children":[],"tail":", in introductory provisions, substituted “May 1 of each year” for “February 1 of each year after the date of enactment of the Transportation Research and Innovative Technology Act of 2012” and “make available to the public on a Department of Transportation website” for “submit to Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2eb99c01-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb99c02-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s13008/a"},"text":"section 13008(a) of Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2eb99c03-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2eb99c04-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
