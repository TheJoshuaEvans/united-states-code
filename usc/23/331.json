{"tag":"section","attrib":{"id":"id2e95c0e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331"},"text":null,"children":[{"tag":"num","attrib":{"value":"331"},"text":"§ 331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of projects within an operational right-of-way","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e95c0e6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e95c0e7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible project or activity.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e95c0e8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible project or activity” means a project or activity within an existing operational right-of-way (as defined in section 771.117(c)(22) of title 23, Code of Federal Regulations (or successor regulations))—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e95c0e9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e95c0ea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for assistance under this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e95c0eb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered as if made available under this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c0ec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e95c0ed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a preventive maintenance, preservation, or highway safety improvement project (as defined in section 148(a)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e95c0ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new turn lane that the State advises in writing to the Secretary would assist public safety; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e95c0ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e95c0f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is classified as a categorical exclusion under section 771.117 of title 23, Code of Federal Regulations (or successor regulations); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e95c0f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the project or activity does not receive assistance described in clause (i) would be considered a categorical exclusion if the project or activity received assistance described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c0f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible project or activity” does not include a project to create a new travel lane.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e95c0f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preliminary evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “preliminary evaluation”, with respect to an application described in subsection (b)(1), means an evaluation that is customary or practicable for the relevant agency to complete within a 45-day period for similar applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e95c0f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relevant agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “relevant agency” means a Federal agency, other than the Federal Highway Administration, with responsibility for review of an application from a State for a permit, approval, or jurisdictional determination for an eligible project or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e95c0f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e95c0f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), not later than 45 days after the date of receipt of an application by a State for a permit, approval, or jurisdictional determination for an eligible project or activity, the head of the relevant agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e95c0f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make at least a preliminary evaluation of the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c0f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the State of the results of the preliminary evaluation under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e95c0f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the relevant agency may extend the review period under paragraph (1) by not more than 30 days if the head of the relevant agency provides to the State written notice that includes an explanation of the need for the extension.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e95c0fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to act","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the head of the relevant agency fails to meet a deadline under paragraph (1) or (2), as applicable, the head of the relevant agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e95c0fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days after the date of the missed deadline, submit to the State, the Committee on Environment and Public Works of the Senate, and the Committee on Transportation and Infrastructure of the House of Representatives a report that describes why the deadline was missed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e95c0fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s331/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 14 days after the date on which a report is submitted under subparagraph (A), make publicly available, including on the internet, a copy of that report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e95c0fd-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11309/a"},"text":"Pub. L. 117–58, div. A, title I, § 11309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/535"},"text":"135 Stat. 535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e95c0fe-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e95c0ff-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e95c100-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
