{"tag":"section","attrib":{"id":"id2e424988-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126"},"text":null,"children":[{"tag":"num","attrib":{"value":"126"},"text":"§ 126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferability of Federal-aid highway funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e424989-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, subject to subsection (b), a State may transfer from an apportionment under section 104(b) not to exceed 50 percent of the amount apportioned for the fiscal year to any other apportionment of the State under that section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e42498a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Certain Set-asides.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e42498b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds that are subject to sections 104(d) and 133(d)(1)(A) shall not be transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e42498c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds transferred by states","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds transferred by a State under this section of the funding set aside for a State under section 133(h) for a fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e42498d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only come from the portion of those funds that are available for obligation in any area of the State under section 133(h); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e42498e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may only be transferred if the Secretary certifies that the State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e42498f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held a competition in compliance with the guidance issued to carry out section 133(h) and provided sufficient time for applicants to apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e424990-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered to each eligible entity, and provided on request of an eligible entity, technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e424991-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s126/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that there were not sufficiently suitable applications from eligible entities to use the funds to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e424992-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1310/a"},"text":"Pub. L. 105–178, title I, § 1310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/234"},"text":"112 Stat. 234","children":[],"tail":", § 110; renumbered § 126, "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tI/s102/a/1"},"text":"Pub. L. 106–159, title I, § 102(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1752"},"text":"113 Stat. 1752","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tI/s1401/a/3/B"},"text":"Pub. L. 109–59, title I, § 1401(a)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1225"},"text":"119 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1509/a"},"text":"Pub. L. 112–141, div. A, title I, § 1509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/567"},"text":"1