{"tag":"section","attrib":{"id":"id2ea68946-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408"},"text":null,"children":[{"tag":"num","attrib":{"value":"408"},"text":"§ 408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ea68947-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Triennial State Management Reviews.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea68948-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under paragraph (2), the Secretary shall conduct a review of each State highway safety program at least once every 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea68949-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may conduct reviews of the highway safety programs of the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands as often as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea6894a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Components","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Reviews under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ea6894b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a management evaluation of all grant programs funded under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea6894c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of State data collection and evaluation relating to performance measures established by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea6894d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of State efforts under subparagraphs (A) and (B) to best practices and programs that have been evaluated for effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea6894e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development of recommendations on how each State could—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ea6894f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the management and oversight of its grant activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ea68950-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a management and oversight plan for such grant programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68951-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations Before Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to provide guidance to State highway safety agencies on matters that should be addressed in the goals and initiatives of the State highway safety program before the program is submitted for review, the Secretary shall provide data-based recommendations to each State at least 90 days before the date on which the program is to be submitted for approval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68952-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Program Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea68953-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a program improvement review of a highway safety program under this chapter of a State that does not make substantial progress over a 3-year period in meeting its priority program goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea68954-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and safety program requirements to be incorporated in the State highway safety program for any goal not achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68955-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional Harmonization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Inspector General of the Department of Transportation shall undertake an administrative review of the practices and procedures of the management reviews and program reviews of State highway safety programs under this chapter conducted by the regional offices of the National Highway Traffic Safety Administration and prepare a written report of best practices and procedures for use by the regional offices in conducting such reviews. The report shall be completed within 180 days after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea68956-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Best Practices Guidelines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ea68957-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniform guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue uniform management review guidelines and program review guidelines based on the report under subsection (d). Each regional office shall use the guidelines in executing its State administrative review duties under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea68958-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make publicly available on the Web site (or successor electronic facility) of the Administration the following documents upon their completion:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ea68959-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s management review guidelines and program review guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea6895a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All State highway safety programs submitted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea6895b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State annual accomplishment reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ea6895c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administration’s Summary Report of findings from Management Reviews and Improvement Plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ea6895d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to state highway safety agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not make publicly available a program, report, or review under paragraph (2) that is directed to a State highway safety agency until after the date on which the program, report, or review is submitted to that agency under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ea6895e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s408/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tracking Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop a process to identify and mitigate possible systemic issues across States and regional offices by reviewing oversight findings and recommended actions identified in triennial State management reviews.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ea6895f-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tII/s2008/a"},"text":"Pub. L. 109–59, title II, § 2008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1533"},"text":"119 Stat. 1533","children":[],"tail":", § 412; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31107"},"text":"Pub. L. 112–141, div. C, title I, § 31107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/755"},"text":"126 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tIV/s4006"},"text":"Pub. L. 114–94, div. A, title IV, § 4006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1510"},"text":"129 Stat. 1510","children":[],"tail":"; renumbered § 408, "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24101/d/1/A"},"text":"Pub. L. 117–58, div. B, title IV, § 24101(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/784"},"text":"135 Stat. 784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2ea68960-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2ea68961-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2ea68962-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 408, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/364/tI/s101/a"},"text":"Pub. L. 97–364, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-25"},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1738"},"text":"96 Stat. 1738","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/363"},"text":"Pub. L. 98–363","children":[],"tail":", §§ 4, 7, "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/436"},"text":"98 Stat. 436","children":[],"tail":", 438; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tII/s203/a"},"text":"Pub. L. 100–17, title II, § 203(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/219"},"text":"101 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tII/s2006/a"},"text":"Pub. L. 109–59, title II, § 2006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1527"},"text":"119 Stat. 1527","children":[],"tail":", related to State traffic safety information system improvements, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"Pub. L. 112–141, § 3(a)","children":[],"tail":", div. C, title I, § 31109(d), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/413"},"text":"126 Stat. 413","children":[],"tail":", 756, effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2ea68963-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which directed the amendment of this chapter by renumbering section 412 “and” section 408, was executed by renumbering section 412 as this section as if “and” had read “as”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
