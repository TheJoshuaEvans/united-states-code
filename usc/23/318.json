{"tag":"section","attrib":{"id":"id2e910557-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s318"},"text":null,"children":[{"tag":"num","attrib":{"value":"318"},"text":"§ 318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highway relocation due to airport","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Federal highway funds shall not be used for the reconstruction or relocation of any highway giving access to an airport constructed or extended after ","children":[{"tag":"date","attrib":{"date":"1944-12-20"},"text":"December 20, 1944","children":[],"tail":", or for the reconstruction or relocation of any highway which has been or may be closed or the usefulness of which has been may be impaired by the location or construction of any airport constructed or extended after "},{"tag":"date","attrib":{"date":"1944-12-20"},"text":"December 20, 1944","children":[],"tail":", unless, prior to such construction or extension, as the case may be, the State transportation department and the Secretary have concurred with the officials in charge of the airport that the location of such airport or extension thereof and the consequent reconstruction or relocation of the highway are in the public interest."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id2e910558-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/916"},"text":"72 Stat. 916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1212/a/2/A/i"},"text":"Pub. L. 105–178, title I, § 1212(a)(2)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/193"},"text":"112 Stat. 193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e910559-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e91055a-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e91055b-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “State transportation department” for “State highway department”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
