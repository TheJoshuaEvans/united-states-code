{"tag":"section","attrib":{"id":"id2ec0a0c2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s606"},"text":null,"children":[{"tag":"num","attrib":{"value":"606"},"text":"§ 606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local permits","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The provision of credit assistance under the TIFIA program with respect to a project shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0c3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s606/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relieve any recipient of the assistance of any obligation to obtain any required State or local permit or approval with respect to the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0c4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s606/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the right of any unit of State or local government to approve or regulate any rate of return on private equity invested in the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0c5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s606/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise supersede any State or local law (including any regulation) applicable to the construction or operation of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ec0a0c6-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1503/a"},"text":"Pub. L. 105–178, title I, § 1503(a)","children":[],"tail":", "},{"tag":"da