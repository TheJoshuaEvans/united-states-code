{"tag":"section","attrib":{"id":"id2e803c5c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179"},"text":null,"children":[{"tag":"num","attrib":{"value":"179"},"text":"§ 179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-carbon transportation materials grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e803c5d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Highway Administration Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $2,000,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":", to the Administrator to reimburse or provide incentives to eligible recipients for the use, in projects, of construction materials and products that have substantially lower levels of embodied greenhouse gas emissions associated with all relevant stages of production, use, and disposal as compared to estimated industry averages of similar materials or products, as determined by the Administrator of the Environmental Protection Agency, and for the operations and administration of the Federal Highway Administration to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c5e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Incremental Costs; Incentives","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c5f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall, subject to the availability of funds, either reimburse or provide incentives to eligible recipients that use low-embodied carbon construction materials and products on a project funded under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c60-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement and incentive amounts","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c61-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incremental amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of reimbursement under paragraph (1) shall be equal to the incrementally higher cost of using such materials relative to the cost of using traditional materials, as determined by the eligible recipient and verified by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c62-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of an incentive under paragraph (1) shall be equal to 2 percent of the cost of using low-embodied carbon construction materials and products on a project funded under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c63-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a reimbursement or incentive is provided under paragraph (1), the total Federal share payable for the project for which the reimbursement or incentive is provided shall be up to 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c64-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c65-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall only provide a reimbursement or incentive under paragraph (1) for a project on a—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e803c66-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal-aid highway;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c67-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal transportation facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c68-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal lands transportation facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e803c69-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal lands access transportation facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c6a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available under this section shall not be subject to any restriction or limitation on the total amount of funds available for implementation or execution of programs authorized for Federal-aid highways.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c6b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single occupant passenger vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available under this section shall not be used for projects that result in additional through travel lanes for single occupant passenger vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c6c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Materials identification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall review the low-embodied carbon construction materials and products identified by the Administrator of the Environmental Protection Agency and shall identify low-embodied carbon construction materials and products—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c6d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate for use in projects eligible under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c6e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for reimbursement or incentives under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e803c6f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e803c70-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of the Federal Highway Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c71-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible recipient","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible recipient” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e803c72-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c73-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c74-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c75-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a territory of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c76-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity described in section 207(m)(1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c77-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recipient of funds under section 203;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c78-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization (as defined in section 134(b)(2)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e803c79-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special purpose district or public authority with a transportation function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e803c7a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s179/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Greenhouse gas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “greenhouse gas” means the air pollutants carbon dioxide, hydrofluorocarbons, methane, nitrous oxide, perfluorocarbons, and sulfur hexafluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e803c7b-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tVI/s60506/a"},"text":"Pub. L. 117–169, title VI, § 60506(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2085"},"text":"136 Stat. 2085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
