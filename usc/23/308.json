{"tag":"section","attrib":{"id":"id2e8e93ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308"},"text":null,"children":[{"tag":"num","attrib":{"value":"308"},"text":"§ 308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with Federal and State agencies and foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e8e93ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e8e93f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may perform, by contract or otherwise, authorized engineering or other services in connection with the survey, construction, maintenance, or improvement of highways for other Federal agencies, cooperating foreign countries, and State cooperating agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e93f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Services authorized under paragraph (1) may include activities authorized under section 214 of the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e93f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Reimbursement for services carried out under this subsection (including depreciation on engineering and road-building equipment) shall be credited to the applicable appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e8e93f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative contracting methods.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e8e93f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law (including the Federal Acquisition Regulation), in performing services under paragraph (1), the Secretary may use any contracting method available to a State under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e8e93f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Methods described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The contracting methods referred to in subparagraph (A) shall include, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e8e93f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project bundling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8e93f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bridge bundling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8e93f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design-build contracting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8e93f9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2-phase contracting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8e93fa-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term concession agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e8e93fb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any method tested, or that could be tested, under an experimental program relating to contracting methods carried out by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e8e93fc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations for the work of the Federal Highway Administration shall be available for expenses of warehouse maintenance and the procurement, care, and handling of supplies, materials, and equipment for distribution to projects under the supervision of the Federal Highway Administration, or for sale or distribution to other Government agencies, cooperating foreign countries, and State cooperating agencies, and the cost of such supplies and materials or the value of such equipment, including the cost of transportation and handling, may be reimbursed to current applicable appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e8e93fd-3a70-11f1-8334-895c8eef5d79"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/767"},"text":"Pub. L. 85–767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/914"},"text":"72 Stat. 914","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/87/tI/s152/5"},"text":"Pub. L. 93–87, title I, § 152(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-13"},"text":"Aug. 13, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/276"},"text":"87 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1521/f"},"text":"Pub. L. 112–141, div. A, title I, § 1521(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/579"},"text":"126 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11305/b"},"text":"Pub. L. 117–58, div. A, title I, § 11305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/532"},"text":"135 Stat. 532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e8e93fe-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e8e93ff-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e8e9400-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 214 of the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, referred to in subsec. (a)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4634"},"text":"section 4634 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e8e9401-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" added subsec. (a) and struck out former subsec. (a) which read as follows: “The Secretary is authorized to perform by contract or otherwise, authorized engineering or other services in connection with the survey, construction, maintenance, or improvement of highways for other Government agencies, cooperating foreign countries, and State cooperating agencies, and reimbursement for such services, which may include depreciation on engineering and roadbuilding equipment used, shall be credited to the appropriation concerned.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/87"},"text":"Pub. L. 93–87","children":[],"tail":" substituted “Federal Highway Administration” for “Bureau of Public Roads” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e8e9402-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e8e9403-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e8e9404-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1521/g"},"text":"Pub. L. 112–141, div. A, title I, § 1521(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/579"},"text":"126 Stat. 579","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dA/tI/s1521/g"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4634"},"text":"section 4634 of Title 42","children":[],"tail":", The Public Health and Welfare, and amending this section and sections 4622 to 4624 and 4633 of Title 42] shall take effect on the date of enactment of this Act [see section 3(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", set out as Effective and Termination Dates of 2012 Amendment notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a) through (c) [amending sections 4622 to 4624 of Title 42] shall take effect 2 years after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
