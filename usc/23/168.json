{"tag":"section","attrib":{"id":"id2e793862-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168"},"text":null,"children":[{"tag":"num","attrib":{"value":"168"},"text":"§ 168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of planning and environmental review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e793863-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e793864-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental review process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “environmental review process” has the meaning given the term in section 139(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793865-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lead agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “lead agency” has the meaning given the term in section 139(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793866-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning product","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “planning product” means a decision, analysis, study, or other documented information that is the result of an evaluation or decisionmaking process carried out by a metropolitan planning organization or a State, as appropriate, during metropolitan or statewide transportation planning under section 134 or 135, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793867-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “project” has the meaning given the term in section 139(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793868-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project sponsor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “project sponsor” has the meaning given the term in section 139(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793869-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relevant agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “relevant agency” means the agency with authority under subparagraph (A) or (B) of subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e79386a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adoption or Incorporation by Reference of Planning Products for Use in NEPA Proceedings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e79386b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d) and to the maximum extent practicable and appropriate, the following agencies may adopt or incorporate by reference and use a planning product in proceedings relating to any class of action in the environmental review process of the project:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e79386c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lead agency for a project, with respect to an environmental impact statement, environmental assessment, categorical exclusion, or other document prepared under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e79386d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cooperating agency with responsibility under Federal law, with respect to the process for and completion of any environmental permit, approval, review, or study required for a project under any Federal law other than the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), if consistent with that law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e79386e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the relevant agency makes a determination to adopt or incorporate by reference and use a planning product, the relevant agency shall identify the agencies that participated in the development of the planning products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e79386f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adoption or incorporation by reference of planning products","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relevant agency may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e793870-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt or incorporate by reference an entire planning product under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793871-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select portions of a planning project under paragraph (1) for adoption or incorporation by reference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793872-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A determination under paragraph (1) with respect to the adoption or incorporation by reference of a planning product may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e793873-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made at the time the relevant agencies decide the appropriate scope of environmental review for the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793874-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occur later in the environmental review process, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e793875-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e793876-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning decisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relevant agency in the environmental review process may adopt or incorporate by reference decisions from a planning product, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e793877-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether tolling, private financial assistance, or other special financial measures are necessary to implement the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793878-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision with respect to general travel corridor or modal choice, including a decision to implement corridor or subarea study recommendations to advance different modal solutions as separate projects with independent utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793879-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose and the need for the proposed action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e79387a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary screening of alternatives and elimination of unreasonable alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e79387b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a basic description of the environmental setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e79387c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision with respect to methodologies for analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e79387d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of programmatic level mitigation for potential impacts of a project, including a programmatic mitigation plan developed in accordance with section 169, that the relevant agency determines are more effectively addressed on a national or regional scale, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e79387e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to avoid, minimize, and mitigate impacts at a national or regional scale of proposed transportation investments on environmental resources, including regional ecosystem and water resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e79387f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential mitigation activities, locations, and investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e793880-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning analyses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relevant agency in the environmental review process may adopt or incorporate by reference analyses from a planning product, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e793881-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel demands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793882-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional development and growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793883-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local land use, growth management, and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793884-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" population and employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793885-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural and built environmental conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793886-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental resources and environmentally sensitive areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793887-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential environmental effects, including the identification of resources of concern and potential direct, indirect, and cumulative effects on those resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e793888-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigation needs for a proposed project, or for programmatic level mitigation, for potential effects that the lead agency determines are most effectively addressed at a regional or national program level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8179-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The relevant agency in the environmental review process may adopt or incorporate by reference a planning product under this section if the relevant agency determines, with the concurrence of the lead agency and, if the planning product is necessary for a cooperating agency to issue a permit, review, or approval for the project, with the concurrence of the cooperating agency, that the following conditions have been met:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b817a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning product was developed through a planning process conducted pursuant to applicable Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b817b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning product was developed in consultation with appropriate Federal and State resource agencies and Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b817c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning process included broad multidisciplinary consideration of systems-level or corridor-wide transportation needs and potential effects, including effects on the human and natural environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b817d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning process included public notice that the planning products produced in the planning process may be adopted during a subsequent environmental review process in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b817e-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During the environmental review process, the relevant agency has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7b817f-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made the planning documents available for public review and comment by members of the general public and Federal, State, local, and tribal governments that may have an interest in the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8180-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided notice of the intention of the relevant agency to adopt or incorporate by reference the planning product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7b8181-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered any resulting comments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8182-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is no significant new information or new circumstance that has a reasonable likelihood of affecting the continued validity or appropriateness of the planning product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8183-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning product has a rational basis and is based on reliable and reasonably current data and reasonable and scientifically acceptable methodologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8184-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning product is documented in sufficient detail to support the decision or the results of the analysis and to meet requirements for use of the information in the environmental review process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8185-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning product is appropriate for adoption or incorporation by reference and use in the environmental review process for the project and is incorporated in accordance with, and is sufficient to meet the requirements of, the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and section 1502.21 of title 40, Code of Federal Regulations (as in effect on the date of enactment of the FAST Act)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8186-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The planning product was approved within the 5-year period ending on the date on which the information is adopted or incorporated by reference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b8187-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Adoption or Incorporation by Reference","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any planning product adopted or incorporated by reference by the relevant agency in accordance with this section may be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b8188-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporated directly into an environmental review process document or other environmental document; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b8189-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relied on and used by other Federal agencies in carrying out reviews of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e7b818a-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e7b818b-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not make the environmental review process applicable to the transportation planning process conducted under this title and chapter 53 of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b818c-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation planning activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Initiation of the environmental review process as a part of, or concurrently with, transportation planning activities does not subject transportation plans and programs to the environmental review process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7b818d-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s168/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect the use of planning products in the environmental review process pursuant to other authorities under any other provision of law or restrict the initiation of the environmental review process during planning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7b818e-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1310/a"},"text":"Pub. L. 112–141, div. A, title I, § 1310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/540"},"text":"126 Stat. 540","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1305"},"text":"Pub. L. 114–94, div. A, title I, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1386"},"text":"129 Stat. 1386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id2e7b818f-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id2e7b8190-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id2e7b8191-3a70-11f1-8334-895c8eef5d79"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsecs. (b)(1) and (d)(9), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the FAST Act, referred to in subsec. (d)(9), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e7b8192-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" amended section generally. Prior to amendment, section related to integration of planning and environmental review."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7b8193-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e7b8194-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id2e7b8195-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
