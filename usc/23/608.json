{"tag":"section","attrib":{"id":"id2ec0a0d5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608"},"text":null,"children":[{"tag":"num","attrib":{"value":"608"},"text":"§ 608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2ec0a0d6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0d7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spending and borrowing authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Spending and borrowing authority for a fiscal year to enter into Federal credit instruments shall be promptly apportioned to the Secretary on a fiscal-year basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0d8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reestimates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the subsidy cost of a Federal credit instrument is reestimated, the cost increase or decrease of the reestimate shall be borne by, or benefit, the general fund of the Treasury, consistent with section 504(f) of the Congressional Budget Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661c/f"},"text":"2 U.S.C. 661c(f)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0d9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rural set-aside.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a0da-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the total amount of funds made available to carry out the TIFIA program for each fiscal year, not more than 10 percent shall be set aside for rural infrastructure projects or rural projects funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a0db-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reobligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts set aside under subparagraph (A) that remain unobligated by June 1 of the fiscal year for which the amounts were set aside shall be available for obligation by the Secretary on projects other than rural infrastructure projects or rural projects funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0dc-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation for certain projects.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2ec0a0dd-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transit-oriented development projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, the Secretary may use to carry out projects described in section 601(a)(12)(E) not more than 15 percent of the amounts made available to carry out the TIFIA program for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2ec0a0de-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airport-related projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may use to carry out projects described in section 601(a)(12)(G)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2ec0a0df-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each fiscal year, not more than 15 percent of the amounts made available to carry out the TIFIA program under the Surface Transportation Reauthorization Act of 2021 for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2ec0a0e0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the period of fiscal years 2022 through 2026, not more than 15 percent of the unobligated carryover balances (as of ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0e1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available to carry out the TIFIA program shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0e2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available to carry out the TIFIA program, the Secretary may use not more than $10,000,000 for each of fiscal years 2022 through 2026 for the administration of the TIFIA program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2ec0a0e3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2ec0a0e4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, execution of a term sheet by the Secretary of a Federal credit instrument that uses amounts made available under the TIFIA program shall impose on the United States a contractual obligation to fund the Federal credit investment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2ec0a0e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s608/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available to carry out the TIFIA program for a fiscal year shall be available for obligation on October 1 of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2ec0a0e6-3a70-11f1-8334-895c8eef5d79"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1503/a"},"text":"Pub. L. 105–178, title I, § 1503(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/249"},"text":"112 Stat. 249","children":[],"tail":", § 188; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9007/a"},"text":"Pub. L. 105–206, title IX, § 9007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/849"},"text":"112 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href