out under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2ec0a0ea-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s12001/i/1/A"},"text":"Pub. L. 117–58, § 12001(i)(1)(A)","children":[],"tail":", (B), added par. (4) and redesignated former par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s12001/i/1/A"},"text":"Pub. L. 117–58, § 12001(i)(1)(A)","children":[],"tail":", (C), redesignated par. (5) as (6), struck it out, and added a new par. (6). Prior to amendment, text read as follows: “Of the amounts made available to carry out the TIFIA program, the Secretary may use not more than $6,875,000 for fiscal year 2016, $7,081,000 for fiscal year 2017, $7,559,000 for fiscal year 2018, $8,195,000 for fiscal year 2019, and $8,441,000 for fiscal year 2020 for the administration of the TIFIA program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s2001/g/1"},"text":"Pub. L. 114–94, § 2001(g)(1)","children":[],"tail":", substituted “the TIFIA program” for “this chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s2001/g/2/A"},"text":"Pub. L. 114–94, § 2001(g)(2)(A)","children":[],"tail":", inserted “of” after “504(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s2001/g/2/B"},"text":"Pub. L. 114–94, § 2001(g)(2)(B)","children":[],"tail":", inserted “or rural proj