:"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id2e7454fc-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 154, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/643/s114/a"},"text":"Pub. L. 93–643, § 114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2286"},"text":"88 Stat. 2286","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/599/tII/s205"},"text":"Pub. L. 95–599, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2729"},"text":"92 Stat. 2729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXI/s1108"},"text":"Pub. L. 97–35, title XI, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/626"},"text":"95 Stat. 626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/17/tI/s174"},"text":"Pub. L. 100–17, title I, § 174","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-02"},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/218"},"text":"101 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tI/s1029/a"},"text":"Pub. L. 102–240, title I, § 1029(a)","children":[],"tail":", (b), (e), (g), "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1968-1970"},"text":"105 Stat. 1968–1970","children":[],"tail":", established the national maximum speed limit, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tII/s205/d/1/B"},"text":"Pub. L. 104–59, title II, § 205(d)(1)(B)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/577"},"text":"109 Stat. 577","children":[],"tail":", applicable to State on 10th day following "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", except that if legislature was not in session on such date and chief executive officer declared before such date that legislature was not in session and that State preferred applicability date that was after date on which legislature would convene, applicable to State on 60th day following date on which legislature would next convene."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id2e7454fd-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s24106/a"},"text":"Pub. L. 117–58, § 24106(a)","children":[],"tail":", substituted “impaired” for “alcohol-impaired” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11131/a/1"},"text":"Pub. L. 117–58, § 11131(a)(1)","children":[],"tail":", substituted “2022” for “2012” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11131/a/2"},"text":"Pub. L. 117–58, § 11131(a)(2)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A). Prior to amendment, text read as follows: “On "},{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":", and each October 1 thereafter, if a State has not enacted or is not enforcing an open container law described in subsection (b), the Secretary shall reserve an amount equal to 2.5 percent of the funds to be apportioned to the State on that date under each of paragraphs (1) and (2) of section 104(b) until the State certifies to the Secretary the means by which the State will use those reserved funds in accordance with subparagraphs (A) and (B) of paragraph (1) and paragraph (3).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11131/a/3"},"text":"Pub. L. 117–58, § 11131(a)(3)","children":[],"tail":", substituted “subparagraph (A)(i)” for “subparagraph (A)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/a/8/A"},"text":"Pub. L. 114–94, § 1446(a)(8)(A)","children":[],"tail":", substituted “paragraphs (1), (2), and (4)” for “paragraphs (1), (3), and (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/a/8/B"},"text":"Pub. L. 114–94, § 1446(a)(8)(B)","children":[],"tail":", substituted “reserved” for “transferred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/a/8/C/i"},"text":"Pub. L. 114–94, § 1446(a)(8)(C)(i)","children":[],"tail":", inserted “or released” after “transferred” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1446/a/8/C/ii"},"text":"Pub. L. 114–94, § 1446(a)(8)(C)(ii)","children":[],"tail":", substituted “under section 104(b)(1)” for “under section 104(b)(l)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1402/1"},"text":"Pub. L. 112–141, § 1402(1)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “On "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"October 1, 2002","children":[],"tail":", and each October 1 thereafter, if a State has not enacted or is not enforcing an open container law described in subsection (b), the Secretary shall transfer an amount equal to 3 percent of the funds apportioned to the State on that date under each of paragraphs (1), (3), and (4) of section 104(b) to the apportionment of the State under section 402 to be used or directed as described in subparagraph (A) or (B) of paragraph (1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1402/2"},"text":"Pub. L. 112–141, § 1402(2)","children":[],"tail":", added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “A State may elect to use all or a portion of the funds transferred under paragraph (1) or (2) for activities eligible under section 148.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s1402/3"},"text":"Pub. L. 112–141, § 1402(3)","children":[],"tail":", added par. (5) and struck out former par. (5). Prior to amendment, text read as follows: “The amount to be transferred under paragraph (1) or (2) may be derived from one or more of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) The apportionment of the State under section 104(b)(1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The apportionment of the State under section 104(b)(3).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) The apportionment of the State under section 104(b)(4).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “148” for “152”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id2e7454fe-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e7454ff-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s11131/a"},"text":"section 11131(a) of Pub. L. 117–58","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"Oct. 1, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/s10003"},"text":"section 10003 of Pub. L. 117–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id2e745500-3a70-11f1-8334-895c8eef5d79"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attr