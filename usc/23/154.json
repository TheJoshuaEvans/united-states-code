{"tag":"section","attrib":{"id":"id2e720bde-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154"},"text":null,"children":[{"tag":"num","attrib":{"value":"154"},"text":"§ 154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open container requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id2e720bdf-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720be0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alcoholic beverage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “alcoholic beverage” has the meaning given the term in section 158(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720be1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motor vehicle” means a vehicle driven or drawn by mechanical power and manufactured primarily for use on public highways, but does not include a vehicle operated exclusively on a rail or rails.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720be2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open alcoholic beverage container","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “open alcoholic beverage container” means any bottle, can, or other receptacle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720be3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains any amount of alcoholic beverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720be4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e720be5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is open or has a broken seal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e720be6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contents of which are partially removed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720be7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Passenger area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “passenger area” shall have the meaning given the term by the Secretary by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720be8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open Container Laws.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720be9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, each State shall have in effect a law that prohibits the possession of any open alcoholic beverage container, or the consumption of any alcoholic beverage, in the passenger area of any motor vehicle (including possession or consumption by the driver of the vehicle) located on a public highway, or the right-of-way of a public highway, in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor vehicles designed to transport many passengers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, if a State has in effect a law that makes unlawful the possession of any open alcoholic beverage container by the driver (but not by a passenger)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720beb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the passenger area of a motor vehicle designed, maintained, or used primarily for the transportation of persons for compensation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720bec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the living quarters of a house coach or house trailer,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the State shall be deemed to have in effect a law described in this subsection with respect to such a motor vehicle for each fiscal year during which the law is in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id2e720bed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id2e720bee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal years 2001 and 2002","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"October 1, 2001","children":[],"tail":", if a State has not enacted or is not enforcing an open container law described in subsection (b), the Secretary shall transfer an amount equal to 1½ percent of the funds apportioned to the State on that date under each of paragraphs (1), (2), and (4) of section 104(b) to the apportionment of the State under section 402—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720bef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be used for impaired driving countermeasures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e720bf0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be directed to State and local law enforcement agencies for enforcement of laws prohibiting driving while intoxicated or driving under the influence and other related laws (including regulations), including the purchase of equipment, the training of officers, and the use of additional personnel for specific impaired driving countermeasures, dedicated to enforcement of the laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e720bf1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year 2022 and thereafter","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e720bf2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reservation of funds.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id2e720bf3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":", and each October 1 thereafter, in the case of a State described in clause (ii), the Secretary shall reserve an amount equal to 2.5 percent of the funds to be apportioned to the State on that date under each of paragraphs (1) and (2) of section 104(b) until the State certifies to the Secretary the means by which the State will use those reserved funds in accordance with subparagraphs (A) and (B) of paragraph (1), and paragraph (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7454e4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State referred to in clause (i) is a State—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7454e5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has not enacted or is not enforcing an open container law described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7454e6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the Secretary determined for the prior fiscal year that the State had not enacted or was not enforcing an open container law described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7454e7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after the date of receipt of a certification from a State under subparagraph (A)(i), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7454e8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer the reserved funds identified by the State for use as described in subparagraphs (A) and (B) of paragraph (1) to the apportionment of the State under section 402; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7454e9-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" release the reserved funds identified by the State as described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7454ea-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use for highway safety improvement program","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7454eb-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State may elect to use all or a portion of the funds reserved under paragraph (2) for activities eligible under section 148.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7454ec-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State departments of transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the State makes an election under subparagraph (A), the funds shall be transferred to the department of transportation of the State, which shall be responsible for the administration of the funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7454ed-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out with funds transferred under paragraph (1) or (2), or used under paragraph (3), shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7454ee-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Derivation of amount to be transferred","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount to be transferred or released under paragraph (2) may be derived from the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7454ef-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The apportionment of the State under section 104(b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7454f0-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The apportionment of the State under section 104(b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7454f1-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of obligation authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id2e7454f2-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary transfers under this subsection any funds to the apportionment of a State under section 402 for a fiscal year, the Secretary shall transfer an amount, determined under subparagraph (B), of obligation authority distributed for the fiscal year to the State for Federal-aid highways and highway safety construction programs for carrying out projects under section 402.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id2e7454f3-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of obligation authority referred to in subparagraph (A) shall be determined by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id2e7454f4-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds transferred under subparagraph (A) to the apportionment of the State under section 402 for the fiscal year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id2e7454f5-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the ratio that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id2e7454f6-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of obligation authority distributed for the fiscal year to the State for Federal-aid highways and highway safety construction programs, bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id2e7454f7-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/6/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total of the sums apportioned to the State for Federal-aid highways and highway safety construction programs (excluding sums not subject to any obligation limitation) for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id2e7454f8-3a70-11f1-8334-895c8eef5d79","identifier":"/us/usc/t23/s154/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on applicability of obligation limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, no limitation on the total of obligations for highway safety programs under section 402 shall apply to funds transferred under this subsection to the apportionment of a State under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id2e7454f9-3a70-11f1-8334-895c8eef5d79"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1405/a"},"text":"Pub. L. 105–178, title I, § 1405(a)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9005/a"},"text":