{"tag":"section","attrib":{"id":"id0db073b6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107"},"text":null,"children":[{"tag":"num","attrib":{"value":"30107"},"text":"§ 30107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db073b7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission has the power—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db073b8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require by special or general orders, any person to submit, under oath, such written reports and answers to questions as the Commission may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073b9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer oaths or affirmations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073ba-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require by subpena, signed by the chairman or the vice chairman, the attendance and testimony of witnesses and the production of all documentary evidence relating to the execution of its duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073bb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any proceeding or investigation, to order testimony to be taken by deposition before any person who is designated by the Commission and has the power to administer oaths and, in such instances, to compel testimony and the production of evidence in the same manner as authorized under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073bc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay witnesses the same fees and mileage as are paid in like circumstances in the courts of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073bd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to initiate (through civil actions for injunctive, declaratory, or other appropriate relief), defend (in the case of any civil action brought under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30109/a/8"},"text":"section 30109(a)(8) of this title","children":[],"tail":") or appeal any civil action in the name of the Commission to enforce the provisions of this Act and chapter 95 and chapter 96 of title 26, through its general counsel;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073be-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to render advisory opinions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30108"},"text":"section 30108 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073bf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop such prescribed forms and to make, amend, and repeal such rules, pursuant to the provisions of chapter 5 of title 5, as are necessary to carry out the provisions of this Act and chapter 95 and chapter 96 of title 26; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073c0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct investigations and hearings expeditiously, to encourage voluntary compliance, and to report apparent violations to the appropriate law enforcement authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db073c1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial orders for compliance with subpenas and orders of Commission; contempt of court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon petition by the Commission, any United States district court within the jurisdiction of which any inquiry is being carried on may, in case of refusal to obey a subpena or order of the Commission issued under subsection (a), issue an order requiring compliance. Any failure to obey the order of the court may be punished by the court as a contempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db073c2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil liability for disclosure of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall be subject to civil liability to any person (other than the Commission or the United States) for disclosing information at the request of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db073c3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concurrent transmissions to Congress or Member of budget estimates, etc.; prior submission of legislative recommendations, testimony, or comments on legislation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db073c4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Commission submits any budget estimate or request to the President or the Office of Management and Budget, it shall concurrently transmit a copy of such estimate or request to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db073c5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Commission submits any legislative recommendation, or testimony, or comments on legislation, requested by the Congress or by any Member of the Congress, to the President or the Office of Management and Budget, it shall concurrently transmit a copy thereof to the Congress or to the Member requesting the same. No officer or agency of the United States shall have any authority to require the Commission to submit its legislative recommendations, testimony, or comments on legislation, to any office or agency of the United States for approval, comments, or review, prior to the submission of such recommendations, testimony, or comments to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db073c6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive civil remedy for enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30109/a/8"},"text":"section 30109(a)(8) of this title","children":[],"tail":", the power of the Commission to initiate civil actions under subsection (a)(6) shall be the exclusive civil remedy for the enforcement of the provisions of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db073c7-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s307"},"text":"Pub. L. 92–225, title III, § 307","children":[],"tail":", formerly § 311, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tII/s208/a"},"text":"Pub. L. 93–443, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1282"},"text":"88 Stat. 1282","children":[],"tail":"; renumbered § 310 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI"},"text":"Pub. L. 94–283, title I","children":[],"tail":", §§ 105, 107, 115(b), "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/481"},"text":"90 Stat. 481","children":[],"tail":", 495; renumbered § 307 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI"},"text":"Pub. L. 96–187, title I","children":[],"tail":", §§ 105(3), 106, "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1354"},"text":"93 Stat. 1354","children":[],"tail":", 1356; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db073c8-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db073c9-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db073ca-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (a)(6), (8), and (e), means the Federal Election Campaign Act of 1971, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0db073cb-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s437d"},"text":"section 437d of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section. Some section numbers referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification to this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db073cc-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s307"},"text":"section 307 of Pub. L. 92–225","children":[],"tail":" was renumbered section 305, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30105"},"text":"section 30105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db073cd-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(6), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187/s106"},"text":"Pub. L. 96–187, § 106","children":[],"tail":", in par. (1) substituted “under oath, such written reports and answers to questions as the Commission may prescribe” for “in writing such reports and answers to questions as the Commission may prescribe” and struck out provision that such submission be made within such reasonable time and under oath as determined by the Commission; in par. (4) struck out “of this subsection” after “paragraph (3)”; in par. (6) substituted “section 437g(a)(8)” for “section 437g(a)(9)”, and substituted “to enforce the provisions of this Act” for “for the purpose of enforcing the provisions of this Act”; struck out par. (9) relating to formulation of general policy respecting administration of this Act and chapters 95 and 96 of title 26; and redesignated former par. (10) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187/s106"},"text":"Pub. L. 96–187, § 106","children":[],"tail":", reworded subsec. (b) without substantive changes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187/s106"},"text":"Pub. L. 96–187, § 106","children":[],"tail":", reenacted subsec. (c) without change."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187/s106"},"text":"Pub. L. 96–187, § 106","children":[],"tail":", struck out “of the United States” after “President” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187/s106"},"text":"Pub. L. 96–187, § 106","children":[],"tail":", substituted “section 437g(a)(8)” for “section 437g(a)(9)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s107/b/1"},"text":"Pub. L. 94–283, § 107(b)(1)","children":[],"tail":", substituted “civil actions” for “civil proceedings” and inserted “(in the case of any civil action brought under section 437g(a) (9) of this title)” after “defend” and “and chapter 95 and chapter 96 of title 26” after “this Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s115/b"},"text":"Pub. L. 94–283, § 115(b)","children":[],"tail":", substituted “section 312” for “section 313” in the original to accommodate the renumbering of "},{"tag":"ref","attrib":{"href":"/us/pl/92/225/s313"},"text":"section 313 of Pub. L. 92–225","children":[],"tail":" as "},{"tag":"ref","attrib":{"href":"/us/pl/92/225/s312"},"text":"section 312 of Pub. L. 92–225","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/s105"},"text":"section 105 of Pub. L. 94–283","children":[],"tail":". Since both the original and substituted references translate as “"},{"tag":"ref","attrib":{"href":"/us/usc/t52/s437f"},"text":"section 437f of this title","children":[],"tail":"” no change in text was required."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s107/a/1"},"text":"Pub. L. 94–283, § 107(a)(1)","children":[],"tail":", inserted “to develop such prescribed forms and to” before “to make, amend, and repeal” and inserted “and chapter 95 and chapter 96 of title 26” after “provisions of this Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s107/a/2"},"text":"Pub. L. 94–283, § 107(a)(2)","children":[],"tail":", substituted “and chapter 95 and chapter 96 of title 26; and” for “and sections 608, 610, 611, 613, 614, 615, 616, and 617 of title 18;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s107/a/3"},"text":"Pub. L. 94–283, § 107(a)(3)","children":[],"tail":", redesignated par. (11) as par. (10). Former par. (10), which covered the development of prescribed forms under subsection (a)(1) of this section, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s107/b/2"},"text":"Pub. L. 94–283, § 107(b)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db073ce-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db073cf-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/s301/a"},"text":"section 301(a) of Pub. L. 96–187","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db073d0-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1975-01-01"},"text":"Jan. 1, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/a"},"text":"section 410(a) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
