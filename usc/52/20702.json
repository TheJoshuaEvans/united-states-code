{"tag":"section","attrib":{"id":"id0d98a65b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20702"},"text":null,"children":[{"tag":"num","attrib":{"value":"20702"},"text":"§ 20702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft, destruction, concealment, mutilation, or alteration of records or papers; penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person, whether or not an officer of election or custodian, who willfully steals, destroys, conceals, mutilates, or alters any record or paper required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20701"},"text":"section 20701 of this title","children":[],"tail":" to be retained and preserved shall be fined not more than $1,000 or imprisoned not more than one year, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d98a65c-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/449/tIII/s302"},"text":"Pub. L. 86–449, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-06"},"text":"May 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/88"},"text":"74 Stat. 88","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d98a65d-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d98a65e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d98a65f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children