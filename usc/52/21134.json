{"tag":"section","attrib":{"id":"id0da48db7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21134"},"text":null,"children":[{"tag":"num","attrib":{"value":"21134"},"text":"§ 21134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date; transition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da48db8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter and the amendments made by this subchapter shall take effect upon the appointment of all members of the Election Assistance Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20923"},"text":"section 20923 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da48db9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the consent of the entity involved, the Election Assistance Commission is authorized to utilize the services of such officers, employees, and other personnel of the entities from which functions have been transferred to the Election Assistance Commission under this subchapter or the amendments made by this subchapter for such period of time as may reasonably be needed to facilitate the orderly transfer of such functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da48dba-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on authorities of Office of Election Administration prior to appointment of members of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the period which begins on ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":", and ends on the effective date described in subsection (a), the Office of Election Administration of the Federal Election Commission shall continue to have the authority to carry out any of the functions (including the development of voluntary standards for voting systems and procedures for the certification of voting systems) which it has the authority to carry out as of "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da48dbb-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVIII/s804"},"text":"Pub. L. 107–252, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1726"},"text":"116 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48dbc-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48dbd-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0da48dbe-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a) and (b), was in the original “this title”, meaning title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1725"},"text":"116 Stat. 1725","children":[],"tail":". For complete classification of title VIII to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da48dbf-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15534"},"text":"section 15534 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
