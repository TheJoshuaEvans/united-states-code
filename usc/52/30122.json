{"tag":"section","attrib":{"id":"id0db79fbf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30122"},"text":null,"children":[{"tag":"num","attrib":{"value":"30122"},"text":"§ 30122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions in name of another prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall make a contribution in the name of another person or knowingly permit his name to be used to effect such a contribution, and no person shall knowingly accept a contribution made by one person in the name of another person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db79fc0-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s320"},"text":"Pub. L. 92–225, title III, § 320","children":[],"tail":", formerly § 325, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI/s112/2"},"text":"Pub. L. 94–283, title I, § 112(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/494"},"text":"90 Stat. 494","children":[],"tail":"; renumbered § 320, "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI/s105/5"},"text":"Pub. L. 96–187, title I, § 105(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1354"},"text":"93 Stat. 1354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db79fc1-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db79fc2-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}]