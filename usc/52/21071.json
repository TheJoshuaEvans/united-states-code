{"tag":"section","attrib":{"id":"id0da2438b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071"},"text":null,"children":[{"tag":"num","attrib":{"value":"21071"},"text":"§ 21071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Student and Parent Mock Election","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da2438c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Election Assistance Commission is authorized to award grants to the National Student and Parent Mock Election, a national nonprofit, nonpartisan organization that works to promote voter participation in American elections to enable it to carry out voter education activities for students and their parents. Such activities may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da2438d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include simulated national elections at least 5 days before the actual election that permit participation by students and parents from each of the 50 States in the United States, its territories, the District of Columbia, and United States schools overseas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da2438e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da2438f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school forums and local cable call-in shows on the national issues to be voted upon in an “issues forum”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da24390-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speeches and debates before students and parents by local candidates or stand-ins for such candidates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da24391-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quiz team competitions, mock press conferences, and speech writing competitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da24392-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weekly meetings to follow the course of the campaign; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da24393-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school and neighborhood campaigns to increase voter turnout, including newsletters, posters, telephone chains, and transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da24394-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Student and Parent Mock Election shall present awards to outstanding student and parent mock election projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da24395-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s295"},"text":"Pub. L. 107–252, title II, § 295","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1703"},"text":"116 Stat. 1703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da24396-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da24397-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da24398-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15471"},"text":"section 15471 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
