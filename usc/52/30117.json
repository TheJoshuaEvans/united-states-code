{"tag":"section","attrib":{"id":"id0db55637-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117"},"text":null,"children":[{"tag":"num","attrib":{"value":"30117"},"text":"§ 30117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of certain limits for House candidates in response to personal fund expenditures of opponents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db55638-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of increased limit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db55639-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), if the opposition personal funds amount with respect to a candidate for election to the office of Representative in, or Delegate or Resident Commissioner to, the Congress exceeds $350,000—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db5563a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limit under subsection (a)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002023"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002023"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" with respect to the candidate shall be tripled;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db5563b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limit under subsection (a)(3) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall not apply with respect to any contribution made with respect to the candidate if the contribution is made under the increased limit allowed under subparagraph (A) during a period in which the candidate may accept such a contribution; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db5563c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limits under subsection (d) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" with respect to any expenditure by a State or national committee of a political party on behalf of the candidate shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db5563d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of opposition personal funds amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db5563e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The opposition personal funds amount is an amount equal to the excess (if any) of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db5563f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the greatest aggregate amount of expenditures from personal funds (as defined in subsection (b)(1)) that an opposing candidate in the same election makes; over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db55640-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of expenditures from personal funds made by the candidate with respect to the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db55641-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for candidate’s campaign funds","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db55642-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the aggregate amount of expenditures from personal funds under subparagraph (A), such amount shall include the gross receipts advantage of the candidate’s authorized committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db55643-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gross receipts advantage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of clause (i), the term “gross receipts advantage” means the excess, if any, of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0db55644-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of 50 percent of gross receipts of a candidate’s authorized committee during any election cycle (not including contributions from personal funds of the candidate) that may be expended in connection with the election, as determined on June 30 and December 31 of the year preceding the year in which a general election is held, over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0db55645-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of 50 percent of gross receipts of the opposing candidate’s authorized committee during any election cycle (not including contributions from personal funds of the candidate) that may be expended in connection with the election, as determined on June 30 and December 31 of the year preceding the year in which a general election is held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db55646-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time to accept contributions under increased limit","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db55647-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), a candidate and the candidate’s authorized committee shall not accept any contribution, and a party committee shall not make any expenditure, under the increased limit under paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db55648-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until the candidate has received notification of the opposition personal funds amount under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db55649-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that such contribution, when added to the aggregate amount of contributions previously accepted and party expenditures previously made under the increased limits under this subsection for the election cycle, exceeds 100 percent of the opposition personal funds amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db5564a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of withdrawal of an opposing candidate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A candidate and a candidate’s authorized committee shall not accept any contribution and a party shall not make any expenditure under the increased limit after the date on which an opposing candidate ceases to be a candidate to the extent that the amount of such increased limit is attributable to such an opposing candidate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db5564b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of excess contributions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db5564c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The aggregate amount of contributions accepted by a candidate or a candidate’s authorized committee under the increased limit under paragraph (1) and not otherwise expended in connection with the election with respect to which such contributions relate shall, not later than 50 days after the date of such election, be used in the manner described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db5564d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return to contributors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A candidate or a candidate’s authorized committee shall return the excess contribution to the person who made the contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db5564e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of expenditures from personal funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db5564f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db55650-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of expenditure from personal funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “expenditure from personal funds” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db55651-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expenditure made by a candidate using personal funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db55652-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contribution or loan made by a candidate using personal funds or a loan secured using such funds to the candidate’s authorized committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db55653-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of intent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 15 days after the date on which an individual becomes a candidate for the office of Representative in, or Delegate or Resident Commissioner to, the Congress, the candidate shall file a declaration stating the total amount of expenditures from personal funds that the candidate intends to make, or to obligate to make, with respect to the election that will exceed $350,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db79f44-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 24 hours after a candidate described in subparagraph (B) makes or obligates to make an aggregate amount of expenditures from personal funds in excess of $350,000 in connection with any election, the candidate shall file a notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db79f45-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a candidate files an initial notification under subparagraph (C), the candidate shall file an additional notification each time expenditures from personal funds are made or obligated to be made in an aggregate amount that exceeds $10,000. Such notification shall be filed not later than 24 hours after the expenditure is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db79f46-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification under subparagraph (C) or (D) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db79f47-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the candidate and the office sought by the candidate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db79f48-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and amount of each expenditure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db79f49-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of expenditures from personal funds that the candidate has made, or obligated to make, with respect to an election as of the date of the expenditure that is the subject of the notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db79f4a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Place of filing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each declaration or notification required to be filed by a candidate under subparagraph (C), (D), or (E) shall be filed with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0db79f4b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0db79f4c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each candidate in the same election and the national party of each such candidate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db79f4d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of disposal of excess contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the next regularly scheduled report after the date of the election for which a candidate seeks nomination for election to, or election to, Federal office, the candidate or the candidate’s authorized committee shall submit to the Commission a report indicating the source and amount of any excess contributions (as determined under subsection (a)) and the manner in which the candidate or the candidate’s authorized committee used such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db79f4e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30117/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For provisions providing for the enforcement of the reporting requirements under this subsection, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30109"},"text":"section 30109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db79f4f-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s315A"},"text":"Pub. L. 92–225, title III, § 315A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII/s319/a"},"text":"Pub. L. 107–155, title III, § 319(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/109"},"text":"116 Stat. 109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db79f50-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db79f51-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db79f52-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (a)(1)(A), (3), and (d), referred to in subsec. (a)(1), probably mean subsections (a)(1)(A), (3), and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30116"},"text":"section 30116 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0db79f53-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s441a–1"},"text":"section 441a–1 of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"id0db79f54-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s315A"},"text":"section 315A of Pub. L. 92–225","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/s319/a"},"text":"section 319(a) of Pub. L. 107–155","children":[],"tail":", see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db79f55-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db79f56-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", but not applicable with respect to runoff elections, recounts, or election contests resulting from elections held prior to "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/s402"},"text":"section 402 of Pub. L. 107–155","children":[],"tail":", set out as an Effective Date of 2002 Amendment; Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
