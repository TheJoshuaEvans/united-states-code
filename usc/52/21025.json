{"tag":"section","attrib":{"id":"id0da24322-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21025"},"text":null,"children":[{"tag":"num","attrib":{"value":"21025"},"text":"§ 21025.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da24323-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21025/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" 6 months after the end of each fiscal year for which an eligible State or eligible unit of local government received a payment under this subpart, the State or unit shall submit a report to the Secretary on the activities conducted with the funds provided during the year, and shall include in the report a list of expenditures made with respect to each category of activities described in "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21021/b"},"text":"section 21021(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da24324-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21025/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary to Committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each fiscal year for which the Secretary makes payments under this subpart, the Secretary shall submit a report on the activities carried out under this subpart to the Committee on House Administration of the House of Representatives and the Committee on Rules and Administration of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da24325-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s265"},"text":"Pub. L. 107–252, title II, § 265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1699"},"text":"116 Stat. 1699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da24326-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da24327-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da24328-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15425"},"text":"section 15425 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
