{"tag":"section","attrib":{"id":"id0da48d48-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21084"},"text":null,"children":[{"tag":"num","attrib":{"value":"21084"},"text":"§ 21084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The requirements established by this subchapter are minimum requirements and nothing in this subchapter shall be construed to prevent a State from establishing election technology and administration requirements that are more strict than the requirements established under this subchapter so long as such State requirements are not inconsistent with the Federal requirements under this subchapter or any law described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21145"},"text":"section 21145 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0da48d49-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIII/s305"},"text":"Pub. L. 107–252, title III, § 305","children":[],"tail":", formerly § 304, "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1714"},"text":"116 Stat. 1714","children":[],"tail":"; renumbered § 305, "},{"tag":"ref","attrib":{"href":"/us/pl/118/106/s2/a/1"},"text":"Pub. L. 118–106, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-04"},"text":"Oct. 4, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1591"},"text":"138 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48d4a-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48d4b-2931-11f1-afae-ea39e71ac6b0"},"text":null,"c