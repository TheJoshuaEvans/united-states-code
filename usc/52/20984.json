{"tag":"section","attrib":{"id":"id0d9fd230-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984"},"text":null,"children":[{"tag":"num","attrib":{"value":"20984"},"text":"§ 20984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on voters who register by mail and use of Social Security information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd231-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration by mail","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd232-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9fd233-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall conduct a study of the impact of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/b"},"text":"section 21083(b) of this title","children":[],"tail":" on voters who register by mail."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9fd234-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific issues studied","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study conducted under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9fd235-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of the impact of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/b"},"text":"section 21083(b) of this title","children":[],"tail":" on first time mail registrant voters who vote in person, including the impact of such section on voter registration;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9fd236-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of the impact of such section on the accuracy of voter rolls, including preventing ineligible names from being placed on voter rolls and ensuring that all eligible names are placed on voter rolls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9fd237-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the impact of such section on existing State practices, such as the use of signature verification or attestation procedures to verify the identity of voters in elections for Federal office, and an analysis of other changes that may be made to improve the voter registration process, such as verification or additional information on the registration card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd238-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date on which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/b/2"},"text":"section 21083(b)(2) of this title","children":[],"tail":" takes effect, the Commission shall submit a report to the President and Congress on the study conducted under paragraph (1)(A) together with such recommendations for administrative and legislative action as the Commission determines is appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd239-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20984/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Social Security information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the date on which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/a/5"},"text":"section 21083(a)(5) of this title","children":[],"tail":" takes effect, the Commission, in consultation with the Commissioner of Social Security, shall study and report to Congress on the feasibility and advisability of using Social Security identification numbers or other information compiled by the Social Security Administration to establish voter registration or other election law eligibility or identification requirements, including the matching of relevant information specific to an individual voter, the impact of such use on national security issues, and whether adequate safeguards or waiver procedures exist to protect the privacy of an individual voter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd23a-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s244"},"text":"Pub. L. 107–252, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1689"},"text":"116 Stat. 1689","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd23b-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd23c-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d9fd23d-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective dates of subsecs. (a)(5) and (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083"},"text":"section 21083 of this title","children":[],"tail":", referred to in subsecs. (a)(2) and (b), see "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/d"},"text":"section 21083(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd23e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15384"},"text":"section 15384 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
