{"tag":"section","attrib":{"id":"id0da48d93-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21122"},"text":null,"children":[{"tag":"num","attrib":{"value":"21122"},"text":"§ 21122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities under Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da48d94-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Program, the Commission (in consultation with the chief election official of each State) shall develop materials, sponsor seminars and workshops, engage in advertising targeted at students, make grants, and take such other actions as it considers appropriate to meet the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21121/b"},"text":"section 21121(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da48d95-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for grant recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under the Program, the Commission shall ensure that the funds provided are spent for projects and activities which are carried out without partisan bias or without promoting any particular point of view regarding any issue, and that each recipient is governed in a balanced manner which does not reflect any partisan bias.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da48d96-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with institutions of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall encourage institutions of higher education (including community colleges) to participate in the Program, and shall make all necessary materials and other assistance (including materials and assistance to enable the institution to hold workshops and poll worker training sessions) available without charge to any institution which desires to participate in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da48d97-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tV/s502"},"text":"Pub. L. 107–252, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1717"},"text":"116 Stat. 1717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48d98-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48d99-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da48d9a-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15522"},"text":"section 15522 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
