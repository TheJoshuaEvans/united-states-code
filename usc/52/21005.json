{"tag":"section","attrib":{"id":"id0d9fd2d3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21005"},"text":null,"children":[{"tag":"num","attrib":{"value":"21005"},"text":"§ 21005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for development and filing of plan; publication by Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd2d4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief State election official shall develop the State plan under this part through a committee of appropriate individuals, including the chief election officials of the two most populous jurisdictions within the States, other local election officials, stake holders (including representatives of groups of individuals with disabilities), and other citizens, appointed for such purpose by the chief State election official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd2d5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of plan by Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After receiving the State plan of a State under this part, the Commission shall cause to have the plan posted on the Commission’s website with a notice published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd2d6-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s255"},"text":"Pub. L. 107–252, title II, § 255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1697"},"text":"116 Stat. 1697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dC/tVI/s622/1"},"text":"Pub. L. 112–74, div. C, title VI, § 622(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/926"},"text":"125 Stat. 926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd2d7-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd2d8-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd2d9-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15405"},"text":"section 15405 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d9fd2da-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" inserted “posted on the Commission’s website with a notice” after “cause to have the plan”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
