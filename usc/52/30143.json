{"tag":"section","attrib":{"id":"id0dba112a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30143"},"text":null,"children":[{"tag":"num","attrib":{"value":"30143"},"text":"§ 30143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws affected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dba112b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the provisions of this Act, and of rules prescribed under this Act, supersede and preempt any provision of State law with respect to election to Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dba112c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local committees of political parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this Act, a State or local committee of a political party may, subject to State law, use exclusively funds that are not subject to the prohibitions, limitations, and reporting requirements of the Act for the purchase or construction of an office building for such State or local committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dba112d-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIV/s403"},"text":"Pub. L. 92–225, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/20"},"text":"86 Stat. 20","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIII/s301"},"text":"Pub. L. 93–443, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1289"},"text":"88 Stat. 1289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/tI/s103/b/2"},"text":"Pub. L. 107–155, title I, § 103(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/87"},"text":"116 Stat. 87","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dba112e-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dba112f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0dba1130-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means the Federal Election Campaign Act of 1971, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0dba1131-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s453"},"text":"section 453 of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dba1132-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155"},"text":"Pub. L. 107–155","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “Subject to subsection (b), the provisions of this Act” for “The provisions of this Act”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" substituted provision for "},{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":" and rules thereunder to supersede and preempt any provision of State law with respect to election to Federal office for prior provisions which in former subsec. (a) stated that nothing in "},{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":" shall be deemed to invalidate or make inapplicable any provision of State law, except where compliance with such provision would result in a violation of "},{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":" and in former subsec. (b) stated that no provision of State law shall be construed to prohibit any person from taking any action authorized by "},{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":" or from making any expenditure which he could lawfully make under "},{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":