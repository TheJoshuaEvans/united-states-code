{"tag":"section","attrib":{"id":"id0d965c66-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503"},"text":null,"children":[{"tag":"num","attrib":{"value":"20503"},"text":"§ 20503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National procedures for voter registration for elections for Federal office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d965c67-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), notwithstanding any other Federal or State law, in addition to any other method of voter registration provided for under State law, each State shall establish procedures to register to vote in elections for Federal office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c68-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by application made simultaneously with an application for a motor vehicle driver’s license pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20504"},"text":"section 20504 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c69-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by mail application pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20505"},"text":"section 20505 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c6a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by application in person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d965c6b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the appropriate registration site designated with respect to the residence of the applicant in accordance with State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965c6c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a Federal, State, or nongovernmental office designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20506"},"text":"section 20506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c6d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability to certain States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to a State described in either or both of the following paragraphs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c6e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State in which, under law that is in effect continuously on and after ","children":[{"tag":"date","attrib":{"date":"1994-08-01"},"text":"August 1, 1994","children":[],"tail":", there is no voter registration requirement for any voter in the State with respect to an election for Federal office."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c6f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State in which, under law that is in effect continuously on and after ","children":[{"tag":"date","attrib":{"date":"1994-08-01"},"text":"August 1, 1994","children":[],"tail":", or that was enacted on or prior to "},{"tag":"date","attrib":{"date":"1994-08-01"},"text":"August 1, 1994","children":[],"tail":", and by its terms is to come into effect upon the enactment of this chapter, so long as that law remains in effect, all voters in the State may register to vote at the polling place at the time of voting in a general election for Federal office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d965c70-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31/s4"},"text":"Pub. L. 103–31, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/78"},"text":"107 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/91/tI/s101/a"},"text":"Pub. L. 104–91, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/11"},"text":"110 Stat. 11","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/99/tII/s211"},"text":"Pub. L. 104–99, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-26"},"text":"Jan. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/37"},"text":"110 Stat. 37","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d965c71-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d965c72-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d965c73-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Upon the enactment of this chapter, referred to in subsec. (b)(2), means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31"},"text":"Pub. L. 103–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d965c74-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg–2"},"text":"section 1973gg–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/91"},"text":"Pub. L. 104–91","children":[],"tail":" is based on section 116(a) of H.R. 2076, One Hundred Fourth Congress, as passed by the House of Representatives on "},{"tag":"date","attrib":{"date":"1995-12-06"},"text":"Dec. 6, 1995","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/104/91"},"text":"Pub. L. 104–91","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d965c75-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/91"},"text":"Pub. L. 104–91","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/99"},"text":"Pub. L. 104–99","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1994-08-01"},"text":"August 1, 1994","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1993-03-11"},"text":"March 11, 1993","children":[],"tail":"” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d965c76-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d965c77-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 116(b) of H.R. 2076, One Hundred Fourth Congress, as passed by the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"1995-12-06"},"text":"Dec. 6, 1995","children":[],"tail":", and as enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/104/91/tI/s101/a"},"text":"Pub. L. 104–91, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/11"},"text":"110 Stat. 11","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/99/tII/s211"},"text":"Pub. L. 104–99, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-26"},"text":"Jan. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/37"},"text":"110 Stat. 37","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/99/tII/s211"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect as if included in the provisions of the National Voter Registration Act of 1993 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31"},"text":"Pub. L. 103–31","children":[],"tail":", see Tables for classification].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
