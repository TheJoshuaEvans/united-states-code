{"tag":"section","attrib":{"id":"id0d98a61c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508"},"text":null,"children":[{"tag":"num","attrib":{"value":"20508"},"text":"§ 20508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal coordination and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d98a61d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Election Assistance Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d98a61e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the chief election officers of the States, shall prescribe such regulations as are necessary to carry out paragraphs (2) and (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a61f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the chief election officers of the States, shall develop a mail voter registration application form for elections for Federal office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a620-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than June 30 of each odd-numbered year, shall submit to the Congress a report assessing the impact of this chapter on the administration of elections for Federal office during the preceding 2-year period and including recommendations for improvements in Federal and State procedures, forms, and other matters affected by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a621-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide information to the States with respect to the responsibilities of the States under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d98a622-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of mail voter registration form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mail voter registration form developed under subsection (a)(2)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d98a623-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require only such identifying information (including the signature of the applicant) and other information (including data relating to previous registration by the applicant), as is necessary to enable the appropriate State election official to assess the eligibility of the applicant and to administer voter registration and other parts of the election process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a624-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include a statement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d98a625-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies each eligibility requirement (including citizenship);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d98a626-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an attestation that the applicant meets each such requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d98a627-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the signature of the applicant, under penalty of perjury;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a628-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not include any requirement for notarization or other formal authentication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a629-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include, in print that is identical to that used in the attestation portion of the application—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d98a62a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/4/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required in section 20507(a)(5)(A) and (B) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d98a62b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/4/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that, if an applicant declines to register to vote, the fact that the applicant has declined to register will remain confidential and will be used only for voter registration purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d98a62c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20508/b/4/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that if an applicant does register to vote, the office at which the applicant submits a voter registration application will remain confidential and will be used only for voter registration purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d98a62d-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31/s9"},"text":"Pub. L. 103–31, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/87"},"text":"107 Stat. 87","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVIII/s802/b"},"text":"Pub. L. 107–252, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1726"},"text":"116 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d98a62e-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d98a62f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d98a630-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg–7"},"text":"section 1973gg–7 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d98a631-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":" substituted “Election Assistance Commission” for “Federal Election Commission” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d98a632-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d98a633-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":" effective upon appointment of all members of the Election Assistance Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20923"},"text":"section 20923 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21134/a"},"text":"section 21134(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
