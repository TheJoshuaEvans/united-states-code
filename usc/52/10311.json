{"tag":"section","attrib":{"id":"id0d8a4e48-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10311"},"text":null,"children":[{"tag":"num","attrib":{"value":"10311"},"text":"§ 10311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impairment of voting rights of persons holding current registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in chapters 103 to 107 of this title shall be construed to deny, impair, or otherwise adversely affect the right to vote of any person registered to vote under the law of any State or political subdivision.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8a4e49-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110/tI/s17"},"text":"Pub. L. 89–110, title I, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-06"},"text":"Aug. 6, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/446"},"text":"79 Stat. 446","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/91/285/s2"},"text":"Pub. L. 91–285, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-22"},"text":"June 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/314"},"text":"84 Stat. 314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8a4e4a-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8a4e4b-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8a4e4c-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973n"},"text":"section 1973n of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
