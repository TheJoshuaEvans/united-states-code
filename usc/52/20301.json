{"tag":"section","attrib":{"id":"id0d8f3028-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301"},"text":null,"children":[{"tag":"num","attrib":{"value":"20301"},"text":"§ 20301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8f3029-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential designee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate the head of an executive department to have primary responsibility for Federal functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8f302a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Presidential designee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Presidential designee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8f302b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult State and local election officials in carrying out this chapter, and ensure that such officials are aware of the requirements of this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f302c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe an official post card form, containing both an absentee voter registration application and an absentee ballot application, for use by the States as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20302/a/4"},"text":"section 20302(a)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f302d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20303"},"text":"section 20303 of this title","children":[],"tail":" with respect to the Federal write-in absentee ballot for absent uniformed services voters and overseas voters in general elections for Federal office;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f302e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe a suggested design for absentee ballot mailing envelopes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f302f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile and distribute (A) descriptive material on State absentee registration and voting procedures, and (B) to the extent practicable, facts relating to specific elections, including dates, offices involved, and the text of ballot questions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f3030-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the end of each year after a Presidential election year, transmit to the President and the Congress a report on the effectiveness of assistance under this chapter, including a statistical analysis of uniformed services voter participation, a separate statistical analysis of overseas nonmilitary participation, and a description of State-Federal cooperation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f3031-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe a standard oath for use with any document under this chapter affirming that a material misstatement of fact in the completion of such a document may constitute grounds for a conviction for perjury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f3032-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20304"},"text":"section 20304 of this title","children":[],"tail":" with respect to the collection and delivery of marked absentee ballots of absent overseas uniformed services voters in elections for Federal office;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f3033-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the greatest extent practicable, take such actions as may be necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8f3034-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that absent uniformed services voters who cast absentee ballots at locations or facilities under the jurisdiction of the Presidential designee are able to do so in a private and independent manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8f3035-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the privacy of the contents of absentee ballots cast by absentee uniformed services voters and overseas voters while such ballots are in the possession or control of the Presidential designee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f3036-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20305"},"text":"section 20305 of this title","children":[],"tail":" with respect to Federal Voting Assistance Program Improvements; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f3037-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" working with the Election Assistance Commission and the chief State election official of each State, develop standards—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8f3038-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for States to report data on the number of absentee ballots transmitted and received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20302/c"},"text":"section 20302(c) of this title","children":[],"tail":" and such other data as the Presidential designee determines appropriate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8f3039-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/b/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Presidential designee to store the data reported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8f303a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of other Federal officials","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8f303b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Government department, agency, or other entity shall, upon request of the Presidential designee, distribute balloting materials and otherwise cooperate in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f303c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator of General Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As directed by the Presidential designee, the Administrator of General Services shall furnish official post card forms (prescribed under subsection (b)) and Federal write-in absentee ballots (prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20303"},"text":"section 20303 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8f303d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for carrying out Federal Voting Assistance Program Improvements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Presidential designee such sums as are necessary for purposes of carrying out subsection (b)(10).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8f303e-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410/tI/s101"},"text":"Pub. L. 99–410, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/924"},"text":"100 Stat. 924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG/tXXII/s2219/c"},"text":"Pub. L. 105–277, div. G, title XXII, § 2219(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-817"},"text":"112 Stat. 2681–817","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXVI/s1606/a/2"},"text":"Pub. L. 107–107, div. A, title XVI, § 1606(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1279"},"text":"115 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVII/s705/a"},"text":"Pub. L. 107–252, title VII, § 705(a)","children":[],"tail":", (b)(1), (c), "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1724"},"text":"116 Stat. 1724","children":[],"tail":", 1725; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s566/a"},"text":"Pub. L. 108–375, div. A, title V, § 566(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1919"},"text":"118 Stat. 1919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV"},"text":"Pub. L. 111–84, div. A, title V","children":[],"tail":", §§ 580(b), (e), 583(a)(2), 584(a), 585(b)(1), "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2325"},"text":"123 Stat. 2325","children":[],"tail":", 2328, 2330, 2331; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/d/4"},"text":"Pub. L. 111–383, div. A, title X, § 1075(d)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4372"},"text":"124 Stat. 4372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8f303f-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8f3040-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d8f3041-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Pub. L. 99–410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/924"},"text":"100 Stat. 924","children":[],"tail":", known as the Uniformed and Overseas Citizens Absentee Voting Act, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8f3042-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff"},"text":"section 1973ff of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification to this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d8f3043-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2), (4), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/d/4"},"text":"Pub. L. 111–383, § 1075(d)(4)","children":[],"tail":", (5), amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":", §§ 584(a), 585(b)(1). See 2009 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s585/b/1/A"},"text":"Pub. L. 111–84, § 585(b)(1)(A)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/d/5"},"text":"Pub. L. 111–383, § 1075(d)(5)","children":[],"tail":", substituted “section 1973ff–1(a)(4)” for “section 1973ff–1(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s585/b/1/B"},"text":"Pub. L. 111–84, § 585(b)(1)(B)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/d/5"},"text":"Pub. L. 111–383, § 1075(d)(5)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “prescribe a suggested design for absentee ballot mailing envelopes for use by the States as recommended in "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s1973ff–3"},"text":"section 1973ff–3 of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s580/b"},"text":"Pub. L. 111–84, § 580(b)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s580/e"},"text":"Pub. L. 111–84, § 580(e)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s583/a/2/A"},"text":"Pub. L. 111–84, § 583(a)(2)(A)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s584/a"},"text":"Pub. L. 111–84, § 584(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/d/4"},"text":"Pub. L. 111–383, § 1075(d)(4)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s583/a/2/B"},"text":"Pub. L. 111–84, § 583(a)(2)(B)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “absent uniformed services voters and overseas voters” for “overseas voters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/s705/a"},"text":"Pub. L. 107–252, § 705(a)","children":[],"tail":", inserted “, and ensure that such officials are aware of the requirements of this Act” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/s705/c"},"text":"Pub. L. 107–252, § 705(c)","children":[],"tail":", substituted “a separate statistical analysis” for “a general assessment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/s705/b/1"},"text":"Pub. L. 107–252, § 705(b)(1)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “as required under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s1973ff–1/4"},"text":"section 1973ff–1(4) of this title","children":[],"tail":"” for “as recommended in "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s1973ff–3"},"text":"section 1973ff–3 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “of uniformed services voter participation, a general assessment of overseas nonmilitary participation,” for “of voter participation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8f3044-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d8f3045-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/d"},"text":"Pub. L. 111–383, div. A, title X, § 1075(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4372"},"text":"124 Stat. 4372","children":[],"tail":", provided that the amendment by section 1075(d)(4), (5) is effective as of "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d8f3046-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s580/f"},"text":"Pub. L. 111–84, div. A, title V, § 580(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2326"},"text":"123 Stat. 2326","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tV/s580/f"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20304"},"text":"section 20304 of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20302"},"text":"section 20302 of this title","children":[],"tail":"] shall apply with respect to the regularly scheduled general election for Federal office held in November 2010 and each succeeding election for Federal office.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s583/a/3"},"text":"Pub. L. 111–84, div. A, title V, § 583(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2328"},"text":"123 Stat. 2328","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tV/s583/a/3"},"text":"“The amendments made by this subsection [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20305"},"text":"section 20305 of this title","children":[],"tail":" and amending this section] shall apply with respect to the regularly scheduled general election for Federal office held in November 2010 and each succeeding election for Federal office.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s584/c"},"text":"Pub. L. 111–84, div. A, title V, § 584(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2331"},"text":"123 Stat. 2331","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/84/dA/tV/s584/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20302"},"text":"section 20302 of this title","children":[],"tail":"] shall apply with respect to the regularly scheduled general election for Federal office held in November 2010 and each succeeding election for Federal office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8f3047-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410/tII/s204"},"text":"Pub. L. 99–410, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/930"},"text":"100 Stat. 930","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/410/tII/s204"},"text":"“The amendments and repeals made by this Act [see Tables for classification] shall apply with respect to elections taking place after ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d8f3048-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress Regarding the Importance of Voting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXVI/s1601"},"text":"Pub. L. 107–107, div. A, title XVI, § 1601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1274"},"text":"115 Stat. 1274","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tXVI/s1601"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that each person who is an administrator of a Federal, State, or local election—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should be aware of the importance of the ability of each uniformed services voter to exercise the right to vote; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" should perform that person’s duties as an election administrator with the intent to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each uniformed services voter receives the utmost consideration and cooperation when voting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each valid ballot cast by such a voter is duly counted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all eligible American voters, regardless of race, ethnicity, disability, the language they speak, or the resources of the community in which they live, should have an equal opportunity to cast a vote and to have that vote counted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniformed Services Voter Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘uniformed services voter’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a uniformed service (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/5"},"text":"section 101(a)(5) of title 10","children":[],"tail":", United States Code) in active service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the merchant marine (as defined in section 107 of the Uniformed and Overseas Citizens Absentee Voting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff–6"},"text":"42 U.S.C. 1973ff–6","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20310"},"text":"52 U.S.C. 20310","children":[],"tail":"]); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a spouse or dependent of a member referred to in paragraph (1) or (2) who is qualified to vote.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d8f3049-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Electronic Voting Demonstration Project","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXVI/s1604"},"text":"Pub. L. 107–107, div. A, title XVI, § 1604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1277"},"text":"115 Stat. 1277","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s567"},"text":"Pub. L. 108–375, div. A, title V, § 567","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1919"},"text":"118 Stat. 1919","children":[],"tail":", which established a demonstration project under which absent uniformed services voters were permitted to vote in the November 2002 general election for Federal office through an electronic voting system, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s593"},"text":"Pub. L. 113–291, div. A, title V, § 593","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3395"},"text":"128 Stat. 3395","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0d8f304a-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Governors’ Reports on Implementation of Recommendations for Changes in State Law Made Under Federal Voting Assistance Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXVI/s1605"},"text":"Pub. L. 107–107, div. A, title XVI, § 1605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1277"},"text":"115 Stat. 1277","children":[],"tail":", required the chief executive authority of a State to provide an implementation status report to the Secretary of Defense, acting as the Presidential designee, within 90 days of receiving a uniformed services voting assistance legislative recommendation from the Secretary of Defense and was applicable to any uniformed services voting assistance legislative recommendation transmitted to a state during the three-year period beginning on "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id0d8f304b-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id0d8f304c-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12642. Designation of Secretary of Defense as Presidential Designee","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12642, ","children":[{"tag":"date","attrib":{"date":"1988-06-08"},"text":"June 8, 1988","children":[],"tail":", 53 F.R. 21975, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me as President by the Constitution and laws of the United States of America, including section 101(a) of the Uniformed and Overseas Citizens Absentee Voting Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Public Law 99–410","children":[],"tail":") (“the Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301/a"},"text":"52 U.S.C. 20301(a)","children":[],"tail":"], it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. The Secretary of Defense is hereby designated as the “Presidential designee” under Title I of the Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"52 U.S.C. 20301","children":[],"tail":" et seq.]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. In order to effectuate the purposes of the Act, the Secretary of Defense is hereby authorized to delegate any or all of the functions, responsibilities, powers, authority, or discretion devolving upon him in consequence of this Order to any person or persons within the Department of Defense."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Ronald Reagan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
