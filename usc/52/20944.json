{"tag":"section","attrib":{"id":"id0d9d616d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944"},"text":null,"children":[{"tag":"num","attrib":{"value":"20944"},"text":"§ 20944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Board of Advisors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9d616e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Advisors shall be composed of 37 members appointed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d616f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the National Governors Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6170-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the National Conference of State Legislatures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6171-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the National Association of Secretaries of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6172-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the National Association of State Election Directors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6173-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the National Association of Counties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6174-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the National Association of County Recorders, Election Administrators, and Clerks.","children":[{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “National Association of County Recorders, Election Officials and Clerks.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6175-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the United States Conference of Mayors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6176-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the Election Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6177-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the International Association of County Recorders, Election Officials, and Treasurers.","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “International Association of Clerks, Recorders, Election Officials and Treasurers.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6178-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the United States Commission on Civil Rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6179-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members appointed by the Architectural and Transportation Barrier ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “Barriers”."}],"tail":" Compliance Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s792"},"text":"section 792 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d617a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief of the Office of Public Integrity of the Department of Justice,","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably means the Public Integrity Section of the Criminal Division of the Department of Justice."}],"tail":" or the chief’s designee."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d617b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief of the Voting Section of the Civil Rights Division of the Department of Justice or the chief’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d617c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The director of the Federal Voting Assistance Program of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d617d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Four members representing professionals in the field of science and technology, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d617e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one each shall be appointed by the Speaker and the Minority Leader of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d617f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one each shall be appointed by the Majority Leader and the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6180-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eight members representing voter interests, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d6181-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members shall be appointed by the Committee on House Administration of the House of Representatives, of whom two shall be appointed by the chair and two shall be appointed by the ranking minority member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6182-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/a/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four members shall be appointed by the Committee on Rules and Administration of the Senate, of whom two shall be appointed by the chair and two shall be appointed by the ranking minority member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d6183-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointments shall be made to the Board of Advisors under subsection (a) in a manner which ensures that the Board of Advisors will be bipartisan in nature and will reflect the various geographic regions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d6184-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service; vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board of Advisors shall serve for a term of 2 years, and may be reappointed. Any vacancy in the Board of Advisors shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d6185-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20944/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Advisors shall elect a Chair from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9d6186-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s214"},"text":"Pub. L. 107–252, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1680"},"text":"116 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9d6187-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9d6188-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9d6189-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15344"},"text":"section 15344 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
