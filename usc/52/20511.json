{"tag":"section","attrib":{"id":"id0d98a648-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511"},"text":null,"children":[{"tag":"num","attrib":{"value":"20511"},"text":"§ 20511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person, including an election official, who in any election for Federal office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d98a649-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly and willfully intimidates, threatens, or coerces, or attempts to intimidate, threaten, or coerce, any person for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d98a64a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registering to vote, or voting, or attempting to register or vote;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d98a64b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urging or aiding any person to register to vote, to vote, or to attempt to register or vote; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d98a64c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercising any right under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d98a64d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly and willfully deprives, defrauds, or attempts to deprive or defraud the residents of a State of a fair and impartially conducted election process, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d98a64e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement or submission of voter registration applications that are known by the person to be materially false, fictitious, or fraudulent under the laws of the State in which the election is held; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d98a64f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20511/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement, casting, or tabulation of ballots that are known by the person to be materially false, fictitious, or fraudulent under the laws of the State in which the election is held,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined in accordance with title 18 (which fines shall be paid into the general fund of the Treasury, miscellaneous receipts (pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":"), notwithstanding any other law), or imprisoned not more than 5 years, or both."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d98a650-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31/s12"},"text":"Pub. L. 103–31, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/88"},"text":"107 Stat. 88","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d98a651-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d98a652-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d98a653-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg–10"},"text":"section 1973gg–10 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
