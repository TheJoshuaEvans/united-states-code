{"tag":"section","attrib":{"id":"id0d965c95-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505"},"text":null,"children":[{"tag":"num","attrib":{"value":"20505"},"text":"§ 20505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mail registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d965c96-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c97-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State shall accept and use the mail voter registration application form prescribed by the Federal Election Commission pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20508/a/2"},"text":"section 20508(a)(2) of this title","children":[],"tail":" for the registration of voters in elections for Federal office."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c98-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to accepting and using the form described in paragraph (1), a State may develop and use a mail voter registration form that meets all of the criteria stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20508/b"},"text":"section 20508(b) of this title","children":[],"tail":" for the registration of voters in elections for Federal office."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c99-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A form described in paragraph (1) or (2) shall be accepted and used for notification of a registrant’s change of address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c9a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief State election official of a State shall make the forms described in subsection (a) available for distribution through governmental and private entities, with particular emphasis on making them available for organized voter registration programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c9b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First-time voters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c9c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), a State may by law require a person to vote in person if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d965c9d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person was registered to vote in a jurisdiction by mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965c9e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has not previously voted in that jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c9f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) does not apply in the case of a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d965ca0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is entitled to vote by absentee ballot under the Uniformed and Overseas Citizens Absentee Voting Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"52 U.S.C. 20301","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965ca1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is provided the right to vote otherwise than in person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20102/b/2/B/ii"},"text":"section 20102(b)(2)(B)(ii) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965ca2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is entitled to vote otherwise than in person under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965ca3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undelivered notices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a notice of the disposition of a mail voter registration application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20507/a/2"},"text":"section 20507(a)(2) of this title","children":[],"tail":" is sent by nonforwardable mail and is returned undelivered, the registrar may proceed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20507/d"},"text":"section 20507(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d965ca4-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31/s6"},"text":"Pub. L. 103–31, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/79"},"text":"107 Stat. 79","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d965ca5-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d965ca6-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d965ca7-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniformed and Overseas Citizens Absentee Voting Act, referred to in subsec. (c)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Pub. L. 99–410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/924"},"text":"100 Stat. 924","children":[],"tail":", which is classified principally to chapter 203 (§ 20301 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d965ca8-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg–4"},"text":"section 1973gg–4 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
