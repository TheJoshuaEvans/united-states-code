{"tag":"section","attrib":{"id":"id0d9fd280-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002"},"text":null,"children":[{"tag":"num","attrib":{"value":"21002"},"text":"§ 21002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd281-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the amount of a requirements payment made to a State for a year shall be equal to the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd282-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount appropriated for requirements payments for the year pursuant to the authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21007"},"text":"section 21007 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd283-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State allocation percentage for the State (as determined under subsection (b)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd284-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allocation percentage defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The “State allocation percentage” for a State is the amount (expressed as a percentage) equal to the quotient of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd285-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voting age population of the State (as reported in the most recent decennial census); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd286-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total voting age population of all States (as reported in the most recent decennial census).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd287-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a requirements payment made to a State for a year may not be less than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd288-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any of the several States or the District of Columbia, one-half of 1 percent of the total amount appropriated for requirements payments for the year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21007"},"text":"section 21007 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd289-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Commonwealth of Puerto Rico, Guam, American Samoa, or the United States Virgin Islands, one-tenth of 1 percent of such total amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd28a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Commission”."}],"tail":" shall make such pro rata reductions to the allocations determined under subsection (a) as are necessary to comply with the requirements of subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd28b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing availability of funds after appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A requirements payment made to a State under this subpart shall be available to the State without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd28c-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s252"},"text":"Pub. L. 107–252, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1693"},"text":"116 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd28d-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd28e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd28f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15402"},"text":"section 15402 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
