{"tag":"section","attrib":{"id":"id0db2e58b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114"},"text":null,"children":[{"tag":"num","attrib":{"value":"30114"},"text":"§ 30114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of contributed amounts for certain purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db2e58c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contribution accepted by a candidate, and any other donation received by an individual as support for activities of the individual as a holder of Federal office, may be used by the candidate or individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db2e58d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for otherwise authorized expenditures in connection with the campaign for Federal office of the candidate or individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e58e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for ordinary and necessary expenses incurred in connection with duties of the individual as a holder of Federal office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e58f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for contributions to an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c"},"text":"section 170(c) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e590-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for transfers, without limitation, to a national, State, or local committee of a political party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e591-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for donations to State and local candidates subject to the provisions of State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e592-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other lawful purpose unless prohibited by subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db2e593-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited use","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db2e594-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contribution or donation described in subsection (a) shall not be converted by any person to personal use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e595-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of paragraph (1), a contribution or donation shall be considered to be converted to personal use if the contribution or amount is used to fulfill any commitment, obligation, or expense of a person that would exist irrespective of the candidate’s election campaign or individual’s duties as a holder of Federal office, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db2e596-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a home mortgage, rent, or utility payment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e597-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clothing purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e598-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noncampaign-related automobile expense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e599-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country club membership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e59a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vacation or other noncampaign-related trip;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e59b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a household food item;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e59c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tuition payment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e59d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admission to a sporting event, concert, theater, or other form of entertainment not associated with an election campaign; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e59e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dues, fees, and other payments to a health club or recreational facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db2e59f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of campaign funds for flights on noncommercial aircraft","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db2e5a0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this Act, a candidate for election for Federal office (other than a candidate who is subject to paragraph (2)), or any authorized committee of such a candidate, may not make any expenditure for a flight on an aircraft unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db2e5a1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is operated by an air carrier or commercial operator certificated by the Federal Aviation Administration and the flight is required to be conducted under air carrier safety rules, or, in the case of travel which is abroad, by an air carrier or commercial operator certificated by an appropriate foreign civil aviation authority and the flight is required to be conducted under air carrier safety rules; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e5a2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the candidate, the authorized committee, or other political committee pays to the owner, lessee, or other person who provides the airplane the pro rata share of the fair market value of such flight (as determined by dividing the fair market value of the normal and usual charter fare or rental charge for a comparable plane of comparable size by the number of candidates on the flight) within a commercially reasonable time frame after the date on which the flight is taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e5a3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" House candidates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this Act, in the case of a candidate for election for the office of Representative in, or Delegate or Resident Commissioner to, the Congress, an authorized committee and a leadership PAC of the candidate may not make any expenditure for a flight on an aircraft unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db2e5a4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is operated by an air carrier or commercial operator certificated by the Federal Aviation Administration and the flight is required to be conducted under air carrier safety rules, or, in the case of travel which is abroad, by an air carrier or commercial operator certificated by an appropriate foreign civil aviation authority and the flight is required to be conducted under air carrier safety rules; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e5a5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is operated by an entity of the Federal government or the government of any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db2e5a6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for aircraft owned or leased by candidate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db2e5a7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) do not apply to a flight on an aircraft owned or leased by the candidate involved or an immediate family member of the candidate (including an aircraft owned by an entity that is not a public corporation in which the candidate or an immediate family member of the candidate has an ownership interest), so long as the candidate does not use the aircraft more than the candidate’s or immediate family member’s proportionate share of ownership allows.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db2e5a8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate family member defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subparagraph (A), the term “immediate family member” means, with respect to a candidate, a father, mother, son, daughter, brother, sister, husband, wife, father-in-law, or mother-in-law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db555a9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30114/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leadership PAC defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “leadership PAC” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30104/i/8/B"},"text":"section 30104(i)(8)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db555aa-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s313"},"text":"Pub. L. 92–225, title III, § 313","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII/s301"},"text":"Pub. L. 107–155, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/95"},"text":"116 Stat. 95","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dH/tV/s532"},"text":"Pub. L. 108–447, div. H, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3272"},"text":"118 Stat. 3272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tVI/s601/a"},"text":"Pub. L. 110–81, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/774"},"text":"121 Stat. 774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db555ab-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db555ac-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db555ad-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(1), (2), means the Federal Election Campaign Act of 1971, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0db555ae-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s439a"},"text":"section 439a of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db555af-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s313"},"text":"section 313 of Pub. L. 92–225","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s439a"},"text":"section 439a of Title 2","children":[],"tail":", The Congress, and also related to use of contributed amounts for certain purposes, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII/s301"},"text":"Pub. L. 107–155, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/95"},"text":"116 Stat. 95","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s313"},"text":"section 313 of Pub. L. 92–225","children":[],"tail":" was renumbered section 309, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30109"},"text":"section 30109 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s313"},"text":"section 313 of Pub. L. 92–225","children":[],"tail":" was renumbered section 308, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30108"},"text":"section 30108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db555b0-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":", which directed the amendment of section 312a(a) of the Federal Election Campaign Act of 1971 by adding pars. (5) and (6), was executed by making the amendments to this section, which is section 313 of the Federal Election Campaign Act of 1971, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db555b1-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db555b2-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81/tVI/s601/b"},"text":"Pub. L. 110–81, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/775"},"text":"121 Stat. 775","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/81/tVI/s601/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to flights taken on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db555b3-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/s402"},"text":"section 402 of Pub. L. 107–155","children":[],"tail":", set out as an Effective Date of 2002 Amendment; Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
