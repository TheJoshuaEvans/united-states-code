{"tag":"section","attrib":{"id":"id0da243a0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081"},"text":null,"children":[{"tag":"num","attrib":{"value":"21081"},"text":"§ 21081.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting systems standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da243a1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each voting system used in an election for Federal office shall meet the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da243a2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da243a3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), the voting system (including any lever voting system, optical scanning voting system, or direct recording electronic system) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da243a4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the voter to verify (in a private and independent manner) the votes selected by the voter on the ballot before the ballot is cast and counted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da243a5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the voter with the opportunity (in a private and independent manner) to change the ballot or correct any error before the ballot is cast and counted (including the opportunity to correct the error through the issuance of a replacement ballot if the voter was otherwise unable to change the ballot or correct any error); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da243a6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the voter selects votes for more than one candidate for a single office—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id0da243a7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the voter that the voter has selected more than one candidate for a single office on the ballot;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0da243a8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the voter before the ballot is cast and counted of the effect of casting multiple votes for the office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id0da243a9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the voter with the opportunity to correct the ballot before the ballot is cast and counted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243aa-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State or jurisdiction that uses a paper ballot voting system, a punch card voting system, or a central count voting system (including mail-in absentee ballots and mail-in ballots), may meet the requirements of subparagraph (A)(iii) by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da243ab-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a voter education program specific to that voting system that notifies each voter of the effect of casting multiple votes for an office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da243ac-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the voter with instructions on how to correct the ballot before it is cast and counted (including instructions on how to correct the error through the issuance of a replacement ballot if the voter was otherwise unable to change the ballot or correct any error).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243ad-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The voting system shall ensure that any notification required under this paragraph preserves the privacy of the voter and the confidentiality of the ballot.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243ae-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit capacity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da243af-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voting system shall produce a record with an audit capacity for such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243b0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manual audit capacity","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0da243b1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The voting system shall produce a permanent paper record with a manual audit capacity for such system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da243b2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The voting system shall provide the voter with an opportunity to change the ballot or correct any error before the permanent paper record is produced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0da243b3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The paper record produced under subparagraph (A) shall be available as an official record for any recount conducted with respect to any election in which the system is used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243b4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessibility for individuals with disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voting system shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da243b5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accessible for individuals with disabilities, including nonvisual accessibility for the blind and visually impaired, in a manner that provides the same opportunity for access and participation (including privacy and independence) as for other voters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243b6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfy the requirement of subparagraph (A) through the use of at least one direct recording electronic voting system or other voting system equipped for individuals with disabilities at each polling place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243b7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if purchased with funds made available under subchapter II on or after ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", meet the voting system standards for disability access (as outlined in this paragraph)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243b8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative language accessibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voting system shall provide alternative language accessibility pursuant to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s10503"},"text":"section 10503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243b9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Error rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The error rate of the voting system in counting ballots (determined by taking into account only those errors which are attributable to the voting system and not attributable to an act of the voter) shall comply with the error rate standards established under section 3.2.1 of the voting systems standards issued by the Federal Election Commission which are in effect on ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243ba-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform definition of what constitutes a vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall adopt uniform and nondiscriminatory standards that define what constitutes a vote and what will be counted as a vote for each category of voting system used in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da243bb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting system defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “voting system” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da243bc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total combination of mechanical, electromechanical, or electronic equipment (including the software, firmware, and documentation required to program, control, and support the equipment) that is used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da243bd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to define ballots;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243be-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cast and count votes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243bf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report or display election results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243c0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and produce any audit trail information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243c1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the practices and associated documentation used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da243c2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify system components and versions of such components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243c3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to test the system during its development and maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243c4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain records of system errors and defects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243c5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine specific system changes to be made to a system after the initial qualification of the system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da243c6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make available any materials to the voter (such as notices, instructions, forms, or paper ballots).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da243c7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da243c8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit a State or jurisdiction which used a particular type of voting system in the elections for Federal office held in November 2000 from using the same type of system after the effective date of this section, so long as the system meets or is modified to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da243c9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of paper ballot voting systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a)(1)(A)(i), the term “verify” may not be defined in a manner that makes it impossible for a paper ballot voting system to meet the requirements of such subsection or to be modified to meet such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da243ca-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21081/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State and jurisdiction shall be required to comply with the requirements of this section on and after ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da243cb-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIII/s301"},"text":"Pub. L. 107–252, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1704"},"text":"116 Stat. 1704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da243cc-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da243cd-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da243ce-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15481"},"text":"section 15481 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
