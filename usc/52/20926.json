{"tag":"section","attrib":{"id":"id0d9b1833-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20926"},"text":null,"children":[{"tag":"num","attrib":{"value":"20926"},"text":"§ 20926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out its duties, the Commission shall, on an ongoing basis, disseminate to the public (through the Internet, published reports, and such other methods as the Commission considers appropriate) in a manner that is consistent with the requirements of chapter 19 of title 44 information on the activities carried out under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d9b1834-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s206"},"text":"Pub. L. 107–252, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1677"},"text":"116 Stat. 1677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9b1835-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9b1836-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d9b1837-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1666"},"text":"116 Stat. 1666","children":[],"tail":", known as the Help America Vote Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9b1838-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15326"},"text":"section 15326 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
