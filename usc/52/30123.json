{"tag":"section","attrib":{"id":"id0db79fc5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30123"},"text":null,"children":[{"tag":"num","attrib":{"value":"30123"},"text":"§ 30123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on contribution of currency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No person shall make contributions of currency of the United States or currency of any foreign country to or for the benefit of any candidate which, in the aggregate, exceed $100, with respect to any campaign of such candidate for nomination for election, or for election, to Federal office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db79fc6-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s321"},"text":"Pub. L. 92–225, title III, § 321","children":[],"tail":", formerly § 326, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI/s112/2"},"text":"Pub. L. 94–283, title I, § 112(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/494"},"text":"90 Stat. 494","children":[],"tail":"; renumbered § 321, "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI/s105/5"},"text":"Pub. L. 96–187, title I, § 105(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1354"},"text":"93 Stat. 1354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db79fc7-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db79fc8-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"tex