{"tag":"section","attrib":{"id":"id0d9b17cb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904"},"text":null,"children":[{"tag":"num","attrib":{"value":"20904"},"text":"§ 20904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9b17cc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for payments under this subchapter $650,000,000, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b17cd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be for payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20901"},"text":"section 20901 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17ce-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be for payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20902"},"text":"section 20902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b17cf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing availability of funds after appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment made to a State under this subchapter shall be available to the State without fiscal year limitation (subject to subsection (c)(2)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b17d0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of returned funds and funds remaining unexpended for requirements payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b17d1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts described in paragraph (2) shall be transferred to the Election Assistance Commission (established under subchapter II) and used by the Commission to make requirements payments under subpart 1 of part D of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17d2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts referred to in this paragraph are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9b17d3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts paid to the Administrator by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20902/d/1"},"text":"section 20902(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9b17d4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts appropriated for payments under this subchapter which remain unobligated as of ","children":[{"tag":"date","attrib":{"date":"2003-09-01"},"text":"September 1, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b17d5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of amounts in State election fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a State has established an election fund described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21004/b"},"text":"section 21004(b) of this title","children":[],"tail":", the State shall ensure that any funds provided to the State under this subchapter are deposited and maintained in such fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b17d6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amounts authorized under subsection (a), there are authorized to be appropriated to the Administrator such sums as may be necessary to administer the programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9b17d7-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tI/s104"},"text":"Pub. L. 107–252, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1672"},"text":"116 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9b17d8-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9b17d9-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9b17da-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15304"},"text":"section 15304 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
