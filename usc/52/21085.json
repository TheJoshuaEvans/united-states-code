{"tag":"section","attrib":{"id":"id0da48d4f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21085"},"text":null,"children":[{"tag":"num","attrib":{"value":"21085"},"text":"§ 21085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of implementation left to discretion of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The specific choices on the methods of complying with the requirements of this subchapter shall be left to the discretion of the State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0da48d50-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIII/s306"},"text":"Pub. L. 107–252, title III, § 306","children":[],"tail":", formerly § 305, "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1714"},"text":"116 Stat. 1714","children":[],"tail":"; renumbered § 306, "},{"tag":"ref","attrib":{"href":"/us/pl/118/106/s2/a/1"},"text":"Pub. L. 118–106, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-04"},"text":"Oct. 4, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1591"},"text":"138 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48d51-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48d52-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0da48d53-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":n