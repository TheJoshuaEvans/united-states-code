{"tag":"section","attrib":{"id":"id0dba113e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30145"},"text":null,"children":[{"tag":"num","attrib":{"value":"30145"},"text":"§ 30145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dba113f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person shall be prosecuted, tried, or punished for any violation of subchapter I of this chapter, unless the indictment is found or the information is instituted within 5 years after the date of the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dba1140-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dba1141-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30145/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of limitations referred to in subsection (a) shall apply with respect to violations referred to in such subsection committed before, on, or after the effective date of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dba1142-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30145/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no criminal proceeding shall be instituted against any person for any act or omission which was a violation of any provision of subchapter I of this chapter, as in effect on ","children":[{"tag":"date","attrib":{"date":"1974-12-31"},"text":"December 31, 1974","children":[],"tail":", if such act or omission does not constitute a violation of any such provision, as amended by the Federal Election Campaign Act Amendments of 1974."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this subsection shall affect any proceeding pending in any court of the United States on ","children":[{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dba1143-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIV/s406"},"text":"Pub. L. 92–225, title IV, § 406","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIII/s302"},"text":"Pub. L. 93–443, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1289"},"text":"88 Stat. 1289","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI/s115/f"},"text":"Pub. L. 94–283, title I, § 115(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/496"},"text":"90 Stat. 496","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII/s313/a"},"text":"Pub. L. 107–155, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/106"},"text":"116 Stat. 106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dba1144-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeadi