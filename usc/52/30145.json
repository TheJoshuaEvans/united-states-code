xt":"Pub. L. 94–283, § 115(f)(1)","children":[],"tail":", struck out references to sections 608, 610, 611, 613, 614, 615, 616, and 617 of title 18."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s115/f/2"},"text":"Pub. L. 94–283, § 115(f)(2)","children":[],"tail":", struck out references to sections 608, 610, 611, and 613 of title 18."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dba1149-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dba114a-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII/s313/b"},"text":"Pub. L. 107–155, title III, § 313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/106"},"text":"116 Stat. 106","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/155/tIII/s313/b"},"text":"“The amendment made by this section [amending this section] shall apply to violations occurring on or after the effective date of this Act [for general effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155"},"text":"Pub. L. 107–155","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/s402"},"text":"section 402 of Pub. L. 107–155","children":[],"tail":", set out as an Effective Date of 2002 Amendment; Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text"