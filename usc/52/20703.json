{"tag":"section","attrib":{"id":"id0d98a660-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20703"},"text":null,"children":[{"tag":"num","attrib":{"value":"20703"},"text":"§ 20703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand for records or papers by Attorney General or representative; statement of basis and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any record or paper required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20701"},"text":"section 20701 of this title","children":[],"tail":" to be retained and preserved shall, upon demand in writing by the Attorney General or his representative directed to the person having custody, possession, or control of such record or paper, be made available for inspection, reproduction, and copying at the principal office of such custodian by the Attorney General or his representative. This demand shall contain a statement of the basis and the purpose therefor."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d98a661-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/449/tIII/s303"},"text":"Pub. L. 86–449, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-06"},"text":"May 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/88"},"text":"74 Stat. 88","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d98a662-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d98a663-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d98a664-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1974b"},"text":"section 1974b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
