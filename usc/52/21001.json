{"tag":"section","attrib":{"id":"id0d9fd26a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001"},"text":null,"children":[{"tag":"num","attrib":{"value":"21001"},"text":"§ 21001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd26b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall make a requirements payment each year in an amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21002"},"text":"section 21002 of this title","children":[],"tail":" to each State which meets the conditions described in "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21003"},"text":"section 21003 of this title","children":[],"tail":" for the year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd26c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd26d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), a State receiving a requirements payment shall use the payment only to meet the requirements of subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd26e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may use a requirements payment to carry out other activities to improve the administration of elections for Federal office if the State certifies to the Commission that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9fd26f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has implemented the requirements of subchapter III; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9fd270-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount expended with respect to such other activities does not exceed an amount equal to the minimum payment amount applicable to the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21002/c"},"text":"section 21002(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd271-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities under Uniformed and Overseas Citizens Absentee Voting Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall use a requirements payment made using funds appropriated pursuant to the authorization under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21007/a/4"},"text":"section 21007(a)(4) of this title","children":[],"tail":" only to meet the requirements under the Uniformed and Overseas Citizens Absentee Voting Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"52 U.S.C. 20301","children":[],"tail":" et seq.] imposed as a result of the provisions of and amendments made by the Military and Overseas Voter Empowerment Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd272-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd273-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, including the maintenance of effort requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21004/a/7"},"text":"section 21004(a)(7) of this title","children":[],"tail":", a State may use a requirements payment as a reimbursement for costs incurred in obtaining voting equipment which meets the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21081"},"text":"section 21081 of this title","children":[],"tail":" if the State obtains the equipment after the regularly scheduled general election for Federal office held in November 2000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd274-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule regarding multiyear contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may use a requirements payment for any costs for voting equipment which meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21081"},"text":"section 21081 of this title","children":[],"tail":" that, pursuant to a multiyear contract, were incurred on or after "},{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":", except that the amount that the State is otherwise required to contribute under the maintenance of effort requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21004/a/7"},"text":"section 21004(a)(7) of this title","children":[],"tail":" shall be increased by the amount of the payment made with respect to such multiyear contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd275-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of Commission guidelines and guidance not required to receive payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subpart may be construed to require a State to implement any of the voluntary voting system guidelines or any of the voluntary guidance adopted by the Commission with respect to any matter as a condition for receiving a requirements payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd276-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the initial appointment of all members of the Commission (but in no event later than 6 months thereafter), and not less frequently than once each calendar year thereafter, the Commission shall make requirements payments to States under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd277-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may not use any portion of a requirements payment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd278-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay costs associated with any litigation, except to the extent that such costs otherwise constitute permitted uses of a requirements payment under this subpart; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd279-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21001/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the payment of any judgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd27a-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s251"},"text":"Pub. L. 107–252, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1692"},"text":"116 Stat. 1692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s588/a"},"text":"Pub. L. 111–84, div. A, title V, § 588(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2333"},"text":"123 Stat. 2333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd27b-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd27c-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d9fd27d-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter III, referred to in subsec. (b)(1), (2)(A), was in the original “title III”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1704"},"text":"116 Stat. 1704","children":[],"tail":", which is classified principally to subchapter III (§ 21081 et seq.) of this chapter. For complete classification of title III to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Uniformed and Overseas Citizens Absentee Voting Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Pub. L. 99–410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/924"},"text":"100 Stat. 924","children":[],"tail":", which is classified principally to chapter 203 (§ 20301 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Military and Overseas Voter Empowerment Act, referred to in subsec. (b)(3), is subtitle H (§§ 575–589) of title V of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2318"},"text":"123 Stat. 2318","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd27e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15401"},"text":"section 15401 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d9fd27f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s588/a/1"},"text":"Pub. L. 111–84, § 588(a)(1)","children":[],"tail":", substituted “paragraphs (2) and (3)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s588/a/2"},"text":"Pub. L. 111–84, § 588(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
