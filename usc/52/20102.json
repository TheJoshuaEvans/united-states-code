{"tag":"section","attrib":{"id":"id0d8cbfdb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102"},"text":null,"children":[{"tag":"num","attrib":{"value":"20102"},"text":"§ 20102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of polling facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8cbfdc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessibility to all polling places as responsibility of each political subdivision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within each State, except as provided in subsection (b), each political subdivision responsible for conducting elections shall assure that all polling places for Federal elections are accessible to handicapped and elderly voters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8cbfdd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to a polling place—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8cbfde-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an emergency, as determined by the chief election officer of the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8cbfdf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the chief election officer of the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d8cbfe0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that all potential polling places have been surveyed and no such accessible place is available, nor is the political subdivision able to make one temporarily accessible, in the area involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d8cbfe1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assures that any handicapped or elderly voter assigned to an inaccessible polling place, upon advance request of such voter (pursuant to procedures established by the chief election officer of the State)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d8cbfe2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be assigned to an accessible polling place, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d8cbfe3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be provided with an alternative means for casting a ballot on the day of the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8cbfe4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Federal Election Commission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8cbfe5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than December 31 of each even-numbered year, the chief election officer of each State shall report to the Federal Election Commission, in a manner to be determined by the Commission, the number of accessible and inaccessible polling places in such State on the date of the preceding general Federal election, and the reasons for any instance of inaccessibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8cbfe6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than April 30 of each odd-numbered year, the Federal Election Commission shall compile the information reported under paragraph (1) and shall transmit that information to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8cbfe7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this subsection shall only be effective for a period of 10 years beginning on ","children":[{"tag":"date","attrib":{"date":"1984-09-28"},"text":"September 28, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8cbfe8-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/435/s3"},"text":"Pub. L. 98–435, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1678"},"text":"98 Stat. 1678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8cbfe9-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8cbfea-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8cbfeb-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ee–1"},"text":"section 1973ee–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8cbfec-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8cbfed-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to elections taking place after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"Dec. 31, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/435/s9"},"text":"section 9 of Pub. L. 98–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20101"},"text":"section 20101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
