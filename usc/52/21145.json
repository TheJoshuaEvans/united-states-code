{"tag":"section","attrib":{"id":"id0da6fde8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145"},"text":null,"children":[{"tag":"num","attrib":{"value":"21145"},"text":"§ 21145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da6fde9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as specifically provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/b"},"text":"section 21083(b) of this title","children":[],"tail":" with regard to the National Voter Registration Act of 1993 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg"},"text":"42 U.S.C. 1973gg","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20501"},"text":"52 U.S.C. 20501","children":[],"tail":" et seq.], nothing in this chapter may be construed to authorize or require conduct prohibited under any of the following laws, or to supersede, restrict, or limit the application of such laws:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da6fdea-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Voting Rights Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973"},"text":"42 U.S.C. 1973","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s10301"},"text":"52 U.S.C. 10301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da6fdeb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Voting Accessibility for the Elderly and Handicapped Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ee"},"text":"42 U.S.C. 1973ee","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20101"},"text":"52 U.S.C. 20101","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da6fdec-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Uniformed and Overseas Citizens Absentee Voting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff"},"text":"42 U.S.C. 1973ff","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"52 U.S.C. 20301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da6fded-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Voter Registration Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg"},"text":"42 U.S.C. 1973gg","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20501"},"text":"52 U.S.C. 20501","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da6fdee-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da6fdef-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da6fdf0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on preclearance or other requirements under Voting Rights Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The approval by the Administrator or the Commission of a payment or grant application under subchapter I or subchapter II, or any other action taken by the Commission or a State under such subchapter, shall not be considered to have any effect on requirements for preclearance under section 5 of the Voting Rights Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973c"},"text":"42 U.S.C. 1973c","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s10304"},"text":"52 U.S.C. 10304","children":[],"tail":"] or any other requirements of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t52/s10301"},"text":"52 U.S.C. 10301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da6fdf1-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIX/s906"},"text":"Pub. L. 107–252, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1729"},"text":"116 Stat. 1729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da6fdf2-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da6fdf3-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0da6fdf4-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Voter Registration Act of 1993, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31"},"text":"Pub. L. 103–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/77"},"text":"107 Stat. 77","children":[],"tail":", which is classified principally to chapter 205 (§ 20501 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1666"},"text":"116 Stat. 1666","children":[],"tail":", known as the Help America Vote Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Voting Rights Act of 1965, referred to in subsecs. (a)(1) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110"},"text":"Pub. L. 89–110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-06"},"text":"Aug. 6, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/437"},"text":"79 Stat. 437","children":[],"tail":", which is classified generally to chapters 103 (§ 10301 et seq.), 105 (§ 10501 et seq.), and 107 (§ 10701 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Voting Accessibility for the Elderly and Handicapped Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/435"},"text":"Pub. L. 98–435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1678"},"text":"98 Stat. 1678","children":[],"tail":", which is classified generally to chapter 201 (§ 20101 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Uniformed and Overseas Citizens Absentee Voting Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Pub. L. 99–410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/924"},"text":"100 Stat. 924","children":[],"tail":", which is classified principally to chapter 203 (§ 20301 et seq.) of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act of 1990, referred to in subsec. (a)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rehabilitation Act of 1973, referred to in subsec. (a)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":", which is classified generally to chapter 16 (§ 701 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"section 701 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da6fdf5-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15545"},"text":"section 15545 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
