{"tag":"section","attrib":{"id":"id0d9fd2db-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21006"},"text":null,"children":[{"tag":"num","attrib":{"value":"21006"},"text":"§ 21006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for public notice and comment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of section 21001(a)(1)(C) ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, a State plan meets the public notice and comment requirements of this section if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd2dc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21006/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days prior to the submission of the plan, the State made a preliminary version of the plan available for public inspection and comment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2dd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21006/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State publishes notice that the preliminary version of the plan is so available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2de-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21006/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State took the public comments made regarding the preliminary version of the plan into account in preparing the plan which was filed with the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd2df-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s256"},"text":"Pub. L. 107–252, title II, § 256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1697"},"text":"116 Stat. 1697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd2e0-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd2e1-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d9fd2e2-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21001/a/1/C"},"text":"Section 21001(a)(1)(C) of this title","children":[],"tail":", referred to in text, probably should be a reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21003/b/1/C"},"text":"section 21003(b)(1)(C) of this title","children":[],"tail":" because there is no subsec. (a)(1)(C) in section 21001 and subsec. (b)(1)(C) of section 21003 relates to public notice and comment requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s21006"},"text":"section 21006 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd2e3-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15406"},"text":"section 15406 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
