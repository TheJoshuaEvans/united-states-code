{"tag":"section","attrib":{"id":"id0d93eacd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20305"},"text":null,"children":[{"tag":"num","attrib":{"value":"20305"},"text":"§ 20305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Voting Assistance Program Improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d93eace-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Presidential designee shall carry out the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d93eacf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop online portals of information to inform absent uniformed services voters regarding voter registration procedures and absentee ballot procedures to be used by such voters with respect to elections for Federal office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93ead0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish a program to notify absent uniformed services voters of voter registration information and resources, the availability of the Federal postcard application, and the availability of the Federal write-in absentee ballot on the military Global Network, and shall use the military Global Network to notify absent uniformed services voters of the foregoing 90, 60, and 30 days prior to each election for Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93ead1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification regarding other duties and obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall relieve the Presidential designee of their duties and obligations under any directives or regulations issued by the Department of Defense, including the Department of Defense Directive 1000.04 (or any successor directive or regulation) that is not inconsistent or contradictory to the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93ead2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Federal Voting Assistance Program of the Department of Defense (or a successor program) such sums as are necessary for purposes of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d93ead3-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410/tI/s103B"},"text":"Pub. L. 99–410, title I, § 103B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s583/a/1"},"text":"Pub. L. 111–84, div. A, title V, § 583(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2327"},"text":"123 Stat. 2327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d93ead4-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d93ead5-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d93ead6-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff–2b"},"text":"section 1973ff–2b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d93ead7-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d93ead8-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to the regularly scheduled general election for Federal office held in November 2010 and each succeeding election for Federal office, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s583/a/3"},"text":"section 583(a)(3) of Pub. L. 111–84","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"section 20301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
