{"tag":"section","attrib":{"id":"id0db79fad-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121"},"text":null,"children":[{"tag":"num","attrib":{"value":"30121"},"text":"§ 30121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions and donations by foreign nationals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db79fae-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db79faf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a foreign national, directly or indirectly, to make—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0db79fb0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contribution or donation of money or other thing of value, or to make an express or implied promise to make a contribution or donation, in connection with a Federal, State, or local election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db79fb1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contribution or donation to a committee of a political party; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0db79fb2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expenditure, independent expenditure, or disbursement for an electioneering communication (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30104/f/3"},"text":"section 30104(f)(3) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db79fb3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person to solicit, accept, or receive a contribution or donation described in subparagraph (A) or (B) of paragraph (1) from a foreign national.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db79fb4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Foreign national” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term “foreign national” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db79fb5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign principal, as such term is defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s611/b"},"text":"section 611(b) of title 22","children":[],"tail":", except that the term “foreign national” shall not include any individual who is a citizen of the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db79fb6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is not a citizen of the United States or a national of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"section 1101(a)(22) of title 8","children":[],"tail":") and who is not lawfully admitted for permanent residence, as defined by "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/20"},"text":"section 1101(a)(20) of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db79fb7-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s319"},"text":"Pub. L. 92–225, title III, § 319","children":[],"tail":", formerly § 324, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI/s112/2"},"text":"Pub. L. 94–283, title I, § 112(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/493"},"text":"90 Stat. 493","children":[],"tail":"; renumbered § 319, "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI/s105/5"},"text":"Pub. L. 96–187, title I, § 105(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1354"},"text":"93 Stat. 1354","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII"},"text":"Pub. L. 107–155, title III","children":[],"tail":", §§ 303, 317, "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/96"},"text":"116 Stat. 96","children":[],"tail":", 109.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db79fb8-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db79fb9-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0db79fba-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s441e"},"text":"section 441e of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db79fbb-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s319"},"text":"section 319 of Pub. L. 92–225","children":[],"tail":" was renumbered section 314, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30115"},"text":"section 30115 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s319"},"text":"section 319 of Pub. L. 92–225","children":[],"tail":" was renumbered section 318, and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s439b"},"text":"section 439b of Title 2","children":[],"tail":", The Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db79fbc-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155/s303/1"},"text":"Pub. L. 107–155, § 303(1)","children":[],"tail":", substituted “Contributions and donations by foreign nationals” for “Contributions by foreign nationals” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155/s303/2"},"text":"Pub. L. 107–155, § 303(2)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which read as follows: “It shall be unlawful for a foreign national directly or through any other person to make any contribution of money or other thing of value, or to promise expressly or impliedly to make any such contribution, in connection with an election to any political office or in connection with any primary election, convention, or caucus held to select candidates for any political office; or for any person to solicit, accept, or receive any such contribution from a foreign national.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155/s317"},"text":"Pub. L. 107–155, § 317","children":[],"tail":", inserted “or a national of the United States (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"section 1101(a)(22) of title 8","children":[],"tail":")” after “United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db79fbd-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db79fbe-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155"},"text":"Pub. L. 107–155","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/s402"},"text":"section 402 of Pub. L. 107–155","children":[],"tail":", set out as an Effective Date of 2002 Amendment; Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
