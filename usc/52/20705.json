{"tag":"section","attrib":{"id":"id0d98a66a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20705"},"text":null,"children":[{"tag":"num","attrib":{"value":"20705"},"text":"§ 20705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction to compel production of records or papers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States district court for the district in which a demand is made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20703"},"text":"section 20703 of this title","children":[],"tail":", or in which a record or paper so demanded is located, shall have jurisdiction by appropriate process to compel the production of such record or paper."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d98a66b-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/449/tIII/s305"},"text":"Pub. L. 86–449, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-06"},"text":"May 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/88"},"text":"74 Stat. 88","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d98a66c-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d98a66d-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d98a66e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1974d"},"text":"section 1974d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
