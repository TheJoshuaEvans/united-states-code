{"tag":"section","attrib":{"id":"id0d9b17c4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20903"},"text":null,"children":[{"tag":"num","attrib":{"value":"20903"},"text":"§ 20903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranteed minimum payment amount","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9b17c5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other payments made under this subchapter, the Administrator shall make a payment to each State to which a payment is made under either section 20901 or 20902 of this title and with respect to which the aggregate amount paid under such sections is less than $5,000,000 in an amount equal to the difference between the aggregate amount paid to the State under sections 20901 and 20902 of this title and $5,000,000. In the case of the Commonwealth of Puerto Rico, Guam, American Samoa, and the United States Virgin Islands, the previous sentence shall be applied as if each reference to “$5,000,000” were a reference to “$1,000,000”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b17c6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make such pro rata reductions to the amounts described in sections 20901(d) and 20902(c) of this title as are necessary to comply with the requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9b17c7-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tI/s103"},"text":"Pub. L. 107–252, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1672"},"text":"116 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9b17c8-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9b17c9-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9b17ca-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15303"},"text":"section 15303 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
