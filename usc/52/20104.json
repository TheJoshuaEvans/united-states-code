{"tag":"section","attrib":{"id":"id0d8f2ff7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104"},"text":null,"children":[{"tag":"num","attrib":{"value":"20104"},"text":"§ 20104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration and voting aids","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8f2ff8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printed instructions; telecommunications devices for the deaf","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State shall make available registration and voting aids for Federal elections for handicapped and elderly individuals, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8f2ff9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instructions, printed in large type, conspicuously displayed at each permanent registration facility and each polling place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f2ffa-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information by telecommunications devices for the deaf.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8f2ffb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No notarization or medical certification shall be required of a handicapped voter with respect to an absentee ballot or an application for such ballot, except that medical certification may be required when the certification establishes eligibility, under State law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8f2ffc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to automatically receive an application or a ballot on a continuing basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8f2ffd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to apply for an absentee ballot after the deadline has passed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8f2ffe-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of availability of aids","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief election officer of each State shall provide public notice, calculated to reach elderly and handicapped voters, of the availability of aids under this section, assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s10508"},"text":"section 10508 of this title","children":[],"tail":", and the procedures for voting by absentee ballot, not later than general public notice of registration and voting is provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8f2fff-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/435/s5"},"text":"Pub. L. 98–435, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1679"},"text":"98 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8f3000-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8f3001-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8f3002-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ee–3"},"text":"section 1973ee–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8f3003-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8f3004-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to elections taking place after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"Dec. 31, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/435/s9"},"text":"section 9 of Pub. L. 98–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20101"},"text":"section 20101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
