{"tag":"section","attrib":{"id":"id0d98a665-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20704"},"text":null,"children":[{"tag":"num","attrib":{"value":"20704"},"text":"§ 20704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of records or papers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless otherwise ordered by a court of the United States, neither the Attorney General nor any employee of the Department of Justice, nor any other representative of the Attorney General, shall disclose any record or paper produced pursuant to this chapter, or any reproduction or copy, except to Congress and any committee thereof, governmental agencies, and in the presentation of any case or proceeding before any court or grand jury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d98a666-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/449/tIII/s304"},"text":"Pub. L. 86–449, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-05-06"},"text":"May 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/88"},"text":"74 Stat. 88","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d98a667-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d98a668-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d98a669-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1974c"},"text":"section 1974c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
