{"tag":"section","attrib":{"id":"id0d9d6217-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982"},"text":null,"children":[{"tag":"num","attrib":{"value":"20982"},"text":"§ 20982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study, report, and recommendations on best practices for facilitating military and overseas voting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9d6218-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d6219-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, in consultation with the Secretary of Defense, shall conduct a study on the best practices for facilitating voting by absent uniformed services voters (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20310/1"},"text":"section 20310(1) of this title","children":[],"tail":") and overseas voters (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20310/5"},"text":"section 20310(5) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d621a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues considered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study under paragraph (1) the Commission shall consider the following issues:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d621b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights of residence of uniformed services voters absent due to military orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d621c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights of absent uniformed services voters and overseas voters to register to vote and cast absentee ballots, including the right of such voters to cast a secret ballot.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d621d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights of absent uniformed services voters and overseas voters to submit absentee ballot applications early during an election year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d621e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate preelection deadline for mailing absentee ballots to absent uniformed services voters and overseas voters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d621f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate minimum period between the mailing of absentee ballots to absent uniformed services voters and overseas voters and the deadline for receipt of such ballots.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6220-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The timely transmission of balloting materials to absent uniformed services voters and overseas voters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6221-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Security and privacy concerns in the transmission, receipt, and processing of ballots from absent uniformed services voters and overseas voters, including the need to protect against fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6222-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of a single application by absent uniformed services voters and overseas voters for absentee ballots for all Federal elections occurring during a year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6223-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of a single application for voter registration and absentee ballots by absent uniformed services voters and overseas voters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6224-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of facsimile machines and electronic means of transmission of absentee ballot applications and absentee ballots to absent uniformed services voters and overseas voters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6225-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other issues related to the rights of absent uniformed services voters and overseas voters to participate in elections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d6226-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":", the Commission shall submit to the President and Congress a report on the study conducted under subsection (a)(1) together with recommendations identifying the best practices used with respect to the issues considered under subsection (a)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd227-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s242"},"text":"Pub. L. 107–252, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1688"},"text":"116 Stat. 1688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd228-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd229-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd22a-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15382"},"text":"section 15382 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
