{"tag":"section","attrib":{"id":"id0da6fdd8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21143"},"text":null,"children":[{"tag":"num","attrib":{"value":"21143"},"text":"§ 21143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and report on adequacy of existing electoral fraud statutes and penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da6fdd9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall conduct a review of existing criminal statutes concerning election offenses to determine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da6fdda-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether additional statutory offenses are needed to secure the use of the Internet for election purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da6fddb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether existing penalties provide adequate punishment and deterrence with respect to such offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da6fddc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall submit a report to the Committees on the Judiciary of the Senate and House of Representatives, the Committee on Rules and Administration of the Senate, and the Committee on House Administration of the House of Representatives on the review conducted under subsection (a) together with such recommendations for legislative and administrative action as the Attorney General determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da6fddd-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIX/s904"},"text":"Pub. L. 107–252, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1729"},"text":"116 Stat. 1729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da6fdde-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da6fddf-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da6fde0-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15543"},"text":"section 15543 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
