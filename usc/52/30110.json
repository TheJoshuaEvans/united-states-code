{"tag":"section","attrib":{"id":"id0db2e535-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30110"},"text":null,"children":[{"tag":"num","attrib":{"value":"30110"},"text":"§ 30110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission, the national committee of any political party, or any individual eligible to vote in any election for the office of President may institute such actions in the appropriate district court of the United States, including actions for declaratory judgment, as may be appropriate to construe the constitutionality of any provision of this Act. The district court immediately shall certify all questions of constitutionality of this Act to the United States court of appeals for the circuit involved, which shall hear the matter sitting en banc.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0db2e536-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s310"},"text":"Pub. L. 92–225, title III, § 310","children":[],"tail":", formerly § 315, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tII/s208/a"},"text":"Pub. L. 93–443, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1285"},"text":"88 Stat. 1285","children":[],"tail":"; renumbered § 314 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI"},"text":"Pub. L. 94–283, title I","children":[],"tail":", §§ 105, 115(e), "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/481"},"text":"90 Stat. 481","children":[],"tail":", 496; renumbered § 310 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI"},"text":"Pub. L. 96–187, title I","children":[],"tail":", §§ 105(4), 112(c), "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1354"},"text":"93 Stat. 1354","children":[],"tail":", 1366; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/1/B"},"text":"Pub. L. 98–620, title IV, § 402(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3357"},"text":"98 Stat. 3357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/352/s6/a"},"text":"Pub. L. 100–352, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/663"},"text":"102 Stat. 663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0db2e537-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0db2e538-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0db2e539-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means the Federal Election Campaign Act of 1971, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0db2e53a-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s437h"},"text":"section 437h of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0db2e53b-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s310"},"text":"section 310 of Pub. L. 92–225","children":[],"tail":" was renumbered section 307, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30107"},"text":"section 30107 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s310"},"text":"section 310 of Pub. L. 92–225","children":[],"tail":" was renumbered section 306, and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30106"},"text":"section 30106 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s310"},"text":"section 310 of Pub. L. 92–225","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s440"},"text":"section 440 of Title 2","children":[],"tail":", The Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0db2e53c-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/352"},"text":"Pub. L. 100–352","children":[],"tail":" struck out “(a)” before “The Commission” and struck out subsec. (b) which read as follows: “Notwithstanding any other provision of law, any decision on a matter certified under subsection (a) of this section shall be reviewable by appeal directly to the Supreme Court of the United States. Such appeal shall be brought no later than 20 days after the decision of the court of appeals.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out subsec. (c) which provided for advancement on appellate docket and expedited disposition of any matter certified under subsec. (a) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187/s112/c"},"text":"Pub. L. 96–187, § 112(c)","children":[],"tail":", struck out “of the United States” after “office of President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/283/s115/e"},"text":"Pub. L. 94–283, § 115(e)","children":[],"tail":", struck out references to sections 608, 610, 611, 613, 614, 615, 616, and 617 of title 18."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0db2e53d-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db2e53e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/352"},"text":"Pub. L. 100–352","children":[],"tail":" effective ninety days after "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", except that such amendment not to apply to cases pending in Supreme Court on such effective date or affect right to review or manner of reviewing judgment or decree of court which was entered before such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/352/s7"},"text":"section 7 of Pub. L. 100–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db2e53f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0db2e540-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/s301/a"},"text":"section 301(a) of Pub. L. 96–187","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0db2e541-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1975-01-01"},"text":"Jan. 1, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/a"},"text":"section 410(a) of Pub. L. 93–443","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id0db2e542-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Judicial Review","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIV/s403"},"text":"Pub. L. 107–155, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/113"},"text":"116 Stat. 113","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/155/tIV/s403"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rules for Actions Brought on Constitutional Grounds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any action is brought for declaratory or injunctive relief to challenge the constitutionality of any provision of this Act [see Tables for classification] or any amendment made by this Act, the following rules shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The action shall be filed in the United States District Court for the District of Columbia and shall be heard by a 3-judge court convened pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2284"},"text":"section 2284 of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the complaint shall be delivered promptly to the Clerk of the House of Representatives and the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A final decision in the action shall be reviewable only by appeal directly to the Supreme Court of the United States. Such appeal shall be taken by the filing of a notice of appeal within 10 days, and the filing of a jurisdictional statement within 30 days, of the entry of the final decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be the duty of the United States District Court for the District of Columbia and the Supreme Court of the United States to advance on the docket and to expedite to the greatest possible extent the disposition of the action and appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intervention by Members of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any action in which the constitutionality of any provision of this Act or any amendment made by this Act is raised (including but not limited to an action described in subsection (a)), any member of the House of Representatives (including a Delegate or Resident Commissioner to the Congress) or Senate shall have the right to intervene either in support of or opposition to the position of a party to the case regarding the constitutionality of the provision or amendment. To avoid duplication of efforts and reduce the burdens placed on the parties to the action, the court in any such action may make such orders as it considers necessary, including orders to require intervenors taking similar positions to file joint papers or to be represented by a single attorney at oral argument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenge by Members of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any Member of Congress may bring an action, subject to the special rules described in subsection (a), for declaratory or injunctive relief to challenge the constitutionality of any provision of this Act or any amendment made by this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any action initially filed on or before ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":", the provisions of subsection (a) shall apply with respect to each action described in such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any action initially filed after ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":", the provisions of subsection (a) shall not apply to any action described in such section unless the person filing such action elects such provisions to apply to the action.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
