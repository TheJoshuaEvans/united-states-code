{"tag":"section","attrib":{"id":"id0d8cbfc7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10702"},"text":null,"children":[{"tag":"num","attrib":{"value":"10702"},"text":"§ 10702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “State” includes the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8cbfc8-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110/tIII/s302"},"text":"Pub. L. 89–110, title III, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/285/s6"},"text":"Pub. L. 91–285, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-22"},"text":"June 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/318"},"text":"84 Stat. 318","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/73/tIV/s407"},"text":"Pub. L. 94–73, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-06"},"text":"Aug. 6, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/405"},"text":"89 Stat. 405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8cbfc9-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8cbfca-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8cbfcb-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib"