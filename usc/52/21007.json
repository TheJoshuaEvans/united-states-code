{"tag":"section","attrib":{"id":"id0d9fd2e4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007"},"text":null,"children":[{"tag":"num","attrib":{"value":"21007"},"text":"§ 21007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd2e5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20904/c"},"text":"section 20904(c) of this title","children":[],"tail":", there are authorized to be appropriated for requirements payments under this subpart the following amounts:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd2e6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2003, $1,400,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2e7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2004, $1,000,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2e8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2005, $600,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2e9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010 and subsequent fiscal years, such sums as are necessary for purposes of making requirements payments to States to carry out the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21001/b/3"},"text":"section 21001(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd2ea-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts appropriated pursuant to the authority of subsection (a) shall remain available without fiscal year limitation until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd2eb-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s257"},"text":"Pub. L. 107–252, title II, § 257","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1697"},"text":"116 Stat. 1697","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s588/c"},"text":"Pub. L. 111–84, div. A, title V, § 588(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2334"},"text":"123 Stat. 2334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd2ec-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"t