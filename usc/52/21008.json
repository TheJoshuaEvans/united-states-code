{"tag":"section","attrib":{"id":"id0d9fd2f0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21008"},"text":null,"children":[{"tag":"num","attrib":{"value":"21008"},"text":"§ 21008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the end of each fiscal year for which a State received a requirements payment under this subpart, the State shall submit a report to the Commission on the activities conducted with the funds provided during the year, and shall include in the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd2f1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21008/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of expenditures made with respect to each category of activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21001/b"},"text":"section 21001(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2f2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21008/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of articles of voting equipment obtained with the funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2f3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21008/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis and description of the activities funded under this subpart to meet the requirements of this chapter and an analysis and description of how such activities conform to the State plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21004"},"text":"section 21004 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd2f4-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s258"},"text":"Pub. L. 107–252, title II, § 258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1697"},"text":"116 Stat. 1697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd2f5-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd2f6-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d9fd2f7-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1666"},"text":"116 Stat. 1666","children":[],"tail":", known as the Help America Vote Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd2f8-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15408"},"text":"section 15408 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
