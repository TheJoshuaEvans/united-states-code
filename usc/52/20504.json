{"tag":"section","attrib":{"id":"id0d965c78-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504"},"text":null,"children":[{"tag":"num","attrib":{"value":"20504"},"text":"§ 20504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simultaneous application for voter registration and application for motor vehicle driver’s license","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d965c79-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c7a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State motor vehicle driver’s license application (including any renewal application) submitted to the appropriate State motor vehicle authority under State law shall serve as an application for voter registration with respect to elections for Federal office unless the applicant fails to sign the voter registration application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c7b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An application for voter registration submitted under paragraph (1) shall be considered as updating any previous voter registration by the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c7c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information relating to the failure of an applicant for a State motor vehicle driver’s license to sign a voter registration application may be used for any purpose other than voter registration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c7d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forms and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c7e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State shall include a voter registration application form for elections for Federal office as part of an application for a State motor vehicle driver’s license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c7f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The voter registration application portion of an application for a State motor vehicle driver’s license—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d965c80-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not require any information that duplicates information required in the driver’s license portion of the form (other than a second signature or other information necessary under subparagraph (C));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965c81-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may require only the minimum amount of information necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d965c82-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent duplicate voter registrations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d965c83-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable State election officials to assess the eligibility of the applicant and to administer voter registration and other parts of the election process;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965c84-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include a statement that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d965c85-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states each eligibility requirement (including citizenship);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d965c86-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains an attestation that the applicant meets each such requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d965c87-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the signature of the applicant, under penalty of perjury;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965c88-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include, in print that is identical to that used in the attestation portion of the application—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d965c89-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required in section 20507(a)(5)(A) and (B) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d965c8a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that, if an applicant declines to register to vote, the fact that the applicant has declined to register will remain confidential and will be used only for voter registration purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d965c8b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement that if an applicant does register to vote, the office at which the applicant submits a voter registration application will remain confidential and will be used only for voter registration purposes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d965c8c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made available (as submitted by the applicant, or in machine readable or other format) to the appropriate State election official as provided by State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c8d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of address","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any change of address form submitted in accordance with State law for purposes of a State motor vehicle driver’s license shall serve as notification of change of address for voter registration with respect to elections for Federal office for the registrant involved unless the registrant states on the form that the change of address is not for voter registration purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d965c8e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal deadline","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d965c8f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), a completed voter registration portion of an application for a State motor vehicle driver’s license accepted at a State motor vehicle authority shall be transmitted to the appropriate State election official not later than 10 days after the date of acceptance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d965c90-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20504/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a registration application is accepted within 5 days before the last day for registration to vote in an election, the application shall be transmitted to the appropriate State election official not later than 5 days after the date of acceptance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d965c91-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/31/s5"},"text":"Pub. L. 103–31, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-20"},"text":"May 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/78"},"text":"107 Stat. 78","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d965c92-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d965c93-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d965c94-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973gg–3"},"text":"section 1973gg–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
