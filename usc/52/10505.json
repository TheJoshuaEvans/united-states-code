{"tag":"section","attrib":{"id":"id0d8cbfa0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10505"},"text":null,"children":[{"tag":"num","attrib":{"value":"10505"},"text":"§ 10505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever shall deprive or attempt to deprive any person of any right secured by section 10501, 10502, or 10503 of this title shall be fined not more than $5,000, or imprisoned not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8cbfa1-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110/tII/s205"},"text":"Pub. L. 89–110, title II, § 205","children":[],"tail":", formerly § 204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/285/s6"},"text":"Pub. L. 91–285, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-22"},"text":"June 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/317"},"text":"84 Stat. 317","children":[],"tail":"; renumbered § 205 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/73/tIII"},"text":"Pub. L. 94–73, title III","children":[],"tail":", §§ 302, 304, "},{"tag":"date","attrib":{"date":"1975-08-06"},"text":"Aug. 6, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/403"},"text":"89 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8cbfa2-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8cbfa3-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":