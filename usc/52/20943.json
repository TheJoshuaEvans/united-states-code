{"tag":"section","attrib":{"id":"id0d9b1860-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943"},"text":null,"children":[{"tag":"num","attrib":{"value":"20943"},"text":"§ 20943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership of Standards Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9b1861-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b1862-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to certification by the chair of the Federal Election Commission under subsection (b), the Standards Board shall be composed of 110 members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9b1863-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fifty-five shall be State election officials selected by the chief State election official of each State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6154-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fifty-five shall be local election officials selected in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6155-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of local election officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State’s local election officials, including the local election officials of Puerto Rico and the United States Virgin Islands, shall select (under a process supervised by the chief election official of the State) a representative local election official from the State for purposes of paragraph (1)(B). In the case of the District of Columbia, Guam, and American Samoa, the chief election official shall establish a procedure for selecting an individual to serve as a local election official for purposes of such paragraph, except that under such a procedure the individual selected may not be a member of the same political party as the chief election official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6156-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requiring mix of political parties represented","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The two members of the Standards Board who represent the same State may not be members of the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d6157-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for notice and certification of appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d6158-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to chair of Federal Election Commission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":", the chief State election official of the State shall transmit a notice to the chair of the Federal Election Commission containing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d6159-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the State election official who agrees to serve on the Standards Board under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d615a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the representative local election official from the State selected under subsection (a)(2) who agrees to serve on the Standards Board under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d615b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receiving a notice from a State under paragraph (1), the chair of the Federal Election Commission shall publish a certification that the selected State election official and the representative local election official are appointed as members of the Standards Board under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d615c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure to provide notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State does not transmit a notice to the chair of the Federal Election Commission under paragraph (1) within the deadline described in such paragraph, no representative from the State may participate in the selection of the initial Executive Board under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d615d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the appointment of the members of the Election Assistance Commission, the Election Assistance Commission shall carry out the duties of the Federal Election Commission under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d615e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d615f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the last day on which the appointment of any of its members may be certified under subsection (b), the Standards Board shall select nine of its members to serve as the Executive Board of the Standards Board, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d6160-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five may be State election officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6161-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five may be local election officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6162-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than five may be members of the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6163-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), members of the Executive Board of the Standards Board shall serve for a term of 2 years and may not serve for more than 3 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6164-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staggering of initial terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members first selected to serve on the Executive Board of the Standards Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d6165-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall serve for 1 term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6166-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall serve for 2 consecutive terms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d6167-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall serve for 3 consecutive terms,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as determined by lot at the time the members are first appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d6168-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20943/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other duties assigned under this subchapter, the Executive Board of the Standards Board may carry out such duties of the Standards Board as the Standards Board may delegate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9d6169-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s213"},"text":"Pub. L. 107–252, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1678"},"text":"116 Stat. 1678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9d616a-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9d616b-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9d616c-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15343"},"text":"section 15343 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
