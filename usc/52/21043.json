{"tag":"section","attrib":{"id":"id0da24344-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21043"},"text":null,"children":[{"tag":"num","attrib":{"value":"21043"},"text":"§ 21043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da24345-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21043/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for grants under this subpart $20,000,000 for fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da24346-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21043/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization under this section shall remain available, without fiscal year limitation, until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da24347-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s273"},"text":"Pub. L. 107–252, title II, § 273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1700"},"text":"116 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da24348-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","a