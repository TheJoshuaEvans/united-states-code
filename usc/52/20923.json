{"tag":"section","attrib":{"id":"id0d9b17f8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923"},"text":null,"children":[{"tag":"num","attrib":{"value":"20923"},"text":"§ 20923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9b17f9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b17fa-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have four members appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17fb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the initial appointment of the members of the Commission and before the appointment of any individual to fill a vacancy on the Commission, the Majority Leader of the Senate, the Speaker of the House of Representatives, the Minority Leader of the Senate, and the Minority Leader of the House of Representatives shall each submit to the President a candidate recommendation with respect to each vacancy on the Commission affiliated with the political party of the Member of Congress involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17fc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission shall have experience with or expertise in election administration or the study of elections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17fd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date of appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointments of the members of the Commission shall be made not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b17fe-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b17ff-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraphs (2) and (3), members shall serve for a term of 4 years and may be reappointed for not more than one additional term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b1800-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of initial appointees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As designated by the President at the time of nomination, of the members first appointed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9b1801-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two of the members (not more than one of whom may be affiliated with the same political party) shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9b1802-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two of the members (not more than one of whom may be affiliated with the same political party) shall be appointed for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b1803-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9b1804-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy on the Commission shall be filled in the manner in which the original appointment was made and shall be subject to any conditions which applied with respect to the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9b1805-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expired terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission shall serve on the Commission after the expiration of the member’s term until the successor of such member has taken office as a member of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9b1806-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unexpired terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual appointed to fill a vacancy shall be appointed for the unexpired term of the member replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b1807-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair and vice chair","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b1808-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall select a chair and vice chair from among its members for a term of 1 year, except that the chair and vice chair may not be affiliated with the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b1809-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Commission may serve as the chairperson and vice chairperson for only 1 term each during the term of office to which such member is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9b180a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b180b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission shall be compensated at the annual rate of basic pay prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b180c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20923/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member appointed to the Commission under subsection (a) may engage in any other business, vocation, or employment while serving as a member of the Commission and shall terminate or liquidate such business, vocation, or employment before sitting as a member of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9b180d-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s203"},"text":"Pub. L. 107–252, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1674"},"text":"116 Stat. 1674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9b180e-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9b180f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9b1810-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15323"},"text":"section 15323 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
