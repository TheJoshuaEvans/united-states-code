{"tag":"section","attrib":{"id":"id0da48d6b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21111"},"text":null,"children":[{"tag":"num","attrib":{"value":"21111"},"text":"§ 21111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by the Attorney General for declaratory and injunctive relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may bring a civil action against any State or jurisdiction in an appropriate United States District Court for such declaratory and injunctive relief (including a temporary restraining order, a permanent or temporary injunction, or other order) as may be necessary to carry out the uniform and nondiscriminatory election technology and administration requirements under sections 21081, 21082, 21083, and 21083a of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0da48d6c-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIV/s401"},"text":"Pub. L. 107–252, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1715"},"text":"116 Stat. 1715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/106/s2/b"},"text":"Pub. L. 118–106, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-04"},"text":"Oct. 4, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1593"},"text":"138 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48d6d-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48d6e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da48d6f-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15511"},"text":"section 15511 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0da48d70-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/106"},"text":"Pub. L. 118–106","children":[],"tail":" substituted “21083, and 21083a” for “and 21083”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
