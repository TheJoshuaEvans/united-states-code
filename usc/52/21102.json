{"tag":"section","attrib":{"id":"id0da48d61-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21102"},"text":null,"children":[{"tag":"num","attrib":{"value":"21102"},"text":"§ 21102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for adoption","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The adoption of the voluntary guidance under this part shall be carried out by the Commission in a manner that provides for each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da48d62-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publication of notice of the proposed recommendations in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da48d63-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An opportunity for public comment on the proposed recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da48d64-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An opportunity for a public hearing on the record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da48d65-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publication of the final recommendations in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da48d66-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tIII/s312"},"text":"Pub. L. 107–252, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1715"},"text":"116 Stat. 1715","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48d67-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48d68-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da48d69-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15502"},"text":"section 15502 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
