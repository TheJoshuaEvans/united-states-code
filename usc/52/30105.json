{"tag":"section","attrib":{"id":"id0dae2994-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30105"},"text":null,"children":[{"tag":"num","attrib":{"value":"30105"},"text":"§ 30105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on convention financing","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each committee or other organization which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0dae2995-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents a State, or a political subdivision thereof, or any group of persons, in dealing with officials of a national political party with respect to matters involving a convention held in such State or political subdivision to nominate a candidate for the office of President or Vice President, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0dae2996-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents a national political party in making arrangements for the convention of such party held to nominate a candidate for the office of President or Vice President,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, within 60 days following the end of the convention (but not later than 20 days prior to the date on which presidential and vice-presidential electors are chosen), file with the Commission a full and complete financial statement, in such form and detail as it may prescribe, of the sources from which it derived its funds, and the purpose for which such funds were expended.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dae2997-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s305"},"text":"Pub. L. 92–225, title III, § 305","children":[],"tail":", formerly § 307, "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/16"},"text":"86 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tII/s208/c/6"},"text":"Pub. L. 93–443, title II, § 208(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1286"},"text":"88 Stat. 1286","children":[],"tail":"; renumbered § 305 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI"},"text":"Pub. L. 96–187, title I","children":[],"tail":", §§ 105(2), 112(a), "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1354"},"text":"93 Stat. 1354","children":[],"tail":", 1366.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dae2998-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dae2999-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0dae299a-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s437"},"text":"section 437 of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id0dae299b-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/s305"},"text":"section 305 of Pub. L. 92–225","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s435"},"text":"section 435 of Title 2","children":[],"tail":", The Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0dae299c-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" substituted “60” and “20” for “sixty” and “twenty”, respectively, and struck out “Federal Election” before “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" substituted “Federal Election Commission” and “it” for “Comptroller General of the United States” and “he”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dae299d-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dae299e-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","chi