{"tag":"section","attrib":{"id":"id0d9fd2fa-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21021"},"text":null,"children":[{"tag":"num","attrib":{"value":"21021"},"text":"§ 21021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to States and units of local government to assure access for individuals with disabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd2fb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall make a payment to each eligible State and each eligible unit of local government (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21023"},"text":"section 21023 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd2fc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible State and eligible unit of local government shall use the payment received under this subpart for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd2fd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making polling places, including the path of travel, entrances, exits, and voting areas of each polling facility, accessible to individuals with disabilities, including the blind and visually impaired, in a manner that provides the same opportunity for access and participation (including privacy and independence) as for other voters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd2fe-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing individuals with disabilities and the other individuals described in paragraph (1) with information about the accessibility of polling places, including outreach programs to inform the individuals about the availability of accessible polling places and training election officials, poll workers, and election volunteers on how best to promote the access and participation of individuals with disabilities in elections for Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd2ff-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21021/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":" (but in no event later than 6 months thereafter), and not less frequently than once each calendar year thereafter, the Secretary shall make payments under this subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd300-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s261"},"text":"Pub. L. 107–252, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1698"},"text":"116 Stat. 1698","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd301-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd302-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd303-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15421"},"text":"section 15421 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
