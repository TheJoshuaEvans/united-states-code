{"tag":"section","attrib":{"id":"id0db79fcb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124"},"text":null,"children":[{"tag":"num","attrib":{"value":"30124"},"text":"§ 30124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent misrepresentation of campaign authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0db79fcc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person who is a candidate for Federal office or an employee or agent of such a candidate shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db79fcd-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraudulently misrepresent himself or any committee or organization under his control as speaking or writing or otherwise acting for or on behalf of any other candidate or political party or employee or agent thereof on a matter which is damaging to such other candidate or political party or employee or agent thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db79fce-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully and knowingly participate in or conspire to participate in any plan, scheme, or design to violate paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0db79fcf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent solicitation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0db79fd0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fraudulently misrepresent the person as speaking, writing, or otherwise acting for or on behalf of any candidate or political party or employee or agent thereof for the purpose of soliciting contributions or donations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0db79fd1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully and knowingly participate in or conspire to participate in any plan, scheme, or design to violate paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0db79fd2-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s322"},"text":"Pub. L. 92–225, title III, § 322","children":[],"tail":", formerly § 327, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/283/tI/s112/2"},"text":"Pub. L. 94–283, title I, § 112(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-11"},"text":"May 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/494"},"text":"90 Stat. 494","children":[],"tail":"; renumbered § 322, "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI/s105/5"},"text":"Pub. L. 96–187, title I, § 105(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref",