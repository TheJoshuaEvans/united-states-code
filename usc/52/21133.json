{"tag":"section","attrib":{"id":"id0da48dad-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21133"},"text":null,"children":[{"tag":"num","attrib":{"value":"21133"},"text":"§ 21133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of property, records, and personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da48dae-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property and records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The contracts, liabilities, records, property, and other assets and interests of, or made available in connection with, the offices and functions of the Federal Election Commission which are transferred by this subchapter are transferred to the Election Assistance Commission for appropriate allocation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da48daf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da48db0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The personnel employed in connection with the offices and functions of the Federal Election Commission which are transferred by this subchapter are transferred to the Election Assistance Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da48db1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any full-time or part-time personnel employed in permanent positions shall not be separated or reduced in grade or compensation because of the transfer under this subsection during the 1-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da48db2-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVIII/s803"},"text":"Pub. L. 107–252, title VIII, § 803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1726"},"text":"116 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48db3-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48db4-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0da48db5-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this subtitle”, meaning subtitle A (§§ 801–804) of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1725"},"text":"116 Stat. 1725","children":[],"tail":". For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da48db6-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15533"},"text":"section 15533 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
