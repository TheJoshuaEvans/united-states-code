{"tag":"section","attrib":{"id":"id0d8a4e3a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310"},"text":null,"children":[{"tag":"num","attrib":{"value":"10310"},"text":"§ 10310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8a4e3b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal contempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All cases of criminal contempt arising under the provisions of chapters 103 to 107 of this title shall be governed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1995"},"text":"section 1995 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8a4e3c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts for declaratory judgment, restraining orders, or temporary or permanent injunction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No court other than the District Court for the District of Columbia shall have jurisdiction to issue any declaratory judgment pursuant to section 10303 or 10304 of this title or any restraining order or temporary or permanent injunction against the execution or enforcement of any provision of chapters 103 to 107 of this title or any action of any Federal officer or employee pursuant hereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8a4e3d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d8a4e3e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “vote” or “voting” shall include all action necessary to make a vote effective in any primary, special, or general election, including, but not limited to, registration, listing pursuant to this chapter, or other action required by law prerequisite to voting, casting a ballot, and having such ballot counted properly and included in the appropriate totals of votes cast with respect to candidates for public or party office and propositions for which votes are received in an election.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8a4e3f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “political subdivision” shall mean any county or parish, except that where registration for voting is not conducted under the supervision of a county or parish, the term shall include any other subdivision of a State which conducts registration for voting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d8a4e40-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “language minorities” or “language minority group” means persons who are American Indian, Asian American, Alaskan Natives or of Spanish heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8a4e41-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action for a declaratory judgment brought pursuant to section 10303 or 10304 of this title, subpenas for witnesses who are required to attend the District Court for the District of Columbia may be served in any judicial district of the United States: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no writ of subpena shall issue for witnesses without the District of Columbia at a greater distance than one hundred miles from the place of holding court without the permission of the District Court for the District of Columbia being first had upon proper application and cause shown."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8a4e42-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney’s fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any action or proceeding to enforce the voting guarantees of the fourteenth or fifteenth amendment, the court, in its discretion, may allow the prevailing party, other than the United States, a reasonable attorney’s fee, reasonable expert fees, and other reasonable litigation expenses as part of the costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8a4e43-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110/tI/s14"},"text":"Pub. L. 89–110, title I, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-06"},"text":"Aug. 6, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/445"},"text":"79 Stat. 445","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/91/285/s2"},"text":"Pub. L. 91–285, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-22"},"text":"June 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/314"},"text":"84 Stat. 314","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/73/tII/s207"},"text":"Pub. L. 94–73, title II, § 207","children":[],"tail":", title IV, § 402, "},{"tag":"date","attrib":{"date":"1975-08-06"},"text":"Aug. 6, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/402"},"text":"89 Stat. 402","children":[],"tail":", 404; "},{"tag":"ref","attrib":{"href":"/us/pl/109/246"},"text":"Pub. L. 109–246","children":[],"tail":", §§ 3(e)(3), 6, "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/580"},"text":"120 Stat. 580","children":[],"tail":", 581.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8a4e44-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8a4e45-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8a4e46-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 1973","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 42, The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d8a4e47-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/246/s3/e/3"},"text":"Pub. L. 109–246, § 3(e)(3)","children":[],"tail":", struck out “or a court of appeals in any proceeding under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s1973g"},"text":"section 1973g of this title","children":[],"tail":"” after “District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/246/s6"},"text":"Pub. L. 109–246, § 6","children":[],"tail":", inserted “, reasonable expert fees, and other reasonable litigation expenses” after “reasonable attorney’s fee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/73/s207"},"text":"Pub. L. 94–73, § 207","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/73/s402"},"text":"Pub. L. 94–73, § 402","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
