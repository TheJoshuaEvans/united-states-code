{"tag":"section","attrib":{"id":"id0d93eb21-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311"},"text":null,"children":[{"tag":"num","attrib":{"value":"20311"},"text":"§ 20311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d93eb22-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d93eb23-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absent uniformed services voter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “absent uniformed services voter” has the meaning given such term in section 107(1) of the Uniformed and Overseas Citizens Absentee Voting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff–6/1"},"text":"42 U.S.C. 1973ff–6(1)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20310/1"},"text":"52 U.S.C. 20310(1)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb24-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas voter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “overseas voter” has the meaning given such term in section 107(5) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20310/5"},"text":"52 U.S.C. 20310(5)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb25-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential designee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Presidential designee” means the individual designated under section 101(a) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301/a"},"text":"52 U.S.C. 20301(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93eb26-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d93eb27-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Presidential designee may establish 1 or more pilot programs under which the feasibility of new election technology is tested for the benefit of absent uniformed services voters and overseas voters claiming rights under the Uniformed and Overseas Citizens Absentee Voting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff"},"text":"42 U.S.C. 1973ff","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"52 U.S.C. 20301","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb28-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design and conduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The design and conduct of a pilot program established under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d93eb29-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be at the discretion of the Presidential designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d93eb2a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not conflict with or substitute for existing laws, regulations, or procedures with respect to the participation of absent uniformed services voters and military voters in elections for Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93eb2b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a pilot program established under subsection (b), the Presidential designee may consider the following issues:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d93eb2c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transmission of electronic voting material across military networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb2d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Virtual private networks, cryptographic voting systems, centrally controlled voting stations, and other information security techniques.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb2e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transmission of ballot representations and scanned pictures in a secure manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb2f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Capturing, retaining, and comparing electronic and physical ballot representations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb30-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilization of voting stations at military bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb31-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Document delivery and upload systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb32-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The functional effectiveness of the application or adoption of the pilot program to operational environments, taking into account environmental and logistical obstacles and State procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93eb33-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Presidential designee shall submit to Congress reports on the progress and outcomes of any pilot program conducted under this subsection, together with recommendations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d93eb34-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the conduct of additional pilot programs under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb35-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such legislation and administrative action as the Presidential designee determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93eb36-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d93eb37-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Election Assistance Commission and the National Institute of Standards and Technology shall provide the Presidential designee with best practices or standards in accordance with electronic absentee voting guidelines established under the first sentence of section 1604(a)(2) of the National Defense Authorization Act for Fiscal Year 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Public Law 107–107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/1277"},"text":"115 Stat. 1277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff"},"text":"42 U.S.C. 1973ff","children":[],"tail":" note [now "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20301"},"text":"52 U.S.C. 20301","children":[],"tail":" note]), as amended by section 567 of the Ronald W. Reagan National Defense Authorization Act for Fiscal Year 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Public Law 108–375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/118/1919"},"text":"118 Stat. 1919","children":[],"tail":") to support the pilot program or programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb38-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case in which the Election Assistance Commission has not established electronic absentee voting guidelines under such section 1604(a)(2), as so amended, by not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2009-10-28"},"text":"October 28, 2009","children":[],"tail":", the Election Assistance Commission shall submit to the relevant committees of Congress a report containing the following information:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d93eb39-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reasons such guidelines have not been established as of such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d93eb3a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed timeline for the establishment of such guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d93eb3b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed explanation of the Commission’s actions in establishing such guidelines since ","children":[{"tag":"date","attrib":{"date":"2004-10-28"},"text":"October 28, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d93eb3c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant committees of Congress defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “relevant committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d93eb3d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations, Armed Services, and Rules and Administration of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d93eb3e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations, Armed Services, and House Administration of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d93eb3f-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20311/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d93eb40-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s589"},"text":"Pub. L. 111–84, div. A, title V, § 589","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2334"},"text":"123 Stat. 2334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/d/6"},"text":"Pub. L. 111–383, div. A, title X, § 1075(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4373"},"text":"124 Stat. 4373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d93eb41-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d93eb42-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d93eb43-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniformed and Overseas Citizens Absentee Voting Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/410"},"text":"Pub. L. 99–410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-28"},"text":"Aug. 28, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/924"},"text":"100 Stat. 924","children":[],"tail":", which is classified principally to this chapter. Sections 101 and 107 of the Act are classified to sections 20301 and 20310, respectively, of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d93eb44-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ff–7"},"text":"section 1973ff–7 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification to this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Military and Overseas Voter Empowerment Act, and also as part of the National Defense Authorization Act for Fiscal Year 2010, and not as part of title I of the Uniformed and Overseas Citizens Absentee Voting Act, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0d93eb45-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/d/6/A"},"text":"Pub. L. 111–383, § 1075(d)(6)(A)","children":[],"tail":", substituted “section 107(1)” for “section 107(a)” and “1973ff–6(1)” for “1973ff et seq.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/d/6/B"},"text":"Pub. L. 111–383, § 1075(d)(6)(B)","children":[],"tail":", substituted “1973ff note” for “1977ff note”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d93eb46-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0d93eb47-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/d"},"text":"Pub. L. 111–383, div. A, title X, § 1075(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4372"},"text":"124 Stat. 4372","children":[],"tail":", provided that the amendment by section 1075(d)(6) is effective as of "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
