{"tag":"section","attrib":{"id":"id0d8cbfb4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10508"},"text":null,"children":[{"tag":"num","attrib":{"value":"10508"},"text":"§ 10508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting assistance for blind, disabled or illiterate persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any voter who requires assistance to vote by reason of blindness, disability, or inability to read or write may be given assistance by a person of the voter’s choice, other than the voter’s employer or agent of that employer or officer or agent of the voter’s union.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8cbfb5-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110/tII/s208"},"text":"Pub. L. 89–110, title II, § 208","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/205/s5"},"text":"Pub. L. 97–205, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-06-29"},"text":"June 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/135"},"text":"96 Stat. 135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8cbfb6-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8cbfb7-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8cbfb8-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href"