{"tag":"section","attrib":{"id":"id0d9b17ed-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922"},"text":null,"children":[{"tag":"num","attrib":{"value":"20922"},"text":"§ 20922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall serve as a national clearinghouse and resource for the compilation of information and review of procedures with respect to the administration of Federal elections by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9b17ee-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the duties described in subpart 3 of this part (relating to the adoption of voluntary voting system guidelines), including the maintenance of a clearinghouse of information on the experiences of State and local governments in implementing the guidelines and in operating voting systems in general;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17ef-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the duties described in part B of this subchapter (relating to the testing, certification, decertification, and recertification of voting system hardware and software);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17f0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the duties described in part C of this subchapter (relating to conducting studies and carrying out other activities to promote the effective administration of Federal elections);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17f1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the duties described in part D of this subchapter (relating to election assistance), and providing information and training on the management of the payments and grants provided under such part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17f2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the duties described in part B of subchapter III (relating to the adoption of voluntary guidance); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9b17f3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20922/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and carrying out the Help America Vote College Program under subchapter V.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9b17f4-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s202"},"text":"Pub. L. 107–252, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1673"},"text":"116 Stat. 1673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9b17f5-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9b17f6-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9b17f7-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15322"},"text":"section 15322 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
