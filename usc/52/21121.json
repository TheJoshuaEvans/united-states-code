{"tag":"section","attrib":{"id":"id0da48d8a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21121"},"text":null,"children":[{"tag":"num","attrib":{"value":"21121"},"text":"§ 21121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da48d8b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the appointment of its members, the Election Assistance Commission shall develop a program to be known as the “Help America Vote College Program” (hereafter in this subchapter referred to as the “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da48d8c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Program shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da48d8d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage students enrolled at institutions of higher education (including community colleges) to assist State and local governments in the administration of elections by serving as nonpartisan poll workers or assistants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da48d8e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s21121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage State and local governments to use the services of the students participating in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da48d8f-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tV/s501"},"text":"Pub. L. 107–252, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1717"},"text":"116 Stat. 1717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da48d90-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da48d91-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da48d92-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15521"},"text":"section 15521 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
