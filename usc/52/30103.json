{"tag":"section","attrib":{"id":"id0da96eaa-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103"},"text":null,"children":[{"tag":"num","attrib":{"value":"30103"},"text":"§ 30103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of political committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0da96eab-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements of organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each authorized campaign committee shall file a statement of organization no later than 10 days after designation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30102/e/1"},"text":"section 30102(e)(1) of this title","children":[],"tail":". Each separate segregated fund established under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30118/b"},"text":"section 30118(b) of this title","children":[],"tail":" shall file a statement of organization no later than 10 days after establishment. All other committees shall file a statement of organization within 10 days after becoming a political committee within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101/4"},"text":"section 30101(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da96eac-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The statement of organization of a political committee shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da96ead-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and type of committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da96eae-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, relationship, and type of any connected organization or affiliated committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da96eaf-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and position of the custodian of books and accounts of the committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da96eb0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the treasurer of the committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da96eb1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the committee is authorized by a candidate, the name, address, office sought, and party affiliation of the candidate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da96eb2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a listing of all banks, safety deposit boxes, or other depositories used by the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da96eb3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Change of information in statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any change in information previously submitted in a statement of organization shall be reported in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30102/g"},"text":"section 30102(g) of this title","children":[],"tail":" no later than 10 days after the date of the change."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0da96eb4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination, etc., requirements and authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0da96eb5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A political committee may terminate only when such a committee files a written statement, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s30102/g"},"text":"section 30102(g) of this title","children":[],"tail":", that it will no longer receive any contributions or make any disbursements and that such committee has no outstanding debts or obligations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0da96eb6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing contained in this subsection may be construed to eliminate or limit the authority of the Commission to establish procedures for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0da96eb7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of insolvency with respect to any political committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da96eb8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the orderly liquidation of an insolvent political committee, and the orderly application of its assets for the reduction of outstanding debts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0da96eb9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30103/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of an insolvent political committee after such liquidation and application of assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0da96eba-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225/tIII/s303"},"text":"Pub. L. 92–225, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/14"},"text":"86 Stat. 14","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tII"},"text":"Pub. L. 93–443, title II","children":[],"tail":", §§ 203, 208(c)(3), "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1276"},"text":"88 Stat. 1276","children":[],"tail":", 1286; "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tI/s103"},"text":"Pub. L. 96–187, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1347"},"text":"93 Stat. 1347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0da96ebb-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0da96ebc-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0da96ebd-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s433"},"text":"section 433 of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section. Some section numbers referenced in amendment notes below reflect the classification of such sections prior to their editorial reclassification to this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id0da96ebe-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" substituted provisions requiring each authorized campaign committee, each segregated fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s441b/b"},"text":"section 441b(b) of this title","children":[],"tail":", and all other committees to file a statement of organization 10 days after establishment for provisions requiring each political committee anticipating the receipt or expenditure during the calendar year of an amount exceeding $1,000 to file with the Commission a statement of organization within 10 days after organization or 10 days after receipt of information causing the anticipation of receipt or expenditure in excess of $1,000 and requiring each committee in existence on the date of enactment of this Act to file a statement of organization at such time as the Commission prescribes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" inserted “of a political committee” in introductory clause; in par. (1) inserted reference to type of committee; in par. (2) inserted reference to type of organization or affiliated committee; in par. (3) substituted provisions relating to the name, address and position of custodian of books and accounts for provisions relating to area, scope or jurisdiction of the committee; in par. (4) substituted provisions relating to the name and address of the treasurer for provisions relating to the name, address and position of the custodian of books and accounts; in par. (5) substituted provisions relating to the name, address, office sought and party affiliation of the candidate for provisions relating to the name, address and position of principal officers including officers of the finance committee; in par. (6) substituted provisions relating to listings of banks, safety deposit boxes, etc. for provisions relating to name and address, office sought and political affiliation of supported candidates, and struck out pars. (7) to (11) relating to other information."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" substituted “in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s432/g"},"text":"section 432(g) of this title","children":[],"tail":" no later than 10 days after the date of the change” for “to the Commission within a ten-day period following the change”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" redesignated existing provisions as par. (1), substituted provisions relating to termination of a political committee by written statement in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s432/g"},"text":"section 432(g) of this title","children":[],"tail":" for provisions relating to notification to the Commission in the event of disbandment or determination no longer to receive contributions during the calendar year of an amount exceeding $1,000, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" struck out subsec. (e) relating to filing of required reports and notifications with the appropriate principal campaign committee instead of the Commission in the case of a political committee which is not a principal campaign committee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s208/c/3/A"},"text":"Pub. L. 93–443, § 208(c)(3)(A)","children":[],"tail":", substituted “Commission” for “supervisory officer” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s208/c/3/B"},"text":"Pub. L. 93–443, § 208(c)(3)(B)","children":[],"tail":", substituted “it prescribes” for “he prescribes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443/s203"},"text":"Pub. L. 93–443, § 203","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0dabb8af-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dabb8b0-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/187"},"text":"Pub. L. 96–187","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/s301/a"},"text":"section 301(a) of Pub. L. 96–187","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id0dabb8b1-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/443"},"text":"Pub. L. 93–443","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1975-01-01"},"text":"Jan. 1, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/s410/a"},"text":"section 410(a) of Pub. L. 93–443","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
