{"tag":"section","attrib":{"id":"id0d8cbfa6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s10506"},"text":null,"children":[{"tag":"num","attrib":{"value":"10506"},"text":"§ 10506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of chapters 103 to 107 of this title or the application of any provision thereof to any person or circumstance is judicially determined to be invalid, the remainder of chapters 103 to 107 of this title or the application of such provision to other persons or circumstances shall not be affected by such determination.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id0d8cbfa7-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/110/tII/s206"},"text":"Pub. L. 89–110, title II, § 206","children":[],"tail":", formerly § 205, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/285/s6"},"text":"Pub. L. 91–285, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-22"},"text":"June 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/318"},"text":"84 Stat. 318","children":[],"tail":"; renumbered § 206, "},{"tag":"ref","attrib":{"href":"/us/pl/94/73/tIII/s302"},"text":"Pub. L. 94–73, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-08-06"},"text":"Aug. 6, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/403"},"text":"89 Stat. 403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8cbfa8-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8cbfa9-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editor