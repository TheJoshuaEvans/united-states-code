{"tag":"section","attrib":{"id":"id0d9fd253-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986"},"text":null,"children":[{"tag":"num","attrib":{"value":"20986"},"text":"§ 20986.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on free absentee ballot postage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9fd254-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study on the establishment of a free absentee ballot postage program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd255-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission, in consultation with the Postal Service, shall conduct a study on the feasibility and advisability of the establishment of a program under which the Postal Service shall waive or otherwise reduce the amount of postage applicable with respect to absentee ballots submitted by voters in general elections for Federal office (other than balloting materials mailed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3406"},"text":"section 3406 of title 39","children":[],"tail":") that does not apply with respect to the postage required to send the absentee ballots to voters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd256-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the study conducted under paragraph (1), the Commission shall conduct a survey of potential beneficiaries under the program described in such paragraph, including the elderly and disabled, and shall take into account the results of such survey in determining the feasibility and advisability of establishing such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd257-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9fd258-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-10-29"},"text":"October 29, 2002","children":[],"tail":", the Commission shall submit to Congress a report on the study conducted under subsection (a)(1) together with recommendations for such legislative and administrative action as the Commission determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd259-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report submitted under paragraph (1) shall contain an estimate of the costs of establishing the program described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd25a-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report submitted under paragraph (1) shall contain an analysis of the feasibility of implementing the program described in subsection (a)(1) with respect to the absentee ballots to be submitted in the general election for Federal office held in 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9fd25b-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations regarding the elderly and disabled","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9fd25c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include recommendations on ways that program described in subsection (a)(1) would target elderly individuals and individuals with disabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9fd25d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify methods to increase the number of such individuals who vote in elections for Federal office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9fd25e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20986/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal Service defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Postal Service” means the United States Postal Service established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s201"},"text":"section 201 of title 39","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9fd25f-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s246"},"text":"Pub. L. 107–252, title II, § 246","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1691"},"text":"116 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9fd260-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9fd261-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9fd262-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15386"},"text":"section 15386 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
