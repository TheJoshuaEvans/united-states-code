{"tag":"section","attrib":{"id":"id0d8cbfee-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20103"},"text":null,"children":[{"tag":"num","attrib":{"value":"20103"},"text":"§ 20103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of registration facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d8cbfef-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State or political subdivision responsible for registration for Federal elections shall provide a reasonable number of accessible permanent registration facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d8cbff0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to any State that has in effect a system that provides an opportunity for each potential voter to register by mail or at the residence of such voter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d8cbff1-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/435/s4"},"text":"Pub. L. 98–435, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-28"},"text":"Sept. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1679"},"text":"98 Stat. 1679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d8cbff2-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d8cbff3-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d8cbff4-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1973ee–2"},"text":"section 1973ee–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id0d8f2ff5-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id0d8f2ff6-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to elections taking place after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"Dec. 31, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/435/s9"},"text":"section 9 of Pub. L. 98–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s20101"},"text":"section 20101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
