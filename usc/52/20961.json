{"tag":"section","attrib":{"id":"id0d9d61a2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961"},"text":null,"children":[{"tag":"num","attrib":{"value":"20961"},"text":"§ 20961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Guidelines Development Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0d9d61a3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established the Technical Guidelines Development Committee (hereafter in this subpart referred to as the “Development Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d61a4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d61a5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Development Committee shall assist the Executive Director of the Commission in the development of the voluntary voting system guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d61a6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for initial set of recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Development Committee shall provide its first set of recommendations under this section to the Executive Director of the Commission not later than 9 months after all of its members have been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d61a7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d61a8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Development Committee shall be composed of the Director of the National Institute of Standards and Technology (who shall serve as its chair), together with a group of 14 other individuals appointed jointly by the Commission and the Director of the National Institute of Standards and Technology, consisting of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d61a9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An equal number of each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id0d9d61aa-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Standards Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9d61ab-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Board of Advisors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id0d9d61ac-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Architectural and Transportation Barrier Compliance Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s792"},"text":"section 792 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61ad-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the American National Standards Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61ae-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of the Institute of Electrical and Electronics Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61af-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives of the National Association of State Election Directors selected by such Association who are not members of the Standards Board or Board of Advisors, and who are not of the same political party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61b0-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other individuals with technical and scientific expertise relating to voting systems and voting equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d61b1-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Development Committee shall constitute a quorum, except that the Development Committee may not conduct any business prior to the appointment of all of its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d61b2-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No compensation for service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Development Committee shall not receive any compensation for their service, but shall be paid travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Development Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d61b3-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical support from National Institute of Standards and Technology","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id0d9d61b4-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the Development Committee, the Director of the National Institute of Standards and Technology shall provide the Development Committee with technical support necessary for the Development Committee to carry out its duties under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d61b5-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The technical support provided under paragraph (1) shall include intramural research and development in areas to support the development of the voluntary voting system guidelines under this subpart, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id0d9d61b6-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security of computers, computer networks, and computer data storage used in voting systems, including the computerized list required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s21083/a"},"text":"section 21083(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61b7-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to detect and prevent fraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61b8-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of voter privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61b9-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of human factors in the design and application of voting systems, including assistive technologies for individuals with disabilities (including blindness) and varying levels of literacy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id0d9d61ba-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote access voting, including voting through the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id0d9d61bb-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No private sector intellectual property rights in guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No private sector individual or entity shall obtain any intellectual property rights to any guideline or the contents of any guideline (or any modification to any guideline) adopted by the Commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0d9d61bc-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s20961/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of recommendations in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time the Commission adopts any voluntary voting system guideline pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t52/s20962"},"text":"section 20962 of this title","children":[],"tail":", the Development Committee shall cause to have published in the Federal Register the recommendations it provided under this section to the Executive Director of the Commission concerning the guideline adopted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0d9d61bd-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tII/s221"},"text":"Pub. L. 107–252, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1682"},"text":"116 Stat. 1682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0d9d61be-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0d9d61bf-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id0d9d61c0-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e)(3), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1666"},"text":"116 Stat. 1666","children":[],"tail":", known as the Help America Vote Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0d9d61c1-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15361"},"text":"section 15361 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
