{"tag":"section","attrib":{"id":"id0dba114c-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30146"},"text":null,"children":[{"tag":"num","attrib":{"value":"30146"},"text":"§ 30146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and use of conference fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id0dba114d-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30146/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Election Commission may charge and collect fees for attending or otherwise participating in a conference sponsored by the Commission, and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any amounts received from such fees during a fiscal year shall be credited to and merged with the amounts appropriated or otherwise made available to the Commission during the year, and shall be available for use during the year for the costs of sponsoring such conferences."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id0dba114e-2931-11f1-afae-ea39e71ac6b0","identifier":"/us/usc/t52/s30146/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply with respect to fiscal year 2007 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id0dba114f-2931-11f1-afae-ea39e71ac6b0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/289/dB/tII/s21078"},"text":"Pub. L. 109–289, div. B, title II, § 21078","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/5/s2"},"text":"Pub. L. 110–5, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-02-15"},"text":"Feb. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/59"},"text":"121 Stat. 59","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id0dba1150-2931-11f1-afae-ea39e71ac6b0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id0dba1151-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id0dba1152-2931-11f1-afae-ea39e71ac6b0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s457"},"text":"section 457 of Title 2","children":[],"tail":", The Congress, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Continuing Appropriations Resolution, 2007, and not as part of the Federal Election Campaign Act of 1971 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
