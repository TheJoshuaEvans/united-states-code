{"tag":"section","attrib":{"id":"idaa32c234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707"},"text":null,"children":[{"tag":"num","attrib":{"value":"3707"},"text":"§ 3707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest and penalties for certain overpayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa32c235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the United States makes an overpayment to a contractor under a contract subject to this chapter and the overpayment was due to the submission by the contractor of defective cost or pricing data, the contractor shall be liable to the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for interest on the amount of such overpayment, to be computed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa32c237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the period beginning on the date the overpayment was made to the contractor and ending on the date the contractor repays the amount of such overpayment to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa32c238-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the current rate prescribed by the Secretary of the Treasury under section 6621 of the Internal Revenue Code of 1986; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the submission of such defective data was a knowing submission, for an additional amount equal to the amount of the overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa32c23a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability Not Affected by Refusal to Submit Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any liability under this section of a contractor that submits cost or pricing data but refuses to submit the certification required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3702/b"},"text":"section 3702(b) of this title","children":[],"tail":" with respect to the cost or pricing data shall not be affected by the refusal to submit such certification."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa32c23b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1831/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1831(a)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4209"},"text":"134 Stat. 4209","children":[],"tail":", 4216; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/10/H"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(10)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2134"},"text":"135 Stat. 2134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa32c23c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa32c23d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa32c23e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6621 of the Internal Revenue Code of 1986, referred to in subsec. (a)(1)(B), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa32c23f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306a"},"text":"section 2306a of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1831/h"},"text":"Pub. L. 116–283, § 1831(h)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s952/a"},"text":"Pub. L. 99–500, § 101(c) [title X, § 952(a)]","child