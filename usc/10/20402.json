{"tag":"section","attrib":{"id":"idabccea35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402"},"text":null,"children":[{"tag":"num","attrib":{"value":"20402"},"text":"§ 20402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: standards and qualifications for retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards and Qualifications for Retention","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force shall, by regulation, prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and qualifications for the retention of enlisted members of the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable procedures for the periodic determination of the compliance of each such member with those standards and qualifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Failure to Comply With Standards and Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an enlisted member serving in Space Force active status fails to comply with the standards and qualifications prescribed under subsection (a), the member shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if qualified, be transferred to Space Force inactive status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if qualified, be retired in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20603"},"text":"section 20603 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the member’s enlistment terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1718/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/656"},"text":"137 Stat. 656","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
