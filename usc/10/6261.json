{"tag":"section","attrib":{"id":"idaac90f4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261"},"text":null,"children":[{"tag":"num","attrib":{"value":"6261"},"text":"§ 6261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Worker protection at nuclear weapons facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90f4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Grant Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90f4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Energy is authorized to award grants to organizations referred to in paragraph (2) in order for such organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90f4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training and education to persons who are or may be engaged in hazardous substance response or emergency response at Department of Energy nuclear weapons facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90f4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop curricula for such training and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90f51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subparagraph (B), the Secretary is authorized to award grants under paragraph (1) to non-profit organizations that have demonstrated (as determined by the Secretary) capabilities in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac90f52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing and conducting effective training and education programs relating to the general health and safety of workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac90f53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, and involving in training, groups of workers whose duties include hazardous substance response or emergency response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90f54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall give preference in the award of grants under this section to employee organizations and joint labor-management training programs that are grant recipients under section 126(g) of the Superfund Amendments and Reauthorization Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9660a"},"text":"42 U.S.C. 9660a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An organization awarded a grant under paragraph (1) shall carry out training, education, or curricula development pursuant to Department of Energy orders relating to employee safety training, including orders numbered 5480.4 and 5480.11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90f56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement of Employee Safety Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90f57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the Secretary shall assess civil penalties against any contractor of the Department of Energy who (as determined by the Secretary)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90f58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs individuals who are engaged in hazardous substance response or emergency response at Department of Energy nuclear weapons facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90f59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails (i) to provide for the training of such individuals to carry out such hazardous substance response or emergency response, or (ii) to certify to the Department of Energy that such employees are adequately trained for such response pursuant to orders issued by the Department of Energy relating to employee safety training (including orders numbered 5480.4 and 5480.11).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil penalties assessed under this subsection may not exceed $5,000 for each day in which a failure referred to in paragraph (1)(B) occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90f5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90f5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6261/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, the term “hazardous substance” includes radioactive waste and mixed radioactive and hazardous waste.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90f5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1419"},"text":"139 Stat. 1419","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90f5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90f5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90f60-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2731"},"text":"section 2731 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac90f61-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
