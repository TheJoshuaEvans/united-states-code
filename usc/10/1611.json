{"tag":"section","attrib":{"id":"ida901959f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611"},"text":null,"children":[{"tag":"num","attrib":{"value":"1611"},"text":"§ 1611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postemployment assistance: certain terminated intelligence employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90195a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the Secretary of Defense may, in the case of any individual who is a qualified former intelligence employee, use appropriated funds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist that individual in finding and qualifying for employment other than in a defense intelligence position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist that individual in meeting the expenses of treatment of medical or psychological disabilities of that individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financial support to that individual during periods of unemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified Former Intelligence Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a qualified former intelligence employee is an individual who was employed as a civilian employee of the Department of Defense in a sensitive defense intelligence position—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been found to be ineligible for continued access to information designated as “Sensitive Compartmented Information” and employment in a defense intelligence position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose employment in a defense intelligence position has been terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance may be provided to a qualified former intelligence employee under subsection (a) only if the Secretary determines that such assistance is essential to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the judgment and emotional stability of the qualified former intelligence employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoid circumstances that might lead to the unlawful disclosure of classified information to which the qualified former intelligence employee had access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance may not be provided under this section in the case of any individual after the end of the five-year period beginning on the date of the termination of the employment of the individual in a defense intelligence position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90195ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359/tVIII/s806/a/1"},"text":"Pub. L. 103–359, title VIII, § 806(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3441"},"text":"108 Stat. 3441","children":[],"tail":", § 1599; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/11"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/503"},"text":"110 Stat. 503","children":[],"tail":"; renumbered § 1611 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/c"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2749"},"text":"110 Stat. 2749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1141(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–318; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/a/15"},"text":"Pub. L. 107–107, div. A, title X, § 1048(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1223"},"text":"115 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s811/b/4/B"},"text":"Pub. L. 107–306, title VIII, § 811(b)(4)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2423"},"text":"116 Stat. 2423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s361/h"},"text":"Pub. L. 108–177, title III, § 361(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2625"},"text":"117 Stat. 2625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90195ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90195ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida90195ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1604/e/4"},"text":"section 1604(e)(4) of this title","children":[],"tail":" and in "},{"tag":"ref","attrib":{"href":"/us/pl/86/36/s17"},"text":"section 17 of Pub. L. 86–36","children":[],"tail":" as added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s503"},"text":"Pub. L. 102–88, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/436"},"text":"105 Stat. 436","children":[],"tail":", which was formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"section 402 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/s806/b"},"text":"Pub. L. 103–359, § 806(b)","children":[],"tail":", and editorial reclassification to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3615"},"text":"section 3615 of Title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90195af-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177"},"text":"Pub. L. 108–177","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Secretary of Defense shall submit to the congressional committees specified in paragraph (3) an annual report with respect to any expenditure made under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) In the case of a report required to be submitted under paragraph (1) to the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives, the date for the submittal of such report shall be as provided in section 507 of the National Security Act of 1947.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The committees referred to in paragraph (1) are the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) The Committee on Armed Services, the Committee on Appropriations, and the Permanent Select Committee on Intelligence of the House of Representatives.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The Committee on Armed Services, the Committee on Appropriations, and the Select Committee on Intelligence of the Senate.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/4/B/i"},"text":"Pub. L. 107–306, § 811(b)(4)(B)(i)","children":[],"tail":", substituted “paragraph (3)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/4/B/ii"},"text":"Pub. L. 107–306, § 811(b)(4)(B)(ii)","children":[],"tail":", (iii), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" struck out “with” before “in a defense intelligence position”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1141(b)(1)], substituted “a defense intelligence position” for “an intelligence component of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1141(b)(2)], substituted “sensitive defense intelligence position” for “sensitive position in an intelligence component of the Department of Defense” in introductory provisions and “in a defense intelligence position” for “with the intelligence component” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1141(b)(3)], substituted “in a defense intelligence position” for “an intelligence component of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1141(b)(4)], struck out heading and text of subsec. (f). Text read as follows: “In this section, the term ‘intelligence component of the Department of Defense’ includes the National Reconnaissance Office and any intelligence component of a military department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599"},"text":"section 1599 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/a/11/A"},"text":"Pub. L. 104–106, § 1502(a)(11)(A)","children":[],"tail":", substituted “The Committee on National Security, the Committee on Appropriations,” for “The Committees on Armed Services and Appropriations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/a/11/B"},"text":"Pub. L. 104–106, § 1502(a)(11)(B)","children":[],"tail":", substituted “The Committee on Armed Services, the Committee on Appropriations,” for “The Committees on Armed Services and Appropriations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “includes the National Reconnaissance Office and any intelligence component of a military department.” for “means any of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The National Security Agency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Defense Intelligence Agency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The National Reconnaissance Office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The Central Imagery Office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) The intelligence components of any of the military departments.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90195b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90195b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s361/n"},"text":"Pub. L. 108–177, title III, § 361(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2626"},"text":"117 Stat. 2626","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/177/tIII/s361/n"},"text":"“The amendments made by this section [amending this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681b"},"text":"section 1681b of Title 15","children":[],"tail":", Commerce and Trade, and sections 2366, 3038, 3047, 3050, 3106, and 3381 of Title 50, War and National Defense, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s540C"},"text":"section 540C of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and repealing provisions set out as notes under sections 3036 and 3381 of Title 50] shall take effect on "},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"December 31, 2003","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90195b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
