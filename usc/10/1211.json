n":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1211(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:276(a)(1) (8th through 22d words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:276(a)(2) (less 1st 18 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:276(a)(3) (less 1st 10 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1211(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:275(c) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:277 (less (a)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1211(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:275(c) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1210/f"},"text":"section 1210(f) of this title","children":[],"tail":"” are substituted for the words “If, as a result of a periodic physical examination”, in 37:275(a) and (b), and 276(a), and the words “and who are subsequently found to be physically fit”, in 37:277(a). The words “subject to the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s277"},"text":"section 277 of this title","children":[],"tail":"”, in 37:275(a), are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(2)–(6) and (b)(2)–(6), the appointment or enlistment is restricted to those already in an enlisted, warrant, or commissioned status, as the case may be, held by the member before placement of his name on the temporary disability retired list, since 37:277 (last sentence) indicates that appointment in the next higher grade for regular warrant officer is restricted to those warrant grades to which the President alone may appoint him. Similarly 37:275 (last 10 words) indicates that an enlisted member may only be reenlisted.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2) reference to the President, in 37:277(a), is omitted as inapplicable to the appointment of warrant officers of the Army and the Air Force.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(5) is substituted for 37:275(b) (proviso) (as applicable to Army and Air Force).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(6) is inserted, since the words “reserve component” are defined by section 102(k) of the source statute to include members of the Army and the Air Force who have no component status.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “by and with the advice and consent of the Senate” are added to make it clear that all appointments to the grade of commissioned warrant officer in the Navy, Marine Corps, and Coast Guard require Senate confirmation. Although these words do not appear in section 405 of the Career Compensation Act of 1949, there is no indication that an exception to the basic law relating to appointments in commissioned grades was intended.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d)(3) is made applicable to members without component status, since the words “reserve component” are defined in section 102(k) of the source statute to include members of the Army and the Air Force who have no component status.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “rank” and “rating” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b068f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The changes correct typographical errors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b068f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b068f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/24/A"},"text":"Pub. L. 116–283, § 924(b)(24)(A)","children":[],"tail":", substituted “, the Air Force, or the Space Force” for “or the Air Force” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/24/B"},"text":"Pub. L. 116–283, § 924(b)(24)(B)","children":[],"tail":", substituted “the Air Force, or the Space Force who” for “or the Air Force, who” and “the Air Force, or the Space Force, as” for “or the Air Force, as”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted “an approved all-fully-qualified-officers list,” after “a promotion list,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" inserted “and if the member is not discharged, retired, or transferred to the Fleet Reserve or Fleet Marine Corps Reserve or inactive Reserve under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1210"},"text":"section 1210 of this title","children":[],"tail":",” after “proposed under subsection (a) or (b),” and inserted “and the member shall be discharged” after “as soon as practicable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “active-duty list” for “active list of his regular component”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651"},"text":"Pub. L. 87–651","children":[],"tail":" substituted “subsection (b)(1) or (2)” for “subsection (b)(1), (2), or (3)” in cl. (1), and “subsection (b)(4)” for “subsection (b)(5)” in cl. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b068f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8b068f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida8b068f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
