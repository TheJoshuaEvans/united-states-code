{"tag":"section","attrib":{"id":"ida8289b65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a"},"text":null,"children":[{"tag":"num","attrib":{"value":"893a"},"text":"§ 893a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 93a. Prohibited activities with military recruit or trainee by person in position of special trust","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8289b66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abuse of Training Leadership Position","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289b67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an officer, a noncommissioned officer, or a petty officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is in a training leadership position with respect to a specially protected junior member of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who engages in prohibited sexual activity with such specially protected junior member of the armed forces;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8289b6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abuse of Position as Military Recruiter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289b6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a military recruiter and engages in prohibited sexual activity with an applicant for military service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a military recruiter and engages in prohibited sexual activity with a specially protected junior member of the armed forces who is enlisted under a delayed entry program;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8289b6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consent is not a defense for any conduct at issue in a prosecution under this section (article).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8289b6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section (article):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289b6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specially protected junior member of the armed forces","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “specially protected junior member of the armed forces” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8289b70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces who is assigned to, or is awaiting assignment to, basic training or other initial active duty for training, including a member who is enlisted under a delayed entry program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8289b71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces who is a cadet, a midshipman, an officer candidate, or a student in any other officer qualification program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8289b72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces in any program that, by regulation prescribed by the Secretary concerned, is identified as a training program for initial career qualification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training leadership position","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “training leadership position” means, with respect to a specially protected junior member of the armed forces, any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8289b74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any drill instructor position or other leadership position in a basic training program, an officer candidate school, a reserve officers’ training corps unit, a training program for entry into the armed forces, or any program that, by regulation prescribed by the Secretary concerned, is identified as a training program for initial career qualification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8289b75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Faculty and staff of the United States Military Academy, the United States Naval Academy, the United States Air Force Academy, and the United States Coast Guard Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicant for military service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “applicant for military service” means a person who, under regulations prescribed by the Secretary concerned, is an applicant for original enlistment or appointment in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military recruiter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “military recruiter” means a person who, under regulations prescribed by the Secretary concerned, has the primary duty to recruit persons for military service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s893a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited sexual activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “prohibited sexual activity” means, as specified in regulations prescribed by the Secretary concerned, inappropriate physical intimacy under circumstances described in such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8289b79-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5410"},"text":"Pub. L. 114–328, div. E, title LX, § 5410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2942"},"text":"130 Stat. 2942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8289b7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8289b7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8289b7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
