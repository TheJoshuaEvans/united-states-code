{"tag":"section","attrib":{"id":"idaa77e172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376"},"text":null,"children":[{"tag":"num","attrib":{"value":"4376"},"text":"§ 4376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach of critical cost growth threshold: reassessment of program; presumption of program termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa77e173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reassessment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the program acquisition unit cost or procurement unit cost of a major defense acquisition program or designated subprogram (as determined by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4374"},"text":"section 4374 of this title","children":[],"tail":") increases by a percentage equal to or greater than the critical cost growth threshold for the program or subprogram, the Secretary of Defense shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa77e174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the root cause or causes of the critical cost growth in accordance with applicable statutory requirements and Department of Defense policies, procedures, and guidance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with the Director of Cost Assessment and Program Evaluation, carry out an assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa77e176-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cost of completing the program if current requirements are not modified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e177-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected cost of completing the program based on reasonable modification of such requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e178-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rough order of magnitude of the costs of any reasonable alternative system or capability; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e179-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to reduce funding for other programs due to the growth in cost of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa77e17a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption of Termination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa77e17b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination unless secretary submits certification and report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After conducting the reassessment required by subsection (a) with respect to a major defense acquisition program, the Secretary shall terminate the program unless the Secretary submits to Congress, before the end of the 60-day period beginning on the day the Selected Acquisition Report containing the information described in section 4375(d) and (e) of this title is required to be submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/f"},"text":"section 4351(f) of this title","children":[],"tail":", a written certification in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e17c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certification described by this paragraph with respect to a major defense acquisition program is a written certification that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa77e17d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuation of the program is essential to the national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e17e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are no alternatives to the program which will provide acceptable capability at less cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e17f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the new estimates of the program acquisition unit cost or procurement unit cost have been determined by the Director of Cost Assessment and Program Evaluation to be reasonable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e180-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program is a higher priority than programs whose funding must be reduced to accommodate the growth in cost of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa77e181-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management structure for the program is adequate to manage and control program acquisition unit cost or procurement unit cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e182-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A written certification under paragraph (2) shall be accompanied by a report presenting the root cause analysis and assessment carried out pursuant to subsection (a) and the basis for each determination made in accordance with subparagraphs (A) through (E) of paragraph (2), together with supporting documentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa77e183-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions if Program Terminated","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a major defense acquisition program is terminated pursuant to subsection (b), the Secretary shall submit to Congress a written report setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa77e184-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the reasons for terminating the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e185-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternatives considered to address any problems in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa77e186-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4376/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the course the Department plans to pursue to meet any continuing military requirements otherwise intended to be met by the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa77e187-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1850/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1850(a)","children":[],"tail":", (j), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4265"},"text":"134 Stat. 4265","children":[],"tail":", 4269; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(E)(v), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2148"},"text":"135 Stat. 2148","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1811/g/4"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1811(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1243"},"text":"139 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa77e188-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa77e189-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa77e18a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsecs. (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433a"},"text":"section 2433a of this title","children":[],"tail":", which was transferred to this section by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/1"},"text":"Pub. L. 116–283, § 1850(j)(1)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/tII/s206/a/1"},"text":"Pub. L. 111–23, title II, § 206(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1726"},"text":"123 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/35"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4371"},"text":"124 Stat. 4371","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433a"},"text":"section 2433a of this title","children":[],"tail":", which was transferred to this section and redesignated subsec. (c) by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/2"},"text":"Pub. L. 116–283, § 1850(j)(2)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/tII/s206/a/1"},"text":"Pub. L. 111–23, title II, § 206(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1726"},"text":"123 Stat. 1726","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa77e18b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1811/g/4/A"},"text":"Pub. L. 119–60, § 1811(g)(4)(A)","children":[],"tail":", struck out “, after consultation with the Joint Requirements Oversight Council regarding program requirements,” after “Secretary of Defense” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1811/g/4/B"},"text":"Pub. L. 119–60, § 1811(g)(4)(B)","children":[],"tail":", struck out “to meet the joint military requirement (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s181/g/1"},"text":"section 181(g)(1) of this title","children":[],"tail":")” after “capability”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1811/g/4/C"},"text":"Pub. L. 119–60, § 1811(g)(4)(C)","children":[],"tail":", struck out “joint” before “military requirements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/1"},"text":"Pub. L. 116–283, § 1850(j)(1)","children":[],"tail":", (2), transferred subsecs. (a), (b), and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433a"},"text":"section 2433a of this title","children":[],"tail":" to this section and redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/3/A"},"text":"Pub. L. 116–283, § 1850(j)(3)(A)","children":[],"tail":", substituted “section 4374” for “section 2433(d)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/4/A"},"text":"Pub. L. 116–283, § 1850(j)(4)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/3/B"},"text":"Pub. L. 116–283, § 1850(j)(3)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701"},"text":"Pub. L. 117–81, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(E)(v), substituted “section 4375(d) and (e)” for “section 2433(g)” and “section 4351(f)” for “section 2432(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1850/j/4/B"},"text":"Pub. L. 116–283, § 1850(j)(4)(B)","children":[],"tail":"–(D), realigned margins and inserted headings."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa77e18c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa77e18d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa77e18e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
