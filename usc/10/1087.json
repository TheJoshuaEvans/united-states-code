{"tag":"section","attrib":{"id":"ida887f84a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087"},"text":null,"children":[{"tag":"num","attrib":{"value":"1087"},"text":"§ 1087.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programing facilities for certain members, former members, and their dependents in construction projects of the uniformed services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida887f84b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Space for inpatient and outpatient care may be programed in facilities of the uniformed services for persons covered by sections 1074(b) and 1076(b) of this title. The maximum amount of space that may be so programed for a facility is the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida887f84c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of space that would be so programed for the facility in order to meet the requirements to be placed on the facility for support of the teaching and training of health-care professionals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida887f84d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of space that would be so programed for the facility based upon the most cost-effective provision of inpatient and outpatient care to persons covered by sections 1074(b) and 1076(b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida887f84e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida887f84f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In making determinations for the purposes of clauses (1) and (2) of subsection (a), the Secretary concerned shall take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida887f850-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of space that would be so programed for the facility based upon projected inpatient and outpatient workloads at the facility for persons covered by sections 1074(b) and 1076(b) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida887f851-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated capability of the medical and dental staff of the facility, determined in accordance with regulations prescribed by the Secretary of Defense and based upon realistic projections of the number of physicians and other health-care providers that it can reasonably be expected will be assigned to or will otherwise be available to the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida887f852-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1087/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition, a determination made for the purpose of clause (2) of subsection (a) shall be made in accordance with an economic analysis (including a life-cycle cost analysis) of the facility and consideration of all reasonable and available medical care treatment alternatives (including treatment provided under a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1086"},"text":"section 1086 of this title","children":[],"tail":" or under part A of title XVIII of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida887f853-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/614/s2/7"},"text":"Pub. L. 89–614, § 2(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"Sept. 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/866"},"text":"80 Stat. 866","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/337/s1"},"text":"Pub. L. 97–337, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1631"},"text":"96 Stat. 1631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/24"},"text":"Pub. L. 98–525, title XIV, § 1405(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2623"},"text":"98 Stat. 2623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/a/4"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3992"},"text":"100 Stat. 3992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida887f854-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida887f855-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida887f856-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of Title 42, The Public Health and Welfare. Part A of title XVIII of the Social Security Act, is classified generally to Part A (§ 1395c et seq.) of subchapter XVIII of chapter 7 of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida887f857-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" substituted “Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.))” for “Act. ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" which directed that “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.)” be inserted after “the Social Security Act.”, was executed by inserting parenthetical after “the Social Security Act” to reflect the probable intent of Congress. See 1986 Amendment note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/337/s1/1"},"text":"Pub. L. 97–337, § 1(1)","children":[],"tail":", designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/337/s1/2"},"text":"Pub. L. 97–337, § 1(2)","children":[],"tail":", substituted provisions limiting the maximum amount of space to be programed as the greater of the amounts of space described in par. (1) or (2) for provisions limiting the amount of space to be programed to that amount needed to support teaching and training requirements, except that space may be programed in areas having large concentrations of retired members where there is a critical shortage of facilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/337/s1/2"},"text":"Pub. L. 97–337, § 1(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida887f858-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida887f859-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/337/s2"},"text":"Pub. L. 97–337, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1632"},"text":"96 Stat. 1632","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/337/s2"},"text":"“The amendment made by paragraph (2) of the first section of this Act [amending this section] shall apply only with respect to a facility for which funds for construction (or a major alteration) are first appropriated for a fiscal year after fiscal year 1983.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida887f85a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/614/s3"},"text":"section 3 of Pub. L. 89–614","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1071"},"text":"section 1071 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
