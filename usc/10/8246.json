{"tag":"section","attrib":{"id":"idab155a8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8246"},"text":null,"children":[{"tag":"num","attrib":{"value":"8246"},"text":"§ 8246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsistence in hospital messes: hospital ration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab155a90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8246/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members of the naval service on duty in hospitals and enlisted members of the naval service, including retired members and members of the Fleet Reserve and the Fleet Marine Corps Reserve, when sick in hospitals, may be subsisted in hospital messes. When subsistence is furnished under this subsection, the appropriation chargeable with the maintenance of the hospital mess shall be credited at the rate prescribed by the Secretary of the Navy as the value of the hospital ration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab155a91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8246/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary prescribes, officers in the Nurse Corps may be subsisted in hospital messes. Each officer so subsisted shall pay for her subsistence at the rate fixed by the regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab155a92-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/380"},"text":"70A Stat. 380","children":[],"tail":", § 6086; renumbered § 8246, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/8"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab155a93-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab155a94-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab155a95-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6086","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s901a"},"text":"34 U.S.C. 901a","children":[],"tail":" (less 1st and 2d sentences)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch756/s17/a"},"text":"Aug. 2, 1946, ch. 756, § 17(a)","children":[],"tail":" (less 1st and 2d sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/855"},"text":"60 Stat. 855","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s43h/a"},"text":"34 U.S.C. 43h(a)","children":[],"tail":" (1st 21 words of 2d proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-04-16/ch38/s208/a"},"text":"Apr. 16, 1947, ch. 38, § 208(a)","children":[],"tail":" (1st 25 words of 2d proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/50"},"text":"61 Stat. 50","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “active duty” before the words “enlisted personnel” are omitted as surplusage since there is no authority to hospitalize an enlisted member in a naval hospital under conditions where he would not be entitled to a hospital ration. The words “active and inactive” before the words “retired enlisted personnel” are omitted as surplusage. The word “members” is substituted for the word “personnel” for uniformity. The words “the Fleet Marine Corps Reserve” are inserted for clarity since the term “Fleet Reserve” in the source statute is used in a generic sense and includes members of the Fleet Marine Corps Reserve.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “that nothing contained in this section shall deprive such nurses of allowances for subsistence now or after ","children":[{"tag":"date","attrib":{"date":"1946-08-02"},"text":"August 2, 1946","children":[],"tail":", provided by law” are omitted as surplusage. Section 301 of the Career Compensation Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s251"},"text":"37 U.S.C. 251","children":[],"tail":") authorizes a basic allowance for subsistence for all officers entitled to basic pay."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab155a96-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab155a97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6086"},"text":"section 6086 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab155a98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab155a99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
