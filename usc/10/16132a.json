{"tag":"section","attrib":{"id":"idabbc4917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16132a"},"text":"§ 16132a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to transfer unused education benefits to family members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabbc4918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to regulation prescribed by the Secretary of Defense, the Secretary concerned may permit a member described in subsection (b) who is entitled to basic educational assistance under this chapter to elect to transfer to one or more of the dependents specified in subsection (c) a portion of such member’s entitlement to such assistance, subject to the limitation under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbc4919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member referred to in subsection (a) is a member of the Selected Reserve of the Ready Reserve who, at the time of the approval of the member’s request to transfer entitlement to basic educational assistance under this section, has completed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbc491a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least six years of service in the Selected Reserve and enters into an agreement to serve at least four more years as a member of the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbc491b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service as determined in regulations pursuant to subsection (j).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbc491c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member approved to transfer an entitlement to basic educational assistance under this section may transfer the member’s entitlement as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbc491d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the member’s spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbc491e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To one or more of the member’s children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbc491f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To a combination of the individuals referred to in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbc4920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Months of Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total number of months of entitlement transferred by a member under this section may not exceed 36 months. The Secretary of Defense may prescribe regulations that would limit the months of entitlement that may be transferred under this section to no less than 18 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9211-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Transferee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member transferring an entitlement to basic educational assistance under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe9212-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the dependent or dependents to whom such entitlement is being transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9213-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the number of months of such entitlement to be transferred to each such dependent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9214-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the period for which the transfer shall be effective for each dependent designated under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9215-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Transfer; Revocation and Modification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe9216-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the time limitation for use of entitlement under section 16133, a member approved to transfer entitlement to basic educational assistance under this section may transfer such entitlement at any time after the approval of the member’s request to transfer such entitlement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9217-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member transferring entitlement under this section may modify or revoke at any time the transfer of any unused portion of the entitlement so transferred. The modification or revocation of the transfer of entitlement under this paragraph shall be made by the submittal of written notice of the action to both the Secretary concerned and the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9218-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entitlement transferred under this section may not be treated as marital property, or the asset of a marital estate, subject to division in a divorce or other civil proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9219-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement of Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dependent to whom entitlement to basic educational assistance is transferred under this section may not commence the use of the transferred entitlement until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe921a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of entitlement transferred to a spouse, the completion by the member making the transfer of at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabbe921b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six years of service in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbe921c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service as determined in regulations pursuant to subsection (j); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe921d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of entitlement transferred to a child, both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabbe921e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the completion by the member making the transfer of at least—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabbe921f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ten years of service in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabbe9220-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service as determined in regulations pursuant to subsection (j); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbe9221-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabbe9222-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the completion by the child of the requirements of a secondary school diploma (or equivalency certificate); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabbe9223-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attainment by the child of 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9224-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Administrative Matters","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe9225-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of any entitlement to basic educational assistance transferred under this section shall be charged against the entitlement of the member making the transfer at the rate of one month for each month of transferred entitlement that is used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9226-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subsection (e)(2) and subject to paragraphs (5) and (6), a dependent to whom entitlement is transferred under this section is entitled to basic educational assistance under this chapter in the same manner as the member from whom the entitlement was transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9227-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly rate of educational assistance payable to a dependent to whom entitlement is transferred under this section shall be the monthly amount payable under sections 16131 and 16131a to the member making the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9228-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The death of a member transferring an entitlement under this section shall not affect the use of the entitlement by the dependent to whom the entitlement is transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9229-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The involuntary separation or retirement of the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabbe922a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of a nondiscretionary provision of law for age or years of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbe922b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of a policy prescribed by the Secretary concerned mandating such separation or retirement based solely on age or years of service for the prescribed pay grade of an enlisted member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbe922c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 16133(b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbe922d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of medical disqualification which is not the result of gross negligence or misconduct of the member,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not affect the use of entitlement by the dependent to whom the entitlement is transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe922e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A child to whom entitlement is transferred under this section may not use any entitlement so transferred after attaining the age of 26 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe922f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administrative provisions of this chapter shall apply to the use of entitlement transferred under this section, except that the dependent to whom the entitlement is transferred shall be treated as the eligible member for purposes of such provisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9230-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/h/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purposes for which a dependent to whom entitlement is transferred under this section may use such entitlement shall include the pursuit and completion of the requirements of a secondary school diploma (or equivalency certificate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9231-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overpayment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe9232-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of an overpayment of basic educational assistance with respect to a dependent to whom entitlement is transferred under this section, the dependent and the member making the transfer shall be jointly and severally liable to the United States for the amount of the overpayment for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3685"},"text":"section 3685 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), if a member’s eligibility is terminated under section 16134(2), the amount of any transferred entitlement under this section that is used by a dependent of the member as of the date of such termination shall be treated as an overpayment of basic educational assistance under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (2) shall not apply in the case of a member who fails to complete service agreed to by the member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabbe9235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of the death of the member; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbe9236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a reason referred to in section 16133(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbe9237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, in consultation with the Secretary of Veterans Affairs, shall prescribe regulations for purposes of this section. Such regulations shall specify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbe9238-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner of authorizing the military departments to offer transfer of entitlements under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe9239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility criteria in accordance with subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe923a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner and effect of an election to modify or revoke a transfer of entitlement under subsection (f)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbe923b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132a/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the provisions referred to in subsections (h)(4) and (5) shall be administered with respect to a dependent to whom entitlement is transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabbe923c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5006/b"},"text":"Pub. L. 110–252, title V, § 5006(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2381"},"text":"122 Stat. 2381","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/55"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(55)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4372"},"text":"124 Stat. 4372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabbe923d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabbe923e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabbe923f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/55/A"},"text":"Pub. L. 111–383, § 1075(b)(55)(A)","children":[],"tail":", substituted “agreement to serve” for “agreement to service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. 