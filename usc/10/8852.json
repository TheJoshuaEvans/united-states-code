{"tag":"section","attrib":{"id":"idab50dc0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852"},"text":null,"children":[{"tag":"num","attrib":{"value":"8852"},"text":"§ 8852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dc10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States district courts have original jurisdiction, exclusive of the courts of the States, of each prize and each proceeding for the condemnation of property taken as prize, if the prize is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brought into the United States, or the Commonwealths or possessions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brought into the territorial waters of a cobelligerent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brought into a locality in the temporary or permanent possession of, or occupied by, the armed forces of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriated for the use of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States district courts, exclusive of the courts of the States, also have original jurisdiction of a prize cause in which the prize property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is lost or entirely destroyed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cannot be brought in for adjudication because of its condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8852/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The jurisdiction conferred by this section of prizes brought into the territorial waters of a cobelligerent may not be exercised, nor may prizes be appropriated for the use of the United States within those territorial waters, unless the government having jurisdiction over those waters consents to the exercise of the jurisdiction or to the appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dc19-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/474"},"text":"70A Stat. 474","children":[],"tail":", § 7652; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/5"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; renumbered § 8852, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dc1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7652(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1159"},"text":"34 U.S.C. 1159","children":[],"tail":" (less applicability to capture)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-18/ch553/s1"},"text":"Aug. 18, 1942, ch. 553, § 1","children":[],"tail":" (less applicability to capture), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-07-01/ch370/s1"},"text":"July 1, 1944, ch. 370, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/678"},"text":"58 Stat. 678","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1945-11-14/ch472/s1"},"text":"Nov. 14, 1945, ch. 472, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/581"},"text":"59 Stat. 581","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1164"},"text":"34 U.S.C. 1164","children":[],"tail":" (2d sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-18/ch553/s6"},"text":"Aug. 18, 1942, ch. 553, § 6","children":[],"tail":" (less 1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/747"},"text":"56 Stat. 747","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7652(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1166"},"text":"34 U.S.C. 1166","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-18/ch553/s8"},"text":"Aug. 18, 1942, ch. 553, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/747"},"text":"56 Stat. 747","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1161"},"text":"34 U.S.C. 1161","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-18/ch553/s3"},"text":"Aug. 18, 1942, ch. 553, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) reflects ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1333"},"text":"28 U.S.C. 1333","children":[],"tail":" by restating the basic prize jurisdiction of that section over prizes brought into the United States, and by providing that the extension of prize jurisdiction conferred by "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1159"},"text":"34 U.S.C. 1159","children":[],"tail":" on the United States district courts is exclusive of the courts of the States. "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1166"},"text":"34 U.S.C. 1166","children":[],"tail":" and the second sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1164"},"text":"34 U.S.C. 1164","children":[],"tail":" are executed in the single jurisdictional statement of this section and the consolidation of the "},{"tag":"ref","attrib":{"href":"/us/act/1942-08-18/ch553"},"text":"Act of August 18, 1942, ch. 553","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1159–116"},"text":"34 U.S.C. 1159–116","children":[],"tail":"6) with the earlier prize provisions. The words “during war” in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1159"},"text":"34 U.S.C. 1159","children":[],"tail":" are omitted as covered in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7651"},"text":"§ 7651 of this title","children":[],"tail":". In clause (1) the words “or the Territories, Commonwealths, or possessions” are added, since “United States” in this title is geographically limited to the 48 States and the District of Columbia, whereas the term here is intended to include all places within the jurisdiction of the district courts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4) the words “taken or” preceding the words “appropriated for the use of the United States” are omitted as surplusage and in order to avoid confusion between the two meanings of the word “taken” in prize law. In both the Revised Statutes and the 1942 Act the phrase “taken or appropriated” means no more than “appropriated” alone, whereas “taken”, in the phrase “taken as prize” means “captured”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is included to make the statement of jurisdiction complete. It is derived by implication from the first sentence of R.S. 4625 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1141"},"text":"34 U.S.C. 1141","children":[],"tail":") which is the source of subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7653"},"text":"§ 7653 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dc1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab50dc1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8852, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/192"},"text":"Pub. L. 85–861, § 1(192)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1537"},"text":"72 Stat. 1537","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/74"},"text":"Pub. L. 86–559, § 1(74)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/280"},"text":"74 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1303/a/27/B"},"text":"Pub. L. 99–145, title XIII, § 1303(a)(27)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/740"},"text":"99 Stat. 740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":", related to transfer or discharge of reserve major generals and brigadier generals with 35 years of service or five years in grade, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1629/c/3"},"text":"Pub. L. 103–337, div. A, title XVI, § 1629(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dc1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7652"},"text":"section 7652 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Commonwealths or possessions” for “Territories, Commonwealths, or possessions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab50dc20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab50dc21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail