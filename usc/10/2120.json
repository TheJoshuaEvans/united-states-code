{"tag":"section","attrib":{"id":"ida92c75af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2120"},"text":null,"children":[{"tag":"num","attrib":{"value":"2120"},"text":"§ 2120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c75b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2120/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “program” means the Armed Forces Health Professions Scholarship and Financial Assistance program provided for in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c75b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2120/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “member of the program” means a person appointed a commissioned officer in a reserve component of the armed forces who is enrolled in the Armed Forces Health Professions Scholarship and Financial Assistance program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c75b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2120/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “course of study” means education received at an accredited college, university, or institution in medicine, dentistry, or other health profession, leading, respectively, to a degree related to the health professions as determined under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c75b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2120/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “specialized training” means advanced training in a health professions specialty received in an accredited program that is beyond the basic education required for appointment as a commissioned officer with a designation as a health professional.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92c75b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/717"},"text":"86 Stat. 717","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1268/13"},"text":"Pub. L. 98–94, title XII, § 1268(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/706"},"text":"97 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/k/2"},"text":"Pub. L. 100–26, § 7(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/284"},"text":"101 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII/s711/a/2"},"text":"Pub. L. 100–180, div. A, title VII, § 711(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1108"},"text":"101 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s725/a"},"text":"Pub. L. 101–189, div. A, title VII, § 725(a)","children":[],"tail":", (h)(1), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1478"},"text":"103 Stat. 1478","children":[],"tail":", 1480.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92c75b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92c75b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92c75b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s725/h/1"},"text":"Pub. L. 101–189, § 725(h)(1)","children":[],"tail":", substituted “Scholarship and Financial Assistance program” for “Scholarship program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s725/a"},"text":"Pub. L. 101–189, § 725(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" substituted “subchapter” for “chapter” in introductory text and in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “The term” after each par. designation and struck out uppercase letter of first word after first quotation marks in each par. and substituted lowercase letter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" substituted a colon for a dash after “In this chapter” in text preceding par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida92c75b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida92c75b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Demonstration Project on Service of Retired Nurse Corps Officers as Faculty at Civilian Nursing Schools","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 597, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4479"},"text":"122 Stat. 4479","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/e/8"},"text":"Pub. L. 111–383, div. A, title X, § 1075(e)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4375"},"text":"124 Stat. 4375","children":[],"tail":", which authorized the Secretary of Defense to conduct a demonstration project to encourage retired military nurses to serve as faculty at civilian nursing schools, expired on "},{"tag":"date","attrib":{"date":"2014-06-30"},"text":"June 30, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
