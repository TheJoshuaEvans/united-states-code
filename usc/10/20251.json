{"tag":"section","attrib":{"id":"idabcce9c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251"},"text":null,"children":[{"tag":"num","attrib":{"value":"20251"},"text":"§ 20251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of selection for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabcce9c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this section, sections 14501, 14503, 14504, 631, and 632 of this title shall apply to promotions of officers on the Space Force officer list. For the purpose of such applicability—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabcce9c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in those sections to the reserve active-status list or the active-duty list shall apply to the Space Force officer list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcce9c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in those sections to a board convened under section 14201 ","children":[{"tag":"ref","attrib":{"idref":"fn002180"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002180"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s611"},"text":"section 611 of this title","children":[],"tail":" shall apply to a board convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcce9c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Failure of Selection for Promotion to Officers Above Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14501"},"text":"section 14501 of this title","children":[],"tail":" to an officer above the promotion zone shall not apply in the promotion of officers on the Space Force officer list."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcce9ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In applying section 631 or 632 of this title to such an officer, the reference in subsection (a)(3) of that section to qualifying for retirement under certain sections of this title shall be deemed to refer to qualifying for retirement under any provision of law other than chapter 61 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcce9cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Failure of Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the administration of this chapter pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabcce9cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer on the Space Force officer list shall not be deemed to have failed twice of selection for promotion for purposes of section 629(e)(2) or 14501(b) of this title until the officer has failed selection of promotion to the next higher grade the maximum number of times specified for opportunities for promotion to such grade within the competitive category concerned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20234"},"text":"section 20234 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcce9cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20251/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in section 631(a) or 632(a) of this title, or in sections 14504 through 14506 of this title, to an officer who has failed of selection for promotion to the next higher grade for the second time shall be deemed to refer instead to an officer on the Space Force officer list who has failed of selection for promotion to the next higher grade for the maximum number of times specified for opportunities for promotion to such grade within the competitive category concerned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20234"},"text":"section 20234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcce9ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/649"},"text":"137 Stat. 649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521/u"},"text":"Pub. L. 118–159, div. A, title V, § 521(u)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1883"},"text":"138 Stat. 1883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/43"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(43)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1210"},"text":"139 Stat. 1210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabcce9cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabcce9d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabcce9d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14201"},"text":"Section 14201 of this title","children":[],"tail":", referred to in subsec. (a)(2), probably should be "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101"},"text":"section 14101 of this title","children":[],"tail":", which relates to convening of selection boards. There is no "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14201"},"text":"section 14201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idabcce9d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 20251 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20252"},"text":"section 20252 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/v/2"},"text":"section 521(v)(2) of Pub. L. 118–159","children":[],"tail":". The amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/u"},"text":"section 521(u) of Pub. L. 118–159","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20251"},"text":"section 20251 of this title","children":[],"tail":" were executed to this section to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabcce9d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out “and” before “14504, 631, and 632”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/u/1/A"},"text":"Pub. L. 118–159, § 521(u)(1)(A)","children":[],"tail":", substituted “14504, 631, and 632” for “14504 and section 631 and 632” in introductory provisions. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/u/1/B"},"text":"Pub. L. 118–159, § 521(u)(1)(B)","children":[],"tail":", substituted “section 14201 or section 611” for “section 14201 or 611”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/u/2"},"text":"Pub. L. 118–159, § 521(u)(2)","children":[],"tail":", substituted “14501(b)” for “14502(b)”. See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
