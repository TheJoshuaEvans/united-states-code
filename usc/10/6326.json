{"tag":"section","attrib":{"id":"idaacdca8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6326"},"text":null,"children":[{"tag":"num","attrib":{"value":"6326"},"text":"§ 6326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of contractor performance evaluations leading to award fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdca8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall take appropriate actions to make available to the public, to the maximum extent practicable, contractor performance evaluations conducted by the Administration of management and operating contractors of the nuclear security enterprise that results in the award of an award fee to the contractor concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Format","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Performance evaluations shall be made public under this section in a common format that facilitates comparisons of performance evaluations between and among similar management and operating contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdca8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1443"},"text":"139 Stat. 1443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdca8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdca90-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdca91-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6326 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8326"},"text":"section 8326 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2785"},"text":"section 2785 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
