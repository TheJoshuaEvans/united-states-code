{"tag":"section","attrib":{"id":"ida7591500-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d"},"text":null,"children":[{"tag":"num","attrib":{"value":"129d"},"text":"§ 129d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to litigation support contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7591501-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer or employee of the Department of Defense may disclose sensitive information to a litigation support contractor if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7591502-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure is for the sole purpose of providing litigation support to the Government in the form of administrative, technical, or professional services during or in anticipation of litigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591503-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under a contract with the Government, the litigation support contractor agrees to and acknowledges—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7591504-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that sensitive information furnished will be accessed and used only for the purposes stated in the relevant contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7591505-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the contractor will take all precautions necessary to prevent disclosure of the sensitive information provided to the contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7591506-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such sensitive information provided to the contractor under the authority of this section shall not be used by the contractor to compete against a third party for Government or non-Government contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7591507-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the violation of subparagraph (A), (B), or (C) is a basis for the Government to terminate the litigation support contract of the contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7591508-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7591509-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “litigation support contractor” means a contractor (including an expert or technical consultant) under contract with the Department of Defense to provide litigation support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida759150a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sensitive information” means confidential commercial, financial, or proprietary information, technical data, or other privileged information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida759150b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s802/a/1"},"text":"Pub. L. 112–81, div. A, title VIII, § 802(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1484"},"text":"125 Stat. 1484","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
