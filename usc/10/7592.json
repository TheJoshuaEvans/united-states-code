{"tag":"section","attrib":{"id":"idaaf8ab3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7592"},"text":null,"children":[{"tag":"num","attrib":{"value":"7592"},"text":"§ 7592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radiograms and telegrams: forwarding charges due connecting commercial facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the operation of telegraph lines, cables, or radio stations, members of the Signal Corps may, in the discretion of the Secretary of the Army, collect forwarding charges due connecting commercial telegraph or radio companies for sending radiograms or telegrams over their lines. Under such regulations as the Secretary may prescribe, they may present a voucher to a disbursing official for payment of the forwarding charge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaaf8ab3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/257"},"text":"70A Stat. 257","children":[],"tail":", § 4592; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/1/A"},"text":"Pub. L. 97–258, § 2(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1052"},"text":"96 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s105/e"},"text":"Pub. L. 104–316, title I, § 105(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3830"},"text":"110 Stat. 3830","children":[],"tail":"; renumbered § 7592, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A