tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:430c (as applicable to 34:430(b)(2)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1305(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:600","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(e) (as applicable to 10:600"},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(b)(2))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:430(e) (as applicable to 34:430(b)(2)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1305(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:600","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"(b)(2) (less last sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"34:430(b)(2) (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “has at least” are substituted for the words “has completed”. The words “and is not so continued on active service” and “on that date which” are omitted as surplusage. 10:600","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(b)(2) (last 16 words of last sentence) and 34:430(b)(2) (last 16 words of last sentence) are omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1315"},"text":"section 1315 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Secretary concerned may defer” are substituted for the words “may, in the discretion of the Secretary, be deferred”. The words “determination of his” are inserted for clarity. The words “not more than” are substituted for the words “a period not to exceed”. The words “he would otherwise be required to retire under this section” are substituted for the words “retirement * * * would otherwise be required”. The words “which is required”, “possible”, “proper”, and “a period of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the Secretary concerned may defer the retirement” are substituted for the words “in the discretion of the Secretary * * * be continued on active service”. The words “but not later than” are substituted for the words “but not beyond that date which is”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b54a12-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8b54a13-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 511 of the Career Compensation Act of 1949, referred to in subsec. (a)(1), is section 511 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-12/ch681"},"text":"act Oct. 12, 1949, ch. 681","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s580"},"text":"section 580 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b54a14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s509A/1"},"text":"Pub. L. 118–31, § 509A(1)","children":[],"tail":", inserted “or a Marine Corps Marine Gunner warrant officer in such grade,” after “chief warrant officer, W–5,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s509A/2"},"text":"Pub. L. 118–31, § 509A(2)","children":[],"tail":", substituted “when the warrant officer” for “when he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s509A/3"},"text":"Pub. L. 118–31, § 509A(3)","children":[],"tail":", substituted “as the Secretary concerned” for “as he” and “after the warrant officer” for “after he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s504/1"},"text":"Pub. L. 112–239, § 504(1)","children":[],"tail":", substituted “Subject to paragraphs (2) and (3), a regular warrant officer” for “A regular warrant officer (other than a regular Army warrant officer)” and “date on which the officer” for “date on which he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s504/2"},"text":"Pub. L. 112–239, § 504(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" designated existing provisions as par. (1), substituted “A regular warrant officer (other than a regular Army warrant officer) who has at least 30 years of active service that could be credited to the officer” for “A regular warrant officer who has at least 30 years of active service as a warrant officer that could be credited to him”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “A regular warrant officer” for “(1) Except as provided in paragraph (2), a regular warrant officer (other than a regular Army warrant officer in the grade of chief warrant officer, W–5)”, inserted “as a warrant officer” after “years of active service” and “the date on which” after “60 days after”, and struck out par. (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2)(A) A regular Army warrant officer in the grade of chief warrant officer, W–5, who has at least 30 years of active service as a warrant officer that could be credited to him under section 511 of the Career Compensation Act of 1949, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/70/114"},"text":"70 Stat. 114","children":[],"tail":"), shall be retired 60 days after the date on which he completes that service, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) A regular Army warrant officer in a warrant officer grade below the grade of chief warrant officer, W–5, who completes 24 years of active service as a warrant officer before he is required to be retired under paragraph (1) shall be retired 60 days after the date on which he completes 24 years of active service as a warrant officer, except as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" designated existing provisions as par. (1), substituted “Except as provided in paragraph (2), a regular warrant officer (other than a regular Army warrant officer in the grade of chief warrant officer, W–5)” for “A permanent regular warrant officer”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “8301” for “47a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" substituted “section 511 of the Career Compensation Act of 1949, as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/70/114"},"text":"70 Stat. 114","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t37/s311"},"text":"section 311 of title 37","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b54a15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8b54a16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1132"},"text":"section 1132 of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8b54a17-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s15"},"text":"section 15 of Pub. L. 87–649","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
