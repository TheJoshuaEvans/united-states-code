{"tag":"section","attrib":{"id":"idab44f5fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8728"},"text":null,"children":[{"tag":"num","attrib":{"value":"8728"},"text":"§ 8728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements and leases: provision for change","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every unit or cooperative plan of development and operation and every lease affecting lands owned by the United States within Naval Petroleum Reserve Numbered 2 and the oil shale reserves shall contain a provision authorizing the Secretary, subject to approval by the President and to any limitation in the plan or lease, to change from time to time the rate of prospecting and development on, and the quantity and rate of production from, lands of the United States under the plan or lease, notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab44f5fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/460"},"text":"70A Stat. 460","children":[],"tail":", § 7428; "},{"tag":"ref","attrib":{"href":"/us/pl/87/796/s1/5"},"text":"Pub. L. 87–796, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/905"},"text":"76 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/258/tII/s201/9"},"text":"Pub. L. 94–258, title II, § 201(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/309"},"text":"90 Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXIV/s