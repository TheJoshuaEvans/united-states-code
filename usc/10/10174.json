{"tag":"section","attrib":{"id":"idab8c8687-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10174"},"text":null,"children":[{"tag":"num","attrib":{"value":"10174"},"text":"§ 10174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air Force Reserve Command","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c8688-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Command","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force, with the advice and assistance of the Chief of Staff of the Air Force, shall establish an Air Force Reserve Command. The Air Force Reserve Command shall be operated as a separate command of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c8689-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commander","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Air Force Reserve is the Commander of the Air Force Reserve Command. The commander of the Air Force Reserve Command reports directly to the Chief of Staff of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c868a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of Forces","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c868b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10174/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assign to the Air Force Reserve Command all forces of the Air Force Reserve stationed in the continental United States other than forces assigned to the unified combatant command for special operations forces established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s167"},"text":"section 167 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c868c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10174/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise directed by the Secretary of Defense in the case of forces assigned to carry out functions of the Secretary of the Air Force specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9013"},"text":"section 9013 of this title","children":[],"tail":", shall assign to the combatant commands all such forces assigned to the Air Force Reserve Command under paragraph (1) in the manner specified by the Secretary of Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c868d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXII/s1211/a/1"},"text":"Pub. L. 104–201, div. A, title XII, § 1211(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2690"},"text":"110 Stat. 2690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c868e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c868f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8c8690-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 9013” for “section 8013”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8c8691-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab8c8692-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
