{"tag":"section","attrib":{"id":"idabca78ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216"},"text":null,"children":[{"tag":"num","attrib":{"value":"20216"},"text":"§ 20216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of selection boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca78ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" shall submit to the Secretary of the Air Force a written report, signed by each member of the board, containing a list of the names of the officers it recommends for promotion and certifying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca78ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the board has carefully considered the record of each officer whose name was furnished to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s615"},"text":"section 615 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca78ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, in the opinion of a majority of the members of the board, the officers recommended for promotion by the board are best qualified for promotion to meet the needs of the Space Force (as noted in the guidelines or information furnished the board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s615/b"},"text":"section 615(b) of this title","children":[],"tail":") among those officers whose names were furnished to the selection board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca78f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Who Should Be Required to Show Cause for Retention","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" shall include in its report the name of any officer before it for consideration for promotion whose record, in the opinion of a majority of the members of the board, indicates that the officer should be required under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20503"},"text":"section 20503 of this title","children":[],"tail":" to show cause for the officer’s retention in a space force active status."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca78f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Recommended to Be Placed Higher on the Promotion List","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" shall, when authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20215/g"},"text":"section 20215(g) of this title","children":[],"tail":", include in its report the names of those officers recommended by the board to be placed higher on the promotion list and the order in which the board recommends that those officers should be placed on the list."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca78f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation for Officers to Be Excluded From Future Consideration for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" may include in its report a recommendation that an officer considered by the board be excluded from future consideration for promotion under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca78f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/637"},"text":"137 Stat. 637","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521/p"},"text":"Pub. L. 118–159, div. A, title V, § 521(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1882"},"text":"138 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabca78f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabca78f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabca78f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “20215(g)” for “20214(g)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
