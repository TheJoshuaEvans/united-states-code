{"tag":"section","attrib":{"id":"idab6660f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9176"},"text":null,"children":[{"tag":"num","attrib":{"value":"9176"},"text":"§ 9176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention on active duty","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may retain on active duty a disabled officer until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6660f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9176/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physical condition of the officer is such that the officer will not be further benefited by retention in a military hospital or a medical facility of the Department of Veterans Affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6660fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9176/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer is processed for physical disability benefits provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6660fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/522"},"text":"70A Stat. 522","children":[],"tail":", § 8446; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/180/C"},"text":"Pub. L. 85–861, § 1(180)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1532"},"text":"72 Stat. 1532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1621/a/10"},"te