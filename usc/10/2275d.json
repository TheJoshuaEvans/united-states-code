{"tag":"section","attrib":{"id":"ida960f34e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2275d"},"text":"§ 2275d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and operation of space systems for space warfighting and control","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f34f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall acquire and operate space systems to be used primarily for space warfighting and control to meet the requirements specified by one or more combatant commanders in carrying out the responsibilities set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s164"},"text":"section 164 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role of Commercial Space Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use one or more commercial space systems to augment the space systems acquired and operated under subsection (a) if such commercial space systems are under the direction of a member of the armed forces with responsibility for space warfighting and control operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the application of subsection (a) if the Secretary determines that such a waiver is in the national security interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 10 days after exercising the waiver authority under paragraph (1), the Secretary shall submit to the congressional defense committees a notification of the use of such authority that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the national security interest upon which the exercise of such authority is based;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated vulnerabilities to national security posed by the use of such waiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of which operational commander will provide direction to the commercial space system that is used pursuant to the waiver instead of a system acquired and operated by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2275d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated duration of such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f358-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1603"},"text":"Pub. L. 119–60, div. A, title XVI, § 1603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1175"},"text":"139 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
