{"tag":"section","attrib":{"id":"ida9d81f08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809"},"text":null,"children":[{"tag":"num","attrib":{"value":"2809"},"text":"§ 2809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term facilities contracts for certain activities and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9d81f09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission and Authorization of Proposed Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may enter into a contract for the procurement of services in connection with the construction, management, and operation of a facility on or near a military installation for the provision of an activity or service described in subsection (b) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d81f0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned has identified the proposed project for that facility in the budget material submitted to Congress by the Secretary of Defense in connection with the budget submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for the fiscal year in which the contract is proposed to be awarded;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned has determined that the services to be provided at that facility can be more economically provided through the use of a long-term contract than through the use of conventional means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project has been authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81f0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Purposes of Contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities and services referred to in subsection (a) are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d81f0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Child care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilities, including potable and waste water treatment services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Depot supply activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Troop housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transient quarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospital or medical facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other logistic and administrative services, other than depot maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81f15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions on Obligation of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract entered into for a project pursuant to subsection (a) shall include the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d81f16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement that the obligation of the United States to make payments under the contract in any fiscal year is subject to appropriations being provided specifically for that fiscal year and specifically for that project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commitment to obligate the necessary amount for each fiscal year covered by the contract when and to the extent that funds are appropriated for that project for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d81f18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement that such a commitment given under the authority of this section does not constitute an obligation of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81f19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each contract entered into under this section shall be awarded through the use of competitive procedures as provided in chapter 137 ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. In accordance with such procedures, the Secretary concerned shall solicit bids or proposals for a contract for each project that has been authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81f1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract under this section may be for any period not in excess of 32 years, excluding the period for construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d81f1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2809/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Wait Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may enter into a contract under this section only after the end of the 14-day period beginning on the date on which the Secretary submits, in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":", to the appropriate committees of Congress a justification of the need for the facility covered by the proposed contract, including an economic analysis (based upon accepted life cycle costing procedures) which demonstrates that the proposed contract is cost effective when compared with alternative means of furnishing the same facility."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9d81f1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/167/tVIII/s811/a"},"text":"Pub. L. 99–167, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-03"},"text":"Dec. 3, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/990"},"text":"99 Stat. 990","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/a/20"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(a)(20)","children":[],"tail":", div. B, title VII, § 2711, "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3994"},"text":"100 Stat. 3994","children":[],"tail":", 4041; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dB"},"text":"Pub. L. 100–180, div. B","children":[],"tail":", subdiv. 3, title I, § 2302(a), (b), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1215"},"text":"101 Stat. 1215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dB/tXXVIII/s2801"},"text":"Pub. L. 100–456, div. B, title XXVIII, § 2801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2115"},"text":"102 Stat. 2115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dB/tXXVIII/s2803"},"text":"Pub. L. 101–189, div. B, title XXVIII, § 2803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1647"},"text":"103 Stat. 1647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dB/tXXVIII/s2805/a/1"},"text":"Pub. L. 102–190, div. B, title XXVIII, § 2805(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1537"},"text":"105 Stat. 1537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/38"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1601"},"text":"117 Stat. 1601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2801/a/7"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2801(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1841"},"text":"131 Stat. 1841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d81f1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d81f1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9d81f1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 137 of this title, referred to in subsec. (d), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1881/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1881(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4293"},"text":"134 Stat. 4293","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", in conjunction with the transfer and reorganization of acquisition provisions in this title by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4149"},"text":"134 Stat. 4149","children":[],"tail":". For definition of “chapter 137 legacy provisions”, see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3016"},"text":"section 3016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9d81f20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added subsec. (f) and struck out former subsec. (f) which related to written or electronic notice and wait requirements for a contract."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" struck out “calendar” after “21” and inserted before period at end “or, if over sooner, a period of 14 days has expired following the date on which a copy of the justification and economic analysis are provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted section catchline for one which read “Test of long-term facilities contracts” and amended text generally, substituting present provisions for provisions authorizing contracts for construction, management, and operation of facilities on or near military installations for the provision of certain enumerated activities or services, setting out procedures, terms, and other limits for such contracts, providing that no more than 5 contracts may be entered into under this section other than contracts for child care centers, and providing that authority to enter into such contracts was to expire on "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2803/1"},"text":"Pub. L. 101–189, § 2803(1)","children":[],"tail":", substituted “Utilities, including potable” for “Potable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2803/2"},"text":"Pub. L. 101–189, § 2803(2)","children":[],"tail":", substituted “activities and services described in clause (i) or (ii) of subsection (a)(1)(B)” for “child care centers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s2803/3"},"text":"Pub. L. 101–189, § 2803(3)","children":[],"tail":", substituted “1991” for “1989”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “32” for “20”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(1)(B)(vi), (vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s2302/a"},"text":"Pub. L. 100–180, § 2302(a)","children":[],"tail":", added cl. (vi) and redesignated former cl. (vi) as (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s2302/b"},"text":"Pub. L. 100–180, § 2302(b)","children":[],"tail":", substituted “1989” for “1987”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s2711"},"text":"Pub. L. 99–661, § 2711","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The Secretary concerned may enter into a contract for the construction, management, and operation of a facility on or near a military installation in the United States for the provision of child care services, waste water treatment, or depot supply activities in a case in which the Secretary concerned determines that the facility can be more efficiently and more economically provided under a long-term contract than by other appropriate means.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s1343/a/20/A"},"text":"Pub. L. 99–661, § 1343(a)(20)(A)","children":[],"tail":", substituted “a contract” for “contracts”, “a facility” for “facilities”, “a military installation” for “military installations”, “a case” for “cases”, “facility” for “facilities”, and “a long-term contract” for “long-term contracts” and inserted a comma after “waste water treatment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s1343/a/20/B"},"text":"Pub. L. 99–661, § 1343(a)(20)(B)","children":[],"tail":", substituted “this section” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s1343/a/20/C"},"text":"Pub. L. 99–661, § 1343(a)(20)(C)","children":[],"tail":", substituted “20” for “twenty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s1343/a/20/D"},"text":"Pub. L. 99–661, § 1343(a)(20)(D)","children":[],"tail":", struck out “the” before “Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/s1343/a/20/E"},"text":"Pub. L. 99–661, § 1343(a)(20)(E)","children":[],"tail":", struck out “the authority of subsection (a) of” after “under”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d81f21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9d81f22-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":", div B, title XXVIII, § 2805(b), "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1538"},"text":"105 Stat. 1538","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2809"},"text":"Section 2809 of title 10","children":[],"tail":", United States Code, as amended by subsection (a), shall apply with respect to contracts entered into under that section on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9da9023-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/s2702"},"text":"section 2702 of Pub. L. 100–456","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2391"},"text":"section 2391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9da9024-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Demonstration Program on Reduction in Long-Term Facility Maintenance Costs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dB/tXXVIII/s2814"},"text":"Pub. L. 107–107, div. B, title XXVIII, § 2814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1310"},"text":"115 Stat. 1310","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dB/tXXVIII/s2813/a"},"text":"Pub. L. 107–314, div. B, title XXVIII, § 2813(a)","children":[],"tail":"–(d)(1), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2709"},"text":"116 Stat. 2709","children":[],"tail":", 2710, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dB/tXXVIII/s2813/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Carry Out Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense or the Secretary of a military department may conduct a demonstration program to assess the feasibility and desirability of including facility maintenance requirements in construction contracts for military construction projects for the purpose of determining whether such requirements facilitate reductions in the long-term facility maintenance costs of the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 12 contracts per military department may contain requirements referred to in subsection (a) for the purpose of the demonstration program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The demonstration program may only cover contracts entered into on or after the date of the enactment of the Bob Stump National Defense Authorization Act for Fiscal Year 2003 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"], except that the Secretary of the Army shall treat any contract containing requirements referred to in subsection (a) that was entered into under the authority in such subsection between that date and "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", as a contract for the purpose of the demonstration program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Period of Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The effective period of a requirement referred to in subsection (a) that is included in a contract for the purpose of the demonstration program may not exceed five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2005-01-31"},"text":"January 31, 2005","children":[],"tail":", the Secretary of Defense shall submit to Congress a report on the demonstration program, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of all contracts that contain requirements referred to in subsection (a) for the purpose of the demonstration program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the demonstration program and a description of the experience of the Secretary with respect to such contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendations, including recommendations for the termination, continuation, or expansion of the demonstration program, that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under subsection (a) to include requirements referred to in that subsection in contracts under the demonstration program shall expire on ","children":[{"tag":"date","attrib":{"date":"2006-09-30"},"text":"September 30, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts authorized to be appropriated for the military departments or defense-wide for a fiscal year for military construction shall be available for the demonstration program under this section in such fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dB/tXXVIII/s2813/d/2"},"text":"Pub. L. 107–314, div. B, title XXVIII, § 2813(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2710"},"text":"116 Stat. 2710","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dB/tXXVIII/s2813/d/2"},"text":"“The amendment made by paragraph (1) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s2814/f"},"text":"section 2814(f) of Pub. L. 107–107","children":[],"tail":", set out above] shall not affect the availability for the purpose of the demonstration program under section 2814 of the Military Construction Authorization Act for Fiscal Year 2002, as amended by this section, of any amounts authorized to be appropriated before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":"] for the Army for military construction that have been obligated for the demonstration program, but not expended, as of that date.”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9da9025-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dB"},"text":"Pub. L. 100–180, div. B","children":[],"tail":", subdiv. 3, title I, § 2302(c), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1215"},"text":"101 Stat. 1215","children":[],"tail":", directed each Secretary who has entered into a contract under this section to submit a report to Committees on Armed Services of Senate and House of Representatives by "},{"tag":"date","attrib":{"date":"1989-02-15"},"text":"Feb. 15, 1989","children":[],"tail":", containing date and duration of, other party to, and nature of activities carried out under each such contract, and recommendations, and reasons therefor, concerning whether authority to enter into contracts under this section should be extended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
