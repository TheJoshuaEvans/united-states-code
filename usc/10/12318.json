{"tag":"section","attrib":{"id":"idaba209c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12318"},"text":null,"children":[{"tag":"num","attrib":{"value":"12318"},"text":"§ 12318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves on active duty: duties; funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba209ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a period that members of a reserve component are serving on active duty pursuant to an order under section 12302 or 12304 of this title, members of reserve components serving on active duty may perform duties in connection with either such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba209cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds available for the pay and allowances of Reserves referred to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12310"},"text":"section 12310 of this title","children":[],"tail":" shall be available for the pay and allowances of such Reserves who perform duties in connection with section 12302 or 12304 of this title under the authority of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba209cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIV/s412/b/1"},"text":"Pub. L. 99–661, div. A, title IV, § 412(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3861"},"text":"100 Stat. 3861","children":[],"tail":", § 686; renumbered § 12318 and