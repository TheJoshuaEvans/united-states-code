 38 and the provisions of subchapters I and II of chapter 36 of such title (with the exception of sections 1786(a), 1787, and 1792)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s319"},"text":"Pub. L. 102–568, § 319","children":[],"tail":", struck out “1780(c),” after “exception of sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/s313/a/6"},"text":"Pub. L. 102–568, § 313(a)(6)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3680A/b"},"text":"section 3680A(b) of title 38","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1673/b"},"text":"section 1673(b) of title 38","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/16"},"text":"Pub. L. 102–16","children":[],"tail":" struck out “1434(b), 1663,” before “1670,” and “1780(g),” before “1786(a),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s645/a/1"},"text":"Pub. L. 101–189, § 645(a)(1)","children":[],"tail":", substituted “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s405/d/3"},"text":"Pub. L. 101–237, § 405(d)(3)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1685"},"text":"section 1685 of title 38","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s642/c"},"text":"Pub. L. 101–189, § 642(c)","children":[],"tail":", amended first sentence generally and substituted “and the term ‘a person’, as used” for “, as used” in second sentence. Prior to amendment, first sentence read as follows: “Except as otherwise provided in this chapter, the provisions of sections 1663, 1670, 1671, 1673, 1674, 1676, 1682(g), and 1683 of chapter 34 of title 38 and the provisions of subchapters I and II of chapter 36 of such title (with the exception of sections 1780(a)(5), 1780(b), 1786, 1787(b)(1), and 1792) shall be applicable to the provision of educational assistance under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s422/b/1"},"text":"Pub. L. 101–237, § 422(b)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabbe927a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbe927b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbe927c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tII/s204/c"},"text":"Pub. L. 105–368, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3327"},"text":"112 Stat. 3327","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/368/tII/s204/c"},"text":"“The amendments made by this section [amending this section and sections 3034 and 3241 of Title 38, Veterans’ Benefits] shall apply with respect to courses of flight training beginning on or after ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbe927d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/s601/d"},"text":"section 601(d) of Pub. L. 103–446","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3034"},"text":"section 3034 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbe927e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/tIV/s405/e"},"text":"Pub. L. 101–237, title IV, § 405(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2082"},"text":"103 Stat. 2082","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/237/tIV/s405/e"},"text":"“The amendments made by this section [amending this section and section 1685 [now 3485] of Title 38, Veterans’ Benefits] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1990-05-01"},"text":"May 1, 1990","children":[],"tail":", and shall apply to services performed on or after that date.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/s422/b/1"},"text":"section 422(b)(1) of Pub. L. 101–237","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"Sept. 30, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/s422/d"},"text":"section 422(d) of Pub. L. 101–237","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s642/c"},"text":"section 642(c) of Pub. L. 101–189","children":[],"tail":" applicable with respect to any person who after "},{"tag":"date","attrib":{"date":"1990-09-30"},"text":"Sept. 30, 1990","children":[],"tail":", meets the requirements set forth in section 2132(a)(1)(A) or (B) [16132(a)(1)(A), (B)] of this title, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/s642/d"},"text":"section 642(d) of Pub. L. 101–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabbe927f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", applicable only to members of the Armed Forces who qualify for educational assistance under this chapter on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/s705/b"},"text":"section 705(b) of Pub. L. 98–525","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idabbe9280-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/568/tIII/s313/b"},"text":"Pub. L. 102–568, title III, § 313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4333"},"text":"106 Stat. 4333","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/568/tIII/s313/b"},"text":"“The amendments made by paragraphs (2) through (6) of subsection (a) of this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3680A"},"text":"section 3680A of Title 38","children":[],"tail":", Veterans’ Benefits, amending this section and sections 3034 and 3241 of Title 38, and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3473"},"text":"section 3473 of Title 38","children":[],"tail":"] shall not apply to any person receiving educational assistance for pursuit of an independent study program in which the person was enrolled on the date of enactment of this section ["},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":"] for as long as such person is continuously thereafter so enrolled and meets the requirements of eligibility for such assistance for the pursuit of such program under title 38, United States Code, or title 10, United States Code, in effect on that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
