{"tag":"section","attrib":{"id":"ida978c158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2423"},"text":null,"children":[{"tag":"num","attrib":{"value":"2423"},"text":"§ 2423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laundry and dry cleaning services: procurement from facilities operated by the Navy Resale and Services Support Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida978c159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may authorize an element of the Department of Defense to enter into a contract (through the use of procedures other than competitive procedures) with a laundry and dry cleaning facility operated by the Navy Resale and Services Support Office to procure laundry and dry cleaning services for the armed forces outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida978c15a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply only with respect to a laundry and dry cleaning facility of the Navy Resale and Services Support Office that began operating before ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida978c15b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s323/a"},"text":"Pub. L. 101–189, div. A, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1414"},"text":"103 Stat. 1414","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
