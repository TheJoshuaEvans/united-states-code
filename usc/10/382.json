{"tag":"section","attrib":{"id":"ida7a7d227-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382"},"text":null,"children":[{"tag":"num","attrib":{"value":"382"},"text":"§ 382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution and administration of programs and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d228-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy Oversight and Resource Allocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall assign responsibility for the oversight of strategic policy and guidance and responsibility for overall resource allocation for security cooperation programs and activities of the Department of Defense to a single official and office in the Office of the Secretary of Defense at the level of Under Secretary of Defense or below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d229-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Execution and Administration of Certain Programs and Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d22a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Defense Security Cooperation Agency shall be responsible for the execution and administration of all security cooperation programs and activities of the Department of Defense involving the provision of defense articles, military training, and other defense-related services by grant, loan, cash sale, or lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d22b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may designate an element of an armed force, combatant command, Defense Agency, Department of Defense Field Activity, or other element or organization of the Department of Defense to execute and administer security cooperation programs and activities described in paragraph (1) if the Director determines that the designation will achieve maximum effectiveness, efficiency, and economy in the activities for which designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d22c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d22d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds available to the Defense Security Cooperation Agency, and other funds available to the Department of Defense for security cooperation programs and activities of the Department of Defense, may be used to implement security cooperation programs and activities of the Department of Defense authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d22e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s382/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget justification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds necessary for implementing security cooperation programs and activities of the Department of Defense under this chapter for a fiscal year shall be identified, with appropriate justification, in the consolidated budget for such fiscal year required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s381"},"text":"section 381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d22f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/m"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2509"},"text":"130 Stat. 2509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a7d230-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a7d231-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7a7d232-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 382 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s282"},"text":"section 282 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
