{"tag":"section","attrib":{"id":"idab914144-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10501"},"text":null,"children":[{"tag":"num","attrib":{"value":"10501"},"text":"§ 10501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Guard Bureau","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab914145-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Guard Bureau","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Department of Defense the National Guard Bureau, which is a joint activity of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab914146-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Guard Bureau is the channel of communications on all matters pertaining to the National Guard, the Army National Guard of the United States, and the Air National Guard of the United States between (1) the Department of the Army and Department of the Air Force, and (2) the several States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab914147-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s904/a"},"text":"Pub. L. 103–337, div. A, title IX, § 904(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2824"},"t