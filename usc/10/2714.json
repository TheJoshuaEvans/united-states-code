{"tag":"section","attrib":{"id":"ida9c77d84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714"},"text":null,"children":[{"tag":"num","attrib":{"value":"2714"},"text":"§ 2714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perfluoroalkyl Substances and Polyfluoroalkyl Substances Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c77d85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a task force to address the effects of the release of perfluoroalkyl substances and polyfluoroalkyl substances from activities of the Department of Defense (in this section referred to as the “PFAS Task Force”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77d86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the PFAS Task Force are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77d87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Energy, Installations, and Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Army for Installations, Energy, and Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Navy for Energy, Installations, and Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of the Air Force for Installations, Environment, and Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Health Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77d8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary of Defense for Energy, Installations, and Environment shall be the chairman of the PFAS Task Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77d8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Personnel and Readiness and such other individuals as the Secretary of Defense considers appropriate shall support the activities of the PFAS Task Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77d8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the PFAS Task Force are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77d8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring the health aspects of exposure to perfluoroalkyl substances and polyfluoroalkyl substances, as found by the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying, and funding the procurement of, an effective alternative to firefighting foam containing perfluoroalkyl substances or polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating within the Department of Defense with respect to mitigating the effects of the release of perfluoroalkyl substances and polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing the perceptions of Congress and the public of the efforts of the Department of Defense with respect to mitigating the effects of the release of perfluoroalkyl substances and polyfluoroalkyl substances from activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supporting research efforts relating to perfluoroalkyl substances or polyfluoroalkyl substances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing practices to ensure the timely and complete dissemination of research findings and related data relating to perfluoroalkyl substances or polyfluoroalkyl substances to the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77d95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2022, and annually thereafter through 2029, the Chairman of the PFAS Task Force shall submit to Congress a report on the activities of the task force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77d96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77d97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “perfluoroalkyl substance” means a man-made chemical of which all of the carbon atoms are fully fluorinated carbon atoms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77d98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2714/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “polyfluoroalkyl substance” means a man-made chemical containing a mix of fully fluorinated carbon atoms, partially fluorinated carbon atoms, and nonfluorinated carbon atoms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c77d99-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s341/a"},"text":"Pub. L. 117–81, div. A, title III, § 341(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1641"},"text":"135 Stat. 1641","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s341/b"},"text":"Pub. L. 117–263, div. A, title III, § 341(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2529"},"text":"136 Stat. 2529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIII/s331"},"text":"Pub. L. 118–31, div. A, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/221"},"text":"137 Stat. 221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c77d9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c77d9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9c77d9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2022, referred to in subsec. (f), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c77d9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “and annually thereafter through 2029,” for “and quarterly thereafter,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added pars. (5) and (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
