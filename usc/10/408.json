{"tag":"section","attrib":{"id":"ida7b8733a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408"},"text":null,"children":[{"tag":"num","attrib":{"value":"408"},"text":"§ 408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in support of Department of Defense accounting for missing United States Government personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b8733b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide assistance to and procure goods and services from any foreign nation to assist the Department of Defense with recovery of and accounting for missing United States Government personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8733c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assistance provided under subsection (a) may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b8733d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b8733e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b8733f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87340-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training of personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87341-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b87342-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval by Secretary of State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assistance may not be provided under this section to any foreign nation unless the Secretary of State specifically approves the provision of such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b87343-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b87344-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amount of assistance provided under this section in any fiscal year may not exceed $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87345-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the limitation under paragraph (1) if the Secretary submits to the congressional defense committees notice of the waiver together with the reasons why the waiver is necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b87346-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No assistance may be provided under this section to a foreign nation the government of which the Secretary of State determines has repeatedly provided support for international terrorism pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b87347-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1754(c)(1)(A) of the Export Control Reform Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c/1/A"},"text":"50 U.S.C. 4813(c)(1)(A)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 620A of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"22 U.S.C. 2371","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b87349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 40 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780"},"text":"22 U.S.C. 2780","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8734a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction With Other Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to provide assistance under this section is in addition to any other authority to provide assistance to foreign nations under law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b8734b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s408/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 31 of each year, the Secretary of Defense shall submit to the congressional defense committees a report on the assistance provided under this section during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b8734c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXII/s1207/a"},"text":"Pub. L. 110–181, div. A, title XII, § 1207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/367"},"text":"122 Stat. 367","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1064/5"},"text":"Pub. L. 112–81, div. A, title X, § 1064(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1587"},"text":"125 Stat. 1587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tX/s1042/a"},"text":"Pub. L. 118–31, div. A, title X, § 1042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/388"},"text":"137 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1041"},"text":"Pub. L. 119–60, div. A, title X, § 1041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1035"},"text":"139 Stat. 1035","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7b8734d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7b8734e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7b8734f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1041/1"},"text":"Pub. L. 119–60, § 1041(1)","children":[],"tail":", inserted “and procure goods and services from” after “assistance to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1041/2"},"text":"Pub. L. 119–60, § 1041(2)","children":[],"tail":", substituted “$15,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1042/a/1"},"text":"Pub. L. 118–31, § 1042(a)(1)","children":[],"tail":", substituted “Assistance in support of” for “Equipment and training of foreign personnel to assist in” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1042/a/2"},"text":"Pub. L. 118–31, § 1042(a)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1042/a/3"},"text":"Pub. L. 118–31, § 1042(a)(3)","children":[],"tail":", in heading, substituted “Limitations” for “Limitation”, and, in text, substituted “(1) Except as provided in paragraph (2), the” for “The” and “$5,000,000” for “$1,000,000” and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1042/a/4"},"text":"Pub. L. 118–31, § 1042(a)(4)","children":[],"tail":", (5), added subsec. (f) and struck out former subsec. (f). Prior to amendment, text read as follows: “Whenever the Secretary of Defense provides assistance to a foreign nation under this section, the Secretary shall submit to the congressional defense committees a report on the assistance provided. Each such report shall identify the nation to which the assistance was provided and include a description of the type and amount of the assistance provided.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Not later than December 31 each year, the Secretary of Defense shall submit to the congressional defense committees a report on the assistance provided under this section during the fiscal year ending in such year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Each report under paragraph (1) shall include, for the fiscal year covered by such report, the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) A listing of each foreign nation provided assistance under this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) For each nation so provided assistance, a description of the type and amount of such assistance.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
