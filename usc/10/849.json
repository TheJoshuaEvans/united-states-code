{"tag":"section","attrib":{"id":"ida81cb453-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849"},"text":null,"children":[{"tag":"num","attrib":{"value":"849"},"text":"§ 849.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 49. Depositions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81cb454-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb455-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), a convening authority or a military judge may order depositions at the request of any party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb456-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A deposition may be ordered under paragraph (1) only if the requesting party demonstrates that, due to exceptional circumstances, it is in the interest of justice that the testimony of a prospective witness be preserved for use at a court-martial, military commission, court of inquiry, or other military court or board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb457-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A party who requests a deposition under this section shall give to every other party reasonable written notice of the time and place for the deposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb458-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A deposition under this section shall be taken before, and authenticated by, an impartial officer, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81cb459-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever practicable, by an impartial judge advocate certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s827/b"},"text":"section 827(b) of this title","children":[],"tail":" (article 27(b))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb45a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In exceptional circumstances, by an impartial military or civil officer authorized to administer oaths by (i) the laws of the United States or (ii) the laws of the place where the deposition is taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb45b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation by Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Representation of the parties with respect to a deposition shall be by counsel detailed in the same manner as trial counsel and defense counsel are detailed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s827"},"text":"section 827 of this title","children":[],"tail":" (article 27). In addition, the accused shall have the right to be represented by civilian or military counsel in the same manner as such counsel are provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s838/b"},"text":"section 838(b) of this title","children":[],"tail":" (article 38(b))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb45c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Admissibility and Use as Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A deposition order under subsection (a) does not control the admissibility of the deposition in a court-martial or other proceeding under this chapter. Except as provided by subsection (d), a party may use all or part of a deposition as provided by the rules of evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb45d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s849/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Testimony by deposition may be presented in capital cases only by the defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81cb45e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/53"},"text":"70A Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/20"},"text":"Pub. L. 90–632, § 2(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1340"},"text":"82 Stat. 1340","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/209/s6/b"},"text":"Pub. L. 98–209, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1400"},"text":"97 Stat. 1400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/3"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s532"},"text":"Pub. L. 113–291, div. A, title V, § 532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3366"},"text":"128 Stat. 3366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVII/s5231"},"text":"Pub. L. 114–328, div. E, title LVII, § 5231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2914"},"text":"130 Stat. 2914","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81cb45f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81cb460-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81cb461-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"849(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"849(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:624(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:624(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 49), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/123"},"text":"64 Stat. 123","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"849(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:624(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"849(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:624(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"849(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:624(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"849(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:624(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “commissioned” is inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “Commonwealth” is inserted to reflect the present status of Puerto Rico. The words “of Columbia” are inserted after the word “District” for clarity. The words “the distance of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (e) and (f), the words “the requirements of” and the words “of this article” are omitted as surplusage. The word “presented” is substituted for the word “adduced” in subsection (e).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the word “directs” is substituted for the words “shall have directed”. The words “by law” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81cb462-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81cb463-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (f) relating to ordering depositions, notice, military and civil officers authorized to take depositions, use of depositions as evidence, testimony by deposition by the defense in capital cases, and use of deposition as evidence in cases in which the death penalty is authorized, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “At any time after charges have been signed as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s830"},"text":"section 830 of this title","children":[],"tail":" (article 30), any party may take oral or written depositions unless the military judge or court-martial without a military judge hearing the case or, if the case is not being heard, an authority competent to convene a court-martial for the trial of those charges forbids it for good cause. If a deposition is to be taken before charges are referred for trial, such an authority may designate commissioned officers to represent the prosecution and the defense and may authorize those officers to take the deposition of any witness.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" struck out “Territory,” after “State,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsecs. (d), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" inserted “or, in the case of audiotape, videotape, or similar material, may be played in evidence” after “read in evidence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" inserted reference to the taking of depositions being forbidden by the military judge or the court-martial without a military judge if the case is being heard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81cb464-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb465-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb466-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" effective on first day of eighth calendar month beginning after "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", but not to apply to any case in which the findings and sentence were adjudged by a court-martial before that date, and the proceedings in any such case to be held in the same manner and with the same effect as if such amendments had not been enacted, see section 12(a)(1), (4) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb467-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" effective first day of tenth month following October 1968, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s4"},"text":"section 4 of Pub. L. 90–632","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
