{"tag":"section","attrib":{"id":"idaa32c24c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709"},"text":null,"children":[{"tag":"num","attrib":{"value":"3709"},"text":"§ 3709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to accelerate contracting and pricing processes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa32c24d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall establish a program to reform and accelerate the contracting and pricing processes associated with contracts in excess of $50,000,000 by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c24e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basing price reasonableness determinations on actual cost and pricing data for purchases of the same or similar products for the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c24f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the cost and pricing data to be submitted in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa32c250-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Under Secretary of Defense for Acquisition and Sustainment, shall ensure that each senior contracting official (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1737"},"text":"section 1737 of this title","children":[],"tail":") for a contract described in subsection (a) has the discretion to implement the program under this section efficiently and effectively by ensuring the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c251-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the program does not include any preferences for contract type or specific contract requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c252-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That each Secretary of a military department has no unique reporting requirements to the Under Secretary of Defense for Acquisition and Sustainment with respect to the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa32c253-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s812/c"},"text":"Pub. L. 119–60, div. A, title VIII, § 812(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/952"},"text":"139 Stat. 952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa32c254-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa32c255-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa32c256-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s890"},"text":"Pub. L. 115–232, div. A, title VIII, § 890","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1919"},"text":"132 Stat. 1919","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s825"},"text":"Pub. L. 116–92, div. A, title VIII, § 825","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1491"},"text":"133 Stat. 1491","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1831/j/7"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1831(j)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4217"},"text":"134 Stat. 4217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s818"},"text":"Pub. L. 117–263, div. A, title VIII, § 818","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2708"},"text":"136 Stat. 2708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVIII/s841"},"text":"Pub. L. 118–31, div. A, title VIII, § 841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/339"},"text":"137 Stat. 339","children":[],"tail":", which was formerly set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3701"},"text":"section 3701 of this title","children":[],"tail":" before being transferred to this chapter and renumbered as this section by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s812/c/1"},"text":"Pub. L. 119–60, div. A, title VIII, § 812(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/952"},"text":"139 Stat. 952","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa32c257-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s812/c/2/A"},"text":"Pub. L. 119–60, § 812(c)(2)(A)","children":[],"tail":", (B), struck out “Pilot” before “program” in section catchline and “pilot” before “program” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s812/c/2/C"},"text":"Pub. L. 119–60, § 812(c)(2)(C)","children":[],"tail":", substituted “this chapter” for “chapter 271 of title 10, United States Code”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s812/c/2/D/i"},"text":"Pub. L. 119–60, § 812(c)(2)(D)(i)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1737"},"text":"section 1737 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1737"},"text":"section 1737 of title 10","children":[],"tail":", United States Code” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s812/c/2/D/ii"},"text":"Pub. L. 119–60, § 812(c)(2)(D)(ii)","children":[],"tail":", substituted “no unique reporting” for “minimal reporting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s812/c/2/E"},"text":"Pub. L. 119–60, § 812(c)(2)(E)","children":[],"tail":", struck out subsecs. (c) and (d), which, respectively, required submission of report on pilot program and provided that pilot program would expire on "},{"tag":"date","attrib":{"date":"2028-01-02"},"text":"Jan. 2, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
