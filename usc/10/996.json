{"tag":"section","attrib":{"id":"ida84793f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996"},"text":null,"children":[{"tag":"num","attrib":{"value":"996"},"text":"§ 996.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual Longitudinal Exposure Record","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84793f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall maintain a data system that is a central web portal for exposure-related data that compiles, collates, presents, and provides available occupational and environmental exposure information to support the needs of the Department of Defense and the Department of Veterans Affairs. Such data system shall be referred to as the “Individual Longitudinal Exposure Record”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Individual Longitudinal Exposure Record includes the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84793f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service records of members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All data available to the Secretary regarding how, where, and when members of the armed forces have been exposed to various occupational or environmental hazards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical records of members relating to exposures described in paragraph (2), including diagnoses, treatment plans, and laboratory data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a member is a member described in paragraph (2) of subsection (b), the Secretary shall include the data described in such paragraph in the service record of such member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Sharing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide access to information in the Individual Longitudinal Exposure Record to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84793f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Defense Health Agency, for use by health care providers, epidemiologists, and researchers of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Health of the Department of Veterans Affairs, for use by health care providers, epidemiologists, and researchers of such department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary for Benefits of the Department of Veterans Affairs, for use by personnel of such department regarding compensation and benefits for service-connected disabilities or death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84793fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84793fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall submit, to the committees specified in paragraph (2), an annual briefing regarding the Individual Longitudinal Exposure Record, including an explanation of how the Secretary intends to include in the Individual Longitudinal Exposure Record data described in subsection (b)(2) in cases where part or all of such data is classified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84793ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The committees specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8479400-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Armed Services of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8479401-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Armed Services of House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8479402-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Veterans’ Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8479403-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s996/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee on Veterans’ Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8479404-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s521/a"},"text":"Pub. L. 119–60, div. A, title V, § 521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/863"},"text":"139 Stat. 863","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
