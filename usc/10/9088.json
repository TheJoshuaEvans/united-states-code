{"tag":"section","attrib":{"id":"idab63ef68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088"},"text":null,"children":[{"tag":"num","attrib":{"value":"9088"},"text":"§ 9088.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty assignments after officer training course","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63ef69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force shall ensure that members of the Space Force who complete an initial Space Force officer training course are assigned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that sustains acquisition billet manning levels comparably to operational billet manning levels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Space Force billets allocated to the National Reconnaissance Office at a manning level that is sufficient to maintain effective operation of the National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2026, and not later than October 31 of each year through 2030, the Secretary of the Air Force shall submit to the Committees on Armed Forces of the Senate and the House of Representatives a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number and percentage of authorized and assigned Space Force officer billets, by grade and year group, within—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab63ef6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition career fields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab63ef6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational career fields;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manning rate for junior officer billets of the Space Force, disaggregated by career field and organization, including the National Reconnaissance Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified shortfalls or imbalances in acquisition manning relative to operational manning in the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9088/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken or planned to achieve and sustain comparable manning levels for billets in acquisition and operations for Space Force officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef73-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1601/a"},"text":"Pub. L. 119–60, div. A, title XVI, § 1601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1172"},"text":"139 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab63ef74-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab63ef75-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab63ef76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2026, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
