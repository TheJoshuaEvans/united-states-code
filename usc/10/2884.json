:"ref","attrib":{"href":"/us/pl/119/60/s2823/a/1/A"},"text":"Pub. L. 119–60, § 2823(a)(1)(A)","children":[],"tail":", added pars. (15) to (18)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s2823/a/2"},"text":"Pub. L. 119–60, § 2823(a)(2)","children":[],"tail":", substituted “paragraphs (1) through (18) of subsection (c)” for “paragraphs (1) through (14) of subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2803/c/1/A"},"text":"Pub. L. 116–283, § 2803(c)(1)(A)","children":[],"tail":", substituted “The Secretary concerned” for “The Secretary of Defense” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2803/c/1/B"},"text":"Pub. L. 116–283, § 2803(c)(1)(B)","children":[],"tail":", inserted “or agreement” after “each contract” and struck out “that the Secretary proposes to solicit” after “unaccompanied housing units”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2803/c/2"},"text":"Pub. L. 116–283, § 2803(c)(2)","children":[],"tail":", substituted “A report required by paragraph (1)” for “For each proposed contract, conveyance, or lease described in paragraph (1), the report required by such paragraph” in introductory provisions and inserted “agreement,” after “contract,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2803/c/3"},"text":"Pub. L. 116–283, § 2803(c)(3)","children":[],"tail":", inserted “or agreement” after “contract” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2811/h"},"text":"Pub. L. 116–283, § 2811(h)","children":[],"tail":", amended par. (10) generally. Prior to amendment, par. (10) read as follows: “An assessment of the dispute resolution process, which shall include a specific analysis of each denied tenant request to withhold rent payments and each instance in which the dispute resolution process resulted in a favorable outcome for the landlord.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(7) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added pars. (7) to (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (4) and struck out former par. (4) which read as follows: “The report shall be submitted not later than 30 days before the date on which the Secretary issues the contract solicitation or offers the conveyance or lease or, if earlier, a period of 20 days has elapsed from the date on which a copy of the report is provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “an evaluation” for “on evaluation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" added subsecs. (b) and (c) and struck out former subsec. (b) which required the Secretary of Defense to provide annual reports to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" inserted “, to specifically include any unique variances associated with litigation costs” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s2803/g"},"text":"Pub. L. 111–383, § 2803(g)","children":[],"tail":", inserted before period at end “or, if earlier, a period of 20 days has elapsed from the date on which a copy of the report is provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/h/6"},"text":"Pub. L. 111–383, § 1075(h)(6)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s2806/c/2/A"},"text":"Pub. L. 109–163, § 2806(c)(2)(A)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s2805/b"},"text":"Pub. L. 110–417, § 2805(b)","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s2805/f"},"text":"Pub. L. 110–417, § 2805(f)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s2806/c/1"},"text":"Pub. L. 109–163, § 2806(c)(1)","children":[],"tail":", inserted before period “, including a description of the specific construction, acquisition, or improvement projects from which funds were transferred to the Funds established under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2883"},"text":"section 2883 of this title","children":[],"tail":" in order to finance the contract, conveyance, or lease”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s2806/c/2/B"},"text":"Pub. L. 109–163, § 2806(c)(2)(B)","children":[],"tail":", (C), substituted “covering each of the Funds” for “covering the Funds” and inserted before period at end “, including a description of the specific construction, acquisition, or improvement projects from which funds were transferred and the privatization projects or contracts to which those funds were transferred. Each report shall also include, for each military department or defense agency, a description of all funds to be transferred to such Funds for the current fiscal year and the next fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s2806/c/2/A"},"text":"Pub. L. 109–163, § 2806(c)(2)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/h/6"},"text":"Pub. L. 111–383, § 1075(h)(6)","children":[],"tail":", substituted “A separate report” for “A report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s2806/a"},"text":"Pub. L. 108–375, § 2806(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The report shall describe the proposed contract, conveyance, or lease and the intended method of participation of the United States in the contract, conveyance, or lease and provide a justification of such method of participation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s2806/b"},"text":"Pub. L. 108–375, § 2806(b)","children":[],"tail":", added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s2807/a"},"text":"Pub. L. 108–136, § 2807(a)","children":[],"tail":", designated second sentence of par. (2) as par. (4) and added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s2807/b/1"},"text":"Pub. L. 108–136, § 2807(b)(1)","children":[],"tail":", inserted before period at end “, and such recommendations as the Secretary considers necessary for improving the extent and effectiveness of the use of such authorities in the future”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s2807/b/2"},"text":"Pub. L. 108–136, § 2807(b)(2)","children":[],"tail":", added pars. (3) to (5) and struck out former par. (3) which read as follows: “A description of the objectives of the Department of Defense for providing military family housing and military unaccompanied housing for members of the armed forces.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9eda340-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9eda341-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4377"},"text":"124 Stat. 4377","children":[],"tail":", provided that amendment by section 1075(h)(6) is effective as of "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9eda342-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Final Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/b"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/551"},"text":"110 Stat. 551","children":[],"tail":", provided that, not later than "},{"tag":"date","attrib":{"date":"2000-03-01"},"text":"Mar. 1, 2000","children":[],"tail":", the Secretary of Defense was to submit to the congressional defense committees a report on the use by the Secretary of Defense and the Secretaries of the military departments of the authorities provided by subchapter IV of chapter 169 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
