}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab9ade5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab9ade5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Appointments made in the permanent reserve grade of warrant officer, W–1, shall be made by warrant by the Secretary concerned. Appointments made in a permanent reserve grade of chief warrant officer shall be made by commission by the Secretary concerned.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s597"},"text":"section 597 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" substituted “section 571(a)” for “section 555(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Reserve chief warrant officers of the Army and the Air Force shall be appointed in those grades, by warrant, by the Secretary concerned. Permanent reserve chief warrant officers of the Navy, Marine Corps, and Coast Guard shall be appointed in those grades, by commission, by the Secretary concerned. Permanent reserve warrant officers, W-1, shall be appointed in those grades, by warrant, by the Secretary concerned.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab9ade5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab9ade5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1132"},"text":"section 1132 of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab9ade60-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s531/d"},"text":"Pub. L. 99–145, title V, § 531(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/633"},"text":"99 Stat. 633","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tV/s531/d"},"text":"“This section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s555"},"text":"section 555 of this title","children":[],"tail":" and enacting provisions set out below] takes effect six months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab9ade61-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions for 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s531/c"},"text":"Pub. L. 99–145, title V, § 531(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/633"},"text":"99 Stat. 633","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tV/s531/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s555"},"text":"section 555 of this title","children":[],"tail":"] apply to any appointment of a warrant officer or chief warrant officer on or after the effective date of this section [see Effective Date of 1985 Amendment note above]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who on the effective date of this section is serving in a chief warrant officer grade under an appointment by warrant may be appointed in that grade by commission under section 555(b) or 597(b) [now 12241(b)] of title 10, United States Code, as appropriate. The date of rank of an officer who receives an appointment under this paragraph is the date of rank for the officer’s appointment by warrant to that grade.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab9ade62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Presidential Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s502/c"},"text":"Pub. L. 111–383, div. A, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4207"},"text":"124 Stat. 4207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tV/s502/c"},"text":"“Except as otherwise provided by the President by Executive order, the provisions of Executive Order 13384 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s531"},"text":"10 U.S.C. 531","children":[],"tail":" note) relating to the functions of the President under the second sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s571/b"},"text":"section 571(b) of title 10","children":[],"tail":", United States Code, shall apply in the same manner to the functions of the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12241/b"},"text":"section 12241(b) of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idab9ade63-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idab9ade64-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under subsec. (b) of this section to appoint by commission reserve chief warrant officers in the Coast Guard delegated to Secretary of Homeland Security by Ex. Ord. No. 14106, § 1(h), ","children":[{"tag":"date","attrib":{"date":"2023-08-14"},"text":"Aug. 14, 2023","children":[],"tail":", 88 F.R. 55905, set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2101"},"text":"section 2101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
