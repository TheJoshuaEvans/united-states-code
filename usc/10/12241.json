{"tag":"section","attrib":{"id":"idab9ade54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12241"},"text":null,"children":[{"tag":"num","attrib":{"value":"12241"},"text":"§ 12241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warrant officers: grades; appointment, how made; term","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9ade55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permanent reserve warrant officer grades in each armed force are those prescribed for regular warrant officers by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s571/a"},"text":"section 571(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9ade56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments in permanent reserve warrant officer grades shall be made in the same manner as is prescribed for regular warrant officer grades by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s571/b"},"text":"section 571(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9ade57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments as Reserves in permanent warrant officer grades are for an indefinite term and are held during the pleasure of the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9ade58-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act