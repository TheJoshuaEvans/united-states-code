{"tag":"section","attrib":{"id":"ida987195c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496"},"text":null,"children":[{"tag":"num","attrib":{"value":"2496"},"text":"§ 2496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of certain goods from the Xinjiang Uyghur Autonomous Region prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida987195d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not knowingly permit the sale, at a commissary store or military exchange, of any good, ware, article, or merchandise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida987195e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" containing any product mined, produced, or manufactured, wholly or in part, by forced labor from the XUAR; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida987195f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from an entity that has used labor from within or transferred from XUAR as part of a “poverty alleviation” or “pairing assistance” program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871961-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “forced labor” means any work or service that is exacted from any person under the menace of any penalty for nonperformance and that the worker does not offer to perform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871962-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2496/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “XUAR” means the Xinjiang Uyghur Autonomous Region of the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9871963-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s651/a"},"text":"Pub. L. 117–263, div. A, title VI, § 651(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2639"},"text":"136 Stat. 2639","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
