 Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3037(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3037(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3037(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:21h(c).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:61a.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:741.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:62.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:62a.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:63.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s208/c"},"text":"June 28, 1950, ch. 383, § 208(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/267"},"text":"64 Stat. 267","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"June 24, 1948, ch. 625","children":[],"tail":", §§ 248, 249, "},{"tag":"html:a","attrib":{"href":"/us/stat/62/643"},"text":"62 Stat. 643","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s13"},"text":"May 5, 1950, ch. 169, § 13","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/147"},"text":"64 Stat. 147","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1199.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1874-06-23/ch458/s2"},"text":"June 23, 1874, ch. 458, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/18/244"},"text":"18 Stat. 244","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1201.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Notwithstanding any other provision of law” and “for such positions” are omitted as surplusage. The last sentence is substituted for 10:61a (last sentence). 10:21h(c) is omitted as covered by 10:61a.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Hereafter” and “exclusive of the present incumbents” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “In addition to duties elsewhere prescribed for him by law”, in 10:62, are omitted as surplusage. The words “and perform such other duties as may be prescribed by the Secretary of the Army”, in 10:62, are omitted as superseded by sections 3012(e) and 3036(d) of this title. Clause (2) is substituted for 10:62a (words after semicolon) and 63. The ","children":[{"tag":"ref","attrib":{"href":"/us/act/1874-06-23/ch458/s2"},"text":"Act of June 23, 1874, ch. 458, § 2","children":[],"tail":" (words before semicolon of 1st sentence, and last sentence), "},{"tag":"ref","attrib":{"href":"/us/stat/18/244"},"text":"18 Stat. 244","children":[],"tail":", are not contained in 10:62. They are also omitted from the revised section as superseded by sections 3037(a) and 3211 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad73fa2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1958 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change corrects an inadvertence. The source statute for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3036/c"},"text":"section 3036(c) of title 10","children":[],"tail":" (the third sentence of sec. 513(a) of the Officer Personnel Act of 1947, "},{"tag":"ref","attrib":{"href":"/us/stat/61/901"},"text":"61 Stat. 901","children":[],"tail":"), providing for a 4-year term of office, applied also to the Judge Advocate General and the Assistant Judge Advocate General. As restated in section 3036(c), it now applies only to the officers named in section 3036(b), which excludes the two officers named. For this reason, the effect of the source statute with respect to those officers is added to section 3037(a), relating to their appointment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad73fa3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad73fa4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3037"},"text":"section 3037 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" struck out last two sentences which read as follows: “The Judge Advocate General, while so serving, has the grade of lieutenant general. An officer appointed as Deputy Judge Advocate General who holds a lower regular grade shall be appointed in the regular grade of major general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s543/a/3/A"},"text":"Pub. L. 110–181, § 543(a)(3)(A)","children":[],"tail":", amended section catchline generally, substituting “Deputy” for “Assistant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s543/a/1"},"text":"Pub. L. 110–181, § 543(a)(1)","children":[],"tail":", (2)(A), substituted “Deputy Judge Advocate General” for “Assistant Judge Advocate General” wherever appearing and substituted “The Judge Advocate General, while so serving, has the grade of lieutenant general.” for “The Judge Advocate General, while so serving, shall hold a grade not lower than major general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s543/a/2/B"},"text":"Pub. L. 110–181, § 543(a)(2)(B)","children":[],"tail":", substituted “Deputy Judge Advocate General” for “Assistant Judge Advocate General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s508/a"},"text":"Pub. L. 109–163, § 508(a)","children":[],"tail":", substituted “The Judge Advocate General, while so serving, shall hold a grade not lower than major general. An officer appointed as Assistant Judge Advocate General who holds a lower regular grade shall be appointed in the regular grade of major general.” for “If an officer who is so appointed holds a lower regular grade, he shall be appointed in the regular grade of major general.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/a/2"},"text":"Pub. L. 109–163, § 1057(a)(2)","children":[],"tail":", struck out “or Territory” after “a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s574/a/1"},"text":"Pub. L. 108–375, § 574(a)(1)","children":[],"tail":", substituted “The term of office of the Judge Advocate General and the Assistant Judge Advocate General is four years.” for “An officer appointed as the Judge Advocate General or Assistant Judge Advocate General normally holds office for four years. However, the President may terminate or extend the appointment at any time.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s574/a/2"},"text":"Pub. L. 108–375, § 574(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" provided that the Judge Advocate General or Assistant Judge Advocate General shall normally hold office for four years, and empowered the President to terminate or extend the appointment at any time."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad73fa5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad73fa6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad73fa7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/g"},"text":"section 33(g) of Pub. L. 85–861","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
