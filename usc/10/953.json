{"tag":"section","attrib":{"id":"ida83df74e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s953"},"text":null,"children":[{"tag":"num","attrib":{"value":"953"},"text":"§ 953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remission or suspension of sentence; restoration to duty; reenlistment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For offenders who were at the time of commission of their offenses subject to his authority and who merit such action, the Secretary concerned shall establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83df74f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s953/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system for the remission or suspension of the unexecuted part of the sentences of selected offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df750-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s953/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system for the restoration to duty of such offenders who have had the unexecuted part of their sentences remitted or suspended and who have not been discharged; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df751-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s953/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system for the enlistment of such offenders who have had the unexecuted part of their sentences remitted and who have been discharged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83df752-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/377/s1"},"text":"Pub. L. 90–377, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-05"},"text":"July 5, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/287"},"text":"82 Stat. 287","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
