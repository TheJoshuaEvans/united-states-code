{"tag":"section","attrib":{"id":"ida98bd436-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567"},"text":null,"children":[{"tag":"num","attrib":{"value":"2567"},"text":"§ 2567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space and services: provision to WIC offices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida98bd437-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allotment of Space and Provision of Services Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application by a WIC office, the Secretary of a military department may allot space on a military installation under the jurisdiction of the Secretary to the WIC office without charge for rent or services if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the WIC office provides or will provide services solely to members of the armed forces assigned to the installation, civilian employees of the Department of Defense employed at the installation, or dependents of such members or employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space is available on the installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd43a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the WIC office will not hinder military mission requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd43b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security situation at the installation permits the presence of a non-Federal entity on the installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd43c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd43d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “services” includes the provision of lighting, heating, cooling, and electricity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd43e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2567/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “WIC office” means a local agency (as defined in subsection (b)(6) of section 17 of the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"42 U.S.C. 1786","children":[],"tail":")) that participates in the special supplemental nutrition program for women, infants, and children under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida98bd43f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2812/a"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2812(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2716"},"text":"130 Stat. 2716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida98bd440-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida98bd441-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida98bd442-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2567, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1076/b/1"},"text":"Pub. L. 109–364, div. A, title X, § 1076(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2405"},"text":"120 Stat. 2405","children":[],"tail":", which related to supplies, services, and equipment: provision in major public emergencies, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1068/b/1"},"text":"Pub. L. 110–181, div. A, title X, § 1068(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/326"},"text":"122 Stat. 326","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
