{"tag":"section","attrib":{"id":"idabb76747-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14513"},"text":null,"children":[{"tag":"num","attrib":{"value":"14513"},"text":"§ 14513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of selection for promotion: transfer, retirement, or discharge","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each reserve officer of the Army, Navy, Air Force, or Marine Corps who is in an active status and whose removal from an active status or from a reserve active-status list is required by section 14504, 14505, or 14506 of this title shall (unless the officer’s separation is deferred or the officer is continued in an active status under another provision of law) not later than the date specified in those sections—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb76748-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14513/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred to an inactive status if the Secretary concerned determines that the officer has skills which may be required to meet the mobilization needs of the officer’s armed force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb76749-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14513/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred to the Retired Reserve if the officer is qualified for such transfer and does not request (in accordance with regulations prescribed by the Secretary concerned) not to be transferred to the Retired Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb7674a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14513/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the officer is not transferred to an inactive status or to the Retired Reserve, be discharged from the officer’s reserve appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb7674b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2953"},"text":"108 Stat. 2953","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s517/b/1"},"text":"Pub. L. 107–107, div. A, title V, § 517(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1094"},"text":"115 Stat. 1094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb7674c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb7674d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb7674e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/b/2/A"},"text":"Pub. L. 107–107, § 517(b)(2)(A)","children":[],"tail":", substituted “Failure of selection for promotion: transfer, retirement, or discharge” for “Separation for failure of selection of promotion” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/b/1"},"text":"Pub. L. 107–107, § 517(b)(1)","children":[],"tail":", substituted “if the officer is qualified for such transfer and does not request (in accordance with regulations prescribed by the Secretary concerned) not to be transferred to the Retired Reserve” for “, if the officer is qualified and applies for such transfer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb7674f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb76750-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" effective on the first day of the first month that begins more than 180 days after "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/g"},"text":"section 517(g) of Pub. L. 107–107","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10154"},"text":"section 10154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb76751-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 