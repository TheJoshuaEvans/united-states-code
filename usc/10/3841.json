(c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2313"},"text":"section 2313 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (d), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1835/b/1"},"text":"Pub. L. 116–283, § 1835(b)(1)","children":[],"tail":", (5), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2201/a/1"},"text":"Pub. L. 103–355, title II, § 2201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3317"},"text":"108 Stat. 3317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 871(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4555"},"text":"122 Stat. 4555","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2313"},"text":"section 2313 of this title","children":[],"tail":", which was transferred to this section and redesignated as subsec. (e) by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1835/b/1"},"text":"Pub. L. 116–283, § 1835(b)(1)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVIII/s808/a"},"text":"Pub. L. 104–201, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2607"},"text":"110 Stat. 2607","children":[],"tail":", which amended subsec. (d) generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2313"},"text":"section 2313 of this title","children":[],