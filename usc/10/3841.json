283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3c5f79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exception From Records Examination Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Requirements under subsecs. (b)(2)(A)–(C) and (c) of this section (former subsecs. (a)(2)(A)–(C) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2313"},"text":"section 2313 of this title","children":[],"tail":") not applicable to certain contracts valued at less than $7,500,000 awarded to small business or nontraditional defense contractors, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s873/b"},"text":"section 873(b) of Pub. L. 114–92","children":[],"tail":", set out in a Pilot Program for Streamlining Awards for Innovative Technology Projects note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3702"},"text":"section 3702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3c5f7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Defense Access to, Use of, and Safeguards and Protections for Contractor Internal Audit Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s832"},"text":"Pub. L. 112–239, div. A, title VIII, § 832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1844"},"text":"126 Stat. 1844","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tVIII/s832"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revised Guidance Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"], the Director of the Defense Contract Audit Agency shall revise guidance on access to defense contractor internal audit reports (including the Contract Audit Manual) to incorporate the requirements of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The revised guidance shall ensure that requests for access to defense contractor internal audit reports are appropriately documented. The required documentation shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Written determination that access to such reports is necessary to complete required evaluations of contractor business systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of any request from the Defense Contract Audit Agency to a contractor for access to such reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A record of response received from the contractor, including the contractor’s rationale or justification if access to requested reports was not granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" [sic] ","children":[{"tag":"inline","attrib":{},"text":"Safeguards and Protections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The revised guidance shall include appropriate safeguards and protections to ensure that contractor internal audit reports cannot be used by the Defense Contract Audit Agency for any purpose other than evaluating and testing the efficacy of contractor internal controls and the reliability of associated contractor business systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk-based Auditing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination by the Defense Contract Audit Agency that a contractor has a sound system of internal controls shall provide the basis for increased reliance on contractor business systems or a reduced level of testing with regard to specific audits, as appropriate. Internal audit reports provided by a contractor pursuant to this section may be considered in determining whether or not a contractor has a sound system of internal controls, but shall not be the sole basis for such a determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act, the Comptroller General of the United States shall initiate a review of the documentation required by subsection (a). Not later than 90 days after completion of the review, the Comptroller General shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report on the results of the review, with findings and recommendations for improving the audit processes of the Defense Contract Audit Agency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idaa3c5f7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3c5f7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemption of Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Functions with respect to purchases authorized to be made outside limits of United States or District of Columbia under Foreign Assistance Act of 1961, as amended, as exempt, see Ex. Ord. No. 11223, ","children":[{"tag":"date","attrib":{"date":"1965-05-12"},"text":"May 12, 1965","children":[],"tail":", 30 F.R. 6635, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2393"},"text":"section 2393 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3c5f7d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Foreign Contractors","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretaries of Defense, Army, Navy, or Air Force, or their designees, to determine, prior to exercising authority provided in amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/607"},"text":"Pub. L. 89–607","children":[],"tail":" to exempt certain contracts with foreign contractors from requirement of an examination-of-records clause, that all reasonable efforts have been made to include such examination-of-records clause, as required by par. (11) of Part I of Ex. Ord. No. 10789, and that alternate sources of supply are not reasonably available, see par. (11) of Part I of Ex. Ord. No. 10789, "},{"tag":"date","attrib":{"date":"1958-11-14"},"text":"Nov. 14, 1958","children":[],"tail":", 23 F.R. 8897, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1431"},"text":"section 1431 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
