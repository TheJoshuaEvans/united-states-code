{"tag":"section","attrib":{"id":"ida8ae1ddd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1184"},"text":null,"children":[{"tag":"num","attrib":{"value":"1184"},"text":"§ 1184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of officer: action by Secretary upon recommendation of board of inquiry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the military department concerned may remove an officer from active duty if the removal of such officer from active duty is recommended by a board of inquiry convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1182"},"text":"section 1182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8ae1dde-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s110"},"text":"Pub. L. 96–513, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2874"},"text":"94 Stat. 2874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s503/b/2"},"text":"Pub. L. 105–261, div. A, title V, § 503(b)(2)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2003"},"text":"112 Stat. 2003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ae1ddf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ae1de0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"t