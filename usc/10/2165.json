{"tag":"section","attrib":{"id":"ida9361262-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165"},"text":null,"children":[{"tag":"num","attrib":{"value":"2165"},"text":"§ 2165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Defense University: component institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9361263-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a National Defense University in the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9361264-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Component Institutions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Defense University consists of the following institutions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9361265-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National War College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361266-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Dwight D. Eisenhower School for National Security and Resource Strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361267-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Forces Staff College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361268-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Institute for National Strategic Studies (including a Center for Strategic Deterrence and Weapons of Mass Destruction Studies).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361269-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The College of Information and Cyberspace.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936126a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The College of International Security Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936126b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other educational institution of the Department of Defense that the Secretary considers appropriate and designates as an institution of the university.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"ida936126c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"[(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tIX/s904/b/2/B"},"text":"Pub. L. 109–364, div. A, title IX, § 904(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2353"},"text":"120 Stat. 2353","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida936126d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Funds for Professional Development Education Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funding for the professional development education operations of the National Defense University shall be provided from funds made available to the Secretary of Defense from the annual appropriation “Operation and Maintenance, Defense-wide”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida936126e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Faculty Research Grants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida936126f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may authorize the President of the National Defense University to accept qualifying research grants. Any such grant may only be accepted if the work under the grant is to be carried out by a professor or instructor of one of the institutions comprising the University for a scientific, literary, or educational purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361270-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A qualifying research grant under this subsection is a grant that is awarded on a competitive basis by an entity referred to in paragraph (3) for a research project with a scientific, literary, or educational purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361271-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A grant may be accepted under this subsection only from a corporation, fund, foundation, educational institution, or similar entity that is organized and operated primarily for scientific, literary, or educational purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361272-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish an account for administering funds received as research grants under this subsection. The President of the University shall use the funds in the account in accordance with applicable provisions of the regulations and the terms and condition of the grants received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361273-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to such limitations as may be provided in appropriations Acts, appropriations available for the National Defense University may be used to pay expenses incurred by the University in applying for, and otherwise pursuing, the award of qualifying research grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361274-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations for the administration of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9361275-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Research and Development Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9361276-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In engaging in research and development projects pursuant to subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4001"},"text":"section 4001 of this title","children":[],"tail":" by a contract, cooperative agreement, or grant pursuant to subsection (b)(1) of such section, the Secretary may enter into such contract or cooperative agreement or award such grant through the National Defense University."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361277-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2165/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Defense University shall be considered a Government-operated Federal laboratory for purposes of section 12 of the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710a"},"text":"15 U.S.C. 3710a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9361278-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX"},"text":"Pub. L. 105–85, div. A, title IX","children":[],"tail":", §§ 921(a)(1), 922(a), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1862"},"text":"111 Stat. 1862","children":[],"tail":", 1863; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIX"},"text":"Pub. L. 105–261, div. A, title IX","children":[],"tail":", §§ 904, 905(a), "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2093"},"text":"112 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 913(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–230; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s527/c/1"},"text":"Pub. L. 107–107, div. A, title V, § 527(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","a