{"tag":"section","attrib":{"id":"idab403c67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8703"},"text":null,"children":[{"tag":"num","attrib":{"value":"8703"},"text":"§ 8703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403c68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Settle Claim","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may settle any claim by the United States for salvage services rendered by the Department of the Navy and may receive payment of any such claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Salvage Services Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “salvage services” includes services performed in connection with a marine salvage operation that are intended to prevent, abate, or minimize damage to the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403c6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1015"},"text":"Pub. L. 104–106, div. A, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/425"},"text":"110 Stat. 425","children":[],"tail":", § 7363; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIII/s315/b"},"text":"Pub. L. 108–136, div. A, title III, § 315(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1431"},"text":"117 Stat. 1431","children":[],"tail":"; renumbered § 8703, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab403c6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab403c6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab403c6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7363"},"text":"section 7363 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab403c6e-3a6f