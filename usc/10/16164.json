{"tag":"section","attrib":{"id":"idabc10316-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164"},"text":null,"children":[{"tag":"num","attrib":{"value":"16164"},"text":"§ 16164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limitation for use of entitlement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc10317-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Entitlement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), a member remains entitled to educational assistance under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10318-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" while the member is serving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10319-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Selected Reserve of the Ready Reserve, in the case of a member called or ordered to active service while serving in the Selected Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1031a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Ready Reserve, in the case of a member ordered to active duty while serving in the Ready Reserve (other than the Selected Reserve); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1031b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person who separates from the Selected Reserve of the Ready Reserve after completion of a period of active service described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of this title","children":[],"tail":" and completion of a service contract under honorable conditions, during the 10-year period beginning on the date on which the person separates from the Selected Reserve."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc1031c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Entitlement for Disabled Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc1031d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a person who is separated from the Ready Reserve because of a disability which was not the result of the individual’s own willful misconduct incurred on or after the date on which such person became entitled to educational assistance under this chapter, such person’s entitlement to educational assistance expires at the end of the 10-year period beginning on the date on which such person became entitled to such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1031e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16164/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subsections (d) and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3031"},"text":"section 3031 of title 38","children":[],"tail":" shall apply to the period of entitlement prescribed by paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc1031f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s527/a"},"text":"Pub. L. 108–375, div. A, title V, § 527(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1892"},"text":"118 Stat. 1892","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s530/a/1"},"text":"Pub. L. 110–181, div. A, title V, § 530(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/110"},"text":"122 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 546(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4466"},"text":"122 Stat. 4466","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc10320-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc10321-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc10322-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “this chapter—” and pars. (1) and (2) for “this chapter while serving—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in the Selected Reserve of the Ready Reserve, in the case of a member called or ordered to active service while serving in the Selected Reserve; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) in the Ready Reserve, in the case of a member ordered to active duty while serving in the Ready Reserve (other than the Selected Reserve).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “honorable conditions” for “other than dishonorable conditions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabc10323-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabc10324-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 546(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4466"},"text":"122 Stat. 4466","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":"] and shall apply to a person described in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163"},"text":"section 16163 of title 10","children":[],"tail":", United States Code, who—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separates from a reserve component on or after ","children":[{"tag":"date","attrib":{"date":"2008-01-28"},"text":"January 28, 2008","children":[],"tail":", the date of the enactment of the National Defense Authorization Act for Fiscal Year 2008 ["},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of the enactment of this Act, has not used any of the person’s entitlement to educational assistance under chapter 1607 of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s530/c"},"text":"Pub. L. 110–181, div. A, title V, § 530(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/110"},"text":"122 Stat. 110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tV/s530/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16165"},"text":"section 16165 of this title","children":[],"tail":"] shall take effect as of "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"October 28, 2004","children":[],"tail":", as if included in the enactment of the Ronald W. Reagan National Defense Authorization Act for Fiscal Year 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Public Law 108–375","children":[],"tail":"), to which such amendments relate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
