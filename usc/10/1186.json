{"tag":"section","attrib":{"id":"ida8ae1df2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186"},"text":null,"children":[{"tag":"num","attrib":{"value":"1186"},"text":"§ 1186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer considered for removal: voluntary retirement or discharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ae1df3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time during proceedings under this chapter with respect to the removal of an officer from active duty, the Secretary of the military department concerned may grant a request by the officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ae1df4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for voluntary retirement, if the officer is qualified for retirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ae1df5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for discharge in accordance with subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ae1df6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer removed from active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1184"},"text":"section 1184 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ae1df7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if eligible for voluntary retirement under any provision of law on the date of such removal, be retired in the grade and with the retired pay for which he would be eligible if retired under such provision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ae1df8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if ineligible for voluntary retirement under any provision of law on the date of such removal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ae1df9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be honorably discharged in the grade then held, in the case of an officer whose case was brought under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1181"},"text":"section 1181 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ae1dfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged in the grade then held, in the case of an officer whose case was brought under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1181"},"text":"section 1181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ae1dfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1186/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is discharged under subsection (b)(2) is entitled, if eligible therefor, to separation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174/a/2"},"text":"section 1174(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ae1dfc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s110"},"text":"Pub. L. 96–513, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2874"},"text":"94 Stat. 2874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s501/f/1"},"text":"Pub. L. 101–510, div. A, title V, § 501(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1550"},"text":"104 Stat. 1550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ae1dfd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ae1dfe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ae1dff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “section 1174(a)(2)” for “section 1174(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ae1e00-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8ae1e01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under this section effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
