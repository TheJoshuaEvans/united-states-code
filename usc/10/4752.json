{"tag":"section","attrib":{"id":"idaa8d65a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4752"},"text":null,"children":[{"tag":"num","attrib":{"value":"4752"},"text":"§ 4752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remission of liquidated damages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the recommendation of the head of an agency, the Secretary of the Treasury may remit all or part, as he considers just and equitable, of any liquidated damages assessed for delay in performing a contract, made by that agency, that provides for such damages.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaa8d65a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/132"},"text":"70A Stat. 132","children":[],"tail":", § 2312; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/c"},"text":"Pub. L. 104–316, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3842"},"text":"110 Stat. 3842","children":[],"tail":"; renumbered § 4752, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1864/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1864(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4279"},"text":"134 Stat. 4279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa8d65a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaa8d65a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","at