{"tag":"section","attrib":{"id":"ida99ee6b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663"},"text":null,"children":[{"tag":"num","attrib":{"value":"2663"},"text":"§ 2663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land acquisition authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida99ee6b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of Land by Condemnation for Certain Military Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee6b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (f), the Secretary of a military department may have proceedings brought in the name of the United States, in a court of proper jurisdiction, to acquire by condemnation any interest in land, including temporary use, needed for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee6b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the site, construction, or operation of fortifications, coast defenses, or military training camps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction and operation of plants for the production of nitrate and other compounds, and the manufacture of explosives or other munitions of war; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and transmission of power for the operation of plants under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of war or when war is imminent, the United States may, immediately upon the filing of a petition for condemnation under paragraph (1), take and use the land to the extent of the interest sought to be acquired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition by Purchase in Lieu of Condemnation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned may contract for or buy any interest in land, including temporary use, needed for any purpose named in subsection (a), as soon as the owner fixes a price for it and the Secretary considers that price to be reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of Low-Cost Interests in Land","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee6bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department may acquire any interest in land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee6c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines is needed in the interest of national defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not cost more than $4,000,000, exclusive of administrative costs and the amounts of any deficiency judgments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department may acquire any interest in land that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee6c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines is needed solely to correct a deficiency that is life-threatening, health-threatening, or safety-threatening; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not cost more than $1,500,000, exclusive of administrative costs and the amounts of any deficiency judgments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not apply to the acquisition, as a part of the same project, of more than one parcel of land unless the parcels are noncontiguous, or, if contiguous, unless the total cost is not more than $750,000, in the case of an acquisition under paragraph (1), or $1,500,000, in the case of an acquisition under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations available to the Department of Defense for operation and maintenance or construction may be used for the acquisition of land or interests in land under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of Interests in Land When Need Is Urgent","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee6c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department may acquire any interest in land in any case in which the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee6c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition is needed in the interest of national defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition is required to maintain the operational integrity of a military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations of urgency do not permit the delay necessary to include the required acquisition in an annual Military Construction Authorization Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 10 days after the date on which the Secretary of a military department determines to acquire an interest in land under the authority of this subsection, the Secretary shall submit, in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":", to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a notice containing a description of the property and interest to be acquired and the reasons for the acquisition."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations available for military construction may be used for the purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Survey Authority; Acquisition Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Authority provided the Secretary of a military department by law to acquire an interest in real property (including a temporary interest) includes authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee6cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make surveys; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire the interest in real property by gift, purchase, exchange of real property owned by the United States, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advance Notice of Use of Condemnation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee6d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before commencing any legal proceeding to acquire any interest in land under subsection (a), including acquisition for temporary use, by condemnation, eminent domain, or seizure, the Secretary of the military department concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee6d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursue, to the maximum extent practicable, all other available options for the acquisition or use of the land, such as the purchase of an easement or the execution of a land exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee6d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the congressional defense committees a report containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida99ee6d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the land to be acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida99ee6d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that negotiations with the owner or owners of the land occurred, and that the Secretary tendered consideration in an amount equal to the fair market value of the land, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida99ee6d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the other approaches considered for acquiring use of the land, the reasons for the acquisition of the land, and the reasons why alternative acquisition strategies are inadequate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may have proceedings brought in the name of the United States to acquire the land after the end of the 21-day period beginning on the date on which the report is received by the committees in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to Advance Notice Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of a military department determines that the use of condemnation, eminent domain, or seizure to acquire an interest in land is required under subsection (a) to satisfy a requirement vital to national security, and that any delay would be detrimental to national security or the protection of health, safety, or the environment, the Secretary may have proceedings brought in the name of the United States to acquire the land in advance of submitting the report required by subsection (f)(1)(B). However, the Secretary shall submit the report not later than seven days after commencement of the legal proceedings with respect to the land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee6da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Land Acquisition Options in Advance of Military Construction Projects","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee6db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department may acquire an option on a parcel of real property before or after its acquisition is authorized by law, if the Secretary considers it suitable and likely to be needed for a military project of the military department under the jurisdiction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee6dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2663/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As consideration for an option acquired under paragraph (1), the Secretary may pay, from funds available to the military department under the jurisdiction of the Secretary for real property activities, an amount that is not more than 12 percent of the appraised fair market value of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida99ee6dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/147"},"text":"70A Stat. 147","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/14"},"text":"Pub. L. 85–861, § 33(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1565"},"text":"72 Stat. 1565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dB/tXXVIII/s2821/a"},"text":"Pub. L. 109–163, div. B, title XXVIII, § 2821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3511"},"text":"119 Stat. 3511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2821/b"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2821(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2474"},"text":"120 Stat. 2474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dB/tXXVIII/s2822/a"},"text":"Pub. L. 110–181, div. B, title XXVIII, § 2822(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/544"},"text":"122 Stat. 544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/g/6"},"text":"Pub. L. 111–383, div. A, title X, § 1075(g)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4377"},"text":"124 Stat. 4377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2811/b"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2811(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1848"},"text":"131 Stat. 1848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2804/b"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2248"},"text":"138 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida99ee6de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida99ee6df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida99ee6e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children"