:[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"Aug. 10, 1956","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/g"},"text":"section 33(g) of Pub. L. 85–861","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida99ee6e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2821/a"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2473"},"text":"120 Stat. 2473","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dB/tXXVIII/s2821/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of Congress that the Secretary of Defense, when acquiring land for military purposes, should—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make every effort to acquire the land by means of purchases from willing sellers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ condemnation, eminent domain, or seizure procedures only as a measure of last resort in cases of compelling national security requirements or at the request of the seller.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
