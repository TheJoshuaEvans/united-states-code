{"tag":"section","attrib":{"id":"ida7e35449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a"},"text":null,"children":[{"tag":"num","attrib":{"value":"580a"},"text":"§ 580a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced authority for selective early discharges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e3544a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may authorize the Secretary of a military department, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":", to take the action set forth in subsection (b) with respect to regular warrant officers of an armed force under the jurisdiction of that Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e3544b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department may, with respect to regular warrant officers of an armed force, when authorized to do so under subsection (a), convene selection boards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s573/c"},"text":"section 573(c) of this title","children":[],"tail":" to consider for discharge regular warrant officers on the warrant officer active-duty list—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e3544c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have served at least one year of active duty in the grade currently held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e3544d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose names are not on a list of warrant officers recommended for promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e3544e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are not eligible to be retired under any provision of law and are not within two years of becoming so eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e3544f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e35450-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an action under subsection (b), the Secretary of the military department concerned may submit to a selection board convened pursuant to that subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e35451-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of all regular warrant officers described in that subsection in a particular grade and competitive category; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e35452-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of all regular warrant officers described in that subsection in a particular grade and competitive category who also are in particular year groups or specialties, or both, within that competitive category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e35453-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned shall specify the total number of warrant officers to be recommended for discharge by a selection board convened pursuant to subsection (b). That number may not be more than 30 percent of the number of officers considered—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e35454-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each grade in each competitive category; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e35455-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each grade, year group, or specialty (or combination thereof) in each competitive category.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e35456-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A warrant officer who is recommended for discharge by a selection board convened pursuant to subsection (b) and whose discharge is approved by the Secretary concerned shall be discharged on a date specified by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e35457-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selection of warrant officers for discharge under this subsection shall be based on the needs of the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e35458-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The discharge of any warrant officer pursuant to this section shall be considered involuntary for purposes of any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e35459-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s580a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies to the Secretary of Homeland Security in the same manner and to the same extent as it applies to the Secretary of Defense. The Commandant of the Coast Guard shall take the action set forth in subsection (b) with respect to regular warrant officers of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e3545a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s504/a"},"text":"Pub. L. 103–160, div. A, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1644"},"text":"107 Stat. 1644","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s541/g"},"text":"Pub. L. 103–337, div. A, title V, § 541(g)","children":[],"tail":", title X, § 1070(a)(3), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2767"},"text":"108 Stat. 2767","children":[],"tail":", 2855; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tV/s501"},"text":"Pub. L. 114–92, div. A, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/806"},"text":"129 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e3545b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e3545c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7e3545d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s501/1"},"text":"Pub. L. 114–92, § 501(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"October 1, 2015","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"November 30, 1993","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s501/2"},"text":"Pub. L. 114–92, § 501(2)","children":[],"tail":", redesignated pars. (4) and (5) as (3) and (4), respectively, and struck out former par. (3) which read as follows: “The total number of regular warrant officers described in subsection (b) from any of the armed forces (or from any of the armed forces in a particular grade) who may be recommended during a fiscal year for discharge by a selection board convened pursuant to the authority of that subsection may not exceed 70 percent of the decrease, as compared to the preceding fiscal year, in the number of warrant officers of that armed force (or the number of warrant officers of that armed force in that grade) authorized to be serving on active duty as of the end of that fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/a/3"},"text":"Pub. L. 103–337, § 1070(a)(3)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"November 30, 1993","children":[],"tail":",” for “the date of the enactment of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s541/g"},"text":"Pub. L. 103–337, § 541(g)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7e3545e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7e3545f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7e35460-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s541/g"},"text":"section 541(g) of Pub. L. 103–337","children":[],"tail":" effective on the first day of the fourth month beginning after "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s541/h"},"text":"section 541(h) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s571"},"text":"section 571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
