{"tag":"section","attrib":{"id":"ida993002d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611"},"text":null,"children":[{"tag":"num","attrib":{"value":"2611"},"text":"§ 2611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional centers for security studies: acceptance of gifts and donations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida993002e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Accept Gifts and Donations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993002f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (c), the Secretary of Defense may, on behalf of any Department of Defense regional center for security studies, any combination of such centers, or such centers generally, accept from any source specified in subsection (b) any gift or donation for purposes of defraying the costs or enhancing the operation of such a center, combination of centers, or centers generally, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930030-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the Department of Defense regional centers for security studies are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9930031-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The George C. Marshall European Center for Security Studies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930032-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Daniel K. Inouye Asia-Pacific Center for Security Studies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930033-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The William J. Perry Center for Hemispheric Defense Studies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930034-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Africa Center for Strategic Studies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930035-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Near East South Asia Center for Strategic Studies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930036-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Ted Stevens Center for Arctic Security Studies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930037-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sources from which gifts and donations may be accepted under subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930038-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The government of a State or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930039-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The government of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993003a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A foundation or other charitable organization, including a foundation or charitable organization this is organized or operates under the laws of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993003b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any source in the private sector of the United States or a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993003c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not accept a gift or donation under subsection (a) if acceptance of the gift or donation would compromise or appear to compromise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993003d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Department of Defense, any employee of the Department, or any member of the armed forces to carry out the responsibility or duty of the Department in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993003e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of any program of the Department, or of any person involved in such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993003f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe written guidance setting forth the criteria to be used in determining whether the acceptance of a gift or donation would have a result described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930040-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds accepted by the Secretary under section (a) shall be credited to appropriations available to the Department of Defense for the regional center, combination of centers, or centers generally for which accepted. Funds so credited shall be merged with the appropriations to which credited and shall be available for the regional center, combination of centers, or centers generally, as the case may be, for the same purposes as the appropriations with which merged. Any funds accepted under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930041-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2611/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift or Donation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “gift or donation” means any gift or donation of funds, materials (including research materials), real or personal property, or services (including lecture services and faculty services).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9930042-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s915/a"},"text":"Pub. L. 106–65, div. A, title IX, § 915(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/721"},"text":"113 Stat. 721","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1041/a/17"},"text":"Pub. L. 107–314, div. A, title X, § 1041(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2645"},"text":"116 Stat. 2645","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s931/a"},"text":"Pub. L. 108–136, div. A, title IX, § 931(a)","children":[],"tail":", (b)(1), (c), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1580"},"text":"117 Stat. 1580","children":[],"tail":", 1581; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/f/2"},"text":"Pub. L. 108–375, div. A, title X, § 1084(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2064"},"text":"118 Stat. 2064","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIX/s903/a/1"},"text":"Pub. L. 109–163, div. A, title IX, § 903(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3397"},"text":"119 Stat. 3397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dB/tXXVIII/s2854/b/2"},"text":"Pub. L. 112–239, div. B, title XXVIII, § 2854(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2162"},"text":"126 Stat. 2162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXVIII/s2861/b/2"},"text":"Pub. L. 113–291, div. B, title XXVIII, § 2861(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3716"},"text":"128 Stat. 3716","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1082/b"},"text":"Pub. L. 117–81, div. A, title X, § 1082(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1922"},"text":"135 Stat. 1922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9930043-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9930044-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9930045-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “Daniel K. Inouye Asia-Pacific Center for Security Studies” for “Asia-Pacific Center for Security Studies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “William J. Perry Center for Hemispheric Defense Studies” for “Center for Hemispheric Defense Studies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text consisted of subsecs. (a) to (f) relating to acceptance of gifts and donations for the Asia-Pacific Center for Security Studies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/a/1"},"text":"Pub. L. 108–136, § 931(a)(1)","children":[],"tail":". See 2003 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/c"},"text":"Pub. L. 108–136, § 931(c)","children":[],"tail":", struck out “foreign” before “gifts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/b/1/A"},"text":"Pub. L. 108–136, § 931(b)(1)(A)","children":[],"tail":", struck out “Foreign” before “Gifts” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/a/1"},"text":"Pub. L. 108–136, § 931(a)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":", substituted “gifts and donations from sources described in paragraph (2)” for “foreign gifts or donations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/a/2"},"text":"Pub. L. 108–136, § 931(a)(2)","children":[],"tail":", (3), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/b/1/B"},"text":"Pub. L. 108–136, § 931(b)(1)(B)","children":[],"tail":", struck out “foreign” before “gift”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s931/b/1/A"},"text":"Pub. L. 108–136, § 931(b)(1)(A)","children":[],"tail":", (C), in heading, struck out “Foreign” before “Gift” and in text, struck out “foreign” after “section, a” and “from a foreign government, a foundation or other charitable organization in a foreign country, or an individual in a foreign country” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “If the total amount of funds accepted under subsection (a) in any fiscal year exceeds $2,000,000, the Secretary shall notify Congress of the amount of those donations for that fiscal year. Any such notice shall list each of the contributors of such amounts and the amount of each contribution in that fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9930046-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9930047-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/f"},"text":"Pub. L. 108–375, div. A, title X, § 1084(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2064"},"text":"118 Stat. 2064","children":[],"tail":", provided that the amendment made by section 1084(f)(2) is effective as of "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
