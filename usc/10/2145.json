{"tag":"section","attrib":{"id":"ida92ee798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2145"},"text":null,"children":[{"tag":"num","attrib":{"value":"2145"},"text":"§ 2145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments of amount of educational assistance and of subsistence allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92ee799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once each year, the Secretary of Defense shall adjust the amount of educational assistance which may be provided to any person in any standard academic year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2143"},"text":"section 2143 of this title","children":[],"tail":", and the amount of the subsistence allowance authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2144"},"text":"section 2144 of this title","children":[],"tail":" for pursuit of a course of instruction on a full-time basis, in a manner consistent with the change over the preceding twelve-month period in the average actual cost of attendance at public institutions of higher education."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92ee79a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “actual cost of attendance” has the meaning given the term “cost of attendance” by section 472 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92ee79b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342/tIX/s901/a"},"text":"Pub. L. 96–342, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1113"},"text":"94 Stat. 1113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXII/s1231/18/A"},"text":"Pub. L. 100–180, div. A, title XII, § 1231(18)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1161"},"text":"101 Stat. 1161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/c/2"},"text":"Pub. L. 103–35, title II, § 201(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/98"},"text":"107 Stat. 98","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92ee79c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92ee79d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92ee79e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" substituted “has the meaning given the term ‘cost of attendance’ by section 472 of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":")” for “means the actual cost of attendance as determined by the Secretary of Education pursuant to section 411(a)(2)(B)(iv) of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070a/a/2/B/iv"},"text":"20 U.S.C. 1070a(a)(2)(B)(iv)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" inserted “the term” after “In this section,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
