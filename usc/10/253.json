{"tag":"section","attrib":{"id":"ida7924e57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s253"},"text":null,"children":[{"tag":"num","attrib":{"value":"253"},"text":"§ 253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with State and Federal law","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President, by using the militia or the armed forces, or both, or by any other means, shall take such measures as he considers necessary to suppress, in a State, any insurrection, domestic violence, unlawful combination, or conspiracy, if it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7924e58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s253/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so hinders the execution of the laws of that State, and of the United States within the State, that any part or class of its people is deprived of a right, privilege, immunity, or protection named in the Constitution and secured by law, and the constituted authorities of that State are unable, fail, or refuse to protect that right, privilege, or immunity, or to give that protection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924e59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s253/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opposes or obstructs the execution of the laws of the United States or impedes the course of justice under those laws.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In any situation covered by clause (1), the State shall be considered to have denied the equal protection of the laws secured by the Constitution.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7924e5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/15"},"text":"70A Stat. 15","children":[],"tail":", § 333; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1076/a/1"},"text":"Pub. L. 109–364, div. A, title X, § 1076(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2404"},"text":"120 Stat. 2404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1068/a/1"},"text":"Pub. L. 110–181, div. A, title X, § 1068(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/325"},"text":"122 Stat. 325","children":[],"tail":"; renumbered § 253, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7924e5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7924e5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7924e5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text"