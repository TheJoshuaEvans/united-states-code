to employ the armed forces during a natural disaster or terrorist attack or to suppress an insurrection in a State and requiring notice to Congress during the exercise of such authority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" amended section catchline and text generally, substituting provisions authorizing the President to employ the armed forces during a natural disaster or terrorist attack or to suppress an insurrection in a State and requiring notice to Congress during the exercise of such authority for provisions directing the President to suppress certain insurrections and domestic violence in a State."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7924e62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7924e63-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1068/d"},"text":"Pub. L. 110–181, div. A, title X, § 1068(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/326"},"text":"122 Stat. 326","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tX/s1068/d"},"text":"“The amendments made by this section [amending this section and sections 334 and 12304 of this title and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2567"},"text":"section 2567