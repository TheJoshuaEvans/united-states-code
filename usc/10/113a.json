{"tag":"section","attrib":{"id":"ida741480d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a"},"text":null,"children":[{"tag":"num","attrib":{"value":"113a"},"text":"§ 113a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of annual defense authorization request","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida741480e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Transmittal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall transmit to Congress the annual defense authorization request for a fiscal year during the first 30 days after the date on which the President transmits to Congress the budget for that fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida741480f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Authorization Request Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “defense authorization request”, with respect to a fiscal year, means a legislative proposal submitted to Congress for the enactment of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7414810-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authorizations of appropriations for that fiscal year, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s114"},"text":"section 114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7414811-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel strengths for that fiscal year, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115"},"text":"section 115 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7414812-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority to carry out military construction projects, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2802"},"text":"section 2802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7414813-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s113a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other matter that is proposed by the Secretary of Defense to be enacted as part of the annual defense authorization bill for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7414814-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1061/a"},"text":"Pub. L. 107–314, div. A, title X, § 1061(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2649"},"text":"116 Stat. 2649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1044/a"},"text":"Pub. L. 108–136, div. A, title X, § 1044(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1612"},"text":"117 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7414815-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7414816-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7414817-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
