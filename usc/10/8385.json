":"html:a","attrib":{"href":"/us/stat/52/1179"},"text":"52 Stat. 1179","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s808"},"text":"July 9, 1952, ch. 608, § 808","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/508"},"text":"66 Stat. 508","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854e"},"text":"34 U.S.C. 854e","children":[],"tail":" (less 2d through 5th provisos)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch690/s206"},"text":"June 25, 1938, ch. 690, § 206","children":[],"tail":" (less 2d through 5th provisos), "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1179"},"text":"52 Stat. 1179","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1940-04-25/ch153"},"text":"Apr. 25, 1940, ch. 153","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/162"},"text":"54 Stat. 162","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854"},"text":"34 U.S.C. 854","children":[],"tail":" (note)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (3d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “A member of the Fleet Reserve or the Fleet Marine Corps Reserve” are substituted for the words “That men so transferred to the Fleet Reserve * * * or other provision of law” for clarity. It is clear from the legislative history of the Armed Forces Reserve Act of 1952 that the amendment to the second proviso of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s854d"},"text":"34 U.S.C. 854d","children":[],"tail":" made by that Act was intended to cover all members of the Fleet Reserve and Fleet Marine Corps Reserve."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the word “enlisted” is omitted as surplusage since only enlisted members may transfer to the Fleet Reserve and Fleet Marine Corps Reserve. The words “after 16 years’ or more service” are omitted as surplusage since all the members of the Fleet Reserve and Fleet Marine Corps Reserve are in that category. The words “If any member fails to report for the physical examination” are substituted for the words “upon failure * * * of such member to report for inspection” to reflect the true meaning of the section. The words “Under such conditions as may be prescribed by the Secretary of the Navy” are omitted as unnecessary since the authority to order a forfeiture is entirely within the Secretary’s discretion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab238ac0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab238ac1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6485"},"text":"section 6485 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79"},"text":"Pub. L. 95–79","children":[],"tail":" struck out requirements relating to physical examinations for members of the Fleet Reserve and Fleet Marine Corps Reserve."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab238ac2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab238ac3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
