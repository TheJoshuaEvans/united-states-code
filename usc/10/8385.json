{"tag":"section","attrib":{"id":"idab238ab6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8385"},"text":null,"children":[{"tag":"num","attrib":{"value":"8385"},"text":"§ 8385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the Fleet Reserve and Fleet Marine Corps Reserve: authority to recall","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab238ab7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Fleet Reserve or the Fleet Marine Corps Reserve may be ordered by competent authority to active duty without his consent—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab238ab8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8385/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in time of war or national emergency declared by Congress, for the duration of the war or national emergency and for six months thereafter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab238ab9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8385/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in time of national emergency declared by the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab238aba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8385/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238abb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of peace any member of the Fleet Reserve or the Fleet Marine Corps Reserve may be required to perform not more than two months’ active duty for training in each four-year period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab238abc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/417"},"text":"70A Stat. 417","children":[],"tail":", § 6485; "},{"tag":"ref","attrib":{"href":"/us/pl/95/79/tVIII/s805"},"text":"Pub. L. 95–79, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-30"},"text":"July 30, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/333"},"text":"91 Stat. 333","children":[],"tail":"; renumbered § 8385, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/17"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab238abd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab238abe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab238abf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"tex