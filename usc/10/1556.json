{"tag":"section","attrib":{"id":"ida8e4e64b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556"},"text":null,"children":[{"tag":"num","attrib":{"value":"1556"},"text":"§ 1556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex parte communications prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e4e64c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall ensure that an applicant seeking corrective action by the Army Review Boards Agency, the Department of the Air Force Review Boards Agency, or the Board for Correction of Naval Records, as the case may be, is provided a copy of all correspondence and communications (including summaries of verbal communications) to or from the agency or board, or a member of the staff of the agency or board, with an entity or person outside the agency or board that pertain directly to the applicant’s case or have a material effect on the applicant’s case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e4e64d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e4e64e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e64f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information the release of which is otherwise prohibited by law or regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any record previously provided to the applicant or known to be possessed by the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e651-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any correspondence that is purely administrative in nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e652-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1556/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any military record that is (or may be) provided to the applicant by the Secretary of the military department or other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e4e653-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s543/a/1"},"text":"Pub. L. 105–261, div. A, title V, § 543(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2020"},"text":"112 Stat. 2020","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/j/2/B"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(j)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/673"},"text":"137 Stat. 673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8e4e654-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8e4e655-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8e4e656-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “the Department of” after “the Army Review Boards Agency,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8e4e657-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8e4e658-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s543/b"},"text":"Pub. L. 105–261, div. A, title V, § 543(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2021"},"text":"112 Stat. 2021","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tV/s543/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1556"},"text":"Section 1556 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to correspondence and communications made 60 days or more after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
