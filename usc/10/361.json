{"tag":"section","attrib":{"id":"ida7a7d1e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361"},"text":null,"children":[{"tag":"num","attrib":{"value":"361"},"text":"§ 361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on providing financial assistance to terrorist countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d1e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds available to the Department of Defense may not be obligated or expended to provide financial assistance to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d1e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any country with respect to which the Secretary of State has made a determination under section 6(j)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4605/j/1/A"},"text":"50 U.S.C. 4605(j)(1)(A)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any country identified in the latest report submitted to Congress under section 140 of the Foreign Relations Authorization Act, Fiscal Years 1988 and 1989 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f"},"text":"22 U.S.C. 2656f","children":[],"tail":"), as providing significant support for international terrorism; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other country that, as determined by the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants sanctuary from prosecution to any individual or group that has committed an act of international terrorism; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise supports international terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d1eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may waive the application of subsection (a) to a country if the President determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it is in the national security interests of the United States to do so; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the waiver should be granted for humanitarian reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d1ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Committee on Armed Services and the Committee on Foreign Relations of the Senate and the Committee on Armed Services and the Committee on International Relations of the House of Representatives at least 15 days before the waiver takes effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d1f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a notice of the waiver in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “international terrorism” has the meaning given that term in section 140(d) of the Foreign Relations Authorization Act, Fiscal Years 1988 and 1989 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f/d"},"text":"22 U.S.C. 2656f(d)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d1f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXIII/s1341/a"},"text":"Pub. L. 104–106, div. A, title XIII, § 1341(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/485"},"text":"110 Stat. 485","children":[],"tail":", § 2249a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/40"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(40)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1902"},"text":"111 Stat. 1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],