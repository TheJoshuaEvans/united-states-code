{"tag":"section","attrib":{"id":"idaa70b633-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324"},"text":null,"children":[{"tag":"num","attrib":{"value":"4324"},"text":"§ 4324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-cycle management and product support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa70b634-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that each covered system is supported by a performance-based life-cycle sustainment plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa70b635-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is approved by the service acquisition executive responsible for such covered system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b636-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets applicable operational readiness requirements and materiel readiness objectives (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s118/c"},"text":"section 118(c) of this title","children":[],"tail":") in the most cost-effective manner practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa70b637-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Life-cycle Sustainment Plan","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa70b638-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A product support manager shall develop, update, and implement a life-cycle sustainment plan for each covered system for which the product support manager is responsible. Such plan shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa70b639-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comprehensive product support strategy that addresses each Integrated Product Support Element in a manner—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa70b63a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to best achieve operational readiness requirements and materiel readiness objectives throughout the planned life cycle of such system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa70b63b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that allows evaluation and selection of product support integrators and product support providers appropriate to execute the product support strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b63c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A life-cycle cost estimate for the covered system that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa70b63d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the product support strategy described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa70b63e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the covered system is a major defense acquisition program or major subprogram, is developed in accordance with the requirements to support a Milestone A approval, Milestone B approval, or Milestone C approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b63f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommended engineering and design considerations that support cost-effective sustainment of the covered system and best value solutions in life cycle planning and management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b640-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An intellectual property management plan for product support developed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3774"},"text":"section 3774 of this title","children":[],"tail":", including requirements for technical data, software, and modular open system approaches (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4401"},"text":"section 4401 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b641-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A strategy to maximize use of public and private sector capabilities including public-private partnerships, when appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b642-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After consideration of the views received by the milestone decision authority from appropriate materiel, logistics, or fleet representatives, a plan to transition the covered system from production to initial fielding that addresses specific products or services required for successful initial fielding of the covered system, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa70b643-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the necessary tooling or other unique support equipment, requirements for initial spare parts and components, technical handbooks and maintenance manuals, maintenance training, and facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa70b644-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the funding required to provide such products and services for any initial fielding location of the covered system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa70b645-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the required number of training simulators, including the initial operational capability and overall fielding of such simulators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b646-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In developing each life-cycle sustainment plan required by this section, the product support manager shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa70b647-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider affordability constraints and key cost factors that could affect operating and support costs during the life cycle of the covered system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b648-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider sustainment risks or challenges to sustaining the covered system in operational environments, including contested logistics environments (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2926"},"text":"section 2926 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b649-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" seek to comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa70b64a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements to maintain a core logistics capability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2464"},"text":"section 2464 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa70b64b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limitations on the performance of depot-level maintenance of materiel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2466"},"text":"section 2466 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b64c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to integrate commercial best practices, use commercial standards, and use advanced technologies to enhance the product support of each covered system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b64d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to maintain a robust, resilient, and innovative defense industrial base to support requirements throughout the life cycle of the covered system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa70b64e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002118"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002118"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (c) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa70b64f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “milestone decision authority” and “Milestone A approval” have the meanings given, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4251"},"text":"section 4251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Milestone B approval” and “Milestone C approval” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4172"},"text":"section 4172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b651-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered system” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa70b652-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a major defense acquisition program as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201"},"text":"section 4201 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b653-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a major subprogram as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4203"},"text":"section 4203 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b654-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acquisition program or project that is carried out using the rapid fielding or rapid prototyping acquisition pathway under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3602"},"text":"section 3602 of this title","children":[],"tail":" that is estimated by the Secretary of Defense to require an eventual total expenditure described in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4201/a/2"},"text":"section 4201(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b655-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “critical readiness items of supply” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa70b656-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parts and systems designated as Mission Impaired Capability Awaiting Parts, Not Mission Capable Supply, or Casualty Report Category 3 or 4 status (as defined by the Secretary of Defense or a Secretary of a military department); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b657-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parts or systems designated by the Secretary of Defense as negatively impacting the materiel readiness objectives of a covered system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b658-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Integrated Product Support Elements” means, with respect to a covered system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa70b659-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product support management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b65a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design interface;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b65b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustaining engineering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b65c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance planning and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b65d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b65e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b65f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b660-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and training support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b661-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology systems continuous support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b662-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities and infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b663-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" packaging, handling, storage, and transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa70b664-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/5/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manpower and personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b665-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “product support” means the package of support functions required to field and sustain the readiness and operational capability of covered systems (including subsystems and components of such covered systems).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa70b666-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “product support arrangement”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa70b667-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a contract, task order, or another contractual arrangement, or any type of agreement or non-contractual arrangement entered into by the Federal Government, for the performance of sustainment or logistics support required for covered systems (including subsystems and components of such covered systems); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa732668-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes arrangements for any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa732669-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance-based logistics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa73266a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sustainment support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa73266b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contractor logistics support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa73266c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Life-cycle product support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa73266d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “product support integrator” means an entity responsible for integrating private and public sources of product support within the scope of a product support arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa73266e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4324/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “product support provider” means an entity that provides product support functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa73266f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVIII/s823/a/1"},"text":"Pub. L. 112–239, div.