{"tag":"section","attrib":{"id":"ida783f65c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192"},"text":null,"children":[{"tag":"num","attrib":{"value":"192"},"text":"§ 192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Agencies and Department of Defense Field Activities: oversight by the Secretary of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida783f65d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overall Supervision","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida783f65e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall assign responsibility for the overall supervision of each Defense Agency and Department of Defense Field Activity designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s191/b"},"text":"section 191(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida783f65f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a civilian officer within the Office of the Secretary of Defense listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s131/b"},"text":"section 131(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida783f660-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f661-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An official assigned such a responsibility with respect to a Defense Agency or Department of Defense Field Activity shall advise the Secretary of Defense on the extent to which the program recommendations and budget proposals of such agency or activity conform with the requirements of the military departments and of the unified and specified combatant commands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f662-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not apply to the Defense Intelligence Agency or the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f663-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program and Budget Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish procedures to ensure that there is full and effective review of the program recommendations and budget proposals of each Defense Agency and Department of Defense Field Activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f664-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida783f665-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida783f666-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", and periodically (but not less frequently than every four years) thereafter, the Secretary of Defense shall conduct a review of the efficiency and effectiveness of each Defense Agency and Department of Defense Field Activity. Each review shall, to the maximum extent practicable, be conducted in coordination with other ongoing efforts in connection with business enterprise reform."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida783f667-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of each review under this paragraph, the Secretary shall identify each activity of an Agency or Activity that is substantially similar to, or duplicative of, an activity carried out by another organization or element of the Department of Defense, or is not being performed to an adequate level to meet Department needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida783f668-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of conducting reviews under this paragraph, the Secretary shall develop internal guidance that defines requirements for such reviews and provides clear direction for conducting and recording the results of reviews.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f669-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida783f66a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after the completion of a review under paragraph (1), the Secretary shall submit to the congressional defense committees a report that sets forth the results of the review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida783f66b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report on a review under this paragraph shall, based on the results of the review, include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida783f66c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A list of each Defense Agency and Department of Defense Field Activity that the Secretary has determined—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida783f66d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates efficiently and effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida783f66e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not carry out any function that is substantially similar to, or duplicative of, a function carried out by another organization or element of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida783f66f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each Agency or Activity not included on the list under clause (i), a plan, aimed at better meeting Department needs, for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida783f670-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rationalizing the functions within such Agency or Activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida783f671-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring some or all of the functions of such Agency or Activity to another organization or element of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida783f672-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for functions, if any, currently conducted separately by the military departments that should be consolidated into an Agency or Activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f673-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall apply to the National Security Agency as determined appropriate by the Secretary, in consultation with the Director of National Intelligence. The Secretary shall establish procedures under which information required for review of the National Security Agency shall be obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f674-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Defense Commissary Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the results of any periodic review under subsection (c) with regard to the Defense Commissary Agency, the Secretary of Defense may not transfer to the Secretary of a military department the responsibility to manage and fund the provision of services and supplies provided by the Defense Commissary Agency unless the transfer of the management and funding responsibility is specifically authorized by a law enacted after ","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"October 17, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f675-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not terminate a Defense Agency or Department of Defense Field Activity until 30 days after the date on which the Secretary submits to the congressional defense committees a report setting forth the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida783f676-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notice of the intent of the Secretary to terminate the Agency or Activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f677-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s192/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such recommendations for legislative action as the Secretary considers appropriate in connection with the termination of the Agency or Activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida783f678-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIII/s301/a/2"},"text":"Pub. L. 99–433, title III, § 301(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1020"},"text":"100 Stat. 1020","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIII/s361/a"},"text":"Pub. L. 105–261, div. A, title III, § 361(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1984"},"text":"112 Stat. 1984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/a/3"},"text":"Pub. L. 106–65, div. A, title X, § 1066(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/770"},"text":"113 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIII/s371"},"text":"Pub. L. 109–163, div. A, title III, § 371","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3209"},"text":"119 Stat. 3209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX"},"text":"Pub. L. 110–181, div. A, title IX","children":[],"tail":", §§ 904(c), 931(a)(1), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/274"},"text":"122 Stat. 274","children":[],"tail":", 285; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIX/s901/n/1"},"text":"Pub. L. 113–291, div. A, title IX, § 901(n)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3469"},"text":"128 Stat. 3469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/b/1/D"},"text":"Pub. L. 115–91, div. A, title X, § 1081(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1597"},"text":"131 Stat. 1597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tIX/s923"},"text":"Pub. L. 115–232, div. A, title IX, § 923","children":[],"tail":", title X, § 1081(f)(1)(A)(i), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1930"},"text":"132 Stat. 1930","children":[],"tail":", 1986; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/11"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3871"},"text":"134 Stat. 3871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s901/b"},"text":"Pub. L. 118–31, div. A, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/354"},"text":"137 Stat. 354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida783f679-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida783f67a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida783f67b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 192, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/215/tV/s501/a"},"text":"Pub. L. 98–215, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-09"},"text":"Dec. 9, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1478"},"text":"97 Stat. 1478","children":[],"tail":", which related to benefits for certain personnel of the Defense Intelligence Agency, was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1605"},"text":"section 1605 of this title","children":[],"tail":" and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1302/a/1"},"text":"Pub. L. 99–145, title XIII, § 1302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/737"},"text":"99 Stat. 737","children":[],"tail":". Provisions of prior section 192 as related to members of the armed forces were enacted as "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s431"},"text":"section 431 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, by "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1302/b/1"},"text":"section 1302(b)(1) of Pub. L. 99–145","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida783f67c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s901/b/1/A"},"text":"Pub. L. 118–31, § 901(b)(1)(A)","children":[],"tail":", substituted “the Secretary of Defense” for “the Chief Management Officer of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s901/b/1/B"},"text":"Pub. L. 118–31, § 901(b)(1)(B)","children":[],"tail":", substituted “the Secretary” for “the Chief Management Officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A), (B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s901/b/2"},"text":"Pub. L. 118–31, § 901(b)(2)","children":[],"tail":", substituted “the Secretary” for “the Chief Management Officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out par. (1) relating to periodic review of services and supplies provided by each Defense Agency and Department of Defense Field Activity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s923/a"},"text":"Pub. L. 115–232, § 923(a)","children":[],"tail":", added par. (1) relating to efficiency and effectiveness reviews and par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s923/b"},"text":"Pub. L. 115–232, § 923(b)","children":[],"tail":", (c), added subsec. (e) and struck out former subsec. (e) which related to special rule for Defense Business Transformation Agency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1081/f/1/A/i"},"text":"Pub. L. 115–232, § 1081(f)(1)(A)(i)","children":[],"tail":", substituted “Chief Management Officer” for “Deputy Chief Management Officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s931/a/1"},"text":"Pub. L. 110–181, § 931(a)(1)","children":[],"tail":", substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s904/c"},"text":"Pub. L. 110–181, § 904(c)","children":[],"tail":", substituted “that the Director of the Agency shall report directly to the Deputy Chief Management Officer of the Department of Defense.” for “that the Agency be managed cooperatively by the Deputy Under Secretary