{"tag":"section","attrib":{"id":"ida9871925-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2494"},"text":null,"children":[{"tag":"num","attrib":{"value":"2494"},"text":"§ 2494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonappropriated fund instrumentalities: furnishing utility services for morale, welfare, and recreation purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Appropriations for the Department of Defense may be used to provide utility services for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871926-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2494/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buildings on military installations authorized by regulation to be used for morale, welfare, and recreation purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871927-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2494/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other morale, welfare, and recreation activities for members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9871928-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/c/4"},"text":"Pub. L. 108–375, div. A, title VI, § 651(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1972"},"text":"118 Stat. 1972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9871929-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida987192a