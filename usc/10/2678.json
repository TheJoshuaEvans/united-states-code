{"tag":"section","attrib":{"id":"ida9a61366-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2678"},"text":null,"children":[{"tag":"num","attrib":{"value":"2678"},"text":"§ 2678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feral horses and burros: removal from military installations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When feral horses or burros are found on an installation under the jurisdiction of the Secretary of a military department, the Secretary may use helicopters and motorized equipment for their removal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9a61367-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1481/h/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1481(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1708"},"text":"104 Stat. 1708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9a61368-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9a61369-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9a6136a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9030"},"text":"Pub. L. 101–165, title IX, § 9030","children":[],"tail":", "},{"tag":"date","