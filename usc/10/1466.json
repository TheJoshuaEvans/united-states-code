{"tag":"section","attrib":{"id":"ida8d44418-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466"},"text":null,"children":[{"tag":"num","attrib":{"value":"1466"},"text":"§ 1466.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments into the Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d44419-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense and the Secretary of the department in which the Coast Guard is operating, with respect to the Coast Guard, shall pay into the Fund at the end of each month the respective pro rata share contribution of the Secretary of Defense and the Secretary of the department in which the Coast Guard is operating to the Fund for that month the amount that is the sum of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d4441a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d4441b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level percentage of basic pay determined using all the methods and assumptions approved for the most recent (as of the first day of the current fiscal year) actuarial valuation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1465/c/1/A"},"text":"section 1465(c)(1)(A) of this title","children":[],"tail":" (except that any statutory change in the military retirement and survivor benefit systems that is effective after the date of that valuation and on or before the first day of the current fiscal year shall be used in such determination); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d4441c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of basic pay accrued for that month for active duty (other than the Coast Guard) and for full-time National Guard duty (other than full-time National Guard duty for training only), but excluding the amount expected to be paid for any duty that would be excluded for active-duty end strength purposes by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/i"},"text":"section 115(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d4441d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d4441e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level percentage of basic pay and of compensation (paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of title 37","children":[],"tail":") determined using all the methods and assumptions approved for the most recent (as of the first day of the current fiscal year) actuarial valuation under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1465/c/1/B"},"text":"section 1465(c)(1)(B) of this title","children":[],"tail":" (except that any statutory change in the military retirement and survivor benefit systems that is effective after the date of that valuation and on or before the first day of the current fiscal year shall be used in such determination); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d4441f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of basic pay and of compensation (paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of title 37","children":[],"tail":") accrued for that month by members of the Selected Reserve of the armed forces for service not otherwise described in paragraph (1)(B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d44420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts paid into the Fund under this subsection shall be paid from funds available for as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d44421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay of members of the armed forces under the jurisdiction of the Secretary of a military department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d44422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Retired Pay appropriation for the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d44423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d44424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the beginning of each fiscal year the Secretary of the Treasury shall promptly pay into the Fund from the General Fund of the Treasury the amount certified to the Secretary by the Secretary of Defense under paragraph (3). Such payment shall be the contribution to the Fund for that fiscal year required by sections 1465(a), 1465(b)(3), 1465(c)(2), and 1465(c)(3) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d44425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the beginning of each fiscal year the Secretary of Defense shall determine the sum of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8d44426-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the payment for that year under the amortization schedule determined by the Board of Actuaries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1465/a"},"text":"section 1465(a) of this title","children":[],"tail":" for the amortization of the original unfunded liabilities of the Fund for the Department of Defense and the Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d44427-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount (including any negative amount) for that year under the most recent amortization schedule determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1465/c/2"},"text":"section 1465(c)(2) of this title","children":[],"tail":" for the amortization of any cumulative unfunded liability (or any gain) to the Fund resulting from changes in benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d44428-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount (including any negative amount) for that year under the most recent amortization schedule determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1465/c/3"},"text":"section 1465(c)(3) of this title","children":[],"tail":" for the amortization of any cumulative actuarial gain or loss to the Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8d44429-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for that year determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1465/b/3"},"text":"section 1465(b)(3) of this title","children":[],"tail":" for the cost to the Fund arising from increased amounts payable from the Fund by reason of section 1413a or 1414 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d4442a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and the Secretary of the Department in which the Coast Guard is operating shall promptly certify the amount determined under paragraph (2) each year to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d4442b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d4442c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall pay into the Fund at the beginning of each fiscal year such amount as may be necessary to pay the cost to the Fund for that fiscal year resulting from the repeal, as of ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"section 5532 of title 5","children":[],"tail":", including any actuarial loss to the Fund resulting from increased benefits paid from the Fund that are not fully covered by the payments made to the Fund for that fiscal year under subsections (a) and (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d4442d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts paid into the Fund under this subsection shall be paid from funds available for the pay of members of the armed forces under the jurisdiction of the Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d4442e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1466/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense Board of Actuaries shall determine, for each armed force, the amount required under paragraph (1) to be deposited in the Fund each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d4442f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s925/a/1"},"text":"Pub. L. 98–94, title IX, § 925(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/647"},"text":"97 Stat. 647","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tIX/s9103/3"},"text":"Pub. L. 99–500, § 101(c) [title IX, §§ 9103(3), 9131]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–118, 1783–128, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tIX/s9103/3"},"text":"Pub. L. 99–591, § 101(c) [title IX, §§ 9103(3), 9131]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–118, 3341–128; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVI/s661/b"},"text":"Pub. L. 99–661, div. A, title VI, § 661(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3892"},"text":"100 Stat. 3892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"