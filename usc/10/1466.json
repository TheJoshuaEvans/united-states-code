,"tail":", 322; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8225, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4659"},"text":"134 Stat. 4659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/a/19"},"text":"Pub. L. 117–81, div. A, title X, § 1081(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1920"},"text":"135 Stat. 1920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d44430-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8d44431-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8d44432-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"Section 5532 of title 5","children":[],"tail":", referred to in subsec. (d)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s651/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/664"},"text":"113 Stat. 664","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida8d44433-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s9131"},"text":"section 9131 of Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is based on section 642 of S. 2638, Ninety-ninth Congress, as passed by the Senate on "},{"tag":"date","attrib":{"date":"1986-08-09"},"text":"Aug. 9, 1986","children":[],"tail":", which was enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s9131"},"text":"section 9131 of Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":". S. 2638 was subsequently enacted as "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8d44434-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", in introductory provisions, substituted “with respect to the Coast Guard” for “with respect to the Coast guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/1/A"},"text":"Pub. L. 116–283, § 8225(1)(A)","children":[],"tail":", (C), in introductory provisions, substituted “Secretary of Defense and the Secretary of the department in which the Coast Guard is operating, with respect to the Coast guard, shall” for “Secretary of Defense shall” and “each month the respective pro rata share contribution of the Secretary of Defense and the Secretary of the department in which the Coast Guard is operating” for “each month as the Department of Defense contribution” and struck out concluding provisions which read as follows:“Amounts paid into the Fund under this subsection shall be paid from funds available for the pay of members of the armed forces under the jurisdiction of the Secretary of a military department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/1/B"},"text":"Pub. L. 116–283, § 8225(1)(B)","children":[],"tail":", struck out “(other than the Coast Guard)” after “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/1/C"},"text":"Pub. L. 116–283, § 8225(1)(C)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/2"},"text":"Pub. L. 116–283, § 8225(2)","children":[],"tail":", which directed redesignation of subsec. (b) as (c), was executed by redesignating the subsec. (b) relating to the prompt payment by the Secretary of the Treasury of certified amounts under the amortization schedule determined by the Board of Actuaries as (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/3/A"},"text":"Pub. L. 116–283, § 8225(3)(A)","children":[],"tail":", substituted “liabilities of the Fund for the Department of Defense and the Coast Guard.” for “liability of the Fund.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/3/B"},"text":"Pub. L. 116–283, § 8225(3)(B)","children":[],"tail":", inserted “and the Secretary of the Department in which the Coast Guard is operating” before “shall promptly”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8225/2"},"text":"Pub. L. 116–283, § 8225(2)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1063/c/4"},"text":"Pub. L. 110–181, § 1063(c)(4)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s591/b/1"},"text":"Pub. L. 109–364, § 591(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s906/c/3"},"text":"Pub. L. 110–181, § 906(c)(3)","children":[],"tail":", struck out “Retirement” before “Board of Actuaries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s591/b/1"},"text":"Pub. L. 109–364, § 591(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1063/c/4"},"text":"Pub. L. 110–181, § 1063(c)(4)","children":[],"tail":", substituted “for active duty (other than the Coast Guard) and for full-time National Guard duty (other than full-time National Guard duty for training only), but excluding the amount expected to be paid for any duty that would be excluded for active-duty end strength purposes by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/i"},"text":"section 115(i) of this title","children":[],"tail":".” for “by members of the armed forces (other than the Coast Guard) on active duty (other than active duty for training) or full-time National Guard duty (other than full-time National Guard duty for training only).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s591/b/2"},"text":"Pub. L. 109–364, § 591(b)(2)","children":[],"tail":", substituted “Selected Reserve” for “Ready Reserve” and “Coast Guard) for service” for “Coast Guard and other than members on full-time National Guard duty other than for training) who are”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “1413a” for “1413, 1413a,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s641/c/5/A"},"text":"Pub. L. 108–136, § 641(c)(5)(A)","children":[],"tail":", substituted “sections 1465(a), 1465(b)(3), 1465(c)(2), and 1465(c)(3)” for “sections 1465(a) and 1465(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s641/c/5/B"},"text":"Pub. L. 108–136, § 641(c)(5)(B)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/a/3"},"text":"Pub. L. 100–26, § 7(a)(3)","children":[],"tail":", inserted at end “Amounts paid into the Fund under this subsection shall be paid from funds available for the pay of members of the armed forces under the jurisdiction of the Secretary of a military department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B), (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s4/a/1"},"text":"Pub. L. 100–26, § 4(a)(1)","children":[],"tail":", amended "},{"tag":