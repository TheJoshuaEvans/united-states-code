{"tag":"section","attrib":{"id":"idaa39ef08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805"},"text":null,"children":[{"tag":"num","attrib":{"value":"3805"},"text":"§ 3805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for commercial products and commercial services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa39ef09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions for Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":" for commercial products and commercial services may be made under such terms and conditions as the head of the agency determines are appropriate or customary in the commercial marketplace and are in the best interests of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39ef0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security for Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the agency shall obtain adequate security for such payments. If the security is in the form of a lien in favor of the United States, such lien is paramount to all other liens and is effective immediately upon the first payment, without filing, notice, or other action by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39ef0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Advance Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Advance payments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":" for commercial products and commercial services may include payments, in a total amount of not more than 15 percent of the contract price, in advance of any performance of work under the contract."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39ef0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication of Certain Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39ef0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conditions of sections 3803 and 3804 of this title need not be applied if they would be inconsistent, as determined by the head of the agency, with commercial terms and conditions pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ef0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3803"},"text":"section 3803 of this title","children":[],"tail":", a payment for covered services acquired through a commercially utilized acquisition strategy shall not be considered an advance payment made under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39ef0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39ef10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “commercially utilized acquisition strategy” means an acquisition of a service by the head of an agency under terms and conditions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa39ef11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are similar to the terms and conditions under which such service is available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa39ef12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide such service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa39ef13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a consumption-based solution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3605"},"text":"section 3605 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa39ef14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a technology subscription model or other model based on predetermined pricing for access to such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ef15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3805/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered service” means a commercial service that includes access to or use of any combination of hardware, equipment, software, labor, or services, including access to commercial satellite data and associated services, that is integrated to provide a capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa39ef16-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1834/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1834(a)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4234"},"text":"134 Stat. 4234","children":[],"tail":", 4236; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1827"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1827","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1250"},"text":"139 Stat. 1250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa39ef17-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa39ef18-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa39ef19-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f"},"text":"Pub. L. 116–283, § 1834(f)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2001/f"},"text":"Pub. L. 103–355, title II, § 2001(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3302"},"text":"108 Stat. 3302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/c/6"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1866"},"text":"132 Stat. 1866","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa39ef1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1827/1"},"text":"Pub. L. 119–60, § 1827(1)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1827/2"},"text":"Pub. L. 119–60, § 1827(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f/1/A"},"text":"Pub. L. 116–283, § 1834(f)(1)(A)","children":[],"tail":", transferred subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":" to this section and struck out subsec. (f) designation and heading “Conditions for Payments for Commercial Products and Commercial Services” at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f/1/B"},"text":"Pub. L. 116–283, § 1834(f)(1)(B)","children":[],"tail":", (4), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/f"},"text":"section 2307(f) of this title","children":[],"tail":" to this section, redesignated par. (1) as subsec. (a), inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":"” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f/4"},"text":"Pub. L. 116–283, § 1834(f)(4)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f/2"},"text":"Pub. L. 116–283, § 1834(f)(2)","children":[],"tail":", which directed the designation of “the second sentence of subsection (a) as subsection (b)”, was executed by designating the second and third sentences of subsec. (a) as (b), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f/1/B"},"text":"Pub. L. 116–283, § 1834(f)(1)(B)","children":[],"tail":", (5), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/f"},"text":"section 2307(f) of this title","children":[],"tail":" to this section, redesignated par. (2) as subsec. (c), inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":"” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/f/1/B"},"text":"Pub. L. 116–283, § 1834(f)(1)(B)","children":[],"tail":", (6), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307/f"},"text":"section 2307(f) of this title","children":[],"tail":" to this section, redesignated par. (3) as subsec. (d), inserted heading, and substituted “sections 3803 and 3804 of this title” for “subsections (d) and (e)” and “this section” for “paragraphs (1) and (2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa39ef1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa39ef1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
