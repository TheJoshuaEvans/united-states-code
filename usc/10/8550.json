{"tag":"section","attrib":{"id":"idab31e246-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550"},"text":null,"children":[{"tag":"num","attrib":{"value":"8550"},"text":"§ 8550.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for faculty research for scientific, literary, and educational purposes: acceptance; authorized grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab31e247-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Research Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may authorize the President of the Naval Postgraduate School to accept qualifying research grants. Any such grant may only be accepted if the work under the grant is to be carried out by a professor or instructor of the School for a scientific, literary, or educational purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e248-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A qualifying research grant under this section is a grant that is awarded on a competitive basis by an entity referred to in subsection (c) for a research project with a scientific, literary, or educational purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e249-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entities From Which Grants May Be Accepted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant may be accepted under this section only from a corporation, fund, foundation, educational institution, or similar entity that is organized and operated primarily for scientific, literary, or educational purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e24a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Grant Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish an account for administering funds received as research grants under this section. The President of the Naval Postgraduate School shall use the funds in the account in accordance with applicable provisions of the regulations and the terms and condition of the grants received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e24b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Related Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to such limitations as may be provided in appropriations Acts, appropriations available for the Naval Postgraduate School may be used to pay expenses incurred by the School in applying for, and otherwise pursuing, the award of qualifying research grants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e24c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8550/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab31e24d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s522/c/1"},"text":"Pub. L. 109–163, div. A, title V, § 522(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3241"},"text":"119 Stat. 3241","children":[],"tail":", § 7050; renumbered § 8550, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab31e24e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab31e24f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab31e250-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8571, acts ","children":[{"tag":"ref","