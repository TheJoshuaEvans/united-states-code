{"tag":"section","attrib":{"id":"ida823b849-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865"},"text":null,"children":[{"tag":"num","attrib":{"value":"865"},"text":"§ 865.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 65. Transmittal and review of records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida823b84a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmittal of Records.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida823b84b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finding of guilty in general or special court-martial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the judgment of a general or special court-martial entered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s860c"},"text":"section 860c of this title","children":[],"tail":" (article 60c) includes a finding of guilty, the record shall be transmitted to the Judge Advocate General."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b84c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In all other cases, records of trial by court-martial and related documents shall be transmitted and disposed of as the Secretary concerned may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida823b84d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cases for Direct Appeal.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida823b84e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automatic review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the judgment includes a sentence of death, dismissal of a commissioned officer, cadet, or midshipman, dishonorable discharge or bad-conduct discharge, or confinement for 2 years or more, the Judge Advocate General shall forward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida823b84f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record of trial to the Court of Criminal Appeals for review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/b/3"},"text":"section 866(b)(3) of this title","children":[],"tail":" (article 66(b)(3)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida823b850-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the record of trial to an appellate defense counsel who shall be detailed to review the case and, upon request of the accused, to represent the accused before the Court of Criminal Appeals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b851-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cases eligible for direct appeal review.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida823b852-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the case is eligible for direct review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/b/1"},"text":"section 866(b)(1) of this title","children":[],"tail":" (article 66(b)(1)), the Judge Advocate General shall, upon written request of the accused—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida823b853-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forward a copy of the record of trial to an appellate defense counsel who shall be detailed to review the case and to represent the accused before the Court of Criminal Appeals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida823b854-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forward a copy of the record of trial to civilian counsel provided by the accused.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida823b855-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) shall not apply if the accused waives the right to appeal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s861"},"text":"section 861 of this title","children":[],"tail":" (article 61)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida823b856-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Right to Appeal.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida823b857-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Judge Advocate General shall provide notice to the accused of the right to file an appeal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/b/1"},"text":"section 866(b)(1) of this title","children":[],"tail":" (article 66(b)(1)) by means of depositing in the United States mails for delivery by first class certified mail to the accused at an address provided by the accused or, if no such address has been provided by the accused, at the latest address listed for the accused in the official service record of the accused."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b858-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability upon waiver of appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply if the accused waives the right to appeal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s861"},"text":"section 861 of this title","children":[],"tail":" (article 61)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida823b859-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review by Judge Advocate General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida823b85a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By whom","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review conducted under this subsection may be conducted by an attorney within the Office of the Judge Advocate General or another attorney designated under regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b85b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of cases not eligible for direct appeal.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida823b85c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review under subparagraph (B) shall be completed in each general and special court-martial that is not eligible for direct appeal under paragraph (1) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/b"},"text":"section 866(b) of this title","children":[],"tail":" (article 66(b))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida823b85d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A review referred to in subparagraph (A) shall include a written decision providing each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida823b85e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conclusion as to whether the court had jurisdiction over the accused and the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida823b85f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conclusion as to whether the charge and specification stated an offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida823b860-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conclusion as to whether the sentence was within the limits prescribed as a matter of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida823b861-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A response to each allegation of error made in writing by the accused.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b862-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review when direct appeal is waived, withdrawn, or not filed.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida823b863-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A review under subparagraph (B) shall be completed in each general and special court-martial if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida823b864-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accused waives the right to appeal or withdraws appeal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s861"},"text":"section 861 of this title","children":[],"tail":" (article 61); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida823b865-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accused does not file a timely appeal in a case eligible for direct appeal under subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/b/1"},"text":"section 866(b)(1) of this title","children":[],"tail":" (article 66(b)(1))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida823b866-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review referred to in subparagraph (A) shall include a written decision limited to providing conclusions on the matters specified in clauses (i), (ii), and (iii) of paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida823b867-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida823b868-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If after a review of a record under subsection (d), the attorney conducting the review believes corrective action may be required, the record shall be forwarded to the Judge Advocate General, who may set aside the findings or sentence, in whole or in part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b869-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In setting aside findings or sentence, the Judge Advocate General may order a rehearing, except that a rehearing may not be ordered in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s844"},"text":"section 844 of this title","children":[],"tail":" (article 44)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida823b86a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy without rehearing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida823b86b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dismissal when no rehearing ordered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Judge Advocate General sets aside findings and sentence and does not order a rehearing, the Judge Advocate General shall dismiss the charges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida823b86c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dismissal when rehearing impracticable.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"ida823b86d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to clause (ii), if the Judge Advocate General sets aside findings and orders a rehearing and the convening authority determines that a rehearing would be impractical, the convening authority shall dismiss the charges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida823b86e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s865/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cases referred by special trial counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a case was referred to trial by a special trial counsel, a special trial counsel shall determine if a rehearing is impracticable and shall dismiss the charges if the special trial counsel so determines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida823b86f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/59"},"text":"70A Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/179/s1/6"},"text":"Pub. L. 90–179, § 1(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-08"},"text":"Dec. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/546"},"text":"81 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/26"},"text":"Pub. L. 90–632, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1341"},"text":"82 Stat. 1341","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/25"},"text":"Pub. L. 96–513, title V, § 511(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2922"},"text":"94 Stat. 2922","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/209/s6/d/1"},"text":"Pub. L. 98–209, § 6(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1401"},"text":"97 Stat. 1401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLIX/s5329"},"text":"Pub. L. 114–328, div. E, title LIX, § 5329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2930"},"text":"130 Stat. 2930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/