{"tag":"section","attrib":{"id":"idaa6e6bbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273"},"text":null,"children":[{"tag":"num","attrib":{"value":"4273"},"text":"§ 4273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance assessments and root cause analyses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa6e6bbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Senior Official Responsibility for Performance Assessments and Root Cause Analyses","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa6e6bbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate a senior official in the Office of the Secretary of Defense as the principal official of the Department of Defense responsible for conducting and overseeing performance assessments and root cause analyses for major defense acquisition programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No program execution responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the senior official designated under paragraph (1) is not responsible for program execution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff and resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall assign to the senior official designated under paragraph (1) appropriate staff and resources necessary to carry out the senior official’s function under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6bc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The senior official designated under subsection (a) shall be responsible for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa6e6bc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out performance assessments of major defense acquisition programs in accordance with the requirements of subsection (c) periodically or when requested by the Secretary of Defense, the Under Secretary of Defense for Acquisition and Sustainment, the Secretary of a military department, or the head of a Defense Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting root cause analyses for major defense acquisition programs in accordance with the requirements of subsection (d) when required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4376/a/1"},"text":"section 4376(a)(1) of this title","children":[],"tail":", or when requested by the Secretary of Defense, the Under Secretary of Defense for Acquisition and Sustainment, the Secretary of a military department, or the head of a Defense Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing policies, procedures, and guidance governing the conduct of performance assessments and root cause analyses by the military departments and the Defense Agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluating the utility of performance metrics used to measure the cost, schedule, and performance of major defense acquisition programs, and making such recommendations to the Secretary of Defense as the official considers appropriate to improve such metrics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Advising acquisition officials on performance issues regarding a major defense acquisition program that may arise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa6e6bc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before certification under sections 4376 and 4377 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa6e6bc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before entry into full-rate production; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa6e6bc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the course of consideration of any decision to request authorization of a multiyear procurement contract for the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6bc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a performance assessment with respect to a major defense acquisition program is an evaluation of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa6e6bca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost, schedule, and performance of the program, relative to current metrics, including performance requirements and baseline descriptions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the level of program cost, schedule, and performance predicted relative to such metrics is likely to result in the timely delivery of a level of capability to the warfighter that is consistent with the level of resources to be expended and provides superior value to alternative approaches that may be available to meet the same military requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6bcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Root Cause Analyses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and sections 4376 and 4377 of this title, a root cause analysis with respect to a major defense acquisition program is an assessment of the underlying cause or causes of shortcomings in cost, schedule, or performance of the program, including the role, if any, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa6e6bcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unrealistic performance expectations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unrealistic baseline estimates for cost or schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immature technologies or excessive manufacturing or integration risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unanticipated design, engineering, manufacturing, or technology integration issues arising during program performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changes in procurement quantities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadequate program funding or funding instability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poor performance by government or contractor personnel responsible for program management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6bd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6bd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4273/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support of Applicable Capabilities and Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the senior official designated under subsection (a) has the support of other Department of Defense officials with relevant capabilities and expertise needed to carry out the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa6e6bd6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s901/d"},"text":"Pub. L. 111–383, div. A, title IX, § 901(d)","children":[],"tail":", (k)(1)(F), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4321"},"text":"124 Stat. 4321","children":[],"tail":", 4325, § 2438; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/27"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1953"},"text":"126 Stat. 1953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1077/b"},"text":"Pub. L. 114–92, div. A, title X, § 1077(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/998"},"text":"129 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/72"},"text":"Pub. L. 116–92, div. A, title IX, § 902(72)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1551"},"text":"133 Stat. 1551","children":[],"tail":"; renumbered § 4273 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1847/e/3"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1847(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4256"},"text":"134 Stat. 4256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/16/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(16)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2134"},"text":"135 Stat. 2134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/34"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/685"},"text":"137 Stat. 685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/44"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2206"},"text":"138 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa6e6bd7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa6e6bd8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa6e6bd9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/23/s103"},"text":"Section 103 of Pub. L. 111–23","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430"},"text":"section 2430 of this title","children":[],"tail":", which was transferred to chapter 144 of this title, renumbered as section 2438, and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/d"},"text":"Pub. L. 111–383, § 901(d)","children":[],"tail":", (k)(1)(F), and subsequently renumbered as this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/3"},"text":"Pub. L. 116–283, § 1847(e)(3)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/111/23/tI/s103"},"text":"Pub. L. 111–23, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-22"},"text":"May 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1715"},"text":"123 Stat. 1715","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa6e6bda-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","chi