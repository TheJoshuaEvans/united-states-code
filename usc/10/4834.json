{"tag":"section","attrib":{"id":"idaa9bbce5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4834"},"text":null,"children":[{"tag":"num","attrib":{"value":"4834"},"text":"§ 4834.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas foreign critical technology monitoring and assessment financial assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa9bbce6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4834/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Purpose of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish a foreign critical technology monitoring and assessment program. Under the program, the Secretary may enter into cooperative arrangements with one or more eligible not-for-profit organizations in order to provide financial assistance for the establishment of foreign critical technology monitoring and assessment offices in Europe, Pacific Rim countries, and such other countries as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbce7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4834/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any not-for-profit industrial or professional organization that has economic and scientific interests in research, development, and applications of dual-use critical technologies is eligible to enter into a cooperative arrangement referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa9bbce8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s821/a"},"text":"Pub. L. 102–190, div. A, title VIII, § 821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1431"},"text":"105 Stat. 1431","children":[],"tail":", § 2526; renumbered § 2518, "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4228"},"text":"Pub. L. 102–484, div. D, title XLII, § 4228","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2685"},"text":"106 Stat. 2685","children":[],"tail":"; renumbered § 4834, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1868/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1868(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4282"},"text":"134 Stat. 4282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa9bbce9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa9bbcea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa9bbceb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4834, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"ta