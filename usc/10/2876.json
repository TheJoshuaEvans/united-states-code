{"tag":"section","attrib":{"id":"ida9eda26f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2876"},"text":null,"children":[{"tag":"num","attrib":{"value":"2876"},"text":"§ 2876.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rental guarantees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may enter into agreements with eligible entities that acquire or construct military family housing units or military unaccompanied housing units under this subchapter in order to assure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda270-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2876/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occupancy of such units at levels specified in the agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda271-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2876/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental income derived from rental of such units at levels specified in the agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eda272-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/546"},"text":"110 Stat. 546","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2803/e"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2803(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/849"},"text":"113 Stat. 849","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eda273-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eda274-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eda275-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “eligible entities” for “private persons” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
