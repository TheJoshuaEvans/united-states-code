{"tag":"section","attrib":{"id":"ida9da90fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2815a"},"text":"§ 2815a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stormwater management, shoreline erosion control, and water resilience projects for installations and defense access roads","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9da90fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Projects Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may carry out one or more of the following projects on or related to a military installation:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da90fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A stormwater management project for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da90fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving military installation resilience or the resilience of a defense access road or other essential civilian infrastructure supporting a military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da90ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting nearby waterways and stormwater-stressed ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A shoreline erosion control project for the purpose of improving, protecting, or repairing shoreline to protect the infrastructure of a military installation or a defense access road.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project to provide water storage and filtration, flood mitigation, or otherwise support water resilience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Methods and Funding Sources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using such amounts as may be provided in advance in appropriation Acts, the Secretary concerned may carry out a project under this section as, or as part of, any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An authorized military construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An unspecified minor military construction project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805"},"text":"section 2805 of this title","children":[],"tail":", including using appropriations available for operation and maintenance subject to the limitation in subsection (c) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A military installation resilience project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2815"},"text":"section 2815 of this title","children":[],"tail":", including the use of appropriations available for operations and maintenance subject to the limitation of subsection (e)(3) of such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A defense community infrastructure resilience project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2391/d"},"text":"section 2391(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A military installation resilience project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2684a"},"text":"section 2684a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A construction project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2914"},"text":"section 2914 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reserve component facility project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233"},"text":"section 18233 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da910a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A defense access road project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s210"},"text":"section 210 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da910b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Priorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting projects to be carried out under this section, the Secretary concerned shall give a priority to a project proposal that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da910c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizes the runoff of untreated stormwater into freshwater systems or tidal systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da910d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protects military installations and defense access roads from stormwater runoff and water levels resulting from extreme weather conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da910e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controls shoreline erosion control that involve the improvement, protection, or repair of shoreline subject to wave action or stormwater runoff and water levels resulting from extreme weather condition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da910f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports water resilience at military installations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9110-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities carried out as part of a project under this section may include, but are not limited to, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9111-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The installation, expansion, or refurbishment of stormwater ponds and other water-slowing, retention, or filtration measures to address storm water management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9112-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The installation of permeable pavement in lieu of, or to replace existing, nonpermeable pavement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9113-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of planters, tree boxes, cisterns, and rain gardens to reduce stormwater runoff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9114-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capture or storage of stormwater for use in supporting water resilience at a military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9115-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of sheet piles, riprap, armor stone, sea walls, natural plantings, or any other technologies created to address shoreline erosion control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9116-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9117-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a project carried out under this section on or related to a military installation and any project related to the same installation carried out under section 2391, 2684, 2815, or 2914 of this title, the Secretary concerned shall ensure coordination between the projects regarding the water access, management, conservation, security, and resilience aspects of the projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9118-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Energy, Installations, and Environment shall designate an official to be responsible for coordinating projects under this section among the military departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9119-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da911a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 90 days after the end of each fiscal year, each Secretary concerned shall submit to the congressional defense committees a report describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da911b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of planned and active projects carried out by that Secretary under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da911c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projects completed by the Secretary concerned during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da911d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report shall include the following information with respect to each project described in the report:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da911e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The title, location, a brief description of the scope of work, the original project cost estimate, and the current working cost estimate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da911f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The rationale for how the project will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9da9120-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve military installation resilience or the resilience of a defense access road or other essential civilian infrastructure supporting a military installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9da9121-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect waterways and stormwater-stressed ecosystems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9da9122-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve, protect, or repair shoreline to protect infrastructure of a military installation or a defense access road from shoreline erosion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9da9123-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide water storage and filtration, flood mitigation, or otherwise support water resilience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9124-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary concerned considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9125-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9126-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense access road” means a road certified to the Secretary of Transportation as important to the national defense under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s210"},"text":"section 210 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9127-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “facility” and “State” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18232"},"text":"section 18232 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9128-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military installation” includes a facility of a reserve component owned by a State rather than the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9129-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military installation resilience” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da912a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da912b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of a military department with respect to military installations under the jurisdiction of that Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da912c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense with respect to matters concerning the Defense Agencies and facilities of a reserve component owned by a State rather than the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da912d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2815a/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “water resilience” means the capacity of a military installation to mitigate, respond, or adapt to changes in water availability due to manmade or natural phenomena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9da912e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dB/tXXVIII/s2803"},"text":"Pub. L. 117–81, div. B, title XXVIII, § 2803","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2186"},"text":"135 Stat. 2186","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2847"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2847","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2264"},"text":"138 Stat. 2264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9da912f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9da9130-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9da9131-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/1"},"text":"Pub. L. 118–159, § 2847(a)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Stormwater management projects for installation and defense access road resilience and waterway and ecosystems conservation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/2"},"text":"Pub. L. 118–159, § 2847(a)(2)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary concerned may carry out a stormwater management project on or related to a military installation for the purpose of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) improving military installation resilience or the resilience of a defense access road or other essential civilian infrastructure supporting the military installation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) protecting nearby waterways and stormwater-stressed ecosystems.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/3/A"},"text":"Pub. L. 118–159, § 2847(a)(3)(A)","children":[],"tail":", struck out “stormwater management” before “project under this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/3/B"},"text":"Pub. L. 118–159, § 2847(a)(3)(B)","children":[],"tail":", (C), added par.(5) and redesignated former pars. (5) to (7) as (6) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/4"},"text":"Pub. L. 118–159, § 2847(a)(4)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “In selecting stormwater management projects to be carried out under this section, the Secretary concerned shall give a priority to project proposals involving the retrofitting of buildings and grounds on a military installation or retrofitting a defense access road to reduce stormwater runoff and ponding or standing water that includes the combination of stormwater runoff and water levels resulting from extreme weather conditions.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/5/A"},"text":"Pub. L. 118–159, § 2847(a)(5)(A)","children":[],"tail":", struck out “stormwater management” before “project” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/5/B"},"text":"Pub. L. 118–159, § 2847(a)(5)(B)","children":[],"tail":", substituted “, retention, or filtration measures to address storm water management” for “and retention measures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/5/C"},"text":"Pub. L. 118–159, § 2847(a)(5)(C)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/6"},"text":"Pub. L. 118–159, § 2847(a)(6)","children":[],"tail":", designated existing provisions as par. (1), struck out “stormwater management” before “project carried”, substituted “section 2391, 2684,” for “section 2391(d),”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/7/A"},"text":"Pub. L. 118–159, § 2847(a)(7)(A)","children":[],"tail":", struck out “stormwater management” before “projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/7/A"},"text":"Pub. L. 118–159, § 2847(a)(7)(A)","children":[],"tail":", struck out “stormwater management” before “project” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/7/B"},"text":"Pub. L. 118–159, § 2847(a)(7)(B)","children":[],"tail":", added cls. (iii) and (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/b"},"text":"Pub. L. 118–159, § 2847(b)","children":[],"tail":", substituted “section 101” for “section 101(e)(8)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2847/a/8"},"text":"Pub. L. 118–159, § 2847(a)(8)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
