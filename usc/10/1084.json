{"tag":"section","attrib":{"id":"ida88587cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1084"},"text":null,"children":[{"tag":"num","attrib":{"value":"1084"},"text":"§ 1084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations of dependency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A determination of dependency by an administering Secretary under this chapter is conclusive. However, the administering Secretary may change a determination because of new evidence or for other good cause. The Secretary’s determination may not be reviewed in any court or by the Comptroller General, unless there has been fraud or gross negligence.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida88587ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/25/B"},"text":"Pub. L. 85–861, § 1(25)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1450"},"text":"72 Stat. 1450","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/614/s2/1"},"text":"Pub. L. 89–614, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"Sept. 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/862"},"text":"80 Stat. 862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/34/A"},"text":"Pub. L. 96–513, title V, § 511(34)(A)","children":[],"tail":", (36), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2922"},"text":"94 Stat. 2922","children":[],"tail":", 2923; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s19/11"},"text":"Pub. L. 98–557, § 19(11)","children":[],"tail":", "},{"tag":"date","attrib":{"