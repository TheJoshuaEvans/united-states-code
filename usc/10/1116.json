{"tag":"section","attrib":{"id":"ida8965139-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116"},"text":null,"children":[{"tag":"num","attrib":{"value":"1116"},"text":"§ 1116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments into the Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida896513a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the beginning of each fiscal year after ","children":[{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":", the Secretary of the Treasury shall promptly pay into the Fund from the General Fund of the Treasury—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida896513b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount certified to the Secretary by the Secretary of Defense under subsection (c), which shall be the contribution to the Fund for that fiscal year required by section 1115; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida896513c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined by each administering Secretary under section 1111(c) as the contribution to the Fund on behalf of the members of the uniformed services under the jurisdiction of that Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida896513d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the beginning of each fiscal year, the Secretary of Defense shall determine the sum of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida896513e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the payment for that year under the amortization schedule determined by the Board of Actuaries under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1115/a"},"text":"section 1115(a) of this title","children":[],"tail":" for the amortization of the original unfunded liability of the Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida896513f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount (including any negative amount) of the Department of Defense contribution for that year as determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1115/b"},"text":"section 1115(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8965140-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount (including any negative amount) for that year under the most recent amortization schedule determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1115/c/2"},"text":"section 1115(c)(2) of this title","children":[],"tail":" for the amortization of any cumulative unfunded liability (or any gain) to the Fund resulting from changes in benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8965141-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount (including any negative amount) for that year under the most recent amortization schedule determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1115/c/3"},"text":"section 1115(c)(3) of this title","children":[],"tail":" for the amortization of any cumulative actuarial gain or loss to the Fund resulting from actuarial assumption changes."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8965142-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount (including any negative amount) for that year under the most recent amortization schedule determined by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1115/c/4"},"text":"section 1115(c)(4) of this title","children":[],"tail":" for the amortization of any cumulative actuarial gain or loss to the Fund resulting from actuarial experience."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8965143-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall promptly certify the amount determined under subsection (b) each year to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8965144-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the same time as the Secretary of Defense makes the certification under subsection (c), the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives the information provided to the Secretary of the Treasury under that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8965145-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VII, § 713(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–182; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVII/s711/b/4"},"text":"Pub. L. 107–107, div. A, title VII, § 711(b)(4)","children":[],"tail":", (d), (e)(1), title X, § 1048(a)(13), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1165"},"text":"115 Stat. 1165","children":[],"tail":", 1166, 1223; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVII/s704/a"},"text":"Pub. L. 107–314, div. A, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2584"},"text":"116 Stat. 2584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVII/s722/b"},"text":"Pub. L. 108–136, div. A, title VII, § 722(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1532"},"text":"117 Stat. 1532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s725/a"},"text":"Pub. L. 108–375, div. A, title VII, § 725(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1991"},"text":"118 Stat. 1991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8965146-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8965147-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8965148-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, section related to, in subsec. (a), calculation of the Department of Defense monthly contribution to the Fund, in subsec. (b), separate calculation by a participating uniformed service, in subsec. (c), payments to the Fund at the beginning of each fiscal year by the Secretary of the Treasury, and, in subsec. (d), amounts paid into the Fund under subsec. (a) from the pay of members of the participating uniformed services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s722/b/1"},"text":"Pub. L. 108–136, § 722(b)(1)","children":[],"tail":", substituted “the amount that, subject to subsection (b),” for “the amount that” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s722/b/2"},"text":"Pub. L. 108–136, § 722(b)(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “pay of members” for “health care programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711/e/1"},"text":"Pub. L. 107–107, § 711(e)(1)","children":[],"tail":", substituted “uniformed services retiree health care programs” for “Department of Defense retiree health care programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711/b/4"},"text":"Pub. L. 107–107, § 711(b)(4)","children":[],"tail":", inserted “under the jurisdiction of the Secretary of Defense” after “uniformed services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711/e/1"},"text":"Pub. L. 107–107, § 711(e)(1)","children":[],"tail":", substituted “uniformed services retiree health care programs” for “Department of Defense retiree health care programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/a/13/A"},"text":"Pub. L. 107–107, § 1048(a)(13)(A)","children":[],"tail":", inserted an opening parenthesis before “other than for training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711/b/4"},"text":"Pub. L. 107–107, § 711(b)(4)","children":[],"tail":", (d)(1), inserted “under the jurisdiction of the Secretary of Defense” after “uniformed services” and struck out at end “Amounts paid into the Fund under this subsection shall be paid from funds available for the Defense Health Program.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/a/13/B"},"text":"Pub. L. 107–107, § 1048(a)(13)(B)","children":[],"tail":", substituted “section 1115(c)(4)” for “section 111(c)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711/d/2"},"text":"Pub. L. 107–107, § 711(d)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8965149-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida896514a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s725/d"},"text":"section 725(d) of Pub. L. 108–375","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1111"},"text":"section 1111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida896514b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711"},"text":"section 711 of Pub. L. 107–107","children":[],"tail":" effective as if included in the enactment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s711/f"},"text":"section 711(f) of Pub. L. 107–107","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1111"},"text":"section 1111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida896514c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", see section 1 [[div. A], title VII, § 713(b)(1)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1113"},"text":"section 1113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida896514d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (d) of this section requiring submittal of annual report to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida896514e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability to Indian Health Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dF/tII"},"text":"Pub. L. 108–7, div. F, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/261"},"text":"117 Stat. 261","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/7/dF/tII"},"text":"“That heretofore and hereafter the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1116"},"text":"10 U.S.C. 1116","children":[],"tail":" shall not apply to the Indian Health Service”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida896514f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"First Year Contributions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVII/s711/g"},"text":"Pub. L. 107–107, div. A, title VII, § 711(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1167"},"text":"115 Stat. 1167","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tVII/s711/g"},"text":"“With respect to contributions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1116/a"},"text":"section 1116(a) of title 10","children":[],"tail":", United States Code, for the first year that the Department of Defense Medicare-Eligible Retiree Health Care Fund is established under chapter 56 of such title, if the Board of Actuaries is unable to execute its responsibilities with respect to such section, the Secretary of Defense may make contributions under such section using methods and assumptions developed by the Secretary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
