{"tag":"section","attrib":{"id":"ida9fe4513-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924"},"text":null,"children":[{"tag":"num","attrib":{"value":"2924"},"text":"§ 2924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fe4514-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “defined fuel source” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fe4515-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petroleum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4516-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Natural gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4517-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4518-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coke.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe4519-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “energy-efficient maintenance” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fe451a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the repair of military vehicles, equipment, or facility and infrastructure systems, such as lighting, heating, or cooling equipment or systems, or industrial processes, by replacement with technology that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9fe451b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will achieve energy savings over the life-cycle of the equipment or system being repaired; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9fe451c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will meet the same end needs as the equipment or system being repaired; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe451d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements in an operation or maintenance process, such as improved training or improved controls, that result in energy savings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe451e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “hybrid”, with respect to a motor vehicle, means a motor vehicle that draws propulsion energy from onboard sources of stored energy that are both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fe451f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an internal combustion or heat engine using combustible fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4520-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rechargeable energy storage system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe4521-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “operational energy” means the energy required for training, moving, and sustaining military forces and weapons platforms for military operations. The term includes energy used by tactical power systems and generators and weapons platforms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe4522-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “petroleum” means natural or synthetic crude, blends of natural or synthetic crude, and products refined or derived from natural or synthetic crude or from such blends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe4523-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “renewable energy source” means energy generated from renewable sources, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9fe4524-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Solar, including electricity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4525-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wind.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4526-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biomass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4527-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biogas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4528-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Landfill gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe4529-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ocean, including tidal, wave, current, and thermal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe452a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geothermal, including electricity and heat pumps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe452b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Municipal solid waste.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe452c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New hydroelectric generation capacity achieved from increased efficiency or additions of new capacity at an existing hydroelectric project. For purposes of this subparagraph, hydroelectric generation capacity is “new” if it was placed in service on or after ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9fe452d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thermal energy generated by any of the preceding sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe452e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “biomass” has the meaning given the term “renewable biomass” in section 211(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1) of the Clean Air Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"42 U.S.C. 7545","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe452f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2924/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “biogas” means biogas as such term is used in section 211(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(B)(ii)(V) of the Clean Air Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7545"},"text":"42 U.S.C. 7545","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(B)(ii)(V))."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fe4530-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dB/tXXVIII/s2821/a/1"},"text":"Pub. L. 112–81, div. B, title XXVIII, § 2821(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1689"},"text":"125 Stat. 1689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2831/c/6"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2831(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1858"},"text":"131 Stat. 1858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s318"},"text":"Pub. L. 117–263, div. A, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2507"},"text":"136 Stat. 2507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9fe4531-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9fe4532-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9fe4533-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (6)(D) to (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s318/1"},"text":"Pub. L. 117–263, § 318(1)","children":[],"tail":", added subpar. (D) and redesignated former subpars. (D) to (I) as (E) to (J), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s318/2"},"text":"Pub. L. 117–263, § 318(2)","children":[],"tail":", added pars. (7) and (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Pars. (3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" redesignated pars. (4) to (7) as (3) to (6), respectively, and struck out former par. (3) which defined “energy security”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
