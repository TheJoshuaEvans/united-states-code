{"tag":"section","attrib":{"id":"ida84c4f10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1039"},"text":null,"children":[{"tag":"num","attrib":{"value":"1039"},"text":"§ 1039.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting of minority service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of determining eligibility for retirement or transfer to the Fleet Reserve or Fleet Marine Corps Reserve, entitlement to retired or retainer pay, and years of service in computing retired or retainer pay of a member of the armed forces, any service which would be creditable but for the fact that it was performed by him under an enlistment or induction entered into before he attained the age prescribed by law for that enlistment or induction, shall be credited.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida84c4f11-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/165/s1/1"},"text":"Pub. L. 87–165, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-25"},"text":"Aug. 25, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/401"},"text":"75 Stat. 401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84c4f12-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84c4f13-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida84c4f14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/165/s2"},"text":"Pub. L. 87–165, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-25"},"text":"Aug. 25, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/401"},"text":"75 Stat. 401","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/165/s2"},"text":"“Section 1 [enacting this section] applies to service performed, and retirements or transfers to the Fleet Reserve or the Fleet Marine Corps Reserve effected, before and after this Act takes effect [","children":[{"tag":"date","attrib":{"date":"1961-08-25"},"text":"Aug. 25, 1961","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
