{"tag":"section","attrib":{"id":"idab17a40c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8271"},"text":null,"children":[{"tag":"num","attrib":{"value":"8271"},"text":"§ 8271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of accounts: remission or cancellation of indebtedness of members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab17a40d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may have remitted or cancelled any part of the indebtedness of a person to the United States or any instrumentality of the United States incurred while the person was serving as a member of the naval service, whether as a regular or a reserve in active status, but only if the Secretary considers such action to be in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a40e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retroactive Applicability to Certain Debts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may be exercised with respect to any debt covered by that subsection that is incurred on or after ","children":[{"tag":"date","attrib":{"date":"2001-10-07"},"text":"October 7, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a40f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8271/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab17a410-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/511/s1/a"},"text":"Pub. L. 86–511, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-11"},"text":"June 11, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/207"},"text":"74 Stat. 207","children":[],"tail":", § 6161; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s683/b/1"},"text":"Pub. L. 109–163, div. A, title VI, § 683(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3322"},"text":"119 Stat. 3322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s673/b/1"},"text":"Pub. L. 109–364, div. A, title VI, § 673(b)(1)","children":[],"tail":", (2), (e)(2), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2271"},"text":"120 Stat. 2271","children":[],"tail":", 2272; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/c/7/B"},"text":"Pub. L. 110–181, div. A, title X, § 1063(c)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/323"},"text":"122 Stat. 323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s671/b/2"},"text":"Pub. L. 114–328, div. A, title VI, § 671(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2173"},"text":"130 Stat. 2173","children":[],"tail":"; renumbered § 8271, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/10"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab17a411-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab17a412-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab17a413-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6161"},"text":"section 6161 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “as a member of the naval service, whether as a regular or a reserve in active status” for “on active duty as a member of the naval service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/b/1"},"text":"Pub. L. 109–364, § 673(b)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “If he considers it in the best interest of the United States, the Secretary of the Navy may have remitted or canceled any part of an enlisted member’s indebtedness to the United States or any of its instrumentalities remaining unpaid before, or at the time of that member’s honorable discharge.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/e/2"},"text":"Pub. L. 109–364, § 673(e)(2)","children":[],"tail":", substituted “The Secretary of the Navy” for “If the Secretary of the Navy considers it to be in the best interest of the United States, the Secretary” and inserted “, but only if the Secretary considers such action to be in the best interest of the United States” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/b/1"},"text":"Pub. L. 109–364, § 673(b)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":", substituted “of a person to the United States or any instrumentality of the United States incurred while the person was serving on active duty as a member of the naval service” for “of a member of the Navy on active duty, or a member of a reserve component of the Navy in an active status, to the United States or any instrumentality of the United States incurred while the member was serving on active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/b/2"},"text":"Pub. L. 109–364, § 673(b)(2)","children":[],"tail":", redesignated subsecs. (c) and (d) as (b) and (c), respectively, and struck out heading and text of former subsec. (b). Text read as follows: “The Secretary of the Navy may exercise the authority in subsection (a) with respect to a member—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) while the member is on active duty or in active status, as the case may be;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) if discharged from the armed forces under honorable conditions, during the one-year period beginning on the date of such discharge; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) if released from active status in a reserve component, during the one-year period beginning on the date of such release.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab17a414-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab17a415-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab17a416-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", and applicable with respect to debt incurred on or after "},{"tag":"date","attrib":{"date":"2001-10-07"},"text":"Oct. 7, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s671/b/5"},"text":"section 671(b)(5) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7837"},"text":"section 7837 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab17a417-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1063/c"},"text":"Pub. L. 110–181, div. A, title X, § 1063(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/322"},"text":"122 Stat. 322","children":[],"tail":", provided that the amendment made by section 1063(c)(7)(B) is effective as of "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", and as if included in the John Warner National Defense Authorization Act for Fiscal Year 2007, "},{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":", as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idab17a418-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s683/b/3"},"text":"Pub. L. 109–163, div. A, title VI, § 683(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3323"},"text":"119 Stat. 3323","children":[],"tail":", which provided for termination of amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s683/b"},"text":"Pub. L. 109–163, § 683(b)","children":[],"tail":", amending this section and the analysis to this chapter, on "},{"tag":"date","attrib":{"date":"2007-12-31"},"text":"Dec. 31, 2007","children":[],"tail":", and restoration of provisions as in effect on the day before "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s673/b/3"},"text":"Pub. L. 109–364, div. A, title VI, § 673(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2271"},"text":"120 Stat. 2271","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab17a419-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Secretary of Defense to prescribe regulations required for purposes of this section, as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":", not later than "},{"tag":"date","attrib":{"date":"2007-03-01"},"text":"Mar. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/d"},"text":"section 673(d) of Pub. L. 109–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7837"},"text":"section 7837 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
