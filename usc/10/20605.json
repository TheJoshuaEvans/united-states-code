{"tag":"section","attrib":{"id":"idabcceab6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605"},"text":null,"children":[{"tag":"num","attrib":{"value":"20605"},"text":"§ 20605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other provisions of law relating to retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabcceab7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Members of the Space Force","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as specifically provided for by this chapter, the provisions of this title specified in subsection (b) apply to members of the Space Force as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabcceab8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to an officer of the Air Force shall apply to an officer of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceab9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to an enlisted member of the Air Force shall apply to an enlisted member of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceaba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to a regular officer shall apply to an officer who is on sustained duty in the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceabb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to a regular enlisted member shall apply to an enlisted member who is on sustained duty in the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceabc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to a reserve officer shall apply to an officer who is in a space force active status but not on sustained duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceabd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to a reserve enlisted member shall apply to an enlisted member who is in a space force active status but not on sustained duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceabe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to service in a regular component shall apply to service on sustained duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceabf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to service in a reserve component shall apply to service in a space force active status not on sustained duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to a member of the Ready Reserve shall apply to a member of the Space Force who is in a space force active status prior to being ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions pertaining to a member of the Retired Reserve shall apply to a member of the Space Force who has retired under chapter 1223 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcceac2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions of Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this title referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabcceac3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 61, relating to retirement or separation for physical disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 63, relating to retirement for age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 69, relating to retired grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 71, relating to computation of retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 941, relating to retirement from the Air Force for length of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 945, relating to computation of retired pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceac9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 1223, relating to retired pay for non-regular service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabcceaca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20605/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 1225, relating to retired grade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcceacb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719A/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719A(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/663"},"text":"137 Stat. 663","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
