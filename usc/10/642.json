{"tag":"section","attrib":{"id":"ida7f41d3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s642"},"text":null,"children":[{"tag":"num","attrib":{"value":"642"},"text":"§ 642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement of officers discharged or retired under this chapter to separation pay or retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f41d40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is discharged under this chapter is entitled, if eligible therefor, to separation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174"},"text":"section 1174 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41d41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is retired under this chapter is entitled to retired pay computed under chapter 71 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f41d42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2867"},"text":"94 Stat. 2867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f41d43-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f41d44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading"