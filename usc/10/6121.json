{"tag":"section","attrib":{"id":"idaabd01c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6121"},"text":null,"children":[{"tag":"num","attrib":{"value":"6121"},"text":"§ 6121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing of nuclear weapons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabd01c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underground Testing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No underground test of nuclear weapons may be conducted by the United States after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", unless a foreign state conducts a nuclear test after this date, at which time the prohibition on United States nuclear testing is lifted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabd01c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Atmospheric Testing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"None of the funds appropriated pursuant to the National Defense Authorization Act for Fiscal Year 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Public Law 103–160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/107/1547"},"text":"107 Stat. 1547","children":[],"tail":") or any other Act for any fiscal year may be available to maintain the capability of the United States to conduct atmospheric testing of a nuclear weapon."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabd01c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1358"},"text":"139 Stat. 1358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabd01ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabd01cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaabd01cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Defense Authorization Act for Fiscal Year 1994, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1547"},"text":"107 Stat. 1547","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabd01cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2530"},"text":"section 2530 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
