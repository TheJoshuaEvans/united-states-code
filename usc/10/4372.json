{"tag":"section","attrib":{"id":"idaa75982b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372"},"text":null,"children":[{"tag":"num","attrib":{"value":"4372"},"text":"§ 4372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit cost reports: quarterly report from program manager to service acquisition executive","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa75982c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa75982d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program manager for a major defense acquisition program (other than a program not required to be included in the Selected Acquisition Report for that quarter under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/b/3"},"text":"section 4351(b)(3) of this title","children":[],"tail":") shall, on a quarterly basis, submit to the service acquisition executive designated by the Secretary concerned a written report on the unit costs of the program (or of each designated major subprogram under the program)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa75982e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for submittal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report shall be submitted not more than 30 calendar days after the end of that quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa75982f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matter to Be Included in Unit Cost Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program manager shall include in each such unit cost report the following information with respect to the program (as of the last day of the quarter for which the report is made):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa759830-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program acquisition unit cost for the program (or for each designated major subprogram under the program).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa759831-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a procurement program, the procurement unit cost for the program (or for each designated major subprogram under the program).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa759832-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any cost variance or schedule variance in a major contract under the program since the contract was entered into.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa759833-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any changes from program schedule milestones or program performances reflected in the baseline description established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4214"},"text":"section 4214 of this title","children":[],"tail":" that are known, expected, or anticipated by the program manager."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa759834-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4372/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any significant changes in the total program cost for development and procurement of the software component of the program or subprogram, schedule milestones for the software component of the program or subprogram, or expected performance for the software component of the program or subprogram that are known, expected, or anticipated by the program manager.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa759835-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1850/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1850(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4265"},"text":"134 Stat. 4265","children":[],"tail":", 4266; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/18"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(18)","children":[],"tail":", ("},{"t