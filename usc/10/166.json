{"tag":"section","attrib":{"id":"ida77354b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166"},"text":null,"children":[{"tag":"num","attrib":{"value":"166"},"text":"§ 166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combatant commands: budget proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida77354b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Combatant Command Budgets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall include in the annual budget of the Department of Defense submitted to Congress a separate budget proposal for such activities of each of the unified and specified combatant commands as may be determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77354b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A budget proposal under subsection (a) for funding of activities of a combatant command shall include funding proposals for such activities of the combatant command as the Secretary (after consultation with the Chairman of the Joint Chiefs of Staff) determines to be appropriate for inclusion. Activities of a combatant command for which funding may be requested in such a proposal include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida77354b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint exercises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77354b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Force training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77354b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contingencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida77354b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selected operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida77354b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s166/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"SOF Training With Foreign Forces","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A funding proposal for force training under subsection (b)(2) may include amounts for training expense payments authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s322"},"text":"section 322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida77354b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s211/a"},"text":"Pub. L. 99–433, title II, § 211(a)",