{"tag":"section","attrib":{"id":"ida9dcda35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817"},"text":null,"children":[{"tag":"num","attrib":{"value":"2817"},"text":"§ 2817.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for certain construction projects in friendly foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9dcda36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using funds available for operations and maintenance, the Secretary of Defense may carry out a construction project in a friendly foreign country, and perform planning and design to support such a project, that the Secretary determines meets each of the following conditions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The commander of the geographic combatant command in which the construction project will be carried out identified the construction project as necessary to support vital United States military requirements at an air port of debarkation, sea port of debarkation, or rail or other logistics support location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction project will not be carried out at a military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The funds made available under the authority of this section for the construction project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will be sufficient to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9dcda3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construct a complete and usable facility or make an improvement to a facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9dcda3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the repair of an existing facility or improvement to a facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not require additional funds from other Department of Defense accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The level of construction for the construction project may not exceed the minimum necessary to meet the military requirements identified under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deferral of the construction project pending inclusion of the construction project proposal in the national defense authorization Act for a subsequent fiscal year is inconsistent with the military requirements identified under paragraph (1) and other national security or national interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon determining to carry out a construction project under this section that has an estimated cost in excess of the amounts authorized for unspecified minor military construction projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/c"},"text":"section 2805(c) of this title","children":[],"tail":", the Secretary of Defense shall submit to the specified congressional committees a notification of such determination."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification that the conditions specified in subsection (a) are satisfied with regard to the construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A justification for such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the cost of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and wait","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may carry out a construction project only after the end of the 30-day period beginning on the date the notice required by paragraph (1) is received by the specified congressional committees in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Limitations on Use of Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Total cost limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not obligate more than $200,000,000 in any fiscal year under the authority provided by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional obligation authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary of Defense may authorize the obligation under this section of not more than an additional $10,000,000 from funds available for operations and maintenance for a fiscal year if the Secretary determines that the additional funds are needed for costs associated with contract closeouts for all construction projects during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum amount that the Secretary may obligate for a single construction project is $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specified Congressional Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “specified congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Subcommittee on Defense and the Subcommittee on Military Construction, Veterans Affairs, and Related Agencies of the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2817/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Subcommittee on Defense and the Subcommittee on Military Construction, Veterans Affairs, and Related Agencies of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9dcda4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2805"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/744"},"text":"137 Stat. 744","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
