{"tag":"section","attrib":{"id":"idaac90f62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262"},"text":null,"children":[{"tag":"num","attrib":{"value":"6262"},"text":"§ 6262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety oversight and enforcement at defense nuclear facilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall take appropriate actions to ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90f63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officials of the Department of Energy who are responsible for independent oversight of matters relating to nuclear safety at defense nuclear facilities and enforcement of nuclear safety standards at such facilities maintain independence from officials who are engaged in, or who are advising persons who are engaged in, management of such facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the independent, internal oversight functions carried out by the Department include activities relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90f65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of the safety of defense nuclear facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90f66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assessment of the effectiveness of Department program offices in carrying out programs relating to the environment, safety, health, and security at defense nuclear facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90f67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the provision to the Secretary of oversight reports that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaac90f68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain validated technical information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaac90f69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a clear analysis of the extent to which line programs governing defense nuclear facilities meet applicable goals for the environment, safety, health, and security at such facilities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90f6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of clear performance standards to be used in assessing the adequacy of the programs referred to in subparagraph (C)(ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department has a system for bringing issues relating to nuclear safety at defense nuclear facilities to the attention of the officials of the Department (including the Secretary of Energy) who have authority to resolve such issues in an adequate and timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6262/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adequate number of qualified personnel of the Department are assigned to oversee matters relating to nuclear safety at defense nuclear facilities and enforce nuclear safety standards at such facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90f6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1420"},"text":"139 Stat. 1420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90f6e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90f6f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90f70-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2732"},"text":"section 2732 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
