ull}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “that * * * will provide the most beneficial treatment” are substituted for the words “best calculated to promise a restoration of reason” for clarity. The second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s595"},"text":"34 U.S.C. 595","children":[],"tail":" is omitted as superseded. It provided a method by which the Secretary of the Navy, in his discretion, could compensate other agencies for expenses involved in hospitalizing insane naval patients. Other provisions of law, principally "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s31"},"text":"24 U.S.C. 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s686"},"text":"31 U.S.C. 686","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s284"},"text":"37 U.S.C. 284","children":[],"tail":", and regulations, principally Executive Order 10122, of "},{"tag":"date","attrib":{"date":"1950-04-14"},"text":"April 14, 1950","children":[],"tail":", establish the method currently used."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab17a432-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab17a433-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6202"},"text":"section 6202 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic"