{"tag":"section","attrib":{"id":"idab17a42d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8282"},"text":null,"children":[{"tag":"num","attrib":{"value":"8282"},"text":"§ 8282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insane members of the naval service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member of the naval service who becomes insane may be placed in the hospital for the insane that, in the opinion of the Secretary of the Navy, is most convenient and will provide the most beneficial treatment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab17a42e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/387"},"text":"70A Stat. 387","children":[],"tail":", § 6202; renumbered § 8282, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab17a42f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab17a430-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab17a431-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}