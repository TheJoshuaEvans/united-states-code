{"tag":"section","attrib":{"id":"ida74f9f65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a"},"text":null,"children":[{"tag":"num","attrib":{"value":"125a"},"text":"§ 125a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reform: improvement of efficacy and efficiency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida74f9f66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall take such action as is necessary to reform the Department of Defense to improve the efficacy and efficiency of the Department, and to improve the ability of the Department to prioritize among and assess the costs and benefits of covered elements of reform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74f9f67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop a policy and issue guidance to implement reform within the Department and to improve the ability of the Department to prioritize among and assess the costs and benefits of covered elements of reform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida74f9f68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Framework for Reform.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida74f9f69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-02-01"},"text":"February 1, 2023","children":[],"tail":", the Secretary shall establish policies, guidance, and a consistent reporting framework to measure the progress of the Department toward covered elements of reform, including by establishing categories of reform, consistent metrics, and a process for prioritization of reform activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74f9f6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The framework required by paragraph (1) may address duties under the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida74f9f6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s125"},"text":"Section 125 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74f9f6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s192"},"text":"Section 192 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74f9f6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222"},"text":"Section 2222 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74f9f6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1124"},"text":"Section 1124 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida74f9f6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11319"},"text":"Section 11319 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida74f9f70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consult with the Deputy Secretary of Defense, the Performance Improvement Officer of the Department of Defense, the Chief Data Officer of the Department of Defense, the Chief Information Officer of the Department of Defense, the Director for Administration and Management of the Department of Defense, and the financial managers of the military departments in carrying out activities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e961-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Elements of Reform","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and the policies, guidance, and reporting framework required by subsection (c), covered elements of reform may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e962-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Business systems modernization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e963-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enterprise business operations process re-engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e964-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expanded and modernized collection, management, dissemination, and visualization of data to support decision-making at all levels of the enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvements in workforce training and education and increasing capabilities of the Department workforce to support and execute reform activities and business processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improvements to decision-making processes to enable cost savings, cost avoidance, or investments to develop process improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and implementation of a uniform methodology for tracking and assessing cost savings and cost avoidance from reform initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementation of reform-focused research to improve management and administrative science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tracking and implementation of technological approaches to improve management decision-making, such as artificial intelligence tools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e96a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other elements as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida751e96b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the same time the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary shall, using the policies, guidance, and reporting framework required by subsection (c), submit to the congressional defense committees a report, including detailed narrative justifications and tradeoff analyses between options, on the actions of the Department as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida751e96c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The activities, expenditures, and accomplishments carried out or made to effect reform under this section during the fiscal year in which such budget is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida751e96d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s125a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proposed activities, expenditures, and accomplishments to effect reform under this section, and consistent with priorities established by the Secretary, during the fiscal year covered by such budget and each of the four succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida751e96e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s911/a/1"},"text":"Pub. L. 116–283, div. A, title IX, § 911(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3800"},"text":"134 Stat. 3800","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIX/s911"},"text":"Pub. L. 117–263, div. A, title IX, § 911","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2750"},"text":"136 Stat. 2750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida751e96f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida751e970-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida751e971-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s911/1/A"},"text":"Pub. L. 117–263, § 911(1)(A)","children":[],"tail":", substituted “2023” for “2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s911/1/B"},"text":"Pub. L. 117–263, § 911(1)(B)","children":[],"tail":", inserted “the Director for Administration and Management of the Department of Defense,” after “the Chief Information Officer of the Department of Defense,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s911/2"},"text":"Pub. L. 117–263, § 911(2)","children":[],"tail":", added pars. (6) to (8) and redesignated former par. (6) as (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida751e972-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida751e973-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Strategic Management Dashboard Demonstration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIX/s916"},"text":"Pub. L. 117–263, div. A, title IX, § 916","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2755"},"text":"136 Stat. 2755","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tIX/s916"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary of Defense shall conduct a demonstration of a strategic management dashboard to automate the data collection and data visualization of the primary management goals of the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that the strategic management dashboard demonstrated under subsection (a) includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The capability for real-time monitoring of the performance of the Department of Defense in meeting the management goals of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An integrated analytics capability, including the ability to dynamically add or upgrade new capabilities when needed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integration with the framework required by subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s125a"},"text":"section 125a of title 10","children":[],"tail":", United States Code, for measuring the progress of the Department toward covered elements of reform (as defined in subsection (d) of that section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incorporation of the elements of the strategic management plan required by section 904(d) of the National Defense Authorization Act of Fiscal Year 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Public Law 110–181","children":[],"tail":"; 10 U.S.C. note prec. 2201), as derived from automated data feeds from existing information systems and databases."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incorporation of the elements of the most recent annual performance plan of the Department required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115/b"},"text":"section 1115(b) of title 31","children":[],"tail":", United States Code, and the most recent update on performance of the Department required by section 1116 of that title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of artificial intelligence and machine learning tools to improve decision making and assessment relating to data analytics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adoption of leading and lagging indicators for key strategic management goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the demonstration required by subsection (a), the Secretary of Defense may use the authorities described in paragraph (2), and such other authorities as the Secretary considers appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help accelerate the development of innovative technological or process approaches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attract new entrants to solve the data management and visualization challenges of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authorities described in this paragraph are the authorities provided under the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4025"},"text":"Section 4025 of title 10","children":[],"tail":", United States Code (relating to prizes for advanced technology achievements)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 217 of the National Defense Authorization Act for Fiscal Year 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222"},"text":"10 U.S.C. 2222","children":[],"tail":" note) (relating to science and technology activities to support business systems information technology acquisition programs)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 908 of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s129a"},"text":"10 U.S.C. 129a","children":[],"tail":" note) (relating to management innovation activities)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting the demonstration required by subsection (a), the Secretary of Defense shall leverage commercial best practices in management and leading research in management and data science.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategic Management Dashboard Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘strategic management dashboard’ means a system for dynamically displaying management metrics, performance goals, and other information necessary for Department of Defense leadership to make strategic decisions related to the management of the Department using modern, commercial practices for data visualization and drawn from existing automated information systems available to the Department.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida751e974-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementing Policies, Guidance, and Reporting Framework","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s911/b"},"text":"Pub. L. 116–283, div. A, title IX, § 911(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3801"},"text":"134 Stat. 3801","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIX/s911/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-03-01"},"text":"March 1, 2022","children":[],"tail":", the Secretary of Defense shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report setting forth the policies, guidance, and reporting framework established pursuant to subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s125a"},"text":"section 125a of title 10","children":[],"tail":", United States Code (as added by subsection (a) of this section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Update","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the submittal to Congress of the report required by section 901(d) of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s132a"},"text":"10 U.S.C. 132a","children":[],"tail":" note], the Secretary shall update the reporting framework referred to in paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
