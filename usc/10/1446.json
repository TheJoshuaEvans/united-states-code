{"tag":"section","attrib":{"id":"ida8c85d45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1446"},"text":null,"children":[{"tag":"num","attrib":{"value":"1446"},"text":"§ 1446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8c85d46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1441"},"text":"section 1441 of this title","children":[],"tail":", if a person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c85d47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1446/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made an election under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c85d48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1446/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is retired for physical disability before he completes 19 years of service for which he is entitled to credit in the computation of his basic pay;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and thereafter dies, his beneficiaries are not entitled to the annuities provided under this subchapter until they give proof to the department concerned that they are not eligible for benefits under chapter 11 or 13 of title 38. If the beneficiaries are not eligible for benefits under chapter 11 or 13 of title 38, the annuity shall begin on the first day of the month in which the death occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c85d49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the beneficiaries on whose behalf the election was made are restricted, under subsection (a), from participating in the annuities provided under this subchapter, the amount withheld from the elector’s retired or retainer pay as a result of an election under this subchapter shall be refunded to the beneficiaries, less the amount of any annuities paid under this subchapter, and in either case without interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c85d4a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/381/s6/1"},"text":"Pub. L. 87–381, § 6(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/811"},"text":"75 Stat. 811","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/485/s1/8"},"text":"Pub. L. 90–485, § 1(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-13"},"text":"Aug. 13, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/754"},"text":"82 Stat. 754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/2/A"},"text":"Pub. L. 92–425, § 1(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/706"},"text":"86 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8c85d4b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8c85d4c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8c85d4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425"},"text":"Pub. L. 92–425","children":[],"tail":" substituted “subchapter” for “chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/485"},"text":"Pub. L. 90–485","children":[],"tail":" substituted “19” for “18”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8c85d4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8c85d4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/485"},"text":"Pub. L. 90–485","children":[],"tail":" effective on first day of third calendar month following "},{"tag":"date","attrib":{"date":"1968-08-13"},"text":"Aug. 13, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/485/s6"},"text":"section 6 of Pub. L. 90–485","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1431"},"text":"section 1431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
