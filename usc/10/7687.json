{"tag":"section","attrib":{"id":"idaafd6567-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687"},"text":null,"children":[{"tag":"num","attrib":{"value":"7687"},"text":"§ 7687.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of excess, obsolete, or unserviceable ammunition and ammunition components","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd6568-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Sell Outside DoD","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army may sell to an eligible purchaser described in subsection (c) ammunition or ammunition components that are excess, obsolete, or unserviceable and have not been demilitarized if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd6569-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the purchaser enters into an agreement, in advance, with the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaafd656a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demilitarize the ammunition or components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaafd656b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reclaim, recycle, or reuse the component parts or materials; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd656c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, or an official of the Department of the Army designated by the Secretary, approves the use of the ammunition or components proposed by the purchaser as being consistent with the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd656d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Method of Sale","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall use competitive procedures to sell ammunition and ammunition components under this section, except that the Secretary may use procedures other than competitive procedures in any case in which the Secretary determines that there is only one potential buyer of the items being offered for sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd656e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Purchasers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to purchase excess, obsolete, or unserviceable ammunition or ammunition components under this section, the purchaser shall be a licensed manufacturer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a/10"},"text":"section 921(a)(10) of title 18","children":[],"tail":") that, as determined by the Secretary, has a capability to modify, reclaim, transport, and either store or sell the ammunition or ammunition components sought to be purchased."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd656f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hold Harmless Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require a purchaser of ammunition or ammunition components under this section to agree to hold harmless and indemnify the United States from any claim for damages for death, injury, or other loss resulting from a use of the ammunition or ammunition components, except in a case of willful misconduct or gross negligence of a representative of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6570-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verification of Demilitarization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish procedures for ensuring that a purchaser of ammunition or ammunition components under this section demilitarizes the ammunition or ammunition components in accordance with any agreement to do so under subsection (a)(1). The procedures shall include onsite verification of demilitarization activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6571-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept ammunition, ammunition components, or ammunition demilitarization services as consideration for ammunition or ammunition components sold under this section. The fair market value of any such consideration shall be equal to or exceed the fair market value or, if higher, the sale price of the ammunition or ammunition components sold.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6572-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Arms Export Control Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect the applicability of section 38 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"22 U.S.C. 2778","children":[],"tail":") to sales of ammunition or ammunition components on the United States Munitions List."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6573-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd6574-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “excess, obsolete, or unserviceable”, with respect to ammunition or ammunition components, means that the ammunition or ammunition components are no longer necessary for war reserves or for support of training of the Army or production of ammunition or ammunition components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd6575-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “demilitarize”, with respect to ammunition or ammunition components—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaafd6576-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means to destroy the military offensive or defensive advantages inherent in the ammunition or ammunition components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaafd6577-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7687/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any mutilation, scrapping, melting, burning, or alteration that prevents the use of the ammunition or ammunition components for the military purposes for which the ammunition or ammunition components was designed or for a lethal purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafd6578-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1065/a/1"},"text":"Pub. L. 105–85, div. A, title X, § 1065(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1893"},"text":"111 Stat. 1893","children":[],"tail":", § 4687; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/30"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2399"},"text":"120 Stat. 2399","children":[],"tail":"; renumbered § 7687, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaafd6579-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaafd657a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaafd657b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4687"},"text":"section 4687 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “921(a)(10)” for “921(10)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaafd657c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaafd657d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
