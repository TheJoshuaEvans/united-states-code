{"tag":"section","attrib":{"id":"ida8406813-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977"},"text":null,"children":[{"tag":"num","attrib":{"value":"977"},"text":"§ 977.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion of military medical and dental positions to civilian medical and dental positions: limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8406814-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in collaboration with the Secretaries of the military departments, shall establish a process to define the military medical and dental personnel requirements necessary to meet operational medical force readiness requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406815-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Relating to Conversion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A military medical or dental position within the Department of Defense may be converted to a civilian medical or dental position if the Secretary determines that the position is not necessary to meet operational medical force readiness requirements, as determined pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406816-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade or Level Converted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a conversion under subsection (b), the Secretary of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8406817-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall convert the applicable military position to a civilian position with a level of compensation commensurate with the skills and experience necessary to carry out the duties of such civilian position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8406818-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not place any limitation on the grade or level to which the military position is so converted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406819-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida840681a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military medical or dental position” means a position for the performance of health care functions within the armed forces held by a member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida840681b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “civilian medical or dental position” means a position for the performance of health care functions within the Department of Defense held by an employee of the Department or of a contractor of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida840681c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s977/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “conversion”, with respect to a military medical or dental position, means a change of the position to a civilian medical or dental position, effective as of the date of the manning authorization document of the military department making the change (through a change in designation from military to civilian in the document, the elimination of the listing of the position as a military position in the document, or through any other means indicating the change in the document or otherwise).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida840681d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s721/a/1"},"text":"Pub. L. 114–328, div. A, title VII, § 721(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2227"},"text":"130 Stat. 2227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida840681e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida840681f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8406820-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 977, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s351/a"},"text":"Pub. L. 103–160, div. A, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1626"},"text":"107 Stat. 1626","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/16"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1901"},"text":"111 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/a/6"},"text":"Pub. L. 106–65, div. A, title X, § 1066(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/770"},"text":"113 Stat. 770","children":[],"tail":", related to prohibition of assignment of active duty members to operation of commissary stores, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/e/1"},"text":"Pub. L. 108–375, div. A, title VI, § 651(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1972"},"text":"118 Stat. 1972","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 977, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342/tX/s1002/a"},"text":"Pub. L. 96–342, title X, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1119"},"text":"94 Stat. 1119","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s11/a/1"},"text":"Pub. L. 97–22, § 11(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/137"},"text":"95 Stat. 137","children":[],"tail":", provided that no one who originally enlisted after "},{"tag":"date","attrib":{"date":"1980-09-07"},"text":"Sept. 7, 1980","children":[],"tail":", in a regular armed services component and failed to serve at least 24 months of such enlistment would be eligible for Federal benefits otherwise receivable because of active service under such enlistment, except that such exclusion was not applicable to one discharged under section 1173 of chapter 61 of this title or to one later proved to be suffering from a disability resulting from an injury or disease incurred during enlistment, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/306/tIV/s408/c/1"},"text":"Pub. L. 97–306, title IV, § 408(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-14"},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1446"},"text":"96 Stat. 1446","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s5303A"},"text":"section 5303A of Title 38","children":[],"tail":", Veterans’ Benefits, and provisions set out as notes under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8406821-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8406822-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s721/a/3"},"text":"Pub. L. 114–328, div. A, title VII, § 721(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2228"},"text":"130 Stat. 2228","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tVII/s721/a/3"},"text":"“The Secretary of Defense may not carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s977/b"},"text":"section 977(b) of title 10","children":[],"tail":", United States Code, as added by paragraph (1), until the date that is 180 days after the date on which the Secretary submits the report under subsection (b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
