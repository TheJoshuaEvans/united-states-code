{"tag":"section","attrib":{"id":"ida8b2d97a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1218a"},"text":"§ 1218a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge or release from active duty: transition assistance for reserve component members injured while on active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b2d97b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Certain Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before a member of a reserve component described in subsection (b) is demobilized or separated from the armed forces, the Secretary of the military department concerned shall provide to the member the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b2d97c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the availability of care and administrative processing through community based warrior transition units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d97d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the location of the community based warrior transition unit located nearest to the permanent place of residence of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d97e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) applies to members of a reserve component who are injured while on active duty in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b2d97f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s641/a"},"text":"Pub. L. 111–84, div. A, title VI, § 641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2364"},"text":"123 Stat. 2364","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
