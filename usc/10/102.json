{"tag":"section","attrib":{"id":"ida7249798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of certain amendments on conforming changes to tables of sections, tables of contents, and similar tabular entries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7249799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automatic Execution of Conforming Changes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an amendment to a covered defense law adds a section or larger organizational unit to the covered defense law, repeals or transfers a section or larger organizational unit in the covered defense law, or amends the designation or heading of a section or larger organizational unit in the covered defense law, that amendment also shall have the effect of amending any table of sections, table of contents, or similar tabular entries in the covered defense law to alter the table to conform to the changes made by the amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida724979a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to an amendment described in such subsection when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida724979b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment or a clerical amendment enacted at the same time expressly amends a table of sections, table of contents, or similar tabular entries in the covered defense law to alter the table to conform to the changes made by the amendment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida724979c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment otherwise expressly exempts itself from the operation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida724979d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Defense Law","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered defense law” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida724979e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida724979f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" titles 32 and 37;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida72497a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any national defense authorization Act that authorizes funds to be appropriated for a fiscal year to the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida72497a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s102/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other law designated in the text thereof as a covered defense law for purposes of application of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida72497a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1081/e/1"},"text":"Pub. L. 117–263, div. A, title X, § 1081(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2798"},"text":"136 Stat. 2798","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida72497a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida72497a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida72497a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1081/e/3"},"text":"Pub. L. 117–263, div. A, title X, § 1081(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2798"},"text":"136 Stat. 2798","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tX/s1081/e/3"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s102"},"text":"Section 102 of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall apply to the amendments made by this section and other amendments made by this Act [see Tables for classification].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida72497a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination With Other Amendments Made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1081/f"},"text":"Pub. L. 117–263, div. A, title X, § 1081(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2798"},"text":"136 Stat. 2798","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tX/s1081/f"},"text":"“For purposes of applying amendments made by provisions of this Act other than this section [see Tables for classification], the amendments made by this section [enacting this section, amending sections 113, 2691, 3014, 4423, 4831, and 4833 of this title, and amending provisions set out as notes under sections 113, 391, and 2224 of this title] shall be treated as having been enacted immediately before any such amendments by other provisions of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida72497a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Elimination of Need for Certain Separate Conforming Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/s2803/b"},"text":"Pub. L. 117–263, div. B, § 2803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2970"},"text":"136 Stat. 2970","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dB/s2803/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automatic execution of conforming changes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an amendment made by a provision of this division [see Tables for classification] to a covered defense law adds a section or larger organizational unit to the covered defense law, repeals or transfers a section or larger organizational unit in the covered defense law, or amends the designation or heading of a section or larger organizational unit in the covered defense law, that amendment also shall have the effect of amending any table of sections, table of contents, or similar table of tabular entries in the covered defense law to alter the table to conform to the changes made by the amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to an amendment described in such paragraph when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment, or a separate clerical amendment enacted at the same time as the amendment, expressly amends a table of sections, table of contents, or similar table of tabular entries in the covered defense law to alter the table to conform to the changes made by the amendment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment otherwise expressly exempts itself from the operation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered defense law defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term ‘covered defense law’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" titles 10, 32, and 37 of the United States Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any national defense authorization Act or military construction authorization Act that authorizes funds to be appropriated for a fiscal year to the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other law designated in the text thereof as a covered defense law for purposes of application of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s2803/b"},"text":"section 2803(b) of Pub. L. 117–263","children":[],"tail":" enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805"},"text":"section 2805 of this title","children":[],"tail":". The "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s2803/b"},"text":"section 2803(b) of Pub. L. 117–263","children":[],"tail":" set out above probably should have been numbered section 2003(b) as it followed "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s2002"},"text":"section 2002 of Pub. L. 117–263","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dB/s2003/b"},"text":"Pub. L. 117–81, div. B, § 2003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2162"},"text":"135 Stat. 2162","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
