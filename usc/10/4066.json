{"tag":"section","attrib":{"id":"idaa56769e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066"},"text":null,"children":[{"tag":"num","attrib":{"value":"4066"},"text":"§ 4066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global Research Watch Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa56769f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Research and Engineering shall carry out a Global Research Watch program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5676a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the program are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5676a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To monitor and analyze the basic and applied research activities and capabilities of foreign nations and private sector persons in areas of military interest, including allies and competitors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide standards for comparison and comparative analysis of research capabilities of foreign nations and private sector persons in relation to the research capabilities of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist Congress and Department of Defense officials in making investment decisions for research in technical areas where the United States may not be the global leader.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify areas where significant opportunities for cooperative research may exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To coordinate and promote the international cooperative research and analysis activities of each of the armed forces and Defense Agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish and maintain an electronic database on international research capabilities, comparative assessments of capabilities, cooperative research opportunities, and ongoing cooperative programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5676a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Focus of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program shall be focused on research and technologies at a technical maturity level equivalent to Department of Defense basic and applied research programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5676a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa5676a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary shall coordinate the program with the international cooperation and analysis activities of the military departments and Defense Agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries of the military departments and the directors of the Defense Agencies shall provide the Under Secretary of Defense for Research and Engineering such assistance as the Under Secretary may require for purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa5676ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa5676ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds available to a military department for a fiscal year for monitoring or analyzing the research activities and capabilities of foreign nations may not be obligated or expended until the Under Secretary of Defense for Research and Engineering certifies to the Under Secretary of Defense for Acquisition, Technology, and Logistics that the Secretary of such military department has provided the assistance required under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa5676ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitation in subparagraph (A) shall not be construed to alter or effect the availability to a military department of funds for intelligence activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5676ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classification of Database Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information in electronic databases of the Global Research Watch program shall be maintained in unclassified form and, as determined necessary by the Under Secretary of Defense for Research and Engineering, in classified form in such databases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa5676af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4066/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement to carry out the program under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2035-09-30"},"text":"September 30, 2035","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa5676b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tII/s231/a"},"text":"Pub. L. 108–136, div. A, title II, § 231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1421"},"text":"117 Stat. 1421","children":[],"tail":", § 2365; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tII/s232"},"text":"Pub. L. 109–364, div. A, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2134"},"text":"120 Stat. 2134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tII/s211"},"text":"Pub. L. 111–84, div. A, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2225"},"text":"123 Stat. 2225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s901/j/3"},"text":"Pub. L. 111–38