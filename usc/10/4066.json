n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/c/2/B/i"},"text":"Pub. L. 112–239, § 1076(c)(2)(B)(i)","children":[],"tail":", inserted “of Defense for Research and Engineering” after “The Assistant Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/c/2/B/ii"},"text":"Pub. L. 112–239, § 1076(c)(2)(B)(ii)","children":[],"tail":", substituted “Assistant Secretary” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/j/3/A"},"text":"Pub. L. 111–383, § 901(j)(3)(A)","children":[],"tail":", substituted “Assistant Secretary” for “Director of Defense Research and Engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/j/3/B"},"text":"Pub. L. 111–383, § 901(j)(3)(B)","children":[],"tail":", substituted “Assistant Secretary” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/j/3/C"},"text":"Pub. L. 111–383, § 901(j)(3)(C)","children":[],"tail":", substituted “Assistant Secretary of Defense for Research and Engineering” for “Director of Defense Research and Engineering” and “Assistant Secretary may” for “Director may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/j/3/D"},"text":"Pub. L. 111–383, § 901(j)(3)(D)","children":[],"tail":", substituted “Assistant Secretary” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s211/a"},"text":"Pub. L. 111–84, § 211(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":