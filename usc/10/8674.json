{"tag":"section","attrib":{"id":"idab3b7fab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674"},"text":null,"children":[{"tag":"num","attrib":{"value":"8674"},"text":"§ 8674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of vessels; striking of vessels from Naval Vessel Register","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3b7fac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Boards of Officers To Examine Naval Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b7fad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy shall designate boards of naval officers to examine naval vessels, including unfinished vessels, for the purpose of making a recommendation to the Secretary as to which vessels, if any, should be stricken from the Naval Vessel Register. Each vessel shall be examined at least once every three years if practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b7fae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3b7faf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), any naval vessel examined under this section on or after ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", shall be examined with minimal notice provided to the crew of the vessel."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3b7fb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) shall not apply to a vessel undergoing necessary trials before acceptance into the fleet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b7fb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions by Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A board designated under subsection (a) shall submit to the Secretary in writing its recommendations as to which vessels, if any, among those it examined should be stricken from the Naval Vessel Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b7fb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary concurs with a recommendation by a board that a vessel should be stricken from the Naval Vessel Register, the Secretary shall strike the name of that vessel from the Naval Vessel Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3b7fb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3b7fb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than March 1 each year, the board designated under subsection (a) shall provide to the congressional defense committees a briefing and submit to such committees a report regarding the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3b7fb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overall narrative summary of the material readiness of Navy ships as compared to established material requirements standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3b7fb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The overall number and types of vessels inspected during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3b7fb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For in-service vessels, material readiness trends by inspected functional area as compared to the previous five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3b7fb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under this subsection shall be submitted in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3b7fb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a classified form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3b7fba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8674/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unclassified form that is releasable to the public without further redaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3b7fbb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s824/b"},"text":"Pub. L. 103–160, div. A, title VIII, § 824(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1708"},"text":"107 Stat. 1708","children":[],"tail":", § 7304; renumbered § 8674 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tIII/s322"},"text":"Pub. L. 115–232, div. A, title III, § 322","children":[],"tail":", title VIII, § 807(d)(2), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1719"},"text":"132 Stat. 1719","children":[],"tail":", 1836; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s362"},"text":"Pub. L. 117–81, div. A, title III, § 362","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1660"},"text":"135 Stat. 1660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3b7fbc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3b7fbd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3b7fbe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s362/1"},"text":"Pub. L. 117–81, § 362(1)","children":[],"tail":", substituted “provide to the congressional defense committees a briefing and submit to such committees a report regarding” for “submit to the congressional defense committees a report setting forth” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s362/2"},"text":"Pub. L. 117–81, § 362(2)","children":[],"tail":", substituted “in—” for “in an unclassified form that is releasable to the public without further redaction.” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s362/3"},"text":"Pub. L. 117–81, § 362(3)","children":[],"tail":", struck out par. (3) which read as follows: “No report shall be required under this subsection after "},{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/2"},"text":"Pub. L. 115–232, § 807(d)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7304"},"text":"section 7304 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s322/a"},"text":"Pub. L. 115–232, § 322(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s322/b"},"text":"Pub. L. 115–232, § 322(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab3b7fbf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3b7fc0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/d/2"},"text":"section 807(d)(2) of Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}