{"tag":"section","attrib":{"id":"idabb03b0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112"},"text":null,"children":[{"tag":"num","attrib":{"value":"14112"},"text":"§ 14112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of names of officers selected","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb03b0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Dissemination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The names of the officers recommended for promotion in the report of a selection board shall be disseminated to the armed force concerned as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb03b10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of officers recommended for promotion to a grade below brigadier general or rear admiral (lower half), such names may be disseminated upon, or at any time after, the transmittal of the report to the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03b11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of officers recommended for promotion to a grade above colonel or, in the case of the Navy, captain, such names may be disseminated upon, or at any time after, the approval of the report by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03b12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of officers whose names have not been sooner disseminated, such names shall be promptly disseminated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb03b13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon confirmation of the promotion of the officers by the Senate (in the case of promotions required to be submitted to the Senate for confirmation); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb03b14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the approval of the report by the President (in the case of promotions not required to be submitted to the Senate for confirmation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb03b15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Names Not Disseminated","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A list of names of officers disseminated under subsection (a) may not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb03b16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any name removed by the President from the report of the selection board containing that name, if dissemination is under the authority of paragraph (2) or (3)(B) of that subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03b17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of any officer whose promotion the Senate failed to confirm, if dissemination is under the authority of paragraph (3)(A) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb03b18-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2930"},"text":"108 Stat. 2930","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 503(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–101.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb03b19-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb03b1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb03b1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5898/d"},"text":"section 5898(d) of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/b/2"},"text":"Pub. L. 103–337, § 1629(b)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb03b1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended text generally. Prior to amendment, text read as follows: “Upon approval by the President of the report of a promotion board, the names of the officers recommended for promotion by the promotion board (other than any name removed by the President) may be disseminated to the armed force concerned. If those names have not been sooner disseminated, those names (other than the name of any officer whose promotion the Senate failed to confirm) shall be promptly disseminated to the armed force concerned upon confirmation by the Senate.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb03b1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb03b1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
