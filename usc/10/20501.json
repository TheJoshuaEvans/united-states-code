{"tag":"section","attrib":{"id":"idabccea66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501"},"text":null,"children":[{"tag":"num","attrib":{"value":"20501"},"text":"§ 20501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish procedures to consider the separation of officers for substandard performance of duty and for certain other reasons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for Review of Record of Officers Relating to Standards of Performance of Duty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force shall prescribe, by regulation, procedures for the review at any time of the record of any commissioned officer (other than a retired officer) of the Space Force in a space force active status to determine whether the officer shall be required, because of a reason stated in paragraph (2), to show cause for the officer’s retention in a space force active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The reasons referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabccea6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officer’s performance of duty has fallen below standards prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officer has failed to satisfy the standards and qualifications established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20403"},"text":"section 20403 of this title","children":[],"tail":" by the Secretary of the Air Force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for Review of Record of Officers Relating to Certain Other Reasons.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force shall prescribe, by regulation, procedures for the review at any time of the record of any commissioned officer (other than a retired officer) of the Space Force in a space force active status to determine whether the officer should be required, because of a reason stated in paragraph (2), to show cause for the officer’s retention in a space force active status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The reasons referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabccea6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Misconduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Moral or professional dereliction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabccea71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officer’s retention is not clearly consistent with the interests of national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary of Defense Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations prescribed by the Secretary of the Air Force under this section are subject to such limitations as the Secretary of Defense may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea73-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/659"},"text":"137 Stat. 659","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
