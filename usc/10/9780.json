{"tag":"section","attrib":{"id":"idab855a38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9780"},"text":null,"children":[{"tag":"num","attrib":{"value":"9780"},"text":"§ 9780.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of buildings in District of Columbia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab855a39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9780/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of war or when war is imminent, the Secretary of the Air Force may acquire by lease any building, or part of a building, in the District of Columbia that may be needed for military purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9780/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At any time, the Secretary may, for the purposes of the Department of the Air Force, requisition the use and take possession of any building or space in any building, and its appurtenances, in the District of Columbia, other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab855a3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9780/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dwelling house occupied as such;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9780/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a building occupied by any other agency of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9780/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" space in such a dwelling house or building.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall determine, and pay out of funds appropriated for the payment of rent by the Department of the Air Force, just compensation for that use. If the amount of the compensation is not satisfactory to the person entitled to it, the Secretary shall pay 75 percent of it to that person, and the claimant is entitled to recover by action against the United States an additional amount that, when added to the amount paid by the Secretary, is determined by the court to be just compensation for that use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab855a3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/203/A"},"text":"Pub. L. 85–861, § 1(203)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1542"},"text":"72 Stat. 1542","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab855a3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab855a40-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab855a41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9780(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9780(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40:37.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"40:41.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":" (3d proviso under “Barracks and Quarters”), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/861"},"text":"40 Stat. 861","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-08/ch139"},"text":"July 8, 1918, ch. 139","children":[],"tail":" (2d par. under “War Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/826"},"text":"40 Stat. 826","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “may acquire by lease” are substituted for the words “is authorized, in his discretion, to rent or lease”. The word “needed” is substituted for the word “required”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “At any time” are inserted for clarity. The word “may” is substituted for the words “is authorized”. The word “agency” is substituted for the word “branch”. Clause (3) is inserted for clarity. The word “determine” is substituted for the word “ascertain”. The words “out of funds appropriated for the payment of rent by” are substituted for the words “within the limits of the appropriations for rent made by any act making appropriations for”. The word “is” is substituted for the word “be”. The words “so ascertained” and “in the manner provided by sections 41(20) and 250 of Title 28” are omitted as surplusage, since those sections were repealed in 1948 and replaced by sections 1346, 1491, 1496, 1501, 1503, 2401, 2402, and 2501 of that title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
