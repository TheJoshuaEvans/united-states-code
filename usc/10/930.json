{"tag":"section","attrib":{"id":"ida82fc674-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930"},"text":null,"children":[{"tag":"num","attrib":{"value":"930"},"text":"§ 930.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 130. Stalking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc675-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc676-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who wrongfully engages in a course of conduct directed at a specific person that would cause a reasonable person to fear death or bodily harm, including sexual assault, to himself or herself, to a member of his or her immediate family, to his or her intimate partner, or to his or her dating partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc677-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has knowledge, or should have knowledge, that the specific person will be placed in reasonable fear of death or bodily harm, including sexual assault, to himself or herself, to a member of his or her immediate family, to his or her intimate partner, or to his or her dating partner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc678-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose conduct induces reasonable fear in the specific person of death or bodily harm, including sexual assault, to himself or herself, to a member of his or her immediate family, to his or her intimate partner, or to his or her dating partner;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of stalking and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc679-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc67a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “conduct” means conduct of any kind, including use of surveillance, the mails, an interactive computer service, an electronic communication service, or an electronic communication system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc67b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “course of conduct” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc67c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a repeated maintenance of visual or physical proximity to a specific person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc67d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a repeated conveyance of verbal threat, written threats, or threats implied by conduct, or a combination of such threats, directed at or toward a specific person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc67e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pattern of conduct composed of repeated acts evidencing a continuity of purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc67f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “dating partner”, in the case of a specific person, means a person who is or has been in a social relationship of a romantic or intimate nature with such specific person based on a consideration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc680-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc681-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc682-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of interaction between the persons involved in the relationship; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc683-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of physical intimacy or sexual contact between the persons involved in the relationship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc684-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “repeated”, with respect to conduct, means two or more occasions of such conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc685-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “immediate family”, in the case of a specific person, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc686-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that person’s spouse, parent, brother or sister, child, or other person to whom he or she stands in loco parentis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc687-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person living in his or her household and related to him or her by blood or marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc688-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “intimate partner”, in the case of a specific person, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc689-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former spouse of the specific person, a person who shares a child in common with the specific person, or a person who cohabits with or has cohabited as a spouse with the specific person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc68a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s930/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who has been in a social relationship of a romantic or intimate nature with the specific person, as determined by the length of the relationship, the type of relationship, and the frequency of interaction between the persons involved in the relationship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc68b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s551/a/1"},"text":"Pub. L. 109–163, div. A, title V, § 551(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3256"},"text":"119 Stat. 3256","children":[],"tail":", § 920a; renumbered § 930 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX"},"text":"Pub. L. 114–328, div. E, title LX","children":[],"tail":", §§ 5401(11), 5443, "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2939"},"text":"130 Stat. 2939","children":[],"tail":", 2955; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s531/d/2"},"text":"Pub. L. 118–31, div. A, title V, § 531(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/259"},"text":"137 Stat. 259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82fc68c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida82fc68d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida82fc68e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 930 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s929a"},"text":"section 929a of this title","children":[],"tail":" and subsequently omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida82fc68f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s531/d/2/A"},"text":"Pub. L. 118–31, § 531(d)(2)(A)","children":[],"tail":", substituted “to his or her intimate partner, or to his or her dating partner” for “or to his or her intimate partner” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s531/d/2/B"},"text":"Pub. L. 118–31, § 531(d)(2)(B)","children":[],"tail":", added par. (3) and redesignated former pars. (3) to (5) as (4) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section set out elements of stalking and defined terms."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5401/11"},"text":"Pub. L. 114–328, § 5401(11)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s920a"},"text":"section 920a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida82fc690-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida82fc691-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida82fc692-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s551/b"},"text":"Pub. L. 109–163, div. A, title V, § 551(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3256"},"text":"119 Stat. 3256","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tV/s551/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s920a"},"text":"Section 920a of title 10","children":[],"tail":", United States Code (article 120a of the Uniform Code of Military Justice), as added by subsection (a), applies to offenses committed after the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
