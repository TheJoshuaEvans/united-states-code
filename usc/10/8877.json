n":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1152"},"text":"34 U.S.C. 1152","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4644.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1152"},"text":"34 U.S.C. 1152","children":[],"tail":" and this section reflect modifications of R.S. 4644 effected by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-05-28/ch252/s6"},"text":"Act of May 28, 1896, ch. 252, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/179"},"text":"29 Stat. 179","children":[],"tail":", which provided for fixed annual salaries for United States attorneys and marshals;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch413/s13"},"text":"Act of March 3, 1899, ch. 413, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1007"},"text":"30 Stat. 1007","children":[],"tail":", which repealed all laws authorizing distribution of prize proceeds to captors;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-02-26/ch49/s1"},"text":"Act of February 26, 1919, ch. 49, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1182"},"text":"40 Stat. 1182","children":[],"tail":", which provided that clerks of United States district courts should receive fixed annual salaries; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(4) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch214"},"text":"Act of May 29, 1920, ch. 214","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/654"},"text":"41 Stat. 654","children":[],"tail":", which abolished the offices of assistant treasurers and distributed their functions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab534d62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab534d63-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7677"},"text":"section 7677 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab534d64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab534d65-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
