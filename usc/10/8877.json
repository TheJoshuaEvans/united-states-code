{"tag":"section","attrib":{"id":"idab534d56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877"},"text":null,"children":[{"tag":"num","attrib":{"value":"8877"},"text":"§ 8877.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts of clerks of district courts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab534d57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The clerk of each district court, for the purpose of the final decree in each prize cause, shall keep account of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab534d58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount deposited with the Treasurer or public depositary, subject to the order of the court in the cause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab534d59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts ordered to be paid therefrom as costs and charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab534d5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clerk shall draw the orders of the court for the payment of costs and allowances and for the disposition of the residue of the prize fund in each cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab534d5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The clerk shall send to the Secretary of the Treasury and the Secretary of the Navy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab534d5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of final decrees in prize causes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab534d5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8877/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a semi-annual statement of the amounts allowed by the court, and ordered to be paid, within the preceding six months to the prize commissioners and special prize commissioners for their services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab534d5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/482"},"text":"70A Stat. 482","children":[],"tail":", § 7677; renumbered § 8877, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab534d5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"hist