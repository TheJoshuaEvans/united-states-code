{"tag":"section","attrib":{"id":"idaad01487-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354"},"text":null,"children":[{"tag":"num","attrib":{"value":"6354"},"text":"§ 6354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program relating to use of proceeds of disposal or utilization of certain department of energy assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad01488-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section is to encourage the Secretary of Energy to dispose of or otherwise utilize certain assets of the Department of Energy by making available to the Secretary the proceeds of such disposal or utilization for purposes of defraying the costs of such disposal or utilization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01489-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Proceeds to Defray Costs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad0148a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", the Secretary may retain from the proceeds of the sale, lease, or disposal of an asset under subsection (c) an amount equal to the cost of the sale, lease, or disposal of the asset. The Secretary shall utilize amounts retained under this paragraph to defray the cost of the sale, lease, or disposal."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad0148b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the cost of a sale, lease, or disposal shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad0148c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of administering the sale, lease, or disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad0148d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of recovering or preparing the asset concerned for the sale, lease, or disposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad0148e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other cost associated with the sale, lease, or disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad0148f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Transactions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) applies to the following transactions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad01490-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sale of heavy water at the Savannah River Site, South Carolina, that is under the jurisdiction of the Defense Environmental Management Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01491-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sale of precious metals that are under the jurisdiction of the Defense Environmental Management Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01492-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lease of buildings and other facilities located at the Hanford Reservation, Washington, that are under the jurisdiction of the Defense Environmental Management Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01493-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lease of buildings and other facilities located at the Savannah River Site that are under the jurisdiction of the Defense Environmental Management Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01494-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The disposal of equipment and other personal property located at the Rocky Flats Defense Environmental Technology Site, Colorado, that is under the jurisdiction of the Defense Environmental Management Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01495-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The disposal of materials at the National Electronics Recycling Center, Oak Ridge, Tennessee that are under the jurisdiction of the Defense Environmental Management Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01496-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Disposal Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to limit the application of subchapter II of chapter 5 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s549"},"text":"section 549 of title 40","children":[],"tail":" to the disposal of equipment and other personal property covered by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad01497-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1454"},"text":"139 Stat. 1454","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad01498-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad01499-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad0149a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2813"},"text":"section 2813 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad0149b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
