{"tag":"section","attrib":{"id":"idabb7675c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14515"},"text":null,"children":[{"tag":"num","attrib":{"value":"14515"},"text":"§ 14515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge or retirement for age","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each reserve officer of the Army, Navy, Air Force, or Marine Corps who is in an active status or on an inactive-status list and who reaches the maximum age specified in section 14509, 14510, 14511, or 14512 of this title for the officer’s grade or position shall (unless the officer is sooner separated or the officer’s separation is deferred or the officer is continued in an active status under another provision of law) not later than the last day of the month in which the officer reaches that maximum age—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb7675d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14515/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred to the Retired Reserve if the officer is qualified for such transfer and does not request (in accordance with regulations prescribed by the Secretary concerned) not to be transferred to the Retired Reserve; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb7675e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14515/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged from the officer’s reserve appointment if the officer is not qualified for transfer to the Retired Reserve or has requested (in accordance with regulations prescribed by the Secretary concerned) not to be so transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb7675f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2954"},"text":"108 Stat. 2954","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/31"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s517/d"},"text":"Pub. L. 107–107, div. A, title V, § 517(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1095"},"text":"115 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb76760-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb76761-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb76762-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/d/1"},"text":"Pub. L. 107–107, § 517(d)(1)","children":[],"tail":", substituted “if the officer is qualified for such transfer and does not request (in accordance with regulations prescribed by the Secretary concerned) not to be transferred to the Retired Reserve” for “, if the officer is qualified and applies for such transfer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/d/2"},"text":"Pub. L. 107–107, § 517(d)(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “if the officer is not qualified or does not apply for transfer to the Retired Reserve, be discharged from the officer’s reserve appointment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “inactive-status” for “inactive status” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb76763-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb76764-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" effective on the first day of the first month that begins more than 180 days after "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s517/g"},"text":"section 517(g) of Pub. L. 107–107","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10154"},"text":"section 10154 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note"