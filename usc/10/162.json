{"tag":"section","attrib":{"id":"ida773544b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162"},"text":null,"children":[{"tag":"num","attrib":{"value":"162"},"text":"§ 162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combatant commands: assigned forces; chain of command","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida773544c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of Forces","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida773544d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As directed by the Secretary of Defense, the Secretaries of the military departments shall assign specified forces under their jurisdiction to unified and specified combatant commands or to the United States element of the North American Aerospace Defense Command to perform missions assigned to those commands. The Secretary of Defense shall ensure that such assignments are consistent with the force structure prescribed by the President for each combatant command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida773544e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A force not assigned to a combatant command or to the United States element of the North American Aerospace Defense Command under paragraph (1) shall remain assigned to the military department concerned for carrying out the responsibilities of the Secretary of the military department concerned as specified in section 7013, 8013, or 9013 of this title, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida773544f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A force assigned to a combatant command or to the United States element of the North American Aerospace Defense Command under this section may be transferred from the command to which it is assigned only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7735450-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by authority of the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7735451-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under procedures prescribed by the Secretary and approved by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7735452-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise directed by the Secretary of Defense, all forces assigned to a unified combatant command shall be under the command of the commander of that command. The preceding sentence applies to forces assigned to a specified combatant command only as prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7735453-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chain of Command","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless otherwise directed by the President, the chain of command to a unified or specified combatant command runs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7735454-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the President to the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7735455-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the Secretary of Defense to the commander of the combatant command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7735456-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s211/a"},"text":"Pub. L. 99–433, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1012"},"text":"100 Stat. 1012","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXIII/s1313"},"text":"Pub. L. 100–180, div. A, title XIII, § 1313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1175"},"text":"101 Stat. 1175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVII/s711"},"text":"Pub. L. 100–456, div. A, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1997"},"text":"102 Stat. 1997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1073/a"},"text":"Pub. L. 104–201, div. A, title X, § 1073(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2657"},"text":"110 Stat. 2657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s924"},"text":"Pub. L. 114–328, div. A, title IX, § 924","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2358"},"text":"130 Stat. 2358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/9"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1594"},"text":"131 Stat. 1594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7735457-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7735458-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7735459-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7013, 8013, or 9013” for “section 3013, 5013, or 8013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out comma after “command of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s924/1"},"text":"Pub. L. 114–328, § 924(1)","children":[],"tail":", substituted “As directed by the Secretary of Defense” for “Except as provided in paragraph (2)” and “specified forces” for “all forces” and struck out “Such assignments shall be made as directed by the Secretary of Defense, including direction as to the command to which forces are to be assigned.” before “The Secretary of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s924/2"},"text":"Pub. L. 114–328, § 924(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “Except as otherwise directed by the Secretary of Defense, forces to be assigned by the Secretaries of the military departments to the combatant commands or to the United States element of the North American Aerospace Defense Command under paragraph (1) do not include forces assigned to carry out functions of the Secretary of a military department listed in sections 3013(b), 5013(b), and 8013(b) of this title or forces assigned to multinational peacekeeping organizations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s924/3/B"},"text":"Pub. L. 114–328, § 924(3)(B)","children":[],"tail":", struck out “assigned to, and” before “under the command”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s924/3/A"},"text":"Pub. L. 114–328, § 924(3)(A)","children":[],"tail":", which directed striking out “operating with the geographic area”, was executed by striking out “operating within the geographic area” after “all forces” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “North American Aerospace Defense Command” for “North American Air Defense Command”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" inserted “or to the United States element of the North American Air Defense Command”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" inserted before period at end “or forces assigned to multinational peacekeeping organizations”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida773545a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida773545b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida773545c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Assignment of Forces to Combatant Commands","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s214/a"},"text":"Pub. L. 99–433, title II, § 214(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1018"},"text":"100 Stat. 1018","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s162/a"},"text":"section 162(a) of this title","children":[],"tail":" shall be implemented not later than 90 days after "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
