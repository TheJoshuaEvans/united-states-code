{"tag":"section","attrib":{"id":"ida7f8d81c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657"},"text":null,"children":[{"tag":"num","attrib":{"value":"657"},"text":"§ 657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on service in the armed forces by individuals convicted of certain sexual offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f8d81d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Commissioning or Enlistment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who has been convicted of an offense specified in subsection (b) under Federal or State law may not be processed for commissioning or permitted to enlist in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f8d81e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An offense specified in this subsection is any felony offense as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f8d81f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rape or sexual assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d820-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Forcible sodomy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d821-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f8d822-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s657/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An attempt to commit an offense specified in paragraph (1) through (3), as punishable under applicable Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f8d823-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1711/a/1"},"text":"Pub. L. 113–66, div. A, title XVII, § 1711(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/962"},"text":"127 Stat. 962","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
