{"tag":"section","attrib":{"id":"ida836cc5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949h"},"text":null,"children":[{"tag":"num","attrib":{"value":"949h"},"text":"§ 949h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former jeopardy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cc60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may, without the person’s consent, be tried by a military commission under this chapter a second time for the same offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Trial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No proceeding in which the accused has been found guilty by military commission under this chapter upon any charge or specification is a trial in the sense of this section until the finding of guilty has become final after review of the case has been fully completed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836cc62-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2587"},"text":"123 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836cc63-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836cc64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836cc65-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949h, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2614"},"text":"120 Stat. 2614","children":[],"tail":", related to former jeopardy, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
