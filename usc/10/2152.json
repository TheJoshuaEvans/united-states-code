{"tag":"section","attrib":{"id":"ida93130d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2152"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152"},"text":"§ 2152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint professional military education: general requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93130d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall implement a comprehensive framework for the joint professional military education of officers, including officers nominated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s661"},"text":"section 661 of this title","children":[],"tail":" for the joint specialty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93130d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Military Education Schools","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, with the advice and assistance of the Chairman of the Joint Chiefs of Staff, shall periodically review and revise the curriculum of each school of the National Defense University (and of any other joint professional military education school) to enhance the education and training of officers in joint matters. The Secretary shall require such schools to maintain rigorous standards for the military education of officers with the joint specialty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93130d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2152/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Professional Military Education Schools","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall require that each Department of Defense school concerned with professional military education periodically review and revise its curriculum for senior and intermediate grade officers in order to strengthen the focus on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93130d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2152/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93130d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2152/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing officers for joint duty assignments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93130d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s532/a/2"},"text":"Pub. L. 108–375, div. A, title V, § 532(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1897"},"text":"118 Stat. 1897","children":[],"tail":", 1900.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93130d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93130d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida93130d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s663"},"text":"section 663 of this title","children":[],"tail":", which were transferred to this section by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/b"},"text":"Pub. L. 108–375, § 532(b)","children":[],"tail":", were based on "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIV/s401/a"},"text":"Pub. L. 99–433, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1027"},"text":"100 Stat. 1027","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93130da-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s532/b"},"text":"Pub. L. 108–375, § 532(b)","children":[],"tail":", transferred subsecs. (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s663"},"text":"section 663 of this title","children":[],"tail":" to end of this section. See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
