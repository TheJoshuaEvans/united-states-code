{"tag":"section","attrib":{"id":"idaa3ea92a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862"},"text":null,"children":[{"tag":"num","attrib":{"value":"3862"},"text":"§ 3862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for equitable adjustment or other relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa3ea92b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A request for equitable adjustment to contract terms or request for relief under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/804"},"text":"Public Law 85–804","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1431"},"text":"50 U.S.C. 1431","children":[],"tail":" et seq.) that exceeds the simplified acquisition threshold may not be paid unless a person authorized to certify the request on behalf of the contractor certifies, at the time the request is submitted, that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea92c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request is made in good faith, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea92d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supporting data are accurate and complete to the best of that person’s knowledge and belief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea92e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on Legislative Payment of Claims","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a contract of an agency named in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":", no provision of a law enacted after "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":", that directs the payment of a particular claim under such contract, a particular request for equitable adjustment to any term of such contract, or a particular request for relief under "},{"tag":"ref","attrib":{"href":"/us/pl/85/804"},"text":"Public Law 85–804","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1431"},"text":"50 U.S.C. 1431","children":[],"tail":" et seq.) regarding such contract may be implemented unless such provision of law—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea92f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically refers to this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea930-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically states that this subsection does not apply with respect to the payment directed by that provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea931-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certain Clauses Implementing Executive Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The unilateral insertion of a covered clause into an existing Department of Defense contract, order, or other transaction by a contracting officer shall be treated as a change directed by the contracting officer pursuant to, and subject to, the Changes clause of the underlying contract, order, or other transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea932-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea933-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “simplified acquisition threshold” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea934-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Changes clause” means the clause described in part 52.243–4 of the Federal Acquisition Regulation or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea935-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3862/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered clause” means any clause implementing the requirements of an Executive order issued by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa3ea936-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2301/a"},"text":"Pub. L. 103–355, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3320"},"text":"108 Stat. 3320","children":[],"tail":", § 2410; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/27"},"text":"Pub. L. 111–350, § 5(b)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3845"},"text":"124 Stat. 3845","children":[],"tail":"; renumbered § 3862 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1836(b), 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4241"},"text":"134 Stat. 4241","children":[],"tail":", 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/d/6"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2136"},"text":"135 Stat. 2136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s805/a"},"text":"Pub. L. 117–263, div. A, title VIII, § 805(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2701"},"text":"136 Stat. 2701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa3ea937-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa3ea938-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa3ea939-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/804"},"text":"Public Law 85–804","children":[],"tail":", referred to in subsecs. (a) and (b), is "},{"tag":"ref","attrib":{"href":"/us/pl/85/804"},"text":"Pub. L. 85–804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/972"},"text":"72 Stat. 972","children":[],"tail":", which is classified generally to chapter 29 (§ 1431 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa3ea93a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s805/a/1"},"text":"Pub. L. 117–263, § 805(a)(1)","children":[],"tail":", struck out “: certification” after “relief” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s805/a/3"},"text":"Pub. L. 117–263, § 805(a)(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s805/a/2"},"text":"Pub. L. 117–263, § 805(a)(2)","children":[],"tail":", (4), redesignated subsec. (c) as (d), substituted “Definitions” for “Definition” in heading, substituted “In this section:” for “In this section,”, designated remainder of existing provisions as par. (1), substituted “The term” for “the term”, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1836/b"},"text":"Pub. L. 116–283, § 1836(b)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2410"},"text":"section 2410 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “section 3063” for “section 2303(a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", which directed that each reference in the text of title 10 to a section that was redesignated by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", as such section was in effect before the redesignation, be amended by striking such reference and inserting a reference to the appropriate redesignated section, was not executed with respect to “section 2303(a)”, which was redesignated as multiple sections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"” for “section 4(11) of the Office of Federal Procurement Policy Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa3ea93b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa3ea93c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" to take effect immediately after the amendments made by title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" have taken effect, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/3"},"text":"section 1701(a)(3) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa3ea93d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":", set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3ea93e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conforming Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s805/c"},"text":"Pub. L. 117–263, div. A, title VIII, § 805(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2702"},"text":"136 Stat. 2702","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVIII/s805/c"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary of Defense shall revise the Department of Defense Supplement to the Federal Acquisition Regulation to implement the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3862"},"text":"section 3862 of title 10","children":[],"tail":", United States Code, as amended by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3ea93f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conforming Policy Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s805/d"},"text":"Pub. L. 117–263, div. A, title VIII, § 805(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2702"},"text":"136 Stat. 2702","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVIII/s805/d"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary of Defense shall revise applicable policy guidance on other transactions to implement the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3862"},"text":"section 3862 of title 10","children":[],"tail":", United States Code, as amended by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
