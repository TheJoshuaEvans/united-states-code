{"tag":"section","attrib":{"id":"ida90195b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612"},"text":null,"children":[{"tag":"num","attrib":{"value":"1612"},"text":"§ 1612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit system principles and civil service protections: applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90195b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Merit System Principles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2301"},"text":"Section 2301 of title 5","children":[],"tail":" shall apply to the exercise of authority under this subchapter (other than sections 1605 and 1611)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Service Protections","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90195b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, in the case of a position established under authority other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1601/a/1"},"text":"section 1601(a)(1) of this title","children":[],"tail":" that is reestablished as an excepted service position under that section, the provisions of law referred to in paragraph (2) applied to the person serving in that position immediately before the position is so reestablished and such provisions of law would not otherwise apply to the person while serving in the position as so reestablished, then such provisions of law shall, subject to paragraph (3), continue to apply to the person with respect to service in that position for as long as the person continues to serve in the position without a break in service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of law referred to in paragraph (1) are the following provisions of title 5:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90195b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 2302, relating to prohibited personnel practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 75, relating to adverse actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90195ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90195bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of chapter 75 of title 5, an appeal of an adverse action by an individual employee covered by paragraph (1) shall be determined within the Department of Defense if the employee so elects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90195bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1612/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe the procedures for initiating and determining appeals of adverse actions pursuant to elections made under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90195bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/d"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2750"},"text":"110 Stat. 2750","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90195be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90195bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida90195c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
