{"tag":"section","attrib":{"id":"idaad014d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6361"},"text":null,"children":[{"tag":"num","attrib":{"value":"6361"},"text":"§ 6361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs of operation and maintenance of infrastructure at Nevada National Security Site","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":" Notwithstanding any other provision of law and effective as of ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", the costs associated with operating and maintaining the infrastructure at the Nevada National Security Site, Nevada, with respect to any activities initiated at the site after that date by the Department of Defense pursuant to a work-for-others agreement may be paid for from funds authorized to be appropriated to the Department of Energy for activities at the Nevada National Security Site."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaad014d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1457"},"text":"139 Stat. 1457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad014d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad014d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad014d