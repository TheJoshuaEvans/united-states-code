{"tag":"section","attrib":{"id":"ida7ea7fa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s617"},"text":null,"children":[{"tag":"num","attrib":{"value":"617"},"text":"§ 617.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of selection boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7ea7fa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s617/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" shall submit to the Secretary of the military department concerned a written report, signed by each member of the board, containing a list of the names of the officers it recommends for promotion and certifying (1) that the board has carefully considered the record of each officer whose name was furnished to it under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s615"},"text":"section 615 of this title","children":[],"tail":", and (2) that, in the opinion of a majority of the members of the board, the officers recommended for promotion by the board are best qualified for promotion to meet the needs of the armed force concerned (as noted in the guidelines or information furnished the board under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s615/b"},"text":"section 615(b) of this title","children":[],"tail":") among those officers whose names were furnished to the selection board."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ea7fa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s617/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" shall include in its report to the Secretary concerned the name of any regular or reserve officer before it for consideration for promotion whose record, in the opinion of a majority of the members of the board, indicates that the officer should be required under chapter 60 or 1411 of this title to show cause for his retention on active duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ea7faa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s617/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" shall include in its report to the Secretary concerned the name of any officer considered and not recommended for promotion by the board who submitted to the board a request not to be selected for promotion or who otherwise directly caused his nonselection through written communication to the Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s614/b"},"text":"section 614(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ea7fab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s617/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s611/a"},"text":"section 611(a) of this title","children":[],"tail":" shall, when authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s616/h"},"text":"section 616(h) of this title","children":[],"tail":", include in its report to the Secretary concerned the names of those officers recommended by the board to be placed higher on the promotion list and the order in which the board recommends that those officers should be placed on the list."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7ea7fac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2853"},"text":"94 Stat. 2853","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tV/s501/c"},"text":"Pub. L. 100–456, div. A, title V, § 501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1966"},"text":"102 Stat. 1966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/8"},"text":"Pub. L. 102–484, div. A, title X, § 1052(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2499"},"text":"106 Stat. 2499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1623"},"text":"Pub. L. 103–337, div. A, title XVI, § 1623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2961"},"text":"108 Stat. 2961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s502/b"},"text":"Pub. L. 105–261, div. A, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2003"},"text":"112 Stat. 2003","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s503/a"},"text":"Pub. L. 106–65, div. A, title V, § 503(