{"tag":"section","attrib":{"id":"idabc82f99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20202"},"text":null,"children":[{"tag":"num","attrib":{"value":"20202"},"text":"§ 20202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original appointments: qualifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An original appointment as a commissioned officer in the Space Force may be given only to a person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 18 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20202/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has such other physical, mental, moral, professional, and age qualifications as the Secretary of the Air Force may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who is otherwise qualified, but who has a physical condition that the Secretary of the Air Force determines will not interfere with the performance of the duties to which that person may be assigned, may be appointed as an officer in the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/632"},"text":"137 Stat. 632","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
