{"tag":"section","attrib":{"id":"idaa377cf5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774"},"text":null,"children":[{"tag":"num","attrib":{"value":"3774"},"text":"§ 3774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major weapon systems and subsystems: long-term technical data needs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa377cf6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments and Acquisitions Strategies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377cf7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall require program managers for major weapon systems and subsystems of major weapon systems to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377cf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the long-term technical data needs of such systems and subsystems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377cf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish corresponding acquisition strategies that provide for technical data rights needed to sustain such systems and subsystems over their life cycle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such strategies may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377cfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of maintenance capabilities within the Department of Defense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377cfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competition for contracts for sustainment of such systems or subsystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377cfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Relating to Assessments and Acquisition Strategies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assessments and corresponding acquisition strategies developed under subsection (a) with respect to a weapon system or subsystem shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377cfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed before issuance of a contract solicitation for the weapon system or subsystem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the merits of including a priced contract option for the future delivery of technical data that were not acquired upon initial contract award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the potential for changes in the sustainment plan over the life cycle of the weapon system or subsystem; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to weapon systems and subsystems that are to be supported by performance-based logistics arrangements as well as to weapons systems and subsystems that are to be supported by other sustainment approaches.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377d02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference for Specially Negotiated Licenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377d03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall, to the maximum extent practicable, negotiate and enter into a contract with a contractor for a specially negotiated license for technical data to support the product support strategy of a major weapon system or subsystem of a major weapon system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377d04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3774/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In performing the assessment and developing the corresponding strategy required under subsection (a) for such a system or subsystem, a program manager shall consider the use of specially negotiated licenses to acquire customized technical data appropriate for the particular elements of the product support strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa377d05-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1833/a/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1833(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4226"},"text":"134 Stat. 4226","children":[],"tail":", 4229.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa377d06-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa377d07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa377d08-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsecs. (a) and (b), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/1"},"text":"Pub. L. 116–283, § 1833(e)(1)","children":[],"tail":"–(4), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVIII/s802/a"},"text":"Pub. L. 109–364, div. A, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2312"},"text":"120 Stat. 2312","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (c), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/1"},"text":"Pub. L. 116–283, § 1833(e)(1)","children":[],"tail":", (5), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s835/c/2"},"text":"Pub. L. 115–91, div. A, title VIII, § 835(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1471"},"text":"131 Stat. 1471","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa377d09-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/1"},"text":"Pub. L. 116–283, § 1833(e)(1)","children":[],"tail":", (3)(A), (B), redesignated subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":" as subsec. (a) of this section, inserted heading, and designated first and second sentences of existing provisions as pars. (1) and (2), respectively. Third sentence of subsec. (a) designated subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/3/C"},"text":"Pub. L. 116–283, § 1833(e)(3)(C)","children":[],"tail":", inserted dash after “major weapon systems to” and reorganized remainder of text into designated subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/3/D"},"text":"Pub. L. 116–283, § 1833(e)(3)(D)","children":[],"tail":", inserted dash after “may include” and reorganized remainder of text into designated subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/2"},"text":"Pub. L. 116–283, § 1833(e)(2)","children":[],"tail":", (4), designated third sentence of subsec. (a) as subsec. (b), inserted heading, and substituted “developed under subsection (a) with respect to” for “developed under this section with respect to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/e/1"},"text":"Pub. L. 116–283, § 1833(e)(1)","children":[],"tail":", (5), redesignated subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":" as subsec. (c) of this section, designated first and second sentences of existing provisions as pars. (1) and (2), respectively, and, in par. (2), substituted “subsection (a)” for “subsection (e)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa377d0a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa377d0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa377d0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVIII/s802/c"},"text":"Pub. L. 109–364, div. A, title VIII, § 802(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2313"},"text":"120 Stat. 2313","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tVIII/s802/c"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"], the Secretary of Defense shall revise regulations under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of title 10","children":[],"tail":", United States Code [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"10 U.S.C. 3771","children":[],"tail":" et seq.], to implement subsection (e) of such section [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3774/a"},"text":"10 U.S.C. 3774(a)","children":[],"tail":", (b)] (as added by this section), including incorporating policy changes developed under such subsection into Department of Defense Directive 5000.1 and Department of Defense Instruction 5000.2.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa377d0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance Relating to Rights in Technical Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s824/a"},"text":"Pub. L. 111–383, div. A, title VIII, § 824(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4269"},"text":"124 Stat. 4269","children":[],"tail":", which required the Secretary of Defense to review certain guidance relating to rights in technical data, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s811/b/12/C"},"text":"Pub. L. 119–60, div. A, title VIII, § 811(b)(12)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/949"},"text":"139 Stat. 949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
