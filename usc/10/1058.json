{"tag":"section","attrib":{"id":"ida8537af4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058"},"text":null,"children":[{"tag":"num","attrib":{"value":"1058"},"text":"§ 1058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of military law enforcement officials at scenes of domestic violence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8537af5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immediate Actions Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed pursuant to subsection (c), the Secretary concerned shall ensure, in any case of domestic violence in which a military law enforcement official at the scene determines that physical injury has been inflicted or a deadly weapon or dangerous instrument has been used, that military law enforcement officials—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8537af6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take immediate measures to reduce the potential for further violence at the scene; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8537af7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 24 hours of the incident, provide a report of the domestic violence to the appropriate commander and to a local military family advocacy representative exercising responsibility over the area in which the incident took place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537af8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family Advocacy Committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed pursuant to subsection (c), the Secretary concerned shall ensure that, whenever a report is provided to a commander under subsection (a)(2), a multidisciplinary family advocacy committee meets, with all due practicable speed, to review the situation and to make recommendations to the commander for appropriate action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537af9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, and the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, shall prescribe by regulation the definition of “domestic violence” for purposes of this section and such other regulations as may be necessary for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537afa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1058/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Law Enforcement Official","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “military law enforcement official” means a person authorized under regulations governing the armed forces to apprehend persons subject to the Uniform Code of Military Justice (chapter 47 of this title) or to trial thereunder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8537afb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s551/a/1"},"text":"Pub. L. 103–160, div. A, title V, § 551(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1661"},"text":"107 Stat. 1661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/a/4"},"text":"Pub. L. 103–337, div. A, title X, § 1070(a)(4)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2855"},"text":"108 Stat. 2855","children":[],"tail":", 2856; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8537afc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8537afd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida8537afe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other sections 1058 were renumbered sections 1059 and 1060 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8537aff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/b/3"},"text":"Pub. L. 103–337, § 1070(b)(3)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/s551/a/1"},"text":"Pub. L. 103–160, § 551(a)(1)","children":[],"tail":", which enacted this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/a/4"},"text":"Pub. L. 103–337, § 1070(a)(4)","children":[],"tail":", substituted “subject to the Uniform Code of Military Justice (chapter 47 of this title)” for “subject to this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8537b00-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8537b01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8537b02-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/b"},"text":"Pub. L. 103–337, div. A, title X, § 1070(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2856"},"text":"108 Stat. 2856","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", and as if included in the National Defense Authorization Act for Fiscal Year 1994, "},{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":", as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8537b03-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Prescribing Procedures","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s551/b"},"text":"Pub. L. 103–160, div. A, title V, § 551(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1662"},"text":"107 Stat. 1662","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tV/s551/b"},"text":"“The Secretary of Defense shall prescribe procedures to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1058"},"text":"section 1058 of title 10","children":[],"tail":", United States Code, as added by subsection (a), not later than six months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
