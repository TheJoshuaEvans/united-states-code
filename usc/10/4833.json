{"tag":"section","attrib":{"id":"idaa9bbcd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833"},"text":null,"children":[{"tag":"num","attrib":{"value":"4833"},"text":"§ 4833.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Defense Laboratory Diversification Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa9bbcd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall conduct a program in accordance with this section for the purpose of promoting cooperation between Department of Defense laboratories and industry on research and development of dual-use technologies in order to further the national security objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbcd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9bbcd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide for the establishment under the program of cooperative arrangements (hereinafter in this section referred to as “partnerships”) between a Department of Defense laboratory and eligible firms and nonprofit research corporations. A partnership may also include one or more additional Federal laboratories, institutions of higher education, agencies of State and local governments, and other entities, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9bbcd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, a federally funded research and development center shall be considered a Department of Defense laboratory if the center is sponsored by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbcd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9bbcd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants, enter into contracts, enter into cooperative agreements and other transactions pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4021"},"text":"section 4021 of this title","children":[],"tail":", and enter into cooperative research and development agreements under section 12 of the Stevenson-Wydler Technology Innovation Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710a"},"text":"15 U.S.C. 3710a","children":[],"tail":") in order to establish partnerships."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9bbcd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (d), the Secretary may provide a partnership with technical and other assistance in order to facilitate the achievement of the purpose of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbcd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Commitment of Non-Federal Government Participants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9bbcd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the non-Federal Government participants in a partnership make a substantial contribution to the total cost of partnership activities. The amount of the contribution shall be commensurate with the risk undertaken by such participants and the potential benefits of the activities for such participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9bbcda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4831/c/2"},"text":"section 4831(c)(2) of this title","children":[],"tail":" shall apply to in-kind contributions made by non-Federal Government participants in a partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbcdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Competitive procedures shall be used in the establishment of partnerships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbcdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The criteria for the selection of a proposed partnership for establishment under this section shall include the criteria set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4831/e"},"text":"section 4831(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9bbcdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4833/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa9bbcde-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXI/s1113/a"},"text":"Pub. L. 103–337, div. A, title XI, § 1113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2864"},"text":"108 Stat. 2864","children":[],"tail":", § 2519; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1081/d"},"text":"Pub. L. 104–106, div. A, title X, § 1081(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/454"},"text":"110 Stat. 454","children":[],"tail":"; renumbered § 4833 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1868/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1868(b)","children":[],"tail":", (c)(3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4282"},"text":"134 Stat. 4282","children":[],"tail":", 4283; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1081/a/7"},"text":"Pub. L. 117–263, div. A, title X, § 1081(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2797"},"text":"136 Stat. 2797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa9bbcdf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa9bbce0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa9bbce1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4833, ","children"