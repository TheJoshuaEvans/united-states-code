{"tag":"section","attrib":{"id":"idaa13c8a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221"},"text":null,"children":[{"tag":"num","attrib":{"value":"3221"},"text":"§ 3221.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Cost Assessment and Program Evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa13c8a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of Cost Assessment and Program Evaluation shall ensure that the cost estimation and cost analysis processes of the Department of Defense provide accurate information and realistic estimates of cost for the acquisition programs of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa13c8a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibility of the Director under subsection (a), the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa13c8a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe, by authority of the Secretary of Defense, policies and procedures for the conduct of cost estimation and cost analysis for the acquisition programs of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to cost estimation in the Department of Defense in general and with respect to specific cost estimates and cost analyses to be conducted in connection with a major defense acquisition program or major subprogram under chapters 321, 324, and 325, subchapter I of chapter 322, and sections 3042, 4232, 4273, 4293, 4321, 4323, and 4328 of this title, provide guidance to and consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c8a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c8a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense for Acquisition and Sustainment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c8a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Defense (Comptroller);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c8a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretaries of the military departments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c8aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of the Defense Agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance relating to the proper discussion of risk in cost estimates generally, and specifically, for the proper discussion of risk in cost estimates for major defense acquisition programs and major subprograms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance relating to full consideration of life-cycle management and sustainability costs in major defense acquisition programs and major subprograms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review all cost estimates and cost analyses conducted in connection with major defense acquisition programs and major subprograms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct or approve independent cost estimates and cost analyses for all major defense acquisition programs and major subprograms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa13c8af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in advance of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa13c8b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decision to grant milestone approval pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c8b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decision to enter into low-rate initial production or full-rate production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c8b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4376"},"text":"section 4376 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa13c8b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any decision to enter into a contract in connection with a military construction project of a value greater than $500,000,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa13c8b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any other time considered appropriate by the Director, upon the request of the Under Secretary of Defense for Acquisition and Sustainment, or upon the request of the milestone decision authority;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically assess and update the cost indexes used by the Department to ensure that such indexes have a sound basis and meet the Department’s needs for realistic cost estimation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa13c8b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually review the cost and associated information required to be included, by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/c/1"},"text":"section 4351(c)(1) of this title","children":[],"tail":", in the Selected Acquisition Reports required by that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa13c8b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3221/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the Director of Cost Assessment and Program Evaluation has sufficient professional staff of military and civilian personnel to enable the Director to carry out the duties and responsibilities of the Director under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa13c8b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1812/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1812(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4174"},"text":"134 Stat. 4174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/c/1"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(c)(1)","children":[],"tail":", (d)(5), ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(A)(i), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2135"},"text":"135 Stat. 2135","children":[],"tail":", 2136, 2147; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2806/b"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2806(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2995"},"text":"136 Stat. 2995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s806/b/2"},"text":"Pub. L. 118–159, div. A, title VIII, § 806(b)(2)","children":[],"tail":", title XVII, § 1701(a)(35), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2