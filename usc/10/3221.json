{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1077/a"},"text":"Pub. L. 114–92, div. A, title X, § 1077(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/998"},"text":"129 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s842/a/3"},"text":"Pub. L. 114–328, div. A, title VIII, § 842(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2288"},"text":"130 Stat. 2288","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa13c8bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3221, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/176"},"text":"70A Stat. 176","children":[],"tail":", related to authorized strength of Army Reserve, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1662(a)(3), 1691, "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2988"},"text":"108 Stat. 2988","children":[],"tail":", 3026, effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12001"},"text":"section 12001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa13c8bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(6)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s806/b/2"},"text":"Pub. L. 118–159, § 806(b)(2)","children":[],"tail":", struck out “4251 or” before “4252 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6)(A)(iv), (v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1701/a/35"},"text":"Pub. L. 118–159, § 1701(a)(35)","children":[],"tail":", redesignated cl. (v) as (iv) and struck out former cl. (iv) which read as follows: “any report under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2445c/f"},"text":"section 2445c(f) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(6)(A)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1812/b/1"},"text":"Pub. L. 116–283, § 1812(b)(1)","children":[],"tail":", transferred subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2334"},"text":"section 2334 of this title","children":[],"tail":" to this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1812/b/1"},"text":"Pub. L. 116–283, § 1812(b)(1)","children":[],"tail":", (2)(A), designated second sentence of subsec. (a) as (b), inserted heading, and substituted “In carrying out the responsibility of the Director under subsection (a),” for “In carrying out that responsibility,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/d/5"},"text":"Pub. L. 117–81, § 1701(d)(5)","children":[],"tail":", in introductory provisions, substituted “chapters 321, 324, and 325, su