), 12(a), "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/173"},"text":"96 Stat. 173","children":[],"tail":", 176, effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", and applicable to military construction projects, and to construction and acquisition of military family housing authorized before, on, or after such date. See section 2828(a), (b) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9aacd58-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, Space Force,” for “Marine Corps,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2481"},"text":"section 2481 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/156/s1/1"},"text":"Pub. L. 86–156, § 1(1)","children":[],"tail":", substituted “concerned” for “of a military department” and inserted “or Coast Guard,” after “Marine Corps,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/156/s1/2"},"text":"Pub. L. 86–156, § 1(2)","children":[],"tail":", struck out “of the military department” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9aacd59-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida9aacd5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
