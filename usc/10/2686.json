{"tag":"section","attrib":{"id":"ida9aacd45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686"},"text":null,"children":[{"tag":"num","attrib":{"value":"2686"},"text":"§ 2686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilities and services: sale; expansion and extension of systems and facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9aacd46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under such regulations and for such periods and at such prices as he may prescribe, the Secretary concerned or his designee may sell or contract to sell to purchasers within or in the immediate vicinity of an activity of the Army, Navy, Air Force, Marine Corps, Space Force, or Coast Guard, as the case may be, any of the following utilities and related services, if it is determined that they are not available from another local source and that the sale is in the interest of national defense or in the public interest:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9aacd47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electric power.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Steam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compressed air.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sewage and garbage disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Natural, manufactured, or mixed gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanical refrigeration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9aacd4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2686/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Telephone service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib