{"tag":"section","attrib":{"id":"idaad01453-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351"},"text":null,"children":[{"tag":"num","attrib":{"value":"6351"},"text":"§ 6351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of real property at certain Department of Energy facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad01454-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad01455-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Energy shall prescribe regulations for the transfer by sale or lease of real property at Department of Energy defense nuclear facilities for the purpose of permitting the economic development of the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01456-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not transfer real property under the regulations prescribed under paragraph (1) until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad01457-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary submits a notification of the proposed transfer to the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad01458-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days has elapsed following the date on which the notification is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01459-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indemnification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad0145a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3) and subject to subsection (c), in the sale or lease of real property pursuant to the regulations prescribed under subsection (a), the Secretary may hold harmless and indemnify a person or entity described in paragraph (2) against any claim for injury to person or property that results from the release or threatened release of a hazardous substance or pollutant or contaminant as a result of Department of Energy activities at the defense nuclear facility on which the real property is located. Before entering into any agreement for such a sale or lease, the Secretary shall notify the person or entity that the Secretary has authority to provide indemnification to the person or entity under this subsection. The Secretary shall include in any agreement for such a sale or lease a provision stating whether indemnification is or is not provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad0145b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to the following persons and entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad0145c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any State that acquires ownership or control of real property of a defense nuclear facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad0145d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any political subdivision of a State that acquires such ownership or control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad0145e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other person or entity that acquires such ownership or control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad0145f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any successor, assignee, transferee, lender, or lessee of a person or entity described in subparagraphs (A) through (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01460-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent the persons and entities described in paragraph (2) contributed to any such release or threatened release, paragraph (1) shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01461-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad01462-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No indemnification on a claim for injury may be provided under this section unless the person or entity making a request for the indemnification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad01463-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the Secretary in writing within two years after such claim accrues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad01464-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes to the Secretary copies of pertinent papers received by the person or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad01465-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes evidence or proof of the claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad01466-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides, upon request by the Secretary, access to the records and personnel of the person or entity for purposes of defending or settling the claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad01467-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begins action within six months after the date of mailing, by certified or registered mail, of notice of final denial of the claim by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01468-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1)(A), the date on which a claim accrues is the date on which the person asserting the claim knew (or reasonably should have known) that the injury to person or property referred to in subsection (b)(1) was caused or contributed to by the release or threatened release of a hazardous substance, pollutant, or contaminant as a result of Department of Energy activities at the defense nuclear facility on which the real property is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01469-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad0146a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the Secretary determines that the Secretary may be required to indemnify a person or entity under this section for any claim for injury to person or property referred to in subsection (b)(1), the Secretary may settle or defend the claim on behalf of that person or entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad0146b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case described in paragraph (1), if the person or entity that the Secretary may be required to indemnify does not allow the Secretary to settle or defend the claim, the person or entity may not be indemnified with respect to that claim under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad0146c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as affecting or modifying in any way section 120(h) of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9620/h"},"text":"42 U.S.C. 9620(h)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad0146d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6351/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “hazardous substance”, “release”, and “pollutant or contaminant” have the meanings provided by section 101 of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad0146e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1452"},"text":"139 Stat. 1452","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad0146f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad01470-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad01471-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2811"},"text":"section 2811 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad01472-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
