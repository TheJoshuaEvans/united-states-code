{"tag":"section","attrib":{"id":"ida9c77dcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722"},"text":null,"children":[{"tag":"num","attrib":{"value":"2722"},"text":"§ 2722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft or loss of ammunition, destructive devices, and explosives: report to Secretary of the Treasury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c77dcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall report the theft or other loss of any ammunition, destructive device, or explosive material from the stocks of the Department of Defense to the Secretary of the Treasury within 72 hours, if possible, after the discovery of such theft or loss.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77dcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion for Certain Items","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may exclude from the reporting requirement under subsection (a) any item referred to in that subsection if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77dce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the item represents a low risk of danger to the public and would be of minimal utility to any person who may illegally receive such item; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77dcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exclusion of such item is specified as being excluded from the reporting requirement in a memorandum of agreement between the Secretary of Defense and the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77dd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77dd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “explosive material” means explosives, blasting agents, and detonators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77dd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “destructive device” and “ammunition” have the meanings given those terms by paragraphs (4) and (17), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a"},"text":"section 921(a) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c77dd3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tIII/s344/a"},"text":"Pub. L. 100–456, div. A, title III, § 344(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1961"},"text":"102 Stat. 1961","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/24"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2399"},"text":"120 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c77dd4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c77dd5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c77dd6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “921(a)” for “921”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c77dd7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9c77dd8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tIII/s344/c"},"text":"Pub. L. 100–456, div. A, title III, § 344(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1962"},"text":"102 Stat. 1962","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/456/dA/tIII/s344/c"},"text":"“The amendment made by subsection (a) [enacting this section] shall take effect with respect to thefts and losses discovered more than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9c77dd9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Incident Reporting Requirements for Department of Defense Regarding Lost or Stolen Weapons","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIII/s363"},"text":"Pub. L. 117–81, div. A, title III, § 363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1661"},"text":"135 Stat. 1661","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIII/s342"},"text":"Pub. L. 118–159, div. A, title III, § 342","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1857"},"text":"138 Stat. 1857","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tIII/s342"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of fiscal years 2022 through 2029, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on security, control, thefts, losses, and recoveries of sensitive conventional arms, ammunition, and explosives (commonly referred to as ‘AA&E’) of the Department of Defense during such year, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" M–16 or M4s.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Light automatic weapons up to and including M249, M2, and 40mm MK19 machine guns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Functional launch tube with umbilical squib installed and grip stock for the Stinger missile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Launch tube, sight assembly, and grip stock for missiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tracker for the Dragon missile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mortar tubes up to and including 81mm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grenade launchers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rocket and missile launchers with an unpacked weight of 100 pounds or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Flame throwers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The launcher, missile guidance se, or the optical sight for the TOW and the Javelin Command Launch Unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Single shot and semi-automatic (non-automatic) shoulder-fired weapons such as shotguns and bolt action rifles and weapons barrels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Handguns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recoil-less rifles up to and including 106mm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"“(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Man-portable missiles and rockets in a ready-to-fire configuration or when jointly stored or transported with the launcher tube or grip-stock and the explosive round.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"“(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stinger missiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"“(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dragon, Javelin, light antitank weapon (66mm), shoulder-launched multi-purpose assault weapon rocket (83mm), M136 (AT4) anti-armor launcher and cartridge (84mm).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"“(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Missiles and rockets that are crew-served or require platform-mounted launchers and other equipment to function, including HYDRA–70 rockets and tube-launched optically wire guided (TOW) missiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"“(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Missiles and rockets that require platform-mounted launchers and complex hardware equipment to function including the HELLFIRE missile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"“(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Explosive rounds of any missile or rocket listed in paragraphs (1) through (18).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"“(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hand or rifle grenades (high-explosive and white phosphorous).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"“(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Antitank or antipersonnel mines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"“(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Explosives used in demolition operations, C–4, military dynamite, and trinitrotoluene (TNT).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"“(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warheads for sensitive missiles and rockets weighing less than 50 pounds each.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"“(24)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ammunition that is .50 caliber or larger with explosive-filled projectile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"“(25)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incendiary grenades and fuses for high-explosive grenades.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"“(26)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Blasting caps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"“(27)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplementary charges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"28"},"text":"“(28)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bulk explosives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"29"},"text":"“(29)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detonating cord.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"30"},"text":"“(30)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Riot control agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immediate Reporting of Confirmed Thefts, Losses, and Recoveries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 72 hours after a confirmed theft, loss, or recovery of a sensitive conventional arm, ammunition, or explosive covered by the report required by subsection (a), the Secretary shall report such theft, loss, or recovery to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Crime Information Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local law enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the Senate and the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
