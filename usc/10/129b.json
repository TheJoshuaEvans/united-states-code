{"tag":"section","attrib":{"id":"ida756a4d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b"},"text":null,"children":[{"tag":"num","attrib":{"value":"129b"},"text":"§ 129b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to procure personal services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida756a4d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary of Defense and the Secretaries of the military departments may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida756a4d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the services of experts or consultants (or of organizations of experts or consultants) in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida756a4d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay in connection with such services travel expenses of individuals, including transportation and per diem in lieu of subsistence while such individuals are traveling from their homes or places of business to official duty stations and return as may be authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida756a4d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services of experts or consultants (or organizations thereof) may be procured under subsection (a) only if the Secretary of Defense or the Secretary of the military department concerned, as the case may be, determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida756a4d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement of such services is advantageous to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida756a4d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such services cannot adequately be provided by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida756a4d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Procurement of the services of experts and consultants (or organizations thereof) under subsection (a) shall be carried out under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida756a4da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Authority for Personal Services Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida756a4db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the authority provided under subsection (a), the Secretary of Defense may enter into personal services contracts if the personal services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida756a4dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are to be provided by individuals outside the United States, regardless of their nationality, and are determined by the Secretary to be necessary and appropriate for supporting the activities and programs of the Department of Defense outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida756a4dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly support the mission of a defense intelligence component or counter-intelligence organization of the Department of Defense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida756a4de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly support the mission of the special operations command of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida756a4df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The contracting officer for a personal services contract under this subsection shall be responsible for ensuring that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida756a4e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services to be procured are urgent or unique; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida756a4e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it would not be practicable for the Department to obtain such services by other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida756a4e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s129b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" shall not apply to a contract entered into under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida756a4e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1481/b/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1481(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1704"},"text":"104 Stat. 1704","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1061/a/2"},"text":"Pub. L. 102–190, div. A, title X, § 1061(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1472"},"text":"105 Stat. 1472","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s841/a"},"text":"Pub. L. 108–136, div. A, title VIII, § 841(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1552"},"text":"117 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida756a4e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida756a4e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida756a4e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9002"},"text":"Pub. L. 101–165, title IX, § 9002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1129"},"text":"103 Stat. 1129","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2241"},"text":"section 2241 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1481/b/3"},"text":"Pub. L. 101–510, § 1481(b)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida756a4e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s841/b/1"},"text":"Pub. L. 108–136, § 841(b)(1)","children":[],"tail":", substituted “Authority to procure personal services” for “Experts and consultants: authority to procure services of” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s841/a"},"text":"Pub. L. 108–136, § 841(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" inserted “of” after “services” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
