{"tag":"section","attrib":{"id":"idaa83c8be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4604"},"text":null,"children":[{"tag":"num","attrib":{"value":"4604"},"text":"§ 4604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes to certain documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa83c8bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each document referred to in a contract or other agreement for procurement entered into by the Secretary of Defense shall include a notation that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa83c8c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the version of such document that is applicable to such contract or other agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates whether any changes have been made to such document after the issuance of the solicitation pursuant to which such contract or other agreement was entered into.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa83c8c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unnotated Documents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a document referred to in a contract or other agreement described in subsection (a) that does not include the notation required under such subsection, the version of the document that shall apply with respect to such contract or other agreement is the version in effect at the time of the issuance of the solicitation pursuant to which such contract or other agreement was entered into.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa83c8c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s802/a"},"text":"Pub. L. 119–60, div. A, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/940"},"text":"139 Stat. 940","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa83c8c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa83c8c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa83c8c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 4621 and 4622 were renumbered sections 7621 and 7622 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4623, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/258"},"text":"70A Stat. 258","children":[],"tail":", provided that the Quartermaster Corps sell not more than 16 ounces of tobacco a month to an enlisted member of the Army on active duty who requests it, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/482/s1/a"},"text":"Pub. L. 91–482, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1082"},"text":"84 Stat. 1082","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4624 to 4629 were renumbered sections 7624 to 7629 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa83c8c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa83c8c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s802/b"},"text":"Pub. L. 119–60, div. A, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/940"},"text":"139 Stat. 940","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVIII/s802/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall apply with respect to a contract or other agreement entered into after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
