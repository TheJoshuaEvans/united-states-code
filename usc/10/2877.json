{"tag":"section","attrib":{"id":"ida9eda276-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2877"},"text":null,"children":[{"tag":"num","attrib":{"value":"2877"},"text":"§ 2877.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Differential lease payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pursuant to an agreement entered into by the Secretary concerned and a lessor of military family housing or military unaccompanied housing to members of the armed forces, the Secretary may pay the lessor an amount in addition to the rental payments for the housing made by the members as the Secretary determines appropriate to encourage the lessor to make the housing available to members of the armed forces as military family housing or as military unaccompanied housing.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9eda277-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/547"},"text":"110 Stat. 547","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2803/f"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2803(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/849"},"text":"113 Stat. 849","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eda278-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eda279-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eda27a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “a lessor” for “a private lessor”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
