{"tag":"section","attrib":{"id":"idab6fd688-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9371"},"text":null,"children":[{"tag":"num","attrib":{"value":"9371"},"text":"§ 9371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air University and Space Delta 13: civilian faculty members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab6fd689-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may employ as many civilians as professors, instructors, and lecturers at a school of the Air University or of the Space Delta 13 as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6fd68a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation of Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compensation of persons employed under this section shall be as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab6fd68b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Certain Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab6fd68c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), this section shall apply with respect to persons who are selected by the Secretary for employment as professors, instructors, and lecturers at a school of the Air University or of the Space Delta 13 after ","children":[{"tag":"date","attrib":{"date":"1990-02-27"},"text":"February 27, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab6fd68d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to professors, instructors, and lecturers employed at a school of the Air University or of the Space Delta 13 if the duration of the principal course of instruction offered at that school is less than 10 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab6fd68e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXI/s1124/d/1"},"text":"Pub. L. 101–189, div. A, title XI, § 1124(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1559"},"text":"103 Stat. 1559","children":[],"tail":", § 9021; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/a/17"},"text":"Pub. L. 103–337, div. A, title X, § 1070(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2856"},"text":"108 Stat. 2856","children":[],"tail":"; renumbered § 9371, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/16"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXI/s1117/a"},"text":"Pub. L. 118–31, div. A, title XI, § 1117(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/433"},"text":"137 Stat. 433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab6fd68f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab6fd690-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab6fd691-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1117/a/1"},"text":"Pub. L. 118–31, § 1117(a)(1)","children":[],"tail":", inserted “and Space Delta 13” after “Air University” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1117/a/2"},"text":"Pub. L. 118–31, § 1117(a)(2)","children":[],"tail":", inserted “or of the Space Delta 13” after “Air University”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1117/a/3/A"},"text":"Pub. L. 118–31, § 1117(a)(3)(A)","children":[],"tail":", inserted “or of the Space Delta 13” after “Air Universit