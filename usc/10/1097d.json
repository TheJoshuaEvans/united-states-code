{"tag":"section","attrib":{"id":"ida8916e5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1097d"},"text":"§ 1097d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: notice of change to benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916e60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary makes a significant change to any benefits provided by the TRICARE program to covered beneficiaries, the Secretary shall provide individuals described in paragraph (2) with notice explaining such changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individuals described by this paragraph are covered beneficiaries participating in the TRICARE program who may be affected by a significant change covered by a notification under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide notice under paragraph (1) through electronic means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide notice under paragraph (1) of subsection (a) by the earlier of the following dates:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date that the Secretary determines would afford individuals described in paragraph (2) of such subsection adequate time to understand the change covered by the notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date that is 90 days before the date on which the change covered by the notification becomes effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effective date of a significant change that is required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916e68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Significant Change Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “significant change” means a systemwide change—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916e69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the structure of the TRICARE program or the benefits provided under the TRICARE program (not including the addition of new services or benefits); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916e6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1097d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in beneficiary cost-share rates of more than 20 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8916e6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVII/s711/a"},"text":"Pub. L. 113–291, div. A, title VII, § 711(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3413"},"text":"128 Stat. 3413","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
