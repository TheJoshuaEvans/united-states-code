{"tag":"section","attrib":{"id":"ida9cea8e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2772"},"text":null,"children":[{"tag":"num","attrib":{"value":"2772"},"text":"§ 2772.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Share of fines and forfeitures to benefit Armed Forces Retirement Home","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cea8e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2772/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned or, in the case of the Coast Guard, the Commandant shall deposit in the Armed Forces Retirement Home Trust Fund a percentage (determined under subsection (b)) of the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea8ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2772/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of forfeitures and fines adjudged against an enlisted member, warrant officer, or limited duty officer of the armed forces by sentence of a court martial or under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s815"},"text":"section 815 of this title","children":[],"tail":" (article 15) over and above any amount that may be due from the member, warrant officer, or limited duty officer for the reimbursement of the United States or any individual."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea8eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2772/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of forfeitures on account of the desertion of an enlisted member, warrant officer, or limited duty officer of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea8ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2772/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Percentage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Operating Officer of the Armed Forces Retirement Home shall determine, on the basis of the financial needs of the Armed Forces Retirement Home, the percentage of the amounts referred to in subsection (a) to be deposited in the trust fund referred to in such subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cea8ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s342/a/1"},"text":"Pub. L. 101–189, div. A, title III, § 342(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1419"},"text":"103 Stat. 1419","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1533/a/3"},"text":"Pub. L. 101–510, div. A, title XV, § 1533(a)(3)","children":[],"tail":", (4)(A), "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1733"},"text":"104 Stat. 1733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tII/s205/b/1"},"text":"Pub. L. 111–281, title II, § 205(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2911"},"text":"124 Stat. 2911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s567/b/2/B"},"text":"Pub. L. 112–81, div. A, title V, § 567(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1425"},"text":"125 Stat. 1425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cea8ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9cea8ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9cea8f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2772, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/156"},"text":"70A Stat. 156","children":[],"tail":", authorized withholding of pay of officers of the Army, Navy, Air Force, or Marine Corps, and is covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s1007"},"text":"section 1007 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/3"},"text":"Pub. L. 87–649, § 14c(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9cea8f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “Chief Operating Officer of the Armed Forces Retirement Home” for “Armed Forces Retirement Home Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s205/b/1/A"},"text":"Pub. L. 111–281, § 205(b)(1)(A)","children":[],"tail":", inserted “or, in the case of the Coast Guard, the Commandant” after “concerned” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s205/b/1/B"},"text":"Pub. L. 111–281, § 205(b)(1)(B)","children":[],"tail":", struck out subsec. (c). Text read as follows: “In this section, the term ‘armed forces’ does not include the Coast Guard when it is not operating as a service in the Navy.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1533/a/4/A"},"text":"Pub. L. 101–510, § 1533(a)(4)(A)","children":[],"tail":", substituted “Retirement Home” for “retirement homes” in section catchline and amended text generally, substituting subsecs. (a) to (c) relating to shares of fines and forfeitures to benefit the Armed Forces Retirement Home for former subsecs. (a) and (b) relating to shares of fines and forfeitures to benefit the Soldiers’ Home and the Naval Home."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1533/a/3"},"text":"Pub. L. 101–510, § 1533(a)(3)","children":[],"tail":", inserted “and forfeitures” after “fines” in subsecs. (a)(1)(A) and (b)(1)(A) and substituted “, warrant officer, or limited duty officer” for “or warrant officer” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cea8f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9cea8f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1533/a/3"},"text":"Pub. L. 101–510, div. A, title XV, § 1533(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1733"},"text":"104 Stat. 1733","children":[],"tail":", provided that the amendment by that section was effective "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1409"},"text":"Pub. L. 107–107, div. A, title XIV, § 1409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1265"},"text":"115 Stat. 1265","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1533/a/4/A"},"text":"section 1533(a)(4)(A) of Pub. L. 101–510","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1541"},"text":"section 1541 of Pub. L. 101–510","children":[],"tail":", formerly set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of Title 24","children":[],"tail":", Hospitals and Asylums."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9cea8f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s342/b"},"text":"Pub. L. 101–189, div. A, title III, § 342(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1420"},"text":"103 Stat. 1420","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tIII/s342/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of section 2772 of such title [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2772/a"},"text":"10 U.S.C. 2772(a)","children":[],"tail":"], as added by subsection (a), shall apply with respect to fines and forfeitures adjudged after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of such section shall apply with respect to fines and forfeitures adjudged after ","children":[{"tag":"date","attrib":{"date":"1990-05-31"},"text":"May 31, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":