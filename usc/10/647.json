{"tag":"section","attrib":{"id":"ida7f41d6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647"},"text":null,"children":[{"tag":"num","attrib":{"value":"647"},"text":"§ 647.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Force shaping authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f41d6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may, solely for the purpose of restructuring an armed force under the jurisdiction of that Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f41d6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharge an officer described in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f41d6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer such an officer from the active-duty list of that armed force to the reserve active-status list of a reserve component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41d6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f41d6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authority under this section may be exercised in the case of an officer (other than an officer of the Space Force) who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7f41d70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed not more than six years of service as a commissioned officer in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed more than six years of service as a commissioned officer in the armed forces, but has not completed a minimum service obligation applicable to that member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f41d72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “minimum service obligation” means the initial period of required active duty service together with any additional period of required active duty service incurred during the initial period of required active duty service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41d73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Transferred Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer of the Regular Army, Regular Air Force, Regular Navy, or Regular Marine Corps who is transferred to a reserve active-status list under this section shall be discharged from the regular component concerned and appointed as a reserve commissioned officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12203"},"text":"section 12203 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall prescribe regulations for the exercise of the Secretary’s authority under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s647/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space Force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a similar provision with respect to officers of the Space Force, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20405"},"text":"section 20405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f68d76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s501/c/1/A"},"text":"Pub. L. 108–375, div. A, title V, § 501(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1873"},"text":"118 Stat. 1873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s503/b"},"text":"Pub. L. 110–181, div. A, title V, § 503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/95"},"text":"122 Stat. 95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/4/H"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(4)(H)","children":[],"tail":", (16), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3822"},"text":"134 Stat. 3822","children":[],"tail":", 3823; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1718/b"},"text":"Pub. L. 118–31, div. A, title XVII, § 1718(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/658"},"text":"137 Stat. 658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f68d77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f68d78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f68d79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1718/b/1"},"text":"Pub. L. 118–31, § 1718(b)(1)","children":[],"tail":", inserted “(other than an officer of the Space Force)” after “in the case of an officer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1718/b/2"},"text":"Pub. L. 118–31, § 1718(b)(2)","children":[],"tail":", which directed amendment of subsec. (c) by substituting “or Regular Marine Corps” for “Regular Marine Corps, of Regular Space Force”, was executed by making the substitution for “Regular Marine Corps, or Regular Space Force” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1718/b/3"},"text":"Pub. L. 118–31, § 1718(b)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/16"},"text":"Pub. L. 116–283, § 924(b)(16)","children":[],"tail":", struck out “of that armed force” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/4/H"},"text":"Pub. L. 116–283, § 924(b)(4)(H)","children":[],"tail":", substituted “Regular Marine Corps, or Regular Space Force” for “or Regular Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “six years” for “5 years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f68d7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7f68d7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first month beginning more than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s501/g"},"text":"section 501(g) of Pub. L. 108–375","children":[],"tail":", set out as an Effective Date of 2004 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s531"},"text":"section 531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
