{"tag":"section","attrib":{"id":"ida7b3b89e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a"},"text":null,"children":[{"tag":"num","attrib":{"value":"398a"},"text":"§ 398a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program for sharing cyber capabilities and related information with foreign operational partners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7b3b89f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Establish Pilot Program to Share Cyber Capabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may, with the concurrence of the Secretary of State, provide cyber capabilities and related information developed or procured by the Department of Defense to foreign countries or organizations described in subsection (b) without compensation, to meet operational imperatives if the Secretary of Defense determines that the provision of such cyber capabilities is in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b8a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Foreign Countries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, with the concurrence of the Secretary of State, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b8a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b3b8a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of foreign countries that the Secretary of Defense considers suitable for sharing of cyber capabilities and related information under the authority established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b8a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for establishing the list under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b8a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 14 days after establishing the list required by paragraph (1), submit to the appropriate committees of Congress such list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b8a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate committees of Congress in writing of any changes to the list established under paragraph (1) at least 14 days prior to the adoption of any such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b8a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to the first use of the authority provided by subsection (a), the Secretaries of Defense and State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b8a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and submit to the appropriate committees of Congress procedures for a coordination process for subsection (a) that is consistent with the operational timelines required to support the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b8a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate committees of Congress in writing of any changes to the procedures established under paragraph (1) at least 14 days prior to the adoption of any such changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b8a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b8aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and Secretary of State jointly shall promptly submit to the appropriate committees of Congress notice in writing of any use of the authority provided by subsection (a) no later than 48 hours following the use of the authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b8ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification under paragraph (1) shall include a certification that the provision of the cyber capabilities was in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b8ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The notification under paragraph (1) shall include an analysis of whether the transfer and the underlying operational imperative could have been met using another authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b8ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority established under subsection (a) shall terminate on the date that is 3 years after the date on which this authority becomes law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b3b8ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Metrics","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b3b8af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall maintain performance metrics to track the results of sharing cyber capabilities and related information with foreign operational partners under a pilot program authorized by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b3b8b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The performance metrics under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b3b8b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whom the cyber capability was used against.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b8b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effect of the cyber capability, including whether and how the transfer of the cyber capability improved the operational cyber posture of the United States and achieved operational objectives of the United States, or had no effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b3b8b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other outcome-based or appropriate performance metrics as the Secretary considers appropriate for evaluating the effectiveness of a pilot program carried out under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b629b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7b629b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7b629b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b629b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7b629b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7b629b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “cyber capability” means a device or computer program, including any combination of software, firmware, or hardware, designed to create an effect in or through cyberspace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7b629ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s398a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as amending, diminishing, or otherwise impacting reporting or other obligations under the War Powers Resolution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7b629bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXV/s1551/a"},"text":"Pub. L. 117–263, div. A, title XV, § 1551(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2918"},"text":"136 Stat. 2918","children":[],"tail":", § 398; renumbered § 398a and amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXV/s1501"},"text":"Pub. L. 118–31, div. A, title XV, § 1501","children":[],"tail":", title XVIII, § 1801(a)(6), (7), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/533"},"text":"137 Stat. 533","children":[],"tail":", 683.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7b629bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7b629bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7b629be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The War Powers Resolution, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/148"},"text":"Pub. L. 93–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-07"},"text":"Nov. 7, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/555"},"text":"87 Stat. 555","children":[],"tail":", which is classified generally to chapter 33 (§ 1541 et seq.) of Title 50, War and National Defense. For complete classification of this Resolution to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1541"},"text":"section 1541 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7b629bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", §§ 1501(1), 1801(a)(6), made identical amendments, renumbering "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s398"},"text":"section 398 of this title","children":[],"tail":" relating to pilot program for sharing cyber capabilities and related information with foreign operational partners as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/7/A/i"},"text":"Pub. L. 118–31, § 1801(a)(7)(A)(i)","children":[],"tail":", substituted “subsection (a)” for “paragraph (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/7/A/ii"},"text":"Pub. L. 118–31, § 1801(a)(7)(A)(ii)","children":[],"tail":", substituted “paragraph (1)” for “paragraph (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/7/A/iii"},"text":"Pub. L. 118–31, § 1801(a)(7)(A)(iii)","children":[],"tail":", substituted “paragraph (1)” for “clause (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/7/B"},"text":"Pub. L. 118–31, § 1801(a)(7)(B)","children":[],"tail":", substituted “subsection (a)” for “paragraph (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1501/2"},"text":"Pub. L. 118–31, § 1501(2)","children":[],"tail":", added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
