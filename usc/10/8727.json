,"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12929, ","children":[{"tag":"date","attrib":{"date":"1994-09-29"},"text":"Sept. 29, 1994","children":[],"tail":", 59 F.R. 50473, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" and sections 7427 and 7428 [now 8727 and 8728] of title 10, United States Code, and in order to meet the goals and requirements of the Naval Petroleum and Oil Shale Reserves, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The functions vested in the President by sections 7427 and 7428 [now 8727 and 8728] of title 10 of the United States Code are delegated to the Secretary of Energy.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Temporary delegations of functions of President under this section were contained in the following prior Executive Orders:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12784, ","children":[{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", 56 F.R. 66339."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12659, ","children":[{"tag":"date","attrib":{"date":"1988-12-15"},"text":"Dec. 15, 1988","children":[],"tail":", 53 F.R. 50911."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
