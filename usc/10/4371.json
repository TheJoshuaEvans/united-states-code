{"tag":"section","attrib":{"id":"idaa75980c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371"},"text":null,"children":[{"tag":"num","attrib":{"value":"4371"},"text":"§ 4371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost growth definitions; applicability of reporting requirements; constant base year dollars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa75980d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa75980e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program acquisition unit cost; procurement unit cost; major contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4203/d"},"text":"section 4203(d) of this title","children":[],"tail":", the terms “program acquisition unit cost”, “procurement unit cost”, and “major contract” have the same meanings as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/a"},"text":"section 4351(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa75980f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Significant cost growth threshold","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “significant cost growth threshold” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa759810-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a major defense acquisition program or designated major defense subprogram, a percentage increase in the program acquisition unit cost for the program or subprogram of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa759811-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 15 percent over the program acquisition unit cost for the program or subprogram as shown in the current Baseline Estimate for the program or subprogram; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa759812-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 percent over the program acquisition unit cost for the program or subprogram as shown in the original Baseline Estimate for the program or subprogram.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa759813-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a major defense acquisition program or designated major defense subprogram that is a procurement program, a percentage increase in the procurement unit cost for the program or subprogram of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa759814-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 15 percent over the procurement unit cost for the program or subprogram as shown in the current Baseline Estimate for the program or subprogram; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa759815-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 30 percent over the procurement unit cost for the program or subprogram as shown in the original Baseline Estimate for the program or subprogram.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa759816-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Critical cost growth threshold","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “critical cost growth threshold” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa759817-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a major defense acquisition program or designated major defense subprogram, a percentage increase in the program acquisition unit cost for the program or subprogram of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa759818-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 25 percent over the program acquisition unit cost for the program or subprogram as shown in the current Baseline Estimate for the program or subprogram; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa759819-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent over the program acquisition unit cost for the program or subprogram as shown in the original Baseline Estimate for the program or subprogram.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa75981a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a major defense acquisition program or designated major defense subprogram that is a procurement program, a percentage increase in the procurement unit cost for the program or subprogram of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa75981b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 25 percent over the procurement unit cost for the program or subprogram as shown in the current Baseline Estimate for the program or subprogram; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa75981c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent over the procurement unit cost for the program or subprogram as shown in the original Baseline Estimate for the program or subprogram.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa75981d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baseline estimate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Baseline Estimate”, with respect to a unit cost report that is submitted under this chapter to the service acquisition executive designated by the Secretary concerned on a major defense acquisition program or designated major subprogram, means the cost estimate included in the baseline description for the program or subprogram under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4214"},"text":"section 4214 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa75981e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original baseline estimate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “original Baseline Estimate” has the same meaning as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4214/d"},"text":"section 4214(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa75981f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “procurement program” means a program for which funds for procurement are authorized to be appropriated in a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa759820-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reporting under this chapter shall not apply if a program has received a limited reporting waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/h"},"text":"section 4351(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa759821-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any determination of a percentage increase under this chapter shall be stated in terms of constant base year dollars (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4202"},"text":"section 4202 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa759822-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1850/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1850(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4265"},"text":"134 Stat. 4265","children":[],"tail":", 4266; "},{"ta