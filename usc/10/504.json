{"tag":"section","attrib":{"id":"ida7d5233d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons not qualified","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7d5233e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insanity, Desertion, Felons, Etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person who is insane, intoxicated, or a deserter from an armed force, or who has been convicted of a felony, may be enlisted in any armed force. However, the Secretary concerned may authorize exceptions, in meritorious cases, for the enlistment of deserters and persons convicted of felonies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7d5233f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citizenship or Residency","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7d52340-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may be enlisted in any armed force only if the person is one of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7d52341-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national of the United States, as defined in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52342-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An alien who is lawfully admitted for permanent residence, as defined in section 101(a)(20) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/20"},"text":"8 U.S.C. 1101(a)(20)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52343-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person described in section 341 of one of the following compacts:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7d52344-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Compact of Free Association between the Federated States of Micronesia and the United States (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/188/s201/a"},"text":"section 201(a) of Public Law 108–188","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/117/2784"},"text":"117 Stat. 2784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921"},"text":"48 U.S.C. 1921","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7d52345-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Compact of Free Association between the Republic of the Marshall Islands and the United States (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/188/s201/b"},"text":"section 201(b) of Public Law 108–188","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/117/2823"},"text":"117 Stat. 2823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1921"},"text":"48 U.S.C. 1921","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7d52346-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Compact of Free Association between Palau and the United States (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/658/s201"},"text":"section 201 of Public Law 99–658","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/100/3678"},"text":"100 Stat. 3678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1931"},"text":"48 U.S.C. 1931","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d52347-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding paragraph (1), and subject to paragraph (3), the Secretary concerned may authorize the enlistment of a person not described in paragraph (1) if the Secretary determines that such person possesses a critical skill or expertise—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7d52348-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is vital to the national interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52349-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the person will use in the primary daily duties of that person as a member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d5234a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7d5234b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person who enlists under paragraph (2) may report to initial training until after the Secretary concerned has completed all required background investigations and security and suitability screening as determined by the Secretary of Defense regarding that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d5234c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Secretary concerned may not authorize more than 1,000 enlistments under paragraph (2) per military department in a calendar year until after—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7d5234d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense submits to Congress written notice of the intent of that Secretary concerned to authorize more than 1,000 such enlistments in a calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7d5234e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days has elapsed after the date on which Congress receives the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7d5234f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative Service in Areas of National Interest","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7d52350-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall carry out a program to provide to an individual described in paragraph (2) information about opportunities to work in areas of national interest to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d52351-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual described in this paragraph is an individual who seeks to originally enlist in an armed force but is denied enlistment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d52352-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the program required by paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7d52353-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify job opportunities in the defense industrial base, cybersecurity or intelligence support, research and development in defense technologies, national emergency and disaster preparedness, or any other non-military field the Secretary considers in the national interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52354-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide available information about training or certification programs to obtain the skills necessary for such a job; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52355-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to enter into agreements with entities in the fields described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d52356-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall annually submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the program required by this subsection. Such report shall include, with respect to the year preceding the date of the report, the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7d52357-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals described in paragraph (2) provided information described in paragraph (3)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52358-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals described in paragraph (2) provided information described in paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7d52359-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s504/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of agreements described in paragraph (3)(C) into which the Secretary entered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7d5235a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s2/a/1/B"},"text":"Pub. L. 90–235, § 2(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/754"},"text":"81 Stat. 754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s542/a"},"text":"Pub. L. 109–163, div. A, title V, § 542(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3253"},"text":"119 Stat. 3253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s521/a"},"text":"Pub. L. 115–232, div. A, title V, § 521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1755"},"text":"132 Stat. 1755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s532/a"},"text":"Pub. L. 119–60, div. A, title V, § 532(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/869"},"text":"139 Stat. 869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7d5235b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7d5235c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7d5235d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 504 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s500d"},"text":"section 500d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7d5235e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s521/a/1"},"text":"Pub. L. 115–232, § 521(a)(1)","children":[],"tail":", inserted “and subject to paragraph (3),” after “Notwithstanding paragraph (1),” substituted “person possesses a critical skill or expertise—” for “enlistment is vital to the national interest.”, and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s521/a/2"},"text":"Pub. L. 115–232, § 521(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7d5235f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7d52360-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Provision of Information Regarding Federal Service to Certain Persons Ineligible To Enlist in Certain Armed Forces","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s536"},"text":"Pub. L. 118–159, div. A, title V, § 536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1888"},"text":"138 Stat. 1888","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s536"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Secretary of Defense shall prescribe regulations directing the Secretary of a military department to provide, to a person described in subsection (b), information regarding opportunities for Federal, or other public, service for which the person may be qualified."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Persons Not Qualified to Enlist","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in this subsection is a person ineligible to serve in a covered Armed Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Armed Force Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘covered Armed Force’ means the Army, Navy, Marine Corps, Air Force, or Space Force.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7d52361-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Waiver for Commissioning or Enlistment in the Armed Forces for any Individual Convicted of a Felony Sexual Offense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s523"},"text":"Pub. L. 112–239, div. A, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1723"},"text":"126 Stat. 1723","children":[],"tail":", which provided that an individual may not be provided a waiver for commissioning or enlistment in the Armed Forces if convicted of rape or other sexual offenses, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1711/b"},"text":"Pub. L. 113–66, div. A, title XVII, § 1711(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/963"},"text":"127 Stat. 963","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s657"},"text":"section 657 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
