{"tag":"section","attrib":{"id":"ida9c50cdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2707"},"text":null,"children":[{"tag":"num","attrib":{"value":"2707"},"text":"§ 2707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental restoration projects for environmental responses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c50cde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental Restoration Projects Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense or the Secretary of a military department may carry out an environmental restoration project if that Secretary determines that the project is necessary to carry out a response under this chapter or CERCLA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50cdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any construction, development, conversion, or extension of a structure, and any installation of equipment, that is included in an environmental restoration project under this section may not be considered military construction (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801/a"},"text":"section 2801(a) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50ce0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds authorized for deposit in an account established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2703/a"},"text":"section 2703(a) of this title","children":[],"tail":" shall be the only source of funds to conduct an environmental restoration project under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50ce1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Environmental Restoration Project Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “environmental restoration project” includes any construction, development, conversion, or extension of a structure, or installation of equipment, in direct support of a response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c50ce2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIII/s313/a/2"},"text":"Pub. L. 107–314, div. A, title III, § 313(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2507"},"text":"116 Stat. 2507","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s316/a"},"text":"Pub. L. 116–92, div. A, title III, § 316(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1304"},"text":"133 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s314/a"},"text":"Pub. L. 116–283, div. A, title III, § 314(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3514"},"text":"134 Stat. 3514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIII/s312/f/1"},"text":"Pub. L. 118–31, div. A, title III, § 312(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/215"},"text":"137 Stat. 215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c50ce3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c50ce4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9c50ce5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2707 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2700"},"text":"section 2700 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c50ce6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out subsec. (e). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Notwithstanding subsection (a) of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2701/c/1"},"text":"section 2701(c)(1) of this title","children":[],"tail":", the Secretary concerned may use funds described in subsection (c) to carry out an environmental restoration project at a facility where military activities are conducted by the National Guard of a State under title 32 in response to perfluorooctanoic acid or perfluorooctane sulfonate contamination under this chapter or CERCLA."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary concerned may use the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2701/d"},"text":"section 2701(d) of this title","children":[],"tail":" to carry out environmental restoration projects under paragraph (1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" designated existing provisions as par. (1), inserted “where military activities are conducted by the National Guard of a State under title 32” after “facility”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c50ce7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"ida9c50ce8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s316"},"text":"section 316 of Pub. L. 116–92","children":[],"tail":" to affect any requirement or authority under the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":" et seq.), see "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/s316/d"},"text":"section 316(d) of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2700"},"text":"section 2700 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
