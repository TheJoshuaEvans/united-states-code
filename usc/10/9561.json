{"tag":"section","attrib":{"id":"idab809f9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9561"},"text":null,"children":[{"tag":"num","attrib":{"value":"9561"},"text":"§ 9561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab809f9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9561/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may prescribe the components, and the quantities thereof, of the Air Force ration and the Space Force ration. He may direct the issue of equivalent articles in place of the prescribed components whenever, in his opinion, economy and the health and comfort of the members of the Air Force or the Space Force so require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809f9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9561/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An enlisted member of the Air Force or the Space Force on active duty is entitled to one ration daily. The emergency ration, when issued, is in addition to the regular ration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809fa0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9561/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fresh or preserved fruits, milk, butter, and eggs necessary for the proper diet of the sick in hospitals shall be provided under regulations approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab809fa1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/577"},"text":"70A Stat. 577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/e/2"},"text":"Pub. L. 116–283, div. A, title IX, § 923(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3816"},"text":"134 Stat. 3816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab809fa2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab809fa3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab809fa4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9561(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9561(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:724.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:716b.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:725.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1901-02-02/ch192"},"text":"Feb. 2, 1901, ch. 192","children":[],"tail":" § 40, "},{"tag":"html:a","attrib":{"href":"/us/stat/31/758"},"text":"31 Stat. 758","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9561(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:726.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1293, ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1892-07-16/ch195"},"text":"July 16, 1892, ch. 195","children":[],"tail":" (last 15 words before proviso under “Subsistence of the Army”), "},{"tag":"html:a","attrib":{"href":"/us/stat/27/178"},"text":"27 Stat. 178","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-02/ch2511"},"text":"Mar. 2, 1907, ch. 2511","children":[],"tail":" (1st proviso under “Subsistence Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1165"},"text":"34 Stat. 1165","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":"R.S. 1175.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the components, and the quantities thereof” are substituted for the words “the kinds and quantities of the component articles”. The words “substitutive” and “a due regard” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “on active duty” are inserted for clarity. The words “under such regulations as may be prescribed by the Secretary of the Army”, in 10:725, are omitted, since the Secretary has inherent authority to issue regulations appropriate to exercising his statutory functions. The words “or reserve”, “prescribed for use on emergent occasions”, and “furnished”, in 10:725, are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “as the Surgeon General” are omitted, since the Air Force does not have the statutory office of Surgeon General, and functions which, for the Army, are assigned by statute to subordinate officers of the Army are, for the Air Force, assigned to the Secretary of the Air Force. The words “Such quantities of” and “may be allowed” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab809fa5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab809fa6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/2/A"},"text":"Pub. L. 116–283, § 923(e)(2)(A)","children":[],"tail":", inserted “and the Space Force ration” after “the Air Force ration” and “or the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/2/B"},"text":"Pub. L. 116–283, § 923(e)(2)(B)","children":[],"tail":", inserted “or the Space Force” after “the Air Force”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idab809fa7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab809fa8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under subsec. (a) of this section to prescribe uniform military ration applicable to Air Force delegated to Secretary of Defense by section 3(a) of Ex. Ord. No. 12781, ","children":[{"tag":"date","attrib":{"date":"1991-11-20"},"text":"Nov. 20, 1991","children":[],"tail":", 56 F.R. 59203, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
