{"tag":"section","attrib":{"id":"ida790043c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239b"},"text":null,"children":[{"tag":"num","attrib":{"value":"239b"},"text":"§ 239b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain intelligence-related programs: budget justification materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida790043d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Use of Program Elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the budget justification materials submitted to Congress in support of the Department of Defense budget for fiscal year 2021 and each fiscal year thereafter (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":"), the Secretary of Defense may not include in any single program element both funds made available under the Military Intelligence Program and funds made available outside of the Military Intelligence Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida790043e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida790043f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “budget” has the meaning given that term in section 231(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7900440-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s239b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense budget materials” has the meaning given that term in section 231(f) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7900441-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1624/b/1"},"text":"Pub. L. 115–232, div. A, title XVI, § 1624(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2120"},"text":"132 Stat. 2120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7900442-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7900443-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7900444-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","