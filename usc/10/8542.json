{"tag":"section","attrib":{"id":"idab2f98b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542"},"text":null,"children":[{"tag":"num","attrib":{"value":"8542"},"text":"§ 8542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" President; assistants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2f98b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2f98b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President of the Naval Postgraduate School shall be one of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab2f98b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An active-duty officer of the Navy or Marine Corps in a grade not below the grade of captain or colonel, respectively, who is assigned or detailed to such position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A civilian individual, including an individual who was retired from the Navy or Marine Corps in a grade not below captain, or colonel, respectively, who has the qualifications appropriate to the position of President and is selected by the Secretary of the Navy as the best qualified from among candidates for the position in accordance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab2f98b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria specified in paragraph (4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors the Secretary considers essential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f98ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before making an assignment, detail, or selection of an individual for the position of President of the Naval Postgraduate School, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab2f98bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Board of Advisors for the Naval Postgraduate School;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any recommendation of the leadership and faculty of the Naval Postgraduate School regarding the assignment or selection to that position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the recommendations of the Chief of Naval Operations and the Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f98be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual selected for the position of President of the Naval Postgraduate School under paragraph (1)(B) shall serve in that position for a term of not more than five years and may be continued in that position for an additional term of up to five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f98bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The qualifications appropriate for selection of an individual for detail or assignment to the position of President of the Naval Postgraduate School include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab2f98c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An academic degree that is either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab2f98c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a doctorate degree in a field of study relevant to the mission and function of the Naval Postgraduate School; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab2f98c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a master’s degree in a field of study relevant to the mission and function of the Naval Postgraduate School, but only if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idab2f98c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is an active-duty or retired officer of the Navy or Marine Corps in a grade not below the grade of captain or colonel, respectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idab2f98c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of the selection of that individual as President, the individual selected for the position of Provost and Chief Academic Officer has a doctorate degree in such a field of study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comprehensive understanding of the Department of the Navy, the Department of Defense, and joint and combined operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leadership experience at the senior level in a large and diverse organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstrated ability to foster and encourage a program of research in order to sustain academic excellence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2f98c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other qualifications, as determined by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2f98c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall detail officers of the Navy and the Marine Corps of appropriate grades and qualifications to assist the President in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2f98ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the advanced instruction and professional and technical education of students and the provision of research opportunities for students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2f98cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of the Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2f98cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/437"},"text":"70A Stat. 437","children":[],"tail":", § 7042; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/53"},"text":"Pub. L. 96–513, title V, § 503(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2915"},"text":"94 Stat. 2915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s557/a/3"},"text":"Pub. L. 108–375, div. A, title V, § 557(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1915"},"text":"118 Stat. 1915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV"},"text":"Pub. L. 109–163, div. A, title V","children":[],"tail":", §§ 523(b), 524, "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3244"},"text":"119 Stat. 3244","children":[],"tail":", 3245; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s508"},"text":"Pub. L. 109–364, div. A, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2180"},"text":"120 Stat. 2180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/49"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4371"},"text":"124 Stat. 4371","children":[],"tail":"; renumbered § 8542, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s554/a/2/C"},"text":"Pub. L. 117–263, div. A, title V, § 554(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2594"},"text":"136 Stat. 2594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2f98cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab2f98ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab2f98cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7042","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1076a"},"text":"34 U.S.C. 1076a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-31/ch420/s2"},"text":"July 31, 1947, ch. 420, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/705"},"text":"61 Stat. 705","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the word “Regular” is omitted as covered by the term “active list”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “line and staff” and “as may be necessary” are omitted as surplusage. The word “grades” is substituted for the word “ranks”. The words “advanced instruction and technical education” are substituted for the words “training * * * in the practical and theoretical duties of commissioned naval officers”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab2f98d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab2f98d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8542, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/527"},"text":"70A Stat. 527","children":[],"tail":", authorized President to detail certain officers as chief and assistant chief of staff of wings of Air National Guard in Federal service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/g/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2996"},"text":"108 Stat. 2996","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12502/b"},"text":"section 12502(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab2f98d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4)(A)(ii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “selected for the position of Provost and Chief Academic Officer” for “permanently appointed to the position of Provost and Academic Dean”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7042"},"text":"section 7042 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" struck out comma after “captain”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) related to assignment of an officer of the Navy in a grade not below the grade of captain or an appropriately qualified civilian individual to the position of President of the Naval Postgraduate School."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s524"},"text":"Pub. L. 109–163, § 524","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Secretary of the Navy shall detail as President of the Naval Postgraduate School an officer on the active-duty list in the line of the Navy eligible for command at sea not below the grade of captain. The President has military command of the Postgraduate School.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s523/b"},"text":"Pub. L. 109–163, § 523(b)","children":[],"tail":", substituted “and professional and technical education of students and the provision of research opportunities for students” for “and technical education of students”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “President” for “Superintendent” wherever appearing in section catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “active-duty list” for “active list”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab2f98d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idab2f98d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s557/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 557(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1915"},"text":"118 Stat. 1915","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dA/tV/s557/a/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position of Superintendent of the Naval Postgraduate School is redesignated as President of the Naval Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any reference to the Superintendent of the Naval Postgraduate School in any law, rule, regulation, document, record, or other paper of the United States shall be deemed to be a reference to the President of the Naval Postgraduate School.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2f98d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2f98d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
