{"tag":"section","attrib":{"id":"idaabf72f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136"},"text":null,"children":[{"tag":"num","attrib":{"value":"6136"},"text":"§ 6136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Earned value management and technology readiness levels for life extension programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabf72f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Contractor Earned Value Management Systems","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall enter into an arrangement with an independent entity under which that entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf72f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and validate whether the earned value management systems of contractors of the Administration for life extension programs meet the earned value management national standard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf72f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic surveillance reviews of such systems to ensure that such systems maintain compliance with that standard through program completion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf72fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benchmarks for Technology Readiness Levels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf72fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish specific benchmarks for technology readiness levels of critical technologies for life extension programs at key decision points; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf72fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that critical technologies meet such benchmarks at such decision points.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf72fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to programs that, as of ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", have not entered phase 3 of the nuclear weapons acquisition process or phase 6.3 of a nuclear weapons life extension program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf72fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6136/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “earned value management national standard” means the most recent version of the EIA-748 Earned Value Management System Standard published by the National Defense Industrial Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabf72ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1371"},"text":"139 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabf7300-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabf7301-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabf7302-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2538f"},"text":"section 2538f of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
