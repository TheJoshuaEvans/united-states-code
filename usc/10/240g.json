{"tag":"section","attrib":{"id":"ida7924de8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g"},"text":null,"children":[{"tag":"num","attrib":{"value":"240g"},"text":"§ 240g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Business Audit Remediation Plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7924de9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall maintain a plan, to be known as the “Defense Business Systems Audit Remediation Plan”. Such plan shall include a current accounting of the defense business systems of the Department of Defense that will be introduced, replaced, updated, modified, or retired in connection with the audit of the full financial statements of the Department, including a comprehensive roadmap that displays—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7924dea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in-service, retirement, and other pertinent dates for affected defense business systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924deb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current cost-to-complete estimates for each affected defense business system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924dec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependencies both between the various defense business systems and between the introduction, replacement, update, modification, and retirement of such systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924ded-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount spent by the Department on operating and maintaining financial management systems during the preceding five fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7924dee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount spent by the Department on acquiring or developing new financial management systems during such five fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7924def-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the same date as the date of the submission of the audited financial statements of the Department of Defense required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s240a"},"text":"section 240a of this title","children":[],"tail":" each year, the Secretary of Defense shall submit to the congressional defense committees an updated annual report on the Defense Business Systems Audit Remediation Plan under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7924df0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s240g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Business System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “defense business system” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2222/i/1/A"},"text":"section 2222(i)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7924df1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tX/s1002/a"},"text":"Pub. L. 116–92, div. A, title X, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1570"},"text":"133 Stat. 1570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1005/a"},"text":"Pub. L. 116–283, div. A, title X, § 1005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3837"},"text":"134 Stat. 3837","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/a/8"},"text":"Pub. L. 117–81, div. A, title X, § 1081(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1920"},"text":"135 Stat. 1920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1003"},"text":"Pub. L. 119–60, div. A, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1028"},"text":"139 Stat. 1028","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7924df2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7924df3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7924df4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) related to annual reports and semiannual briefings on the Defense Business Systems Audit Remediation Plan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted a semicolon for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added pars. (4) and (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
