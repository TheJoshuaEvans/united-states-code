{"tag":"section","attrib":{"id":"idaad9b154-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070"},"text":null,"children":[{"tag":"num","attrib":{"value":"7070"},"text":"§ 7070.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army Medical Specialist Corps: organization; Chief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b155-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Army Medical Specialist Corps consists of the Chief of that corps, other officers in grades prescribed by the Secretary of the Army, and the following sections:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad9b156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Dietitian Section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Physical Therapist Section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Occupational Therapist Section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Physician Assistant Section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad9b15a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chiropractic Section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b15b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall appoint the Chief from the officers of the Regular Army in that corps whose regular grade is above captain and who are recommended by the Surgeon General. The Chief serves during the pleasure of the Secretary, but not for more than four years, and may not be reappointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b15c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7070/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chiropractors who are qualified under regulations prescribed by the Secretary of the Army may be appointed as commissioned officers in the Chiropractic Section of the Army Medical Specialist Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b15d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/169"},"text":"70A Stat. 169","children":[],"tail":", § 3070; "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tI/s101/2"},"text":"Pub. L. 85–155, title I, § 101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Au