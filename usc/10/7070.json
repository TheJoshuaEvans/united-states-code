:[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3070(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:81–1 (9th through 14th words of last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:166a(a) (less 2d sentence; and less last sentence, as applicable to strength).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s307"},"text":"June 28, 1950, ch. 383, § 307","children":[],"tail":" (9th through 14th words of last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/270"},"text":"64 Stat. 270","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-04-16/ch38"},"text":"Apr. 16, 1947, ch. 38","children":[],"tail":", §§ 102(a) (less 2d sentence; and less last sentence, as applicable to strength), 102(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/42"},"text":"61 Stat. 42","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3070(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:166a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), 10:166a(a) (1st 20 words of 1st sentence) is omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3067"},"text":"section 3067 of this title","children":[],"tail":", which establishes the Women’s Medical Specialist Corps in the Army Medical Service. 10:166a(a) (last 16 words of 1st sentence) is omitted as superseded by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3012/e"},"text":"section 3012(e) of this title","children":[],"tail":", which authorizes the Secretary of the Army to prescribe the duties of members of the Army."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “officers of the Regular Army in that corps” are substituted for the words “officers permanently commissioned in such Women’s Medical Specialist Corps”. The words “vacating her regular grade” are substituted for the words “vacation of her permanent grade”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad9b161-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad9b162-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3070"},"text":"section 3070 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s502/p/2"},"text":"Pub. L. 114–328, § 502(p)(2)","children":[],"tail":", amended section catchline generally, substituting “Army Medical Specialist Corps: organization; Chief” for “Army Medical Specialist Corps: organization; Chief and assistant chiefs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s502/p/1/A"},"text":"Pub. L. 114–328, § 502(p)(1)(A)","children":[],"tail":", struck out “and assistant chiefs” after “consists of the Chief” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s502/p/1/B"},"text":"Pub. L. 114–328, § 502(p)(1)(B)","children":[],"tail":", (C), redesignated subsec. (d) as (c) and struck out former subsec. (c) which read as follows: “The Surgeon General shall appoint up to five assistant chiefs from officers of the Regular Army in that corps whose regular grade is above captain. Each assistant chief is the chief of a section of that corps. An assistant chief serves during the pleasure of the Surgeon General, but not for more than four years, and may not be reappointed to the same position.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s505/a/1"},"text":"Pub. L. 102–484, § 505(a)(1)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s505/a/2"},"text":"Pub. L. 102–484, § 505(a)(2)","children":[],"tail":", substituted “up to five assistant chiefs” for “four assistant chiefs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/s505/a/3"},"text":"Pub. L. 102–484, § 505(a)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s551/a/1"},"text":"Pub. L. 102–190, § 551(a)(1)","children":[],"tail":", (2), substituted “sections:” for “sections—”, substituted “The” for “the” and a period for the concluding semicolon in par. (1), substituted “The” for “the” and a period for “; and” in par. (2), substituted “The” for “the” in par. (3), and added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s551/a/3"},"text":"Pub. L. 102–190, § 551(a)(3)","children":[],"tail":", substituted “four assistant chiefs” for “three assistant chiefs” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" removed limitation restricting membership in the Corps to officers in grades of second lieutenant through colonel and inserted provisions authorizing the Secretary of the Army to prescribe the grades of officers comprising the Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out provision entitling the Chief to the temporary grade of colonel while serving, ranking above all other colonels in the Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out provisions entitling each assistant chief to the temporary grade of lieutenant colonel while so serving, ranking above all other lieutenant colonels in the section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/609/s1/2"},"text":"Pub. L. 89–609, § 1(2)","children":[],"tail":", combined second and third sentences, substituting “, and” for period at end of second sentence and introductory word “She” to third sentence, and substituted “the regular grade held, the Chief” for “her regular grade, she” in fourth sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/609/s1/3"},"text":"Pub. L. 89–609, § 1(3)","children":[],"tail":", combined second and third sentences, substituting “, and” for period at end of second sentence and introductory word “She” to third sentence, substituted “An assistant chief” for “She” in fourth sentence, and in fifth sentence substituted “the regular grade held” and “in the section” for “her regular grade” and “in her section”, respectively, and struck out “and the pay and allowances” before “of a lieutenant colonel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649/s6/b/2"},"text":"Pub. L. 87–649, § 6(b)(2)","children":[],"tail":", struck out provisions which authorized the pay and allowances of a colonel for Chief of the Army Medical Specialist Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649/s6/b/3"},"text":"Pub. L. 87–649, § 6(b)(3)","children":[],"tail":", struck out provisions which authorized the pay and allowances of a lieutenant colonel for each assistant chief of the Army Medical Specialist Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1957—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155"},"text":"Pub. L. 85–155","children":[],"tail":" substituted “Army Medical Specialist Corps” for “Women’s Medical Specialist Corps” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155"},"text":"Pub. L. 85–155","children":[],"tail":" substituted “Army Medical Specialist Corps” for “Women’s Medical Specialist Corps” and “colonel” for “major”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155"},"text":"Pub. L. 85–155","children":[],"tail":" struck out provisions which related to assistant chiefs which are now covered by subsec. (c) of this section, substituted “Army Medical Specialist Corps” for “Women’s Medical Specialist Corps”, required the chief to be above the regular grade of captain, prohibited service for more than four years and reappointment, and provided that the chief shall rank above all other colonels in the corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155"},"text":"Pub. L. 85–155","children":[],"tail":" added subsec. (c). Former provisions which related to assistant chiefs were contained in subsec. (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad9b163-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b164-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad9b165-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s15"},"text":"section 15 of Pub. L. 87–649","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaad9b166-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tV/s505/d"},"text":"Pub. L. 102–484, div. A, title V, § 505(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2404"},"text":"106 Stat. 2404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tV/s505/d"},"text":"“The regulations required to be prescribed by the amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5139"},"text":"section 5139 of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8067"},"text":"section 8067 of this title","children":[],"tail":"] shall be prescribed not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaad9b167-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retirement of Officers Serving in Physician Assistant Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s551/c"},"text":"Pub. L. 102–190, div. A, title V, § 551(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1370"},"text":"105 Stat. 1370","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tV/s551/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“A member of the Army who on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"] is a warrant officer serving on active duty (other than for training) as a physician assistant and who is subsequently appointed as a commissioned officer in, or is assigned to, the Physician Assistant Section of the Army Medical Specialist Corps may elect at the time of the officer’s retirement after 20 years or more of active service that could be credited to the officer under section 511 of the Career Compensation Act of 1949, as amended ["},{"tag":"ref","attrib":{"href":"/us/act/1949-10-12/ch681/tV/s511"},"text":"act Oct. 12, 1949, ch. 681, title V, § 511","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/829"},"text":"63 Stat. 829","children":[],"tail":", as amended, formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s580"},"text":"section 580 of this title","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to revert to the highest warrant officer grade in which the officer served on active duty (other than for training) satisfactorily (as determined by the Secretary of the Army) for a period of more than 30 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be retired under chapter 65 of title 10, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaad9b168-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constructive Credit for Determination of Grade and Rank of Officers in Army Medical Specialist Corps","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s551/d"},"text":"Pub. L. 102–190, div. A, title V, § 551(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1371"},"text":"105 Stat. 1371","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tV/s551/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of determining the grade and rank within grade of a person who is appointed as a commissioned officer in the Army Medical Specialist Corps for service in the Physician Assistant Section, or who is assigned to the Army Medical Specialist Corps for service as a physician assistant, and who on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"] is a warrant officer and a physician assistant on active duty or in an active reserve status, the Secretary of the Army shall credit that person at the time of such appointment with any service on active duty, or in an active reserve status, as a physician assistant performed as a member of the Armed Forces before that appointment."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations to carry out this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
