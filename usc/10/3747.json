{"tag":"section","attrib":{"id":"idaa32c312-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3747"},"text":null,"children":[{"tag":"num","attrib":{"value":"3747"},"text":"§ 3747.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractor certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa32c313-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3747/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content and Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proposal for settlement of indirect costs applicable to a covered contract shall include a certification by an official of the contractor that, to the best of the certifying official’s knowledge and belief, all indirect costs included in the proposal are allowable. Any such certification shall be in a form prescribed in the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa32c314-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3747/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the agency or the Secretary of the military department concerned may, in an exceptional case, waive the requirement for certification under subsection (a) in the case of any contract if the head of the agency or the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c315-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3747/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines in such case that it would be in the interest of the United States to waive such certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c316-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3747/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states in writing the reasons for that determination and makes such determination available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa32c317-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1832/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1832(a)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4218"},"text":"134 Stat. 4218","children":[],"tail":", 4221.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa32c318-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa32c319-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa32c31a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2324"},"text":"section 2324 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1832/f"},"text":"Pub. L. 116–283, § 1832(f