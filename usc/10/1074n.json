{"tag":"section","attrib":{"id":"ida879a055-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n"},"text":null,"children":[{"tag":"num","attrib":{"value":"1074n"},"text":"§ 1074n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual mental health assessments for members of the armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida879a056-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mental Health Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), not less frequently than once each calendar year (and before separation from active duty pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1145/a/5/A"},"text":"section 1145(a)(5)(A) of this title","children":[],"tail":"), the Secretary of Defense shall provide a person-to-person mental health assessment for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a057-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each member of a regular component of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a058-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each member of the Selected Reserve of an armed force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a059-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mental health assessments provided pursuant to this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a05a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be conducted in accordance with the requirements of subsection (c)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074m"},"text":"section 1074m of this title","children":[],"tail":" with respect to a mental health assessment provided pursuant to such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a05b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a review of the health records of the member that are related to each previous health assessment or other relevant activities of the member while serving in the armed forces, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a05c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sufficiency of Other Mental Health Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a05d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is not required to provide a mental health assessment pursuant to this section to an individual in a calendar year in which the individual has received a mental health assessment pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074m"},"text":"section 1074m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a05e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may treat periodic health assessments and other person-to-person assessments that are provided to members of the armed forces, including examinations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074f"},"text":"section 1074f of this title","children":[],"tail":", as meeting the requirements for mental health assessments required under this section if the Secretary determines that such assessments and person-to-person assessments meet the requirements for mental health assessments established by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a05f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Privacy Matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any medical or other personal information obtained under this section shall be protected from disclosure or misuse in accordance with the laws on privacy applicable to such information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a060-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074n/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall, in consultation with the other administering Secretaries, prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida879a061-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVII/s701/a/1"},"text":"Pub. L. 113–291, div. A, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3408"},"text":"128 Stat. 3408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s706/b"},"text":"Pub. L. 115–91, div. A, title VII, § 706(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1436"},"text":"131 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida879a062-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida879a063-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida879a064-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “(and before separation from active duty pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1145/a/5/A"},"text":"section 1145(a)(5)(A) of this title","children":[],"tail":")” after “each calendar year” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida879a065-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida879a066-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVII/s701/a/3"},"text":"Pub. L. 113–291, div. A, title VII, § 701(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3409"},"text":"128 Stat. 3409","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tVII/s701/a/3"},"text":"“Not later than 180 days after the date of the issuance of the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074n/e"},"text":"section 1074n(e) of title 10","children":[],"tail":", United States Code, as added by paragraph (1), the Secretary of Defense shall implement such regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
