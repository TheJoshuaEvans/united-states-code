{"tag":"section","attrib":{"id":"ida7e109a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s572"},"text":null,"children":[{"tag":"num","attrib":{"value":"572"},"text":"§ 572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warrant officers: original appointment; service credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e109a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of promotion, persons originally appointed in regular or reserve warrant officer grades shall be credited with such service as the Secretary concerned may prescribe. However, such a person may not be credited with a period of service greater than the period of active service performed in the grade, or pay grade corresponding to the grade, in which so appointed, or in any higher grade or pay grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e109aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned shall credit a person who is receiving an original appointment as a warrant officer in the regular component of an armed force under the jurisdiction of such Secretary concerned, and who has advanced education or training or special experience, with constructive service for such education, training, or experience, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e109ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For special training or experience in a particular warrant officer field designated by the Secretary concerned, if such training or experience is directly related to the operational needs of the armed force concerned, as determined by such Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e109ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For advanced education in a warrant officer field designated by the Secretary concerned, if such education is directly related to the operational needs of the armed force concerned, as determined by such Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e109ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tXI/s1112/a"},"text":"Pub. L. 102–190, div. A, title XI, § 1112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1493"},"text":"105 Stat. 1493","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s507/a"},"text":"Pub. L. 117–263, div. A, title V, § 507(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2558"},"text":"136 Stat. 2558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e109ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e109af-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"top