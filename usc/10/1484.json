{"tag":"section","attrib":{"id":"ida8db6f78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484"},"text":null,"children":[{"tag":"num","attrib":{"value":"1484"},"text":"§ 1484.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pensioners, indigent patients, and persons who die on military reservations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If proper disposition of the remains cannot otherwise be made, the Secretary concerned may provide for the care and disposition of the remains of pensioners and indigent patients who die in hospitals operated by his department and of persons who die on the military reservations of that department and, incident thereto, pay the necessary expenses of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8db6f79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification to the next of kin or other appropriate person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of the remains for burial, including cremation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishing of clothing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishing of a casket or urn, or both, with outside box;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of the remains to a cemetery selected by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6f7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1484/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interment of the remains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8db6f7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/114"},"text":"70A Stat. 114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8db6f80-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8db6f81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8db6f82-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"tex