{"tag":"section","attrib":{"id":"idaa0c9d71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3157"},"text":null,"children":[{"tag":"num","attrib":{"value":"3157"},"text":"§ 3157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; applicability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0c9d72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3157/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “requirements definition” means the process of translating policy objectives and mission needs into specific requirements, the description of which will be the basis for awarding acquisition contracts for projects to be accomplished, work to be performed, or products to be delivered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0c9d73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3157/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency program management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contingency program management” means the process of planning, organizing, staffing, controlling, and leading the combined efforts of participating civilian and military personnel and organizations for the management of a specific defense acquisition program or programs during combat operations, post-conflict operations, and contingency operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0c9d74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3157/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency contracting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contingency contracting” means all stages of the process of acquiring property or services by the Department of Defense during a contingency operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0c9d75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3157/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency contracting personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “contingency contracting personnel” means members of the armed forces and civilian employees of the Department of Defense who are members of the defense acquisition workforce and, as part of their duties, are assigned to provide support to contingency operations (whether deployed or not).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0c9d76-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1810/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1810(a)","children":[],"tail":", (b)(7), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4162"},"text":"134 Stat. 4162","children":[],"tail":", 4164.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa0c9d77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa0c9d78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa0c9d79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f)(1), (2), (5), and (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2333"},"text":"section 2333 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1810/b/7"},"text":"Pub. L. 116–283, § 1810(b)(7)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVIII/s854/a/1"},"text":"Pub. L. 109–364, div. A, title VIII, § 854(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2343"},"text":"120 Stat. 2343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVIII/s849/a"},"text":"Pub. L. 110–181, div. A, title VIII, § 849(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/245"},"text":"122 Stat. 245","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa0c9d7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1810/b/7"},"text":"Pub. L. 116–283, § 1810(b)(7)","children":[],"tail":", redesignated pars. (6), (5), (2), and (1) of subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2333"},"text":"section 2333 of this title","children":[],"tail":" as pars. (1) to (4), respectively, of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa0c9d7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa0c9d7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
