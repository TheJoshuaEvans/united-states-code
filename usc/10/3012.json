{"tag":"section","attrib":{"id":"idaa030018-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012"},"text":null,"children":[{"tag":"num","attrib":{"value":"3012"},"text":"§ 3012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive procedures","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part, the term “competitive procedures” means procedures under which the head of an agency enters into a contract pursuant to full and open competition. Such term also includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa030019-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement of architectural or engineering services conducted in accordance with chapter 11 of title 40;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa03001a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the competitive selection for award of science and technology proposals resulting from a general solicitation and the peer review or scientific review (as appropriate) of such proposals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa03001b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the procedures established by the Administrator of General Services for the multiple award schedule program of the General Services Administration if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa03001c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participation in the program has been open to all responsible sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa03001d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orders and contracts under such program result in the best value to meet the needs of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa03001e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurements conducted in furtherance of section 15 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s644"},"text":"15 U.S.C. 644","children":[],"tail":") as long as all responsible business concerns that are entitled to submit offers for such procurements are permitted to compete; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa03001f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3012/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a competitive selection of research proposals resulting from a general solicitation and peer review or scientific review (as appropriate) solicited pursuant to section 9 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"15 U.S.C. 638","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa030020-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1806/b/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1806(b)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4153"},"text":"134 Stat. 4153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s812/a/3"},"text":"Pub. L. 119–60, div. A, title VIII, § 812(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/951"},"text":"139 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa030021-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa030022-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa030023-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of par. (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"section 2302 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1806/b/3"},"text":"Pub. L. 116–283, § 1806(b)(3)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/127"},"text":"70A Stat. 127","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVII/s2722/a"},"text":"Pub. L. 98–369, div. B, title VII, § 2722(a)","children":[],