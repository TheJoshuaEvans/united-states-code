{"tag":"section","attrib":{"id":"ida8289b7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s894"},"text":null,"children":[{"tag":"num","attrib":{"value":"894"},"text":"§ 894.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 94. Mutiny or sedition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8289b7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s894/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person subject to this chapter who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289b7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s894/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to usurp or override lawful military authority, refuses, in concert with any other person, to obey orders or otherwise do his duty or creates any violence or disturbance is guilty of mutiny;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s894/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to cause the overthrow or destruction of lawful civil authority, creates, in concert with any other person, revolt, violence, or other disturbance against that authority is guilty of sedition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s894/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to do his utmost to prevent and suppress a mutiny or sedition being committed in his presence, or fails to take all reasonable means to inform his superior commissioned officer or commanding officer of a mutiny or sedition which he knows or has reason to believe is taking place, is guilty of a failure to suppress or report a mutiny or sedition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8289b82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s894/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is found guilty of attempted mutiny, mutiny, sedition, or failure to suppress or report a mutiny or sedition shall be punished by death or such other punishment as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8289b83-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/68"},"text":"70A Stat. 68","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8289b84-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8289b85-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8289b86-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"894(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"894(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:688(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:688(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 94), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/136"},"text":"64 Stat. 136","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1) and (2), the words “or persons” are omitted, since, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", words importing the singular may apply to several persons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the word “a” is substituted for the words “an offense of”. The words “commissioned officer” are inserted after the word “superior”, for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
