{"tag":"section","attrib":{"id":"idaa51bc2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4027"},"text":null,"children":[{"tag":"num","attrib":{"value":"4027"},"text":"§ 4027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirements for recipients of research and development funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa51bc2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4027/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsections (b) and (c), an individual or entity (including a State or local government) that uses funds received from the Department of Defense to carry out research or development activities shall include, in any public document pertaining to such activities, a clear statement indicating the dollar amount of the funds received from the Department for such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa51bc2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4027/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The disclosure requirement under subsection (a) shall not apply to a public document consisting of fewer than 280 characters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa51bc2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4027/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may waive the disclosure requirement under subsection (a) on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa51bc30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4027/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Document Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “public document” means any document or other written statement made available for public reference or use, regardless of whether such document or statement is made available in hard copy or electronic format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa51bc31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s212/a/1"},"text":"Pub. L. 116–283, div. A, title II, § 212(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3456"},"text":"134 Stat. 3456","children":[],"tail":", § 2374b; renumbered § 4027, "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/e/4/A"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(e)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2139"},"text":"135 Stat. 2139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa51bc32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa51bc33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa51bc34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4027 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7377"},"text":"section 7377 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa51bc35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2374b"},"text":"section 2374b of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa51bc36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa51bc37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s881/a"},"text":"Pub. L. 117–263, div. A, title VIII, § 881(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2744"},"text":"136 Stat. 2744","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVIII/s881/a"},"text":"“The amendments made by section 1701(e) and paragraphs (1) and (2) of section 802(b) of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":") [renumbering this section and sections 4094, 4873, 4875, and 8755 of this title] shall be deemed to have taken effect immediately before the amendments made by section 1881 of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 ("},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/134/4293"},"text":"134 Stat. 4293","children":[],"tail":") [see Tables for classification].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Subsec. (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1881"},"text":"section 1881 of Pub. L. 116–283","children":[],"tail":", referred to in "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s881/a"},"text":"section 881(a) of Pub. L. 117–263","children":[],"tail":", set out above, provided in part that chapter 139 of this title, in which chapter "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2374b"},"text":"section 2374b of this title","children":[],"tail":" had been located, was repealed.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa51bc38-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s212/b"},"text":"Pub. L. 116–283, div. A, title II, § 212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3456"},"text":"134 Stat. 3456","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tII/s212/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2021-10-01"},"text":"October 1, 2021","children":[],"tail":", and shall apply with respect to funds for research and development that are awarded by the Department of Defense on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa51bc39-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Section 4027 Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s881/b"},"text":"Pub. L. 117–263, div. A, title VIII, § 881(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2744"},"text":"136 Stat. 2744","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVIII/s881/b"},"text":"“An individual or entity to which the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4027"},"text":"section 4027 of title 10","children":[],"tail":", United States Code, were applicable during the period beginning on "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":", and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"] pursuant to subsection (a) [set out as an Effective Date of 2021 Amendment note above] shall be deemed to have complied with such requirements during such period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
