{"tag":"section","attrib":{"id":"idab0973f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8048"},"text":null,"children":[{"tag":"num","attrib":{"value":"8048"},"text":"§ 8048.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical Officer of the Marine Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0973fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8048/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Medical Officer of the Marine Corps who shall be appointed from among flag officers of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0973fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8048/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Medical Officer of the Marine Corps, while so serving, shall hold the grade of rear admiral (lower half).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0973fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s509B/a/1"},"text":"Pub. L. 118–159, div. A, title V, § 509B(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1872"},"text":"138 Stat. 1872","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
