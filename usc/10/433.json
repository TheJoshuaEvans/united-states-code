{"tag":"section","attrib":{"id":"ida7bd2ea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433"},"text":null,"children":[{"tag":"num","attrib":{"value":"433"},"text":"§ 433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship with other Federal laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bd2ea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by subsection (b), a commercial activity conducted pursuant to this subchapter shall be carried out in accordance with applicable Federal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2eaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Waivers When Necessary to Maintain Security","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2eab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of Defense determines, in connection with a commercial activity authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s431"},"text":"section 431 of this title","children":[],"tail":", that compliance with certain Federal laws or regulations pertaining to the management and administration of Federal agencies would create an unacceptable risk of compromise of an authorized intelligence activity, the Secretary may, to the extent necessary to prevent such compromise, waive compliance with such laws or regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any determination and waiver by the Secretary under paragraph (1) shall be made in writing and shall include a specification of the laws and regulations for which compliance by the commercial activity concerned is not required consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary under paragraph (1) may be delegated only to the Deputy Secretary of Defense, an Under Secretary of Defense, an Assistant Secretary of Defense, or a Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2eae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Laws and Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, Federal laws and regulations pertaining to the management and administration of Federal agencies are only those Federal laws and regulations pertaining to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2eaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The receipt and use of appropriated and nonappropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition or management of property or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information disclosure, retention, and management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employment of personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments for travel and housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of legal entities or government instrumentalities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2eb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s433/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign trade or financial transaction restrictions that would reveal the commercial activity as an activity of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2eb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s504/a/2"},"text":"Pub. L. 102–88, title V, § 504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/438"},"text":"105 Stat. 438","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
