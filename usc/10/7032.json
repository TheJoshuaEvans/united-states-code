{"tag":"section","attrib":{"id":"idaad4f62d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032"},"text":null,"children":[{"tag":"num","attrib":{"value":"7032"},"text":"§ 7032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Army Staff: general duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad4f62e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army Staff shall furnish professional assistance to the Secretary, the Under Secretary, and the Assistant Secretaries of the Army and to the Chief of Staff of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f62f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the authority, direction, and control of the Secretary of the Army, the Army Staff shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f630-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7014"},"text":"section 7014 of this title","children":[],"tail":", prepare for such employment of the Army, and for such recruiting, organizing, supplying, equipping (including those aspects of research and development assigned by the Secretary of the Army), training, servicing, mobilizing, demobilizing, administering, and maintaining of the Army, as will assist in the execution of any power, duty, or function of the Secretary or the Chief of Staff;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f631-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate and report upon the efficiency of the Army and its preparation to support military operations by combatant commands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f632-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare detailed instructions for the execution of approved plans and supervise the execution of those plans and instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f633-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as directed by the Secretary or the Chief of Staff, coordinate the action of organizations of the Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f634-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7032/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties, not otherwise assigned by law, as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f635-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/161"},"text":"70A Stat. 161","children":[],"tail":", § 3032; "},{"tag":"ref","attrib":{"href":"/us/pl/85/599/s4/g"},"text":"Pub. L. 85–599, § 4(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/517"},"text":"72 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s502/b"},"text":"Pub. L. 99–433, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1040"},"text":"100 Stat. 1040","children":[],"tail":"; renumbered § 7032 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 808(a), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad4f636-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad4f637-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad4f638-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","att