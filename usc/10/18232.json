text":"69 Stat. 594","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of 50:886(b) is omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc34d31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc34d32-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dB/tXXVIII/s2807/b/1"},"text":"Pub. L. 106–398, § 1 [div. B, title XXVIII, § 2807(b)(1)]","children":[],"tail":", substituted “armory, readiness center, or other structure” for “armory or other structure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dB/tXXVIII/s2807/a"},"text":"Pub. L. 106–398, § 1 [div. B, title XXVIII, § 2807(a)]","children":[],"tail":", substituted “The terms ‘armory’ and ‘readiness center’ mean” for “The term ‘armory’ means” and “Such terms include” for “It includes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2232"},"text":"section 2232 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “The term” after each par. designation and struck out uppercase letter of first word after first quotation marks in pars. (2) and (3) and substituted lowercase letter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Cl. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":" substituted provision defining “State” as any State of the United States, the District of Columbia, Puerto Rico, and each territory and possession of the United States including political subdivisions and military units thereof and tax-supported agencies therein for provision defining “State” and “Territory” as including political subdivisions and military units thereof and tax-supported agencies therein."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Cl. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" added cl. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabc34d33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabc34d34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214"},"text":"Pub. L. 97–214","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", and applicable to military construction projects, and to construction and acquisition of military family housing authorized before, on, or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attr