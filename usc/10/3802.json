{"tag":"section","attrib":{"id":"idaa39eee0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802"},"text":null,"children":[{"tag":"num","attrib":{"value":"3802"},"text":"§ 3802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa39eee1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference for Performance-Based Payments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever practicable, payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":" shall be made using performance-based payments on any of the following bases:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39eee2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance measured by objective, quantifiable methods such as delivery of acceptable items, work measurement, or statistical process controls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eee3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accomplishment of events defined in the program management plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other quantifiable measures of results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis for performance-based payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Performance-based payments shall not be conditioned upon costs incurred in contract performance but on the achievement of performance outcomes listed in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor Accounting Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39eee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to receive performance-based payments, a contractor’s accounting system shall be in compliance with Generally Accepted Accounting Principles, and there shall be no requirement for a contractor to develop Government-unique accounting systems or practices as a prerequisite for agreeing to receive performance-based payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39eee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed to grant the Defense Contract Audit Agency the authority to audit compliance with Generally Accepted Accounting Principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3801"},"text":"section 3801 of this title","children":[],"tail":" may not exceed the unpaid contract price."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa39eeea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3802/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Nontraditional Defense Contractors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that nontraditional defense contractors and other private sector companies are eligible for performance-based payments, consistent with best commercial practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa39eeeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1834/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1834(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4234"},"text":"134 Stat. 4234","children":[],"tail":", 4235.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa39eeec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa39eeed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa39eeee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsecs. (a), (b), (c), and (e), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1834/c/1"},"text":"Pub. L. 116–283, § 1834(c)(1)","children":[],"tail":"–(5), (7), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tII/s2001/b"},"text":"Pub. L. 103–355, title II, § 2001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3302"},"text":"108 Stat. 3302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s831/a"},"text":"Pub. L. 114–328, div. A, title VIII, § 831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2282"},"text":"130 Stat. 2282","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2307"},"text":"section 2307 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (d), and amended by "},{"tag":"ref","attrib":