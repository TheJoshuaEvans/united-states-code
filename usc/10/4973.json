{"tag":"section","attrib":{"id":"idaab11a77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4973"},"text":null,"children":[{"tag":"num","attrib":{"value":"4973"},"text":"§ 4973.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11a78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4973/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions of Loan Guarantees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In issuing a guarantee under this subchapter for a medium-term or long-term loan, the Secretary may not offer terms and conditions more beneficial than those that would be provided to the recipient by the Export-Import Bank of the United States under similar circumstances in conjunction with the provision of guarantees for nondefense articles and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4973/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Losses Arising From Fraud or Misrepresentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No payment may be made under a guarantee issued under this subchapter for a loss arising out of fraud or misrepresentation for which the party seeking payment is responsible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4973/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Right of Acceleration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not accelerate any guaranteed loan or increment, and may not pay any amount, in respect of a guarantee issued under this subchapter, other than in accordance with the original payment terms of the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11a7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXIII/s1321/a/1"},"text":"Pub. L. 104–106, div. A, title XIII, § 1321(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/476"},"text":"110 Stat. 476","children":[],"tail":", § 2540b; renumbered § 4973, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1873/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1873(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4290"},"text":"134 Stat. 4290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab11a7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab11a7d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab11a7e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2540b"},"text":"section 2540b of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaab11a7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaab11a80-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
