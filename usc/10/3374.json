{"tag":"section","attrib":{"id":"idaa1fb00c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374"},"text":null,"children":[{"tag":"num","attrib":{"value":"3374"},"text":"§ 3374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undefinitized contractual actions: allowable profit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1fb00d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowed Profit to Reflect Cost Risks of Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency shall ensure that the profit allowed on an undefinitized contractual action for which the final price is negotiated after a substantial portion of the performance required is completed reflects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1fb00e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the possible reduced cost risk of the contractor with respect to costs incurred during performance of the contract before the final price is negotiated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb00f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduced cost risk of the contractor with respect to costs incurred during performance of the remaining portion of the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb010-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the increased cost risk of the contractor with respect to any costs incurred prior to the award of the undefinitized contractual action when such costs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa1fb011-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would have been directly chargeable to the contract if incurred after the award of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa1fb012-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were incurred to meet an anticipated contract delivery schedule or anticipated contract price targets of the Government under an acquisition strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4211"},"text":"section 4211 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1fb013-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the increased cost risk of the contractor with respect to negotiations continuing for more than 180 days beginning on the date on which the contractor submitted the qualifying proposal to definitize such undefinitized contractual action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1fb014-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3374/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Date as of Which Contractor Cost Risk to Be Determined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a contractor submits a qualifying proposal to definitize an undefinitized contractual action and the contracting officer for such action definitizes the contract after the end of the 180-day period beginning on the date on which the contractor submitted the qualifying proposal, the head of the agency concerned shall ensure that the profit allowed on the contract accurately reflects the cost risk of the contractor as such risk existed on the date the contractor submitted the qualifying proposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1fb015-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1819/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1819(a)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4189"},"text":"134 Stat. 4189","children":[],"tail":", 4190; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s814/a"},"text":"Pub. L. 119–60, div. A, title VIII, § 814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/953"},"text":"139 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa1fb016-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa1fb017-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa1fb018-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":", which was transferred to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/e"},"text":"Pub. L. 116–283, § 1819(e)","children":[],"tail":", was based on "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s908/d/1/A"},"text":"Pub. L. 99–500, § 101(c) [title X, § 908(d)(1)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–141, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tX/s908/d/1/A"},"text":"Pub. L. 99–591, § 101(c) [title X, § 908(d)(1)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–141; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIX"},"text":"Pub. L. 99–661, div. A, title IX","children":[],"tail":", formerly title IV, § 908(d)(1)(A), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3921"},"text":"100 Stat. 3921","children":[],"tail":", renumbered title IX, "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s3/5"},"text":"Pub. L. 100–26, § 3(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/273"},"text":"101 Stat. 273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s811/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 811(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2268"},"text":"130 Stat. 2268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s815/a/1"},"text":"Pub. L. 115–91, div. A, title VIII, § 815(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1462"},"text":"131 Stat. 1462","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added identical subsections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa1fb019-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s814/a/1"},"text":"Pub. L. 119–60, § 814(a)(1)","children":[],"tail":", struck out “Certain Reduced” before “Cost Risks” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s814/a/2"},"text":"Pub. L. 119–60, § 814(a)(2)","children":[],"tail":"–(4), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/e/1/A"},"text":"Pub. L. 116–283, § 1819(e)(1)(A)","children":[],"tail":", transferred subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":" to this section and struck out subsec. (f) designation and heading “Allowable Profit” at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/e/1/B"},"text":"Pub. L. 116–283, § 1819(e)(1)(B)","children":[],"tail":", (2), redesignated par. (1) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326/f"},"text":"section 2326(f) of this title","children":[],"tail":" as subsec. (a) of this section, inserted heading, and redesignated subpars. (A) and (B) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/e/1/B"},"text":"Pub. L. 116–283, § 1819(e)(1)(B)","children":[],"tail":", (3), redesignated par. (2) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326/f"},"text":"section 2326(f) of this title","children":[],"tail":" as subsec. (b) of this section and inserted heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa1fb01a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa1fb01b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa1fb01c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s814/b"},"text":"Pub. L. 119–60, div. A, title VIII, § 814(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/953"},"text":"139 Stat. 953","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVIII/s814/b"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall revise the Department of Defense Supplement to the Federal Acquisition Regulation to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3374/a"},"text":"section 3374(a) of title 10","children":[],"tail":", United States Code, as amended by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
