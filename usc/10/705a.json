{"tag":"section","attrib":{"id":"ida8000445-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a"},"text":null,"children":[{"tag":"num","attrib":{"value":"705a"},"text":"§ 705a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rest and recuperation absence: certain members undergoing extended deployment to a combat zone","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8000446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rest and Recuperation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, the Secretary concerned may provide a member of the armed forces described in subsection (b) the benefits described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8000447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the armed forces described in this subsection is any member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8000448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is assigned or deployed for at least 270 days in an area or location—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8000449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is designated by the President as a combat zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida800044a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which hardship duty pay is authorized to be paid under section 305 or 352(a) of title 37; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800044b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary of Defense may prescribe in the regulations required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800044c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The benefits described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida800044d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A period of rest and recuperation absence for not more than 15 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800044e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Round-trip transportation at Government expense from the area or location in which the member is serving in connection with the exercise of the period of rest and recuperation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800044f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s705a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction With Other Leave","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any benefits provided a member under this section are in addition to any other leave or absence to which the member may be entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8000450-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s532/a"},"text":"Pub. L. 111–383, div. A, title V, § 532(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4216"},"text":"124 Stat. 4216","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/e"},"text":"Pub. L. 115–91, div. A, title VI, § 618(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1426"},"text":"131 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8000451-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8000452-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8000453-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 352(a)” after “section 305”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
