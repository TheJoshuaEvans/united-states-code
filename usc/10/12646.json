ext":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1195(a) (last 30 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1195(b) (last 30 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1006(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1195(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “Notwithstanding any other provisions of this chapter, except as provided in sections 1265 and 1279 of this title” and “has been credited with, or” are omitted as surplusage. The words “entitled to be” in clause (1) are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “at the end of that period” are substituted for the word “then” for clarity. The words “before the end of that period” are substituted for the word “earlier” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaba6c492-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change reflects the repeal of section 611 of the Reserve Officer Personnel Act of 1954, ch. 1257 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/68/1186"},"text":"68 Stat. 1186","children":[],"tail":"), formerly "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1391"},"text":"section 1391 of title 50","children":[],"tail":", and its restatement in "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s787"},"text":"section 787 of title 14","children":[],"tail":" (see sections 5(2) and 36A of the Act of "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"September 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/72/1547"},"text":"72 Stat. 1547","children":[],"tail":" and 1569))."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba6c493-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaba6c494-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 21 of title 14, referred to in subsecs. (a) and (b), was comprised of sections 701 to 713 and 720 to 746 prior to the renumbering of such sections as sections 3701 to 3714 and 3731 to 3757, respectively, of title 14 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":". After renumbering, such sections now comprise chapter 37 (designated as chapter “1” in chapter analysis) of title 14."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s740"},"text":"Section 740 of title 14","children":[],"tail":", referred to in subsec. (e)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3751"},"text":"section 3751 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s118/b"},"text":"Pub. L. 115–282, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4233"},"text":"132 Stat. 4233","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s740"},"text":"section 740 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba6c495-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “under chapter 843,” for “under chapter 573,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “under section 8373,” for “under section 6389,” and “section 7311, 8323, or 9311” for “section 3911, 6323, or 8911”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7311, 8323, or 9311” for “section 3911, 6323, or 8911”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/h/2"},"text":"Pub. L. 103–337, § 1662(h)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1006"},"text":"section 1006 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/d/3/B"},"text":"Pub. L. 103–337, § 1675(d)(3)(B)","children":[],"tail":", substituted “573, 1407, or 1409” for “337, 361, 363, 573, 837, 861, or 863”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/d/3/A"},"text":"Pub. L. 103–337, § 1675(d)(3)(A)","children":[],"tail":", substituted “12732” for “1332” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/d/3/C"},"text":"Pub. L. 103–337, § 1675(d)(3)(C)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “A reserve commissioned officer on active duty (other than for training) who, on the date on which he would otherwise be removed from an active status under section 3846, 3848, 3851, 3852, 6389, 6397, 6403, 6410, 8846, 8848, 8851, or 8852 of this title or "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s740"},"text":"section 740 of title 14","children":[],"tail":", and who is within two years of qualifying for retirement under section 3911, 6323, or 8911 of this title, may, in the discretion of the Secretary concerned, be retained on active duty for a period of not more than two years, if at the end of that period he will be qualified for retirement under one of those sections and will not, before the end of that period, reach the age at which transfer from an active status or discharge is required by this title or title 14. An officer who is retained on active duty under this section may not be removed from an active status while he is on that duty. For officers covered by section 3846, 3848, 3851, or 3852 of this title, the ages at which transfer from an active status or discharge is required are those set forth in section 3843, 3844, or 3845 of this title, or "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s21/e"},"text":"section 21(e) of Public Law 85–861","children":[],"tail":", as the case may be.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Public Law 85–861","children":[],"tail":"” for “the Act enacting this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/322"},"text":"Pub. L. 96–322","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s740"},"text":"section 740 of title 14","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s787"},"text":"section 787 of title 14","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/586/s3/1"},"text":"Pub. L. 93–586, § 3(1)","children":[],"tail":", inserted reference to chapter 21 of title 14."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/586/s3/2"},"text":"Pub. L. 93–586, § 3(2)","children":[],"tail":", substituted “An officer who is retained” for “An officer of the Army or the Air Force who is retained”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/586/s3/3"},"text":"Pub. L. 93–586, § 3(3)","children":[],"tail":", substituted “discharge is required by this title or title 14” for “discharge is required by this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/130"},"text":"Pub. L. 90–130","children":[],"tail":" struck out references to sections 3847 and 8847 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (e). Pub. L. 87—651 substituted “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s787"},"text":"section 787 of title 14","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1391"},"text":"section 1391 of title 50","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/559"},"text":"Pub. L. 86–559","children":[],"tail":" struck out references to sections 3849 and 8849 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba6c496-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaba6c497-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Sections of Title 14 as Redesignated by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"t