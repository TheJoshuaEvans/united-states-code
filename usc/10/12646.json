{"tag":"section","attrib":{"id":"idaba6c47d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646"},"text":null,"children":[{"tag":"num","attrib":{"value":"12646"},"text":"§ 12646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: retention of after completing 18 or more, but less than 20, years of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba6c47e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If on the date prescribed for the discharge or transfer from an active status of a reserve commissioned officer he is entitled to be credited with at least 18, but less than 19, years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":", he may not be discharged or transferred from an active status under chapter 843, 1407, or 1409 of this title or chapter 21 "},{"tag":"ref","attrib":{"idref":"fn002176"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002176"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, without his consent before the earlier of the following dates—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c47f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which he is entitled to be credited with 20 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c480-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the third anniversary of the date on which he would otherwise be discharged or transferred from an active status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c481-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If on the date prescribed for the discharge or transfer from an active status of a reserve commissioned officer he is entitled to be credited with at least 19, but less than 20, years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":", he may not be discharged or transferred from an active status under chapter 843, 1407, or 1409 of this title or chapter 21 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 14, without his consent before the earlier of the following dates—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c482-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which he is entitled to be credited with 20 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c483-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second anniversary of the date on which he would otherwise be discharged or transferred from an active status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c484-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is retained in an active status under subsection (a) or (b) is an additional number to those otherwise authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c485-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsections (a) and (b) do not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c486-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officers who are discharged or transferred from an active status for physical disability, for cause, or because they have reached the age at which transfer from an active status or discharge is required by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c487-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissioned warrant officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c488-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c489-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reserve commissioned officer on active duty (other than for training) or full-time National Guard duty (other than full-time National Guard duty for training only) who, on the date on which the officer would otherwise be removed from an active status under section 8373, 14513, or 14514 of this title or section 740 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 14, is within two years of qualifying for retirement under section 7311, 8323, or 9311 of this title may, in the discretion of the Secretary concerned and subject to paragraph (2), be retained on that duty for a period of not more than two years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c48a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer may be retained on active duty or full-time National Guard duty under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaba6c48b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of the period for which the officer is retained the officer will be qualified for retirement under section 7311, 8323, or 9311 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaba6c48c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer will not, before the end of that period, reach the age at which transfer from an active status or discharge is required by this title or title 14.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c48d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12646/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is retained on active duty or full-time National Guard duty under this section may not be removed from an active status while on that duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba6c48e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/22/B"},"text":"Pub. L. 85–861, § 1(22)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1444"},"text":"72 Stat. 1444","children":[],"tail":", § 1006; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/3/A"},"text":"Pub. L. 86–559, § 1(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/264"},"text":"74 Stat. 264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s105"},"text":"Pub. L. 87–651, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/508"},"text":"76 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/130/s1/4"},"text":"Pub. L. 90–130, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-08"},"text":"Nov. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/374"},"text":"8