{"tag":"section","attrib":{"id":"idab61a5c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9067"},"text":null,"children":[{"tag":"num","attrib":{"value":"9067"},"text":"§ 9067.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Surgeon General for Dental Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is an Assistant Surgeon General for Dental Services in the Air Force who is appointed by the Secretary of the Air Force upon the recommendation of the Surgeon General from officers of the Air Force above the grade of lieutenant colonel who are designated as dental officers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9067/b"},"text":"section 9067(b) of this title","children":[],"tail":". The Assistant Surgeon General for Dental Services serves at the pleasure of the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab61a5c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485/tVIII/s805/c/1"},"text":"Pub. L. 95–485, title VIII, § 805(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1622"},"text":"92 Stat. 1622","children":[],"tail":", § 8081; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s506"},"text":"Pub. L. 105–261, div. A, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2004"},"text":"112 Stat. 2004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s504/a"},"text":"Pub. L. 109–364, div. A, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href"