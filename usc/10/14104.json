{"tag":"section","attrib":{"id":"idabb03a80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104"},"text":null,"children":[{"tag":"num","attrib":{"value":"14104"},"text":"§ 14104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of board proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb03a81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The proceedings of a selection board convened under section 14101 or 14502 of this title may not be disclosed to any person not a member of the board, except as authorized or required to process the report of the board. This prohibition is a statutory exemption from disclosure, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb03a82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Uses of Board Discussions, Deliberations, Notes, and Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The discussions and deliberations of a selection board described in subsection (a) and any written or documentary record of such discussions and deliberations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb03a83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are immune from legal process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03a84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be admitted as evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb03a85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used for any purpose in any action, suit, or judicial or administrative proceeding without the consent of the Secretary of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb03a86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to all selection boards convened under section 14101 or 14502 of this title, regardless of the date on which the board was convened.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb03a87-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2925"},"text":"108 Stat. 2925","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s547/b"},"text":"Pub. L. 109–364, div. A, title V, § 547(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2216"},"text":"120 Stat. 2216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s503/c"},"text":"Pub. L. 111–383, div. A, title V, § 503(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4208"},"text":"124 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb03a88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb03a89-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb03a8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5898/e"},"text":"section 5898(e) of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/b/2"},"text":"Pub. L. 103–337, § 1629(b)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb03a8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s503/c/1"},"text":"Pub. L. 111–383, § 503(c)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The proceedings of a selection board convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101"},"text":"section 14101 of this title","children":[],"tail":" may not be disclosed to any person not a member of the board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s503/c/2"},"text":"Pub. L. 111–383, § 503(c)(2)","children":[],"tail":", substituted “Notes, and Records” for “and Records” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s503/c/3"},"text":"Pub. L. 111–383, § 503(c)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “Except as otherwise authorized or required by law, the proceedings of a selection board convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101"},"text":"section 14101 of this title","children":[],"tail":" may not be disclosed to any person not a member of the board.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb03a8c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb03a8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":", applicable with respect to the proceedings of all selection boards convened under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101"},"text":"section 14101 of this title","children":[],"tail":", including selection boards convened before "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s547/c"},"text":"section 547(c) of Pub. L. 109–364","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s613a"},"text":"section 613a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb03a8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
