{"tag":"section","attrib":{"id":"idaba45438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641"},"text":null,"children":[{"tag":"num","attrib":{"value":"12641"},"text":"§ 12641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and procedures: Secretary to prescribe","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba45439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned shall, by regulation, prescribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba4543a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and qualifications for the retention and promotion of members of the reserve components under his jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba4543b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable procedures for the periodic determination of the compliance of each such Reserve with those standards and qualifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba4543c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a Reserve fails to comply with the standards and qualifications prescribed under subsection (a), he shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba4543d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if qualified, be transferred to an inactive reserve status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba4543e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if qualified, be retired without pay; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba4543f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12641/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have his appointment or enlistment terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba45440-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/79"},"text":"70A Stat. 79","children":[],"tail":", § 1001; renumbered § 12641 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/h/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(h)(2)","children":[],"tail":", (4)(A), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2996"},"text":"108 Stat. 2996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba45441-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaba45442-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaba45443-3a6f-11f1-a