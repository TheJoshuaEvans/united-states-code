{"tag":"section","attrib":{"id":"ida98bd429-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566"},"text":null,"children":[{"tag":"num","attrib":{"value":"2566"},"text":"§ 2566.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Space and services: provision to military welfare societies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida98bd42a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Provide Space and Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may provide, without charge, space and services under the jurisdiction of that Secretary to a military welfare society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd42b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd42c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “military welfare society” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd42d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army Emergency Relief Society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd42e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Navy-Marine Corps Relief Society.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd42f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Air Force Aid Society, Inc.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coast Guard Mutual Assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd431-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2566/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “services” includes lighting, heating, cooling, electricity, office furniture, office machines and equipment, telephone and other information technology services (including installation of lines and equipment, connectivity, and other associated services), and security systems (including installation and other associated expenses).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida98bd432-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1066/a"},"text":"Pub. L. 107–314, div. A, title X, § 1066(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2656"},"text":"116 Stat. 2656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1043"},"text":"Pub. L. 117–81, div. A, title X, § 1043","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1903"},"text":"135 Stat. 1903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida98bd433-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida98bd434-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida98bd435-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1043/1"},"text":"Pub. L. 117–81, § 1043(1)","children":[],"tail":", substituted “concerned” for “of a military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1043/2"},"text":"Pub. L. 117–81, § 1043(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
