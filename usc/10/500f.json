{"tag":"section","attrib":{"id":"ida7cb8698-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f"},"text":null,"children":[{"tag":"num","attrib":{"value":"500f"},"text":"§ 500f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations of abilities of armed forces and combatant commands to perform electromagnetic spectrum operations missions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7cb8699-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluations of Armed Forces","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb869a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":", and annually thereafter through 2029, the Chief of Staff of the Army, the Chief of Naval Operations, the Chief of Staff of the Air Force, the Commandant of the Marine Corps, and the Chief of Space Operations shall each carry out an evaluation of the ability of the armed force concerned to perform electromagnetic spectrum operations missions required by each of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb869b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Electromagnetic Spectrum Superiority Strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb869c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Staff-developed concept of operations for electromagnetic spectrum operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb869d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operations and contingency plans of the combatant commands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb869e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than December 31 of each year in which evaluations are required under paragraph (1), each official specified in that paragraph shall certify to the congressional defense committees that the evaluation required to be carried out by that official has occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb869f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each evaluation under paragraph (1) shall include an assessment of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb86a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Current programs of record, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7cb86a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of weapon systems to perform missions in contested electromagnetic spectrum environments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7cb86a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of electromagnetic attack with capabilities to disrupt adversary operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Future programs of record, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7cb86a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for distributed or network-centric electromagnetic warfare and signals intelligence capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7cb86a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for automated and machine learning- or artificial intelligence-assisted electromagnetic spectrum operations capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Order of battle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individual and unit training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Tactics, techniques, and procedures, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7cb86a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maneuver, distribution of assets, and the use of decoys; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7cb86aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of non-kinetic and kinetic fires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other matters relevant to evaluating the ability of the armed force concerned to perform electromagnetic spectrum operations missions described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7cb86ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluations of Combatant Commands","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7cb86ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":", and annually thereafter through 2029, the Chairman of the Joint Chiefs of Staff, acting through the Electromagnetic Spectrum Enterprise Operational Lead for Joint Electromagnetic Spectrum Operations established under section 500e "},{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should refer to section 505 of this chapter."}],"tail":" (in this section referred to as the “operational lead”), shall carry out an evaluation of the plans and posture of the combatant commands to execute the electromagnetic spectrum operations envisioned in each of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb86ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Electromagnetic Spectrum Superiority Strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Staff-developed concept of operations for electromagnetic spectrum operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb86b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each evaluation under paragraph (1) shall include an assessment, as relevant, of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7cb86b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation and contingency plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manning, organizational alignment, and capability of joint electromagnetic spectrum operations cells.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mission rehearsal and exercises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7cb86b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Force positioning, posture, and readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7cb86b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s500f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than December 31 of each year in which an evaluation is required under paragraph (A), the Chairman of the Joint Chiefs of Staff, acting through the operational lead, shall brief the congressional defense committees on the results of the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7cb86b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1682/a"},"text":"Pub. L. 118–31, div. A, title XVI, § 1682(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/616"},"text":"137 Stat. 616","children":[],"tail":", § 506; renumbered § 500f, "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/10"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2203"},"text":"138 Stat. 2203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7cb86b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7cb86b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7cb86b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s506"},"text":"section 506 of this title","children":[],"tail":", relating to evaluations of the abilities of armed forces and combatant commands to perform electromagnetic spectrum operations missions, as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
