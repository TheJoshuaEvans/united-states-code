{"tag":"section","attrib":{"id":"idab25fc71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452"},"text":null,"children":[{"tag":"num","attrib":{"value":"8452"},"text":"§ 8452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian teachers: number; compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab25fc72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may employ as many civilians as professors, instructors, and lecturers at the Naval Academy as he considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab25fc73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compensation of persons employed under this section is as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab25fc74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may, notwithstanding the provisions of subchapter V of chapter 55 of title 5 or section 6101 of such title, prescribe for persons employed under this section the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab25fc75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The work schedule, including hours of work and tours of duty, set forth with such specificity and other characteristics as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab25fc76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any premium pay or compensatory time off for hours of work or tours of duty in excess of the regularly scheduled hours or tours of duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab25fc77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8452/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, to the extent he considers proper, may delegate the authority conferred by this section to any person in the Department of the Navy, with or without the authority to make successive redelegations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab25fc78-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/428"},"text":"70A Stat. 428","children":[],"tail":", § 6952; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tXI/s1107/b"},"text":"Pub. L. 106–65, div. A, title XI, § 1107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/778"},"text":"113 Stat. 778","children":[],"tail":"; renumbered § 8452, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},