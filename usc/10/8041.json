{"tag":"section","attrib":{"id":"idab09738a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041"},"text":null,"children":[{"tag":"num","attrib":{"value":"8041"},"text":"§ 8041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Headquarters, Marine Corps: function; composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab09738b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the executive part of the Department of the Navy a Headquarters, Marine Corps. The function of the Headquarters, Marine Corps, is to assist the Secretary of the Navy in carrying out his responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab09738c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Headquarters, Marine Corps, is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab09738d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab09738e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab09738f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Commandants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097390-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Staff Judge Advocate to the Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097391-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other members of the Navy and Marine Corps assigned or detailed to the Headquarters, Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab097392-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees in the Department of the Navy assigned or detailed to the Headquarters, Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab097393-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise specifically prescribed by law, the Headquarters, Marine Corps, shall be organized in such manner, and its members shall perform such duties and have such titles, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab097394-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s513/b"},"tex