tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5041"},"text":"section 5041 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" added par. (4) and redesignated former pars. (4) and (5) as (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" added par. (3), redesignated pars. (6) and (7) as (4) and (5), respectively, and struck out former pars. (3) to (5) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Chief of Staff of the Marine Corps.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) The Deputy Chiefs of Staff.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) The Assistant Chiefs of Staff.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab097398-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab097399-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of