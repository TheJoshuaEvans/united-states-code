/90/1090"},"text":"90 Stat. 1090","children":[],"tail":", subject to valid existing rights."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 226d and 226e of title 30, referred to in subsec. (a), were omitted from the Code. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s226"},"text":"section 226 of Title 30","children":[],"tail":", Mineral Lands and Mining."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t30/s227"},"text":"Section 227 of title 30","children":[],"tail":", referred to in subsec. (a), was omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab476677-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7435"},"text":"section 7435 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258"},"text":"Pub. L. 94–258","children":[],"tail":" struck out “of the Navy” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/796"},"text":"Pub. L. 87–796","children":[],"tail":" substituted “land in the naval petroleum, naval oil shale, or other naval fuel reserves” for “land in the naval petroleum or other naval fuel reserves”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab476678-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"