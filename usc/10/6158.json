{"tag":"section","attrib":{"id":"idaac1e3eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6158"},"text":null,"children":[{"tag":"num","attrib":{"value":"6158"},"text":"§ 6158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements on information on radioactive materials","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy may, with the concurrence of the Secretary of State and in coordination with the Secretary of Defense, the Secretary of Homeland Security, and the Director of National Intelligence, enter into agreements with countries or international organizations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac1e3ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6158/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire for the materials information program of the Department of Energy validated information on the physical characteristics of radioactive material produced, used, or stored at various locations, in order to facilitate the ability to determine accurately and in a timely manner the source of any components of, or fissile material used or attempted to be used in, a nuclear device or weapon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac1e3ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6158/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to obtain access to information described in paragraph (1) in the event of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac1e3ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6158/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nuclear detonation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac1e3ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6158/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interdiction or discovery of a nuclear device or weapon or nuclear material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac1e3f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1382"},"text":"139 Stat. 1382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac1e3f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac1e3f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac1e3f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6158, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/387"},"text":"70A Stat. 387","children":[],"tail":", exempted enlisted members of the Marine Corps, while on active duty, from personal arrest for debt or contract, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s7/b/1"},"text":"Pub. L. 90–235, § 7(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/763"},"text":"81 Stat. 763","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2573"},"text":"section 2573 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
