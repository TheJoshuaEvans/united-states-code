{"tag":"section","attrib":{"id":"ida8479405-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997"},"text":null,"children":[{"tag":"num","attrib":{"value":"997"},"text":"§ 997.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of women’s initiative teams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8479406-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall establish a women’s initiative team in each of the Army, Navy, Air Force, Marine Corps, and Space Force to identify and address barriers, if any, to the service, recruitment, retention, and advancement of women in those armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8479407-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each women’s initiative team established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8479408-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and address issues, if any, that hinder service by women in the armed force in which such team is established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8479409-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the recruitment and retention of women in such armed force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida847940a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend policy changes that support the needs of women members of such armed force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida847940b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster a sense of community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida847940c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each women’s initiative team established under subsection (a) shall be composed of members of the armed force in which such team is established of a variety of ranks, backgrounds, and occupational specialities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida847940d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s997/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A women’s initiative team established under subsection (a) shall work collaboratively with the leadership of the armed force in which such team is established and other stakeholders to carry out the duties described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida847940e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s522/a"},"text":"Pub. L. 119–60, div. A, title V, § 522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/864"},"text":"139 Stat. 864","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
