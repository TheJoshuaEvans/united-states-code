{"tag":"section","attrib":{"id":"ida8fa698c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594"},"text":null,"children":[{"tag":"num","attrib":{"value":"1594"},"text":"§ 1594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for financial institution charges incurred because of Government error in direct deposit of pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa698d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa698e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian officer or employee of the Department of Defense who, in accordance with law or regulation, participates in a program for the automatic deposit of pay to a financial institution may be reimbursed for a covered late-deposit charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa698f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered late-deposit charge for purposes of paragraph (1) is a charge (including an overdraft charge or a minimum balance charge) that is levied by a financial institution and that results from an administrative or mechanical error on the part of the Government that causes the pay of the officer or employee concerned to be deposited late or in an incorrect manner or amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6990-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursements under this section shall be made from appropriations available for the pay of the officer or employee concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6991-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries concerned shall prescribe regulations to carry out this section, including regulations for the manner in which reimbursement under this section is to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6992-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa6993-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “financial institution” means a bank, savings and loan association, or similar institution or a credit union chartered by the United States or a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6994-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1594/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “pay” includes allowances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa6995-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s664/b/1"},"text":"Pub. L. 101–189, div. A, title VI, § 664(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1466"},"text":"103 Stat. 1466","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1484/k/6"},"text":"Pub. L. 101–510, div. A, title XIV, § 1484(k)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1719"},"text":"104 Stat. 1719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/e/8/A"},"text":"Pub. L. 102–25, title VII, § 701(e)(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/115"},"text":"105 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s564/b"},"text":"Pub. L. 105–261, div. A, title V, § 564(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2029"},"text":"112 Stat. 2029","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fa6996-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fa6997-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fa6998-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The term ‘financial institution’ has the meaning given the term ‘financial organization’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3332/a"},"text":"section 3332(a) of title 31","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “mandatory” after “error in” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “In this section” for “in this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fa6999-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8fa699a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to pay and allowances deposited (or scheduled to be deposited) on or after first day of first month beginning after ","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/s664/c"},"text":"section 664(c) of Pub. L. 101–189","children":[],"tail":", set out as an Effective Date of 1989 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1053"},"text":"section 1053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
