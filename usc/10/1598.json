)(2)(A), (B) and (f), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tXVII/s1707/a/1"},"text":"Pub. L. 106–65, div. A, title XVII, § 1707(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/823"},"text":"113 Stat. 823","children":[],"tail":", and a new "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1151"},"text":"section 1151 of this title","children":[],"tail":" was subsequently added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s561/a"},"text":"Pub. L. 109–364, § 561(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 472 of the Higher Education Act of 1965, referred to in subsec. (e)(1)(B), which is classified to section 1087","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of Title 20, Education, was generally amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tVII/s702/b"},"text":"Pub. L. 116–260, div. FF, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3138"},"text":"134 Stat. 3138","children":[],"tail":". For provisions similar to former pars. (1), (2), (3), (8), and (9), see subsec. (a)(1), (2), (5), (9), and (10), respectively, of section 1087"},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of Title 20."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (e)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1070 et seq.) of chapter