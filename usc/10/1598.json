{"tag":"section","attrib":{"id":"ida8fcd9fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598"},"text":null,"children":[{"tag":"num","attrib":{"value":"1598"},"text":"§ 1598.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to terminated employees to obtain certification and employment as teachers or employment as teachers’ aides","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fcd9fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Placement Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may establish a program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcd9fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist eligible civilian employees of the Department of Defense and the Department of Energy after the termination of their employment to obtain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcd9fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification or licensure as elementary or secondary school teachers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcd9ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credentials necessary to serve as teachers’ aides; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to facilitate the employment of such employees by local educational agencies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are receiving grants under title I of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"20 U.S.C. 6301","children":[],"tail":" et seq.) as a result of having within their jurisdictions concentrations of children from low-income families; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are also experiencing a shortage of teachers or teachers’ aides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Employees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A civilian employee of the Department of Defense or the Department of Energy shall be eligible for selection by the Secretary of Defense to participate in the placement program authorized by subsection (a) if the employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the five-year period beginning ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":", is terminated from such employment as a result of reductions in defense spending or the closure or realignment of a military installation, as determined by the Secretary of Defense or the Secretary of Energy, as the case may be;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has received—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8fcda07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee applying for assistance for placement as an elementary or secondary school teacher, a baccalaureate or advanced degree from an accredited institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8fcda08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee applying for assistance for placement as a teacher’s aide in an elementary or secondary school, an associate, baccalaureate, or advanced degree from an accredited institution of higher education or a junior or community college; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies such other criteria for selection as the Secretary of Defense may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may accept an application from a civilian employee referred to in paragraph (1) who was terminated during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"October 1, 1992","children":[],"tail":", if the employee otherwise satisfies the eligibility criteria specified in that paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Participants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Selection of civilian employees to participate in the placement program shall be made on the basis of applications submitted to the Secretary of Defense after the employees receive a notice of termination. An application shall be filed within such time, in such form, and contain such information as the Secretary of Defense may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting participants to receive assistance for placement as elementary or secondary school teachers, the Secretary of Defense shall give priority to civilian employees who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have educational, military, or employment experience in science, mathematics, or engineering and agree to seek employment as science, mathematics, or engineering teachers in elementary or secondary schools; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have educational, military, or employment experience in another subject area identified by the Secretary, in consultation with the Secretary of Education, as important for national educational objectives and agree to seek employment in that subject area in elementary or secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may not select a civilian employee to participate in the program unless the Secretary has sufficient appropriations for the placement program available at the time of the selection to satisfy the obligations to be incurred by the United States under the program with respect to that member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civilian employee selected to participate in the placement program shall be required to enter into an agreement with the Secretary of Defense in which the employee agrees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain, within such time as the Secretary may require, certification or licensure as an elementary or secondary school teacher or the necessary credentials to serve as a teacher’s aide in an elementary or secondary school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to accept—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee selected for assistance for placement as a teacher, an offer of full-time employment as an elementary or secondary school teacher for not less than two school years with a local educational agency identified under section 1151(b)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, as in effect on "},{"tag":"date","attrib":{"date":"1999-10-04"},"text":"October 4, 1999","children":[],"tail":", to begin the school year after obtaining that certification or licensure; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee selected for assistance for placement as a teacher’s aide, an offer of full-time employment as a teacher’s aide in an elementary or secondary school for not less than two school years with a local educational agency identified under section 1151(b)(3) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, as in effect on "},{"tag":"date","attrib":{"date":"1999-10-04"},"text":"October 4, 1999","children":[],"tail":", to begin the school year after obtaining the necessary credentials."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stipend for Participants","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), the Secretary of Defense shall pay to each participant in the placement program a stipend in an amount equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total costs of the type described in paragraphs (1), (2), (3), (8), and (9) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of section 472 of the Higher Education Act of 1965 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087"},"text":"20 U.S.C. 1087","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":") incurred by the participant while obtaining teacher certification or licensure or the necessary credentials to serve as a teacher’s aide and employment as an elementary or secondary school teacher or teacher aide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civilian employee selected to participate in the placement program who receives separation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5597"},"text":"section 5597 of title 5","children":[],"tail":" shall not be paid a stipend under paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A stipend paid under paragraph (1) shall be taken into account in determining the eligibility of the participant for Federal student financial assistance provided under title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1598/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Placement of Participants as Teachers and Teachers’ Aides","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (h) through (k) of section 1151 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, as in effect on "},{"tag":"date","attrib":{"date":"1999-10-04"},"text":"October 4, 1999","children":[],"tail":", shall apply with respect to the placement program authorized by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcda1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4442/a"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4442(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2730"},"text":"106 Stat. 2730","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s201/h/1"},"text":"Pub. L. 103–35, title II, § 201(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/100"},"text":"107 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIII/s1331/c/2"},"text":"Pub. L. 103–160, div. A, title XIII, § 1331(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1792"},"text":"107 Stat. 1792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391/b/3"},"text":"Pub. L. 103–382, title III, § 391(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4021"},"text":"108 Stat. 4021","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1503/a/14"},"text":"Pub. L. 104–106, div. A, title XV, § 1503(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/511"},"text":"110 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s576/b"},"text":"Pub. L. 104–201, div. A, title V, § 576(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":