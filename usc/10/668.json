{"tag":"section","attrib":{"id":"ida7fb48bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668"},"text":null,"children":[{"tag":"num","attrib":{"value":"668"},"text":"§ 668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fb48c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Matters","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb48c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this chapter, the term “joint matters” means matters related to any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb48c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The development or achievement of strategic objectives through the synchronization, coordination, and organization of integrated forces in operations conducted across domains, such as land, sea, or air, in space, or in the information environment, including matters relating to any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7fb48c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National military strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic planning and contingency planning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Command and control, intelligence, fires, movement and maneuver, protection or sustainment of operations under unified command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National security planning with other departments and agencies of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Combined operations with military forces of allied nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb48c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquisition matters conducted by members of the armed forces and covered under chapter 87 of this title involved in developing, testing, contracting, producing, or fielding of multi-service programs or systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb48c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other matters designated in regulation by the Secretary of Defense in consultation with the Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb48ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the context of joint matters, the term “integrated forces” refers to military forces that are involved in achieving unified action with participants from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb48cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one military department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb48cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a military department and one or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7fb48cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other departments and agencies of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The military forces or agencies of other countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-governmental persons or entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb48d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Duty Assignment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fb48d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall by regulation define the term “joint duty assignment” for the purposes of this chapter. That definition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb48d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be limited to assignments in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7fb48d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preponderance of the duties of the officer involve joint matters and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7fb48d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer gains significant experience in joint matters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb48d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall exclude student assignments for joint training and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fb48d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall publish a joint duty assignment list showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fb48d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the positions that are joint duty assignment positions under such regulation and the number of such positions and, of those positions, those that are positions held by general or flag officers and the number of such positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fb48d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the positions listed under subparagraph (A), those that are critical joint duty assignment positions and the number of such positions and, of those positions, those that are positions held by general or flag officers and the number of such positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fb48d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s668/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification of “Tour of Duty”","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this chapter, a tour of duty in which an officer serves in more than one joint duty assignment without a break between such assignments shall be considered to be a single tour of duty in a joint duty assignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fb48da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tIV/s401/a"},"text":"Pub. L. 99–433, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1029"},"text":"100 Stat. 1029","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXIII"},"text":"Pub. L. 100–180, div. A, title XIII","children":[],"tail":", §§ 1302(c)(1), 1303(b), "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1170"},"text":"101 Stat. 1170","children":[],"tail":", 1172; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tV/s519/b"},"text":"Pub. L. 100–456, div. A, title V, § 519(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1972"},"text":"102 Stat. 1972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s534/a"},"text":"Pub. L. 108–375, div. A, title V, § 534(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1901"},"text":"118 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s519/a"},"text":"Pub. L. 109–364, div. A, title V, § 519(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2190"},"text":"120 Stat. 2190","children":[],"tail":", 2191; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s521"},"text":"Pub. L. 111–383, div. A, title V, § 521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4214"},"text":"124 Stat. 4214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s503"},"text":"Pub. L. 112–239, div. A, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1715"},"text":"126 Stat. 1715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s843"},"text":"Pub. L. 114–92, div. A, title VIII, § 843","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/915"},"text":"129 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s510A"},"text":"Pub. L. 114–328, div. A, title V, § 510A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2111"},"text":"130 Stat. 2111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fb48db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7fb48dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fb48dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s510A/a"},"text":"Pub. L. 114–328, § 510A(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “In this chapter, the term ‘joint matters’ means matters related to the achievement of unified action by integrated military forces in operations conducted across domains such as land, sea, or air, in space, or in the information environment, including matters relating to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) national military strategy;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) strategic planning and contingency planning;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) command and control of operations under unified command;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) national security planning with other departments and agencies of the United States;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) combined operations with military forces of allied nations; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) acquisition matters addressed by military personnel and covered under chapter 87 of this title.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s510A/b"},"text":"Pub. L. 114–328, § 510A(b)","children":[],"tail":", substituted “integrated forces” for “integrated military forces” and “achieving unified action with” for “the planning or execution (or both) of operations involving” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s510A/c"},"text":"Pub. L. 114–328, § 510A(c)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “shall be limited to assignments in which the officer gains significant experience in joint matters; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s510A/d"},"text":"Pub. L. 114–328, § 510A(d)","children":[],"tail":", struck out subsec. (d). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) In this chapter, the term ‘critical occupational specialty’ means a military occupational specialty involving combat operations within the combat arms, in the case of the Army, or the equivalent arms, in the case of the Navy, Air Force, and Marine Corps, that the Secretary of Defense designates as critical.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) At a minimum, the Secretary of Defense shall designate as a critical occupational specialty under paragraph (1) any military occupational specialty within a combat arms (or the equivalent) that is experiencing a severe shortage of trained officers in that specialty, as determined by the Secretary.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “student assignments for joint training and education” for “assignments for joint training and education, except an assignment as an instructor responsible for preparing and presenting courses in areas of the curricula designated in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2155/c"},"text":"section 2155(c) of this title","children":[],"tail":" as part of a program designated by the Secretary of Defense as joint professional military education Phase II”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s521/1/A"},"text":"Pub. L. 111–383, § 521(1)(A)","children":[],"tail":", substituted “integrated” for “multiple” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s521/1/B"},"text":"Pub. L. 111–383, § 521(1)(B)","children":[],"tail":", substituted “or” for “and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s521/2"},"text":"Pub. L. 111–383, § 521(2)","children":[],"tail":", added par. (2) and struck out former par. (2), which read as follows: “In the context of joint matters, the term ‘multiple military forces’ refers to forces that involve participants from the armed forces and one or more of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) Other departments and agencies of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) The military forces or agencies of other countries.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) Non-governmental persons or entities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s519/a"},"text":"Pub. L. 109–364, § 519(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “In this chapter, the term ‘joint matters’ means matters relating to the integrated employment of land, sea, and air forces, including matters relating to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) national military strategy;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) strategic planning and contingency planning; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) command and control of combat operations under unified command.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s519/b"},"text":"Pub. L. 109–364, § 519(b)","children":[],"tail":", substituted provisions limiting the definition of “joint duty assignment” to assignments in which the officer gains significant experience in joint matters and excluding assignments for joint training and education, except an assignment as an instructor responsible for courses as part of a program designated as joint professional military education Phase II, for provisions limiting the definition of “joint duty assignment” to assignments in which the officer gains significant experience in joint matters and excluding assignments for joint training or joint education and assignments within an officer’s own military department."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s519/c"},"text":"Pub. L. 109–364, § 519(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s534/a"},"text":"Pub. L. 108–375, § 534(a)","children":[],"tail":", substituted “a joint duty assignment list” for “a list” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s534/b"},"text":"Pub. L. 108–375, § 534(b)","children":[],"tail":", struck out “within the same organization” before “without a break”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" redesignated subsec. (f) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s1302/c/1"},"text":"Pub. L. 100–180, § 1302(c)(1)","children":[],"tail":", inserted “and, of those positions, those that are positions held by general or flag officers and the number of such positions” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/s1303/b"},"text":"Pub. L. 100–180, § 1303(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fb48de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7fb48df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"Oct. 1, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s519/e"},"text":"section 519(e) of Pub. L. 109–364","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s664"},"tex