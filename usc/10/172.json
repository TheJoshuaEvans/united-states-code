e","attrib":{"width":"50%","id":"ida77a8011-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"172(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"172(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:83 (less last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:83 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1928-05-29/ch853"},"text":"May 29, 1928, ch. 853","children":[],"tail":" (last par. under “Ordnance Establishment”), "},{"tag":"html:a","attrib":{"href":"/us/stat/45/928"},"text":"45 Stat. 928","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “informed on stored” are substituted for the words “advised of storage”. The words “particular regard” are substituted for the words “special reference”. The words “inside or outside of” are substituted for the words “within or without”. The word “selected” is substituted for the word “appointed”, since the filling of the position involved is not appointment to an office in the constitutional sense.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in carrying out” are substituted for the words “in the execution of”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida77a8012-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida77a8013-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1601/a/1"},"text":"Pub. L. 118–31, § 1601(a)(1)","children":[],"tail":", substituted “Except as provided in subsection (h), the chair” for “The chair” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/2/A"},"text":"Pub. L. 118–31, § 1801(a)(2)(A)","children":[],"tail":", substituted “perform” for “performs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/2/B"},"text":"Pub. L. 118–31, § 1801(a)(2)(B)","children":[],"tail":", substituted “establish” for “establishes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/2/C"},"text":"Pub. L. 118–31, § 1801(a)(2)(C)","children":[],"tail":", substituted “conduct” for “conducts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1601/a/2"},"text":"Pub. L. 118–31, § 1601(a)(2)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s924/b/2/A/ii"},"text":"Pub. L. 116–283, § 924(b)(2)(A)(ii)","children":[],"tail":", substituted “Marine Corps, Space Force,” for “Marine Corps,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s351/a"},"text":"Pub. L. 116–283, § 351(a)","children":[],"tail":", added subsecs. (c) to (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/23"},"text":"Pub. L. 115–23","children":[],"tail":" substituted “Marine Corps, and Coast Guard” for “and Marine Corps” and inserted at end “When the Coast Guard is not operating as a service in the Department of the Navy, the Secretary of Homeland Security shall appoint an officer of the Coast Guard to serve as a voting member of the board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s341/b/1"},"text":"Pub. L. 115–91, § 341(b)(1)","children":[],"tail":", substituted “Explosive safety” for “Ammunition storage” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s341/a/1"},"text":"Pub. L. 115–91, § 341(a)(1)","children":[],"tail":"–(8), designated existing provisions as subsec. (a) and inserted heading, inserted “that includes members” after “joint board”, substituted “selected by the Secretaries of the military departments” for “selected by them”, inserted “military” before “officers”, “designated as the chair and voting members of the board for each military department” after “officers”, and “and other” before “civilian officers”, and substituted “as necessary” for “or both” and “provide oversight on storage and transportation of” for “keep informed on stored”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s341/a/9"},"text":"Pub. L. 115–91, § 341(a)(9)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" struck out subsec. (a) designation before “The Secretaries” and struck out subsec. (b) which read as follows: “The board shall confer with and advise the Secretaries of the military departments in carrying out the recommendations in House Document No. 199 of the Seventieth Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “a joint board selected by them composed of officers, civilian officers and employees of the Department of Defense, or both” for “a joint board of officers selected by them”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida77a8014-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida77a8015-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Appointment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s351/b"},"text":"Pub. L. 116–283, div. A, title III, § 351(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3543"},"text":"134 Stat. 3543","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIII/s351/b"},"text":"“By not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], the Secretary of Defense shall take such steps as may be necessary to ensure that the explosive safety board of the Department of Defense, as authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s172"},"text":"section 172 of title 10","children":[],"tail":", United States Code, has a chair who is a military officer and whose responsibilities include the day-to-day management of the explosive safety board and the responsibilities provided in subsection (c) of such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
