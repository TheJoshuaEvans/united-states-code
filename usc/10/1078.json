{"tag":"section","attrib":{"id":"ida880cc53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078"},"text":null,"children":[{"tag":"num","attrib":{"value":"1078"},"text":"§ 1078.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical and dental care for dependents: charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida880cc54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, after consulting the other administering Secretaries, shall prescribe fair charges for inpatient medical and dental care given to dependents under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076"},"text":"section 1076 of this title","children":[],"tail":". The charge or charges prescribed shall be applied equally to all classes of dependents."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida880cc55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As a restraint on excessive demands for medical and dental care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076"},"text":"section 1076 of this title","children":[],"tail":", uniform minimal charges may be imposed for outpatient care. Charges may not be more than such amounts, if any, as the Secretary of Defense may prescribe after consulting the other administering Secretaries, and after a finding that such charges are necessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida880cc56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts received for subsistence and medical and dental care given under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1076"},"text":"section 1076 of this title","children":[],"tail":" shall be deposited to the credit of the appropriation supporting the maintenance and operation of the facility furnishing the care."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida880cc57-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/25/B"},"text":"Pub. L. 85–861, § 1(25)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1448"},"text":"72 Stat. 1448","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/614/s2/5"},"text":"Pub. L. 89–614, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-30"},"text":"Sept. 30, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/863"},"text":"80 Stat. 863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/36"},"text":"Pub. L. 96–513, title V, § 511(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2923"},"text":"94 Stat. 2923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s19/6"},"text":"Pub. L. 98–557, § 19(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2869"},"text":"98 Stat. 2869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida880cc58-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida880cc59-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%