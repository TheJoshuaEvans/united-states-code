{"tag":"section","attrib":{"id":"idab50dcaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8863"},"text":null,"children":[{"tag":"num","attrib":{"value":"8863"},"text":"§ 8863.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prize property appropriated for the use of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dcb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8863/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any officer or agency designated by the President may appropriate for the use of the United States any captured vessel, arms, munitions, or other material taken as prize. The department or agency for whose use the prize property is appropriated shall deposit the value of the property with the Treasurer of the United States or with the public depositary nearest to the court in which the proceedings are to be had, subject to the orders of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dcb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8863/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever any captured vessel, arms, munitions, or other material taken as prize is appropriated for the use of the United States before that property comes into the custody of the prize court, it shall be surveyed, appraised, and inventoried by persons as competent and impartial as can be obtained, and the survey, appraisal, and inventory sent to the court in which the proceedings are to be had. If the property is appropriated after it comes into the custody of the court, sufficient notice shall be given to enable the court to have the property appraised for the protection of the rights of the claimants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dcb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8863/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsections (a) and (b), in any case where prize property is appropriated for the use of the United States, a prize court may adjudicate the cause on the basis of an inventory and survey and an appropriate undertaking by the United States to respond for the value of the property, without either an appraisal or a deposit of the value of the prize with the Treasurer of the United States or a public depositary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dcb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/478"},"text":"70A Stat. 478","children":[],"tail":", § 7663; renumbered § 8863, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dcb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dcb5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dcb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7663","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1162"},"text":"34 U.S.C. 1162","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-18/ch553/s4"},"text":"Aug. 18, 1942, ch. 553, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-07-01/ch370/s2"},"text":"July 1, 1944, ch. 370, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/678"},"text":"58 Stat. 678","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1140"},"text":"34 U.S.C. 1140","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4624; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-11-14/ch472/s3"},"text":"Nov. 14, 1945, ch. 472, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/581"},"text":"59 Stat. 581","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “may appropriate” are substituted for the words “the power to take or appropriate * * * may be exercised”, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1162"},"text":"34 U.S.C. 1162","children":[],"tail":", for clarity and uniformity of statement. Under the Revised Statutes it was implied and understood that the Navy could appropriate prizes on behalf of the United States for use by the Navy. Use by other government agencies was not contemplated. The 1942 Act enabled the Navy to turn prize vessels over to the War Shipping Administration without bringing them back to United States ports. Reference to that Administration in subsection (a) is omitted since the Administration has been abolished and these functions have not been specifically vested in its successors. It is surplusage as well, because the authority to appropriate is given to any officer or agency designated by the President."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The proviso added to R.S. 4624 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1140"},"text":"34 U.S.C. 1140","children":[],"tail":") by the 1945 amendment is identical with the proviso added to the 1942 Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1162"},"text":"34 U.S.C. 1162","children":[],"tail":") by the 1944 amendment. The 1945 Act completed the process of making the procedure under the Revised Statutes the same as that in effect for causes over which the courts were given jurisdiction by the World War II legislation, and its single statement in subsection (c) is therefore justified."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1140"},"text":"34 U.S.C. 1140","children":[],"tail":" and the revised section reflect the "},{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch413/s13"},"text":"Act of March 3, 1899, ch. 413, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1007"},"text":"30 Stat. 1007","children":[],"tail":", which repealed laws authorizing distribution of prize proceeds to captors, and the "},{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch214"},"text":"Act of May 29, 1920, ch. 214","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/654"},"text":"41 Stat. 654","children":[],"tail":", which requires substitution of “Treasurer of the United States or public depositary” for “assistant treasurer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dcb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dcb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7663"},"text":"section 7663 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab50dcb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab50dcba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
