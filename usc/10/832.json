:[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 32), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/118"},"text":"64 Stat. 118","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"832(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:603(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"832(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:603(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “may” is substituted for the word “shall”. The words “consideration of the” and “a recommendation as to” are inserted in the interest of accuracy and precision of statement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “detailed” is substituted for the word “appointed”, since the filling of the position involved is not appointment to an office in the constitutional sense.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “before” is substituted for the words “prior to the time”. The words “of this section” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “are” is substituted for the words “shall be.” The word “does” is substituted for the words “in any case shall”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida817d1ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida817d1ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s536/a/1"},"text":"Pub. L. 117–81, § 536(a)(1)","children":[],"tail":", substituted “hearing officer detailed in accordance with subparagraph (C).” for “hearing officer, detailed by the convening authority in accordance with subsection (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s536/a/2"},"text":"Pub. L. 117–81, § 536(a)(2)","children":[],"tail":", substituted “written waiver to—” and cls. (i) and (ii) for “written waiver to the convening authority and the convening authority determines that a hearing is not required.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s536/a/3"},"text":"Pub. L. 117–81, § 536(a)(3)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s536/b"},"text":"Pub. L. 117–81, § 536(b)","children":[],"tail":", inserted “or Special Trial Counsel” after “Convening Authority” in heading and substituted “to the convening authority or, in the case of a preliminary hearing in which the hearing officer is provided at the request of a special trial counsel to the special trial counsel,” for “to the convening authority” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/a"},"text":"Pub. L. 114–328, § 5203(a)","children":[],"tail":", substituted “Preliminary hearing required before referral to general court-martial” for “Preliminary hearing” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/a"},"text":"Pub. L. 114–328, § 5203(a)","children":[],"tail":", added subsecs. (a) to (c) and struck out former subsecs. (a) to (c) which related to requirement of preliminary hearing, hearing officer, and report of hearing results, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/b/1"},"text":"Pub. L. 114–328, § 5203(b)(1)","children":[],"tail":", substituted “this section” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/b/2"},"text":"Pub. L. 114–328, § 5203(b)(2)","children":[],"tail":", substituted “that is relevant to the issues for determination under subsection (a)(2).” for “in defense and mitigation, relevant to the limited purposes of the hearing, as provided for in paragraph (4) and subsection (a)(2).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/b/3"},"text":"Pub. L. 114–328, § 5203(b)(3)","children":[],"tail":", inserted at end “A declination under this paragraph shall not serve as the sole basis for ordering a deposition under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s849"},"text":"section 849 of this title","children":[],"tail":" (article 49).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/b/4"},"text":"Pub. L. 114–328, § 5203(b)(4)","children":[],"tail":", substituted “determinations under subsection (a)(2)” for “the limited purposes of the hearing, as provided in subsection (a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/c"},"text":"Pub. L. 114–328, § 5203(c)","children":[],"tail":", substituted “under such rules as the President may prescribe” for “as prescribed by the Manual for Courts-Martial”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5203/d"},"text":"Pub. L. 114–328, § 5203(d)","children":[],"tail":", inserted at end “A defect in a report under subsection (c) is not a basis for relief if the report is in substantial compliance with that subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" inserted “, unless such hearing is waived by the accused” after “preliminary hearing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “Preliminary hearing” for “Investigation” in section catchline and amended text generally. Prior to amendment, section provided that no charge or specification may be referred to general court-martial for trial until thorough and impartial investigation of all the matters had been made."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/81"},"text":"Pub. L. 97–81","children":[],"tail":" substituted “The accused has the right to be represented at that investigation as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s838"},"text":"section 838 of this title","children":[],"tail":" (article 38) and in regulations prescribed under that section” for “Upon his own request he shall be represented by civilian counsel if provided by him, or military counsel of his own selection if such counsel is reasonably available, or by counsel detailed by the officer exercising general court-martial jurisdiction over the command”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida817d1ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida817d1f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" effective on the date that is two years after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", and applicable with respect to offenses that occur after that date, with provisions for delayed effect and applicability if regulations are not prescribed by the President before the date that is two years after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539C"},"text":"section 539C of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"tex