{"tag":"section","attrib":{"id":"idaa88aa9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4661"},"text":null,"children":[{"tag":"num","attrib":{"value":"4661"},"text":"§ 4661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain procurements from the Xinjiang Uyghur Autonomous Region","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa88aa9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4661/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on the Availability of Funds for Certain Procurements From XUAR","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"None of the funds authorized to be appropriated by a national defense authorization Act or any other Act, or otherwise made available for any fiscal year for the Department of Defense, may be obligated or expended to knowingly procure any products mined, produced, or manufactured wholly or in part by forced labor from XUAR or from an entity that has used labor from within or transferred from XUAR as part of a “poverty alleviation” or “pairing assistance” program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa88aa9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4661/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “forced labor” and “XUAR” have the meanings given, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2496"},"text":"section 2496 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa88aa9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s855/b"},"text":"Pub. L. 117–263, div. A, title VIII, § 855(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2723"},"text":"136 Stat. 2723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa88aaa0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa88aaa1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa88aaa2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Policy Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s855/d"},"text":"Pub. L. 117–263, div. A, title VIII, § 855(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2723"},"text":"136 Stat. 2723","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tVIII/s855/d"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary of Defense shall issue a policy to require that an offeror or awardee of a Department of Defense contract shall make a good faith effort to determine that forced labor from XUAR, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4661"},"text":"section 4661 of title 10","children":[],"tail":", United States Code (as amended by subsection (b)), will not be used in the performance of such contract.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
