{"tag":"section","attrib":{"id":"idab31e2c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8587"},"text":null,"children":[{"tag":"num","attrib":{"value":"8587"},"text":"§ 8587.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of annuity for self and beneficiary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab31e2c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8587/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the time of his retirement, a civilian member retiring under this chapter may elect to receive instead of the amount payable annually by the Secretary of the Navy under section 8585 or 8586 of this title a reduced annuity for his life and an annuity payable after his death to his beneficiary in either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab31e2c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8587/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to his reduced annuity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e2c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8587/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 50 percent of his reduced annuity.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The annuities payable to principal and beneficiary, under either election, shall be in amounts that have, on the date of the retirement of the civilian member, a combined actuarial value equal to the actuarial value of the annuity payable by the Secretary under section 8585 or 8586 of this title, as determined under actuarial tables prepared by the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e2c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8587/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the civilian member elects to take a reduced annuity under this section, he shall, at the time of his retirement, designate the beneficiary in writing and file the designation with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e2c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8587/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annuity payable under this section to the beneficiary of a deceased civilian member shall be terminated upon the death of the beneficiary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab31e2c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/440"},"text":"70A Stat. 440","children":[],"tail":", § 7087; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/45"},"text":"Pub. L. 97–295, § 1(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1298"},"text":"96 Stat. 1298","children":[],"tail":"; renumbered § 8587 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab31e2c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab31e2c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab31e2ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7087","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1073c–3"},"text":"34 U.S.C. 1073c–3","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-01-16/ch3/s4C"},"text":"Jan. 16, 1936, ch. 3, § 4C","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch740"},"text":"Aug. 2, 1946, ch. 740","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/805"},"text":"60 Stat. 805","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “under actuarial tables prepared by the Civil Service Commission” are substituted for the words “under the provisions of the Civil Service Retirement Act” because that Act, as amended in 1948, no longer provides for the computation of actuarial values. The Secretary of the Navy, in administering the provisions of law codified in this section, uses tables prepared by the Civil Service Commission prior to the 1948 amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab31e2cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1982 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 10:7087(a) to reflect the transfer of functions from the Civil Service Commission to the Director of the Office of Personnel Management under section 102 of Reorganization Plan No. 2 of 1978 (eff. ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab31e2cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab31e2cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/c/1"},"text":"Pub. L. 115–232, § 807(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7087"},"text":"section 7087 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8585 or 8586” for “section 7085 or 7086” in introductory provisions and concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “Director of the Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab31e2ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"chi