{"tag":"section","attrib":{"id":"ida836cc1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c"},"text":null,"children":[{"tag":"num","attrib":{"value":"949c"},"text":"§ 949c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of trial counsel and defense counsel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cc1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trial Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The trial counsel of a military commission under this chapter shall prosecute in the name of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accused shall be represented in the accused’s defense before a military commission under this chapter as provided in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accused may be represented by military counsel detailed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s948k"},"text":"section 948k of this title","children":[],"tail":" or by military counsel of the accused’s own selection, if reasonably available."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The accused may be represented by civilian counsel if retained by the accused, provided that such civilian counsel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cc22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a United States citizen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is admitted to the practice of law in a State, district, or possession of the United States, or before a Federal court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been the subject of any sanction of disciplinary action by any court, bar, or other competent governmental authority for relevant misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been determined to be eligible for access to information classified at the level Secret or higher; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has signed a written agreement to comply with all applicable regulations or instructions for counsel, including any rules of court for conduct during the proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the accused is represented by civilian counsel, military counsel shall act as associate counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accused is not entitled to be represented by more than one military counsel. However, the person authorized under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s948k"},"text":"section 948k of this title","children":[],"tail":" to detail counsel, in such person’s sole discretion, may detail additional military counsel to represent the accused."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defense counsel may cross-examine each witness for the prosecution who testifies before a military commission under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949c/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian defense counsel shall protect any classified information received during the course of representation of the accused in accordance with all applicable law governing the protection of classified information, and may not divulge such information to any person not authorized to receive it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836cc2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2585"},"text":"123 Stat. 2585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836cc2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836cc2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836cc2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949c, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2610"},"text":"120 Stat. 2610","children":[],"tail":", related to duties of trial counsel and defense counsel, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
