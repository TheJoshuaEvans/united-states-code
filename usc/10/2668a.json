{"tag":"section","attrib":{"id":"ida9a3a1a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2668a"},"text":"§ 2668a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements: granting restrictive easements in connection with land conveyances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a3a1a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Include Restrictive Easement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In connection with the conveyance of real property by the Secretary concerned under any provision of law, the Secretary concerned may grant an easement to an entity specified in subsection (b) restricting future uses of the conveyed real property for a conservation purpose consistent with section 170(h)(4)(A)(iv) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h/4/A/iv"},"text":"26 U.S.C. 170(h)(4)(A)(iv)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An easement under subsection (a) may be granted only to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified organization, as that term is defined in section 170(h) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/h"},"text":"26 U.S.C. 170(h)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Use of Easement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An easement under subsection (a) may not be granted unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed recipient of the easement consents to the receipt of the easement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary concerned determines that the easement is in the public interest and the conservation purpose to be promoted by the easement cannot be effectively achieved through the application of State law by the State or a local government without the grant of restrictive easements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction that encompasses the property to be subject to the easement authorizes the grant of restrictive easements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary can give or assign to a third party the responsibility for monitoring and enforcing easements granted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Easements granted under this section shall be without consideration from the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acreage Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No easement granted under this section may include more land than is necessary for the easement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The grant of an easement under this section shall be subject to such additional terms and conditions as the Secretary concerned considers appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a3a1b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2823/a"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2823(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2475"},"text":"120 Stat. 2475","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
