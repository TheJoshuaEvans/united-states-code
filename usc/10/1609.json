{"tag":"section","attrib":{"id":"ida9019580-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609"},"text":null,"children":[{"tag":"num","attrib":{"value":"1609"},"text":"§ 1609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of defense intelligence employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9019581-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of Defense may terminate the employment of any employee in a defense intelligence position if the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9019582-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers that action to be in the interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019583-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the procedures prescribed in other provisions of law that authorize the termination of the employment of such employee cannot be invoked in a manner consistent with the national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019584-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A decision by the Secretary of Defense to terminate the employment of an employee under this section is final and may not be appealed or reviewed outside the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019585-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Congressional Committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary of Defense terminates the employment of an employee under the authority of this section, the Secretary shall promptly notify the congressional oversight committees of such termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019586-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Right To Seek Other Employment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any termination of employment under this section does not affect the right of the employee involved to seek or accept employment with any other department or agency of the United States if that employee is declared eligible for such employment by the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019587-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1609/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Secretary of Defense under this section may be delegated only to the Deputy Secretary of Defense, the head of an intelligence component of the Department of Defense (with respect to employees of that component), or the Secretary of a military department (with respect to employees of that department). An action to terminate employment of such an employee by any such official may be appealed to the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9019588-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/b"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2748"},"text":"110 Stat. 2748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9019589-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida901958a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida901958b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 1590(e) and 1604(e) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", §§ 1632(a)(3), 1633(a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida901958c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida901958d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
