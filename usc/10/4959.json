{"tag":"section","attrib":{"id":"idaab11a38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959"},"text":null,"children":[{"tag":"num","attrib":{"value":"4959"},"text":"§ 4959.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancing small business growth","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11a39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Clause Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment shall require the clause described in paragraph (2) to be included in each covered contract awarded by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The clause described in this paragraph is a clause that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab11a3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the contractor to acknowledge that acceptance of the contract may cause the business to exceed the applicable small business size standards (established pursuant to section 3(a) of the Small Business Act) for the industry concerned and that the contractor may no longer qualify as a small business concern for that industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab11a3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages the contractor to develop capabilities and characteristics typically desired in contractors that are competitive as an other-than-small business in that industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Covered small businesses may be provided assistance as part of any procurement technical assistance furnished pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered contract” means a contract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaab11a41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awarded to a qualified small business concern as defined pursuant to section 3(a) of the Small Business Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaab11a42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with an estimated annual value—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaab11a43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that will exceed the applicable receipt-based small business size standard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaab11a44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the contract is in an industry with an employee-based size standard, that will exceed $70,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4959/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered small business” means a qualified small business concern as defined pursuant to section 3(a) of the Small Business Act that has entered into a contract with the Department of Defense that includes a contract clause described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11a46-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVI/s1611/a/1/B"},"text":"Pub. L. 113–66, div. A, title XVI, § 1611(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/946"},"text":"127 Stat. 946","children":[],"tail":", § 2419; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/63"},"text":"Pub. L. 116–92, div. A, title IX, § 902(63)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1550"},"text":"133 Stat. 1550","children":[],"tail":"; renumbered § 4959, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1872/a/10"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1872(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4289"},"text":"134 Stat. 4289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/b/24"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(b)(24)","children":[],"tail":", (m)(2)(F), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2135"},"text":"135 Stat. 2135","children":[],"tail":", 2145.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab11a47-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab11a48-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaab11a49-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(a) of the Small Business Act, referred to in subsecs. (a)(2)(A) and (c)(1)(A), (2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"section 632(a) of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaab11a4a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/m/2/G"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(m)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2145"},"text":"135 Stat. 2145","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/11"},"text":"Pub. L. 116–283, § 1872(a)(11)","children":[],"tail":", which had originally transferred "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2417"},"text":"section 2417 of this title","children":[],"tail":" to this section. After amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1872/a/11"},"text":"section 1872(a)(11) of Pub. L. 116–283","children":[],"tail":" instead transferred section 2417 to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4961"},"text":"section 4961 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaab11a4b-3a6f-11f1-a58a-d8db54b14ab5"},"text":