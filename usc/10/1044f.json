{"tag":"section","attrib":{"id":"ida85109f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1044f"},"text":"§ 1044f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies with respect to special trial counsel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida85109f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall establish policies with respect to the appropriate mechanisms and procedures that the Secretaries of the military departments shall establish relating to the activities of special trial counsel, including expected milestones for such Secretaries to fully implement such mechanisms and procedures. Subject to subsection (c), the policies shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida85109f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the establishment of a dedicated office within each military service from which office the activities of the special trial counsel of the military service concerned shall be supervised and overseen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida85109f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for the appointment of one lead special trial counsel, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida85109f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a judge advocate of that service in a grade no lower than O–7, with significant experience in military justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida85109f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the overall supervision and oversight of the activities of the special trial counsel of that service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida85109f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Secretary concerned, without intervening authority;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida85109f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that within each office created pursuant to paragraph (1), the special trial counsel and other personnel assigned or detailed to the office—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida85109fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are independent of the military chains of command of both the victims and those accused of covered offenses and any other offenses over which a special trial counsel at any time exercises authority in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s824a"},"text":"section 824a of this title","children":[],"tail":" (article 24a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida85109fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct assigned activities free from unlawful or unauthorized influence or coercion;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida85109fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that special trial counsel shall be well-trained, experienced, highly skilled, and competent in handling cases involving covered offenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida85109fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that commanders of the victim and the accused in a case involving a covered offense shall have the opportunity to provide input to the special trial counsel regarding case disposition, but that the input is not binding on the special trial counsel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida85109fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniformity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that any lack of uniformity in the implementation of policies, mechanisms, and procedures established under subsection (a) does not render unconstitutional any such policy, mechanism, or procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida85109ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Trial Counsel of Department of the Air Force","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing policies under subsection (a), the Secretary of Defense shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8510a00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of providing for separate offices for the Air Force and Space Force under subsection (a)(1), provide for the establishment of a single dedicated office from which office the activities of the special trial counsel of the Department of the Air Force shall be supervised and overseen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of providing for separate lead special trial counsels for the Air Force and Space Force under subsection (a)(2), provide for the appointment of one lead special trial counsel who shall be responsible for the overall supervision and oversight of the activities of the special trial counsel of the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8510a02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1044f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Service Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “military service” means the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8510a03-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s532/a"},"text":"Pub. L. 117–81, div. A, title V, § 532(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1694"},"text":"135 Stat. 1694","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s545/a"},"text":"Pub. L. 117–263, div. A, title V, § 545(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2584"},"text":"136 Stat. 2584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8510a04-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8510a05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8510a06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s545/a/1"},"text":"Pub. L. 117–263, § 545(a)(1)","children":[],"tail":", substituted “Subject to subsection (c), the policies shall” for “The policies shall” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s545/a/2"},"text":"Pub. L. 117–263, § 545(a)(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8510a07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8510a08-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s545/b"},"text":"Pub. L. 117–263, div. A, title V, § 545(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2584"},"text":"136 Stat. 2584","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tV/s545/b"},"text":"“The amendments made subsection (a) [amending this section] shall take effect immediately after the coming into effect of the amendments made by section 532 of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/135/1694"},"text":"135 Stat. 1694","children":[],"tail":") [enacting this section] as provided in section 539C of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8510a09-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is two years after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", and applicable with respect to offenses that occur after that date, with provisions for delayed effect and applicability if regulations are not prescribed by the President before the date that is two years after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539C"},"text":"section 539C of Pub. L. 117–81","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
