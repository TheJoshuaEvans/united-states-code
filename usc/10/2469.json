{"tag":"section","attrib":{"id":"ida97fed0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469"},"text":null,"children":[{"tag":"num","attrib":{"value":"2469"},"text":"§ 2469.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts to perform workloads previously performed by depot-level activities of the Department of Defense: requirement of competition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida97fed0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Competition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that the performance of a depot-level maintenance and repair workload described in subsection (b) is not changed to performance by a contractor or by another depot-level activity of the Department of Defense unless the change is made using—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida97fed0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merit-based selection procedures for competitions among all depot-level activities of the Department of Defense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97fed10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competitive procedures for competitions among private and public sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97fed11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), subsection (a) applies to any depot-level maintenance and repair workload that has a value of not less than $3,000,000 (including the cost of labor and materials) and is being performed by a depot-level activity of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97fed12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Public-Private Partnerships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of subsection (a) may be waived in the case of a depot-level maintenance and repair workload that is performed at a Center of Industrial and Technical Excellence designated under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2474"},"text":"section 2474 of this title","children":[],"tail":" by a public-private partnership entered into under subsection (b) of such section consisting of a depot-level activity and a private entity."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97fed13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2469/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of OMB Circular A","children":[],"tail":"–76.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Office of Management and Budget Circular A–76 (or any successor administrative regulation or policy) does not apply to a performance change to which subsection (a) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida97fed14-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s353/a"},"text":"Pub. L. 102–484, div. A, title III, § 353(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2378"},"text":"106 Stat. 2378","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s346"},"text":"Pub. L. 103–160, div. A, title III, § 346","children":[],"tail":", title XI, § 1182(a)(7), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1625"},"text":"107 Stat. 1625","children":[],"tail":", 1771; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s338"},"text":"Pub. L. 103–337, div. A, title III, § 338","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2718"},"text":"108 Stat. 2718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s311/f/1"},"text":"Pub. L. 104–106, div. A, title III, § 311(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/248"},"text":"110 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIII"},"text":"Pub. L. 105–85, div. A, title III","children":[],"tail":", §§ 355(b), 363, "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1694"},"text":"111 Stat. 1694","children":[],"tail":", 1702; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s334"},"text":"Pub. L. 106–65, div. A, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/568"},"text":"113 Stat. 568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIII/s333"},"text":"Pub. L. 108–136, div. A, title III, § 333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1442"},"text":"117 Stat. 1442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida97fed15-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida97fed16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida97fed17-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s333/1"},"text":"Pub. L. 108–136, § 333(1)","children":[],"tail":", substituted “Except as provided in subsection (c), subsection” for “Subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s333/2"},"text":"Pub. L. 108–136, § 333(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" inserted “(including the cost of labor and materials)” after “$3,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s363"},"text":"Pub. L. 105–85, § 363","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s311/f/1"},"text":"Pub. L. 104–106, § 311(f)(1)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s355/b"},"text":"Pub. L. 105–85, § 355(b)","children":[],"tail":", substituted “maintenance and repair” for “maintenance or repair”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s311/f/1"},"text":"Pub. L. 104–106, § 311(f)(1)","children":[],"tail":", which directed repeal of this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/s363"},"text":"Pub. L. 105–85, § 363","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Competition","children":[],"tail":".—The Secretary of Defense or the Secretary of a military department may not change the performance of a depot-level maintenance workload that has a value of not less than $3,000,000 and is being performed by a depot-level activity of the Department of Defense to performance by a contractor unless the Secretary uses competitive procedures for the selection of the contractor to perform such workload."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of OMB Circular","children":[],"tail":" A–76.—The use of Office of Management and Budget Circular A–76 shall not apply to a performance change under subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s346"},"text":"Pub. L. 103–160, § 346","children":[],"tail":", amended section, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/7"},"text":"Pub. L. 103–160, § 1182(a)(7)","children":[],"tail":", (h), by designating existing provisions as subsec. (a), inserting heading, striking out “threshold” before “value”, substituting “to performance by a contractor unless the Secretary uses competitive procedures for the selection of the contractor to perform such workload” for “unless the Secretary uses competitive procedures to make the change”, and adding subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/7"},"text":"Pub. L. 103–160, § 1182(a)(7)","children":[],"tail":", struck out “, prior to any such change,” after “Department of Defense unless”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
