{"tag":"section","attrib":{"id":"idaa02ffc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense acquisition system; element of the defense acquisition system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa02ffc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Acquisition System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part, the term “defense acquisition system” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa02ffc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the workforce engaged in carrying out the acquisition of property and services for the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa02ffc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management structure responsible for directing and overseeing the acquisition of property and services for the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa02ffca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory, regulatory, and policy framework that guides the acquisition of property and services for the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa02ffcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Element of the Defense Acquisition System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this part, the term “element of the defense acquisition system” means an organization that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa02ffcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs members of the acquisition workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa02ffcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carries out acquisition functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa02ffce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focuses primarily on acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa02ffcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition","children":