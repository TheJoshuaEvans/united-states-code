{"tag":"section","attrib":{"id":"ida9930048-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612"},"text":null,"children":[{"tag":"num","attrib":{"value":"2612"},"text":"§ 2612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Defense University: acceptance of gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9930049-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may accept, hold, administer, and spend any gift, including a gift from an international organization and a foreign gift or donation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s343/f/4"},"text":"section 343(f)(4) of this title","children":[],"tail":"), that is made on the condition that it be used in connection with the operation or administration of the National Defense University. The Secretary may pay all necessary expenses in connection with the acceptance of a gift under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993004a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury a fund to be known as the “National Defense University Gift Fund”. Gifts of money, and the proceeds of the sale of property, received under subsection (a) shall be deposited in the fund. The Secretary may disburse funds deposited under this subsection for the benefit or use of the National Defense University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993004b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2601"},"text":"section 2601 of this title","children":[],"tail":" applies to property that is accepted under subsection (a) in the same manner that such subsection applies to property that is accepted under subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993004c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993004d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon request of the Secretary of Defense, the Secretary of the Treasury may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida993004e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain money, securities, and the proceeds of the sale of securities, in the National Defense University Gift Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida993004f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest money and reinvest the proceeds of the sale of securities in that fund in securities of the United States or in securities guaranteed as to principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930050-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interest and profits accruing from those securities shall be deposited to the credit of the fund and may be disbursed as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930051-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930052-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “gift” includes a devise of real property or a bequest of personal property and any gift of an interest in real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930053-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “National Defense University” includes any school or other component of the National Defense University specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2165/b"},"text":"section 2165(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930054-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2612/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9930055-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIX/s931/a"},"text":"Pub. L. 107–314, div. A, title IX, § 931(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2624"},"text":"116 Stat. 2624","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s931/d"},"text":"Pub. L. 108–136, div. A, title IX, § 931(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1581"},"text":"117 Stat. 1581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/44"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1596"},"text":"131 Stat. 1596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9930056-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9930057-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9930058-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “section 343(f)(4)” for “section 2166(f)(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “2166(f)(4)” for “2611(f)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
