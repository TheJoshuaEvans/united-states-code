{"tag":"section","attrib":{"id":"idaaa9ef0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892"},"text":null,"children":[{"tag":"num","attrib":{"value":"4892"},"text":"§ 4892.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of samples, drawings, information, equipment, materials, and certain services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaa9ef0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Secretaries of the military departments, under regulations prescribed by the Secretary of Defense and when determined by the Secretary of Defense or the Secretary concerned to be in the interest of national defense, may each—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaa9ef0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell, rent, lend, or give samples, drawings, and manufacturing or other information (subject to the rights of third parties) to any person or entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9ef0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sell, rent, or lend government equipment or materials to any person or entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaa9ef0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in independent research and development programs, subject to the condition that the equipment or material be used exclusively for such research and development; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaa9ef10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in demonstrations to a friendly foreign government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9ef11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to any person or entity, at an appropriate fee, the services of any government laboratory, center, range, or other testing facility for the testing of materials, equipment, models, computer software, and other items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaa9ef12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to any person or entity, through leases, contracts, or other appropriate arrangements, facilities, services, and equipment of any government laboratory, research center, or range, if the facilities, services, and equipment provided will not be in direct competition with the domestic private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9ef13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality of Test Results","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The results of tests performed with services made available under subsection (a)(3) are confidential and may not be disclosed outside the Federal Government without the consent of the persons for whom the tests are performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9ef14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fees made available under subsections (a)(3) and (a)(4) shall be established in the regulations prescribed pursuant to subsection (a). Such fees may not exceed the amount necessary to recoup the direct and indirect costs involved, such as direct costs of utilities, contractor support, and salaries of personnel that are incurred by the United States to provide for the testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaa9ef15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4892/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fees received under subsections (a)(3) and (a)(4) may be credited to the appropriations or other funds of the activity making such services available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaa9ef16-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s822/b/1"},"text":"Pub. L. 103–160, div. A, title VIII, § 822(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1705"},"text":"107 Stat. 1705","children":[],"tail":", § 2541; renumbered § 2539b, "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/a/13/A"},"text":"Pub. L. 103–337, div. A, title X, § 1070(a)(13)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2856"},"text":"108 Stat. 2856","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tIII/s3022"},"text":"Pub. L. 103–355, title III, § 3022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3333"},"text":"108 Stat. 3333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVIII/s804"},"text":"Pub. L. 104–106, div. A, title VIII, § 804","children":[],"tail":", div. D, title XLIII, § 4321(a)(8), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/390"},"text":"110 Stat. 390","children":[],"tail":", 671; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1066/a/23"},"text":"Pub. L. 106–65, div. A, title X, § 1066(a)(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/771"},"text":"113 Stat. 771","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tII/s232"},"text":"Pub. L. 110–181, div. A, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/46"},"text":"122 Stat. 46","children":[],"tail":"; renumbered § 4892, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1870/f/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1870(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4287"},"text":"134 Stat. 4287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaa9ef17-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaa9ef18-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaa9ef19-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2539b"},"text":"section 2539b of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s232/1"},"text":"Pub. L. 110–181, § 232(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s232/2"},"text":"Pub. L. 110–181, § 232(2)","children":[],"tail":", struck out “for services” before “made available” and substituted “subsections (a)(3) and (a)(4)” for “subsection (a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s232/3"},"text":"Pub. L. 110–181, § 232(3)","children":[],"tail":", struck out “for services made available” after “Fees received” and substituted “subsections (a)(3) and (a)(4)” for “subsection (a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “Secretaries of the military departments” for “secretaries of the military departments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s4321/a/8"},"text":"Pub. L. 104–106, § 4321(a)(8)","children":[],"tail":", made technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s3022"},"text":"Pub. L. 103–355, § 3022","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s804"},"text":"Pub. L. 104–106, § 804","children":[],"tail":", inserted “and indirect” after “recoup the direct”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2541"},"text":"section 2541 of this title","children":[],"tail":" as section 2539b."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s3022"},"text":"Pub. L. 103–355, § 3022","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s4321/a/8"},"text":"Pub. L. 104–106, § 4321(a)(8)","children":[],"tail":", inserted “rent,” after “sell,” in par. (1) and “, rent,” after “sell” in par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaa9ef1a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,