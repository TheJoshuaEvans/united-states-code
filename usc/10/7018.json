{"tag":"section","attrib":{"id":"idaad4f5b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7018"},"text":null,"children":[{"tag":"num","attrib":{"value":"7018"},"text":"§ 7018.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative Assistant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad4f5b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7018/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is an Administrative Assistant in the Department of the Army. The Administrative Assistant shall be appointed by the Secretary of the Army and shall perform duties that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f5b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7018/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a vacancy in the office of Secretary, the Administrative Assistant has charge and custody of all records, books, and papers of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f5b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7018/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may authorize the Administrative Assistant to sign, during the temporary absence of the Secretary, any paper requiring his signature. In such a case, the Administrative Assistant’s signature has the same effect as the Secretary’s signature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f5b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/159"},"text":"70A Stat. 159","children":[],"tail":", § 3016; renumbered § 3018, "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s501/a/3"},"text":"Pub. L. 99–433, title V, § 501(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1034"},"text":"100 Stat. 1034","children":[],"tail":"; renumbered § 7018, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad4f5b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad4f5ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad4f5bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3016(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3016(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3016(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:185.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:186.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:187.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 215; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1877-02-27/ch69"},"text":"Feb. 27, 1877, ch. 69","children":[],"tail":" (2d par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/19/241"},"text":"19 Stat. 241","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1874-03-04/ch44"},"text":"Mar. 4, 1874, ch. 44","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/18/19"},"text":"18 Stat. 19","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Although 5:185, 186, and 187 are omitted from the United States Code as covered by 5:181–5, they are not so superseded and are restated in this revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a), (b), and (c), the title “Administrative Assistant” is substituted for the title “Assistant and Chief Clerk”, to accord with present usage. R.S. 215 (less last sentence) is not contained in 5:185 and 186. It is also omitted from the revised section as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an inferior officer” are omitted, since the Secretary’s authority to appoint the Administrative Assistant makes the office an inferior office within the meaning of the Constitution. The words “perform duties that the Secretary considers appropriate” are substituted for the words “to be employed therein as he shall deem proper”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “During a vacancy in the office of Secretary * * * has” are substituted for the words “whenever the Secretary of the Army shall be removed from office by the President of the United States, or in any other case of vacancy, shall, during such vacancy have the”. The word “of” is substituted for the words “appertaining to”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “during the temporary absence of the Secretary” are substituted for the words “When, from illness or other cause, the Secretary of War is temporarily absent from the War Department”. The words “requisitions upon the Treasury Department” are omitted as surplusage. The last sentence is substituted for 5:187 (words after semicolon).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad4f5bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaad4f5bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3018"},"text":"section 3018 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3016"},"text":"section 3016 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaad4f5be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaad4f5bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
