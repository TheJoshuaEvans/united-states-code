{"tag":"section","attrib":{"id":"idab50dc22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8853"},"text":null,"children":[{"tag":"num","attrib":{"value":"8853"},"text":"§ 8853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court in which proceedings brought","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dc23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a prize is brought into a port of the United States, or the Commonwealths or possessions, proceedings for the adjudication of the prize cause shall be brought in the district in which the port is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a prize is brought into the territorial waters of a cobelligerent, or is brought into a locality in the temporary or permanent possession of, or occupied by, the armed forces of the United States, or is appropriated for the use of the United States, before proceedings are started, the venue of the proceedings for adjudication of the cause shall be in the judicial district selected by the Attorney General, or his designee, for the convenience of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8853/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the prize property is lost or entirely destroyed or if, because of its condition, no part of it has been or can be sent in for adjudication, proceedings for adjudication of the cause may be brought in any district designated by the Secretary of the Navy. In such cases the proceeds of anything sold shall be deposited with the Treasurer of the United States or public depositary in or nearest the district designated by the Secretary, subject to the orders of the court for that district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dc26-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/474"},"text":"70A Stat. 474","children":[],"tail":", § 7653; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/5"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; renumbered § 8853, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc27-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc28-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dc29-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7653(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1160"},"text":"34 U.S.C. 1160","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-18/ch553/s2"},"text":"Aug. 18, 1942, ch. 553, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7653(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1141"},"text":"34 U.S.C. 1141","children":[],"tail":" (less last sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4625 (less last sentence).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is inserted in order to present a complete statement of the subject matter of the section. Its substance is not specifically set out in the Revised Statutes but is strongly implied in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1135"},"text":"34 U.S.C. 1135","children":[],"tail":" which requires the United States attorney for the district in which the port is located to file a libel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the requisites for jurisdiction conferred under the 1942 Act are substituted for the words “brought under the jurisdiction conferred by this Act”. The substituted words are the same as those used in clauses (2), (3), and (4) of the preceding section except that the words “before proceedings are started” are added following the words “appropriated for the use of the United States” for clarity. An appropriation can take place before or after proceedings are commenced, but in the latter case there is no occasion for the Attorney General to determine venue.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “or if because the whole has been appropriated to the use of the United States” and the words “or the value of anything taken or appropriated for the use of the United States” are omitted. The provision in the 1942 Act which empowers the Attorney General to decide the venue of proceedings when the prize property has been appropriated is incompatible with the provision in R.S. 4625 which authorizes the Secretary of the Navy to select the judicial district in such cases. Hence the 1942 Act superseded R.S. 4625 with respect to cases of this type. Deposit of the value of prize property appropriated by the United States is adequately covered in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7663"},"text":"§ 7663 of this title","children":[],"tail":" and is not mentioned here. The second sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1141"},"text":"34 U.S.C. 1141","children":[],"tail":" (R.S. 4625), relating to proceedings by captors, is omitted because it was rendered inoperative by the "},{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch413/s13"},"text":"Act of March 3, 1899, ch. 413, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1007"},"text":"30 Stat. 1007","children":[],"tail":", which repealed all laws authorizing the distribution of prize money to captors."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dc2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab50dc2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8853, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/192"},"text":"Pub. L. 85–861, § 1(192)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1538"},"text":"72 Stat. 1538","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/75"},"text":"Pub. L. 86–559, § 1(75)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/280"},"text":"74 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1016/c"},"text":"Pub. L. 98–94, title X, § 1016(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/668"},"text":"97 Stat. 668","children":[],"tail":", related to computation of years of service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1629/c/3"},"text":"Pub. L. 103–337, div. A, title XVI, § 1629(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14706"},"text":"section 14706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dc2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7653"},"text":"section 7653 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Commonwealths or possessions” for “Territories, Commonwealths, or possessions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab50dc2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
