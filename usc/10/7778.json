{"tag":"section","attrib":{"id":"idaaffd698-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7778"},"text":null,"children":[{"tag":"num","attrib":{"value":"7778"},"text":"§ 7778.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licenses: military reservations; erection and use of buildings; Young Men’s Christian Association","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under such conditions as he may prescribe, the Secretary of the Army may issue a revocable license to the International Committee of Young Men’s Christian Associations of North America to erect and maintain on military reservations, inside the United States and the Commonwealths and possessions, buildings needed by that organization for the promotion of the social, physical, intellectual, and moral welfare of the members of the Army on those reservations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaaffd699-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/270"},"text":"70A Stat. 270","children":[],"tail":", § 4778; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/5"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":", 3441; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h/4/A/i"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)(4)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4377"},"text":"124 Stat. 4377","children":[],"tail":"; ren