{"tag":"section","attrib":{"id":"ida908c1b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product support manager","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida908c1b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A product support manager is the individual responsible for managing product support required to field and maintain the readiness and operational capability of a covered system throughout the life cycle of the covered system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c1b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate a product support manager for each covered system who shall be coequal with the program manager for such covered system and report directly to the portfolio acquisition executive responsible for such covered system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c1b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objectives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The product support manager shall seek to achieve the objectives of the defense acquisition system established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":" and shall identify, develop, implement, incentivize, and measure quantifiable best value outcome-based product support that optimizes life-cycle cost, readiness, and operational capability of a covered system."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c1b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A product support manager shall be responsible for the following with respect to a covered system:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c1b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and executing the product support strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4324"},"text":"section 4324 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing product support and subject matter expertise to the relevant program manager and portfolio acquisition executive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002074"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002074"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There are two pars. (3)."}],"tail":" Collaborating with chief engineers and systems engineers—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida908c1ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing the life-cycle sustainment plan and product support strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4324"},"text":"section 4324 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c1bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to analyze the operating and support costs to ensure cost-effective operation, management, and availability of the covered system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Adopting predictive analytics and simulation and modeling tools to improve materiel availability and reliability, increase operational availability rates, and reduce operation and sustainment costs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Conducting product support business case analyses to provide a structured, iterative methodology to compare and assess the full impact of product support alternatives and provide data-informed recommendations that balance requirements with affordability. Such analyses shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida908c1be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the development of the product support strategy as early as possible, but not later than Milestone B approval has been granted for the covered system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida908c1bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform proposed updates or changes in the product support strategy as needed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing and recommending resource allocations across product support integrators and product support providers to meet performance requirements of the product support strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating product support arrangements between product support integrators and product support providers across materiel commands, depots, sustainment working capital funds, and commercial entities to execute the product support strategy and maintain updated parts cataloging and provisioning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seeking to resolve issues relating to diminishing manufacturing supply, material shortages, critical ","children":[{"tag":"ref","attrib":{"idref":"fn002075"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “and”."}],"tail":" readiness items of supply."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Managing the end-to-end coordination process related to qualification, certification, and testing of alternative sources of supply for critical readiness items of supply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring the evaluation and selection of product support integrators and product support providers that are best suited to execute the product support strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida908c1c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida908c1c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “best value” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida908c1c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1733/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “covered system”, “critical readiness items of supply”, “product support”, “product support arrangement”, “product support integrator”, and “product support provider” have the meanings given, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4324"},"text":"section 4324 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida908c1c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1803/a/1"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1803(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1227"},"text":"139 Stat. 1227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida908c1c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida908c1ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida908c1cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1733 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1731"},"text":"section 1731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
