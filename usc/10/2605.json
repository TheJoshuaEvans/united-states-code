{"tag":"section","attrib":{"id":"ida9908eda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605"},"text":null,"children":[{"tag":"num","attrib":{"value":"2605"},"text":"§ 2605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gifts for defense dependents’ schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9908edb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may accept, hold, administer, and spend any gift (including any gift of an interest in real property) made on the condition that it be used in connection with the operation or administration of a defense dependents’ school. The Secretary may pay all necessary expenses in connection with the acceptance of a gift under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908edc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury a fund to be known as the “Department of Defense Dependents’ Education Gift Fund”. Gifts of money, and the proceeds of the sale of property, received under subsection (a) shall be deposited in the fund. The Secretary may disburse funds deposited under this subsection for the benefit or use of defense dependents’ schools, subject to the terms of the gift.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908edd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2601"},"text":"section 2601 of this title","children":[],"tail":" applies to property that is accepted under subsection (a) in the same manner that such subsection applies to property that is accepted under subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908ede-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908edf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon request of the Secretary of Defense, the Secretary of the Treasury may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9908ee0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain money, securities, and the proceeds of the sale of securities, in the Department of Defense Dependents’ Education Gift Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9908ee1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest money and reinvest the proceeds of the sale of securities in that fund in securities of the United States or in securities guaranteed as to principal and interest by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908ee2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interest and profits accruing from those securities shall be deposited to the credit of the fund and may be disbursed as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908ee3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “gift” includes a devise of real property or a bequest of personal property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908ee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9908ee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “defense dependents’ school” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9908ee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A school established as part of the defense dependents’ education system provided for under the Defense Dependents’ Education Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"20 U.S.C. 921","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9908ee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2605/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An elementary or secondary school established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2164"},"text":"section 2164 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9908ee8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIII/s314/a"},"text":"Pub. L. 99–661, div. A, title III, § 314(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3853"},"text":"100 Stat. 3853","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s353/a"},"text":"Pub. L. 103–337, div. A, title III, § 353(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2731"},"text":"108 Stat. 2731","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9908ee9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9908eea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9908eeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Defense Dependents’ Education Act of 1978, referred to in subsec. (g)(1), is title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/561"},"text":"Pub. L. 95–561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2365"},"text":"92 Stat. 2365","children":[],"tail":", as amended, which is classified principally to chapter 25A (§ 921 et seq.) of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"section 921 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9908eec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s353/c/1"},"text":"Pub. L. 103–337, § 353(c)(1)","children":[],"tail":", substituted “schools” for “education system” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s353/a/1"},"text":"Pub. L. 103–337, § 353(a)(1)","children":[],"tail":", substituted “a defense dependents’ school” for “the defense dependents’ education system provided for under the Defense Dependents’ Education Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s921"},"text":"20 U.S.C. 921","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s353/a/2"},"text":"Pub. L. 103–337, § 353(a)(2)","children":[],"tail":", substituted “defense dependents’ schools” for “the defense dependent’s education system”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s353/b"},"text":"Pub. L. 103–337, § 353(b)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
