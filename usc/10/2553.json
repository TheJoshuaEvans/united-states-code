{"tag":"section","attrib":{"id":"ida9871a1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553"},"text":null,"children":[{"tag":"num","attrib":{"value":"2553"},"text":"§ 2553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment and services: Presidential inaugural ceremonies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9871a1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may, with respect to the ceremonies relating to the inauguration of a President, provide the assistance referred to in subsection (b) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871a20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Presidential Inaugural Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional Joint Inaugural Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871a22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance that may be provided under subsection (a) is the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871a23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning and carrying out activities relating to security and safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning and carrying out ceremonial activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loan of property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other assistance that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Presidential Inaugural Committee shall reimburse the Secretary for any costs incurred in connection with the provision to the committee of assistance referred to in subsection (b)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs reimbursed under paragraph (1) shall be credited to the appropriations from which the costs were paid. The amount credited to an appropriation shall be proportionate to the amount of the costs charged to that appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871a2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loaned Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to property loaned for a presidential inauguration under subsection (b)(3), the Presidential Inaugural Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871a2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return that property within nine days after the date of the ceremony inaugurating the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give good and sufficient bond for the return in good order and condition of that property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indemnify the United States for any loss of, or damage to, that property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defray any expense incurred for the delivery, return, rehabilitation, replacement, or operation of that property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871a2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871a30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Presidential Inaugural Committee” means the committee referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s501"},"text":"section 501 of title 36","children":[],"tail":" that is appointed with respect to the inauguration of a President-elect and Vice President-elect."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871a31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2553/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “congressional Joint Inaugural Committee” means the joint committee of the Senate and House of Representatives referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s507"},"text":"section 507 of title 36","children":[],"tail":" that is appointed with respect to the inauguration of a President-elect and Vice President-elect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9871a32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/48/A"},"text":"Pub. L. 85–861, § 1(48)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1458"},"text":"72 Stat. 1458","children":[],"tail":", § 2543; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/81"},"text":"Pub. L. 96–513, title V, § 511(81)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2927"},"text":"94 Stat. 2927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s366/a"},"text":"Pub. L. 104–201, div. A, title III, § 366(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2495"},"text":"110 Stat. 2495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s4/a/2"},"text":"Pub. L. 105–225, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1498"},"text":"112 Stat. 1498","children":[],"tail":"; renumbered § 2553, "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1033(b)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–260.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9871a33-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9871a34-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9871a35-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2543(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2543(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2543(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:726 (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"36:726 (less 1st and 2d sentences).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"36:721(b)(1) (as applicable to 36:726).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"36:726 (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-06/ch974"},"text":"Aug. 6, 1956, ch. 974","children":[],"tail":", §§ 1(b)(1) (as applicable to § 6), 6, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/1049"},"text":"70 Stat. 1049","children":[],"tail":", 1050."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s721"},"text":"section 721 of title 36","children":[],"tail":"” are inserted for clarity. The words “ensigns” and “Red Cross flags” are omitted as covered by the word “flags”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “and the whole without expense to the United States” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “nine days after the date of the ceremony inaugurating the President” are substituted for the words “five days after the end of the inaugural period”, in 36:726 (2d sentence), and 36:721(b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9871a36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9871a37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2553 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2563"},"text":"section 2563 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9871a38-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2543"},"text":"section 2543 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225/s4/a/2/A"},"text":"Pub. L. 105–225, § 4(a)(2)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t36/s501"},"text":"section 501 of title 36","children":[],"tail":"” for “subsection (b)(2) of the first section of the Presidential Inaugural Ceremonies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t36/s721"},"text":"36 U.S.C. 721","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225/s4/a/2/B"},"text":"Pub. L. 105–225, § 4(a)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t36/s507"},"text":"section 507 of title 36","children":[],"tail":"” for “the proviso in section 9 of the Presidential Inaugural Ceremonies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t36/s729"},"text":"36 U.S.C. 729","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “Equipment and services: Presidential inaugural ceremonies” for “Equipment: Inaugural Committee” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Secretary of Defense, under such conditions as he may prescribe, may lend, to an Inaugural Committee established under the first section of the Presidential Inaugural Ceremonies Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s721"},"text":"36 U.S.C. 721","children":[],"tail":"), hospital tents, smaller tents, camp appliances, hospital furniture, flags other than battle flags, flagpoles, litters, and ambulances and the services of their drivers, that can be spared without detriment to the public service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Inaugural Committee must give a good and sufficient bond for the return in good order and condition of property lent under subsection (a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) Property lent under subsection (a) shall be returned within nine days after the date of the ceremony inaugurating the President. The Inaugural Committee shall—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) indemnify the United States for any loss of, or damage to, property lent under subsection (a); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) defray any expense incurred for the delivery, return, rehabilitation, replacement, or operation of that property.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “the first section of the Presidential Inaugural Ceremonies Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t36/s721"},"text":"36 U.S.C. 721","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t36/s721"},"text":"section 721 of title 36","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9898a39-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9898a3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
