{"tag":"section","attrib":{"id":"ida82628fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869"},"text":null,"children":[{"tag":"num","attrib":{"value":"869"},"text":"§ 869.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 69. Review by Judge Advocate General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82628fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon application by the accused or receipt of the record pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s864/c/3"},"text":"section 864(c)(3) of this title","children":[],"tail":" (article 64(c)(3)) and subject to subsections (b), (c), and (d), the Judge Advocate General may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82628ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a summary court-martial, modify or set aside, in whole or in part, the findings and sentence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8262900-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a general or special court-martial, order such court-martial to be reviewed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":" (article 66)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8262901-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8262902-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To qualify for consideration, an application under subsection (a) must be submitted to the Judge Advocate General not later than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8262903-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a summary court-martial, one year after the date of completion of review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s864"},"text":"section 864 of this title","children":[],"tail":" (article 64); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8262904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a general or special court-martial, one year after the end of the 90-day period beginning on the date the accused is provided notice of appellate rights under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s865/c"},"text":"section 865(c) of this title","children":[],"tail":" (article 65(c)), unless the accused submitted a waiver or withdrawal of appellate review under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s861"},"text":"section 861 of this title","children":[],"tail":" (article 61) before being provided notice of appellate rights, in which case the application must be submitted to the Judge Advocate General not later than one year after the entry of judgment under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s860c"},"text":"section 860c of this title","children":[],"tail":" (article 60c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8262905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Judge Advocate General may, for good cause shown, extend the period for submission of an application, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8262906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an application for review of a summary court martial, the Judge Advocate may not consider an application submitted more than three years after the completion date referred to in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8262907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in case of an application for review of a general or special court-martial, the Judge Advocate may not consider an application submitted more than three years after the end of the applicable period under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8262908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8262909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida826290a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case reviewed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s864"},"text":"section 864 of this title","children":[],"tail":" (article 64), the Judge Advocate General may set aside the findings or sentence, in whole or in part, on the grounds of newly discovered evidence, fraud on the court, lack of jurisdiction over the accused or the offense, error prejudicial to the substantial rights of the accused, or the appropriateness of the sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida826290b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In setting aside findings or sentence, the Judge Advocate General may order a rehearing, except that a rehearing may not be ordered in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s844"},"text":"section 844 of this title","children":[],"tail":" (article 44)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida826290c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Judge Advocate General sets aside findings and sentence and does not order a rehearing, the Judge Advocate General shall dismiss the charges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida826290d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida826290e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to clause (ii), if the Judge Advocate General sets aside findings and orders a rehearing and the convening authority determines that a rehearing would be impracticable, the convening authority shall dismiss the charges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida826290f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a case was referred to trial by a special trial counsel, a special trial counsel shall determine if a rehearing is impracticable and shall dismiss the charges if the special trial counsel so determines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8262910-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case reviewed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s865/b"},"text":"section 865(b) of this title","children":[],"tail":" (article 65(b)), review under this section is limited to the issue of whether the waiver or withdrawal of an appeal was invalid under the law. If the Judge Advocate General determines that the waiver or withdrawal of an appeal was invalid, the Judge Advocate General shall send the case to the Court of Criminal Appeals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8262911-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Court of Criminal Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8262912-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Court of Criminal Appeals may review the action taken by the Judge Advocate General under subsection (c)(1) in a case submitted to the Court of Criminal Appeals by the accused in an application for review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8262913-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Court of Criminal Appeals may grant an application under paragraph (1) only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8262914-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application demonstrates a substantial basis for concluding that the action on review under subsection (c) constituted prejudicial error; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8262915-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the application is filed not later than the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8262916-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days after the date on which the accused is notified of the decision of the Judge Advocate General; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8262917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days after the date on which a copy of the decision of the Judge Advocate General is deposited in the United States mails for delivery by first-class certified mail to the accused at an address provided by the accused or, if no such address has been provided by the accused, at the latest address listed for the accused in his official service record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8262918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The submission of an application for review under this subsection does not constitute a proceeding before the Court of Criminal Appeals for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s870/c/1"},"text":"section 870(c)(1) of this title","children":[],"tail":" (article 70(c)(1))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8262919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s869/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action Only on Matters of Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":" (article 66), in any case reviewed by a Court of Criminal Appeals under subsection (d), the Court may take action only with respect to matters of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida826291a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/61"},"text":"70A Stat. 61","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/30"},"text":"Pub. L. 90–632, § 2(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1342"},"text":"82 Stat. 1342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/81/s6"},"text":"Pub. L. 97–81, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-11-20"},"text":"Nov. 20, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1089"},"text":"95 Stat. 1089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/209/s7/e/1"},"text":"Pub. L. 98–209, § 7(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1402"},"text":"97 Stat. 1402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXIII"},"text":"Pub. L. 101–189, div. A, title XIII","children":[],"tail":", §§ 1302(a), 1304(b)(1), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1576"},"text":"103 Stat. 1576","children":[],"tail":", 1577; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s924/c/2"},"text":"Pub. L. 103–337, div. A, title IX, § 924(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2831"},"text":"108 Stat. 2831","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLIX/s5333"},"text":"Pub. L. 114–328, div. E, title LIX, § 5333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2935"},"text":"130 Stat. 2935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/c/1/L"},"text":"Pub. L. 115–91, div. A, title X, § 1081(c)(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1598"},"text":"131 Stat. 1598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s539A/d"},"text":"Pub. L. 117–81, div. A, title V, § 539A(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1699"},"text":"135 Stat. 1699","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s544/c"},"text":"Pub. L. 117–263, div. A, title V, § 544(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2582"},"text":"136 Stat. 2582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida826291b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida826291c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida826291d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"869","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:656.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 69), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/130"},"text":"64 Stat. 130","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “may” is substituted for the word “will”. The word “under” is substituted for the words “pursuant to the provisions of”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida826291e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida826291f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/c/1"},"text":"Pub. L. 117–263, § 544(c)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “Upon application by the accused and subject to subsections (b), (c), and (d), the Judge Advocate General may modify or set aside, in whole or in part, the findings and sentence in a court-martial that is not reviewed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":" (article 66).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/c/2"},"text":"Pub. L. 117–263, § 544(c)(2)","children":[],"tail":", designated existing provisions as par. (1), substituted “not later than—” and subpars. (A) and (B) for “not later than one year after the date of completion of review under section 864 or 865 of this title (article 64 or 65), as the case may be. The Judge Advocate General may, for good cause shown, extend the period for submission of an application, but may not consider an application submitted more than three years after such completion date.” and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/c/3/A"},"text":"Pub. L. 117–263, § 544(c)(3)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s864"},"text":"section 864 of this title","children":[],"tail":" (article 64)” for “section 864 or 865(b) of this title (article 64 or 65(b))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/c/3/B"},"text":"Pub. L. 117–263, § 544(c)(3)(B)","children":[],"tail":", substituted “the Judge Advocate General shall send the case to the Court of Criminal Appeals” for “the Judge Advocate General shall order appropriate corrective action under rules prescribed by the President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/c/4/A"},"text":"Pub. L. 117–263, § 544(c)(4)(A)","children":[],"tail":", substituted “under subsection (c)(1) in a case submitted” for “under subsection (c)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in a case sent to the Court of Criminal Appeals by order of the Judge Advocate General; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in a case submitted”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/c/4/B"},"text":"Pub. L. 117–263, § 544(c)(4)(B)","children":[],"tail":", substituted “paragraph (1)” for “paragraph (1)(B)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" designated existing provisions as cl. (i), substituted “Subject to clause (ii), if the Judge Advocate General” for “If the Judge Advocate General” and “impracticable” for “impractical”, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted comma after “in whole or in part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section related to review in the office of the Judge Advocate General."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “Court of Criminal Appeals” for “Court of Military Review” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1304/b/1"},"text":"Pub. L. 101–189, § 1304(b)(1)","children":[],"tail":", which directed amendment of subsec. (a) by striking “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s867/b/2"},"text":"section 867(b)(2) of this title","children":[],"tail":" (article 67(b)(2))” in the third sentence and inserting in lieu thereof “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s867/a/2"},"text":"section 867(a)(2) of this title","children":[],"tail":" (article 67(a)(2))”, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1302/a/1"},"text":"Pub. L. 101–189, § 1302(a)(1)","children":[],"tail":", which struck out the third sentence, see below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1302/a/1"},"text":"Pub. L. 101–189, § 1302(a)(1)","children":[],"tail":", struck out the third sentence, which read as follows: “If the Judge Advocate General so directs, the record shall be reviewed by a Court of Military Review under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":" (article 66), but in that event there may be no further review by the Court of Military Appeals except under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s867/b/2"},"text":"section 867(b)(2) of this title","children":[],"tail":" (article 67(b)(2)).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1302/a/2"},"text":"Pub. L. 101–189, § 1302(a)(2)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" amended section generally. Prior to amendment section provided that every record of trial by general court-martial, in which there had been a finding of guilty and a sentence, the appellate review of which was not otherwise provided for by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":", was to be examined in the office of the Judge Advocate General; that if any part of the findings or sentence was found unsupported in law, or if the Judge Advocate General so directed, the record was to be reviewed by a board of review in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":", but in that event there could be no further review by the Court of Military Appeals except under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s867/b/2"},"text":"section 867(b)(2) of this title","children":[],"tail":", that notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s876"},"text":"section 876 of this title","children":[],"tail":", the findings or sentence, or both, in a court-martial case which had been finally reviewed, but had not been reviewed by a Court of Military Review could be vacated or modified, in whole or in part, by the Judge Advocate General on the ground of newly discovered evidence, fraud on the court, lack of jurisdiction over the accused or the offense, or error prejudicial to the substantial rights of the accused; and that when such a case was considered upon application of the accused, the application had to be filed in the Office of the Judge Advocate General by the accused before: (1) "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", or (2) the last day of the two-year period beginning on the date the sentence was approved by the convening authority or, in a special court-martial case which required action under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s865/b"},"text":"section 865(b) of this title","children":[],"tail":", the officer exercising general court-martial jurisdiction, whichever was later, unless the accused established good cause for failure to file within that time."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/81"},"text":"Pub. L. 97–81","children":[],"tail":" inserted provision that, when a case is considered upon application of the accused, the application must be filed in the Office of the Judge Advocate General by the accused before (1) "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", or (2) the last day of the two-year period beginning on the date the sentence is approved by the convening authority or, in a special court-martial case which requires action under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s865/b"},"text":"section 865(b) of this title","children":[],"tail":" (article 65(b)), the officer exercising general court-martial jurisdiction, whichever is later, unless the accused establishes good cause for failure to file within that time."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" authorized the Judge Advocate General to either vacate or modify the findings or sentence, or both, in whole or in part, in any court-martial case which has been finally reviewed, but which has not been reviewed by a Court of Military Review, because of newly discovered evidence, fraud on the court, lack of jurisdiction over the accused or the offense, or error prejudicial to the substantial rights of the accused."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8262920-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262921-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" not applicable to any matter that was submitted before "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", to a Judge Advocate General under this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s544/d/2"},"text":"section 544(d)(2) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s861"},"text":"section 861 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262922-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" effective on the date that is two years after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", and applicable with respect to offenses that occur after that date, with provisions for delayed effect and applicability if regulations are not prescribed by the President before the date that is two years after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539C"},"text":"section 539C of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262923-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after the amendments made by div. E (§§ 5001–5542) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" take effect as provided for in section 5542 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/c/4"},"text":"section 1081(c)(4) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262924-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262925-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXIII/s1302/b"},"text":"Pub. L. 101–189, div. A, title XIII, § 1302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1576"},"text":"103 Stat. 1576","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tXIII/s1302/b"},"text":"“Subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s869"},"text":"section 869 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to cases in which a finding of guilty is adjudged by a general court-martial after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262926-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" effective first day of eighth calendar month beginning after "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", but not to apply to any case in which the findings and sentence were adjudged by a court-martial before that date, and the proceedings in any such case to be held in the same manner and with the same effect as if such amendments had not been enacted, see section 12(a)(1), (4) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262927-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/81"},"text":"Pub. L. 97–81","children":[],"tail":" effective at end of 60-day period beginning on "},{"tag":"date","attrib":{"date":"1981-11-20"},"text":"Nov. 20, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/81/s7/a"},"text":"section 7(a) of Pub. L. 97–81","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s706"},"text":"section 706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8262928-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s4/b"},"text":"section 4(b) of Pub. L. 90–632","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8262929-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Two-Year Period for Applications for Modification or Set-Aside Inapplicable to Applications Filed On or Before ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209/s7/e/2"},"text":"Pub. L. 98–209, § 7(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1403"},"text":"97 Stat. 1403","children":[],"tail":", provided that the two-year period specified under the second sentence of subsec. (b) of this section did not apply to any application filed in the office of the appropriate Judge Advocate General on or before "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 1983","children":[],"tail":", and that the application in such a case would be considered in the same manner and with the same effect as if such two-year period had not been enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
