","attrib":{},"text":" the Commandant of the Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7780f90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s171/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7780f91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Armed Forces Policy Council shall advise the Secretary of Defense on matters of broad policy relating to the armed forces and shall consider and report on such other matters as the Secretary of Defense may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7780f92-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/8"},"text":"70A Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/599/s9/c"},"text":"Pub. L. 85–599, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/521"},"text":"72 Stat. 521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/596/s5"},"text":"Pub. L. 92–596, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-27"},"text":"Oct. 27, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1318"},"text":"86 Stat. 1318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/140/s3/b"},"text":"Pub. L. 95–140, § 3(b)","children":[],"tail":", "},{"tag":"date",