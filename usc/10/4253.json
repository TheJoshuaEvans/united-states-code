{"tag":"section","attrib":{"id":"idaa6e6b83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253"},"text":null,"children":[{"tag":"num","attrib":{"value":"4253"},"text":"§ 4253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major defense acquisition programs: submissions to Congress on Milestone C","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa6e6b84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Brief Summary Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days after granting Milestone C approval for a major defense acquisition program, the milestone decision authority for the program shall provide to the congressional defense committees and, in the case of intelligence or intelligence-related activities, the congressional intelligence committees a brief summary report that contains the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa6e6b85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The estimated cost and schedule for the program established by the military department concerned, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa6e6b86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar values estimated for the program acquisition unit cost, average procurement unit cost, and total life-cycle cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa6e6b87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned dates for initial operational test and evaluation and initial operational capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6b88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The independent estimated cost for the program established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3221/b/6"},"text":"section 3221(b)(6) of this title","children":[],"tail":", and any independent estimated schedule for the program, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa6e6b89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar values estimated for the program acquisition unit cost, average procurement unit cost, and total life-cycle cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa6e6b8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned dates for initial operational test and evaluation and initial operational capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6b8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of any production, manufacturing, and fielding risks associated with the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa6e6b8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the sufficiency of the developmental test and evaluation completed, including the use of automated data analytics or modeling and simulation tools and methodologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6b8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of any of the congressional defense committees or, in the case of intelligence or intelligence-related activities, the congressional intelligence committees, the milestone decision authority shall submit to the committee further information or underlying documentation for the information in a brief summary report submitted under subsection (a), including the independent cost and schedule estimates and the independent technical risk assessments referred to in that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6b8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Intelligence Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “congressional intelligence committees” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s437/c"},"text":"section 437(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa6e6b8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s808/c/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2265"},"text":"130 Stat. 2265","children":[],"tail":", § 2366c; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s838/a/2"},"text":"Pub. L. 115–91, div. A, title VIII, § 838(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1474"},"text":"131 Stat. 1474","children":[],"tail":"; renumbered § 4253 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1847/d/3"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1847(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4256"},"text":"134 Stat. 4256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa6e6b90-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa6e6b91-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa6e6b92-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2366c"},"text":"section 2366c of this title","children":[],"tail":" as this section and, in subsec. (a)(2), substituted “section 3221(b)(6)” for “section 2334(a)(6)” in introductory provisions. Section was inserted after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":", as renumbered by par. (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/d"},"text":"section 1847(d) of Pub. L. 116–283","children":[],"tail":", to reflect the probable intent of Congress, notwithstanding language directing this section be inserted after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":" “as transferred and redesignated by paragraph (3)” of section 1847(d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa6e6b93-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa6e6b94-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa6e6b95-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Responsibility for Conducting Assessments; Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions designating officials responsible for conducting assessments and provisions requiring guidance for assessments under subsec. (a)(4) of this section, see section 838(a)(3), (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
