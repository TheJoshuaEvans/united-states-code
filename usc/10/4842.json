{"tag":"section","attrib":{"id":"idaa9e071d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842"},"text":null,"children":[{"tag":"num","attrib":{"value":"4842"},"text":"§ 4842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Defense Manufacturing Technology Panel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa9e071e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department of Defense the Joint Defense Manufacturing Technology Panel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e071f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0720-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Panel shall be cochaired by the Under Secretary of Defense for Acquisition and Sustainment and the Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0721-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Panel shall be composed of at least one individual from among appropriate personnel of each military department and Defense Agency with manufacturing technology programs. The Panel may include as ex-officio members such individuals from other government organizations, academia, and industry as the Chair considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0722-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of the Panel shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0723-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify and integrate requirements for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0724-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct joint planning for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0725-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop joint strategies for the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e0726-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the purposes specified in subsection (c), the Panel shall perform the functions as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa9e0727-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct comprehensive reviews and assessments of defense-related manufacturing issues being addressed by the manufacturing technology programs and related activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0728-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Execute strategic planning to identify joint planning opportunities for increased cooperation in the development and implementation of technological products and the leveraging of funding for such purposes with the private sector and other government agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e0729-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensure the integration and coordination of requirements and programs under the program with the Office of the Secretary of Defense and other national-level initiatives, including the establishment of information exchange processes with other government agencies, private industry, academia, and professional associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa9e072a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conduct such other functions as the Under Secretary of Defense for Research and Engineering shall specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e072b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Panel shall report to and receive direction from one or more individuals designated by the Under Secretary of Defense for Research and Engineering for purposes of this subsection on manufacturing technology issues of multi-service concern and application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa9e072c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4842/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administrative expenses of the Panel shall be borne by each military department and Defense Agency with manufacturing technology programs in such manner as the Panel shall provide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa9e072d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1869/c/1/B"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1869(c)(1)(B)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4283"},"text":"134 Stat. 4283","children":[],"tail":", 4284; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1846/a/1"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1846(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1261"},"text":"139 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa9e072e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa9e072f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":