n":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1552"},"text":"133 Stat. 1552","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa9e0731-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4842 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7842"},"text":"section 7842 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa9e0732-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “The Panel shall be cochaired by the Under Secretary of Defense for Acquisition and Sustainment and the Under Secretary of Defense for Research and Engineering.” for “The Chair of the Joint Defense Manufacturing Technology Panel shall be the head of the Panel. The Chair shall be appointed, on a rotating basis, from among the appropriate personnel of the military departments and Defense Agencies with manufacturing technology programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1869/c/2/A"},"text":"Pub. L. 116–283, § 1869(c)(2)(A)","children":[],"tail":", (B), struck out subsec. (e) designation and heading and redesignated pars. (1) to (6) as subsecs. (a) to (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1869/c/1/B"},"text":"Pub. L. 116–283, § 1869(c)(1)(B)","children":[],"tail":", transferred subsec. (e), related to Joint Defense Manufacturing Technology Panel, of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4841"},"text":"section 4841 of this title","children":[],"tail":" to this section and added section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1869/c/2/C"},"text":"Pub. L. 116–283, § 1869(c)(2)(C)","children":[],"tail":", redesignated subpars. (A) and (B) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1869/c/2/D"},"text":"Pub. L. 116–283, § 1869(c)(2)(D)","children":[],"tail":", redesignated subpars. (A) to (C) as pars. (1) to (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1869/c/2/E"},"text":"Pub. L. 116–283, § 1869(c)(2)(E)","children":[],"tail":", substituted “subsection (c)” for “paragraph (3)” in introductory provisions and redesignated subpars. (A) to (D) as pars. (1) to (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1869/c/2/F"},"text":"Pub. L. 116–283, § 1869(c)(2)(F)","children":[],"tail":", substituted “this subsection” for “this paragraph”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa9e0733-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa9e0734-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
