{"tag":"section","attrib":{"id":"idab63ef1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084"},"text":null,"children":[{"tag":"num","attrib":{"value":"9084"},"text":"§ 9084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Chief of Space Operations: function; composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63ef1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the executive part of the Department of the Air Force an Office of the Chief of Space Operations to assist the Secretary of the Air Force in carrying out the responsibilities of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of the Chief of Space Operations is composed of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other members of the Space Force and Air Force assigned or detailed to the Office of the Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian employees in the Department of the Air Force assigned or detailed to the Office of the Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9084/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise specifically prescribed by law, the Office of the Chief of Space Operations shall be organized in such manner, and the members of the Office of the Chief of Space Operations shall perform such duties and have such titles, as the Secretary of the Air Force may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef21-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s921/a"},"text":"Pub. L. 116–283, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3805"},"text":"134 Stat. 3805","children":[],"tail":", § 9083; renumbered § 9084, "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s509C/a/1"},"text":"Pub. L. 118–159, div. A, title V, § 509C(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1873"},"text":"138 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab63ef22-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab63ef23-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idab63ef24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 9084 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9087"},"text":"section 9087 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab63ef25-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9084 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9085"},"text":"section 9085 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 9084 was successively renumbered section 9068, then 9083, of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s952/b/1"},"text":"Pub. L. 116–92, div. A, title IX, § 952(b)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1561"},"text":"133 Stat. 1561","children":[],"tail":", 1562, and was subsequently repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s921/a"},"text":"Pub. L. 116–283, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3804"},"text":"134 Stat. 3804","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab63ef26-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9083"},"text":"section 9083 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab63ef27-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab63ef28-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s921/c"},"text":"Pub. L. 116–283, div. A, title IX, § 921(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3805"},"text":"134 Stat. 3805","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIX/s921/c"},"text":"“The amendments made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of this title","children":[],"tail":" relating to general duties of the Office of the Chief of Space Operations, repealing former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9083"},"text":"section 9083 of this title","children":[],"tail":", and enacting provisions set out as a note below] shall take effect on the date on which the Secretary of the Air Force and the Chief of Space Operations jointly submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report detailing the functions that the headquarters staff of the Department of the Air Force will continue to perform in support of the Space Force.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab63ef29-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Authorization of Additional Military Billets","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s921/d"},"text":"Pub. L. 116–283, div. A, title IX, § 921(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3806"},"text":"134 Stat. 3806","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tIX/s921/d"},"text":"“The Secretary shall establish the Office of the Chief of Space Operations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9083"},"text":"section 9083 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"10 U.S.C. 9084","children":[],"tail":"], as amended by subsection (a), using military personnel otherwise authorized. Nothing in this section [enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of this title","children":[],"tail":" relating to general duties of the Office of the Chief of Space Operations, repealing former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9083"},"text":"section 9083 of this title","children":[],"tail":", and enacting provisions set out as a note above] or the amendments made by this section shall be construed to authorize additional military billets for the purposes of, or in connection with, the establishment of the Office of the Chief of Space Operations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
