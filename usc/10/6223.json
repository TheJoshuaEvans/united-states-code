{"tag":"section","attrib":{"id":"idaac69dcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6223"},"text":null,"children":[{"tag":"num","attrib":{"value":"6223"},"text":"§ 6223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Background investigations of certain personnel at Department of Energy facilities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall ensure that an investigation meeting the requirements of section 145 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2165"},"text":"42 U.S.C. 2165","children":[],"tail":") is made for each Department of Energy employee, or contractor employee, at a national security laboratory or nuclear weapons production facility who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69dd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6223/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carries out duties or responsibilities in or around a location where Restricted Data is present; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69dd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6223/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has or may have regular access to a location where Restricted Data is present.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69dd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1403"},"text":"139 Stat. 1403","chi