{"tag":"section","attrib":{"id":"idaa7f0e39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509"},"text":null,"children":[{"tag":"num","attrib":{"value":"4509"},"text":"§ 4509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for advisory and assistance services: cost comparison studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa7f0e3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa7f0e3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa7f0e3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before the Secretary of Defense enters into a contract described in subparagraph (B), the Secretary shall determine whether Department of Defense personnel have the capability to perform the services proposed to be covered by the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa7f0e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) applies to any contract of the Department of Defense for advisory and assistance services that is expected to have a value in excess of $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7f0e3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines that Department of Defense personnel have the capability to perform the services to be covered by the contract, the Secretary shall conduct a study comparing the cost of performing the services with Department of Defense personnel and the cost of performing the services with contractor personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa7f0e3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may, pursuant to guidelines prescribed by the Secretary, waive the requirement to perform a cost comparison study under subsection (a)(2) based on factors that are not related to cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa7f0e40-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s363/a/1"},"text":"Pub. L. 103–337, div. A, title III, § 363(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2733"},"text":"108 Stat. 2733","children":[],"tail":", § 2410"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"; renumbered § 4509, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1856/g"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1856(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4275"},"text":"134 Stat. 4275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa7f0e41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa7f0e42-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa7f0e43-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4531, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/253"},"text":"70A Stat. 253","children":[],"tail":", authorized Secretary of the Army to procure materials and facilities necessary to maintain and support the Army, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s823/2"},"text":"Pub. L. 103–160, div. A, title VIII, § 823(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1707"},"text":"107 Stat. 1707","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4532 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7532"},"text":"section 7532 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4533 to 4535 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s823/3"},"text":"Pub. L. 103–160, div. A, title VIII, § 823(3)","children":[],"tail":"–(5), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 