n market at Army posts, within maximum prices prescribed by Secretary of the Army, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/482/s1/a"},"text":"Pub. L. 91–482, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1082"},"text":"84 Stat. 1082","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 4540 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7540"},"text":"section 7540 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 4541 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7541"},"text":"section 7541 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 4542 to 4544, 4551 to 4555, and 4561 to 4565 were renumbered sections 7542 to 7544, 7551 to 7555, and 7561 to 7565 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa7f0e44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered section 2410"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa7f0e45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa7f0e46-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa7f0e47-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s363/c"},"text":"Pub. L. 103–337, div. A, title III, § 363(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2734"},"text":"108 Stat. 2734","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tIII/s363/c"},"text":"“Section 2410","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 10, United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4509"},"text":"10 U.S.C. 4509","children":[],"tail":"], as added by subsection (a), shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa7f0e48-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procedures for Conduct of Studies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s363/b"},"text":"Pub. L. 103–337, div. A, title III, § 363(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2734"},"text":"108 Stat. 2734","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tIII/s363/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense shall prescribe the following procedures:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for carrying out a cost comparison study under subsection (a)(2) of section 2410","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 10, United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4509/a/2"},"text":"10 U.S.C. 4509(a)(2)","children":[],"tail":"], as added by subsection (a), which may contain a requirement that the cost comparison study include consideration of factors that are not related to cost, including the quality of the service required to be performed, the availability of Department of Defense personnel, the duration and recurring nature of the services to be performed, and the consistency of the workload."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for reviewing contracts entered into after a waiver under subsection (b) of such section to determine whether the contract is justified and sufficiently documented.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
