{"tag":"section","attrib":{"id":"idab7e2ddd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9512"},"text":null,"children":[{"tag":"num","attrib":{"value":"9512"},"text":"§ 9512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil Reserve Air Fleet contracts: payment rate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7e2dde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall determine a fair and reasonable rate of payment for airlift services provided to the Department of Defense by air carriers who are participants in the Civil Reserve Air Fleet program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2ddf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations for purposes of subsection (a). The Secretary may exclude from the applicability of those regulations any airlift services contract made through the use of competitive procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2de0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commitment of Aircraft as a Business Factor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may, in determining the quantity of business to be received under an airlift services contract for which the rate of payment is determined in accordance with subsection (a), use as a factor the relative amount of airlift capability committed by each air carrier to the Civil Reserve Air Fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2de1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9512/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicable Provisions of Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An airlift services contract for which the rate of payment is determined in accordance with subsection (a) shall not be subject to the provisions of chapter 271 of this title or to the provisions of subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1502"},"text":"section 1502 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7e2de2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s366/a"},"text":"Pub. L. 112–81, div. A, title III, § 366(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1380"},"text":"125 Stat. 1380","children":[],"tail":", § 9511a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1831/j/6"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1831(j)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4217"},"text":"134 Stat. 4217","children":[],"tail":"; renumbered § 9512 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1083/a/2/A"},"text":"Pub. L. 117–81, div. A, title X, § 1083(a)(2)(A)","children":[],"tail":", (c)(1)(A), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1922"},"text":"135 Stat. 1922","children":[],"tail":", 1923.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab7e2de3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab7e2de4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab7e2de5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9512 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9513"},"text":"section 9513 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab7e2de6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9511a"},"text":"section 9511a of this title","children":[],"tail":" as this section and substituted “Secretary” for “Secretary of Defense” in subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “chapter 271” for “section 2306a”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab7e2de7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab7e2de8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d/1"},"text":"section 1801(d)(1) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab7e2de9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s366/c"},"text":"Pub. L. 112–81, div. A, title III, § 366(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1381"},"text":"125 Stat. 1381","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tIII/s366/c"},"text":"“Regulations shall be prescribed under ","children":[{"tag":"re