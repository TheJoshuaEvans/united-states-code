{"tag":"section","attrib":{"id":"idab5cc3ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9036"},"text":null,"children":[{"tag":"num","attrib":{"value":"9036"},"text":"§ 9036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surgeon General: appointment; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5cc3ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Surgeon General of the Air Force shall be appointed by the President, by and with the advice and consent of the Senate from officers of the Air Force who are in the Air Force medical department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5cc3af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5cc3b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9036/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General serves as the principal advisor to the Secretary of the Air Force, the Chief of Staff of the Air Force, and the Chief of Space Operations on all health and medical matters of the Air Force and the Space Force, including strategic planning and policy development relating to such matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc3b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9036/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General serves as the chief medical advisor of the Air Force and the Space Force to the Director of the Defense Health Agency on matters pertaining to military health readiness requirements and safety of members of the Air Force and members of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc3b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9036/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Surgeon General, acting under the authority, direction, and control of the Secretary of the Air Force, shall recruit, organize, train, and equip, medical personnel of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5cc3b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/288/s5/a"},"text":"Pub. L. 89–288, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1050"},"text":"79 Stat. 1050","children":[],"tail":", § 8036; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s522/g/2"},"text":"Pub. L. 99–433, title V, § 522(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1063"},"text":"100 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s506/c"},"text":"Pub. L. 104–106, div. A, title V, § 506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/296"}