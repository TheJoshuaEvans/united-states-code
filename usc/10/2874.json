{"tag":"section","attrib":{"id":"ida9eb3259-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2874"},"text":null,"children":[{"tag":"num","attrib":{"value":"2874"},"text":"§ 2874.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing of housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eb325a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2874/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may enter into contracts for the lease of housing units that the Secretary determines are suitable for use as military family housing or military unaccompanied housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eb325b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2874/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Leased Units","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall utilize housing units leased under this section as military family housing or military unaccompanied housing, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eb325c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2874/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract under this section may be for any period that the Secretary concerned determines appropriate and may provide for the owner of the leased property to operate and maintain the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eb325d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/546"},"text":"110 Stat. 546","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dB/tXXVIII/s2802/b/1"},"text":"Pub. L. 107–314, div. B, title XXVIII, § 2802(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2703"},"text":"116 Stat. 2703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eb325e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eb325f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eb3260-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s2802/b/2"},"text":"Pub. L. 107–314, § 2802(b)(2)","children":[],"tail":", in section catchline struck out “to be constructed” after “Leasing of housing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s2802/b/1/B"},"text":"Pub. L. 107–314, § 2802(b)(1)(B)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “The Secretary concerned may enter into contracts for the lease of military family housing units or military unaccompanied housing units to be constructed under this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s2802/b/1"},"text":"Pub. L. 107–314, § 2802(b)(1)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
