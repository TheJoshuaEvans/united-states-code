{"tag":"section","attrib":{"id":"ida855eb84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1060b"},"text":"§ 1060b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military ID cards: dependents and survivors of retirees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida855eb85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Permanent ID Card","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855eb86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In issuing military ID cards to retiree dependents, the Secretary concerned shall issue a permanent ID card (not subject to renewal) to any such retiree dependent as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida855eb87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retiree dependent who has attained 75 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida855eb88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retiree dependent who is permanently disabled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855eb89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A permanent ID card shall be issued to a retiree dependent under paragraph (1)(A) upon the expiration, after the retiree dependent attains 75 years of age, of any earlier, renewable military card or, if earlier, upon the request of the retiree dependent after attaining age 75.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855eb8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855eb8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “military ID card” means a card or other form of identification used for purposes of demonstrating eligibility for any benefit from the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855eb8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “retiree dependent” means a person who is a dependent of a retired member of the uniformed services, or a survivor of a deceased retired member of the uniformed services, who is eligible for any benefit from the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida855eb8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s583/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 583(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1929"},"text":"118 Stat. 1929","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s598/a"},"text":"Pub. L. 109–364, div. A, title V, § 598(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2237"},"text":"120 Stat. 2237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida855eb8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida855eb8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida855eb90-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s598/b/1"},"text":"Pub. L. 109–364, § 598(b)(1)","children":[],"tail":", struck out “; issuance of permanent ID card after attaining 75 years of age” after “retirees” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s598/a"},"text":"Pub. L. 109–364, § 598(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “In issuing military ID cards to retiree dependents, the Secretary concerned shall issue a permanent ID card (not subject to renewal) to any such retiree dependent who has attained 75 years of age. Such a permanent ID card shall be issued upon the expiration, after the retiree dependent attains 75 years of age, of any earlier, renewable military ID card or, if earlier, upon the request of such a retiree dependent after attaining age 75.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida855eb91-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida855eb92-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s583/b"},"text":"Pub. L. 108–375, div. A, title V, § 583(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1929"},"text":"118 Stat. 1929","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dA/tV/s583/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1060b"},"text":"Section 1060b of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
