{"tag":"section","attrib":{"id":"ida817d15f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829"},"text":null,"children":[{"tag":"num","attrib":{"value":"829"},"text":"§ 829.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 29. Assembly and impaneling of members; detail of new members and military judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida817d160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assembly","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The military judge shall announce the assembly of a general or special court-martial with members. After such a court-martial is assembled, no member may be absent, unless the member is excused—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida817d161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a result of a challenge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d162-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (b)(1)(B); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d163-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by order of the military judge or the convening authority for disability or other good cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d164-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Impaneling","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida817d165-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under rules prescribed by the President, the military judge of a general or special court-martial with members shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida817d166-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after determination of challenges, impanel the court-martial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d167-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excuse the members who, having been assembled, are not impaneled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d168-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a general court-martial, the military judge shall impanel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida817d169-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 members in a capital case; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d16a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eight members in a noncapital case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d16b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a special court-martial, the military judge shall impanel four members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d16c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to members under subsection (b), the military judge shall impanel alternate members, if the convening authority authorizes alternate members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d16d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of New Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida817d16e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If, after members are impaneled, the membership of the court-martial is reduced to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida817d16f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fewer than 12 members with respect to a general court-martial in a capital case;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d170-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fewer than six members with respect to a general court-martial in a noncapital case; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d171-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fewer than four members with respect to a special court-martial;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the trial may not proceed unless the convening authority details new members and, from among the members so detailed, the military judge impanels new members sufficient in number to provide the membership specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d172-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The membership referred to in paragraph (1) is as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida817d173-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 members with respect to a general court-martial in a capital case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d174-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least six but not more than eight members with respect to a general court-martial in a noncapital case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida817d175-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four members with respect to a special court-martial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d176-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of New Military Judge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the military judge is unable to proceed with the trial because of disability or otherwise, a new military judge shall be detailed to the court-martial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida817d177-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida817d178-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of new members under subsection (d), the trial may proceed with the new members present after the evidence previously introduced is read or, in the case of audiotape, videotape, or similar recording, is played, in the presence of the new members, the military judge, the accused, and counsel for both sides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida817d179-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s829/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a new military judge under subsection (e), the trial shall proceed as if no evidence had been introduced, unless the evidence previously introduced is read or, in the case of audiotape, videotape, or similar recording, is played, in the presence of the new military judge, the accused, and counsel for both sides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida817d17a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/47"},"text":"70A Stat. 47","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/11"},"text":"Pub. L. 90–632, § 2(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1337"},"text":"82 Stat. 1337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/209/s3/d"},"text":"Pub. L. 98–209, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1394"},"text":"97 Stat. 1394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s582/c"},"text":"Pub. L. 107–107, div. A, title V, § 582(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1124"},"text":"115 Stat. 1124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLV/s5187"},"text":"Pub. L. 114–328, div. E, title LV, § 5187","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2902"},"text":"130 Stat. 2902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida817d17b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida817d17c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida817d17d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"829(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"829(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:593(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:593(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 29), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/117"},"text":"64 Stat. 117","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"829(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:593(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a), (b), and (c), the word “may” is substituted for the word “shall”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “details” is substituted for the word “appoints”, since the filling of the position involved is not appointment to an office in the constitutional sense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida817d17e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida817d17f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section related to absent and additional members of a general or special court-martial."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" designated existing provisions as par. (1), substituted “the applicable minimum number of members” for “five members” in two places, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" substituted “unless excused as a result of a challenge, excused by the military judge for physical disability or other good cause, or excused by order of the convening authority for good cause” for “except for physical disability or as a result of a challenge or by order of the convening authority for good cause”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/11/A"},"text":"Pub. L. 90–632, § 2(11)(A)","children":[],"tail":", substituted “court has been assembled for the trial of the accused” for “accused has been arraigned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/11/B"},"text":"Pub. L. 90–632, § 2(11)(B)","children":[],"tail":", inserted reference to court-martial composed of a military judge alone, struck out reference to oath of members, and inserted provisions requiring that only the evidence which has been introduced before members of the court be read to the court and that all evidence, not merely testimony, be included."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/11/C"},"text":"Pub. L. 90–632, § 2(11)(C)","children":[],"tail":", inserted reference to court-martial composed of a military judge alone, struck out reference to oath of members, and substituted evidence previously introduced for testimony of previously examined witnesses as the body of evidence which the verbatim record must cover."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d) ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/11/D"},"text":"Pub. L. 90–632, § 2(11)(D)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida817d180-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida817d181-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida817d182-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" applicable with respect to offenses committed after "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"Dec. 31, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s582/d"},"text":"section 582(d) of Pub. L. 107–107","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s816"},"text":"section 816 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida817d183-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Ef