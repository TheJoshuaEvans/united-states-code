{"tag":"section","attrib":{"id":"ida8f7f888-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580"},"text":null,"children":[{"tag":"num","attrib":{"value":"1580"},"text":"§ 1580.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency essential employees: designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f7f889-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense or the Secretary of the military department concerned may designate as an emergency essential employee any employee of the Department of Defense, whether permanent or temporary, the duties of whose position meet all of the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f7f88a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the duty of the employee to provide immediate and continuing support for combat operations or to support maintenance and repair of combat essential systems of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f88b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is necessary for the employee to perform that duty in a combat zone after the evacuation of nonessential personnel, including any dependents of members of the armed forces, from the zone in connection with a war, a national emergency declared by Congress or the President, or the commencement of combat operations of the armed forces in the zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f88c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is impracticable to convert the employee’s position to a position authorized to be filled by a member of the armed forces because of a necessity for that duty to be performed without interruption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f88d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Employees of Nonappropriated Fund Instrumentalities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A nonappropriated fund instrumentality employee is eligible for designation as an emergency essential employee under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f88e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f7f88f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “combat zone” has the meaning given that term in section 112(c)(2) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f890-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1580/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nonappropriated fund instrumentality employee” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1587/a/1"},"text":"section 1587(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f7f891-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tXI/s1103/b/1"},"text":"Pub. L. 106–65, div. A, title XI, § 1103(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/776"},"text":"113 Stat. 776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8f7f892-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8f7f893-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8f7f894-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 112(c)(2) of the Internal Revenue Code of 1986, referred to in subsec. (c)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s112/c/2"},"text":"section 112(c)(2) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8f7f895-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1580, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651/tII/s206/a"},"text":"Pub. L. 87–651, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/519"},"text":"76 Stat. 519","children":[],"tail":", related to appointment of civilian employees by the Secretary of Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/663"},"text":"80 Stat. 663","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
