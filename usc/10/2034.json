{"tag":"section","attrib":{"id":"ida923008b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2034"},"text":null,"children":[{"tag":"num","attrib":{"value":"2034"},"text":"§ 2034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational institutions not maintaining units of Junior Reserve Officers’ Training Corps: issuance of arms, tentage, and equipment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of a military department may issue arms, tentage, and equipment to an educational institution at which no unit of the Junior Reserve Officers’ Training Corps is maintained if the educational institution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida923008c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2034/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers a course in military training prescribed by that Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida923008d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2034/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a student body of at least 50 students who are in a grade above the eighth grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida923008e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tV/s552/a"},"text":"Pub. L. 112–239, div. A, title V, § 552(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1741"},"text":"126 Stat. 1741","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
