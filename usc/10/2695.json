{"tag":"section","attrib":{"id":"ida9bb96c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695"},"text":null,"children":[{"tag":"num","attrib":{"value":"2695"},"text":"§ 2695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of funds to cover administrative expenses relating to certain real property transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9bb96c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Accept","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In connection with a real property transaction referred to in subsection (b) with a non-Federal person or entity, the Secretary of a military department may accept amounts provided by the person or entity to cover administrative expenses incurred by the Secretary in entering into the transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Transactions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to the following transactions involving real property under the control of the Secretary of a military department:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb96c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exchange of real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grant of an easement over, in, or upon real property of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lease or license of real property of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The disposal of real property of the United States for which the Secretary will be the disposal agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The conveyance of real property under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2694a"},"text":"section 2694a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts Collected","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb96cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts collected by the Secretary of a military department under subsection (a) for administrative expenses shall be credited, at the option of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9bb96cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the appropriation, fund, or account from which the expenses were paid; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb96ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an appropriate appropriation, fund, or account currently available to the Secretary for the purposes for which the expenses were paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2695/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts credited under paragraph (1) shall be merged with funds in such appropriation, fund, or account and shall be available for the same purposes and subject to the same limitations as the funds with which merged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9bb96d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dB/tXXVIII/s2813/a"},"text":"Pub. L. 105–85, div. B, title XXVIII, § 2813(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1993"},"text":"111 Stat. 1993","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2813"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/851"},"text":"113 Stat. 851","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dB/tXXVIII/s2812/b"},"text":"Pub. L. 107–314, div. B, title XXVIII, § 2812(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2709"},"text":"116 Stat. 2709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXVIII/s2812/a"},"text":"Pub. L. 113–291, div. B, title XXVIII, § 2812(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3700"},"text":"128 Stat. 3700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9bb96d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9bb96d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9bb96d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s2812/a/1"},"text":"Pub. L. 113–291, § 2812(a)(1)","children":[],"tail":", substituted “(1) Amounts collected by the Secretary of a military department under subsection (a) for administrative expenses shall be credited, at the option of the Secretary—” and subpars. (A) and (B) for “Amounts collected under subsection (a) for administrative expenses shall be credited to the appropriation, fund, or account from which the expenses were paid.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s2812/a/2"},"text":"Pub. L. 113–291, § 2812(a)(2)","children":[],"tail":", substituted “(2) Amounts credited under paragraph (1)” for “Amounts so credited”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" inserted “involving real property under the control of the Secretary of a military department” after “transactions” in introductory provisions and added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9bb96d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9bb96d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dB/tXXVIII/s2812/b"},"text":"Pub. L. 113–291, div. B, title XXVIII, § 2812(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3700"},"text":"128 Stat. 3700","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dB/tXXVIII/s2812/b"},"text":"“The amendments made by subsection (a) [amending this section] shall not apply to administrative expenses related to a real property transaction referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2695/b"},"text":"section 2695(b) of title 10","children":[],"tail":", United States Code, that were covered by the Secretary of a military department using amounts appropriated to the Secretary before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9bb96d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administrative Costs of Land Conveyances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s226"},"text":"Pub. L. 106–541, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2598"},"text":"114 Stat. 2598","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/541/tII/s226"},"text":"“Notwithstanding any other provision of law, the administrative costs associated with the conveyance of property by the Secretary to a non-Federal governmental or nonprofit entity shall be limited to the extent that the Secretary determines that such limitation is necessary to complete the conveyance based on the entity’s ability to pay.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
