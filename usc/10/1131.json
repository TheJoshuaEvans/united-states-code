{"tag":"section","attrib":{"id":"ida89b0bfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1131"},"text":null,"children":[{"tag":"num","attrib":{"value":"1131"},"text":"§ 1131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purple Heart: limitation to members of the armed forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The decoration known as the Purple Heart (authorized to be awarded pursuant to Executive Order 11016) may only be awarded to a person who is a member of the armed forces at the time the person is killed or wounded under circumstances otherwise qualifying that person for award of the Purple Heart.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida89b0bfc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s571/a/1"},"text":"Pub. L. 105–85, div. A, title V, § 571(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1756"},"text":"111 Stat. 1756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida89b0bfd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida89b0bfe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida89b0bff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 11016, referred to in text, is Ex. Ord. No. 11016, ","children":[{"tag":"date","attrib":{"date":"1962-04-25"},"text":"Apr. 25, 1962","children":[],"tail":", 27 F.R. 4139, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1129"},"text":"section 1129 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida89b0c00-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida89b0c01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s571/b"},"text":"Pub. L. 105–85, div. A, title V, § 571(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1756"},"text":"111 Stat. 1756","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tV/s571/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1131"},"text":"Section 1131 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to persons who are killed or wounded after the end of the 180-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
