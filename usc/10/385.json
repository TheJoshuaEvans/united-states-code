{"tag":"section","attrib":{"id":"ida7aa1b9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385"},"text":null,"children":[{"tag":"num","attrib":{"value":"385"},"text":"§ 385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense support for other departments and agencies of the United States Government that advance Department of Defense security cooperation objectives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7aa1b9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), the Secretary of Defense is authorized to support other departments and agencies of the United States Government for the purpose of implementing or supporting foreign assistance programs and activities described in subsection (b) that advance security cooperation objectives of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aa1b9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Assistance Programs and Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The foreign assistance programs and activities described in this subsection are foreign assistance programs and activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aa1b9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are necessary for the effectiveness of one or more programs of the Department of Defense relating to security cooperation conducted pursuant to an authority in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aa1b9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cannot be carried out by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aa1ba0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Limitation on Amount of Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of support provided pursuant to subsection (a) in any fiscal year may not exceed $75,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aa1ba1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Wait","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a determination is made to transfer funds in connection with the provision of support pursuant to subsection (a) for a program or activity, the transfer may not occur until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aa1ba2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary and the head of the department or agency to receive the funds jointly submit to the congressional defense committees a notice on the transfer, which notice shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aa1ba3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the purpose and estimated cost of such program or activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1ba4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the security cooperation objectives of the Department, including the theater campaign plan of the combatant command concerned, that will be advanced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1ba5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification why such program or activity will advance such objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1ba6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification why such program or activity cannot be carried out by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1ba7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any funds programmed or obligated by the department or agency other than the Department on such program or activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1ba8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timeline for the provision of such support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aa1ba9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s385/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days elapses after the date of the submittal of the notice pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7aa1baa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/m"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2511"},"text":"130 Stat. 2511","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXII/s1204/c/1/E"},"text":"Pub. L. 115–232, div. A, title XII, § 1204(c)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2017"},"text":"132 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7aa1bab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7aa1bac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7aa1bad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “including” for “include”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
