{"tag":"section","attrib":{"id":"idab238ac4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8386"},"text":null,"children":[{"tag":"num","attrib":{"value":"8386"},"text":"§ 8386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the Fleet Reserve and Fleet Marine Corps Reserve: release from active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab238ac5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8386/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), the Secretary of the Navy may, at any time, release any member of the Fleet Reserve or the Fleet Marine Corps Reserve from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238ac6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8386/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In time of war or national emergency declared by Congress or by the President after ","children":[{"tag":"date","attrib":{"date":"1953-01-01"},"text":"January 1, 1953","children":[],"tail":", a member of the Fleet Reserve or the Fleet Marine Corps Reserve, without his consent, may be released from active duty other than from active duty for training only if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab238ac7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8386/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a board of officers convened at his request by an authority designated by the Secretary recommends the release and the recommendation is approved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab238ac8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8386/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member does not request that a board be convened; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab238ac9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8386/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his release is otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection does not apply during a period of demobilization or reduction in strength of the Navy or the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab238aca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/417"},"text":"70A Stat. 417","children":[],"tail":", § 6486; renumbered § 8386, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/17"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab238acb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab238acc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab238acd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"ht