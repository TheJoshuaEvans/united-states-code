ch. 690, § 205","children":[],"tail":" (3d proviso); added "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s808"},"text":"July 9, 1952, ch. 608, § 808","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/508"},"text":"66 Stat. 508","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854"},"text":"34 U.S.C. 854","children":[],"tail":" (note)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (3d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “or active duty for training” are omitted as covered by the term “active duty” as used in this revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “other than from active duty for training” are inserted since the term “active duty” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s854d"},"text":"34 U.S.C. 854d","children":[],"tail":" (3d proviso) does not include active duty for training. Clause (3) is inserted, since other provisions of law are necessarily exceptions to the general rule here stated. The words “or the Marine Corps” are inserted in the last sentence of subsection (b) to reflect the applicability of the section to the Fleet Marine Corps Reserve."}],"tail":"\n"}],"ta