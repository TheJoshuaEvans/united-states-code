{"tag":"section","attrib":{"id":"ida849de42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032"},"text":null,"children":[{"tag":"num","attrib":{"value":"1032"},"text":"§ 1032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability and death compensation: dependents of members held as captives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida849de43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall prescribe regulations under which the Secretary concerned may pay compensation for the disability or death of a dependent of a member of the uniformed services if the President determines that the disability or death—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was caused by hostile action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a result of the relationship of the dependent to the member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any compensation otherwise payable to a person under this section in connection with any disability or death shall be reduced by any amount payable to such person under any other program funded in whole or in part by the United States in connection with such disability or death, except that nothing in this subsection shall result in the reduction of any amount below zero.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by the President under subsection (a) is conclusive and is not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida849de48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “dependent” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s551"},"text":"section 551 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1032/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary concerned” has the meaning given that term in section 101 of that title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida849de4b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s806/b/1"},"text":"Pub. L. 