{"tag":"section","attrib":{"id":"ida9254a0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2106"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106"},"text":"§ 2106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced training; commission on completion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9254a0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon satisfactorily completing the academic and military requirements of the program of advanced training, a member of the program who was selected for advanced training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2104"},"text":"section 2104 of this title","children":[],"tail":" may be appointed as a regular or reserve officer in the appropriate armed force in the grade of second lieutenant or ensign, even though he is under 21 years of age."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9254a0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of rank of officers appointed under this section in May or June of any year is the date of graduation of cadets or midshipmen from the United States Military Academy, the United States Naval Academy, or the United States Air Force Academy, as the case may be, in that year. The Secretary of the military department concerned shall establish the date of rank of all other officers appointed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9254a10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In computing length of service for any purpose, an officer appointed under this section may not be credited with enlisted service for the period covered by his advanced training, other than any period of enlisted service performed on or after ","children":[{"tag":"date","attrib":{"date":"1979-08-01"},"text":"August 1, 1979","children":[],"tail":", as a member of the Selected Reserve."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9254a11-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647/tII/s201/1"},"text":"Pub. L. 88–647, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1066"},"text":"78 Stat. 1066","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tV/s517/a/1"},"text":"Pub. L. 102–484, div. A, title V, § 517(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2407"},"text":"106 Stat. 2407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s507/a/1"},"text":"Pub. L. 104–201, div. A, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2512"},"text":"110 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9254a12-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9254a13-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9254a14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “performed on or after "},{"tag":"date","attrib":{"date":"1979-08-01"},"text":"August 1, 1979","children":[],"tail":", as a member of the Selected Reserve” for “while serving on active duty other than for training after "},{"tag":"date","attrib":{"date":"1990-07-31"},"text":"July 31, 1990","children":[],"tail":", while a member of the Selected Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" inserted before period at end “, other than any period of enlisted service while serving on active duty other than for training after "},{"tag":"date","attrib":{"date":"1990-07-31"},"text":"July 31, 1990","children":[],"tail":", while a member of the Selected Reserve”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9254a15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9254a16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Benefits Not To Accrue for Periods Prior to ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"September 23, 1996","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s507/c"},"text":"Pub. L. 104–201, div. A, title V, § 507(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2512"},"text":"110 Stat. 2512","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tV/s507/c"},"text":"“No increase in pay or retired or retainer pay shall accrue for periods before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":"] by reason of the amendments made by this section [amending this section, sections 2107 and 2107a of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s205"},"text":"section 205 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
