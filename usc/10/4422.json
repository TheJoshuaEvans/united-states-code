{"tag":"section","attrib":{"id":"idaa7a5326-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422"},"text":null,"children":[{"tag":"num","attrib":{"value":"4422"},"text":"§ 4422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weapon system component or technology prototype projects: oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa7a5327-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall establish an oversight board or identify a similar existing group of senior advisors for managing prototype projects for weapon system components and other technologies and subsystems, including the use of funds for such projects, within the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa7a5328-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each oversight board shall be comprised of senior officials with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa7a5329-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise in requirements; research, development, test, and evaluation; acquisition; sustainment; or other relevant areas within the military department concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a532a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awareness of technology development activities and opportunities in the Department of Defense, industry, and other sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a532b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awareness of the component capability requirements of major weapon systems, including scheduling and fielding goals for such component capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa7a532c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of each oversight board are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa7a532d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To issue a strategic plan every three years that prioritizes the capability and weapon system component portfolio areas for conducting prototype projects, based on assessments of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa7a532e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high priority warfighter needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa7a532f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capability gaps or readiness issues with major weapon systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa7a5330-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to incrementally integrate new components into major weapon systems based on commercial technology or science and technology efforts that are expected to be sufficiently mature to prototype within three years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa7a5331-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to reduce operation and support costs of major weapon systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5332-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To annually recommend funding levels for weapon system component or technology development and prototype projects across capability or weapon system component portfolios.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5333-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To annually recommend to the service acquisition executive of the military department concerned specific weapon system component or technology development and prototype projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5334-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure projects are managed by experts within the Department of Defense who are knowledgeable in research, development, test, and evaluation and who are aware of opportunities for incremental deployment of component capabilities and other technologies to major weapon systems or directly to support warfighting capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5335-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure projects are conducted in a manner that allows for appropriate experimentation and technology risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5336-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure projects have a plan for technology transition of the prototype into a fielded system, program of record, or operational use, as appropriate, upon successful achievement of technical and project goals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5337-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure necessary technical, contracting, and financial management resources are available to support each project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa7a5338-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To submit to the congressional defense committees a semiannual notification that includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa7a5339-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each weapon system component or technology prototype project initiated during the preceding six months, including an explanation of each project and its required funding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa7a533a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4422/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results achieved from weapon system component prototype and technology projects completed and tested during the preceding six months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa7a533b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s806/a/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 806(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2257"},"text":"130 Stat. 2257","children":[],"tail":", § 2447b; renumbered § 4422 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1851/c/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1851(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4272"},"text":"134 Stat. 4272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s811/d/3"},"text":"Pub. L. 119–60, div. A, title VIII, § 811(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/951"},"text":"139 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa7a533c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa7a533d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa7a533e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out “, subject to the requirements and limitations in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4423"},"text":"section 4423 of this title","children":[],"tail":"” after “projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1851/c/1"},"text":"Pub. L. 116–283, § 1851(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2447b"},"text":"section 2447b of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1851/c/2"},"text":"Pub. L. 116–283, § 1851(c)(2)","children":[],"tail":", substituted “section 4423” for “section 2447c”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa7a533f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa7a5340-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa7a5341-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"Jan. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s806/a/2"},"text":"section 806(a)(2) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4421"},"text":"section 4421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
