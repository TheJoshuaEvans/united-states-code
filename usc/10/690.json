{"tag":"section","attrib":{"id":"ida7fd925f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690"},"text":null,"children":[{"tag":"num","attrib":{"value":"690"},"text":"§ 690.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired members ordered to active duty: limitation on number","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7fd9260-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General and Flag Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 15 retired general officers of the Army, Air Force, Marine Corps, or Space Force, and not more than 15 retired flag officers of the Navy, may be on active duty at any one time. For the purposes of this subsection a retired officer ordered to active duty for a period of 60 days or less is not counted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fd9261-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation by Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7fd9262-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 25 officers of any one armed force may be serving on active duty concurrently pursuant to orders to active duty issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s688"},"text":"section 688 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7fd9263-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the administration of paragraph (1), the following officers shall not be counted:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7fd9264-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A chaplain who is assigned to duty as a chaplain for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fd9265-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A health care professional (as characterized by the Secretary concerned) who is assigned to duty as a health care professional for the period of the active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fd9266-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any officer assigned to duty with the American Battle Monuments Commission for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fd9267-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member of the Retiree Council of the Army, Navy, or Air Force for the period on active duty to attend the annual meeting of the Retiree Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7fd9268-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is assigned to duty as a defense attaché or service attaché for the period of active duty to which ordered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7fd9269-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s690/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver for Periods of War or National Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply in time of war or of national emergency declared by Congress or the President after ","children":[{"tag":"date","attrib":{"date":"1980-11-30"},"text":"November 30, 1980","children":[],"tail":". Subsection (b) does not apply in time of war or of national emergency declared by Congress or the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7fd926a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s521/a"},"text":"Pub. L. 104–201, div. A, title V, § 521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2516"},"text":"110 Stat. 2516","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s507"},"text":"Pub. L. 106–65, div. A, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/591"},"text":"113 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s509/b"},"text":"Pub. L. 107–107, div. A, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1091"},"text":"115 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1741/b/1"},"text":"Pub. L. 118–31, div. A, title XVII, § 1741(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/680"},"text":"137 Stat. 680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7fd926b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7fd926c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7fd926d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 690 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12321"},"text":"section 12321 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (a) and (c) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s688/c"},"text":"section 688(c) of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s521/a"},"text":"Pub. L. 104–201, § 521(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7fd926e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “Marine Corps, or Space Force,” for “or Marine Corps,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" added subpar. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7fd926f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7fd9270-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" applicable with respect to officers serving on active duty as a defense attaché or service attaché on or after "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/s509/c"},"text":"section 509(c) of Pub. L. 107–107","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/