{"tag":"section","attrib":{"id":"idab17a420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8281"},"text":null,"children":[{"tag":"num","attrib":{"value":"8281"},"text":"§ 8281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the naval service in other United States hospitals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab17a421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When appropriate naval hospital facilities are unavailable, the Secretary of the Navy may provide for the care and treatment of members of the naval service, entitled to treatment in naval hospitals, in other United States hospitals, if the agencies controlling the other hospitals consent. Expenses incident to such care and treatment are chargeable to the same appropriation as would be chargeable for care and treatment in a naval hospital.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab17a422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The deduction authorized by section 4812 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s16"},"text":"24 U.S.C. 16","children":[],"tail":") shall be made from accounts of members hospitalized under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab17a423-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/387"},"text":"70A Stat. 387","children":[],"tail":", § 6201; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s36B/19"},"text":"Pub. L. 85–861, § 36B(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1571"},"text":"72 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/14"},"text":"Pub. L. 96–513, title V, § 513(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2932"},"text":"94 Stat. 2932","children":[],"tail":"; renumbered § 8281, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":", 1835.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab17a424-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab17a425-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab17a426-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6201(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t24/s31"},"text":"24 U.S.C. 31","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1929-01-19/ch85"},"text":"Jan. 19, 1929, ch. 85","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/1090"},"text":"45 Stat. 1090","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6201(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854f"},"text":"34 U.S.C. 854f","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1938-06-25/ch690/s207"},"text":"June 25, 1938, ch. 690, § 207","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1180"},"text":"52 Stat. 1180","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s854"},"text":"34 U.S.C. 854","children":[],"tail":" (note)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s803"},"text":"July 9, 1952, ch. 608, § 803","children":[],"tail":" (3d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/505"},"text":"66 Stat. 505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “members of the naval service” are substituted for the words “naval patients on the active or retired list and members of the Naval Reserve or Marine Corps Reserve”. The definition of “member of the naval service” makes the terms coextensive. Reference to St. Elizabeths Hospital is omitted in view of Reorganization Plan No. 3 of 1946, § 201, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/60/1098"},"text":"60 Stat. 1098","children":[],"tail":", which transferred the functions of that hospital pertaining to members of the naval service to the Secretary of the Navy. For the purposes of this section, St. Elizabeths is now in the same category as other United States hospitals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) reference to R.S. 4813 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s6"},"text":"24 U.S.C. 6","children":[],"tail":") is omitted because the Administrator of Veterans’ Affairs held in Decision Number 571 ("},{"tag":"date","attrib":{"date":"1944-07-27"},"text":"July 27, 1944","children":[],"tail":") that R.S. 4813 was repealed by implication. Since this decision is binding on the Secretary of the Navy (see "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s11a–2"},"text":"38 U.S.C. 11a–2","children":[],"tail":"), the deductions from pension accounts authorized by R.S. 4813 may not be made."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “each retired enlisted member of the naval service” are substituted for the words “retired enlisted men” and the words “is entitled to” are substituted for the words “shall receive” to conform to terminology used throughout this title. The words “equal in value to the hospital ration” are substituted for the words “prescribed by law for enlisted men of the Regular Navy” to show that the amount of the allowance is the value of the hospital ration. The words “for each day” are inserted to make it clear that the ration allowance is credited on a daily basis. The words “under this section” are substituted for the words “in a Federal hospital in accordance with law” because this section is the only authority for the hospitalization of members of the Fleet Reserve and Fleet Marine Corps Reserve and retired enlisted members of the naval service in Federal hospitals, other than naval hospitals, under conditions entitling the members to a ration allowance. The subsistence of a member of the Fleet Reserve or Fleet Marine Corps Reserve or a retired enlisted member of the naval service while hospitalized in naval hospitals is covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6086"},"text":"§ 6086 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab17a427-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab17a428-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8281 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9151"},"text":"section 9151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab17a429-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6201"},"text":"section 6201 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “section 4812 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t24/s16"},"text":"24 U.S.C. 16","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t24/s16"},"text":"section 16 of title 24","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" repealed subsec. (c) which related to a ration allowance for members of the Fleet Reserve of the Fleet Marine Corps Reserve and retired enlisted members of the naval service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab17a42a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab17a42b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab17a42c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref"