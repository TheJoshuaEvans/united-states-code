{"tag":"section","attrib":{"id":"idab07027e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8023"},"text":null,"children":[{"tag":"num","attrib":{"value":"8023"},"text":"§ 8023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Naval Research: appropriations; time limit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab07027f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8023/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Sums appropriated for the Office of Naval Research may be used to pay the cost of performing its duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8022"},"text":"section 8022 of this title","children":[],"tail":" including the cost of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070280-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8023/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070281-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8023/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct of research and development work in Government facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070282-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8023/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct of research and development work under contracts with individuals, corporations, and educational or scientific institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"