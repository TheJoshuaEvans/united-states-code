{"tag":"section","attrib":{"id":"ida9f25e88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2894a"},"text":"§ 2894a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaint database","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9f25e89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Database Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a database of complaints made by a tenant regarding covered dwelling units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The database shall be available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Tenant Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall permit a tenant of a covered dwelling unit to file a complaint regarding the covered dwelling unit for inclusion in the database.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Certain Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f25e8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information accessible in the database regarding a complaint shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f25e8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the installation for which the covered dwelling unit is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the landlord responsible for the covered dwelling unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the nature of the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may not disclose personally identifiable information through the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response by Landlords","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f25e93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall include in any contract with a landlord responsible for a housing unit a requirement that the landlord respond in a timely manner to any complaints included in the database that relate to the housing unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include landlord responses in the database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9f25e95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9f25e96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered armed force” means the Army, Navy, Marine Corps, Air Force, or Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered dwelling unit” means a unit of accompanied family housing, unaccompanied housing, or barracks—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f25e98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is acquired or constructed pursuant to subchapter IV of chapter 169 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which a member of a covered armed force resides; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such member does not own.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “tenant” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f25e9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of a covered armed force who resides in a covered dwelling unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2894a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A dependent of a member described in subparagraph (A) who resides in a covered dwelling unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9f25e9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3016/b"},"text":"Pub. L. 116–92, div. B, title XXX, § 3016(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1929"},"text":"133 Stat. 1929","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2825/a"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2825(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2256"},"text":"138 Stat. 2256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f25e9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f25ea0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f25ea1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2825/a/1"},"text":"Pub. L. 118–159, § 2825(a)(1)","children":[],"tail":", substituted “by a tenant regarding covered dwelling units” for “regarding housing units”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2825/a/2"},"text":"Pub. L. 118–159, § 2825(a)(2)","children":[],"tail":", substituted “covered dwelling unit” for “housing unit” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s2825/a/3"},"text":"Pub. L. 118–159, § 2825(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
