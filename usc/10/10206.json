{"tag":"section","attrib":{"id":"idab8c86d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206"},"text":null,"children":[{"tag":"num","attrib":{"value":"10206"},"text":"§ 10206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members: physical examinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c86d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each member of the Selected Reserve who is not on active duty shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c86d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a comprehensive medical readiness health and dental assessment on an annual basis, including routine annual preventive health care screening and periodic comprehensive physical examinations in accordance with regulations prescribed by the Secretary of Defense that reflect morbidity and mortality risks associated with the military service, age, and gender of the member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute and submit to the Secretary concerned on an annual basis documentation of the medical and dental readiness of the member to perform military duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Individual Ready Reserve or inactive National Guard shall be examined for physical fitness as necessary to determine the member’s physical fitness for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c86da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military duty or promotion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attendance at a school of the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other action related to career progression.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Reserve in an active status, or on an inactive status list, who is not on active duty shall execute and submit annually to the Secretary concerned a certificate of physical condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The kind of duty to which a Reserve ordered to active duty may be assigned shall be considered in determining physical qualifications for active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c86df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2977"},"text":"108 Stat. 2977","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s516"},"text":"Pub. L. 107–107, div. A, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1094"},"text":"115 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVII/s732/a"},"text":"Pub. L. 109–163, div. A, title VII, § 732(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3351"},"text":"119 Stat. 3351","children":[],"tail":", 3352.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c86e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c86e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab8c86e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 1004(a), (b) of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/a/4/A"},"text":"Pub. L. 103–337, § 1661(a)(4)(A)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab8c86e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s732/b"},"text":"Pub. L. 109–163, § 732(b)","children":[],"tail":", struck out “periodic” before “physical” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s732/a/1"},"text":"Pub. L. 109–163, § 732(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “be examined as to the member’s physical fitness every five years, or more often as the Secretary concerned considers necessary; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s732/a/2"},"text":"Pub. L. 109–163, § 732(a)(2)","children":[],"tail":", substituted “to the Secretary concerned on an annual basis documentation of the medical and dental readiness of the member to perform military duties” for “annually to the Secretary concerned a certificate of physical condition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s516/a/1"},"text":"Pub. L. 107–107, § 516(a)(1)","children":[],"tail":", (2), substituted “Selected Reserve” for “Ready Reserve” in introductory provisions and redesignated concluding provisions as subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s516/b"},"text":"Pub. L. 107–107, § 516(b)","children":[],"tail":", substituted “the member’s physical fitness” for “his physical fitness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s516/a/4"},"text":"Pub. L. 107–107, § 516(a)(4)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s516/a/2"},"text":"Pub. L. 107–107, § 516(a)(2)","children":[],"tail":", redesignated concluding provisions of subsec. (a) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s516/a/3"},"text":"Pub. L. 107–107, § 516(a)(3)","children":[],"tail":", redesignated subsec. (b) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8c86e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab8c86e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
