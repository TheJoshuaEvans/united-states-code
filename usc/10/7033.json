{"tag":"section","attrib":{"id":"idaad4f63d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033"},"text":null,"children":[{"tag":"num","attrib":{"value":"7033"},"text":"§ 7033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad4f63e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f63f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Chief of Staff of the Army, appointed for a period of four years by the President, by and with the advice and consent of the Senate, from the general officers of the Army. He serves at the pleasure of the President. In time of war or during a national emergency declared by Congress, he may be reappointed for a term of not more than four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f640-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may appoint an officer as Chief of Staff only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad4f641-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has had significant experience in joint duty assignments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad4f642-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such experience includes at least one full tour of duty in a joint duty assignment (as defined in section 664(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002152"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002152"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) as a general officer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f643-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may waive paragraph (2) in the case of an officer if the President determines such action is necessary in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f644-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff, while so serving, has the grade of general without vacating his permanent grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f645-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise prescribed by law and subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7013/f"},"text":"section 7013(f) of this title","children":[],"tail":", the Chief of Staff performs his duties under the authority, direction, and control of the Secretary of the Army and is directly responsible to the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f646-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of the Army, the Chief of Staff shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f647-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preside over the Army Staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f648-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit the plans and recommendations of the Army Staff to the Secretary and advise the Secretary with regard to such plans and recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f649-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after approval of the plans or recommendations of the Army Staff by the Secretary, act as the agent of the Secretary in carrying them into effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f64a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise supervision, consistent with the authority assigned to commanders of unified or specified combatant commands under chapter 6 of this title, over such of the members and organizations of the Army as the Secretary determines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f64b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform the duties prescribed for him by sections 171 and 3104 of this title and other provisions of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f64c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other military duties, not otherwise assigned by law, as are assigned to him by the President, the Secretary of Defense, or the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad4f64d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad4f64e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff shall also perform the duties prescribed for him as a member of the Joint Chiefs of Staff under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f64f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that such action does not impair the independence of the Chief of Staff in the performance of his duties as a member of the Joint Chiefs of Staff, the Chief of Staff shall inform the Secretary regarding military advice rendered by members of the Joint Chiefs of Staff on matters affecting the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad4f650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7033/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of Defense, the Chief of Staff shall keep the Secretary of the Army fully informed of significant military operations affecting the duties and responsibilities of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad4f651-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/162"},"text":"70A Stat. 162","children":[],"tail":", § 3034; "},{"tag":"ref","attrib":{"href":"/us/pl/85/599/s4/a"},"text":"Pub. L. 85–599, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/516"},"text":"72 Stat. 516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s114"},"text":"Pub. L. 87–651, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/513"},"text":"76 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/22/tIV/s401"},"text":"Pub. L. 90–22, title IV, § 401