{"tag":"section","attrib":{"id":"idab369e58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8628"},"text":null,"children":[{"tag":"num","attrib":{"value":"8628"},"text":"§ 8628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchant vessels: supplies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab369e59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy, under such regulations as he prescribes, may sell to a merchant ship such fuel and other supplies as may be required to meet its necessities if the ship is unable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab369e5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8628/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure the supplies from other sources at its present location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab369e5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8628/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to proceed to the nearest port where they may be obtained without endangering the safety of the ship, the health and comfort of its personnel, or the safe condition of the property carried on it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab369e5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sales under this section shall be at such prices as the Secretary considers reasonable. Payment shall be made on a cash basis or on such other basis as will reasonably assure prompt payment. Amounts received from such a sale shall, unless otherwise directed by another provision of law, be credited to the current appropriation concerned and are available for the same purposes as that appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab369e5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/448"},"text":"70A Stat. 448","children":[],"tail":", § 7228; renumbered § 8628, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab369e5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab369e5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab369e60-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":