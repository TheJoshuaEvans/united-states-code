{"tag":"section","attrib":{"id":"ida8b2d980-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1219"},"text":null,"children":[{"tag":"num","attrib":{"value":"1219"},"text":"§ 1219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of origin of disease or injury: limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member of an armed force may not be required to sign a statement relating to the origin, incurrence, or aggravation of a disease or injury that he has. Any such statement against his interests, signed by a member, is invalid.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8b2d981-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/56/tXXII/s2201/31/A"},"text":"Pub. L. 85–56, title XXII, § 2201(31)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-06-17"},"text":"June 17, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/160"},"text":"71 Stat. 160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s107/c"},"text":"Pub. L. 87–651, title I, § 107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/509"},"text":"76 Stat. 509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b2d982-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b2d983-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b2d984-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1218 and 1219 are restated, without substantive change, to conform to the style adopted for title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b2d985-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b2d986-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651"},"text":"Pub. L. 87–651","children":[],"tail":" substituted “Statement of origin of disease or injury: limitation” for “Statement against interest void” in section catchline, and “A member of an armed force may not be required to sign a statement relating to the origin, incurrence, or aggravation of a disease or injury that he has. Any such statement against his interests, signed by a member, is invalid” for “No person in the Armed Forces may be required to sign a statement of any nature relating to the origin, incurrence, or aggravation of any disease or injury he may have. Any such statement against his own interest, whenever signed, is of no force and effect.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b2d987-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8b2d988-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1958-01-01"},"text":"Jan. 1, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/56/s2301"},"text":"section 2301 of Pub. L. 85–56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/172"},"text":"71 Stat. 172","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
