{"tag":"section","attrib":{"id":"idabccea25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401"},"text":null,"children":[{"tag":"num","attrib":{"value":"20401"},"text":"§ 20401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions of law related to separation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officer Separation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as specified in this section or otherwise modified in this chapter, the provisions of chapter 59 of this title applicable to officers of a regular component shall apply to officers of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as specified in this section or otherwise modified in this chapter, the provisions of sections 1169, 1170, 1171, 1173, 1174(b), and 1176(a) of chapter 59 of this title applicable to enlisted members of a regular component shall apply to enlisted members of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1172"},"text":"section 1172 of this title","children":[],"tail":" pertaining to a person enlisted under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s518"},"text":"section 518 of this title","children":[],"tail":" shall apply to an enlisted member of the Space Force."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174"},"text":"section 1174 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertaining to a regular officer shall apply to a Space Force officer serving on sustained duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertaining to a regular enlisted member shall apply to an enlisted member of the Space Force serving on sustained duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertaining to other members shall apply to members of the Space Force not serving on sustained duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":" pertaining to a voluntary appointment, enlistment, or transfer to a reserve component shall apply to the voluntary release from active duty of a member of the Space Force on sustained duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1176"},"text":"section 1176 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertaining to a regular enlisted member shall apply to an enlisted member of the Space Force serving on sustained duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20401/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertaining to a reserve enlisted member serving in an active status shall apply to an enlisted member of the Space Force serving in a space force active status or on sustained duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1718/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1718(a)","children":[],"tai