{"tag":"section","attrib":{"id":"idabccea14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20301"},"text":null,"children":[{"tag":"num","attrib":{"value":"20301"},"text":"§ 20301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Original enlistments: qualifications; grade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original Enlistments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabccea16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to accept","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may accept original enlistments in the Space Force of qualified, effective, and able-bodied persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabccea17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Age","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person accepted for original enlistment shall be not less than seventeen years of age. However, no person under eighteen years of age may be originally enlisted without the written consent of the person’s parent or guardian, if the person has a parent or guardian entitled to the person’s custody and control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person is enlisted in the Space Force in the grade prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea19-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1717/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1717(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/654"},"text":"137 Stat. 654","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
