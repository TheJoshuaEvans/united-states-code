tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"971","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1414.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-06-25/ch439/s4"},"text":"June 25, 1956, ch. 439, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/333"},"text":"70 Stat. 333","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83df783-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida83df784-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “, Air Force, or Space Force” for “or Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “"},{"tag":"inline","attrib":{},"text":"Navy Reserve","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Naval Reserve","children":[],"tail":"” in heading and “Navy Reserve” for “Naval Reserve” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “Commissioned Corps” for “commissioned corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s581/c/3"},"text":"Pub. L. 104–201, § 581(c)(3)","children":[],"tail":", struck out “enlisted” after “count” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s581/a"},"text":"Pub. L. 104–201, § 581(a)","children":[],"tail":", (c)(2), inserted heading, substituted “while also performing service as a cadet or midshipman or serving as a midshipman” for “while also serving as a cadet at the United States Military Academy, the United States Air Force Academy, or the United States Coast Guard Academy, or as a midshipman at the United States Naval Academy or”, and inserted before period at end “or an officer in the Commissioned Corps of the Public Health Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s581/b"},"text":"Pub. L. 104–201, § 581(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “In computing length of service for any purpose—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) no officer of the Navy or Marine Corps may be credited with service as a midshipman at the United States Naval Academy or as a cadet at the United States Military Academy, United States Air Force Academy, or United States Coast Guard Academy;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) no commissioned officer of the Army or Air Force may be credited with service as a midshipman at the United States Naval Academy or as a cadet at the United States Military Academy, United States Air Force Academy, or United States Coast Guard Academy; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) no officer of the Coast Guard may be credited with service as a midshipman at the United States Naval Academy or as a cadet at the United States Military Academy, United States Air Force Academy, or United States Coast Guard Academy.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s581/c/1"},"text":"Pub. L. 104–201, § 581(c)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s652/a/1/A"},"text":"Pub. L. 101–189, § 652(a)(1)(A)","children":[],"tail":", struck out “, under an appointment accepted after "},{"tag":"date","attrib":{"date":"1956-06-25"},"text":"June 25, 1956","children":[],"tail":",” after “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s652/a/2/A"},"text":"Pub. L. 101–189, § 652(a)(2)(A)","children":[],"tail":", struck out “, if he was appointed as a midshipman or cadet after "},{"tag":"date","attrib":{"date":"1913-03-04"},"text":"March 4, 1913","children":[],"tail":"” after “United States Coast Guard Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s652/a/2/B"},"text":"Pub. L. 101–189, § 652(a)(2)(B)","children":[],"tail":", struck out “, if he was appointed as a midshipman or cadet after "},{"tag":"date","attrib":{"date":"1912-08-24"},"text":"August 24, 1912","children":[],"tail":"” after “United States Coast Guard Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235"},"text":"Pub. L. 90–235","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida83df785-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida83df786-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida83df787-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Subsection (a) to Service Under Appointment Accepted Before ","children":[{"tag":"date","attrib":{"date":"1956-06-26"},"text":"June 26, 1956","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s652/a/1/B"},"text":"Pub. L. 101–189, div. A, title VI, § 652(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1461"},"text":"103 Stat. 1461","children":[],"tail":", provided that the computing limitation in subsection (a) of this section did not apply to service under an appointment as a cadet or midshipman accepted before "},{"tag":"date","attrib":{"date":"1956-06-26"},"text":"June 26, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
