{"tag":"section","attrib":{"id":"ida78666ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199"},"text":null,"children":[{"tag":"num","attrib":{"value":"199"},"text":"§ 199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Interagency Task Force 401","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78666cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department of Defense a joint activity to be known as the “Joint Interagency Task Force 401” (referred to in this section as the “Task Force”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is a Director of the Task Force (referred to in this section as the “Director”) who shall be appointed by the Secretary of Defense from among personnel of the Department of Defense who are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78666d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general or flag officers of the covered armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78666d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall report directly to the Deputy Secretary of Defense and shall serve as the principal advisor to the Deputy Secretary and the Chairman of the Joint Chiefs of Staff on counter-small unmanned aircraft system matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Task Force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designated as a jointly manned activity with full joint manning support from the covered armed forces as determined by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consist of such other subordinate organizational elements as the Director determines appropriate, subject to the authority, direction, and control of the Secretary of Defense with support from designated organizational elements within the Office of the Secretary of Defense as determined by the Director in coordination with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of the Task Force shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lead, advocate, coordinate, and focus all Department of Defense actions in support of efforts of the combatant commands and the covered armed forces to defeat small unmanned aircraft systems (referred to in this section as “sUAS”) as weapons of strategic influence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrate all counter-sUAS solutions throughout the Department of Defense, seeking interagency participation and assistance as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and share counter-sUAS training tools, expertise, and tactics, techniques, and procedures for components of the Department of Defense that address needs of the joint force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate efforts across the Department of Defense to develop, test, evaluate, and procure counter-sUAS kinetic and non-kinetic defeat capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carry out the counter-sUAS validation and acquisition responsibilities described in subsections (e) and (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and regularly update a counter-sUAS strategic plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carry out such other activities relating to counter-sUAS as the Secretary of Defense determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval and Validation of Counter-suas Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Task Force shall serve as the entity within the Department of Defense with primary responsibility for the validation and approval of counter-sUAS systems for procurement and use by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In coordination with other components of the Department of Defense, the Director shall develop, maintain, and regularly update a list of counter-sUAS systems that are validated and approved for procurement and use by the Department as described in paragraph (1). The Director shall ensure that each counter-sUAS system on the list has been vetted by the Task Force and has proven to be effective for use by the Department in countering sUAS.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (4), no component of the Department of Defense may procure a counter-sUAS system unless such system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78666e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been validated and approved by the Task Force under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78666e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is included on the list maintained under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The service acquisition executive of the military department concerned (in the case of a procurement by a military department) or the Under Secretary of Defense for Acquisition and Sustainment (in the case of a procurement not under the authority of a service acquisition executive) may waive the restriction under paragraph (3), on a case-by-case basis, by submitting to the congressional defense committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78666e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of the intent to issue such a waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78666e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the reasons for issuing the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Division","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish and maintain an acquisition division within the Task Force. The acquisition division shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include acquisition professionals from relevant portfolio acquisition executives (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1732"},"text":"section 1732 of this title","children":[],"tail":") within each covered armed force;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support and facilitate efforts of the Director and covered armed forces—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78666ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to budget and plan for the integration and sustainment of counter-sUAS capabilities that are approved and validated by the Task Force under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78666ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to efficiently and effectively transition such capabilities into operational use; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have such other duties and responsibilities as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Director shall submit to the congressional defense committees a report that includes a summary of the activities of the Task Force over the period covered by the report, including a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Task Force in carrying out the requirements of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the metrics used to measure such progress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for congressional consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78666f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “counter-sUAS system” means a system or device capable of lawfully and safely disabling, disrupting, or seizing control of a small unmanned aircraft or small unmanned aircraft system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered armed forces” means the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78666f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s199/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “small unmanned aircraft”, “unmanned aircraft”, and “unmanned aircraft system” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44801"},"text":"section 44801 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida78666f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIX/s912/a"},"text":"Pub. L. 119–60, div. A, title IX, § 912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1015"},"text":"139 Stat. 1015","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
