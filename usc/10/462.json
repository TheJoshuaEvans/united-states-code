{"tag":"section","attrib":{"id":"ida7c210a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s462"},"text":null,"children":[{"tag":"num","attrib":{"value":"462"},"text":"§ 462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance to certain employees in acquisition of critical skills","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may establish an undergraduate training program with respect to civilian employees of the National Geospatial-Intelligence Agency that is similar in purpose, conditions, content, and administration to the program established by the Secretary of Defense under section 16 of the National Security Agency Act of 1959 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3614"},"text":"50 U.S.C. 3614","children":[],"tail":") for civilian employees of the National Security Agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida7c210a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/108/tV/s504/a"},"text":"Pub. L. 107–108, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1405"},"text":"115 Stat. 1405","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/2/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/9"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c210a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c210a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c210aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3614"},"text":"50 U.S.C. 3614","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"50 U.S.C. 402","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
