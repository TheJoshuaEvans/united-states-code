{"tag":"section","attrib":{"id":"ida9efee0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2891c"},"text":"§ 2891c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency regarding finances and performance metrics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9efee0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Landlord Financial Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9efee0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less frequently than annually, the Secretary of Defense shall require that each landlord submit to the Secretary a report providing information regarding all housing units provided by the landlord.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9efee0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information provided under paragraph (1) by a landlord shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9efee0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comprehensive summary of the landlord’s financial performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of base management fees relating to all housing units provided by the landlord.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of asset management fees relating to such housing units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of preferred return fees relating to such housing units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee12-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The residual cashflow distributions relating to such housing units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of deferred fees or other fees relating to such housing units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information with respect to each insurance policy maintained by the landlord for such housing units, including the—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9efee15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scope of coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9efee16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deductible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9efee17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy limit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9efee18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total premium amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of any payments made by the landlord to tenants of such housing units pursuant to a dispute resolution process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9efee1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9efee1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “base management fees” means the monthly management fees collected for services associated with accepting and processing rent payments, ensuring tenant rent payments, property inspections, maintenance management, and emergency maintenance calls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “asset management fees” means fees paid to manage a housing unit for the purpose of ensuring the housing unit is maintained in good condition and making repairs over the lifecycle of the housing unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “preferred return fees” means fees associated with any claims on profits furnished to preferred investors with an interest in the housing unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “residual cashflow distribution” means the steps a specific housing project takes to restructure after it is determined that the project is in an unacceptable financial condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9efee1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “deferred fee” means any fee that was not paid to a person in a calendar year in order to meet other financial obligations of the landlord.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9efee20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Information on Performance Metrics and Use of Incentive Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9efee21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not less frequently than annually, the Secretary of Defense shall make available, upon request of a tenant, at the applicable installation housing office the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9efee22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the indicators underlying the performance metrics for each contract for the provision or management of housing units to ensure such indicators adequately measure the condition and quality of each housing unit covered by the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information regarding the use by the Secretary concerned of incentive fees to support contracts for the provision or management of housing units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f25e25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1)(A), the indicators underlying the performance metrics for a contract for the provision or management of housing units shall measure at a minimum the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9f25e26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tenant satisfaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9f25e27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintenance management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9f25e28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9f25e29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment required to be made available under paragraph (1)(A) shall include a detailed description of each indicator underlying the performance metrics, including the following information:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9f25e2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitations of available survey data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9f25e2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How tenant satisfaction and maintenance management is calculated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9f25e2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether any relevant data is missing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9f25e2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The information provided under paragraph (1)(B) shall include, with respect to each contract for the provision or management of housing units, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9f25e2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicable incentive fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The metrics used to determine the incentive fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether incentive fees were paid in full, or were withheld in part or in full, during the period covered by the release of information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9f25e32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any incentive fees were withheld, the reasons for such withholding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9f25e33-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3016/a"},"text":"Pub. L. 116–92, div. B, title XXX, § 3016(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1927"},"text":"133 Stat. 1927","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/tXXVIII/s2814/a"},"text":"Pub. L. 116–283, div. B, title XXVIII, § 2814(a)","children":[],"tail":"–(d)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4327"},"text":"134 Stat. 4327","children":[],"tail":", 4328; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2825"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2825","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1308"},"text":"139 Stat. 1308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f25e34-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f25e35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f25e36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(G), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subpars. (G) and (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2814/d/1"},"text":"Pub. L. 116–283, § 2814(d)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Financial transparency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2814/a/1"},"text":"Pub. L. 116–283, § 2814(a)(1)","children":[],"tail":", inserted “Performance Metrics and” before “Use of Incentive Fees” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2814/a/2"},"text":"Pub. L. 116–283, § 2814(a)(2)","children":[],"tail":", substituted “shall make available, upon request of a tenant, at the applicable installation housing office the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(A) An assessment of the indicators underlying the performance metrics for each contract for the provision or management of housing units to ensure such indicators adequately measure the condition and quality of each housing unit covered by the contract.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(B) Information”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “shall publish, on a publicly accessible website, information”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2814/b/2"},"text":"Pub. L. 116–283, § 2814(b)(2)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s2814/b/1"},"text":"Pub. L. 116–283, § 2814(b)(1)","children":[],"tail":", (c), redesignated par. (2) as (3) and substituted “paragraph (1)(B)” for “paragraph (1)” and “each contract for the provision or management of housing units” for “each contract” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
