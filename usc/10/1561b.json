{"tag":"section","attrib":{"id":"ida8ec10fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1561b"},"text":"§ 1561b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential reporting of sexual harassment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ec10fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1561"},"text":"section 1561 of this title","children":[],"tail":", the Secretary of Defense and the Secretary of the department in which the Coast Guard is operating when not operating as a service in the Navy shall prescribe in regulations a process by which a member of an armed force under the jurisdiction of the Secretary of a military department or the Commandant may confidentially allege a complaint of sexual harassment to an individual outside the immediate chain of command of the member."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ec10fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receipt of Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual designated and trained to receive complaints under the process under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ec10fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the confidentiality of the member alleging the complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ec10ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" explain to the member alleging the complaint the different avenues of redress available to resolve the complaint and the different consequences of each avenue on the manner in which the complaint will be investigated (if at all), including an explanation of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8ec1100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner in which to file a complaint concerning alleged sexual harassment with the official or office designated for receipt of such complaint through such avenue of redress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ec1101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That confidentiality in connection with the complaint cannot be maintained when there is a clear and present risk to health or safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ec1102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the alleged sexual harassment also involves an allegation of sexual assault, including sexual contact—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8ec1103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which to file a confidential report with a Sexual Assault Response Coordinator or a Sexual Assault Prevention and Response Victim Advocate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8ec1104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options available pursuant to such reporting, including a Restricted Report or Unrestricted Report, and participation in the Catch a Serial Offender Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8ec1105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The services and assistance available to the member in connection with the complaint and the alleged sexual harassment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ec1106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education and Tracking","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense or the Secretary of the department in which the Coast Guard is operating when not operating as a service in the Navy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ec1107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate members under the jurisdiction of the Secretaries of the military departments or the Commandant departments regarding the process established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ec1108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track complaints alleged pursuant to the process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ec1109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2023-04-30"},"text":"April 30, 2023","children":[],"tail":", and April 30 every two years thereafter, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report containing data on the complaints of sexual harassment alleged pursuant to the process under subsection (a) during the previous two calendar years. Any data on such complaints shall not contain any personally identifiable information."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ec110a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports for the Coast Guard.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ec110b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2026-04-30"},"text":"April 30, 2026","children":[],"tail":", and April 30 every 2 years thereafter, the Secretary of the department in which the Coast Guard is operating shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report containing data on the complaints of sexual harassment alleged pursuant to the process under subsection (a) during the previous 2 calendar years."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ec110c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1561b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally identifiable information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any data on complaints described in paragraph (1) shall not contain any personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ec110d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s532/a/1"},"text":"Pub. L. 116–283, div. A, title V, § 532(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3601"},"text":"134 Stat. 3601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXV/s7525"},"text":"Pub. L. 119–60, div. G, title LXXV, § 7525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1816"},"text":"139 Stat. 1816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ec110e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ec110f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ec1110-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7525/1"},"text":"Pub. L. 119–60, § 7525(1)","children":[],"tail":", inserted “and the Secretary of the department in which the Coast Guard is operating when not operating as a service in the Navy” after “Secretary of Defense” and “or the Commandant” after “Secretary of a military department”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7525/2/A"},"text":"Pub. L. 119–60, § 7525(2)(A)","children":[],"tail":", inserted “or the Secretary of the department in which the Coast Guard is operating when not operating as a service in the Navy” after “Secretary of Defense” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7525/2/B"},"text":"Pub. L. 119–60, § 7525(2)(B)","children":[],"tail":", inserted “departments or the Commandant” after “Secretaries of the military”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7525/3"},"text":"Pub. L. 119–60, § 7525(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
