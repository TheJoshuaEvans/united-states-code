{"tag":"section","attrib":{"id":"idabb766cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503"},"text":null,"children":[{"tag":"num","attrib":{"value":"14503"},"text":"§ 14503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of officers with less than six years of commissioned service or found not qualified for promotion to first lieutenant or lieutenant (junior grade)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb766cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Discharges","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may discharge any reserve officer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb766ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has less than six years of service in an active status as a commissioned officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb766cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in the grade of second lieutenant or ensign and has been found not qualified for promotion to the grade of first lieutenant or lieutenant (junior grade).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb766d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Discharge","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb766d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer described in subsection (a)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb766d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be discharged at any time after being found not qualified for promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb766d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not sooner discharged, shall be discharged at the end of the 18-month period beginning on the date on which the officer is first found not qualified for promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb766d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply if the officer is sooner promoted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb766d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Discharges under this section shall be made under regulations prescribed by the Secretary of Defense and may be made without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12645"},"text":"section 12645 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb766d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2949"},"text":"108 Stat. 2949","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s503/c/1"},"text":"Pub. L. 110–181, div. A, title V, § 503(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/95"},"text":"122 Stat. 95","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb766d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb766d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb766d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (a) and (b) of this section were contained in sections 3819(b) and 8819(c) of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/2"},"text":"Pub. L. 103–337, § 1629(a)(2)","children":[],"tail":", (c)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb766da-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s503/c/2"},"text":"Pub. L. 110–181, § 503(c)(2)","children":[],"tail":", substituted “six years” for “five years” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s503/c/1"},"text":"Pub. L. 110–181, § 503(c)(1)","children":[],"tail":", substituted “six years” for “five years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb766db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb766dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idabb766dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rights for Officers With Over Three Years Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1689"},"text":"Pub. L. 103–337, div. A, title XVI, § 1689","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3025"},"text":"108 Stat. 3025","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tXVI/s1689"},"text":"“A reserve officer of the Army, Navy, Air Force, or Marine Corps who was in an active status on the day before the effective date of this title [","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see section 1691(b)(1), (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"] and who was subject to placement of the reserve active-status list on the effective date of this title may not be discharged under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14503"},"text":"section 14503 of title 10","children":[],"tail":", United States Code, as added by this title, until on or after the day on which that officer completes three years of continuous service as a reserve commissioned officer.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
