{"tag":"section","attrib":{"id":"idab534d78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8880"},"text":null,"children":[{"tag":"num","attrib":{"value":"8880"},"text":"§ 8880.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals and amendments in prize causes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab534d79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8880/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A United States Court of Appeals may allow an appeal in a prize cause if it appears that a notice of appeal was filed with the clerk of the district court within thirty days after the final decree in that cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab534d7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8880/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A United States Court of Appeals, if in its opinion justice requires it, may allow amendments in form or substance of any appeal in a prize cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab534d7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/483"},"text":"70A Stat. 483","children":[],"tail":", § 7680; renumbered § 8880, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"ty