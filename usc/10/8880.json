:null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1146"},"text":"34 U.S.C. 1146","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1006; R.S. 4636.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1146"},"text":"34 U.S.C. 1146","children":[],"tail":" and this section reflect—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) Acts of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s128"},"text":"March 3, 1911, ch. 231, § 128","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1133"},"text":"36 Stat. 1133","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-13/ch229/s1"},"text":"February 13, 1925, ch. 229, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/938"},"text":"43 Stat. 938","children":[],"tail":", which defined the appellate jurisdiction of the United States Circuit Courts of Appeals; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"Act of June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":", which repealed the 1911 and 1925 Acts, but enacted similar provisions and changed the name of the circuit courts to United States Courts of Appeals for the several circuits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or of intention to appeal” are omitted as surplusage. Formerly “notices of appeal” were filed in some courts and “notices of intention to appeal” were filed in others. The difference was in terminology, not in substance. These notices are now known as “notices of appeal”. The words “next” and “the rendition of” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab534d7f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab534d80-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7680"},"text":"section 7680 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab534d81-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab534d82-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
