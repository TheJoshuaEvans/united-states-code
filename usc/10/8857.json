{"tag":"section","attrib":{"id":"idab50dc4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857"},"text":null,"children":[{"tag":"num","attrib":{"value":"8857"},"text":"§ 8857.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of commanding officer of capturing vessel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dc50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The commanding officer of a vessel making a capture shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure the documents of the captured vessel, including the log, and the documents of cargo, together with all other documents and papers, including letters, found on board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inventory and seal all the documents and papers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" send the inventory and documents and papers to the court in which proceedings are to be had, with a written statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab50dc54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the documents and papers sent are all the papers found, or explaining the reasons why any are missing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab50dc55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the documents and papers sent are in the same condition as found, or explaining the reasons why any are in different condition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" send as witnesses to the prize court the master, one or more of the other officers, the supercargo, purser, or agent of the prize, and any other person found on board whom he believes to be interested in or to know the title, national character, or destination of the prize, and if any of the usual witnesses cannot be sent, send the reasons therefor to the court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place a competent prize master and a prize crew on board the prize and send the prize, the witnesses, and all documents and papers, under charge of the prize master, into port for adjudication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the absence of instructions from higher authority as to the port to which the prize shall be sent for adjudication, the commanding officer of the capturing vessel shall select the port that he considers most convenient in view of the interests of probable claimants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dc59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8857/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the captured vessel, or any part of the captured property, is not in condition to be sent in for adjudication, the commanding officer of the capturing vessel shall have a survey and an appraisal made by competent and impartial persons. The reports of the survey and the appraisal shall be sent to the court in which proceedings are to be had. Property so surveyed and appraised, unless appropriated for the use of the United States, shall be sold under authority of the commanding officer present. Proceeds of the sale shall be deposited with the Treasurer of the United States or in the public depositary most accessible to the court in which proceedings are to be had and subject to its order in the cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dc5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/476"},"text":"70A Stat. 476","children":[],"tail":", § 7657; renumbered § 8857, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dc5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7657","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1133"},"text":"34 U.S.C. 1133","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4615.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"As does ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1133"},"text":"34 U.S.C. 1133","children":[],"tail":", the revised section reflects the "},{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch413/s13"},"text":"Act of March 3, 1899, ch. 413, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1007"},"text":"30 Stat. 1007","children":[],"tail":", and the "},{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch214/s1"},"text":"Act of May 29, 1920, ch. 214, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/654"},"text":"41 Stat. 654","children":[],"tail":", which, respectively, abolished the interest of captors in prize property and substituted “Treasurer of the United States or public depositary” for “assistant treasurer of the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dc5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dc5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7657"},"text":"section 7657 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab50dc60-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab50dc61-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
