{"tag":"section","attrib":{"id":"idabcceaa5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20601"},"text":null,"children":[{"tag":"num","attrib":{"value":"20601"},"text":"§ 20601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers: voluntary retirement for length of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabcceaa6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Twenty Years or More","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may, upon the officer’s request, retire a commissioned officer of the Space Force who has at least 20 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20602"},"text":"section 20602 of this title","children":[],"tail":", at least 10 years of which have been active service as a commissioned officer."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcceaa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Thirty Years or More","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A commissioned officer of the Space Force who has at least 30 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20602"},"text":"section 20602 of this title","children":[],"tail":" may be retired upon the officer’s request, in the discretion of the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcceaa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forty Years or More","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20503"},"text":"section 20503 of this title","children":[],"tail":", a commissioned officer of the Space Force who has at least 40 years of service computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20602"},"text":"section 20602 of this title","children":[],"tail":" shall be retired upon the officer’s request."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcceaa9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719A/a"},"text":"Pub. L. 118–31, div. A, title XVII, § 1719A(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/662"},"text":"137 Stat. 662","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
