{"tag":"section","attrib":{"id":"idaa377cce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772"},"text":null,"children":[{"tag":"num","attrib":{"value":"3772"},"text":"§ 3772.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights in technical data: provisions required in contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa377ccf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Provisions Relating to Technical Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"section 3771 of this title","children":[],"tail":" shall require that, whenever practicable, a contract for supplies or services entered into by an agency named in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":" contain appropriate provisions relating to technical data, including provisions—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377cd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining the respective rights of the United States and the contractor or subcontractor (at any tier) regarding any technical data to be delivered under the contract and providing that, in the case of a contract for a commercial product, the product shall be presumed to be developed at private expense unless shown otherwise in accordance with section 3784;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying the technical data, if any, to be delivered under the contract and delivery schedules for such delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or referencing procedures for determining the acceptability of technical data to be delivered under the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing separate contract line items for the technical data, if any, to be delivered under the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum practicable extent, identifying, in advance of delivery, technical data which is to be delivered with restrictions on the right of the United States to use such data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requiring the contractor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377cd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to revise any technical data delivered under the contract to reflect engineering design changes made during the performance of the contract and affecting the form, fit, and function of the items specified in the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377cd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deliver such revised technical data to an agency within a time specified in the contract;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing remedies to be available to the United States when technical data required to be delivered or made available under the contract is found—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377cd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be incomplete or inadequate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377cda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to not satisfy the requirements of the contract concerning technical data;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing the head of the agency to withhold payments under the contract (or exercise such other remedies as the head of the agency considers appropriate) during any period if the contractor does not meet the requirements of the contract pertaining to the delivery of technical data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377cdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing that, in addition to technical data that is already subject to a contract delivery requirement, the United States may require, until the date occurring six years after acceptance of the last item (other than technical data) under a contract or the date of contract termination, whichever is later, the delivery of technical data that has been generated in the performance of the contract, and compensate the contractor only for reasonable costs incurred for having converted and delivered the data in the required form, upon a determination that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa377cdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical data is needed for the purpose of reprocurement, sustainment, modification, or upgrade (including through competitive means) of a major system or subsystem thereof, a weapon system or subsystem thereof, or any noncommercial product or process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa377cde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the technical data—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa377cdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pertains to an item or process developed in whole or in part with Federal funds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa377ce0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in paragraphs (4)(A)(ii), (6), and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771/b"},"text":"section 3771(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377ce1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that the United States is not foreclosed from requiring the delivery of the technical data by a failure to challenge, in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3782"},"text":"section 3782 of this title","children":[],"tail":", the contractor’s assertion of a use or release restriction on the technical data."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa377ce2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subchapter or in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3208"},"text":"section 3208 of this title","children":[],"tail":" prohibits the Secretary of Defense from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa377ce3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing standards for determining whether a contract entered into by the Department of Defense shall provide for a time to be specified in the contract after which the United States shall have the right to use (or have used) for any purpose of the United States all technical data required to be delivered to the United States under the contract or providing for such a period of time (not to exceed 7 years) as a negotiation objective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377ce4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any limitation upon the license rights conveyed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"section 3771 of this title","children":[],"tail":", allowing a covered Government support contractor access to and use of any technical data delivered under a contract for the sole purpose of furnishing independent and impartial advice or technical assistance directly to the Government in support of the Government’s management and oversight of the program or effort to which such technical data relates; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa377ce5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3772/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing reasonable and flexible guidelines, including negotiation objectives, for the conduct of negotiations regarding the respective rights in technical data of the United States and the contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa377ce6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1833/a/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1833(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4226"},"text":"134 Stat. 4226","children":[],"tail":", 4228.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa377ce7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa377ce8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa377ce9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (a), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/1"},"text":"Pub. L. 116–283, § 1833(c)(1)","children":[],"tail":", (2), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1216/a"},"text":"Pub. L. 98–525, title XII, § 1216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2596"},"text":"98 Stat. 2596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVIII/s8106/a"},"text":"Pub. L. 103–355, title VIII, § 8106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3393"},"text":"108 Stat. 3393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s844"},"text":"Pub. L. 108–136, div. A, title VIII, § 844","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1553"},"text":"117 Stat. 1553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII"},"text":"Pub. L. 112–81, div. A, title VIII","children":[],"tail":", 815(a), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1492"},"text":"125 Stat. 1492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s809/c"},"text":"Pub. L. 114–328, div. A, title VIII, § 809(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2267"},"text":"130 Stat. 2267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/c/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1866"},"text":"132 Stat. 1866","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (b), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/1"},"text":"Pub. L. 116–283, § 1833(c)(1)","children":[],"tail":", (3), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1216/a"},"text":"Pub. L. 98–525, title XII, § 1216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2596"},"text":"98 Stat. 2596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVIII/s808/b"},"text":"Pub. L. 100–180, div. A, title VIII, § 808(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1130"},"text":"101 Stat. 1130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVIII/s821/a"},"text":"Pub. L. 111–84, div. A, title VIII, § 821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2411"},"text":"123 Stat. 2411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s801/a/1"},"text":"Pub. L. 111–383, div. A, title VIII, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4253"},"text":"124 Stat. 4253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVIII/s802/b/1"},"text":"Pub. L. 112–81, div. A, title VIII, § 802(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1485"},"text":"125 Stat. 1485","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa377cea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/1"},"text":"Pub. L. 116–283, § 1833(c)(1)","children":[],"tail":", (2)(A)–(C), redesignated subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":" as subsec. (a) of this section, inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"section 3771 of this title","children":[],"tail":"” for “subsection (a)” and “section 3063” for “section 2303” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/2/D"},"text":"Pub. L. 116–283, § 1833(c)(2)(D)","children":[],"tail":", substituted “section 3784” for “section 2321(f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/2/E"},"text":"Pub. L. 116–283, § 1833(c)(2)(E)","children":[],"tail":", inserted dash after “the contractor” and reorganized remainder of text into designated subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/2/F"},"text":"Pub. L. 116–283, § 1833(c)(2)(F)","children":[],"tail":", inserted dash after “is found” and reorganized remainder of text into designated subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/2/G"},"text":"Pub. L. 116–283, § 1833(c)(2)(G)","children":[],"tail":", substituted “paragraphs (4)(A)(ii), (6), and (7) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771/b"},"text":"section 3771(b) of this title","children":[],"tail":"” for “subparagraphs (D)(i)(II), (F), and (G) of subsection (a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/2/H"},"text":"Pub. L. 116–283, § 1833(c)(2)(H)","children":[],"tail":", substituted “section 3782” for “section 2321(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/3/A"},"text":"Pub. L. 116–283, § 1833(c)(3)(A)","children":[],"tail":", which directed substitution of “in this subchapter or in section 3208” for “in this section or in section 2305(a)”, was executed by making the substitution for “in this section or in section 2305(d)” in introductory provisions to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/1"},"text":"Pub. L. 116–283, § 1833(c)(1)","children":[],"tail":" redesignated subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2320"},"text":"section 2320 of this title","children":[],"tail":" as subsec. (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1833/c/3/B"},"text":"Pub. L. 116–283, § 1833(c)(3)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3771"},"text":"section 3771 of this title","children":[],"tail":"” for “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa377ceb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa377cec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
