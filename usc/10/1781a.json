{"tag":"section","attrib":{"id":"ida90fed6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1781a"},"text":"§ 1781a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense Military Family Readiness Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90fed70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Department of Defense the Department of Defense Military Family Readiness Council (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90fed71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90fed72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall consist of the following members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90fed73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Personnel and Readiness, who shall serve as chair of the Council and who may designate a representative to chair the council in the Under Secretary’s absence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following persons, who shall be appointed or designated by the Secretary of Defense:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida90fed75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One representative of each of the Army, Navy, Air Force, Marine Corps, and Space Force, each of whom shall be a member or civilian employee of the armed force to be represented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One representative, who shall be a member or civilian employee of the National Guard Bureau, to represent both the Army National Guard and the Air National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One spouse or parent of a member of each of the Army, Navy, Air Force, Marine Corps, and Space Force, two of whom shall be the spouse or parent of an active component member, two of whom shall be the spouse or parent of a reserve component member, and one of whom shall be the spouse or parent of a member of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three individuals appointed by the Secretary of Defense from among representatives of military family organizations, including military family organizations of families of members of the regular components and of families of members of the reserve components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The senior enlisted advisor from each of the Army, Navy, Air Force, Marine Corps, and Space Force, except that two of these members may instead be selected from among the spouses of the senior enlisted advisors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Military Family Readiness Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90fed7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term on the Council of the members appointed or designated under subparagraph (B) of paragraph (1) shall be two years and may be renewed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term on the Council of the members appointed under subparagraph (C) of paragraph (1) shall be two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90fed7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet not less often than twice each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90fed7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Council shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90fed80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review and make recommendations to the Secretary of Defense regarding the policy and plans required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1781b"},"text":"section 1781b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To monitor requirements for the support of military family readiness programs and activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To evaluate and assess the effectiveness of the military family readiness programs and activities of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make recommendations to the Secretary of Defense to improve collaboration, awareness, and promotion of accurate and timely military family readiness information and support services by policy makers, service providers, and targeted beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90fed84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Family Readiness Working Group for Military Housing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90fed85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Council the Military Family Readiness Working Group for Military Housing (in this section referred to as the “Housing Working Group”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90fed87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Housing Working Group shall be composed of the following members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida90fed88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary of Defense for Energy, Installations, and Environment, who shall serve as chair of the Housing Working Group on a nondelegable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" One representative of each of the Army, Navy, Air Force, Marine Corps, and Space Force—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida90fed8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of whom shall be a member of the armed force to be represented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida90fed8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than two of whom shall be enlisted members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One spouse of a member of each of the Army, Navy, Air Force, Marine Corps, and Space Force on active duty, not fewer than two of which shall be the spouse of an enlisted member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One commander or senior official of a military installation from each military department with responsibility for the public works or civil engineering systems of such installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One individual appointed by the Secretary of Defense among representatives of a voluntary consensus standards body that develops personnel certification standards for building maintenance, inspections, or restoration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Military Family Readiness Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of Housing Working Group members specified under clauses (ii) through (v) of subparagraph (A) shall be two years and may be renewed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chair of the Housing Working Group shall extend an invitation to all landlords for one representative of each landlord to attend such meetings of the Housing Working Group as the chair considers appropriate but at a minimum of once per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Housing Working Group shall meet at least two times each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The duties of the Housing Working Group shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90fed94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review and make recommendations to the Secretary of Defense on policies for covered military housing, including inspections practices and resident surveys.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To make recommendations to the Secretary of Defense to improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida90fed96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awareness and promotion of accurate and timely information about covered military housing, accommodations available through the Exceptional Family Member Program of the Department, and other support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90fed97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaboration among policymakers, providers of such accommodations and other support services, and targeted beneficiaries of such accommodations and other support services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90fed98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90fed99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “landlord” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2871"},"text":"section 2871 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90fed9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1781a/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered military housing” means housing acquired or constructed pursuant to subchapter IV of chapter 169 of this title that is owned by an entity other than the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90fed9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s581/a"},"text":"Pub. L. 110–181, div. A, title V, § 581(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/120"},"text":"122 Stat. 120","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s562"},"text":"Pub. L. 111–84, div. A, title V, § 562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2303"},"text":"123 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s581"},"text":"Pub. L. 111–383, div. A, title V, § 581","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4226"},"text":"124 Stat. 4226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s574"},"text":"Pub. L. 112–81, div. A, title V, § 574","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1427"},"text":"125 Stat. 1427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s933/a/2"},"text":"Pub. L. 114–328, div. A, title IX, § 933(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2364"},"text":"130 Stat. 2364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s571/a"},"text":"Pub. L. 115–232, div. A, title V, § 571(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1777"},"text":"132 Stat. 1777","children":[],"tail":", 1778; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/29"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3825"},"text":"134 Stat. 3825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/k/1"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(k)(1)","children":[],"tail":", div. B, title XXVIII, § 2821(a), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/673"},"text":"137 Stat. 673","children":[],"tail":", 749.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90fed9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90fed9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90fed9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1722/k/1"},"text":"Pub. L. 118–31, § 1722(k)(1)","children":[],"tail":", substituted “active component member,” for “active component member and” and inserted “, and one of whom shall be the spouse or parent of a member of the Space Force” after “parent of a reserve component member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s2821/a"},"text":"Pub. L. 118–31, § 2821(a)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) related to annual reports on military family readiness."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Air Force, Marine Corps, and Space Force” for “Marine Corps, and Air Force” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/a/1/A"},"text":"Pub. L. 115–232, § 571(a)(1)(A)","children":[],"tail":", substituted “a member or civilian employee of the armed force to be represented” for “a member of the armed force to be represented”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/a/1/B"},"text":"Pub. L. 115–232, § 571(a)(1)(B)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “One representative of the Army National Guard or the Air National Guard, who may be a member of the National Guard.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/a/2/A"},"text":"Pub. L. 115–232, § 571(a)(2)(A)","children":[],"tail":", struck out “clauses (i) and (iii) of” before “subparagraph (B)” and “Representation on the Council under clause (ii) of that subparagraph shall rotate between the Army National Guard and Air National Guard every two years on a calendar year basis.” after “Secretary of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/a/2/B"},"text":"Pub. L. 115–232, § 571(a)(2)(B)","children":[],"tail":", substituted “two years” for “three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/b/1"},"text":"Pub. L. 115–232, § 571(b)(1)","children":[],"tail":", substituted “military family readiness programs and activities of the Department of Defense” for “military family readiness by the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/b/2"},"text":"Pub. L. 115–232, § 571(b)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s571/c"},"text":"Pub. L. 115–232, § 571(c)","children":[],"tail":", substituted “July 1” for “February 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “Office of Military Family Readiness Policy” for “Office of Community Support for Military Families with Special Needs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) related to members."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/d/1/A"},"text":"Pub. L. 111–383, § 581(d)(1)(A)","children":[],"tail":", struck out “, who shall be appointed by the Secretary of Defense” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/d/1/B"},"text":"Pub. L. 111–383, § 581(d)(1)(B)","children":[],"tail":", struck out “, who shall be appointed by the Secretary of Defense” after “Air National Guard” in cl. (i) and after “Air Force Reserve” in cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/d/1/C"},"text":"Pub. L. 111–383, § 581(d)(1)(C)","children":[],"tail":", struck out “by the Secretary of Defense” after “appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/a/1/B"},"text":"Pub. L. 111–383, § 581(a)(1)(B)","children":[],"tail":", added subpar. (E). Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/c"},"text":"Pub. L. 111–383, § 581(c)","children":[],"tail":", amended subpar. (F) generally. Prior to amendment, subpar. (F) read as follows: “In addition to the representatives appointed under subparagraphs (B) and (C), the senior enlisted advisors of the Army, Navy, Marine Corps, and Air Force, or the spouse of a senior enlisted member from each of the Army, Navy, Marine Corps, and Air Force.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/a/1/A"},"text":"Pub. L. 111–383, § 581(a)(1)(A)","children":[],"tail":", redesignated subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/b"},"text":"Pub. L. 111–383, § 581(b)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/a/2"},"text":"Pub. L. 111–383, § 581(a)(2)","children":[],"tail":", substituted “subparagraphs (C), (D), and (E)” for “subparagraphs (C) and (D)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s581/d/2"},"text":"Pub. L. 111–383, § 581(d)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s562/a"},"text":"Pub. L. 111–84, § 562(a)","children":[],"tail":", added subpar. (C), redesignated former subpars. (C) and (D) as (D) and (E), respectively, and substituted “subparagraphs (B) and (C)” for “subparagraph (B)” in subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s562/b"},"text":"Pub. L. 111–84, § 562(b)","children":[],"tail":", substituted “subparagraphs (C) and (D) of paragraph (1)” for “paragraph (1)(C)” and inserted at end “Representation on the Council required by clause (i) of paragraph (1)(C) shall rotate between the Army National Guard and Air National Guard. Representation required by clause (ii) of such paragraph shall rotate among the reserve components specified in such clause.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90fed9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90feda0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s571/d"},"text":"Pub. L. 115–232, div. A, title V, § 571(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1778"},"text":"132 Stat. 1778","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tV/s571/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of membership and term amendments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) shall apply to members of the Department of Defense Military Family Readiness Council appointed after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
