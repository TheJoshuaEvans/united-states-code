{"tag":"section","attrib":{"id":"idabbe92e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16163a"},"text":"§ 16163a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to transfer unused education benefits to family members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabbe92e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the provisions of this section, the Secretary concerned may permit, at such Secretary’s sole discretion, a member described in subsection (b) who is entitled to basic educational assistance under this chapter to elect to transfer to one or more of the dependents specified in subsection (c) a portion of such member’s entitlement to such assistance, subject to the limitation under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member referred to in subsection (a) is a member of the armed forces who, at the time of the approval of the member’s request to transfer entitlement to basic educational assistance under this section, has completed at least—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc102e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six years of service in the armed forces and enters into an agreement to serve at least four more years as a member of the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service as determined in regulations pursuant to subsection (j).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member approved to transfer an entitlement to basic educational assistance under this section may transfer the member’s entitlement as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc102e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the member’s spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To one or more of the member’s children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To a combination of the individuals referred to in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Months of Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total number of months of entitlement transferred by a member under this section may not exceed 36 months. The Secretary of Defense may prescribe regulations that would limit the months of entitlement that may be transferred under this section to no less than 18 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Transferee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member transferring an entitlement to basic educational assistance under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc102eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the dependent or dependents to whom such entitlement is being transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the number of months of such entitlement to be transferred to each such dependent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the period for which the transfer shall be effective for each dependent designated under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Transfer; Revocation and Modification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc102ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the time limitation for use of entitlement under section 16164, a member approved to transfer entitlement to basic educational assistance under this section may transfer such entitlement only while serving as a member of the armed forces when the transfer is executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member transferring entitlement under this section may modify or revoke at any time the transfer of any unused portion of the entitlement so transferred. The modification or revocation of the transfer of entitlement under this paragraph shall be made by the submittal of written notice of the action to both the Secretary concerned and the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entitlement transferred under this section may not be treated as marital property, or the asset of a marital estate, subject to division in a divorce or other civil proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement of Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dependent to whom entitlement to basic educational assistance is transferred under this section may not commence the use of the transferred entitlement until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc102f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of entitlement transferred to a spouse, the completion by the member making the transfer of at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc102f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six years of service in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc102f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service as determined in regulations pursuant to subsection (j); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of entitlement transferred to a child, both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc102f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the completion by the member making the transfer of at least—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabc102f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ten years of service in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc102f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the years of service as determined in regulations pursuant to subsection (j); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc102fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabc102fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the completion by the child of the requirements of a secondary school diploma (or equivalency certificate); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc102fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attainment by the child of 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc102fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Administrative Matters","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc102fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of any entitlement to basic educational assistance transferred under this section shall be charged against the entitlement of the member making the transfer at the rate of one month for each month of transferred entitlement that is used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc102ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subsection (e)(2) and subject to paragraphs (5) and (6), a dependent to whom entitlement is transferred under this section is entitled to basic educational assistance under this chapter in the same manner as the member from whom the entitlement was transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10300-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly rate of educational assistance payable to a dependent to whom entitlement is transferred under this section shall be the monthly amount payable under sections 16162 and 16162a to the member making the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10301-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The death of a member transferring an entitlement under this section shall not affect the use of the entitlement by the dependent to whom the entitlement is transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10302-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 16164(a)(2), a child to whom entitlement is transferred under this section may use the benefit without regard to the 10-year delimiting date, but may not use any entitlement so transferred after attaining the age of 26 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10303-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administrative provisions of this chapter shall apply to the use of entitlement transferred under this section, except that the dependent to whom the entitlement is transferred shall be treated as the eligible member for purposes of such provisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10304-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/h/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purposes for which a dependent to whom entitlement is transferred under this section may use such entitlement shall include the pursuit and completion of the requirements of a secondary school diploma (or equivalency certificate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10305-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overpayment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc10306-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint and several liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event of an overpayment of basic educational assistance with respect to a dependent to whom entitlement is transferred under this section, the dependent and the member making the transfer shall be jointly and severally liable to the United States for the amount of the overpayment for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3685"},"text":"section 3685 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10307-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to complete service agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (3), if an individual transferring entitlement under this section fails to complete the service agreed to by the individual under subsection (b)(1) in accordance with the terms of the agreement of the individual under that subsection, the amount of any transferred entitlement under this section that is used by a dependent of the individual as of the date of such failure shall be treated as an overpayment of educational assistance under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc10308-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (2) shall not apply in the case of an individual who fails to complete service agreed to by the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc10309-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of the death of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1030a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a reason referred to in section 16133(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc1030b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc1030c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, in coordination with the Secretary of Veterans Affairs, shall prescribe regulations for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1030d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such regulations shall specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc1030e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner of authorizing the transfer of entitlements under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1030f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility criteria in accordance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc10310-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner and effect of an election to modify or revoke a transfer of entitlement under subsection (f)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc10311-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16163a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary Concerned Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “Secretary concerned” has the meaning given in section 101(a)(9) in the case of a member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc10312-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/252/tV/s5006/c"},"text":"Pub. L. 110–252, title V, § 5006(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2383"},"text":"122 Stat. 2383","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/56"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(56)","children":[],"tail":", "},{"tag":"date","att