{"tag":"section","attrib":{"id":"ida959c7b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246"},"text":null,"children":[{"tag":"num","attrib":{"value":"2246"},"text":"§ 2246.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of certain support for military service academy foundations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c7b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b) and pursuant to regulations prescribed by the Secretary of Defense, the Superintendent of a Service Academy may authorize a covered foundation to use, on an unreimbursed basis, facilities or equipment of such Service Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Use of facilities or equipment under subsection (a) may be provided only if such use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c7b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is without any liability of the United States to the covered foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not affect the ability of any official or employee of the military department concerned, or any member of the armed forces, to carry out any responsibility or duty in a fair and objective manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not compromise the integrity or appearance of integrity of any program of the military department concerned, or any individual involved in such a program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the participation of any cadet or midshipman, other than participation in an honor guard at an event of the covered foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the Joint Ethics Regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been reviewed and approved by an attorney of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any fiscal year during which the Superintendent of a Service Academy exercises the authority under subsection (a), the Secretary of the military department concerned shall provide a briefing not later than the last day of that fiscal year to the Committees on Armed Services of the Senate and House of Representatives regarding the number of events or activities of a covered foundation supported by such exercise during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c7bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered foundation” means a charitable, educational, or civic nonprofit organization under section 501(c)(3) of the Internal Revenue Code of 1986, that the Secretary concerned determines operates exclusively to support, with respect to a Service Academy, any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c7bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruiting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c7be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parent or alumni development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c7bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Academic, leadership, or character development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c7c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Institutional development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c7c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Athletics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2246/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Service Academy” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s347"},"text":"section 347 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c7c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s551/a"},"text":"Pub. L. 117–263, div. A, title V, § 551(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2591"},"text":"136 Stat. 2591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c7c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c7c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida959c7c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(3) of the Internal Revenue Code of 1986, referred to in subsec. (d)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida959c7c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s551/a"},"text":"Pub. L. 117–263, div. A, title V, § 551(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2591"},"text":"136 Stat. 2591","children":[],"tail":", which directed amendment of this subchapter by inserting this section “after section 2245 the end”, was executed by inserting this section after "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2245"},"text":"section 2245 of this title","children":[],"tail":" to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida959c7c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2246"},"text":"section 2246 of this title","children":[],"tail":" was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2491a"},"text":"section 2491a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
