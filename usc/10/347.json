{"tag":"section","attrib":{"id":"ida7a56145-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347"},"text":null,"children":[{"tag":"num","attrib":{"value":"347"},"text":"§ 347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International engagement authorities for service academies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a56146-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Persons From Foreign Countries To Receive Instruction at Service Academies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a56147-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attendance authorized.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a56148-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of each military department may permit persons from foreign countries to receive instruction at the Service Academy under the jurisdiction of the Secretary. Such persons shall be in addition to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7a56149-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the United States Military Academy, the authorized strength of the Corps of the Cadets of the Academy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7442"},"text":"section 7442 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7a5614a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the United States Naval Academy, the authorized strength of the Brigade of Midshipmen of the Academy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8454"},"text":"section 8454 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7a5614b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the United States Air Force Academy, the authorized strength of the Cadet Wing of the Academy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9442"},"text":"section 9442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a5614c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on number","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of persons permitted to receive instruction at each Service Academy under this subsection may not be more than 80 at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a5614d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of foreign countries from which persons may be selected","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of a military department, upon approval by the Secretary of Defense, shall determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a5614e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the countries from which persons may be selected for appointment under this subsection to the Service Academy under the jurisdiction of that Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a5614f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of persons that may be selected from each country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56150-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications and selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of each military department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a56151-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish entrance qualifications and methods of competition for selection among individual applicants under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a56152-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall select those persons who will be permitted to receive instruction at the Service Academy under the jurisdiction of the Secretary under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56153-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection priority to persons with national service obligation upon graduation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In selecting persons to receive instruction under this subsection from among applicants from the countries approved under paragraph (2), the Secretary of the military department concerned shall give a priority to persons who have a national service obligation to their countries upon graduation from the Service Academy concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56154-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay, allowances, and emoluments of persons admitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person receiving instruction under this subsection is entitled to the pay, allowances, and emoluments of a cadet or midshipman appointed from the United States, and from the same appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56155-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of costs by foreign countries from which persons are admitted.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a56156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each foreign country from which a cadet or midshipman is permitted to receive instruction at one of the Service Academies under this subsection shall reimburse the United States for the cost of providing such instruction, including the cost of pay, allowances, and emoluments provided under paragraph (5). The Secretaries of the military departments shall prescribe the rates for reimbursement under this paragraph, except that the reimbursement rates may not be less than the cost to the United States of providing such instruction, including pay, allowances, and emoluments, to a cadet or midshipman appointed from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a56157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may waive, in whole or in part, the requirement for reimbursement of the cost of instruction for a cadet or midshipman under subparagraph (A). In the case of a partial waiver, the Secretary of Defense shall establish the amount waived.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of academy regulations, etc.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a56159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as the Secretary of the military department concerned determines, a person receiving instruction under this subsection at the Service Academy under the jurisdiction of that Secretary is subject to the same regulations governing admission, attendance, discipline, resignation, discharge, dismissal, and graduation as a cadet or midshipman at that Academy appointed from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a5615a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classified information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned may prescribe regulations with respect to access to classified information by a person receiving instruction under this subsection at the Service Academy under the jurisdiction of that Secretary that differ from the regulations that apply to a cadet or midshipman at that Academy appointed from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a5615b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility for appointment in the united states armed forces","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person receiving instruction at a Service Academy under this subsection is not entitled to an appointment in an armed force of the United States by reason of graduation from the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a5615c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of requirement for taking oath of admission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person receiving instruction under this subsection is not subject to section 7446(d), 8458(d), or 9446(d) of this title, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a5615d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exchange Programs With Foreign Military Academies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a5615e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exchange programs authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may permit a student enrolled at a military academy of a foreign country to receive instruction at the Service Academy under the jurisdiction of that Secretary in exchange for a cadet or midshipman receiving instruction at that foreign military academy pursuant to an exchange agreement entered into between the Secretary and appropriate officials of the foreign country. A student receiving instruction at a Service Academy under the exchange program under this subsection shall be in addition to persons receiving instruction at the Academy under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a5615f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on number and duration of exchanges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An exchange agreement under this subsection between the Secretary and a foreign country shall provide for the exchange of students on a one-for-one basis each fiscal year. Not more than 100 cadets or midshipmen from each Service Academy and a comparable number of students from foreign military academies participating in the exchange program may be exchanged during any fiscal year. The duration of an exchange may not exceed the equivalent of one academic semester at a Service Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs and expenses.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a56161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No pay and allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A student from a military academy of a foreign country is not entitled to the pay, allowances, and emoluments of a cadet or midshipman by reason of attendance at a Service Academy under the exchange program, and the Department of Defense may not incur any cost of international travel required for transportation of such a student to and from the sponsoring foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a56162-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsistence, transportation, etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned may provide a student from a foreign country under the exchange program, during the period of the exchange, with subsistence, transportation within the continental United States, clothing, health care, and other services to the same extent that the foreign country provides comparable support and services to the exchanged cadet or midshipman in that foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a56163-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Service Academy shall bear all costs of the exchange program from funds appropriated for that Academy and from such additional funds as may be available to that Academy from a source, other than appropriated funds, to support cultural immersion, regional awareness, or foreign language training activities in connection with the exchange program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a56164-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on expenditures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Expenditures in support of the exchange program from funds appropriated for each Academy may not exceed $1,000,000 during any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56165-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of other laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraphs (7), (8), and (9) of subsection (a) shall apply with respect to a student enrolled at a military academy of a foreign country while attending a Service Academy under the exchange program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56166-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned shall prescribe regulations to implement this subsection. Such regulations may include qualification criteria and methods of selection for students of foreign military academies to participate in the exchange program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a56167-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign and Cultural Exchange Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a56168-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attendance authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may authorize the Service Academy under the jurisdiction of that Secretary to permit students, officers, and other representatives of a foreign country to attend that Academy for periods of not more than four weeks if the Secretary determines that the attendance of such persons contributes significantly to the development of foreign language, cross-cultural interactions and understanding, and cultural immersion of cadets or midshipmen, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d169-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of attendance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Persons attending a Service Academy under paragraph (1) are not considered to be students enrolled at that Academy and are in addition to persons receiving instruction at that Academy under subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d16a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial matters.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d16b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs and expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may pay the travel, subsistence, and similar personal expenses of persons incurred to attend the Service Academy under the jurisdiction of that Secretary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d16c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Service Academy shall bear the costs of the attendance of persons at that Academy under paragraph (1) from funds appropriated for that Academy and from such additional funds as may be available to that Academy from a source, other than appropriated funds, to support cultural immersion, regional awareness, or foreign language training activities in connection with their attendance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d16d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on expenditures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Expenditures from appropriated funds in support of activities under this subsection for any Service Academy may not exceed $40,000 during any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d16e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Academy Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Service Academy” means the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d16f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Military Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d170-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Naval Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d171-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s347/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Air Force Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d172-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1248/a"},"text":"Pub. L. 114–328, div. A, title XII, § 1248(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2522"},"text":"130 Stat. 2522","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/a/18"},"text":"Pub. L. 115–91, div. A, title X, § 1081(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1595"},"text":"131 Stat. 1595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", title XII, § 1204(c)(1)(D), "