{"tag":"section","attrib":{"id":"ida7a56130-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346"},"text":null,"children":[{"tag":"num","attrib":{"value":"346"},"text":"§ 346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution to certain foreign personnel of education and training materials and information technology to enhance military interoperability with the armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a56131-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enhance interoperability between the armed forces and military forces of friendly foreign countries, the Secretary of Defense, with the concurrence of the Secretary of State, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a56132-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to personnel referred to in subsection (b) electronically-distributed learning content for the education and training of such personnel for the development or enhancement of allied and friendly military and civilian capabilities for multinational operations, including joint exercises and coalition operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56133-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information technology, including computer software developed for such purpose, but only to the extent necessary to support the use of such learning content for the education and training of such personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a56134-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The personnel to whom learning content and information technology may be provided under subsection (a) are military and civilian personnel of a friendly foreign government, with the permission of that government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a56135-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education and Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any education and training provided under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a56136-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Internet-based education and training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a56137-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced distributed learning and similar Internet learning tools, as well as distributed training and computer-assisted exercises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a56138-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Export Control Regimes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provision of learning content and information technology under this section shall be subject to the provisions of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"22 U.S.C. 2751","children":[],"tail":" et seq.) and any other export control regime under law relating to the transfer of military technology to foreign countries."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a56139-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance on Utilization of Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a5613a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall develop and issue guidance on the procedures for the use of the authority in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a5613b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s346/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary modifies the guidance issued under paragraph (1), the Secretary shall submit to the appropriate committees of Congress a report setting forth the modified guidance not later than 30 days after the date of such modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a5613c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XII, § 1205(a)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4623"},"text":"122 Stat. 4623","children":[],"tail":", § 2249d; renumbered § 346 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/h"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2507"},"text":"130 Stat. 2507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a5613d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a5613e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7a5613f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":", which is classified principally to chapter 39 (§ 2751 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a56140-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/h/1"},"text":"Pub. L. 114–328, § 1241(h)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2249d"},"text":"section 2249d of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/h/2/A"},"text":"Pub. L. 114–328, § 1241(h)(2)(A)","children":[],"tail":", substituted “countries” for “nations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/h/2/B"},"text":"Pub. L. 114–328, § 1241(h)(2)(B)","children":[],"tail":", struck out subsecs. (f) and (g) which, respectively, required the Secretary of Defense to submit annual reports to the appropriate committees of Congress and defined “appropriate committees of Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7a56141-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7a56142-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XII, § 1205(d), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4625"},"text":"122 Stat. 4625","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"“This section [enacting this section and provisions set out as notes under this section] and the amendments made by this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7a56143-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Provide Mission Training Through Distributed Simulation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXII/s1210"},"text":"Pub. L. 118–31, div. A, title XII, § 1210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/449"},"text":"137 Stat. 449","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXII/s1210"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Training and Distribution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enhance the interoperability and integration between the United States Armed Forces and the military forces of friendly foreign countries, effective beginning on the date that is 30 days after the date on which the Secretary of Defense submits the report required by subsection (d), the Secretary of Defense, with the concurrence of the Secretary of State, is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide to military personnel of a friendly foreign country persistent advanced networked training and exercise activities (in this section referred to as ‘mission training through distributed simulation’); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information technology related to mission training through distributed simulation, including hardware and computer software developed for such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Mission Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Mission training through distributed simulation provided under subsection (a) may include advanced distributed network training events and computer-assisted exercises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance on Use of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Secretary of Defense shall develop and issue guidance on the procedures for the use of the authority provided in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to the appropriate committees of Congress a report on the anticipated use of mission training through distributed simulation by military personnel of friendly foreign countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of anticipated mission training through distributed simulation activities between the United States Armed Forces and the military forces of friendly foreign countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the current capabilities of the military forces of friendly foreign countries to support mission training through distributed simulation activities with the United States Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the manner in which the Department intends to use mission training through distributed simulation activities to support implementation of the National Defense Strategy, including in areas of responsibility of the United States European Command and the United States Indo-Pacific Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendation of the Secretary of Defense for legislative proposals or policy guidance regarding the use of mission training through distributed simulation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term ‘appropriate committees of Congress’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Appropriations, and the Committee on Foreign Relations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Appropriations, and the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided in this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7a56144-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance on Utilization of Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title XII, § 1205(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4624"},"text":"122 Stat. 4624","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after issuing the guidance required by section 2249d(e) [now 346(e)] of title 10, United States Code, as added by subsection (a), the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report setting forth such guidance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utilization of similar guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the guidance required by section 2249d(e) [now 346(e)] of title 10, United States Code, as so added, the Secretary may utilize applicable portions of the current guidance developed by the Secretary under subsection (f) of section 1207 of the John Warner National Defense Authorization Act for Fiscal Year 2007 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Public Law 109–364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/120/2419"},"text":"120 Stat. 2419","children":[],"tail":") for purposes of the exercise of the authority in such section 1207.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
