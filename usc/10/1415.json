{"tag":"section","attrib":{"id":"ida8c5ec3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415"},"text":null,"children":[{"tag":"num","attrib":{"value":"1415"},"text":"§ 1415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump sum payment of certain retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8c5ec3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c5ec3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered retired pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered retired pay” means retired pay under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c5ec40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title 14;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Oceanic and Atmospheric Administration Commissioned Officer Corps Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s3001"},"text":"33 U.S.C. 3001","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"42 U.S.C. 201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible person","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible person” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c5ec45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8c5ec46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first becomes a member of a uniformed service on or after ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8c5ec47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the election described in section 1409(b)(4)(B) or 12739(f)(2) of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not retire or separate under chapter 61 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement age","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “retirement age” has the meaning given the term in section 216(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s416"},"text":"42 U.S.C. 416","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c5ec4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election of Lump Sum Payment of Certain Retired Pay.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c5ec4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible person entitled to covered retired pay (including an eligible person who is entitled to such pay by reason of an election described in subsection (a)(2)(A)(ii)) may elect to receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c5ec4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a lump sum payment of the discounted present value at the time of the election of an amount of the covered retired pay that the eligible person is otherwise entitled to receive for the period beginning on the date of retirement and ending on the date the eligible person attains the eligible person’s retirement age equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8c5ec4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the amount of such covered retired pay during such period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8c5ec4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the amount of such covered retired pay during such period; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a monthly amount during the period described in subparagraph (A) equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8c5ec50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible person electing to receive an amount described in subparagraph (A)(i), 50 percent of the amount of monthly covered retired pay the eligible person is otherwise entitled to receive during such period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8c5ec51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible person electing to receive an amount described in subparagraph (A)(ii), 75 percent of the amount of monthly covered retired pay the eligible person is otherwise entitled to receive during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discounted present value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall compute the discounted present value of amounts of covered retired pay that an eligible person is otherwise entitled to receive for a period for purposes of paragraph (1)(A) by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c5ec53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimating the aggregate amount of retired pay the person would receive for the period, taking into account cost-of-living adjustments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":" projected by the Secretary at the time the person separates from service and would otherwise begin receiving covered retired pay; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reducing the aggregate amount estimated pursuant to subparagraph (A) by an appropriate percentage determined by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8c5ec55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using average personal discount rates (as defined and calculated by the Secretary taking into consideration applicable and reputable studies of personal discount rates for military personnel and past actuarial experience in the calculation of personal discount rates under this paragraph); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8c5ec56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with generally accepted actuarial principles and practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible person shall make the election under this subsection not later than 90 days before the date of the retirement of the eligible person from the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single payment or combination of payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible person may elect to receive a lump sum payment under this subsection in a single payment or in a combination of payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement of payment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible person who makes an election under this subsection shall receive the lump sum payment, or the first installment of a combination of payments of the lump sum payment if elected under paragraph (4), as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8c5ec5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the date of the retirement of the eligible person from the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8c5ec5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an eligible person who is a member of a reserve component, not later than 60 days after the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8c5ec5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the eligible person attains 60 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8c5ec5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the eligible person first becomes entitled to covered retired pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No subsequent adjustment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible person who accepts payment of a lump sum under this subsection may not seek the review of or otherwise challenge the amount of the lump sum in light of any variation in cost-of-living adjustments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":", actuarial assumptions, or other factors used by the Secretary in calculating the amount of the lump sum that occur after the Secretary pays the lump sum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c5ec5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resumption of Monthly Annuity.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c5ec60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), an eligible person who makes an election described in subsection (b)(1) shall be entitled to receive the eligible person’s monthly covered retired pay calculated in accordance with paragraph (2) after the eligible person attains the eligible person’s retirement age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c5ec61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restoration of full retirement amount at retirement age","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The retired pay of an eligible person who makes an election described in subsection (a) shall be recomputed, effective on the first day of the first month beginning after the person attains the eligible person’s retirement age, so as to be an amount equal to the amount of covered retired pay to which the eligible person would otherwise be entitled on that date if the annual increases, in the retired pay of the eligible person made to reflect changes in the Consumer Price Index, had been made in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c5ec62-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Retired Pay to Persons Not Making Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible person who does not make the election described in subsection (b)(1) shall be paid the retired pay to which the eligible person is otherwise entitled under the applicable provisions of law referred to in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c5ec63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1415/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c5ec64-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s633/a/1"},"text":"Pub. L. 114–92, div. A, title VI, § 633(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/847"},"text":"129 Stat. 847","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/a/4"},"text":"Pub. L. 114–328, div. A, title X, § 1081(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2417"},"text":"130 Stat. 2417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/14"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1984"},"text":"132 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8c5ec65-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8c5ec66-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8c5ec67-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Oceanic and Atmospheric Administration Commissioned Officer Corps Act of 2002, referred to in subsec. (a)(1)(C), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/372"},"text":"Pub. L. 107–372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-19"}