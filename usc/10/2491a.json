{"tag":"section","attrib":{"id":"ida984a8d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2491a"},"text":"§ 2491a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense golf courses: limitation on use of appropriated funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida984a8d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), funds appropriated to the Department of Defense may not be used to equip, operate, or maintain a golf course at a facility or installation of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a8d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a8d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to a golf course at a facility or installation outside the United States or at a facility or installation inside the United States at a location designated by the Secretary of Defense as a remote and isolated location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a8d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2491a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations governing the use of appropriated funds under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida984a8d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s312/a"},"text":"Pub. L. 103–160, div. A, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1618"},"text":"107 Stat. 1618","children":[],"tail":", § 2246; renumbered § 2491a, "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/d"},"text":"Pub. L. 108–375, div. A, title VI, § 651(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1972"},"text":"118 Stat. 1972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida984a8d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida984a8d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida984a8da-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2246"},"text":"section 2246 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
