":"p","attrib":{},"text":"In subsection (b), the word “under” is substituted for the words “in pursuance of”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81a423a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81a423b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s4/a/3/A"},"text":"Pub. L. 109–366, § 4(a)(3)(A)","children":[],"tail":", inserted “, except as provided in chapter 47A of this title,” after “but which may not”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s4/a/3/B"},"text":"Pub. L. 109–366, § 4(a)(3)(B)","children":[],"tail":", inserted before period at end “, except insofar as applicable to military commissions established under chapter 47A of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out “and shall be reported to Congress” after “as practicable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/107"},"text":"Pub. L. 96–107","children":[],"tail":" substituted provisions authorizing pretrial, trial, and post-trial procedures for cases under this chapter triable in courts-martial, military commissions and other military tribunals, for provisions authorizing procedure in cases before courts-martial, military commissions, and other military tribunals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
