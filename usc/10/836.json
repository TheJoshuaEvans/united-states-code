{"tag":"section","attrib":{"id":"ida81a4233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s836"},"text":null,"children":[{"tag":"num","attrib":{"value":"836"},"text":"§ 836.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 36. President may prescribe rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81a4234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s836/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pretrial, trial, and post-trial procedures, including modes of proof, for cases arising under this chapter triable in courts-martial, military commissions and other military tribunals, and procedures for courts of inquiry, may be prescribed by the President by regulations which shall, so far as he considers practicable, apply the principles of law and the rules of evidence generally recognized in the trial of criminal cases in the United States district courts, but which may not, except as provided in chapter 47A of this title, be contrary to or inconsistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81a4235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s836/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All rules and regulations made under this article shall be uniform insofar as practicable, except insofar as applicable to military commissions established under chapter 47A of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81a4236-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/50"},"text":"70A Stat. 50","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/107/tVIII/s801/b"},"text":"Pub. L. 96–107, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-09"},"text":"Nov. 9, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/811"},"text":"93 Stat. 811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1301/4"},"text":"Pub. L. 101–510, div. A, title XIII, § 1301(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1668"},"text":"104 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/366/s4/a/3"},"text":"Pub. L. 109–366, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2631"},"text":"120 Stat. 2631","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81a4237-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81a4238-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81a4239-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"htm