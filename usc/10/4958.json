{"tag":"section","attrib":{"id":"idaab11a25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958"},"text":null,"children":[{"tag":"num","attrib":{"value":"4958"},"text":"§ 4958.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide certain types of technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab11a26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance Relating to Certain Non-defense Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procurement technical assistance furnished by eligible entities assisted by the Department of Defense under this chapter may include technical assistance relating to contracts entered into with (1) Federal departments and agencies other than the Department of Defense, and (2) State and local governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Relating to Assistance and Other Programs Available","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible entity assisted by the Department of Defense under this chapter also may furnish information relating to assistance and other programs available pursuant to the Defense Conversion, Reinvestment, and Transition Assistance Act of 1992.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education on Requirements Applicable to Small Businesses Under Certain Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity assisted by the Department of Defense under this chapter also may furnish education on the requirements applicable to small businesses under the regulations issued—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 38 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"22 U.S.C. 2778","children":[],"tail":"), and on compliance with those requirements;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 9 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"15 U.S.C. 638","children":[],"tail":"), and on compliance with those requirements;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under clause 252.204–7012 of the Defense Acquisition Regulation Supplement, or any successor regulation, and on compliance with those requirements (and any successor requirements);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 847 of the National Defense Authorization Act for Fiscal Year 2020 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Public Law 116–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/133/1505"},"text":"133 Stat. 1505","children":[],"tail":"), and on compliance with those requirements (and any such successor requirements); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the AUKUS partnership (as defined in section 1321 of the National Defense Authorization Act for Fiscal Year 2024 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10401"},"text":"22 U.S.C. 10401","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab11a2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab11a2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to an eligible entity that is a center of excellence for the APEX Accelerator Program of the Department of Defense (or a successor program) to provide specialized expertise to business entities outside of the geographic area served by the center of excellence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab11a30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4958/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may waive the government cost share restriction in accordance with section 4954(f) of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab11a31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4236/a/1/B"},"text":"Pub. L. 102–484, div. D, title XLII, § 4236(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2691"},"text":"106 Stat. 2691","children":[],"tail":", § 2418; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVIII/s823/b"},"text":"Pub. L. 113–291, div. A, title VIII, § 823(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3436"},"text":"128 Stat. 3436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVII/s1708"},"text":"Pub. L. 115–91, div. A, title XVII, § 1708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1809"},"text":"131 Stat. 1809","children":[],"tail":"; renumbered § 4958 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1872/a/9"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1872(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4289"},"text":"134 Stat. 