{"tag":"section","attrib":{"id":"ida86b48b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1073b"},"text":"§ 1073b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recurring reports and publication of certain data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida86b48b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report on Recording of Health Assessment Data in Military Health Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall issue each year a report on the compliance by the military departments with applicable law and policies on the recording of health assessment data in military health records, including compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074f/c"},"text":"section 1074f(c) of this title","children":[],"tail":". The report shall cover the calendar year preceding the year in which the report is submitted and include a discussion of the extent to which immunization status and predeployment and postdeployment health care data are being recorded in such records."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida86b48b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Data on Patient Safety, Quality of Care, Satisfaction, and Health Outcome Measures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida86b48b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall publish on a publically available Internet website of the Department of Defense data on all measures that the Secretary considers appropriate that are used by the Department to assess patient safety, quality of care, patient satisfaction, and health outcomes for health care provided under the TRICARE program at each military medical treatment facility. Such data shall include the core quality performance metrics adopted by the Secretary under section 728 of the National Defense Authorization Act for Fiscal Year 2017.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86b48b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish an update to the data published under paragraph (1) not less frequently than once each quarter during each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86b48b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not include data relating to risk management activities of the Department in any publication under paragraph (1) or update under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida86b48b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1073b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the data published under paragraph (1) and updated under paragraph (2) is accessible to the public through the primary Internet website of the Department and the primary Internet website of the military medical treatment facility with respect to which such data applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida86b48b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s739/a/1"},"text":"Pub. L. 108–375, div. A, title VII, § 739(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2001"},"text":"118 Stat. 2001","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVII/s712"},"text":"Pub. L. 114–92, div. A, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/864"},"text":"129 Stat. 864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s728/b/1"},"text":"Pub. L. 114–328, div. A, title VII, § 728(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2234"},"text":"130 Stat. 2234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX"},"text":"Pub. L. 115–91, div. A, title X","children":[],"tail":", §§ 1051(a)(5), 1081(d)(3), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1560"},"text":"131 Stat. 1560","children":[],"tail":", 1600.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida86b48ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida86b48bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida86b48bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 728 of the National Defense Authorization Act for Fiscal Year 2017, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s728"},"text":"section 728 of Pub. L. 114–328","children":[],"tail":", which amended this section and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1071"},"text":"section 1071 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida86b48bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/d/3"},"text":"Pub. L. 115–91, § 1081(d)(3)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s728/b/1"},"text":"Pub. L. 114–328, § 728(b)(1)","children":[],"tail":". See 2016 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1051/a/5"},"text":"Pub. L. 115–91, § 1051(a)(5)","children":[],"tail":", redesignated subsecs. (b) and (c) as (a) and (b), respectively, and struck out former subsec. (a) which related to annual report on the Force Health Protection Quality Assurance Program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s728/b/1/B"},"text":"Pub. L. 114–328, § 728(b)(1)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/d/3"},"text":"Pub. L. 115–91, § 1081(d)(3)","children":[],"tail":", inserted “and publication of certain data” after “reports” in section catchline. Amendment was executed as the probable intent of Congress, notwithstanding directory language amending the section heading of section “1073b(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s728/b/1/A"},"text":"Pub. L. 114–328, § 728(b)(1)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/d/3"},"text":"Pub. L. 115–91, § 1081(d)(3)","children":[],"tail":", substituted “The Secretary” for “Not later than 180 days after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2016, the Secretary” and inserted at end “Such data shall include the core quality performance metrics adopted by the Secretary under section 728 of the National Defense Authorization Act for Fiscal Year 2017.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida86b48be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida86b48bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/d"},"text":"Pub. L. 115–91, div. A, title X, § 1081(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1599"},"text":"131 Stat. 1599","children":[],"tail":", provided that the amendment made by section 1081(d)(3) is effective as of "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida86b48c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of Dental Care","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For purposes of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" adding this section, references to medical readiness, health status, and health care to be considered to include dental readiness, dental status, and dental care, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s740"},"text":"section 740 of Pub. L. 108–375","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074"},"text":"section 1074 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida86b48c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Initial Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVII/s739/a/3"},"text":"Pub. L. 108–375, div. A, title VII, § 739(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2002"},"text":"118 Stat. 2002","children":[],"tail":", directed that the first reports under this section be completed not later than 180 days after "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
