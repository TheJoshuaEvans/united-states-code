{"tag":"section","attrib":{"id":"ida81cb421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847"},"text":null,"children":[{"tag":"num","attrib":{"value":"847"},"text":"§ 847.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 47. Refusal of person not subject to chapter to appear, testify, or produce evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81cb422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person described in paragraph (2) who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81cb424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully neglects or refuses to appear; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully refuses to qualify as a witness or to testify or to produce any evidence which that person is required to produce;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of an offense against the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb426-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The persons referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81cb427-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person not subject to this chapter who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida81cb428-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is issued a subpoena or other process described in subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s846"},"text":"section 846 of this title","children":[],"tail":" (article 46); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida81cb429-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided a means for reimbursement from the Government for fees and mileage at the rates allowed to witnesses attending the courts of the United States or, in the case of extraordinary hardship, is advanced such fees and mileage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb42a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person not subject to this chapter who is issued a subpoena or other process described in subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s846"},"text":"section 846 of this title","children":[],"tail":" (article 46)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb42b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who commits an offense named in subsection (a) shall be tried on indictment or information in a United States district court or in a court of original criminal jurisdiction in any of the Commonwealths or possessions of the United States, and jurisdiction is conferred upon those courts for that purpose. Upon conviction, such a person shall be fined or imprisoned, or both, at the court’s discretion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb42c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States attorney or the officer prosecuting for the United States in any such court of original criminal jurisdiction shall, upon the certification of the facts to him by the military court, commission, court of inquiry, board, or convening authority, file an information against and prosecute any person violating this article.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb42d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s847/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fees and mileage of witnesses shall be advanced or paid out of the appropriations for the compensation of witnesses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81cb42e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/stat/70A/53"},"text":"70A Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXI/s1111"},"text":"Pub. L. 104–106, div. A, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/461"},"text":"110 Stat. 461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/5"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s542/a"},"text":"Pub. L. 112–81, div. A, title V, § 542(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1411"},"text":"125 Stat. 1411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1702/c/3/D"},"text":"Pub. L. 113–66, div. A, title XVII, § 1702(c)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/958"},"text":"127 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVII/s5229"},"text":"Pub. L. 114–328, div. E, title LVII, § 5229","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2913"},"text":"130 Stat. 2913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81cb42f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81cb430-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81cb431-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"847(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"847(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:622(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:622(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 47), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/123"},"text":"64 Stat. 123","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"847(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:622(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"847(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:622(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “Any” is substituted for the word “Every”. The word “is” is substituted for the words “shall be deemed”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “named in subsection (a)” are substituted for the words “denounced by this article”. The words “Territories, Commonwealths, or” are substituted for the word “Territorial”. The words “not more than” are substituted for the words “a period not exceeding”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “It shall be the duty of * * * to” are omitted as surplusage. The words “United States Attorney” are substituted for the words “United States district attorney”, to conform to the terminology of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s501"},"text":"section 501 of title 28","children":[],"tail":". The word “shall” is inserted after the word “jurisdiction”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81cb432-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81cb433-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5229/b"},"text":"Pub. L. 114–328, § 5229(b)","children":[],"tail":", amended section catchline generally, substituting “Refusal of person not subject to chapter to appear, testify, or produce evidence” for “Refusal to appear or testify”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5229/a"},"text":"Pub. L. 114–328, § 5229(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Any person not subject to this chapter who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) has been duly subpoenaed to appear as a witness before a court-martial, military commission, court of inquiry, or any other military court or board, or before any military or civil officer designated to take a deposition to be read in evidence before such a court, commission, or board, or has been duly issued a subpoena duces tecum for a preliminary hearing pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s832"},"text":"section 832 of this title","children":[],"tail":" (article 32);"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) has been provided a means for reimbursement from the Government for fees and mileage at the rates allowed to witnesses attending the courts of the United States or, in the case of extraordinary hardship, is advanced such fees and mileage; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) willfully neglects or refuses to appear, or refuses to qualify as a witness or to testify or to produce any evidence which that person may have been legally subpoenaed to produce;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"is guilty of an offense against the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “a preliminary hearing pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s832"},"text":"section 832 of this title","children":[],"tail":" (article 32)” for “an investigation pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s832/b"},"text":"section 832(b) of this title","children":[],"tail":" (article 32(b))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s542/b"},"text":"Pub. L. 112–81, § 542(b)","children":[],"tail":", substituted “subpoenaed” for “subpenaed” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s542/a/1/A"},"text":"Pub. L. 112–81, § 542(a)(1)(A)","children":[],"tail":", substituted “board, or has been duly issued a subpoena duces tecum for an investigation pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s832/b"},"text":"section 832(b) of this title","children":[],"tail":" (article 32(b));” for “board;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s542/a/1/B"},"text":"Pub. L. 112–81, § 542(a)(1)(B)","children":[],"tail":", substituted “provided a means for reimbursement from the Government for fees and mileage” for “duly paid or tendered the fees and mileage of a witness” and inserted “or, in the case of extraordinary hardship, is advanced such fees and mileage” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s542/a/2"},"text":"Pub. L. 112–81, § 542(a)(2)","children":[],"tail":", substituted “board, or convening authority” for “or board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Commonwealths or possessions” for “Territories, Commonwealths, or possessions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" inserted “indictment or” after “shall be tried on” and substituted “shall be fined or imprisoned, or both, at the court’s discretion” for “shall be punished by a fine of not more than $500, or imprisonment for not more than six months, or both”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81cb434-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb435-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb436-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" effective on the later of "},{"tag":"date","attrib":{"date":"2014-12-26"},"text":"Dec. 26, 2014","children":[],"tail":", or the date of the enactment of the Carl Levin and Howard P. “Buck” McKeon National Defense Authorization Act for Fiscal Year 2015 ("},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":") and applicable with respect to preliminary hearings conducted on or after that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/d/1"},"text":"section 1702(d)(1) of Pub. L. 113–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb437-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s542/c"},"text":"Pub. L. 112–81, div. A, title V, § 542(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1411"},"text":"125 Stat. 1411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tV/s542/c"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to subpoenas issued after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
