{"tag":"section","attrib":{"id":"idab12e90a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8162"},"text":null,"children":[{"tag":"num","attrib":{"value":"8162"},"text":"§ 8162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation commands: eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab12e90b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab12e90c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8162/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to command an aircraft carrier or an aircraft tender, an officer must be an officer in the line of the Navy who is designated as a naval aviator or naval flight officer and who is otherwise qualified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab12e90d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8162/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply to command of a nuclear-powered aircraft carrier that has been inactivated for the purpose of permanent decommissioning and disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab12e90e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to command a naval aviation school, a naval air station, or a naval aviation unit organized for flight tactical purposes, an officer must be an officer in the line of the Navy designated as a naval aviator or naval flight officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab12e90f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to command a Marine Corps aviation school, a Marine Corps air station, or a Marine Corps aviation unit organized for flight tactical purposes, an officer must be an officer of the Marine Corps designated as a naval aviator or naval flight officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab12e910-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/371"},"text":"70A Stat. 371","children":[],"tail":", § 5942; "},{"tag":"ref","attrib":{"href":"/us/pl/91/198/s1/1"},"text":"Pub. L. 91–198, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-02-26"},"text":"Feb. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/15"},"text":"84 Stat. 15","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s507"},"text":"Pub. L. 113–291, div. A, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3357"},"text":"128 Stat. 3357","children":[],"tail":"; renumbered § 8162, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/5"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab12e911-3a