{"tag":"section","attrib":{"id":"ida9e67790-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856"},"text":null,"children":[{"tag":"num","attrib":{"value":"2856"},"text":"§ 2856.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military unaccompanied housing: standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e67791-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Comparability in Floor Areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the construction, acquisition, and improvement of covered military unaccompanied housing, the Secretary concerned shall ensure that the floor areas of such housing in a particular locality (as designated by the Secretary concerned for purposes of this section) do not exceed the floor areas of similar housing in the private sector in that locality, except for purposes of meeting minimum area requirements under subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67792-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Floor Space and Number of Members Allowed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the design and configuration of covered military unaccompanied housing, the Secretary of Defense shall establish uniform design standards that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67793-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a minimum area of floor space, not including bathrooms or closets, per individual occupying a unit of covered military unaccompanied housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67794-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that not more than two individuals may occupy such a unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67795-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide definitions and measures that specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e67796-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria of design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67797-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality of construction material to be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levels of maintenance to be required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2856/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Military Unaccompanied Housing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, section 2856a, and section 2856b, the term “covered military unaccompanied housing” means Government-owned military housing intended to be occupied by members of the armed forces serving a tour of duty unaccompanied by dependents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e6779a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s2/a"},"text":"Pub. L. 97–214, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/166"},"text":"96 Stat. 166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1301/19"},"text":"Pub. L. 101–510, div. A, title XIII, § 1301(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1668"},"text":"104 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2807/a/1"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2468"},"text":"120 Stat. 2468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2831/a/1"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2831(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/753"},"text":"137 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/31"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2205"},"text":"138 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e6779b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e6779c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e6779d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “subsection (b)(1)(A).” for “subsection (b)(1)(A),.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s2831/a/1/B"},"text":"Pub. L. 118–31, § 2831(a)(1)(B)","children":[],"tail":"–(D), designated existing provisions as subsec. (a) and inserted heading, inserted “covered” before “military unaccompanied housing” and “, except for purposes of meeting minimum area requirements under subsection (b)(1)(A),” before period at end, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s2831/a/1/A"},"text":"Pub. L. 118–31, § 2831(a)(1)(A)","children":[],"tail":", substituted “standards” for “local comparability of floor areas” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “The Secretary of Defense shall prescribe regulations establishing the maximum allowable net square feet per occupant for new permanent barracks construction. Such regulations shall be uniform for the armed forces under the jurisdiction of the Secretary of a military department.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out “(a)” before “The Secretary of Defense” and struck out subsec. (b) which read as follows: “Before taking effect, any regulations under this section, and any modifications to such regulations, shall be submitted to the appropriate committees of Congress. Such regulations (including any modifications to such regulations) may not then take effect until 21 days after being received by such committees.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e6779e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9e6779f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e677a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Improvement of Administration of Military Unaccompanied Housing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2827"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2827","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1311"},"text":"139 Stat. 1311","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dB/tXXVIII/s2827"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updated Guidance on Surveys","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in carrying out the satisfaction survey requirement under section 3058 of the Military Construction Authorization Act for Fiscal Year 2020 (division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Public Law 116–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2821"},"text":"10 U.S.C. 2821","children":[],"tail":" note), shall update guidance to the Secretaries of the military departments to ensure that members of the Armed Forces living in military unaccompanied housing are surveyed in a consistent and comparable manner."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review on Processes and Methodologies for Condition Scores.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall conduct a review of the processes and methodologies by which the Secretaries of the military departments calculate condition scores for military unaccompanied housing facilities under the jurisdiction of the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The review required under paragraph (1) shall, among other factors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider how best to ensure a condition score of a facility reflects—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physical condition of the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of that condition on the quality of life of members of the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aim to increase methodological consistency among the military departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report on the results of the review conducted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounting of Members Residing in Military Unaccompanied Housing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall include with the submission to Congress by the President of the annual budget of the Department of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, an accounting of unaccompanied members of the Armed Forces whose rank would require that they live in military unaccompanied housing, but that also receive a basic allowance for housing under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of title 37","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The accounting required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of members of the Armed Forces described in such paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of basic allowance for housing payments provided to those members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Centralized Tracking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act, each Secretary of a military department shall develop a means for centralized tracking, at the service level, of all military construction requirements related to military unaccompanied housing that have been identified at the installation level, regardless of whether or not such requirements are submitted for funding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Unaccompanied Housing Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘military unaccompanied housing’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2871"},"text":"section 2871 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9e677a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Uniform Design Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dB/tXXVIII/s2831/b"},"text":"Pub. L. 118–31, div. B, title XXVIII, § 2831(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/753"},"text":"137 Stat. 753","children":[],"tail":", 754, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dB/tXXVIII/s2831/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion and Issuance of Uniform Design Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Secretary of Defense shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the uniform design standards required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856/b/1"},"text":"section 2856(b)(1) of title 10","children":[],"tail":", United States Code, as added by subsection (a)(1)(D), are completed, issued, and submitted to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the congressional defense committees a report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explaining in detail why such standards are not completed and issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicating when such standards are expected to be completed and issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying the names of the personnel responsible for the failure to complete and issue such standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Uniform Design Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than two years after the date of the enactment of this Act, the Secretary of each military department shall ensure that all covered military unaccompanied housing located on a military installation under the jurisdiction of such Secretary complies with the uniform standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856/b/1"},"text":"section 2856(b)(1) of title 10","children":[],"tail":", United States Code, as added by subsection (a)(1)(D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement under paragraph (1) may not be waived.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered military unaccompanied housing defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term ‘covered military unaccompanied housing’ has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856"},"text":"section 2856 of title 10","children":[],"tail":", United States Code (as amended by subsection (a)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
