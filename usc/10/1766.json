ub. L. 115–232","children":[],"tail":" and inserting reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118c"},"text":"section 118c of this title","children":[],"tail":" was undone by subsequent general amendment, which reinstated the prior reference. See 2021 Amendment notes below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90d7d39-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s913/a/4/A"},"text":"Pub. L. 118–31, § 913(a)(4)(A)","children":[],"tail":", substituted “as determined by the Secretary of Defense” for “as determined by the Under Secretary of Defense for Research and Engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s913/a/4/B"},"text":"Pub. L. 118–31, § 913(a)(4)(B)","children":[],"tail":", substituted “as directed by the Secretary of Defense” for “as directed by the Under Secretary of Defense for Research and Engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1878A/a"},"text":"Pub. L. 116–283, § 1878A(a)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/q/2"},"text":"Pub. L. 117–81, § 1701(q)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2358b"},"text":"section 2358b of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1842/b"},"text":"Pub. L. 116–283, § 1842(b)","children":[],"tail":", which directed the renumbering of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2358b"},"text":"section 2358b of this title","children":[],"tail":" as section 4064 instead of this section, was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/q/1"},"text":"Pub. L. 117–81, § 1701(q)(1)","children":[],"tail":", (u)(3)(B), effective as if included therein, so that such renumbering was no longer directed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1081/a/37"},"text":"Pub. L. 116–283, § 1081(a)(37)","children":[],"tail":", substituted “accelerate” for “to accelerate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s213/a"},"text":"Pub. L. 117–81, § 213(a)","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, cl. (ii) read as follows: “the technology requirements of the Department of Defense as identified in the National Defense Science and Technology Strategy developed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118c"},"text":"section 118c of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s211/d"},"text":"Pub. L. 117–81, § 211(d)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s118c"},"text":"section 118c of this title","children":[],"tail":"” for “section 218 of the John S. McCain National Defense Authorization Act for Fiscal Year 2019 ("},{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Public Law 115–232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/132/1679"},"text":"132 Stat. 1679","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90d7d3a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90d7d3b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s913/b/1"},"text":"Pub. L. 118–31, div. A, title IX, § 913(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/368"},"text":"137 Stat. 368","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tIX/s913/b/1"},"text":"“The amendments made by subsection (a) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4127"},"text":"section 4127 of this title","children":[],"tail":" and amending this section and sections 4021 and 4022 of this title] shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida90d7d3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 1701(q), (u)(3)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida90d7d3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s913/b/2"},"text":"Pub. L. 118–31, div. A, title IX, § 913(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/368"},"text":"137 Stat. 368","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tIX/s913/b/2"},"text":"“Not later than the effective date specified in paragraph (1) [set out as an Effective Date of 2023 Amendment note above], the Secretary of Defense shall issue or modify any rules, regulations, policies, or other guidance necessary to implement the amendments made by subsection (a) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4127"},"text":"section 4127 of this title","children":[],"tail":" and amending this section and sections 4021 and 4022 of this title].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
