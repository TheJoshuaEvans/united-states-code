{"tag":"section","attrib":{"id":"ida81cb438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848"},"text":null,"children":[{"tag":"num","attrib":{"value":"848"},"text":"§ 848.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 48. Contempt","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81cb439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Punish","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb43a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any proceeding under this chapter, a judicial officer specified in paragraph (2) may punish for contempt any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81cb43b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses any menacing word, sign, or gesture in the presence of the judicial officer during the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb43c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disturbs the proceeding by any riot or disorder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb43d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully disobeys a lawful writ, process, order, rule, decree, or command issued with respect to the proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb43e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A judicial officer referred to in paragraph (1) is any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81cb43f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any judge of the Court of Appeals for the Armed Forces and any judge of a Court of Criminal Appeals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866"},"text":"section 866 of this title","children":[],"tail":" (article 66)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb440-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any military judge detailed to a court-martial, a provost court, a military commission, or any other proceeding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb441-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any military magistrate designated to preside under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s819"},"text":"section 819 of this title","children":[],"tail":" (article 19)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb442-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The president of a court of inquiry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb443-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Punishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The punishment for contempt under subsection (a) may not exceed confinement for 30 days, a fine of $1,000, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb444-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A punishment under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb445-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if imposed by a military judge or military magistrate, may be reviewed by the Court of Criminal Appeals in accordance with the uniform rules of procedure for the Courts of Criminal Appeals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/h"},"text":"section 866(h) of this title","children":[],"tail":" (article 66(h));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if imposed by a judge of the Court of Appeals for the Armed Forces or a judge of a Court of Criminal Appeals, shall constitute a judgment of the court, subject to review under the applicable provisions of section 867 or 867a of this title (article 67 or 67a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if imposed by a court of inquiry, shall be subject to review by the convening authority in accordance with rules prescribed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s848/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Military Commissions Under Chapter","children":[],"tail":" 47"},{"tag":"inline","attrib":{},"text":"A","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a military commission established under chapter 47A of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81cb449-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/53"},"text":"70A Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/366/s4/a/2"},"text":"Pub. L. 109–366, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2631"},"text":"120 Stat. 2631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s542/a"},"text":"Pub. L. 111–383, div. A, title V, § 542(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4218"},"text":"124 Stat. 4218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVII/s5230"},"text":"Pub. L. 114–328, div. E, title LVII, § 5230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2913"},"text":"130 Stat. 2913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/c/1/F"},"text":"Pub. L. 115–91, div. A, title X, § 1081(c)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1598"},"text":"131 Stat. 1598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81cb44a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81cb44b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81cb44c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"848","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:623.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 48), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/123"},"text":"64 Stat. 123","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “may” is substituted for the word “shall”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81cb44d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81cb44e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/h"},"text":"section 866(h) of this title","children":[],"tail":" (article 66(h))” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s866/g"},"text":"section 866(g) of this title","children":[],"tail":" (article 66(g))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5230/c"},"text":"Pub. L. 114–328, § 5230(c)","children":[],"tail":", amended section catchline generally, substituting “Contempt” for “Contempts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5230/a"},"text":"Pub. L. 114–328, § 5230(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “A judge detailed to a court-martial, a court of inquiry, the United States Court of Appeals for the Armed Forces, a military Court of Criminal Appeals, a provost court, or a military commission may punish for contempt any person who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) uses any menacing word, sign, or gesture in the presence of the judge during the proceedings of the court-martial, court, or military commission;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) disturbs the proceedings of the court-martial, court, or military commission by any riot or disorder; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) willfully disobeys the lawful writ, process, order, rule, decree, or command of the court-martial, court, or military commission.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5230/b"},"text":"Pub. L. 114–328, § 5230(b)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “A court-martial, provost court, or military commission may punish for contempt any person who uses any menacing word, sign, or gesture in its presence, or who disturbs its proceedings by any riot or disorder. The punishment may not exceed confinement for 30 days or a fine of $100, or both. This section does not apply to a military commission established under chapter 47A of this title.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366"},"text":"Pub. L. 109–366","children":[],"tail":" inserted last sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81cb44f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb450-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after the amendments made by div. E (§§ 5001–5542) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" take effect as provided for in section 5542 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/c/4"},"text":"section 1081(c)(4) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb451-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb452-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s542/b"},"text":"Pub. L. 111–383, div. A, title V, § 542(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4218"},"text":"124 Stat. 4218","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tV/s542/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s848"},"text":"Section 848 of title 10","children":[],"tail":", United States Code (article 48 of the Uniform Code of Military Justice), as amended by subsection (a), shall apply with respect to acts of contempt committed after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
