{"tag":"section","attrib":{"id":"idaad9b184-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7074"},"text":null,"children":[{"tag":"num","attrib":{"value":"7074"},"text":"§ 7074.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commands: territorial organization; engineer tactical units","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad9b185-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7074/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise prescribed by law or by the Secretary of Defense, the Army shall be divided into such commands, forces, and organizations as may be prescribed by the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b186-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7074/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For Army purposes, the United States, the Commonwealths and possessions, and other places in which the Army is stationed or is operating may be divided into such areas as may be directed by the Secretary. Officers of the Army may be assigned to command Army activities, installations, and personnel in those areas. In the discharge of the Army’s functions or other functions authorized by law, officers so assigned have the duties and powers prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad9b187-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7074/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such part of the Corps of Engineers as the President directs shall be formed into tactical units organized as he prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad9b188-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/170"},"text":"70A Stat. 170","children":[],"tail":", § 3074; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s503"},"text":"Pub. L. 99–433, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1042"},"text":"100 Stat. 1042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/6"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":"; renumbered § 7074, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad9b189-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaad9b18a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaad9b18b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":