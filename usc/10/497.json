{"tag":"section","attrib":{"id":"ida7c93ca6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497"},"text":null,"children":[{"tag":"num","attrib":{"value":"497"},"text":"§ 497.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification required for reduction, consolidation, or withdrawal of nuclear forces based in Europe","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c93ca7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon any decision to reduce, consolidate, or withdraw the nuclear forces of the United States that are based in Europe, the President shall transmit to the appropriate congressional committees a notification containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c93ca8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification for such reduction, consolidation, or withdrawal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93ca9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of how member states of the North Atlantic Treaty Organization, in light of such reduction, consolidation, or withdrawal, assess the credibility of the deterrence capability of the United States in support of its commitments undertaken pursuant to article 5 of the North Atlantic Treaty, signed at Washington, District of Columbia, on ","children":[{"tag":"date","attrib":{"date":"1949-04-04"},"text":"April 4, 1949","children":[],"tail":", and entered into force on "},{"tag":"date","attrib":{"date":"1949-08-24"},"text":"August 24, 1949","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/63/2241"},"text":"63 Stat. 2241","children":[],"tail":"; TIAS 1964)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c93caa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior Notification Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c93cab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall transmit the notification required by subsection (a) by not later than 120 days before the date on which the President commences a reduction, consolidation, or withdrawal of the nuclear forces of the United States that are based in Europe described in such notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93cac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation in paragraph (1) shall not apply to a reduction, consolidation, or withdrawal of nuclear weapons of the United States that are based in Europe made to ensure the safety, security, reliability, and credibility of such weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c93cad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Congressional Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c93cae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the House of Representatives and the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c93caf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s497/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c93cb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1037/b/1"},"text":"Pub. L. 112–239, div. A, title X, § 1037(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1926"},"text":"126 Stat. 1926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1635"},"text":"Pub. L. 117–81, div. A, title XVI, § 1635","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2091"},"text":"135 Stat. 2091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c93cb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c93cb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c93cb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “120 days” for “60 days”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
