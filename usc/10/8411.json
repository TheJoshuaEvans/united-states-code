{"tag":"section","attrib":{"id":"idab238aee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411"},"text":null,"children":[{"tag":"num","attrib":{"value":"8411"},"text":"§ 8411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation cadets: grade; procurement; transfer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab238aef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grade of aviation cadet is a special enlisted grade in the naval service. Under such regulations as the Secretary of the Navy prescribes, citizens in civil life may be enlisted as, and enlisted members of the naval service with their consent may be designated as, aviation cadets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238af0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except in time of war or emergency declared by Congress, 20 percent of the aviation cadets procured in each fiscal year shall be procured from qualified enlisted members of the Regular Navy and the Regular Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238af1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person may be enlisted or designated as an aviation cadet unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab238af2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he agrees in writing that, upon his successful completion of the course of training as an aviation cadet, he will accept a commission as an ensign in the Navy Reserve or a second lieutenant in the Marine Corps Reserve, and will serve on active duty as such for at least three years, unless sooner released; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab238af3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if under 21 years of age, he has the consent of his parent or guardian to his agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238af4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary prescribes, an aviation cadet may be transferred to another enlisted grade or rating in the naval service, released from active duty, or discharged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab238af5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/426"},"text":"70A Stat. 426","children":[],"tail":", § 6911; "},{"tag":"ref","attrib":{"href":"/us/pl/85/578"},"text":"Pub. L. 85–578","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-31"},"text":"July 31, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/456"},"text":"72 Stat. 456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tIII/s373/f"},"text":"Pub. L. 96–513, title III, § 373(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2903"},"text":"94 Stat. 2903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/N"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(N)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; renumbered § 8411, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab238af6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab238af7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab238af8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6911(a), (c), (d)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s850a"},"text":"34 U.S.C. 850a","children":[],"tail":", 850b."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-04/ch547"},"text":"Aug. 4, 1942, ch. 547","children":[],"tail":", §§ 2, 3, 56 Stat.737."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6911(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s735b"},"text":"34 U.S.C. 735b","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-13/ch199/s3"},"text":"June 13, 1949, ch. 199, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/175"},"text":"63 Stat. 175","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “in civil life” are added to indicate that regular enlisted members, to be eligible, must be discharged as is required by subsection (b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words before the first proviso are omitted as executed. The words “after ","children":[{"tag":"date","attrib":{"date":"1949-06-13"},"text":"June 13, 1949","children":[],"tail":"” in the first proviso, relating to a declaration of emergency by Congress, are omitted as executed. The emergencies existing on "},{"tag":"date","attrib":{"date":"1949-06-13"},"text":"June 13, 1949","children":[],"tail":", have expired, as indicated in the "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-03/ch570"},"text":"Act of July 3, 1952, ch. 570","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/333"},"text":"66 Stat. 333","children":[],"tail":". The word “Regular” is inserted before “Navy” and “Marine Corps” to preserve the meaning of this provision which distinguishes members of the reserve components from members of the Navy and the Marine Corps. The words “who are discharged for the purpose of enlisting as aviation cadets” are added. Since discharge from a regular component must precede enlistment in a reserve component, the designation language of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s735b"},"text":"34 U.S.C. 735b","children":[],"tail":", although appropriate to the Air Force counterpart to which it also applies, is inappropriate to this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is written as a condition precedent to enlistment or transfer, and not as a requirement, to conform with interpretation of the provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab238af9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab238afa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6911"},"text":"section 6911 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Navy Reserve” for “Naval Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out “male” before “citizens” and “enlisted”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/578"},"text":"Pub. L. 85–578","children":[],"tail":" substituted “naval service” for “Naval Reserve and the Marine Corps Reserve”, made changes in phraseology including the substitution of “designated” for “transferred”, and specified consent as requisite for designation as aviation cadet."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/578"},"text":"Pub. L. 85–578","children":[],"tail":" struck out “at least” before “20 percent” and “who, with their consent, are discharged for the purpose of enlisting as aviation cadets” after “Regular Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/578"},"text":"Pub. L. 85–578","children":[],"tail":" designated existing provisions as cls. (1) and (2), made phraseological changes including the substitution of “designated” for “transferred”, and prescribed consent for one under 21 years of age instead of one described as minor and active duty service with commissioned status for minimum three year period instead of maximum four year period and unspecified grade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/578"},"text":"Pub. L. 85–578","children":[],"tail":" substituted “naval service” for “Naval Reserve or the Marine Corps Reserve” and struck out “as appropriate” after such term."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab238afb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab238afc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab238afd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
