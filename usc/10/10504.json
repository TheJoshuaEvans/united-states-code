{"tag":"section","attrib":{"id":"idab914187-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504"},"text":null,"children":[{"tag":"num","attrib":{"value":"10504"},"text":"§ 10504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of National Guard Bureau: annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab914188-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report on State of the National Guard","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab914189-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the National Guard Bureau shall submit to the Secretary of Defense, through the Secretaries of the Army and the Air Force, an annual report on the state of the National Guard and the ability of the National Guard to meet its missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab91418a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual report required by paragraph (1) shall be prepared in conjunction with the Secretary of the Army and the Secretary of the Air Force and may be submitted in classified and unclassified versions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab91418b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall transmit the annual report of the Chief of the National Guard Bureau to Congress, together with such comments on the report as the Secretary considers appropriate. The report shall be transmitted at the same time each year that the annual report of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/c"},"text":"section 113(c) of this title","children":[],"tail":" is submitted to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab91418c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report on Non-federalized Service National Guard Personnel, Training, and Equipment Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab91418d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than January 31 of each of calendar years 2018 through 2020, the Chief of the National Guard Bureau, in coordination with the Secretary of Defense, shall submit to the recipients described in paragraph (3) a report that identifies the personnel, training, and equipment required by the non-Federalized National Guard—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab91418e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support civilian authorities in connection with natural and man-made disasters during the covered period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab91418f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out prevention, protection, mitigation, response, and recovery activities relating to such disasters during the covered period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab914190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In preparing each report under paragraph (1), the Chief of the National Guard Bureau shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab914191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the chief executive of each State, the Council of Governors, and other appropriate civilian authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab914192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and validate information from each State relating to the personnel, training, and equipment requirements described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab914193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" set forth separately the personnel, training, and equipment requirements for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab914194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the emergency support functions of the National Response Framework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab914195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the Federal Emergency Management Agency regions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab914196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess core civilian capability gaps relating to natural and man-made disasters, as identified by States in submissions to the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab914197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account threat and hazard identifications and risk assessments of the Department of Defense, the Department of Homeland Security, and the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab914198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the budgets of each State to support the personnel, training, and equipment requirements of the non-Federalized National Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab914199-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The annual report required by paragraph (1) shall be submitted to the following officials:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab91419a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The congressional defense committees, the Committee on Homeland Security of the House of Representatives, and the Committee on Homeland Security and Governmental Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab91419b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab91419c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab91419d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council of Governors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab91419e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab91419f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9141a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Northern Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9141a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Indo-Pacific Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9141a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Cyber Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9141a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10504/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “covered period” means the fiscal year beginning after the date on which a report is submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9141a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIX/s904/a"},"text":"Pub. L. 103–337, div. A, title IX, § 904(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2825"},"text":"108 Stat. 2825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIII/s333/a"},"text":"Pub. L. 115–91, div. A, title III, § 333(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1354-1356"},"text":"131 Stat. 1354–1356","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/30"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(30)","children":[],"tail":", title XII, § 1251(b)(1), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1985"},"text":"132 Stat. 1985","children":[],"tail":", 2053.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9141a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab9141a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab9141a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1081/a/30/A"},"text":"Pub. L. 115–232, § 1081(a)(30)(A)","children":[],"tail":", inserted “(1)” before “The Chief”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1081/a/30/B"},"text":"Pub. L. 115–232, § 1081(a)(30)(B)","children":[],"tail":", redesignated subsec. (b), relating to annual report on non-Federalized service National Guard personnel, training, and equipment requirements, as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1251/b/1"},"text":"Pub. L. 115–232, § 1251(b)(1)","children":[],"tail":", substituted “United States Indo-Pacific Command” for “United States Pacific Command”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s333/b/1"},"text":"Pub. L. 115–91, § 333(b)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Chief of National Guard Bureau: annual report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s333/a/1/A"},"text":"Pub. L. 115–91, § 333(a)(1)(A)","children":[],"tail":", substituted “Report on State of the National Guard” for “Report” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s333/a/1/B"},"text":"Pub. L. 115–91, § 333(a)(1)(B)","children":[],"tail":", designated second sentence of subsec. (a) as par. (2) and substituted “The annual report required by paragraph (1)” for “The report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s333/a/2"},"text":"Pub. L. 115–91, § 333(a)(2)","children":[],"tail":", added subsec. (b) relating to annual report on non-Federalized service National Guard personnel, training, and equipment requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab9141a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab9141a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at end of 90-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s904/d"},"text":"section 904(d) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10501"},"text":"section 10501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
