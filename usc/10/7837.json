"text":"R.S. 1300.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:875b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1301.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4837(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4837(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4837(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:875a (less 3d and last provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:875a (last proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:875a (3d proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1928-05-22/ch676"},"text":"May 22, 1928, ch. 676","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/698"},"text":"45 Stat. 698","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1934-06-26/ch751"},"text":"June 26, 1934, ch. 751","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/1222"},"text":"48 Stat. 1222","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4837(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:871.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1303.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4837(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:872.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1304.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4837(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:875c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1299.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “sold to the member on credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4621/a/1"},"text":"section 4621(a)(1) of this title","children":[],"tail":"” are substituted for the words “articles designated by the inspectors general of the Army, and sold to him on credit by officers of the Quartermaster Corps”, in 10:875. The words “at cost prices” are omitted to reflect "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4623"},"text":"section 4623 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the last sentence is substituted for 10:875a (1st and 2d provisos). The words “on current payrolls” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Subject to subsection (b)” are substituted for the words “in the proportions hereinbefore indicated”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “If he considers it in the best interest of the United States” are substituted for the words “when in his opinion the interests of the Government are best served by such action”. The words “before, or at the time of” are substituted for the words “either on * * * or prior thereto”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “member” and “his” are substituted for the words “officer or soldier”. The words “or implement” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “or if an article of military supply with whose issue a commissioned officer is charged is damaged” are substituted for 10:872 (last sentence). The words “that he was not at fault” are substituted for the words “that said deficiency [such damage] was not occasioned by any fault on his part”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “bought on credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4621/a/1"},"text":"section 4621(a)(1) of this title","children":[],"tail":"” are substituted for the words “designated by the officers of the Inspector-General’s Department of the Army and purchased on credit from commissaries of subsistence”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab024729-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1958 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The change [in subsec. (b)] reflects the opinion of the Judge Advocate General of the Air Force (","children":[{"tag":"date","attrib":{"date":"1957-06-10"},"text":"June 10, 1957","children":[],"tail":") that the term “rate of pay”, as used in the source law for section 4837(b) ("},{"tag":"ref","attrib":{"href":"/us/act/1928-05-22/ch676"},"text":"Act of May 22, 1928, ch. 676","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/45/698"},"text":"45 Stat. 698","children":[],"tail":"), as amended), included special pay and incentive pay."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The change [in subsec. (f)] reflects the opinion of the Assistant General Counsel (Fiscal Matters), Department of Defense (","children":[{"tag":"date","attrib":{"date":"1957-07-19"},"text":"July 19, 1957","children":[],"tail":"), that section 1304, Revised Statutes (formerly "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s872"},"text":"10 U.S.C. 872","children":[],"tail":"), the source law for this section, applied to warrant officers as well as to commissioned officers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab02472a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab02472b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4837"},"text":"section 4837 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “as a member of the Army, whether as a regular or a reserve in active status” for “on active duty as a member of the Army”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/a/1"},"text":"Pub. L. 109–364, § 673(a)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “If he considers it in the best interest of the United States, the Secretary may have remitted or cancelled any part of an enlisted member’s indebtedness to the United States or any of its instrumentalities remaining unpaid before, or at the time of, that member’s honorable discharge.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/e/1"},"text":"Pub. L. 109–364, § 673(e)(1)","children":[],"tail":", substituted “The Secretary of the Army” for “If the Secretary considers it to be in the best interest of the United States, the Secretary” and inserted “, but only if the Secretary considers such action to be in the best interest of the United States” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/a/1"},"text":"Pub. L. 109–364, § 673(a)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":", substituted “of a person to the United States or any instrumentality of the United States incurred while the person was serving on active duty as a member of the Army” for “of a member of the Army on active duty, or a member of a reserve component of the Army in an active status, to the United States or any instrumentality of the United States incurred while the member was serving on active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s673/a/2"},"text":"Pub. L. 109–364, § 673(a)(2)","children":[],"tail":", redesignated subsecs. (c) and (d) as (b) and (c), respectively, and struck out heading and text of former subsec. (b). Text read as follows: “The Secretary may exercise the authority in subsection (a) with respect to a member—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) while the member is on active duty or in active status, as the case may be;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) if discharged from the armed forces under honorable conditions, during the one-year period beginning on the date of such discharge; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) if released from active status in a reserve component, during the one-year period beginning on the date of such release.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":", substituted “remission or cancellation of indebtedness of enlisted members” for “deductions from pay” in section catchline, and in text substituted “If he” for “(d) If he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" repealed subsecs. (a) to (c) and (e) to (g) which related to deductions from pay. See subsecs. (b) to (g), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s1007"},"text":"section 1007 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/27/A"},"text":"Pub. L. 85–861, § 33(a)(27)(A)","children":[],"tail":", substituted “his pay for that month” for “his basic pay for that month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/27/B"},"text":"Pub. L. 85–861, § 33(a)(27)(B)","children":[],"tail":", substituted “an officer” for “a commissioned officer” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab02472c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab02472d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 