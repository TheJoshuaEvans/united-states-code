{"tag":"section","attrib":{"id":"idaaffd721-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7837"},"text":null,"children":[{"tag":"num","attrib":{"value":"7837"},"text":"§ 7837.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of accounts: remission or cancellation of indebtedness of members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaffd722-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7837/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may have remitted or cancelled any part of the indebtedness of a person to the United States or any instrumentality of the United States incurred while the person was serving as a member of the Army, whether as a regular or a reserve in active status, but only if the Secretary considers such action to be in the best interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd723-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7837/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retroactive Applicability to Certain Debts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority in subsection (a) may be exercised with respect to any debt covered by that subsection that is incurred on or after ","children":[{"tag":"date","attrib":{"date":"2001-10-07"},"text":"October 7, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd724-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7837/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be administered under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaffd725-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/273"},"text":"70A Stat. 273","children":[],"tail":", § 4837; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s33/a/27"},"text":"Pub. L. 85–861, § 33(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1566"},"text":"72 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/10"},"text":"Pub. L. 87–649, § 14c(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s512/24/A"},"text":"Pub. L. 96–513, title V, § 512(24)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2930"},"text":"94 Stat. 2930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s683/a/1"},"text":"Pub. L. 109–163, div. A, title VI, § 683(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3322"},"text":"119 Stat. 3322","children":[],"t