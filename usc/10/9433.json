{"tag":"section","attrib":{"id":"idab74b7e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9433"},"text":null,"children":[{"tag":"num","attrib":{"value":"9433"},"text":"§ 9433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superintendent; faculty: appointment and detail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab74b7e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Superintendent and the Commandant of Cadets of the Academy shall be detailed to those positions by the President from the officers of the Air Force or the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab74b7e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permanent professors of the Academy shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab74b7e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The director of admissions of the Academy shall be appointed by the President, by and with the advice and consent of the Senate, and shall perform such duties as the Superintendent of the Academy may prescribe with the approval of the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab74b7ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/562"},"text":"70A Stat. 562","children":[],"tail":", § 9333; "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/20"},"text":"Pub. L. 85–600, § 1(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/523"},"text":"72 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tV/s515/a/2"},"text":"Pub. L. 101–189, div. A, title V, § 515(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1441"},"text":"103 Stat. 1441","children":[],"tail":"; renumbered § 9433, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/a/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/d/8"},"text":"Pub. L. 116–283, div. A, title IX, § 923(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3814"},"text":"134 Stat. 3814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab74b7eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab74b7ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab74b7ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9333(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1062.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1313.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9333(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1063.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1314 (words before semicolon).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “detailed” is substituted for the word “selected”, since historically the offices of superintendent and commandant of cadets have been filled by detail. The words “the officers of the Air Force” are substituted for the words “any arm of the service”, since the Air Force does not have statutory arms or corps. 10:1063 (1st sentence and 1st 26 words of last sentence) is omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8012"},"text":"section 8012 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “by and with the advice and consent of the Senate” are inserted, since many of the statutes establishing particular permanent professorships from time to time have so provided, and historically it has been the uniform practice to make these appointments in this manner. 10:1063 (last 14 words) is omitted as obsolete and as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9349/b"},"text":"section 9349(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab74b7ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab74b7ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or the Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9333"},"text":"section 9333 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “director of admissions” for “registrar”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/600"},"text":"Pub. L. 85–600","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab74b7f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab74b7f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
