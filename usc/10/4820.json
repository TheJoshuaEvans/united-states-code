01/s/2/C/i"},"text":"Pub. L. 117–81, § 1701(s)(2)(C)(i)","children":[],"tail":", substituted “section 4811” for “section 2501”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/s/2/C/ii"},"text":"Pub. L. 117–81, § 1701(s)(2)(C)(ii)","children":[],"tail":", substituted “subchapters 381 through 385 and subchapter 389” for “chapter 148”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" inserted “, in accordance with the strategy required by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2501"},"text":"section 2501 of this title","children":[],"tail":",” after “base”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “industrial base plans” for “Industrial Base Plans” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa994c9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa994c9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":