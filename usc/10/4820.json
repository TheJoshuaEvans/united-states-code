{"tag":"section","attrib":{"id":"idaa994c94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4820"},"text":null,"children":[{"tag":"num","attrib":{"value":"4820"},"text":"§ 4820.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National technology and industrial base plans, policy, and guidance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa994c95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4820/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations requiring consideration of the national technology and industrial base, in accordance with the strategy required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811"},"text":"section 4811 of this title","children":[],"tail":", in the development and implementation of acquisition plans for each major defense acquisition program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa994c96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4820/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition Policy and Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall develop and promulgate acquisition policy and guidance to the service acquisition executives, the heads of the appropriate Defense Agencies and Department of Defense Field Activities, and relevant program managers. Such policy and guidance shall be germane to the use of the research and development, manufacturing, and production capabilities identified pursuant to chapters 381 through 385 and chapter 389 of this title and the technologies, companies, laboratories, and factories in specific Department of Defense research and development, international cooperative research, procurement, and sustainment activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa994c97-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLII/s4216/b/1"},"text":"Pub. L. 102–484, div. D, title XLII, § 4216(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2669"},"text":"106 Stat. 2669","children":[],"tail":", § 2440; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/17"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2399"},"text":"120 Stat. 2399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1603/c"},"text":"Pub. L. 112–239, div. A, title XVI, § 1603(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2063"},"text":"126 Stat. 2063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s846/b/1"},"text":"Pub. L. 116–283, div. A, title VIII, § 846(b)(1)","children":[],"tail":", title XVIII, § 1847(b)(2)(A), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3768"},"text":"134 Stat. 3768","children":[],"tail":", 4253; renumbered § 4820 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/s/1/A"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(s)(1)(A)","children":[],"tail":", (2)