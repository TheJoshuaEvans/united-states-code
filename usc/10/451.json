{"tag":"section","attrib":{"id":"ida7bf9f3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s451"},"text":null,"children":[{"tag":"num","attrib":{"value":"451"},"text":"§ 451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maps, charts, books, and datasets","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s451/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the National Geospatial-Intelligence Agency prepare nautical and aeronautical charts, topographic and geomatics maps, books, models, and datasets required in navigation and have those materials published and furnished to navigators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s451/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire (by purchase, lease, license, or barter) all necessary rights, including copyrights and other intellectual property rights, required to prepare, publish, and furnish to navigators the products described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/50/C"},"text":"Pub. L. 97–295, § 1(50)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1299"},"text":"96 Stat. 1299","children":[],"tail":", § 2792; renumbered § 451 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/b"},"text":"Pub. L. 104–20