{"tag":"section","attrib":{"id":"ida78d92ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236"},"text":null,"children":[{"tag":"num","attrib":{"value":"236"},"text":"§ 236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal protection equipment procurement: display of budget information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78d9300-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Justification Display","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to Congress, as a part of the defense budget materials for each fiscal year after fiscal year 2014, a consolidated budget justification display that covers all programs and activities associated with the procurement of personal protection equipment during the period covered by the future-years defense program submitted in that fiscal year under section 221.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78d9301-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Budget Display","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consolidated budget justification display under subsection (a) for a fiscal year shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78d9302-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for personal protection equipment included in both the base budget of the President and any overseas contingency operations budget of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78d9303-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief description of each category of personal protection equipment for each military department planned to be procured and developed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78d9304-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each category planned to be procured using funds made available for operation and maintenance (whether under the base budget or any overseas contingency operations budget)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78d9305-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant appropriations account, budget activity, and subactivity group for the category; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78d9306-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding profile for the fiscal year as requested, including cost and quantities, and an estimate of projected investments or procurements for each of the subsequent five fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78d9307-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each category planned to be developed using funds made available for research, development, test, and evaluation (whether under the base budget or any overseas contingency operations budget)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78d9308-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant appropriations account, program, project or activity; program element number, and line number; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78d9309-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding profile for the fiscal year as requested and an estimate of projected investments for each of the subsequent five fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78d930a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78d930b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “budget” and “defense budget materials” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s234"},"text":"section 234 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78d930c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “category of personal protection equipment” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78d930d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Body armor components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78d930e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Combat helmets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78d930f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Combat protective eyewear.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78d9310-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s236/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other items as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida78d9311-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tI/s141/a"},"text":"Pub. L. 113–66, div. A, title I, § 141(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/696"},"text":"127 Stat. 696","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
