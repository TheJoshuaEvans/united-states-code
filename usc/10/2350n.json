{"tag":"section","attrib":{"id":"ida9719517-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350n"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350n"},"text":"§ 2350n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North Atlantic Treaty Organization Joint Force Command","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9719518-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall authorize the establishment of, and the participation by members of the armed forces in, the North Atlantic Treaty Organization Joint Force Command (in this section referred to as the “Joint Force Command”), to be established in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9719519-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Department of Defense Facilities and Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use facilities and equipment of the Department of Defense to support the Joint Force Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida971951a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts authorized to be appropriated to the Department of Defense shall be available to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida971951b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXII/s1249/a"},"text":"Pub. L. 116–92, div. A, title XII, § 1249(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1664"},"text":"133 Stat. 1664","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
