{"tag":"section","attrib":{"id":"ida80274aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709a"},"text":null,"children":[{"tag":"num","attrib":{"value":"709a"},"text":"§ 709a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses incurred in connection with leave canceled due to contingency operations: reimbursement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida80274ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization To Reimburse","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may reimburse a member of the armed forces under the jurisdiction of the Secretary for travel and related expenses (to the extent not otherwise reimbursable under law) incurred by the member as a result of the cancellation of previously approved leave when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida80274ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave is canceled in connection with the member’s participation in a contingency operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida80274ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cancellation occurs within 48 hours of the time the leave would have commenced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida80274ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and, in the case of the Coast Guard when it is not operating as a service in the Navy, the Secretary of Homeland Security shall prescribe regulations to establish the criteria for the applicability of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida80274af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s709a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conclusiveness of Settlement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The settlement of an application for reimbursement under subsection (a) is final and conclusive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida80274b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s522/a"},"text":"Pub. L. 114–328, div. A, title V, § 522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2115"},"text":"130 Stat. 2115","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
