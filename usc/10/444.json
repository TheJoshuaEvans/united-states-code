{"tag":"section","attrib":{"id":"ida7bf9f22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444"},"text":null,"children":[{"tag":"num","attrib":{"value":"444"},"text":"§ 444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support from Central Intelligence Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bf9f23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Central Intelligence Agency may provide support in accordance with this section to the Director of the National Geospatial-Intelligence Agency. The Director of the National Geospatial-Intelligence Agency may accept support provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative and Contract Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In furtherance of the national intelligence effort, the Director of the Central Intelligence Agency may provide administrative and contract services to the National Geospatial-Intelligence Agency as if that agency were an organizational element of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Services provided under paragraph (1) may include the services of security police. For purposes of section 15 of the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3515"},"text":"50 U.S.C. 3515","children":[],"tail":"), an installation of the National Geospatial-Intelligence Agency that is provided security police services under this section shall be considered an installation of the Central Intelligence Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support provided under this subsection shall be provided under terms and conditions agreed upon by the Secretary of Defense and the Director of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Central Intelligence Agency may detail personnel of the Central Intelligence Agency indefinitely to the National Geospatial-Intelligence Agency without regard to any limitation on the duration of interagency details of Federal Government personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursable or Nonreimbursable Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Support under this section may be provided and accepted on either a reimbursable basis or a nonreimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Transfer Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Geospatial-Intelligence Agency may transfer funds available for that agency to the Director of the Central Intelligence Agency for the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Central Intelligence Agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bf9f2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept funds transferred under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bf9f2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s444/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall expend such funds, in accordance with the Central Intelligence Agency Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3501"},"text":"50 U.S.C. 3501","children":[],"tail":" et seq.), to provide administrative and contract services or detail personnel to the National Geospatial-Intelligence Agency under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/a/2"},"text":"Pub. L. 104–201, div. A, title XI, § 1112(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2680"},"text":"110 Stat. 2680","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/2/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s931/b/2"},"text":"Pub. L. 110–181, div. A, title IX, § 931(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/285"},"text":"122 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 932(c), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4576"},"text":"122 Stat. 4576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c/10"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2475"},"text":"123 Stat. 2475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/7"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bf9f30-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bf9f31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7bf9f32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Central Intelligence Agency Act of 1949, referred to in subsec. (e)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227"},"text":"act June 20, 1949, ch. 227","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/208"},"text":"63 Stat. 208","children":[],"tail":", which is classified generally to chapter 46 (§ 3501 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bf9f33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/c/7/A"},"text":"Pub. L. 113–291, § 1071(c)(7)(A)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3515"},"text":"50 U.S.C. 3515","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403"},"text":"50 U.S.C. 403","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1071/c/7/B"},"text":"Pub. L. 113–291, § 1071(c)(7)(B)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3501"},"text":"50 U.S.C. 3501","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403a"},"text":"50 U.S.C. 403a","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/c"},"text":"Pub. L. 110–417, § 932(c)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/c"},"text":"Pub. L. 110–417, § 932(c)","children":[],"tail":", amended section identically, substituting “Director of the Central Intelligence Agency” for “Director of Central Intelligence” wherever appearing. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/c"},"text":"Pub. L. 110–417, § 932(c)","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a), (b)(1), (2), (c), (e)(1), (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bf9f34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7bf9f35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":", provided that the amendment made by section 1073(c)(10) is effective as of "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7bf9f36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
