{"tag":"section","attrib":{"id":"idab855a7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784"},"text":null,"children":[{"tag":"num","attrib":{"value":"9784"},"text":"§ 9784.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air Force and Space Force Museum System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab855a7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force shall support a system of official Air Force and Space Force museums within the Department of the Air Force. Such system shall include the National Museum of the United States Air Force and may contain other museums honoring individual installations, units, and branches, as designated by the Secretary of the Air Force, that meet criteria established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force shall establish criteria for designating museums of subsection (a) for inclusion in the Air Force and Space Force museum system. Such criteria shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab855a7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historical significance to Air Force and Space Force operations, technology, or personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public accessibility and educational outreach programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alignment with the mission of the Air Force and Space Force to preserve the heritage of the Air Force and Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Closure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force shall establish criteria for the closure of museums within the Air Force and Space Force museum system. No museum within such system may be closed until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab855a82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Air Force submits to the Committees on Armed Services of the House of Representatives and the Senate notice that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab855a83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the preservation, storage, or alternate display of historical collections contained in the museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab855a84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how any issues relating to museum personnel will be resolved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab855a85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any efforts to maintain museum operations through public-private partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab855a86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the cost to transport, consolidate, and preserve the historical collections contained in the museum; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 90 days has elapsed after the date on which such notice is received by such committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9784/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding and Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consistent with applicable law, the Secretary may enter into partnerships, including with nonprofit organizations, to enhance the financial sustainability and public engagement of the museums in the Air Force and Space Force museum system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab855a89-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s376"},"text":"Pub. L. 119–60, div. A, title III, § 376","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/840"},"text":"139 Stat. 840","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
