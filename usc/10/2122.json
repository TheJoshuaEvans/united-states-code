{"tag":"section","attrib":{"id":"ida92c75d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122"},"text":null,"children":[{"tag":"num","attrib":{"value":"2122"},"text":"§ 2122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92c75d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible for participation as a member of the program, a person must be a citizen of the United States and must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92c75d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accepted for admission to, or enrolled in, an institution in a course of study or selected to receive specialized training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c75d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sign an agreement that unless sooner separated he will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92c75d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the educational phase of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c75d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept an appropriate reappointment or designation within his military service, if tendered, based upon his health profession, following satisfactory completion of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c75d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the intern program of his service if selected for such participation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c75da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the residency program of his service, if selected, or be released from active duty for the period required to undergo civilian residency if selected for such training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92c75db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of his sincere motivation and dedication to a career in the uniformed services, participate in military training while he is in the program, under regulations prescribed by the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92c75dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements for appointment as a commissioned officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92c75dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may require, as part of the agreement under subsection (a)(2), that a person must agree to accept, if offered, residency training in a health profession skill which has been designated by the Secretary as a critically needed wartime skill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92c75de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/717"},"text":"86 Stat. 717","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII/s712/a"},"text":"Pub. L. 100–180, div. A, title VII, § 712(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1112"},"text":"101 Stat. 1112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s725/c"},"text":"Pub. L. 101–189, div. A, title VII, § 725(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1479"},"text":"103 Stat. 1479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92c75df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92c75e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92c75e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “study or selected to receive specialized training” for “study, as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2120/3"},"text":"section 2120(3) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
