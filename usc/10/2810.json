{"tag":"section","attrib":{"id":"ida9da9026-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810"},"text":null,"children":[{"tag":"num","attrib":{"value":"2810"},"text":"§ 2810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military construction projects for innovation, research, development, test, and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9da9027-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Authorization Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may carry out such military construction projects for innovation, research, development, test, and evaluation as are authorized by law, using funds appropriated or otherwise made available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9028-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Project Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the defense budget materials for each fiscal year, the Secretary of Defense shall include the following information for each military construction project covered by subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9029-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da902a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da902b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief description of the scope of work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da902c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A completed Department of Defense Form 1391 budget justification that includes the original project cost estimate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da902d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current working cost estimate, if different that the cost estimate contained in such Form 1391.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da902e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da902f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Justification Display","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall include with the defense budget materials for each fiscal year a consolidated budget justification display that individually identifies each military construction project covered by subsection (a) and the amount requested for such project for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9030-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Military Construction Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply to military construction projects covered by subsection (a) for which a Department of Defense Form 1391 is submitted to the appropriate committees of Congress in connection with the budget of the Department of Defense for fiscal year 2023 and thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9031-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Five-year Plans on Improvement of Innovation Infrastructure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9032-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Along with the budget for each fiscal year submitted by the President pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", each Secretary of a military department and the Secretary of Defense shall submit to the congressional defense committees a plan that describes the objectives of that Secretary to improve innovation infrastructure during the five fiscal years following the fiscal year for which such budget is submitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9033-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan submitted by a Secretary of a military department under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9034-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the five-year period covered by the plan, an identification of the major lines of effort, milestones, and investment goals of the Secretary over such period relating to the improvement of innovation infrastructure and a description of how such goals support such goals, including the use of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9da9035-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military construction, facilities restoration and modernization funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9da9036-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defense lab modernization program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/d"},"text":"section 2805(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9da9037-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military construction projects for innovation, research, development, test, and evaluation under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9038-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The estimated costs of necessary innovation infrastructure improvements and a description of how such costs would be addressed by the Department of Defense budget request submitted during the same year as the plan and the applicable future-years defense program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9039-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information regarding the plan of the Secretary to initiate such environmental and engineering studies as may be necessary to carry out planned innovation infrastructure improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da903a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detailed information regarding how innovation infrastructure improvement projects will be paced and sequenced to ensure continuous operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da903b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incorporation of results-oriented management practices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan under subsection (a) shall incorporate the leading results-oriented management practices identified in the report of the Comptroller General of the United States titled “Actions Needed to Improve Poor Conditions of Facilities and Equipment that Affect Maintenance Timeliness and Efficiency” (GAO–19–242), or any successor report, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da903c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytically based goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da903d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results-oriented metrics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da903e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of required resources, risks, and stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da903f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regular reporting on progress to decision makers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9040-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innovative infrastructure defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “innovation infrastructure” includes laboratories, test and evaluation ranges, and any other infrastructure whose primary purpose is research, development, test, and evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9da9041-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Laboratory Modernization Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9da9042-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Using amounts appropriated or otherwise made available to the Department of Defense for research, development, test, and evaluation, the Secretary of Defense may fund a military construction project described in paragraph (4) at any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9043-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department of Defense science and technology reinvention laboratory (as designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4121/b"},"text":"section 4121(b) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9044-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department of Defense federally funded research and development center that functions primarily as a research laboratory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9045-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department of Defense facility in support of a technology development program that is consistent with the fielding of offset technologies as described in section 218 of the National Defense Authorization Act for Fiscal Year 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; 10 U.S.C. note 4811)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9046-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Department of Defense research, development, test, and evaluation facility that is not designated as a science and technology reinvention laboratory, but nonetheless is involved with developmental test and evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9047-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the condition that a military construction project under paragraph (1) be authorized in a Military Construction Authorization Act, the authority to carry out the military construction project includes authority for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9048-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveys, site preparation, and advanced planning and design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9049-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition, conversion, rehabilitation, and installation of facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da904a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition and installation of equipment and appurtenances integral to the project; acquisition and installation of supporting facilities (including utilities) and appurtenances incident to the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da904b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning, supervision, administration, and overhead expenses incident to the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da904c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da904d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall include military construction projects proposed to be carried out under paragraph (1) in the budget justification documents for the Department of Defense submitted to Congress in connection with the budget for a fiscal year submitted under 1105 of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da904e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 14 days prior to the first obligation of funds described in paragraph (1) for a military construction project to be carried out under such paragraph, the Secretary of Defense shall submit to the congressional defense committees a notification providing an updated construction description, cost, and schedule for the project and any other matters regarding the project as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da904f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authority provided by paragraph (1) to fund military construction projects using amounts appropriated or otherwise made available for research, development, test, and evaluation is limited to military construction projects that the Secretary of Defense, in the budget justification documents exhibits submitted pursuant to paragraph (3)(A), determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9050-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will support research and development activities at laboratories described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9051-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will establish facilities that will have significant potential for use by entities outside the Department of Defense, including universities, industrial partners, and other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9052-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are endorsed for funding by more than one military department or Defense Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9053-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cannot be fully funded within the thresholds otherwise specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9054-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maximum amount of funds appropriated or otherwise made available for research, development, test, and evaluation that may be obligated in any fiscal year for military construction projects under paragraph (1) is $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9da9055-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9da9056-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the authority provided to the Secretary of Defense under paragraph (1) to use amounts appropriated or otherwise made available for research, development, test, and evaluation for a military construction project referred to in such subsection, the Secretary of the military department concerned may use amounts appropriated or otherwise made available for research, development, test, and evaluation to obtain architectural and engineering services and to carry out construction design in connection with such a project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9da9057-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2810/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of architectural and engineering services and construction design to be undertaken under this paragraph for which the estimated cost exceeds $4,000,000, the Secretary concerned shall notify the appropriate committees of Congress of the scope of the proposed project and the estimated cost of such services before the initial obligation of funds for such services. The Secretary may then obligate funds for such services only after the end of the 14-day period beginning on the date on which the notification is received by the committees in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9da9058-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2805/a"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2805(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2994"},"text":"136 Stat. 2994","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2806/a"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2806(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2249"},"text":"138 Stat. 2249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2873"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2873","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1328"},"text":"139 Stat. 1328","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9da9059-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9da905a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9da905b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/g"},"text":"section 2805(g) of this title","children":[],"tail":", which was transferred to this section and redesignated subsec. (f) by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s2873"},"text":"Pub. L. 119–60, § 2873","children":[],"tail":", was based on Pub. L. "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2803/a"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2992"},"text":"136 Stat. 2992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2805"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2249"},"text":"138 Stat. 2249","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9da905c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2810, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s211/b/1"},"text":"Pub. L. 99–499, title II, § 211(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1725"},"text":"100 Stat. 1725","children":[],"tail":", related to military construction projects for environmental response actions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIII/s313/b"},"text":"Pub. L. 107–314, div. A, title III, § 313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2507"},"text":"116 Stat. 2507","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9da905d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/g"},"text":"section 2805(g) of this title","children":[],"tail":" as subsec. (f) of this section. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9da905e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9da905f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2806/b"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2806(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2250"},"text":"138 Stat. 2250","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dB/tXXVIII/s2806/b"},"text":"“The first plan required under subsection (e) of such section [meaning ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2810"},"text":"10 U.S.C. 2810","children":[],"tail":"] (as amended by subsection (a)) shall be submitted as part of the annual budget submission of the President to Congress pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, for fiscal year 2027.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9da9060-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance for Military Construction Projects for Innovation, Research, Development, Test, and Evaluation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2815"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2815","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1303"},"text":"139 Stat. 1303","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dB/tXXVIII/s2815"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall issue written guidance on the implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2810"},"text":"section 2810 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance required by this section shall include, at minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures and criteria for the development and submission of project proposals pursuant to subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2810"},"text":"section 2810 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Definitions for roles and responsibilities for Department of Defense employees with respect to review, approval, and execution of projects carried out under the authority of such section 2810.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clarification on how the use of the authority to carry out projects under such section 2810 may be coordinated with the use of authorities for such projects under sections 2803, 2805, and 4123 of title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A process for internal review and validation of projects proposed to be carried out using the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2810"},"text":"section 2810 of title 10","children":[],"tail":", United States Code, which shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessments of how such proposed projects could be integrated across military departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive time-phased milestone plans for such proposed projects with clearly defined dependencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explicit documentation of budget programming action decisions of the Secretary of the military department with jurisdiction over such project.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
