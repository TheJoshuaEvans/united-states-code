{"tag":"section","attrib":{"id":"idaba209e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12321"},"text":null,"children":[{"tag":"num","attrib":{"value":"12321"},"text":"§ 12321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve Officer Training Corps units: limitation on number of Reserves assigned","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The number of members of the reserve components serving on active duty or full-time National Guard duty for the purpose of organizing, administering, recruiting, instructing, or training the reserve components who are assigned to duty with a unit of the Reserve Officer Training Corps program may not exceed 275.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaba209e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s559/a/1"},"text":"Pub. L. 101–510, div. A, title V, § 559(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1571"},"text":"104 Stat. 1571","children":[],"tail":", § 687; renumbered § 690 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s704/a/3/A"},"text":"Pub. L. 102–25, title VII, § 704(a)(3)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/118"},"text":"105 Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1061/a/4/A"},"text":"Pub. L. 102–190, div. A, title X, § 1061(a)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1472"},"text":"105 Stat. 1472","children":[],"tail":"; "},{"tag":"ref","attrib":{"h