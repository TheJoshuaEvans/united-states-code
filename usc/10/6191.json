{"tag":"section","attrib":{"id":"idaac42e05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6191"},"text":null,"children":[{"tag":"num","attrib":{"value":"6191"},"text":"§ 6191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports in connection with permanent closures of Department of Energy defense nuclear facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42e06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6191/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training and Job Placement Services Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days before a Department of Energy defense nuclear facility permanently ceases all production and processing operations, the Secretary of Energy shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report containing a discussion of the training and job placement services needed to enable the employees at such facility to obtain employment in the defense environmental cleanup activities at such facility. The discussion shall include the actions that should be taken by the contractor operating and managing such facility to provide retraining and job placement services to employees of such contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42e07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6191/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Closure Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the permanent cessation of production operations at a Department of Energy defense nuclear facility, the Secretary of Energy shall submit to Congress a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42e08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6191/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete survey of environmental problems at the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6191/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget quality data indicating the cost of defense environmental cleanup activities at the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42e0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6191/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of the proposed cleanup schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42e0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1395"},"text":"139 Stat. 1395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42e0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42e0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42e0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2602"},"text":"section 2602 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
