actional year of less than six months to be disregarded (hearing before the Committee on Armed Services of the Senate on H.R. 5007, 81st Cong., 1st sess., p. 313, ","children":[{"tag":"date","attrib":{"date":"1949-07-06"},"text":"July 6, 1949","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab238a85-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab238a86-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8374, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/178/C"},"text":"Pub. L. 85–861, § 1(178)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1528"},"text":"72 Stat. 1528","children":[],"tail":", provided that promotion of reserve commissioned officers be effective upon Federal recognition in next higher grade of Air National Guard, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1629/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1629(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14308/f"},"text":"section 14308(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"