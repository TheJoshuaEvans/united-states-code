{"tag":"section","attrib":{"id":"idab214190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8374"},"text":null,"children":[{"tag":"num","attrib":{"value":"8374"},"text":"§ 8374.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of fractions of years of service in computing retired pay and separation pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In determining the total number of years of service to be used as a multiplier in computing retired pay and separation pay on discharge under this chapter, each full month of service that is in addition to the number of full years of service creditable to a member is counted as one-twelfth of a year and any remaining fractional part of a month is disregarded.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab214191-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/415"},"text":"70A Stat. 415","children":[],"tail":", § 6404; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s503/50"},"text":"Pub. L. 96–513, title V, § 503(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2915"},"text":"94 Stat. 2915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s923/c/4"},"text":"Pub. L. 98–94, title IX, § 923(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/643"},"text":"97 Stat. 643","children":[],"tail":"; renumbered § 8374, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/16"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(16)","children":[],"tail":