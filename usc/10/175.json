}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"175(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"175(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"175(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"175(d)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"175(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:1008(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1008(b).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1008(c).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1008(d) (less proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:1008(d) (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s257"},"text":"July 9, 1952, ch. 608, § 257","children":[],"tail":" (less (e)), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/497"},"text":"66 Stat. 497","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “are” is substituted for the words “is established”, to make clear the continuing authority of the organization established by the source statute. Clauses (3), (4), and (5) are substituted for 50:1008(a)(iii) for clarity. In clauses (6), (7), (8), and (9), the word “designated” is substituted for the word “appointed”, in 50:1008(iv), (v), (vi), and (vii), to make it clear that the positions described are not constitutional offices.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Regular Coast Guard or Coast Guard Reserve” are substituted for the words “Regular or Reserve * * * Coast Guard”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida77a8035-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida77a8036-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/b/3"},"text":"Pub. L. 103–337, § 1661(b)(3)","children":[],"tail":", amended section generally, substituting single undesignated par. for former subsecs. (a) to (f) relating to establishment, composition, functions, and powers of Reserve Forces Policy Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s921/1"},"text":"Pub. L. 103–337, § 921(1)","children":[],"tail":", substituted “and an officer of the Regular Marine Corps each” for “or Regular Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s921/2"},"text":"Pub. L. 103–337, § 921(2)","children":[],"tail":"–(4), added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" substituted “3021” and “8021” for “3033” and “8033”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “Regular or Reserve, to serve as voting members” for “regular or reserve, to serve as a voting member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1306"},"text":"Pub. L. 98–525, § 1306","children":[],"tail":", substituted “two officers of the Coast Guard, regular or reserve” for “an officer of the Regular Coast Guard or the Coast Guard Reserve”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1405/4"},"text":"Pub. L. 98–525, § 1405(4)","children":[],"tail":", inserted a comma following “Reserve Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" substituted “Assistant Secretary of Defense for Reserve Affairs” for “Assistant Secretary of Defense for Manpower and Reserve Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/3"},"text":"Pub. L. 90–168, § 2(3)","children":[],"tail":", substituted “the Assistant Secretary of the Army for Manpower and Reserve Affairs, the Assistant Secretary of the Navy for Manpower and Reserve Affairs, and the Assistant Secretary of the Air Force for Manpower and Reserve Affairs” for “the Secretary, the Under Secretary, or an Assistant Secretary designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s264/b"},"text":"section 264(b) of this title","children":[],"tail":", of each of the military departments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/4"},"text":"Pub. L. 90–168, § 2(4)","children":[],"tail":", substituted “Secretary of Transportation” for “Secretary of the Treasury” as the Secretary empowered to designate officers to serve on the Board and substituted “serve as a voting member” for “serve without vote as a member” in the description of the officer’s service on the Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/4"},"text":"Pub. L. 90–168, § 2(4)","children":[],"tail":", substituted “Assistant Secretary of Defense for Manpower and Reserve Affairs” for “Assistant Secretary of Defense designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s264/a"},"text":"section 264(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/4"},"text":"Pub. L. 90–168, § 2(4)","children":[],"tail":", inserted references to sections 5251 and 5252 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/4"},"text":"Pub. L. 90–168, § 2(4)","children":[],"tail":", substituted “member of a committee or board prescribed under a section listed in subsection (d)” for “member of a committee under section 3033 or 8033 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/168/s2/4"},"text":"Pub. L. 90–168, § 2(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida77a8037-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida77a8038-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/b/3"},"text":"section 1661(b)(3) of Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida77a8039-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-10-01"},"text":"Oct. 1, 19