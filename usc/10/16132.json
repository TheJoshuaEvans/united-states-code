{"tag":"section","attrib":{"id":"idabbc4904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132"},"text":null,"children":[{"tag":"num","attrib":{"value":"16132"},"text":"§ 16132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for educational assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabbc4905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabbc4906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabbc4907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlists, reenlists, or extends an enlistment as a Reserve for service in the Selected Reserve for a period of not less than six years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabbc4908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appointed as, or is serving as, a reserve officer and agrees to serve in the Selected Reserve for a period of not less than six years in addition to any other period of obligated service in the Selected Reserve to which the person may be subject; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabbc4909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before applying for benefits under this section, has completed the requirements of a secondary school diploma (or an equivalency certificate);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to educational assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbc490a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational assistance may not be provided to a member under this chapter until the member has completed the initial period of active duty for training required of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbc490b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each person who becomes entitled to educational assistance under subsection (a) shall at the time the person becomes so entitled be given a statement in writing summarizing the provisions of this chapter and stating clearly and prominently the substance of sections 16134 and 16135 of this title as such sections may apply to the person. At the request of the Secretary of Veterans Affairs, the Secretary of Defense shall transmit a notice of entitlement for each such person to that Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabbc490c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who serves in the Selected Reserve may not receive credit for such service under both the program established by chapter 30 of title 38 and the program established by this chapter but shall elect (in such form and manner as the Secretary of Veterans Affairs may prescribe) the program to which such service is to be credited. However, a person may not receive credit under the program established by this chapter for service (in any grade) on full-time active duty or full-time National Guard duty for the purpose of organizing, administering, recruiting, instructing, or training the reserve components in a position which is included in the end strength required to be authorized each year by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/a/1/B"},"text":"section 115(a)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabbc490d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79/tIV/s402/a"},"text":"Pub. L. 95–79, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-07-30"},"text":"July 30, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/329"},"text":"91 Stat. 329","children":[],"tail":", § 2132; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/485/tIV/s402/a"},"text":"Pub. L. 95–485, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1613"},"text":"92 Stat. 1613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/69"},"text":"Pub. L. 96–513, title V, § 511(69)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2926"},"text":"94 Stat. 2926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tVII/s705/a/1"},"text":"Pub. L. 98–525, title VII, § 705(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2565"},"text":"98 Stat. 2565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/48/s4"},"text":"Pub. L. 100–48, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-06-01"},"text":"June 1, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/331"},"text":"101 Stat. 331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/689/tI"},"text":"Pub. L. 100–689, title I","children":[],"tail":", §§ 110(b), 111(b)(2)–(4), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4170"},"text":"102 Stat. 4170","children":[],"tail":", 4173; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI"},"text":"Pub. L. 101–189, div. A, title VI","children":[],"tail":", §§ 643(a), 645(a), (b)(2), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1458"},"text":"103 Stat. 1458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/f/6"},"text":"Pub. L. 102–25, title VII, § 701(f)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/115"},"text":"105 Stat. 115","children":[],"tail":"; renumbered § 16132 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1663/b/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1663(b)(2)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3006"},"text":"108 Stat. 3006","children":[],"tail":", 3007; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/34"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/419/tI/s102/d"},"text":"Pub. L. 106–419, title I, § 102(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1825"},"text":"114 Stat. 1825","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabbc490e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabbc490f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabbc4910-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/419"},"text":"Pub. L. 106–419","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “before completing initial active duty for training has completed the requirements of a secondary school diploma (or an equivalency certificate), or in the case of an individual who reenlists or extends an enlistment as described in paragraph (1)(A) of this subsection, has completed such requirements at any time before such reenlistment or extension;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “sections 16134” for “section 16134”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/b/2"},"text":"Pub. L. 103–337, § 1663(b)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2132"},"text":"section 2132 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/b/4/A"},"text":"Pub. L. 103–337, § 1663(b)(4)(A)","children":[],"tail":", substituted “16131” for “2131” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/b/4/B"},"text":"Pub. L. 103–337, § 1663(b)(4)(B)","children":[],"tail":", substituted “section 16134 and 16135” for “sections 2134 and 2135”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" substituted “section 115(a)(1)(B)” for “section 115(b)(1)(A)(ii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s645/a"},"text":"Pub. L. 101–189, § 645(a)","children":[],"tail":", substituted “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs” and “to that Secretary” for “to the Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s645/a/1"},"text":"Pub. L. 101–189, § 645(a)(1)","children":[],"tail":", (b)(2), substituted “A person” for “An individual” and “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s643/a"},"text":"Pub. L. 101–189, § 643(a)","children":[],"tail":", inserted at end “However, a person may not receive credit under the program established by this chapter for service (in any grade) on full-time active duty or full-time National Guard duty for the purpose of organizing, administering, recruiting, instructing, or training the reserve components in a position which is included in the end strength required to be authorized each year by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/b/1/A/ii"},"text":"section 115(b)(1)(A)(ii) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/s111/b/2"},"text":"Pub. L. 100–689, § 111(b)(2)","children":[],"tail":", substituted “completed the requirements of” for “received”, and inserted before semicolon at end “, or in the case of an individual who reenlists or extends an enlistment as described in paragraph (1)(A) of this subsection, has completed such requirements at any time before such reenlistment or extension”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/s110/b"},"text":"Pub. L. 100–689, § 110(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Educational assistance may not be provided to a member under this chapter until the member—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) has completed the initial period of active duty for training required of the member; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) has completed 180 days of service in the Selected Reserve.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/s111/b/3"},"text":"Pub. L. 100–689, § 111(b)(3)","children":[],"tail":", inserted at end “At the request of the Administrator of Veterans’ Affairs, the Secretary of Defense shall transmit a notice of entitlement for each such person to the Administrator.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/689/s111/b/4"},"text":"Pub. L. 100–689, § 111(b)(4)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “A person who is entitled to educational assistance under chapter 30 of title 38 based on section 1412 of that title may not also be provided educational assistance under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/48"},"text":"Pub. L. 100–48","children":[],"tail":" substituted “after "},{"tag":"date","attrib":{"date":"1985-06-30"},"text":"June 30, 1985","children":[],"tail":"” for “during the period beginning on "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1988-06-30"},"text":"June 30, 1988","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" amended section generally, updating provisions covering eligibility for educational assistance to cover the period beginning "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1988-06-30"},"text":"June 30, 1988","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" inserted “of this title” after “section 2131” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/485"},"text":"Pub. L. 95–485","children":[],"tail":" substituted “not less than six years” for “automatically extended by two years” and “last day of the term” for “eighth anniversary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabbc4911-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbc4912-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective as if included in the Reserve Officer Personnel Management Act, title XVI of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", as enacted on "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1501/f/3"},"text":"section 1501(f)(3) of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbc4913-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbc4914-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", applicable only to members of the Armed Forces who qualify for educational assistance under this chapter on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/s705/b"},"text":"section 705(b) of Pub. L. 98–525","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16131"},"text":"section 16131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabbc4915-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idabbc4916-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s643/b"},"text":"Pub. L. 101–189, div. A, title VI, § 643(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1458"},"text":"103 Stat. 1458","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tVI/s643/b"},"text":"“The amendment made by subsection (a) [amending this section] shall not affect the eligibility for educational assistance of any person who before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":"] is entitled to educational assistance under section 2131(a) [now 16131(a)] of title 10, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
