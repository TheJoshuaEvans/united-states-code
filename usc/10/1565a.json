{"tag":"section","attrib":{"id":"ida8f33dfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1565a"},"text":"§ 1565a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DNA samples maintained for identification of human remains: use for law enforcement purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f33dff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with Court Order","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f33e00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), if a valid order of a Federal court (or military judge) so requires, an element of the Department of Defense that maintains a repository of DNA samples for the purpose of identification of human remains shall make available, for the purpose specified in subsection (b), such DNA samples on such terms and conditions as such court (or military judge) directs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f33e01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A DNA sample with respect to an individual shall be provided under paragraph (1) in a manner that does not compromise the ability of the Department of Defense to maintain a sample with respect to that individual for the purpose of identification of human remains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33e02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose referred to in subsection (a) is the purpose of an investigation or prosecution of a felony, or any sexual offense, for which no other source of DNA information is reasonably available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f33e03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1565a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “DNA sample” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1565/c"},"text":"section 1565(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f33e04-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1063/a"},"text":"Pub. L. 107–314, div. A, title X, § 1063(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2653"},"text":"116 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
