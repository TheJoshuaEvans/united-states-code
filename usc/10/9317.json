mputed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8925"},"text":"section 8925 of this title","children":[],"tail":"” are inserted for clarity. The 21 words before the proviso and the proviso of the Act of "},{"tag":"date","attrib":{"date":"1885-02-14"},"text":"February 14, 1885","children":[],"tail":", as restated, are not contained in 10:947a. They are also omitted from the revised section, since the proviso is executed and the 21 words before the proviso are omitted as covered by formula E of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8991"},"text":"section 8991 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab6b1b95-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab6b1b96-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9317 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9417"},"text":"section 9417 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab6b1b97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or the Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8917"