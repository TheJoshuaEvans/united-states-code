{"tag":"section","attrib":{"id":"idab6b1b90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9317"},"text":null,"children":[{"tag":"num","attrib":{"value":"9317"},"text":"§ 9317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thirty years or more: regular enlisted members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A regular enlisted member of the Air Force or the Space Force who has at least 30 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9325"},"text":"section 9325 of this title","children":[],"tail":" shall be retired upon his request."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab6b1b91-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/550"},"text":"70A Stat. 550","children":[],"tail":", § 8917; renumbered § 9317 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 806(b)(13), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":", 1840; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/c/15"},"text":"Pub. L. 116–283, div. A, title IX, § 923(c)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3811"},"text":"134 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab6b1b92-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab6b1b93-3a6f-11f1-a58a-d8db54b14ab5