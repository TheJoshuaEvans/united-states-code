{"tag":"section","attrib":{"id":"ida987193e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2495a"},"text":"§ 2495a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas package stores: treatment of United States wines","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall ensure that each nonappropriated-fund activity engaged principally in selling alcoholic beverage products in a packaged form (commonly referred to as a “package store”) that is located at a military installation outside the United States shall give appropriate treatment with respect to wines produced in the United States to ensure that such wines are given, in general, an equitable distribution, selection, and price when compared with wines produced by the host nation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida987193f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tIII/s311/a/1"},"text":"Pub. L. 100–180, div. A, title III, § 311(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1073"},"text":"101 Stat. 1073","children":[],"tail":", § 2489; renumbered § 2495a, "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/b/2"},"text":"Pub. L. 108–375, div. A, title VI, § 651(b)(2)","children":[],"tail":", (c)(5), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1971"},"text":"118 Stat. 1971","children":[],"tail":", 1972.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9871940-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9871941-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9871942-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2489"},"text":"section 2489 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9871943-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9871944-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tIII/s311/b"},"text":"Pub. L. 100–180, div. A, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1073"},"text":"101 Stat. 1073","children":[],"tail":", directed Secretary of Defense to prescribe regulations to implement this section not later than 90 days after "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
