{"tag":"section","attrib":{"id":"ida90d7cc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1761"},"text":null,"children":[{"tag":"num","attrib":{"value":"1761"},"text":"§ 1761.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management information system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90d7cc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1761/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to ensure that the military departments and Defense Agencies establish a management information system capable of providing standardized information to the Secretary on persons serving in acquisition positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7cc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1761/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management information system shall, at a minimum, provide for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7cca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1761/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The collection and retention of information concerning the qualifications, assignments, and tenure of persons in the acquisition workforce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7ccb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1761/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any exceptions and waivers granted with respect to the application of qualification, assignment, and tenure policies, procedures, and practices to such persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7ccc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1761/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relative promotion rates for military personnel in the acquisition workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90d7ccd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1653"},"text":"104 Stat. 1653","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIX/s904/d/1"},"text":"Pub. L. 103–160, div. A, title IX, § 904(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1728"},"text":"107 Stat. 1728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/b/2"},"text":"Pub. L. 107–107, div. A, title X, § 1048(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1225"},"text":"115 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/d/15"},"text":"Pub. L. 108–375, div. A, title X, § 1084(d)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2062"},"text":"118 Stat. 2062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90d7cce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90d7ccf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90d7cd0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “provide for the following:” for “provide for—” in introductory provisions, capitalized first letter of first word in pars. (1) to (3), substituted period for semicolon at end in pars. (1) and (2), substituted period for “; and” at end in par. (3), and struck out par. (4) which read as follows: “collection of the information necessary for the Under Secretary of Defense for Acquisition, Technology, and Logistics and the Secretary of Defense to comply with the requirements of section 1762 for the years in which that section is in effect.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Technology” for “Under Secretary of Defense for Acquisition”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida90d7cd1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida90d7cd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Management Information System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1209/k"},"text":"Pub. L. 101–510, div. A, title XII, § 1209(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1667"},"text":"104 Stat. 1667","children":[],"tail":", required the Secretary of Defense to prescribe in regulations the requirements under this section for the uniform management information system by "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", and ensure that the requirements were implemented by "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
