{"tag":"section","attrib":{"id":"ida7924e84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s261"},"text":null,"children":[{"tag":"num","attrib":{"value":"261"},"text":"§ 261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" During war or threat to national security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7924e85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, through any agency of the Department of Defense designated by him, may arm, have armed, or allow to be armed, any watercraft or aircraft that is capable of being used as a means of transportation on, over, or under water, and is documented, registered, or licensed under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7924e86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies during a war and at any other time when the President determines that the security of the United States is threatened by the application, or the imminent danger of application, of physical force by any foreign government or agency against the United States, its citizens, the property of its citizens, or their commercial interests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7924e87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/s16"},"text":"Section 16 of the Act of March 4, 1909","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s463"},"text":"22 U.S.C. 463","children":[],"tail":") does not apply to vessels armed under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7924e88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/16"},"text":"70A Stat. 16","children":[],"tail":", § 351; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/12"},"text":"Pub. L. 96–513, title V, § 511(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2921"},"text":"94 Stat. 2921","children":[],"tail":"; renumbered § 261, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7924e89-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7924e8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida7924e8b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p"