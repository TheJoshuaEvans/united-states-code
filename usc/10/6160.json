{"tag":"section","attrib":{"id":"idaac1e41e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160"},"text":null,"children":[{"tag":"num","attrib":{"value":"6160"},"text":"§ 6160.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information relating to certain defense nuclear nonproliferation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac1e41f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technologies and Capabilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall document, for efforts that are not focused on basic research, the technologies and capabilities of the defense nuclear nonproliferation research and development program that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac1e420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are transitioned to end users for further development or deployment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac1e421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are deployed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac1e422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments of Status","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac1e423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In assessing projects under the defense nuclear nonproliferation research and development program or the defense nuclear nonproliferation and arms control program, the Administrator shall compare the status of each such project, including with respect to the final results of such project, to the baseline targets and goals established in the initial project plan of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac1e424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6160/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may carry out paragraph (1) using a common template or such other means as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac1e425-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1385"},"text":"139 Stat. 1385","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac1e426-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac1e427-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac1e428-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6160 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8270"},"text":"section 8270 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2576"},"text":"section 2576 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaac1e429-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
