{"tag":"section","attrib":{"id":"ida7f1ac67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s635"},"text":null,"children":[{"tag":"num","attrib":{"value":"635"},"text":"§ 635.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement for years of service: regular and Space Force brigadier generals; regular Navy rear admirals (lower half)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f1ac68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s635/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Army, Navy, Air Force, and Marine Corps","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under section 637(b) or 637a of this title, each officer of the Regular Army, Regular Air Force, or Regular Marine Corps who holds the regular grade of brigadier general, and each officer of the Regular Navy who holds the regular grade of rear admiral (lower half), who is not on a list of officers recommended for promotion to the regular grade of major general or rear admiral, respectively, shall, if not earlier retired, be retired on the first day of the first month beginning after the date of the fifth anniversary of his appointment to that grade or on the first day of the month after the month in which he completes 30 years of active commissioned service, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s635/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space Force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under section 637(b) or 637a of this title, each officer of the Space Force who holds the grade of brigadier general who is not on a list of officers recommended for promotion to the grade of major general shall, if not earlier retired, be retired as specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f1ac6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2863"},"text":"94 Stat. 2863","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIV/s405/b/1"},"text":"Pub. L. 97–86, title IV, § 405(b)(1)","children":[],"tail":", (5)(A), "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1105"},"text":"95 Stat. 1105","children":[],"tail":", 1106; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/13"},"text":"Pub. L. 98–525, title XIV, § 1405(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2622"},"text":"98 Stat. 2622","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tV/s514/b/1"},"text":"Pub. L. 99–145, title V, § 514(b)(1)","children":[],"tail":", (5)(A), "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/628"},"text":"99 Stat. 628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s505/b/3"},"text":"Pub. L. 114–328, div. A, title V, § 505(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2108"},"text":"130 Stat. 2108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/4/F"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(4)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3822"},"text":"134 Stat. 3822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/b/6/C"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(b)(6)(C)","children":[],"tail":", (E)(iii), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/669"},"text":"137 Stat. 669","children":[],"tail":", 670.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f1ac6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f1ac6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f1ac6d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “and Space Force brigadier generals; regular Navy” for “brigadier generals and” in section catchline; designated existing provisions as subsec. (a), inserted heading, and substituted “or Regular Marine Corps” for “Regular Marine Corps, or Regular Space Force”; and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":"