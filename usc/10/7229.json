{"tag":"section","attrib":{"id":"idaade6bc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7229"},"text":null,"children":[{"tag":"num","attrib":{"value":"7229"},"text":"§ 7229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Command: commissioned officers of Army Medical Department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaade6bca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7229/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), a commissioned officer of the Army Medical Department is not entitled to exercise command because of his rank, except within the Army Medical Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaade6bcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7229/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Medical Service Corps may exercise command of troops that are not part of the Army Medical Department whenever authorized by the Secretary of the Army. The Secretary of the Army may delegate such authority to appropriate commanders as the interest of the Army may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaade6bcc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/206"},"text":"70A Stat. 206","children":[],"tail":", § 3579; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/60"},"text":"Pub. L. 85–861, § 1(60)","children":[],"tail":", (87), "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1462"},"t