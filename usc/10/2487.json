{"tag":"section","attrib":{"id":"ida984a888-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487"},"text":null,"children":[{"tag":"num","attrib":{"value":"2487"},"text":"§ 2487.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship between defense commissary system and exchange stores system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida984a889-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate Operation of Systems","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a88a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the defense commissary system and the exchange stores system shall be operated as separate systems of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a88b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) does not apply to the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a88c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Combined exchange and commissary stores operated under the authority provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2489"},"text":"section 2489 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a88d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NEXMART stores of the Navy Exchange Service Command established before ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a88e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consolidation or Other Organizational Changes of Defense Retail Systems","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a88f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation and administration of the defense retail systems may not be consolidated or otherwise merged unless the consolidation or merger is specifically authorized by an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a890-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “defense retail systems” means the defense commissary system and exchange stores system and other revenue-generating facilities operated by nonappropriated fund instrumentalities of the Department of Defense for the morale, welfare, and recreation of members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a891-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Common Business Practices","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a892-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsections (a) and (b), the Secretary of Defense may establish common business processes, practices, and systems—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a893-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exploit synergies between the defense commissary system and the exchange system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a894-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to optimize the operations of the defense retail systems as a whole and the benefits provided by the commissaries and exchanges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a895-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may authorize the defense commissary system and the exchange system to enter into contracts or other agreements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a896-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for products and services that are shared by the defense commissary system and the exchange system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a897-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the acquisition of supplies, resale goods, and services on behalf of both the defense commissary system and the exchange system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a898-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of a contract or agreement authorized under paragraph (2), the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a899-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2483"},"text":"section 2483 of this title","children":[],"tail":" to reimburse a nonappropriated fund entity or instrumentality for the portion of the cost of a contract or agreement entered by the nonappropriated fund entity or instrumentality that is attributable to the defense commissary system; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a89a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the defense commissary system to accept reimbursement from a nonappropriated fund entity or instrumentality for the portion of the cost of a contract or agreement entered by the defense commissary system that is attributable to the nonappropriated fund entity or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida984a89b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2487/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access of Exchange Stores System to Federal Financing Bank","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To facilitate the provision of in-store credit to patrons of the exchange stores system while reducing the costs of providing such credit, the Army and Air Force Exchange Service, Navy Exchange Service Command, and Marine Corps exchanges may issue and sell their obligations to the Federal Financing Bank as provided in section 6 of the Federal Financing Bank Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s2285"},"text":"12 U.S.C. 2285","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida984a89c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/b/1"},"text":"Pub. L. 108–375, div. A, title VI, § 651(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1971"},"text":"118 Stat. 1971","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s642"},"text":"Pub. L. 112–81, div. A, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1466"},"text":"125 Stat. 1466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s661/d"},"text":"Pub. L. 114–328, div. A, title VI, § 661(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2171"},"text":"130 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida984a89d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida984a89e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida984a89f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2487, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIII/s313/a"},"text":"Pub. L. 99–661, div. A, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3852"},"text":"100 Stat. 3852","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s364/a"},"text":"Pub. L. 102–484, div. A, title III, § 364(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2381"},"text":"106 Stat. 2381","children":[],"tail":", 2382; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s332"},"text":"Pub. L. 104–106, div. A, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/260"},"text":"110 Stat. 260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tIII/s333/a"},"text":"Pub. L. 107–107, div. A, title III, § 333(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1058"},"text":"115 Stat. 1058","children":[],"tail":", related to release of certain commercially valuable information to the public by the Secretary of Defense with respect to commissary stores, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/a/1"},"text":"Pub. L. 108–375, div. A, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1964"},"text":"118 Stat. 1964","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida984a8a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
