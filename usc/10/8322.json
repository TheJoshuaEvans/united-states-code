ren":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s879"},"text":"34 U.S.C. 879","children":[],"tail":" (less applicability to enlisted men)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch228/s3"},"text":"June 4, 1920, ch. 228, § 3","children":[],"tail":" (3d proviso, less applicability to enlisted men), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/835"},"text":"41 Stat. 835","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s626–1/a"},"text":"34 U.S.C. 626–1(a)","children":[],"tail":" (1st sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s314/a"},"text":"Aug. 7, 1947, ch. 512, § 314(a)","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/863"},"text":"61 Stat. 863","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-05-05/ch180/s205"},"text":"May 5, 1954, ch. 180, § 205","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/68"},"text":"68 Stat. 68","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “Regular” and “holding a permanent appointment in the grade of warrant officer, W–1, or above” are inserted for clarity. The words “after completing 30 or more years of active service” are substituted for the words “has been thirty years in the service” for clarity. The words “retired from active service” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is added to clarify the word “service”. It has been consistently interpreted to include active service in the armed forces as defined in this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “is entitled to retired pay at the rate of 75 percent of the highest basic pay of the grade in which retired” are substituted for the words “with three-fourths of the highest pay of his grade” for clarity and uniformity of expression.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1c8662-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1c8663-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6322"},"text":"section 6322 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/348"},"text":"Pub. L. 99–348","children":[],"tail":" struck out subsec. (c) which provided that each officer retired under this section be entitled to retired pay, in the case of an officer who first became a member of a uniformed service, as defined in section 1407(a)(2), before "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", at the rate of 75 percent of the highest basic pay of the grade in which retired, and in the case of an officer who first became a member of a uniformed service, as defined in section 1407(a)(2), on or after "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", at the rate of 75 percent of the monthly retired pay base computed under section 1407(d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"September 8, 1980","children":[],"tail":"” for “the date of the enactment of the Department of Defense Authorization Act, 1981” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342"},"text":"Pub. L. 96–342","children":[],"tail":" designated existing provisions as par. (1), inserted provision limiting applicability to officers who became members of the uniformed services before the date of the enactment of the Department of Defense Authorization Act, 1981, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1c8664-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1c8665-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl