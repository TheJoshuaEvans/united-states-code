{"tag":"section","attrib":{"id":"idab1c865b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8322"},"text":null,"children":[{"tag":"num","attrib":{"value":"8322"},"text":"§ 8322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers: 30 years","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1c865c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Regular Navy or the Regular Marine Corps holding a permanent appointment in the grade of warrant officer, W–1, or above who applies for retirement after completing 30 or more years of active service may, in the discretion of the Secretary of the Navy, be retired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c865d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, an officer’s years of active service are computed by adding all his active service in the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1c865e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/394"},"text":"70A Stat. 394","children":[],"tail":", § 6322; "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s813/d/1"},"text":"Pub. L. 96–342, title VIII, § 813(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1104"},"text":"94 Stat. 1104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/p