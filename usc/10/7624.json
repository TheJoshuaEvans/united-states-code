{"tag":"section","attrib":{"id":"idaafb1ba1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7624"},"text":null,"children":[{"tag":"num","attrib":{"value":"7624"},"text":"§ 7624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical supplies: civilian employees of the Army; American National Red Cross; Armed Forces Retirement Home","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafb1ba2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations to be prescribed by the Secretary of the Army, a civilian employee of the Department of the Army who is stationed at an Army post may buy necessary medical supplies from the Army when they are prescribed by an officer of the Medical Corps on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafb1ba3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the approval of the Secretary, the Army Medical Department may sell medical supplies to the American National Red Cross for cash.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafb1ba4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any branch, office, or officer designated by the Secretary may sell medical and hospital supplies to the Armed Forces Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafb1ba5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041"