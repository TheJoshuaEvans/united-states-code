{"tag":"section","attrib":{"id":"ida8537b4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060"},"text":null,"children":[{"tag":"num","attrib":{"value":"1060"},"text":"§ 1060.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military service of retired members with newly democratic nations: consent of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8537b4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), Congress consents to a retired member of the uniformed services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8537b4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepting employment by, or holding an office or position in, the military forces of a newly democratic nation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8537b50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepting compensation associated with such employment, office, or position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537b51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The consent provided in subsection (a) for a retired member of the uniformed services to accept employment or hold an office or position shall apply to a retired member only if the Secretary concerned and the Secretary of State jointly approve the employment or the holding of such office or position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537b52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Newly Democratic Nations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned and the Secretary of State shall jointly determine whether a nation is a newly democratic nation for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"ida8537b53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"[(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/9"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1597"},"text":"117 Stat. 1597","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537b54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Entitlement to Retired Pay and Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The eligibility of a retired member to receive retired or retainer pay and other benefits arising from the retired member’s status as a retired member of the uniformed services, and the eligibility of dependents of such retired member to receive benefits on the basis of such retired member’s status as a retired member of the uniformed services, may not be terminated by reason of employment or holding of an office or position consented to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537b55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retired Member Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “retired member” means a member or former member of the uniformed services who is entitled to receive retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8537b56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Employment by Foreign Governments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a provision of law providing the consent of Congress to civil employment by foreign governments, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s908"},"text":"section 908 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8537b57-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIV/s1433/b/1"},"text":"Pub. L. 103–160, div. A, title XIV, § 1433(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1834"},"text":"107 Stat. 1834","children":[],"tail":", § 1058; renumbered § 1060, "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/a/6/A"},"text":"Pub. L. 103–337, div. A, title X, § 1070(a)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2855"},"text":"108 Stat. 2855","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/13"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/503"},"text":"110 Stat. 503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/9"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1597"},"text":"117 Stat. 1597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8537b58-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8537b59-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8537b5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “The Secretary concerned and the Secretary of State shall notify the Committee on Armed Services and the Committee on Foreign Relations of the Senate and the Committee on Armed Services and the Committee on International Relations of the House of Representatives of each approval under subsection (b) and each determination under subsection (c).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “Committee on National Security and the Committee on International Relations” for “Committee on Armed Services and the Committee on Foreign Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1058"},"text":"section 1058 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8537b5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8537b5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIV/s1433/d"},"text":"Pub. L. 103–160, div. A, title XIV, § 1433(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1835"},"text":"107 Stat. 1835","children":[],"tail":", provided that this section was to take effect as of "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s182/b"},"text":"Pub. L. 103–236, title I, § 182(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/418"},"text":"108 Stat. 418","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8537b5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restoration of Withheld Benefits","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s182/a"},"text":"Pub. L. 103–236, title I, § 182(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/418"},"text":"108 Stat. 418","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/d/7"},"text":"Pub. L. 103–337, div. A, title X, § 1070(d)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2858"},"text":"108 Stat. 2858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/j"},"text":"Pub. L. 103–415, § 1(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4301"},"text":"108 Stat. 4301","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/415/s1/j"},"text":"“With respect to any person for which the Secretary of State and the Secretary concerned within the Department of Defense have approved the employment or the holding of a position pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1060"},"text":"section 1060 of title 10","children":[],"tail":", United States Code, before "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"April 30, 1994","children":[],"tail":", the consents, approvals and determinations under that section shall be deemed to be effective as of "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8537b5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXIV/s1433/a"},"text":"Pub. L. 103–160, div. A, title XIV, § 1433(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1833"},"text":"107 Stat. 1833","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/160/dA/tXIV/s1433/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is in the national security interest of the United States to promote democracy throughout the world.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The armed forces of newly democratic nations often lack the democratic traditions that are a hallmark of the Armed Forces of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The understanding of military roles and missions in a democracy is essential for the development and preservation of democratic forms of government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The service of retired members of the Armed Forces of the United States in the armed forces of newly democratic nations could lead to a better understanding of military roles and missions in a democracy.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
