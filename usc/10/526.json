{"tag":"section","attrib":{"id":"ida7dc4ecc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526"},"text":null,"children":[{"tag":"num","attrib":{"value":"526"},"text":"§ 526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized strength: general officers and flag officers on active duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7dc4ecd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of general officers on active duty in the Army, Air Force, Marine Corps, and Space Force, and the number of flag officers on active duty in the Navy, may not exceed the number specified for the armed force concerned as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4ece-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Army, 219.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ecf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Navy, 150.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ed0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Air Force, 168.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ed1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Marine Corps, 64.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ed2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Space Force, 24.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4ed3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited Exclusion for Joint Duty Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4ed4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may designate up to 232 general officer and flag officer positions that are joint duty assignments for purposes of chapter 38 of this title for exclusion from the limitations in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ed5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum number","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the Secretary of Defense determines that a lower number is in the best interest of the Department of Defense, the minimum number of officers serving in positions designated under paragraph (1) for each armed force shall be as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4ed6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Army, 75.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ed7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Navy, 53.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ed8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Air Force, 68.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ed9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Marine Corps, 17.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4eda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Space Force, 6.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4edb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Certain Officers of Reserve Components and of the Space Force","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitations of this section do not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4edc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A general or flag officer of a reserve component or of the Space Force who is on active duty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4edd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for training; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ede-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a call or order specifying a period of less than 180 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4edf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4ee0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general or flag officer of a reserve component who is authorized by the Secretary of the military department concerned to serve on active duty for a period of at least 180 days and not longer than 365 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ee1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the military department concerned may authorize a number, determined under subparagraph (C), of officers in the reserve component of each armed force under the jurisdiction of that Secretary to serve as described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ee2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each number described in subparagraph (B) may not exceed 10 percent of the number of general or flag officers, as the case may be, authorized to serve in the armed force concerned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12004"},"text":"section 12004 of this title","children":[],"tail":". In determining a number under this subparagraph, any fraction shall be rounded down to the next whole number that is greater than zero."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ee3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may authorize not more than two of the general officers authorized to serve in the Space Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20110"},"text":"section 20110 of this title","children":[],"tail":" to serve on active service for a period of at least 180 days and not longer than 365 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4ee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general or flag officer of a reserve component, or a Space Force general officer in a Space Force active status not on sustained duty, who is on active duty for a period longer than 365 days and not longer than three years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of officers described in subparagraph (A) who do not serve in a position that is a joint duty assignment for purposes of chapter 38 of this title may not exceed five per armed force, unless authorized by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4ee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Certain Officers Pending Separation or Retirement or Between Senior Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitations of this section do not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4ee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of an armed force in the grade of brigadier general or above or, in the case of the Navy, in the grade of rear admiral (lower half) or above, who is on leave pending the retirement, separation, or release of that officer from active duty, but only during the 60-day period beginning on the date of the commencement of such leave of such officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of an armed force who has been relieved from a position designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s601/a"},"text":"section 601(a) of this title","children":[],"tail":" or by law to carry one of the grades specified in such section, but only during the 60-day period beginning on the date on which the assignment of the officer to the first position is terminated or until the officer is assigned to a second such position, whichever occurs first; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4eea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Space Force officer in the grade of brigadier general or above who is pending transition off of sustained duty orders, but only during the 60-day period preceding the end date of such orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4eeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Exclusion for Assignment to Certain Temporary Billets.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4eec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitations in subsection (a) do not apply to a general officer or flag officer assigned to a temporary joint duty assignment designated by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4eed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A general officer or flag officer assigned to a temporary joint duty assignment as described in paragraph (1) may not be excluded under this subsection from the limitations in subsection (a) for a period of longer than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4eee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Officers Departing From Joint Duty Assignments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitations in subsection (a) do not apply to an officer released from a joint duty assignment, but only during the 60-day period beginning on the date the officer departs the joint duty assignment. The Secretary of Defense may authorize the Secretary of a military department to extend the 60-day period by an additional 120 days, except that not more than three officers on active duty from each armed force may be covered by the additional extension at the same time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4eef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Medical Officer of Marine Corps","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitations of this section do not apply to the flag officer who is serving as the Medical Officer of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4ef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary of Defense Adaptive Force Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitations in subsection (a) and in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s525/a"},"text":"section 525(a) of this title","children":[],"tail":" do not apply to a general officer or flag officer assigned to the Secretary of Defense Adaptive Force Account as designated by the Secretary of Defense. The total number of positions designated as the Secretary of Defense Adaptive Force Account for purposes of this subsection shall not exceed 35."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4ef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active-Duty Baseline.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4ef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and wait requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of a military department proposes an action that would increase above the baseline the number of general officers or flag officers of an armed force under the jurisdiction of that Secretary who would be on active duty and would count against the statutory limit applicable to that armed force under subsection (a), the action shall not take effect until after the end of the 60-calendar day period beginning on the date on which the Secretary provides notice of the proposed action, including the rationale for the action, to the Committees on Armed Services of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ef3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baseline defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (1), the term “baseline” for an armed force means the lower of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4ef4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory limit of general officers or flag officers of that armed force under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4ef5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual number of general officers or flag officers of that armed force who, as of ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", counted toward the statutory limit of general officers or flag officers of that armed force under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4ef6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Duty Assignment Baseline.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4ef7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and wait requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense, the Secretary of a military department, or the Chairman of the Joint Chiefs of Staff proposes an action that would increase above the baseline the number of general officers and flag officers of the armed forces in joint duty assignments who count against the statutory limit under subsection (b)(1), the action shall not take effect until after the end of the 60-calendar day period beginning on the date on which such Secretary or the Chairman, as the case may be, provides notice of the proposed action, including the rationale for the action, to the Committees on Armed Services of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4ef8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Baseline defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In paragraph (1), the term “baseline” means the lower of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4ef9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statutory limit on general officer and flag officer positions that are joint duty assignments under subsection (b)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4efa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual number of general officers and flag officers who, as of ","children":[{"tag":"date","attrib":{"date":"2023-01-01"},"text":"January 1, 2023","children":[],"tail":", were in joint duty assignments counted toward the statutory limit under subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4efb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 each year, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report specifying the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4efc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The numbers of general officers and flag officers who, as of January 1 of the calendar year in which the report is submitted, counted toward the service-specific limits of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4efd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of general officers and flag officers in joint duty assignments who, as of such January 1, counted toward the statutory limit under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7dc4efe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Authorizations Among the Military Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7dc4eff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may increase the maximum number of brigadier generals or major generals in the Army, Air Force, Marine Corps, or Space Force, or rear admirals (lower half) or rear admirals in the Navy, allowed under subsection (a) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s525"},"text":"section 525 of this title","children":[],"tail":" and the President may appoint officers in the equivalent grades equal to the number increased by the Secretary of Defense if each appointment is made in conjunction with an offsetting reduction under paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4f00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each increase and appointment made under the authority of paragraph (1) in the Army, Navy, Air Force, Marine Corps, or Space Force, the number of appointments that may be made in the equivalent grade in one of the other armed forces (other than the Coast Guard) shall be reduced by one. When such an increase and appointment is made, the Secretary of Defense shall specify the armed force in which the reduction required by this paragraph is to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4f01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of general officers and flag officers increased under paragraph (1), combined with the total number of general officers and flag officers increased under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s526/k/1"},"text":"section 526(k)(1) of this title","children":[],"tail":", may not exceed 15 at any one time."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7dc4f02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not increase the maximum number of general officers or flag officers under paragraph (1) until the date that is 30 days after the date on which the Secretary provides, to the Committees on Armed Services of the Senate and the House of Representatives, written notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7dc4f03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such increase; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7dc4f04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s526/l/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each offsetting reduction under paragraph (2), specifying the armed force and billet so reduced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7dc4f05-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s501/h/1"},"text":"Pub. L. 114–328, div. A, title V, § 501(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2100"},"text":"130 Stat. 2100","children":[],"tail":", § 526a; amended "},{"tag":"ref","attrib"