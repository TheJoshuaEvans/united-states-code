{"tag":"section","attrib":{"id":"idaade6b8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7216"},"text":null,"children":[{"tag":"num","attrib":{"value":"7216"},"text":"§ 7216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leader of Army Band: appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaade6b8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may appoint the leader of the Army band from the warrant officers of the Regular Army. The leader serves during the pleasure of the Secretary and may be returned to his former status in the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"idaade6b8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/5"},"text":"Pub. L. 87–649, § 14c(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaade6b8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon retirement, the leader of the Army band has the grade of warrant officer, with the retired pay to which he would have been entitled had he not been appointed leader.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaade6b90-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/201"},"text":"70A Stat. 201","children":[],"tail":", § 3536; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/5"},"text":"Pub. L. 87–649, § 14c(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":"; renumbered § 7216, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/6"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaade6b91-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaade6b92-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaade6b93-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"