{"tag":"section","attrib":{"id":"ida842d98d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985"},"text":null,"children":[{"tag":"num","attrib":{"value":"985"},"text":"§ 985.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons convicted of capital crimes; certain other persons: denial of specified burial-related benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida842d98e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Performance of Military Honors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of a military department and the Secretary of Homeland Security, with respect to the Coast Guard when it is not operating as a service in the Navy, may not provide military honors (under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of this title","children":[],"tail":" or any other authority) at the funeral or burial of any of the following persons:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida842d98f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411/b"},"text":"section 2411(b) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida842d990-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is a veteran (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491/h"},"text":"section 1491(h) of this title","children":[],"tail":") or who died while on active duty or a member of a reserve component, when the circumstances surrounding the person’s death or other circumstances as specified by the Secretary of Defense are such that to provide military honors at the funeral or burial of the person would bring discredit upon the person’s service (or former service)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida842d991-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disqualification From Burial in Military Cemeteries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), a person who is ineligible for interment in a national cemetery under the control of the National Cemetery Administration by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411/b"},"text":"section 2411(b) of title 38","children":[],"tail":" is not entitled to or eligible for, and may not be provided, burial in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida842d992-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arlington National Cemetery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida842d993-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Soldiers’ and Airmen’s National Cemetery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida842d994-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other cemetery administered by the Secretary of a military department or the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida842d995-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unclaimed Remains of Military Prisoners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (b) shall not preclude the burial at the United States Disciplinary Barracks Cemetery at Fort Leavenworth, Kansas, of a military prisoner, including a military prisoner who is a person described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411/b"},"text":"section 2411(b) of title 38","children":[],"tail":", who dies while in custody of a military department and whose remains are not claimed by the person authorized to direct disposition of the remains or by other persons legally authorized to dispose of the remains."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida842d996-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s985/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “burial” includes inurnment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida842d997-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1077/a/1"},"text":"Pub. L. 105–85, div. A, title X, § 1077(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1914"},"text":"111 Stat. 1914","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s662/b/1"},"text":"Pub. L. 109–163, div. A, title VI, § 662(b)(1)","children":[],"tail":"–(3), (c)(1), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3315"},"text":"119 Stat. 3315","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s592"},"text":"Pub. L. 115–232, div. A, title V, § 592","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1788"},"text":"132 Stat. 1788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida842d998-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida842d999-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida842d99a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s592/1"},"text":"Pub. L. 115–232, § 592(1)","children":[],"tail":", substituted “Except as provided in subsection (c), a person who is ineligible” for “A person who is ineligible” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s592/2"},"text":"Pub. L. 115–232, § 592(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/c/1"},"text":"Pub. L. 109–163, § 662(c)(1)","children":[],"tail":", substituted “Persons convicted of capital crimes; certain other persons: denial of specified burial-related benefits” for “Persons convicted of capital crimes: denial of certain burial-related benefits” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/b/1/B"},"text":"Pub. L. 109–163, § 662(b)(1)(B)","children":[],"tail":", substituted “any of the following persons:” for “a person who has been convicted of a capital offense under Federal or State law for which the person was sentenced to death or life imprisonment without parole.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/b/1/A"},"text":"Pub. L. 109–163, § 662(b)(1)(A)","children":[],"tail":", inserted “(under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of this title","children":[],"tail":" or any other authority)” after “military honors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/b/2"},"text":"Pub. L. 109–163, § 662(b)(2)","children":[],"tail":", in introductory provisions, substituted “who is ineligible for interment in a national cemetery under the control of the National Cemetery Administration by reason of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411/b"},"text":"section 2411(b) of title 38","children":[],"tail":"” for “convicted of a capital offense under Federal law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s662/b/3"},"text":"Pub. L. 109–163, § 662(b)(3)","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows: “In this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘capital offense’ means an offense for which the death penalty may be imposed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘burial’ includes inurnment.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The term ‘State’ includes the District of Columbia and any commonwealth or territory of the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida842d99b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida842d99c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s662/e"},"text":"Pub. L. 109–163, div. A, title VI, § 662(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3316"},"text":"119 Stat. 3316","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVI/s662/e"},"text":"“The amendments made by this section [amending this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411"},"text":"section 2411 of Title 38","children":[],"tail":", Veterans’ Benefits and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411"},"text":"section 2411 of Title 38","children":[],"tail":"] shall apply with respect to funerals and burials that occur on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida842d99d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida842d99e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1077/b"},"text":"Pub. L. 105–85, div. A, title X, § 1077(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1915"},"text":"111 Stat. 1915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tX/s1077/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s985"},"text":"Section 985 of title 10","children":[],"tail":", United States Code, as added by subsection (a), applies with respect to persons dying after "},{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida842d99f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s662/d/2"},"text":"Pub. L. 109–163, div. A, title VI, § 662(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3316"},"text":"119 Stat. 3316","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVI/s662/d/2"},"text":"“The Secretary of Defense shall prescribe regulations to ensure that a person is not interred in any military cemetery under the authority of the Secretary of a military department or provided funeral honors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of title 10","children":[],"tail":", United States Code, unless a good faith effort has been made to determine whether such person is ineligible for such interment or honors by reason of being a person described in "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s2411/b"},"text":"section 2411(b) of title 38","children":[],"tail":", United States Code, or is otherwise ineligible for such interment or honors under Federal law.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
