{"tag":"section","attrib":{"id":"idabca7975-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239"},"text":null,"children":[{"tag":"num","attrib":{"value":"20239"},"text":"§ 20239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotions: how made","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca7976-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion Lists.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca7977-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Placement of names on promotion list","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the report of a selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" is approved by the President, the Secretary of the Air Force shall place the names of all officers approved for promotion within a competitive category on a single list for that competitive category, to be known as a promotion list, in the order of the seniority of such officers on the Space Force officer list or based on particular merit, as determined by the promotion board, or as modified by the Secretary of the Air Force under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20217"},"text":"section 20217 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7978-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time of establishment of promotion list","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A promotion list is considered to be established under this section as of the date of the approval of the report of the selection board under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7979-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotions; How Made; Order.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca797a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Officers on a promotion list shall be promoted by appointment in the manner specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20201"},"text":"section 20201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca797b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Officers on a promotion list for a competitive category shall be promoted to the next higher grade in accordance with regulations prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca797c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsections (e) and (f), promotions shall be made in the order in which the names of officers appear on the promotion list and after officers previously selected for promotion in that competitive category have been promoted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca797d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotions to grade of first lieutenant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Officers to be promoted to the grade of first lieutenant shall be promoted in accordance with regulations prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca797e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promotion of First Lieutenants on an All-fully-qualified Officers List","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca797f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (f), officers on the Space Force officer list in the grade of first lieutenant who are on an approved all-fully-qualified-officers list shall be promoted to the grade of captain in accordance with regulations prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7980-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An all-fully-qualified-officers list shall be considered to be approved for purposes of paragraph (1) when the list is approved by the President. When so approved, such a list shall be treated in the same manner as a promotion list under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7981-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force may make a recommendation to the President for approval of an all-fully-qualified-officers list only when the Secretary determines that all officers on the list are needed in the next higher grade to accomplish mission objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7982-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this paragraph, an all-fully-qualified-officers list is a list of all officers on the Space Force officer list in a grade who the Secretary of the Air Force determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabca7983-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are fully qualified for promotion to the next higher grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabca7984-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be eligible for consideration for promotion to the next higher grade by a selection board convened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20211"},"text":"section 20211 of this title","children":[],"tail":" upon the convening of such a board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7985-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of the Air Force determines that one or more officers or former officers were not placed on an all-fully-qualified-list under this subsection because of administrative error, the Secretary may prepare a supplemental all-fully-qualified-officers list containing the names of any such officers for approval in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca7986-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Date of Rank.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca7987-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The date of rank of an officer appointed to a higher grade under this section is determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s741/d"},"text":"section 741(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7988-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The date of rank of an officer appointed to a higher grade under this section may be adjusted in the same manner as an adjustment may be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s741/d/4"},"text":"section 741(d)(4) of this title","children":[],"tail":" in the date of rank of an officer appointed to a higher grade under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s624/a"},"text":"section 624(a) of this title","children":[],"tail":". In any use of the authority under the preceding sentence, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s741/d/4/C/ii"},"text":"section 741(d)(4)(C)(ii) of this title","children":[],"tail":" shall be applied by substituting “Space Force officer list” for “active-duty list”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca7989-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional pay and allowances precluded","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2) or as otherwise specifically authorized by law, an officer is not entitled to additional pay or allowances if the effective date of the officer’s promotion is adjusted to reflect a date earlier than the actual date of the officer’s promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca798a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay of Promotions to General Officer Grades to Comply With Strength Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense, the promotion of an officer on the Space Force officer list to the grade of brigadier general or major general shall be delayed if that promotion would cause any strength limitation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s526"},"text":"section 526 of this title","children":[],"tail":" to be exceeded. The delay shall expire when the Secretary of the Air Force determines that the delay is no longer required to ensure compliance with the strength limitation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca798b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20239/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Delay Appointments for Specified Reasons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14311"},"text":"section 14311 of this title","children":[],"tail":" shall apply to the appointment of an officer under this section in the same manner as they apply to an appointment of an officer under that section, and any reference in that section to an reserve active-status list shall be treated for purposes of applicability to an officer of the Space Force as referring to the Space Force officer list."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabca798c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/645"},"text":"137 Stat. 645","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521/s"},"text":"Pub. L. 118–159, div. A, title V, § 521(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1882"},"text":"138 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabca798d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabca798e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabca798f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/s/1"},"text":"Pub. L. 118–159, § 521(s)(1)","children":[],"tail":", substituted “paragraph (1)” for “subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s521/s/2"},"text":"Pub. L. 118–159, § 521(s)(2)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s741/d/4/C/ii"},"text":"section 741(d)(4)(C)(ii) of this title","children":[],"tail":"” for “subparagraph (C)(ii) of such section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
