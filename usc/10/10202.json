{"tag":"section","attrib":{"id":"idab8c86a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10202"},"text":null,"children":[{"tag":"num","attrib":{"value":"10202"},"text":"§ 10202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c86a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to standards, policies, and procedures prescribed by the Secretary of Defense, the Secretary of each military department shall prescribe such regulations as the Secretary considers necessary to carry out provisions of law relating to the reserve components under the Secretary’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security, with the concurrence of the Secretary of the Navy, shall prescribe such regulations as the Secretary considers necessary to carry out all provisions of law relating to the reserve components insofar as they relate to the Coast Guard, except when the Coast Guard is operating as a service in the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" So far as practicable, regulations for all reserve components shall be uniform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c86a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[