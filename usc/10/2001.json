{"tag":"section","attrib":{"id":"ida91bd441-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001"},"text":"§ 2001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human relations training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida91bd442-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Human Relations Training","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91bd443-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida91bd444-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that the Secretary of each military department conducts ongoing programs for human relations training for all members of the armed forces under the jurisdiction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91bd445-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Matters covered by such training include race relations, equal opportunity, opposition to gender discrimination, and sensitivity to hate group activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91bd446-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such training shall be provided during basic training (or other initial military training) and on a regular basis thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91bd447-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that a unit commander is aware of the responsibility to ensure that impermissible activity, based upon discriminatory motives, does not occur in a unit under the command of such commander.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91bd448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Provided to Prospective Recruits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91bd449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each individual preparing to enter an officer accession program or to execute an original enlistment agreement is provided information concerning the meaning of the oath of office or oath of enlistment for service in the armed forces in terms of the equal protection and civil liberties guarantees of the Constitution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91bd44a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each such individual is informed that if supporting such guarantees is not possible personally for that individual, then that individual should decline to enter the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida91bd44b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s552/a"},"text":"Pub. L. 117–81, div. A, title V, § 552(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1735"},"text":"135 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida91bd44c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida91bd44d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida91bd44e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2001, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/119"},"text":"70A Stat. 119","children":[],"tail":", related to division of reserve components into training categories, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/3/A"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2980"},"text":"108 Stat. 2980","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10141/c"},"text":"section 10141(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
