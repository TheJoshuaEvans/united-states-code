{"tag":"section","attrib":{"id":"ida92c7602-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2125"},"text":null,"children":[{"tag":"num","attrib":{"value":"2125"},"text":"§ 2125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the program: exclusion from authorized strengths","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, members of the program shall not be counted against any prescribed military strengths.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida92c7603-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/426/s2/a"},"text":"Pub. L. 92–426, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/718"},"text":"86 Stat. 718","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
