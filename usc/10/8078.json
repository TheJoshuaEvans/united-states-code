{"tag":"section","attrib":{"id":"idab0bbd76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8078"},"text":null,"children":[{"tag":"num","attrib":{"value":"8078"},"text":"§ 8078.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Medicine and Surgery: Dental Corps; Chief; functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0bbd77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8078/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Dental Corps shall be detailed as Chief of the Dental Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbd78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8078/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Dental Corps is entitled to the same privileges of retirement as provided for chiefs of bureaus in section 5133 ","children":[{"tag":"ref","attrib":{"idref":"fn002161"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbd79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8078/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All matters relating to dentistry shall be referred to the Chief of the Dental Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbd7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8078/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"