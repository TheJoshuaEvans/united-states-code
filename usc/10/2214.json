{"tag":"section","attrib":{"id":"ida93f888d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214"},"text":null,"children":[{"tag":"num","attrib":{"value":"2214"},"text":"§ 2214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds: procedure and limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93f888e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Transfer of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever authority is provided in an appropriation Act to transfer amounts in working capital funds or to transfer amounts provided in appropriation Acts for military functions of the Department of Defense (other than military construction) between such funds or appropriations (or any subdivision thereof), amounts transferred under such authority shall be merged with and be available for the same purposes and for the same time period as the fund or appropriations to which transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f888f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Programs for Which Authority May Be Used","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such authority to transfer amounts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93f8890-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used except to provide funds for a higher priority item, based on unforeseen military requirements, than the items for which the funds were originally appropriated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f8891-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used if the item to which the funds would be transferred is an item for which Congress has denied funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f8892-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall promptly notify the Congress of each transfer made under such authority to transfer amounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93f8893-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Requests to Congress for Reprogrammings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the Secretary of Defense nor the Secretary of a military department may prepare or present to the Congress, or to any committee of either House of the Congress, a request with respect to a reprogramming of funds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93f8894-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the funds to be transferred are to be used for a higher priority item, based on unforeseen military requirements, than the item for which the funds were originally appropriated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93f8895-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2214/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the request would be for authority to reprogram amounts to an item for which the Congress has denied funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93f8896-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1482/c/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1482(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1709"},"text":"104 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93f8897-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida93f8898-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida93f8899-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1482/d"},"text":"section 1482(d) of Pub. L. 101–510","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s119"},"text":"section 119 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida93f889a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification to Congress of Reprogramming Involving Military Construction Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2810"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2810","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2252"},"text":"138 Stat. 2252","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dB/tXXVIII/s2810"},"text":"“The Secretary of Defense shall notify the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] of any reprogramming of funds made available for military construction not later than 14 days after the date of such reprogramming.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
