{"tag":"section","attrib":{"id":"idaac42d7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176"},"text":null,"children":[{"tag":"num","attrib":{"value":"6176"},"text":"§ 6176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense environmental cleanup technology program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42d7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall establish and carry out a program of research for the development of technologies useful for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of environmental hazards and contamination resulting from defense waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental restoration of inactive defense waste disposal sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense waste” means waste, including radioactive waste, resulting primarily from atomic energy defense activities of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6176/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “inactive defense waste disposal site” means any site (including any facility) under the control or jurisdiction of the Secretary of Energy which is used for the disposal of defense waste and is closed to the disposal of additional defense waste, including any site that is subject to decontamination and decommissioning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42d84-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1389"},"text":"139 Stat. 1389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42d85-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42d86-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42d87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2586"},"text":"section 2586 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
