{"tag":"section","attrib":{"id":"idaafd65c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715"},"text":null,"children":[{"tag":"num","attrib":{"value":"7715"},"text":"§ 7715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army museum system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd65c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall support a system of official Army museums within the United States Army Center of Military History. Such system shall include the National Museum of the United States Army and may contain other museums honoring individual installations, units, and branches, as designated by the Secretary of the Army, that meet criteria established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall establish criteria for designating museums of subsection (a) for inclusion in the Army museum system. Such criteria shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd65ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historical significance to Army operations, technology, or personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public accessibility and educational outreach programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alignment with the mission of the Army to preserve its heritage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Closure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall establish criteria for closing museums within the Army museum system. No museum within such system may be closed until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd65ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the Army submits to the Committees on Armed Services of the House of Representatives and the Senate notice that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaafd65cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for the preservation, storage, or alternate display of historical collections contained in the museum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaafd65d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how any issues relating to museum personnel will be resolved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaafd65d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any efforts to maintain museum operations through public-private partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaafd65d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the cost to transport, consolidate, and preserve the historical collections contained in the museum; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 90 days has elapsed after the date on which such notice is received by such committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding and Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consistent with applicable law, the Secretary may enter into partnerships, including with nonprofit organizations, to enhance the financial sustainability and public engagement of the museums in the Army museum system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafd65d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s374"},"text":"Pub. L. 119–60, div. A, title III, § 374","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/838"},"text":"139 Stat. 838","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
