{"tag":"section","attrib":{"id":"idabadf14f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14003"},"text":null,"children":[{"tag":"num","attrib":{"value":"14003"},"text":"§ 14003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve active-status lists: position of officers on the list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabadf150-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Position on List","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Officers shall be carried on the reserve active-status list of the armed force of which they are members in the order of seniority of the grade in which they are serving in an active status. Officers serving in the same grade shall be carried in the order of their rank in that grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf151-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Position Held by Reason of Temporary Appointment or Assignment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer whose position on the reserve active-status list results from service under a temporary appointment or in a grade held by reason of assignment to a position has, when that appointment or assignment ends, the grade and position on that list that the officer would have held if the officer had not received that appointment or assignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabadf152-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2923"},"text":"108 Stat. 2923","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/b/22"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(b)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/497"},"text":"110 Stat. 497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabadf153-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb03a44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb03a45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" inserted “lists” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb03a46-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb03a47-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"ta