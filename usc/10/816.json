tml:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"816","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:576.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 16), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/113"},"text":"64 Stat. 113","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “The” is substituted for the words “There shall be”. The word “are” is substituted for the word “namely”. The words “not less than five members” are substituted for the words “any number of members not less than five”. The words “not less than three members” are substituted for the words “any number of members not less than three”. The word “commissioned” is inserted before the word “officer” in clause (3) for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida813174a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida813174b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out “by the convening authority” after “is so referred”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “sections 825(e)(3) and 829 of this title (articles 25(e)(3) and 29)” for “sections 825(d)(3) and 829 of this title (articles 25(d)(3) and 29)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section defined the three kinds of courts-martial in each of the armed forces."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" inserted “or, in a case in which the accused may be sentenced to a penalty of death, the number of members determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s825a"},"text":"section 825a of this title","children":[],"tail":" (article 25a)” after “five members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209"},"text":"Pub. L. 98–209","children":[],"tail":" substituted “orally on the record or in writing” for “in writing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" provided that a general or special court-martial shall consist of only a military judge if the accused, before the court is assembled, so requests in writing and the military judge approves, with the added requirements that the accused know the identity of the military judge and have the advice of counsel, and that the election be available in the case of a special court-martial only if a military judge has been detailed to the court."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida813174c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida813174d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s531/e"},"text":"Pub. L. 118–31, div. A, title V, § 531(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/260"},"text":"137 Stat. 260","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tV/s531/e"},"text":"“The amendments made by subsection (b) and subsection (c)(1) [amending this section and sections 824a and 825 of this title] shall take effect immediately after the coming into effect of the amendments made by part 1 of subtitle D of title V of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":") as provided in section 539C of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida813174e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after the amendments made by div. E (§§ 5001–5542) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" take effect as provided for in section 5542 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/c/4"},"text":"section 1081(c)(4) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida813174f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8131750-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s582/d"},"text":"Pub. L. 107–107, div. A, title V, § 582(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1125"},"text":"115 Stat. 1125","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tV/s582/d"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s825a"},"text":"section 825a of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s829"},"text":"section 829 of this title","children":[],"tail":"] shall apply with respect to offenses committed after "},{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8131751-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,