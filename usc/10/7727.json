{"tag":"section","attrib":{"id":"idaafd6639-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727"},"text":null,"children":[{"tag":"num","attrib":{"value":"7727"},"text":"§ 7727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cemetery concessions contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd663a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may enter into a contract with an appropriate entity for the provision of transportation, interpretative, or other necessary or appropriate concession services to visitors at the Army National Military Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd663b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd663c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall establish and include in each concession contract such requirements as the Secretary determines are necessary to ensure the protection, dignity, and solemnity of the cemetery at which services are provided under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd663d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A concession contract shall not include operation of the gift shop at Arlington National Cemetery without the specific prior authorization by an Act of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd663e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Franchise Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A concession contract shall provide for payment to the United States of a franchise fee or such other monetary consideration as determined by the Secretary of the Army. The Secretary shall ensure that the objective of generating revenue for the United States is subordinate to the objectives of honoring the service and sacrifices of the deceased members of the armed forces and of providing necessary and appropriate services for visitors to the Cemeteries at reasonable rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd663f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All franchise fees (and other monetary consideration) collected by the United States under subsection (c) shall be deposited into a special account established in the Treasury of the United States. The funds deposited in such account shall be available for expenditure by the Secretary of the Army, to the extent authorized and in such amounts as are provided in advance in appropriations Acts, to support activities at the Cemeteries. The funds deposited into the account shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd6640-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7727/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concession Contract Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “concession contract” means a contract authorized and entered into under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafd6641-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV/s585/a"},"text":"Pub. L. 113–66, div. A, title V, § 585(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/777"},"text":"127 Stat. 777","children":[],"tail":", § 4727; renumbered § 7727, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaafd6642-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaafd6643-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaafd6644-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7727 to 7730 were renumbered sections 8897 to 8900 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaafd6645-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4727"},"text":"section 4727 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaafd6646-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaafd6647-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
