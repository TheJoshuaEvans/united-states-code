{"tag":"section","attrib":{"id":"ida9f25e51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2893"},"text":null,"children":[{"tag":"num","attrib":{"value":"2893"},"text":"§ 2893.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of incentive fees for landlords of housing units for failure to remedy health or environmental hazards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary concerned shall not approve the payment of incentive fees otherwise authorized to be paid to a landlord that the Secretary determines has demonstrated a pattern of failing to remedy, or failing to remedy in a timely manner, a health or environmental hazard at a housing unit provided by the landlord.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9f25e52-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3021"},"text":"Pub. L. 116–92, div. B, title XXX, § 3021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1931"},"text":"133 Stat. 1931","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/tXXVIII/s2811/f"},"text":"Pub. L. 116–283, div. B, title XXVIII, § 2811(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4324"},"text":"134 Stat. 4324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f25e53-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9f25e54-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9f25e55-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “pattern of” for “propensity for”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
