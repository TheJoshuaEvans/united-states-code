{"tag":"section","attrib":{"id":"ida8289b45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s890"},"text":null,"children":[{"tag":"num","attrib":{"value":"890"},"text":"§ 890.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 90. Willfully disobeying superior commissioned officer","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who willfully disobeys a lawful command of that person’s superior commissioned officer shall be punished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8289b46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s890/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense is committed in time of war, by death or such other punishment as a court-martial may direct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8289b47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s890/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense is committed at any other time, by such punishment, other than death, as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8289b48-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/68"},"text":"70A Stat. 68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5409"},"text":"Pub. L. 114–328, div. E, title LX, § 5409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2942"},"text":"130 Stat. 2942","children":[],"tail"