{"tag":"section","attrib":{"id":"idaa1d3e63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308"},"text":null,"children":[{"tag":"num","attrib":{"value":"3308"},"text":"§ 3308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1d3e64-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protest File.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1d3e65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, in the case of a solicitation for a contract issued by, or an award or proposed award of a contract by, the head of an agency, a protest is filed pursuant to the procedures in subchapter V of chapter 35 of title 31 and an actual or prospective offeror so requests, a file of the protest shall be established by the procuring activity and reasonable access shall be provided to actual or prospective offerors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1d3e66-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redacted information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" may be redacted in a file established pursuant to paragraph (1) unless an applicable protective order provides otherwise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1d3e67-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Actions on Protests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in connection with a protest, the head of an agency determines that a solicitation, proposed award, or award does not comply with the requirements of law or regulation, the head of the agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1d3e68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take any action set out in subparagraphs (A) through (F) of subsection (b)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3554"},"text":"section 3554 of title 31","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1d3e69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may pay costs described in paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3554/c"},"text":"section 3554(c) of title 31","children":[],"tail":" within the limits referred to in paragraph (2) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1d3e6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","child