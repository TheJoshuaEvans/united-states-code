{"tag":"section","attrib":{"id":"idabc34d52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a"},"text":null,"children":[{"tag":"num","attrib":{"value":"18233a"},"text":"§ 18233a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and wait requirements for certain projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc34d53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), an expenditure or contribution in excess of the amount specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/b/1"},"text":"section 2805(b)(1) of this title","children":[],"tail":" may not be made under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233"},"text":"section 18233 of this title","children":[],"tail":" for any facility until—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc34d54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense has notified the congressional defense committees of the location, nature, and estimated cost of the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 21 days has elapsed after the notification has been received by those committees or, if over sooner, a period of 14 days has elapsed after the date on which a copy of the notification is provided in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc34d56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Expenditures or Contributions Exempted","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to expenditures or contributions for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc34d57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilities acquired by lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A project for a facility that has been authorized by Congress, if the location and purpose of the facility are the same as when authorized and if, based upon bids received—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc34d59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope of work of the project, as approved by Congress, is not proposed to be reduced by more than 25 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc5be5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the current working estimate of the cost of the project does not exceed the amount approved for the project by more than the lesser of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabc5be5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabc5be5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200 percent of the amount specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/a"},"text":"section 2805(a) of this title","children":[],"tail":" as the maximum amount for a minor military construction project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc5be5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A repair project (as that term is defined in subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2811"},"text":"section 2811 of this title","children":[],"tail":") that costs less than the amount specified in subsection (d) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc5be5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/685/tVI/s601/3"},"text":"Pub. L. 85–685, title VI, § 601(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-20"},"text":"Aug. 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/665"},"text":"72 Stat. 665","children":[],"tail":", § 2233a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/554/tVII/s701"},"text":"Pub. L. 87–554, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-07-27"},"text":"July 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/243"},"text":"76 Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/552/tVII/s703"},"text":"Pub. L. 93–552, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-27"},"text":"Dec. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1770"},"text":"88 Stat. 1770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/107/tVII/s703"},"text":"Pub. L. 94–107, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-10-07"},"text":"Oct. 7, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/569"},"text":"89 Stat. 569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/125/tVII/s704"},"text":"Pub. L. 96–125, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-26"},"text":"Nov. 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/947"},"text":"93 Stat. 947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s3/c/1"},"text":"Pub. L. 97–214, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/169"},"text":"96 Stat. 169","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/115/tVII/s702"},"text":"Pub. L. 98–115, title VII, § 702","children":[],"tail