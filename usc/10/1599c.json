{"tag":"section","attrib":{"id":"ida8fcda36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599c"},"text":"§ 1599c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care professionals: enhanced appointment and compensation authority for personnel for care and treatment of wounded and injured members of the armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fcda37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may, at the discretion of the Secretary, exercise any authority for the appointment and pay of health care personnel under chapter 74 of title 38 for purposes of the recruitment, employment, and retention of civilian health care professionals for the Department of Defense if the Secretary determines that the exercise of such authority is necessary in order to provide or enhance the capacity of the Department to provide care and treatment for members of the armed forces who are wounded or injured on active duty in the armed forces and to support the ongoing patient care and medical readiness, education, and training requirements of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcda3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304"},"text":"section 3304 of title 5","children":[],"tail":", the Secretary of Defense may—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida8fcda3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate any category of medical or health professional positions within the Department of Defense as a shortage category occupation or critical need occupation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8fcda3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the authority in such section to recruit and appoint qualified persons directly in the competitive service to positions so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In using the authority provided by this paragraph, the Secretary shall apply the principles of preference for the hiring of veterans and other persons established in subchapter I of chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcda3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any designation by the Secretary for purposes of subparagraph (A)(i) shall be based on an analysis of current and future Department of Defense workforce requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcda40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary of Defense under subsection (a)(1) to exercise authorities available under chapter 74 of title 38 for purposes of the recruitment, employment, and retention of civilian health care professionals for the Department of Defense expires ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcda41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not appoint a person to a position of employment under subsection (a)(2) after ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcda42-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref