 Stat. 3897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s712"},"text":"Pub. L. 118–159, div. A, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1947"},"text":"138 Stat. 1947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fcda43-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fcda44-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8fcda45-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1599c, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1615/a/1"},"text":"Pub. L. 104–201, div. A, title XVI, § 1615(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2740"},"text":"110 Stat. 2740","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/31"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1902"},"text":"111 Stat. 1902","children":[],"tail":", related to treatment of a Department of Defense violation of veterans’ preference requirements as a prohibited personnel practice, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/339/s6/c/1/A"},"text":"Pub. L. 105–339, § 6(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3188"},"text":"112 Stat. 3188","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fcda46-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2025-12-31"},"text":"December 31, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1109/c/1"},"text":"Pub. L. 113–66, § 1109(c)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304"},"text":"section 3304 of title 5","children":[],"tail":"” for “sections 3304, 5333, and 5753 of title 5” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1109/c/2"},"text":"Pub. L. 113–66, § 1109(c)(2)","children":[],"tail":", substituted “the authority in such section” for “the authorities in such sections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1109/b"},"text":"Pub. L. 113–66, § 1109(b)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to recruitment of personnel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1109/b/2"},"text":"Pub. L. 113–66, § 1109(b)(2)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1109/a"},"text":"Pub. L. 113–66, § 1109(a)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1104/a/1/A"},"text":"Pub. L. 111–383, § 1104(a)(1)(A)","children":[],"tail":", substituted “a shortage category occupation or critical need occupation” for “shortage category positions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1104/a/1/B"},"text":"Pub. L. 111–383, § 1104(a)(1)(B)","children":[],"tail":", substituted “qualified persons directly in the competitive service” for “highly qualified persons directly”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1075/b/22"},"text":"Pub. L. 111–383, § 1075(b)(22)","children":[],"tail":", substituted “subchapter I” for “subchapter 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1104/a/2"},"text":"Pub. L. 111–383, § 1104(a)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1104/b/1"},"text":"Pub. L. 111–383, § 1104(b)(1)","children":[],"tail":", inserted “under subsection (a)(1)” after “Secretary of Defense” and substituted “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s1104/b/2"},"text":"Pub. L. 111–383, § 1104(b)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" amended section generally. Prior to amendment, section related to appointment in excepted service of certain health care professionals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s1107/a"},"text":"Pub. L. 110–417, § 1107(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s1107/b"},"text":"Pub. L. 110–417, § 1107(b)","children":[],"tail":", designated existing provisions as par. (1), substituted “"},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":"”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fcda47-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8fcda48-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Adjustment for Certain Health Care Occupations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/10/dA/tVIII/s8086"},"text":"Pub. L. 112–10, div. A, title VIII, § 8086","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/76"},"text":"125 Stat. 76","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/10/dA/tVIII/s8086"},"text":"“Notwithstanding any other provision of law or regulation, during the current fiscal year and hereafter, the Secretary of Defense may adjust wage rates for civilian employees hired for certain health care occupations as authorized for the Secretary of Veterans Affairs by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7455"},"text":"section 7455 of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
