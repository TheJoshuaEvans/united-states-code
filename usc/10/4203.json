{"tag":"section","attrib":{"id":"idaa64cf29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203"},"text":null,"children":[{"tag":"num","attrib":{"value":"4203"},"text":"§ 4203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major subprograms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa64cf2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Designate Major Subprograms as Subject to Acquisition Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64cf2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa64cf2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of Defense determines that a major defense acquisition program requires the delivery of two or more categories of end items which differ significantly from each other in form and function, the Secretary may designate each such category of end items as a major subprogram for the purposes of acquisition reporting under this subpart.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa64cf2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of Defense determines that a major defense acquisition program requires the delivery of two or more increments or blocks, the Secretary may designate each such increment or block as a major subprogram for the purposes of acquisition reporting under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa67402e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify the congressional defense committees in writing of any proposed designation pursuant to paragraph (1) not less than 30 days before the date such designation takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa67402f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa674030-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary designates a major subprogram of a major defense acquisition program in accordance with subsection (a), Selected Acquisition Reports, unit cost reports, and program baselines under this subpart shall reflect cost, schedule, and performance information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa674031-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the major defense acquisition program as a whole (other than as provided in paragraph (2)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa674032-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each major subprogram of the major defense acquisition program so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa674033-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a major defense acquisition program for which a designation of a major subprogram has been made under subsection (a), unit costs under this subpart shall be submitted in accordance with the definitions in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa674034-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Cover Entire Major Defense Acquisition Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a subprogram of a major defense acquisition program is designated as a major subprogram under subsection (a), all other elements of the major defense acquisition program shall be appropriately organized into one or more subprograms under the major defense acquisition program, each of which subprograms, as so organized, shall be treated as a major subprogram under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa674035-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4351/a"},"text":"section 4351(a) of this title","children":[],"tail":", in the case of a major defense acquisition program for which the Secretary has designated one or more major subprograms under this section for the purposes of this subpart—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa674036-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “program acquisition unit cost” applies at the level of the subprogram and means the total cost for the development and procurement of, and specific military construction for, the major defense acquisition program that is reasonably allocable to each such major subprogram, divided by the relevant number of fully-configured end items to be produced under such major subprogram;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa674037-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “procurement unit cost” applies at the level of the subprogram and means the total of all funds programmed to be available for obligation for procurement for each such major subprogram, divided by the number of fully-configured end items to be procured under such major subprogram;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa674038-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “major contract”, with respect to a designated major subprogram, means each of the six largest prime, associate, or Government furnished equipment contracts under the subprogram that is in excess of $40,000,000 and that is not a firm-fixed price contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa674039-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4203/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “life cycle cost”, with respect to a designated major subprogram, means all costs of development, procurement, military construction, and operations and support, without regard to funding source or management control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa67403a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 811(a)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4520"},"text":"122 Stat. 4520","children":[],"tail":", § 2430a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVIII/s814/a"},"text":"Pub. L. 111–383, div. A, title VIII, § 814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4266"},"text":"124 Stat. 4266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIX/s912"},"text":"Pub. L. 112–81, div. A, title IX, § 912","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1536"},"text":"125 Stat. 1536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s850"},"text":"Pub. L. 114–328, div. A, title VIII, § 850","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2295"},"text":"130 Stat. 2295","children":[],"tail":"; renumbered § 4203 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1846/g"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1846(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4251"},"text":"134 Stat. 4251","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(B)(ii), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2147"},"text":"135 Stat. 2147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa67403b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa67403c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa67403d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/g/2"},"text":"Pub. L. 116–283, § 1846(g)(2)","children":[],"tail":", substituted “this subpart” for “this chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/g"},"text":"Pub. L. 116–283, § 1846(g)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2430a"},"text":"section 2430a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1846/g/1"},"text":"Pub. L. 116–283, § 1846(g)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701"},"text":"Pub. L. 117–81, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(B)(ii), substituted “section 4351(a)” for “section 2432(a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", which directed substitution of “major defense acquisition program requires the delivery of two or more increments or blocks” for “major defense acquisition program to purchase satellites requires the delivery of satellites in two or more increments or blocks” in par. (1)(B), was executed by making the substitution in par. (1)(B) of subsec. (a), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" designated existing provisions as par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), inserted “(other than as provided in paragraph (2))” before semicolon in subpar. (A), and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa67403e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa67403f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
