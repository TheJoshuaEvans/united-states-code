[],"tail":", 573."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “consider, ascertain, adjust, determine” are omitted as covered by the word “settle”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4801"},"text":"section 4801 of this title","children":[],"tail":". 10:1861 (1st proviso) is omitted as unnecessary, since other applicable claims laws are restated in this title. 10:1861 (2d proviso) is omitted as surplusage."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaffd6eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaffd6ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4802"},"text":"section 4802 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “$100,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/417"},"text":"Pub. L. 92–417","children":[],"tail":" substituted “Admiralty claims against the United States” for “Damage by United States vessels, towage and salvage of United States vessels” in section catchline, in text preceding par. (1), struck out requirement that the Secretary of the Army discharge his functions under