{"tag":"section","attrib":{"id":"idaaffd6e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802"},"text":null,"children":[{"tag":"num","attrib":{"value":"7802"},"text":"§ 7802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admiralty claims against the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaffd6e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Army may settle or compromise an admiralty claim against the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaffd6e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a vessel of, or in the service of, the Department of the Army or by other property under the jurisdiction of the Department of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for towage and salvage service, including contract salvage, rendered to a vessel of, or in the service of, the Department of the Army or to other property under the jurisdiction of the Department of the Army; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a maritime tort committed by any agent or employee of the Department of the Army or by property under the jurisdiction of the Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd6e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a claim under subsection (a) is settled or compromised for $500,000 or less, the Secretary of the Army may pay it. If it is settled or compromised for more than $500,000, he shall certify it to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd6e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the amount to be paid is not more than $100,000, the Secretary of the Army may delegate his authority under subsection (a) to any person in the Department of the Army designated by him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaffd6e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/271"},"text":"70A Stat. 271","children":[],"tail":", § 4802; "},{"tag":"ref","attrib":{"href":"/us/pl/89/67"},"text":"Pub. L. 89–67","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-07"},"text":"July 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/212"},"text":"79 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/417/s1/1"},"text":"Pub. L. 92–417, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/654"},"text":"86 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1633"},"text":"Pub. L. 101–189, div. A, title XVI, § 1633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1608"},"text":"103 Stat. 1608","children":[],"tail":"; renumbered § 7802, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaffd6e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaffd6e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaaffd6ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"ta