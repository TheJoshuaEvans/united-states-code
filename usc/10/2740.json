{"tag":"section","attrib":{"id":"ida9cc38ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740"},"text":null,"children":[{"tag":"num","attrib":{"value":"2740"},"text":"§ 2740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property loss: reimbursement of members and civilian employees for full replacement value of household effects when contractor reimbursement not available","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and the Secretaries of the military departments, in paying a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3721"},"text":"section 3721 of title 31","children":[],"tail":" arising from loss or damage to household goods stored or transported at the expense of the Department of Defense, may pay the claim on the basis of full replacement value in any of the following cases in which reimbursement for the full replacement value for the loss or damage is not available directly from a carrier under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2636a"},"text":"section 2636a of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cc38bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cc38bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lost or damaged goods were stored or transported under a contract, tender, or solicitation in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2636a"},"text":"section 2636a of this title","children":[],"tail":" that requires the transportation service provider to settle claims on the basis of full replacement value; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cc38bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss or damage occurred under circumstances that exclude the transportation service provider from liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc38be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cc38bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss or damage occurred while the lost or damaged goods were in the possession of an ocean carrier that was transporting, loading, or unloading the goods under a Department of Defense contract for ocean carriage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cc38c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land-based portions of the transportation were under contracts, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2636a"},"text":"section 2636a of this title","children":[],"tail":", that require the land carriers to settle claims on the basis of full replacement value."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cc38c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cc38c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lost or damaged goods were transported or stored under a contract or solicitation that requires at least one of the transportation service providers or carriers that handled the shipment to settle claims on the basis of full replacement value pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2636a"},"text":"section 2636a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cc38c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lost or damaged goods have been in the custody of more than one independent contractor or transportation service provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cc38c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2740/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim submitted to the delivering transportation service provider or carrier is denied in whole or in part because the loss or damage occurred while the lost or damaged goods were in the custody of a prior transportation service provider or carrier or government entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cc38c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIII/s354/a/1"},"text":"Pub. L. 111–383, div. A, title III, § 354(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4194"},"text":"124 Stat. 4194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cc38c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cc38c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9cc38c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIII/s354/b"},"text":"Pub. L. 111–383, div. A, title III, § 354(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4195"},"text":"124 Stat. 4195","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tIII/s354/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2740"},"text":"Section 2740 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to losses incurred after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
