{"tag":"section","attrib":{"id":"idabb51c22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314"},"text":null,"children":[{"tag":"num","attrib":{"value":"14314"},"text":"§ 14314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army and Air Force commissioned officers: generals ceasing to occupy positions commensurate with grade; State adjutants general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb51c23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb51c24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), within 30 days after a reserve officer of the Army or the Air Force on the reserve active-status list in a general officer grade ceases to occupy a position commensurate with that grade (or commensurate with a higher grade), the Secretary concerned shall transfer or discharge the officer in accordance with whichever of the following the officer elects:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb51c25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer the officer in grade to the Retired Reserve, if the officer is qualified and applies for the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb51c26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transfer the officer in grade to the inactive status list of the Standby Reserve, if the officer is qualified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb51c27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Discharge the officer from the officer’s reserve appointment and, if the officer is qualified and applies therefor, appoint the officer in the reserve grade held by the officer as a reserve officer before the officer’s appointment in a general officer grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb51c28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Discharge the officer from the officer’s reserve appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb51c29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any general officer covered by paragraph (1) who is released from a joint duty assignment or other non-joint active-duty assignment, the Secretary concerned shall complete the transfer or discharge required by paragraph (1) not later than 60 days after the officer’s release.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb51c2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjutants General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a reserve officer who is federally recognized in the Army National Guard or the Air National Guard solely because of the officer’s appointment as adjutant general or assistant adjutant general of a State ceases to occupy that position, the Secretary concerned, not later than 30 days after the date on which the officer ceases to occupy that position, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb51c2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdraw that officer’s Federal recognition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb51c2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require that the officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabb51c2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred in grade to the Retired Reserve, if the officer is qualified and applies for the transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb51c2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged from the officer’s reserve appointment and appointed in the reserve grade held by the officer as a reserve officer immediately before the appointment of that officer as adjutant general or assistant adjutant general, if the officer is qualified and applies for that appointment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabb51c2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be discharged from the officer’s reserve appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb51c30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit for Service in Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is appointed under subsection (a)(1)(C) or (b)(2)(B) shall be credited with an amount of service in the grade in which appointed that is equal to the amount of prior service in an active status in that grade and in any higher grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb51c31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2942"},"text":"108 Stat. 2942","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s544/c"},"text":"Pub. L. 104–201, div. A, title V, § 544(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2523"},"text":"110 Stat. 2523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s512"},"text":"Pub. L. 118–159, div. A, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1875"},"text":"138 Stat. 1875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb51c32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb51c33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb51c34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3375, 8375, and 8381 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/1"},"text":"Pub. L. 103–337, § 1629(a)(1)","children":[],"tail":", (c)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb51c35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s512/1"},"text":"Pub. L. 118–159, § 512(1)","children":[],"tail":", designated introductory provisions as par. (1) and substituted “Except as provided in paragraph (2), within” for “Within”, redesignated former pars. (1) to (4) as subpars. (A) to (D), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s512/2"},"text":"Pub. L. 118–159, § 512(2)","children":[],"tail":", substituted “subsection (a)(1)(C)” for “subsection (a)(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" struck out “of the Air Force” after “reserve officer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb51c36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb51c37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
