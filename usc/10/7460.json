{"tag":"section","attrib":{"id":"idaaf3eef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7460"},"text":null,"children":[{"tag":"num","attrib":{"value":"7460"},"text":"§ 7460.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadets: charges and fees for attendance; limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf3eef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7460/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), no charge or fee for tuition, room, or board for attendance at the Academy may be imposed unless the charge or fee is specifically authorized by a law enacted after ","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf3eef2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7460/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition specified in subsection (a) does not apply with respect to any item or service provided to cadets for which a charge or fee is imposed as of ","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":". The Secretary of Defense shall notify Congress of any change made by the Academy in the amount of a charge or fee authorized under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf3eef3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","childre