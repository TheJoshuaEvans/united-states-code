{"tag":"section","attrib":{"id":"ida8393c95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e"},"text":null,"children":[{"tag":"num","attrib":{"value":"950e"},"text":"§ 950e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8393c96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition of Military Commission for Rehearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each rehearing under this chapter shall take place before a military commission under this chapter composed of members who were not members of the military commission which first heard the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393c97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Rehearing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8393c98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon a rehearing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8393c99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accused may not be tried for any offense of which the accused was found not guilty by the first military commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8393c9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no sentence in excess of or more than the original sentence may be imposed unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8393c9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sentence is based upon a finding of guilty of an offense not considered upon the merits in the original proceedings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8393c9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sentence prescribed for the offense is mandatory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8393c9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon a rehearing, if the sentence approved after the first military commission was in accordance with a pretrial agreement and the accused at the rehearing changes his plea with respect to the charges or specifications upon which the pretrial agreement was based, or otherwise does not comply with pretrial agreement, the sentence as to those charges or specifications may include any punishment not in excess of that lawfully adjudged at the first military commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8393c9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2602"},"text":"123 Stat. 2602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8393c9f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8393ca0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8393ca1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 950e, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2621"},"text":"120 Stat. 2621","children":[],"tail":", related to rehearings, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
