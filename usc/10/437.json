{"tag":"section","attrib":{"id":"ida7bd2ecc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s437"},"text":null,"children":[{"tag":"num","attrib":{"value":"437"},"text":"§ 437.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bd2ecd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s437/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposed Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Copies of regulations proposed to be prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s436"},"text":"section 436 of this title","children":[],"tail":" (including any proposed revision to such regulations) shall be submitted to congressional defense committees and the congressional intelligence committees not less than 30 days before they take effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2ece-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s437/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Current Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that congressional defense committees and the congressional intelligence committees are kept fully and currently informed of actions taken pursuant to this subchapter, including any significant anticipated activity to be authorized pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2ecf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s437/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Intelligence Committees Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “congressional intelligence committees” has the meaning given the term in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2ed0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s504/a/2"},"text":"Pub. L. 102–88, title V, § 504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/440"},"text":"105 Stat. 440","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s811/b/4/A"},"text":"Pub. L. 107–306, title VIII, § 811(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2423"},"text":"116 Stat. 2423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/7"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1596"},"text":"117 Stat. 1596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/d/3"},"text":"Pub. L. 108–375, div. A, title X, § 1084(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2061"},"text":"118 Stat. 2061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1061/5"},"text":"Pub. L. 112–81, div. A, title X, § 1061(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1583"},"text":"125 Stat. 1583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tIX/s921/c"},"text":"Pub. L. 113–66, div. A, title IX, § 921(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/827"},"text":"127 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bd2ed1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bd2ed2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bd2ed3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s921/c/1"},"text":"Pub. L. 113–66, § 921(c)(1)","children":[],"tail":", substituted “congressional defense committees and the congressional intelligence committees” for “the intelligence committees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s921/c/2"},"text":"Pub. L. 113–66, § 921(c)(2)","children":[],"tail":", substituted “The Secretary” for “Consistent with title V of the National Security Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s413"},"text":"50 U.S.C. 413","children":[],"tail":" et seq.), the Secretary” and “congressional defense committees and the congressional intelligence committees” for “the intelligence committees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/s921/c/3"},"text":"Pub. L. 113–66, § 921(c)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" struck out subsec. (c) which related to submission of an annual report on certain authorized commercial activities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" inserted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s415b"},"text":"50 U.S.C. 415b","children":[],"tail":")” after “National Security Act of 1947”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/7/A"},"text":"Pub. L. 108–136, § 1031(a)(7)(A)","children":[],"tail":", struck out at end “The Secretary shall promptly notify the appropriate committees of Congress whenever a corporation, partnership, or other legal entity is established pursuant to this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1031/a/7/B"},"text":"Pub. L. 108–136, § 1031(a)(7)(B)","children":[],"tail":", substituted “report) the following:” for “report)—” in introductory provisions, “A” for “a” in pars. (1) to (3), a period for the semicolon at end of par. (1) and for “; and” at end of par. (2), and added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/4/A/i"},"text":"Pub. L. 107–306, § 811(b)(4)(A)(i)","children":[],"tail":", in introductory provisions, substituted “Not later each year than the date provided in section 507 of the National Security Act of 1947, the Secretary shall submit to the congressional intelligence committees (as defined in section 3 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s401a"},"text":"50 U.S.C. 401a","children":[],"tail":"))” for “Not later than January 15 of each year, the Secretary shall submit to the appropriate committees of Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s811/b/4/A/ii"},"text":"Pub. L. 107–306, § 811(b)(4)(A)(ii)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “In this section, the term ‘intelligence committees’ means the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
