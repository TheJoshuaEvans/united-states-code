{"tag":"section","attrib":{"id":"ida93130f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155"},"text":null,"children":[{"tag":"num","attrib":{"value":"2155"},"text":"§ 2155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint professional military education Phase II program of instruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93130f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prerequisite of Completion of Joint Professional Military Education Phase I Program of Instruction","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93130fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":", an officer of the armed forces may not be accepted for, or assigned to, a program of instruction designated by the Secretary of Defense as joint professional military education Phase II unless the officer has successfully completed a program of instruction designated by the Secretary of Defense as joint professional military education Phase I."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93130fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Joint Chiefs of Staff may grant exceptions to the requirement under paragraph (1). Such an exception may be granted only on a case-by-case basis under exceptional circumstances, as determined by the Chairman. An officer selected to receive such an exception shall have knowledge of joint matters and other aspects of the Phase I curriculum that, to the satisfaction of the Chairman, qualifies the officer to meet the minimum requirements established for entry into Phase II instruction without first completing Phase I instruction. The number of officers selected to attend an offering of the principal course of instruction at the Joint Forces Staff College or a senior level service school designated by the Secretary of Defense as a joint professional military education institution who have not completed Phase I instruction should comprise no more than 10 percent of the total number of officers selected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93130fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Phase II Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that the curriculum for Phase II joint professional military education at any school—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93130fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on developing joint operational expertise and perspectives and honing joint warfighting skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93130fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be structured—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93130ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so as to adequately prepare students to perform effectively in an assignment to a joint, multiservice organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9313100-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so that students progress from a basic knowledge of joint matters learned in Phase I instruction to the level of expertise necessary for successful performance in the joint arena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9313101-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Curriculum Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the subjects specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2151/a"},"text":"section 2151(a) of this title","children":[],"tail":", the curriculum for Phase II joint professional military education shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9313102-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National security strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Theater strategy and campaigning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint planning processes and systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint, interagency, and multinational capabilities and the integration of those capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9313106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Student Ratio; Faculty Ratio","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":", for courses of instruction in a Phase II program of instruction that is offered at senior level service school that has been designated by the Secretary of Defense as a joint professional military education institution—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9313107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of students enrolled in any such course who are officers of the armed force that administers the school may not exceed 60 percent, with the remaining services proportionally represented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2155/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the faculty at the school who are active-duty officers who provide instruction in such courses, the percentage who are officers of the armed force that administers the school may not exceed 60 percent, with the remaining services proportionally represented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9313109-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s532/a/2"},"text":"Pub. L. 108–375, div. A, title V, § 532(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1898"},"text":"118 Stat. 1898","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/13"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(13)","children":[],"tail":", (14), "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2399"},"text":"120 Stat. 2399","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida931310a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida931310b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida931310c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s1071/a/13"},"text":"Pub. L. 109–364, § 1071(a)(13)","children":[],"tail":", substituted “Phase” for “phase” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s1071/a/14"},"text":"Pub. L. 109–364, § 1071(a)(14)","children":[],"tail":", inserted “Phase” after “Education” in heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida931310d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida931310e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on JPME Phase II on Other Than In-Residence Basis","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s552/b"},"text":"Pub. L. 112–81, div. A, title V, § 552(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1412"},"text":"125 Stat. 1412","children":[],"tail":", authorized the Secretary of Defense to carry out a pilot program to assess the feasibility and advisability of offering a program of instruction under this section on an other than in-residence basis and provided that the authority for the program would expire five years after "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
