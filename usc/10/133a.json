{"tag":"section","attrib":{"id":"ida760418e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a"},"text":null,"children":[{"tag":"num","attrib":{"value":"133a"},"text":"§ 133a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Defense for Research and Engineering","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida760418f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an Under Secretary of Defense for Research and Engineering, appointed from civilian life by the President, by and with the advice and consent of the Senate. The Under Secretary shall be appointed from among persons who have an extensive technology, science, or engineering background and experience with managing complex or advanced technological programs. A person may not be appointed as Under Secretary within seven years after relief from active duty as a commissioned officer of a regular component of an armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7604190-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the authority, direction, and control of the Secretary of Defense, the Under Secretary shall perform such duties and exercise such powers as the Secretary may prescribe, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7604191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the chief technology officer of the Department of Defense with the mission of advancing technology and innovation for the armed forces (and the Department);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7604192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing policies on, and supervising, all elements of the Department relating to defense research and engineering, technology development, technology transition, appropriate prototyping activities, experimentation, and developmental testing activities and programs and unifying defense research and engineering efforts and enhancing jointness across the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7604193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the principal advisor to the Secretary on all research, engineering, and technology development activities and programs in the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7604194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing the Secretaries of the military departments and the heads of all other elements of the Department with regard to matters for which the Under Secretary has responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7604195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting developmental prototyping, designing and executing experiments of prototypes in the field to demonstrate operational relevance to address joint force capability gaps, and encouraging and supporting the rapid transition of technology from the research and development phase into operational use within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7604196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in Department of Defense.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7604197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in matters of responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With regard to all matters for which the Under Secretary has responsibility by the direction of the Secretary of Defense or by law, the Under Secretary takes precedence in the Department of Defense after the Secretary and the Deputy Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7604198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in other matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With regard to all matters other than the matters for which the Under Secretary has responsibility by the direction of the Secretary or by law, the Under Secretary takes precedence in the Department of Defense after the Secretary, the Deputy Secretary, and the Secretaries of the military departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7604199-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s901/a/1"},"text":"Pub. L. 114–328, div. A, title IX, § 901(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2339"},"text":"130 Stat. 2339","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s910/c/2"},"text":"Pub. L. 115–91, div. A, title IX, § 910(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1518"},"text":"131 Stat. 1518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/2"},"text":"Pub. L. 116–92, div. A, title IX, § 902(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1542"},"text":"133 Stat. 1542","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s901/a/1"},"text":"Pub. L. 118–31, div. A, title IX, § 901(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/354"},"text":"137 Stat. 354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIX/s902"},"text":"Pub. L. 119–60, div. A, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1008"},"text":"139 Stat. 1008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida760419a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida760419b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida760419c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 133a, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s902/a/1"},"text":"Pub. L. 99–500, § 101(c) [title X, § 902(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–131, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tX/s902/a/1"},"text":"Pub. L. 99–591, § 101(c) [title X, § 902(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–131; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIX"},"text":"Pub. L. 99–661, div. A, title IX","children":[],"tail":", formerly title IV, § 902(a)(1), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"