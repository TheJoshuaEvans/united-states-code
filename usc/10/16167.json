{"tag":"section","attrib":{"id":"idabc10339-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16167"},"text":null,"children":[{"tag":"num","attrib":{"value":"16167"},"text":"§ 16167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc1033a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to provide educational assistance under this chapter shall terminate on the date that is four years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2016.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc1033b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Provision of Assistance Pending Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter, during the period beginning on the date of the enactment of the National Defense Authorization Act for Fiscal Year 2016 and ending on the date that is four years after the date of the enactment of that Act, educational assistance may be provided under this chapter only to a member otherwise eligible for educational assistance under this chapter who received educational assistance under this chapter for a course of study at an educational institution for the enrollment period at the educational institution that immediately preceded the date of the enactment of that Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc1033c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for Post-","children":[],"tail":"9/11"},{"tag":"inline","attrib":{},"text":" Educational Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member who loses eligibility for benefits under this chapter pursuant to subsection (b) shall be allowed to elect (in such form and manner as the Secretary of Veterans Affairs may prescribe) to have such service previously credited toward this chapter credited towards establishing eligibility for educational assistance under chapter 33 of title 38, notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16163/e"},"text":"section 16163(e) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s3322/h/1"},"text":"section 3322(h)(1) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc1033d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tV/s555/a"},"text":"Pub. L. 114–92, div. A, title V, § 555(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/824"},"text":"129 Stat. 824","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/48/tI/s106/a"},"text":"Pub. L. 115–48, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-16"},"text":"Aug. 16, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/977"},"text":"131 Stat. 977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc1033e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc1033f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabc10340-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2016, referred to in subsecs. (a) and (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc10341-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/48"},"text":"Pub. L. 115–48","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
