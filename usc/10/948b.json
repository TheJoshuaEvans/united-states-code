{"tag":"section","attrib":{"id":"ida8348156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b"},"text":null,"children":[{"tag":"num","attrib":{"value":"948b"},"text":"§ 948b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military commissions generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8348157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter establishes procedures governing the use of military commissions to try alien unprivileged enemy belligerents for violations of the law of war and other offenses triable by military commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Military Commissions Under This Chapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President is authorized to establish military commissions under this chapter for offenses triable by military commission as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures for military commissions set forth in this chapter are based upon the procedures for trial by general courts-martial under chapter 47 of this title (the Uniform Code of Military Justice). Chapter 47 of this title does not, by its terms, apply to trial by military commission except as specifically provided therein or in this chapter, and many of the provisions of chapter 47 of this title are by their terms inapplicable to military commissions. The judicial construction and application of chapter 47 of this title, while instructive, is therefore not of its own force binding on military commissions established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida834815a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida834815b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following provisions of this title shall not apply to trial by military commission under this chapter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida834815c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 810 (article 10 of the Uniform Code of Military Justice), relating to speedy trial, including any rule of courts-martial relating to speedy trial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834815d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 831(a), (b), and (d) (articles 31(a), (b), and (d) of the Uniform Code of Military Justice), relating to compulsory self-incrimination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida834815e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 832 (article 32 of the Uniform Code of Military Justice), relating to preliminary hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida834815f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other provisions of chapter 47 of this title shall apply to trial by military commission under this chapter only to the extent provided by the terms of such provisions or by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8348160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Geneva Conventions Not Establishing Private Right of Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No alien unprivileged enemy belligerent subject to trial by military commission under this chapter may invoke the Geneva Conventions as a basis for a private right of action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8348161-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2575"},"text":"123 Stat. 2575","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1702/c/3/E"},"text":"Pub. L. 113–66, div. A, title XVII, § 1702(c)(3)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/958"},"text":"127 Stat. 958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8348162-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8348163-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8348164-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 948b, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2602"},"text":"120 Stat. 2602","children":[],"tail":", related to military commissions generally, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8348165-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “preliminary hearing” for “pretrial investigation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8348166-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8348167-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" effective on the later of "},{"tag":"date","attrib":{"date":"2014-12-26"},"text":"Dec. 26, 2014","children":[],"tail":", or the date of the enactment of the Carl Levin and Howard P. “Buck” McKeon National Defense Authorization Act for Fiscal Year 2015 ("},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":") and applicable with respect to preliminary hearings conducted on or after that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s1702/d/1"},"text":"section 1702(d)(1) of Pub. L. 113–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida8348168-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"ida8348169-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 13425. Trial of Alien Unlawful Enemy Combatants by Military Commission","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13425, ","children":[{"tag":"date","attrib":{"date":"2007-02-14"},"text":"Feb. 14, 2007","children":[],"tail":", 72 F.R. 7737, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including the Military Commissions Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366"},"text":"Public Law 109–366","children":[],"tail":"), the Authorization for Use of Military Force ("},{"tag":"ref","attrib":{"href":"/us/pl/107/40"},"text":"Public Law 107–40","children":[],"tail":"), and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s948b/b"},"text":"section 948b(b) of title 10","children":[],"tail":", United States Code, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"Establishment of Military Commissions","children":[],"tail":". There are hereby established military commissions to try alien unlawful enemy combatants for offenses triable by military commission as provided in chapter 47A of title 10."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. "},{"tag":"i","attrib":{},"text":"Definitions","children":[],"tail":". As used in this order:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) “unlawful enemy combatant” has the meaning provided for that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s948a/1"},"text":"section 948a(1) of title 10","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) “alien” means a person who is not a citizen of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. "},{"tag":"i","attrib":{},"text":"Supersedure","children":[],"tail":". This order supersedes any provision of the President’s Military Order of "},{"tag":"date","attrib":{"date":"2001-11-13"},"text":"November 13, 2001","children":[],"tail":" (66 "},{"tag":"i","attrib":{},"text":"Fed. Reg","children":[],"tail":". 57,833), that relates to trial by military commission, specifically including:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) section 4 of the Military Order; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) any requirement in section 2 of the Military Order, as it relates to trial by military commission, for a determination of:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) reason to believe specified matters; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) the interest of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. "},{"tag":"i","attrib":{},"text":"General Provisions","children":[],"tail":". (a) This order shall be implemented in accordance with applicable law and subject to the availability of appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) The heads of executive departments and agencies shall provide such information and assistance to the Secretary of Defense as may be necessary to implement this order and chapter 47A of title 10.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) This order is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by any party against the United States, its departments, agencies, entities, officers, employees, or agents, or any other person.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George W. Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
