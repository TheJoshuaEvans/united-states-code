{"tag":"section","attrib":{"id":"idaa96db83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815"},"text":null,"children":[{"tag":"num","attrib":{"value":"4815"},"text":"§ 4815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfunded priorities of the national technology and industrial base: annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa96db84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 10 days after the date on which the budget of the President for a fiscal year is submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Under Secretary of Defense for Acquisition and Sustainment shall submit to the Secretary of Defense, the Chairman of the Joint Chiefs of Staff, and the congressional defense committees a report on the unfunded priorities to address gaps or vulnerabilities in the national technology and industrial base."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa96db85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa96db86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subsection (a) shall specify, for each unfunded priority covered by such report, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa96db87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary description of such priority, including the objectives to be achieved if such priority is funded (whether in whole or in part).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa96db88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional amount of funds recommended in connection with the objectives under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa96db89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Account information with respect to such priority, including the following (as applicable):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaa96db8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Line Item Number (LIN) for applicable procurement accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa96db8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program Element (PE) number for applicable research, development, test, and evaluation accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaa96db8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sub-activity group (SAG) for applicable operation and maintenance accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96db8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization of priorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report shall present the unfunded priorities covered by such report in order of urgency of priority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa96db8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfunded Priority Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “unfunded priority”, in the case of a fiscal year, means a program, activity, or mission requirement of the national technology and industrial base that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa96db8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not funded in the budget of the President for the fiscal year as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96db90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to address gaps or vulnerabilities in the national technology and industrial base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa96db91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" would have been recommended for funding through the budget referred to in paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa96db92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional resources had been available for the budget to fund the program, activity, or mission requirement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa96db93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4815/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program, activity, or mission requirement had emerged before the budget was formulated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa96db94-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s846/c/1"},"text":"Pub. L. 116–92, div. A, title VIII, § 846(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1504"},"text":"133 Stat. 1504","children":[],"tail":", § 2504a; renumbered § 4815, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1867/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1867(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4281"},"text":"134 Stat. 4281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa96db95-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa96db96-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa96db97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2504a"},"text":"section 2504a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa96db98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa96db99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
