{"tag":"section","attrib":{"id":"ida7f41cf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b"},"text":null,"children":[{"tag":"num","attrib":{"value":"638b"},"text":"§ 638b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary retirement incentive","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f41cfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incentive for Voluntary Retirement for Certain Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may authorize the Secretary of a military department to provide a voluntary retirement incentive payment in accordance with this section to an officer of the armed forces under that Secretary’s jurisdiction who is specified in subsection (c) as being eligible for such a payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41cfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f41cfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any authority provided the Secretary of a military department under this section shall expire as specified by the Secretary of Defense, but not later than ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f41cfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of officers who may be provided a voluntary retirement incentive payment under this section may not exceed 675 officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41cfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f41cff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), an officer of the armed forces is eligible for a voluntary retirement incentive payment under this section if the officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7f41d00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served on active duty for more than 20 years, but not more than 29 years, on the approved date of retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the minimum length of commissioned service requirement for voluntary retirement as a commissioned officer in accordance with section 7311, 8323, or 9311 of this title, as applicable to that officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the approved date of retirement, has 12 months or more remaining on active-duty service before reaching the maximum retirement years of active service for the member’s grade as specified in section 633 or 634 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the approved date of retirement, has 12 months or more remaining on active-duty service before reaching the maximum retirement age under any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets any additional requirements for such eligibility as is specified by the Secretary concerned, including any requirement relating to years of service, skill rating, military specialty or competitive category, grade, any remaining period of obligated service, or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f41d05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following officers are not eligible for a voluntary retirement incentive payment under this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7f41d06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer being evaluated for disability under chapter 61 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer projected to be retired under section 1201 or 1204 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer projected to be discharged with disability severance pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1212"},"text":"section 1212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member transferred to the temporary disability retired list under section 1202 or 1205 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer subject to pending disciplinary action or subject to administrative separation or mandatory discharge under any other provision of law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41d0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the voluntary retirement incentive payment paid an officer under this section shall be an amount determined by the Secretary concerned, but not to exceed an amount equal to 12 times the amount of the officer’s monthly basic pay at the time of the officer’s retirement. The amount may be paid in a lump sum at the time of retirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f41d0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment for Members Who Return to Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f41d0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), a member of the armed forces who, after having received all or part of a voluntary retirement incentive under this section, returns to active duty shall have deducted from each payment of basic pay, in such schedule of monthly installments as the Secretary concerned shall specify, until the total amount deducted from such basic pay equals the total amount of voluntary retirement incentive received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f41d0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members who are involuntarily recalled to active duty or full-time National Guard duty under any provision of law shall not be subject to this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f41d0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s638b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive, in whole or in part, repayment required under paragraph (1) if the Secretary determines that recovery would be against equity and good conscience or would be contrary to the best interest of the United States. The authority in this paragraph may be delegated only to the Under Secretary of Defense for Personnel and Readiness and the Principal Deputy Under Secretary of Defense of Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f41d10-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s504/a/1"},"text":"Pub. L. 112–81, div. A, title V, § 504(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1389"},"text":"125 Stat. 1389","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f41d11-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f41d12-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f41d13-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7311, 8323, or 9311” for “section 3911, 6323, or 8911”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f41d14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f41d15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
