{"tag":"section","attrib":{"id":"idaa8639f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4653"},"text":null,"children":[{"tag":"num","attrib":{"value":"4653"},"text":"§ 4653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds to relieve economic dislocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8639f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to help avoid the uneconomic use of Department of Defense funds in the procurement of goods and services, the Congress finds that it is necessary to prohibit the use of such funds for certain purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8639f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No funds appropriated to or for the use of the Department of Defense may be used to pay, in connection with any contract awarded by the Department of Defense, a price differential for the purpose of relieving economic dislocations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8639f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX/s913/a/1"},"text":"Pub. L. 97–86, title IX, § 913(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1123"},"text":"95 Stat. 1123","children":[],"tail":", § 2392; renumbered § 4653, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4277"},"text":"134 Stat. 4277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa8639fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa8639fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa8639fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4653 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7653"},"text":"section 7653 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa8639fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2392"},"text":"section 2392 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa8639fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa8639ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"headi