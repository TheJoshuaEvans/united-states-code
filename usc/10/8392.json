{"tag":"section","attrib":{"id":"idab238ad7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8392"},"text":null,"children":[{"tag":"num","attrib":{"value":"8392"},"text":"§ 8392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of effects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab238ad8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If money or other personal property of a deceased member of the naval service is in the custody of the Department of the Navy, the Secretary of the Navy shall keep it in safe custody and make a diligent effort to determine and locate the heirs or next of kin of the deceased member. Property remaining unclaimed two years after the death of the member shall be sold, and the proceeds, together with any of his money held in custody, shall be covered into the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238ad9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within five years after the date the money and proceeds are covered into the Treasury, any claim that is presented therefor supported by competent proof shall be certified to Congress for consideration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab238ada-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab238adb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/419"},"text":"70A Stat. 419","children":[],"tail":", § 6522; renumbered § 8392, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/18"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab238adc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab238add-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab238ade-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6522","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s942"},"text":"34 U.S.C. 942","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-03-29/ch31"},"text":"Mar. 29, 1918, ch. 31","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/499"},"text":"40 Stat. 499","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the word “shall” is substituted for the words “authorized and directed”; the word “effort” is substituted for the word “inquiry”; the words “determine and locate” are substituted for the words “ascertain the whereabouts”; the words “personal property” are substituted for the words “all articles of value, papers, keepsakes, and other similar effects”. The phrase “to the credit of the Navy pension fund” is omitted since this fund was abolished by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-26/ch756/s9"},"text":"§ 9 of the Act of June 26, 1934, ch. 756","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1229"},"text":"48 Stat. 1229","children":[],"tail":". The application of this section is confined to the money and other personal property of the deceased member in the custody of the Department of the Navy to make it clear that disposition is made only of property held by the Department of the Navy and not of property which may be under other custody, over which the Department of the Navy would have no control."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the word “covered” is substituted for the word “deposited”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab238adf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab238ae0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 8392 to 8396 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1629/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1629(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2963"},"text":"108 Stat. 2963","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8392, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/178/C"},"text":"Pub. L. 85–861, § 1(178)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1531"},"text":"72 Stat. 1531","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":", related to appointment of adjutant general or assistant adjutant general in reserve commissioned grade in which Federal recognition in Air National Guard was extended. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12215/b"},"text":"section 12215(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8393, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/178/C"},"text":"Pub. L. 85–861, § 1(178)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1531"},"text":"72 Stat. 1531","children":[],"tail":", provided that sea or foreign service not to be required for promotion of reserve commissioned officers in reserve grades."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8394, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/521"},"text":"70A Stat. 521","children":[],"tail":", related to acceptance of promotion by officers of Air National Guard of United States or Air Force Reserve. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14309"},"text":"section 14309 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8395, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/521"},"text":"70A Stat. 521","children":