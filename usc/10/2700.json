{"tag":"section","attrib":{"id":"ida9bb9707-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700"},"text":null,"children":[{"tag":"num","attrib":{"value":"2700"},"text":"§ 2700.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb9708-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “CERCLA” means the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb9709-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “environment”, “facility”, “hazardous substance”, “person”, “pollutant or contaminant”, “release”, “removal”, “response”, “disposal”, and “hazardous waste” have the meanings given those terms in section 101 of CERCLA (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb970a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb970b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “National Guard facility” includes land used for training the National Guard pursuant to chapter 5 of title 32 with funds provided by the Secretary of Defense or the Secretary of a military department, without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9bb970c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of the facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9bb970d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2700/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the facility is under the jurisdiction of the Department of Defense or a military department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9bb970e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s211/a/1/B"},"text":"Pub. L. 99–499, title II, § 211(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1725"},"text":"100 Stat. 1725","children":[],"tail":", § 2707; renumbered § 2700 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIII/s313/a/1"},"text":"Pub. L. 107–314, div. A, title III, § 313(a)(1)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2507"},"text":"116 Stat. 2507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/46/A"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(46)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4371"},"text":"124 Stat. 4371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s316/b"},"text":"Pub. L. 116–92, div. A, title III, § 316(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1304"},"text":"133 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s314/b"},"text":"Pub. L. 116–283, div. A, title III, § 314(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3514"},"text":"134 Stat. 3514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s313/a"},"text":"Pub. L. 117–263, div. A, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2502"},"text":"136 Stat. 2502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIII/s312/a"},"text":"Pub. L. 118–31, div. A, title III, § 312(a)","children":[],"tail":", title XVIII, § 1801(a)(22), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/215"},"text":"137 Stat. 215","children":[],"tail":", 684.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9bb970f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9bb9710-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9bb9711-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Comprehensive Environmental Response, Compensation, and Liability Act of 1980, referred to in par. (1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", as amended, which is classified principally to chapter 103 (§ 9601 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9bb9712-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1801/a/22"},"text":"Pub. L. 118–31, § 1801(a)(22)","children":[],"tail":", substituted “The terms” for “The term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s312/a"},"text":"Pub. L. 118–31, § 312(a)","children":[],"tail":", struck out “State-owned” before “National Guard facility” and “owned and operated by a State when such land is” before “used for training” and substituted “without regard to—” and subpars. (A) and (B) for “even though such land is not under the jurisdiction of the Department of Defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s314/b"},"text":"Pub. L. 116–283, § 314(b)","children":[],"tail":", which directed amendment of par. (1) by substituting “The term” for “(A) The terms” and striking subpar. (B), was executed by making the amendment in par. (2) to reflect the probable intent of Congress. Prior to amendment, subpar. (B) of par. (2) read as follows: “The term ‘facility’ includes real property that is owned by, leased to, or otherwise possessed by the United States at locations at which military activities are conducted under this title or title 32 (including real property owned or leased by the Federal Government that is licensed to and operated by a State for training for the National Guard).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" inserted “ ‘pollutant or contaminant’,” after “ ‘person’,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s313/c/1"},"text":"Pub. L. 107–314, § 313(c)(1)","children":[],"tail":", added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s313/a/1"},"text":"Pub. L. 107–314, § 313(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2707"},"text":"section 2707 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9bde003-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"ida9bde004-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIII/s316/d"},"text":"Pub. L. 116–92, div. A, title III, § 316(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1304"},"text":"133 Stat. 1304","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tIII/s316/d"},"text":"“Nothing in this section [amending this section and sections 2701 and 2707 of this title], or the amendments made by this section, shall affect any requirement or authority under the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
