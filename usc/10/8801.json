, ch. 255","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/35/768"},"text":"35 Stat. 768","children":[],"tail":" (1st proviso); "},{"tag":"html:a","attrib":{"href":"/us/act/1937-04-14/ch78"},"text":"Apr. 14, 1937, ch. 78","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/63"},"text":"50 Stat. 63","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-06-10/ch196"},"text":"June 10, 1939, ch. 196","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/814"},"text":"53 Stat. 814","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-01-23/ch15"},"text":"Jan. 23, 1942, ch. 15","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/13"},"text":"56 Stat. 13","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1943-04-09/ch39"},"text":"Apr. 9, 1943, ch. 39","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/57/60"},"text":"57 Stat. 60","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-08-08/ch390/s2"},"text":"Aug. 8, 1953, ch. 390, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/499"},"text":"67 Stat. 499","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7601(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s533a"},"text":"34 U.S.C. 533a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-08-08/ch390/s1"},"text":"Aug. 8, 1953, ch. 390, § 1","children":[],"tail":" (as applicable to Secretary of the Navy), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/499"},"text":"67 Stat. 499","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “members of the naval service” are substituted for the words “officers and enlisted men of the Navy, Marine Corps”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the word “outside” is substituted for the words “beyond the continental limitations”. The words “or in Alaska” are omitted, since, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/1"},"text":"section 101(1) of this title","children":[],"tail":", the words, “United States” are defined to include only the States and the District of Columbia. The word “continental”, after the words “within the”, is omitted for the same reason. The last sentence is substituted for "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s533a"},"text":"34 U.S.C. 533a","children":[],"tail":" (proviso)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab4e927b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab4e927c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7601"},"text":"section 7601 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1301/c/3/B"},"text":"Pub. L. 99–145, § 1301(c)(3)(B)","children":[],"tail":", inserted “the” before “naval service” and “and widowers” after “widows” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/s1301/c/3/A"},"text":"Pub. L. 99–145, § 1301(c)(3)(A)","children":[],"tail":", inserted “and widowers” after “widows”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab4e927d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab4e927e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idab4e927f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
