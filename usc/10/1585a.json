{"tag":"section","attrib":{"id":"ida8f7f8c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1585a"},"text":"§ 1585a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special agents of the Defense Criminal Investigative Service: authority to execute warrants and make arrests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8f7f8c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may authorize any DCIS special agent described in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8f7f8c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to execute and serve any warrant or other process issued under the authority of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8f7f8c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to make arrests without a warrant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8f7f8ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any offense against the United States committed in the presence of that agent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8f7f8cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any felony cognizable under the laws of the United States if the agent has probable cause to believe that the person to be arrested has committed or is committing the felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f8cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agents To Have Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) applies to any DCIS special agent whose duties include conducting, supervising, or coordinating investigations of criminal activity in programs and operations of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f8cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines on Exercise of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority provided under subsection (a) shall be exercised in accordance with guidelines prescribed by the Inspector General of the Department of Defense and approved by the Attorney General and any other applicable guidelines prescribed by the Secretary of Defense or the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8f7f8ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1585a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DCIS Special Agent Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “DCIS special agent” means an employee of the Department of Defense who is a special agent of the Defense Criminal Investigative Service (or any successor to that service).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8f7f8cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1071/a"},"text":"Pub. L. 105–85, div. A, title X, § 1071(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1897"},"text":"111 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
