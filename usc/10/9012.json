{"tag":"section","attrib":{"id":"idab580817-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9012"},"text":null,"children":[{"tag":"num","attrib":{"value":"9012"},"text":"§ 9012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of the Air Force: seal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Air Force shall have a seal for the Department of the Air Force. The design of the seal must be approved by the President. Judicial notice shall be taken of the seal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab580818-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/488"},"text":"70A Stat. 488","children":[],"tail":", § 8011; renumbered § 8012, "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s521/a/1"},"text":"Pub. L. 99–433, title V, § 521(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1055"},"text":"100 Stat. 1055","children":[],"tail":"; renumbered § 9012, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/c"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab580819-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab58081a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab58081b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8011","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:626(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-26/ch343/s207/g"},"text":"July 26, 1947, ch. 343, § 207(g)","children":[],"tail":", 61 Stat 503."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “of office” are omitted as surplusage. The words “a design” are substituted for the words “such device”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab58081c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab58081d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8012"},"text":"section 8012 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8011"},"text":"section 8011 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab58081e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab58081f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idab580820-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idab580821-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 9902. Seal for the Department of the Air Force","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 9902, ","children":[{"tag":"date","attrib":{"date":"1947-11-01"},"text":"Nov. 1, 1947","children":[],"tail":", 12 F.R. 7153, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"WHEREAS section 207(g) of the National Security Act of 1947, approved ","children":[{"tag":"date","attrib":{"date":"1947-07-26"},"text":"July 26, 1947","children":[],"tail":" (Public Law 253, 80th Congress 1st Session) provides, in part, that the Secretary of the Air Force shall cause a seal of office to be made for the Department of the Air Force of such device as the President shall approve; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"WHEREAS the Secretary of the Air Force has caused to be made and has recommended that I approve a seal the design of which accompanies and is hereby made a part of this order, and which is described in heraldic terms as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"SHIELD: Per fess nebuly abased azure and argent, in chief a thunderbolt or inflamed proper.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"CREST: On a wreath argent and azure an American bald eagle, wings displayed and partially elevated proper in front of a cloud argent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Encircling the shield and crest an arc of thirteen stars and below the shield the inscription “MCMXLVII”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"On a band encircling the whole the inscriptions “Department of the Air Force” and “United States of America.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"When illustrating the seal in color the background shall be ultramarine blue, the shield a light blue and white, and the thunderbolt in gold with flames in natural color. The twists of the wreath shall be alternated white and blue, and the eagle shall be in natural color in front of a white cloud. The thirteen stars shall be white, and the Roman numerals shall be gold. The encircling band shall be white edged in gold with black letters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"AND WHEREAS it appears that such seal is of suitable design and is appropriate for establishment as the official seal of the Department of the Air Force:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"NOW, THEREFORE, by virtue of and pursuant to the authority vested in me by the said section 207(g) of the National Security Act of 1947, I hereby approve such seal as the official seal of the Department of the Air Force.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Harry S. Truman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
