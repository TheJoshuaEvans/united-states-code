{"tag":"section","attrib":{"id":"ida76e993f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151"},"text":null,"children":[{"tag":"num","attrib":{"value":"151"},"text":"§ 151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Chiefs of Staff: composition; functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida76e9940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are in the Department of Defense the Joint Chiefs of Staff, headed by the Chairman of the Joint Chiefs of Staff. The Joint Chiefs of Staff consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida76e9941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Staff of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the National Guard Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76e9949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function as Military Advisers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida76e994a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Joint Chiefs of Staff is the principal military adviser to the President, the National Security Council, the Homeland Security Council, and the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e994b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The other members of the Joint Chiefs of Staff are military advisers to the President, the National Security Council, the Homeland Security Council, and the Secretary of Defense as specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76e994c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation by Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida76e994d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out his functions, duties, and responsibilities, the Chairman shall, as necessary, consult with and seek the advice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida76e994e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other members of the Joint Chiefs of Staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida76e994f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commanders of the unified and specified combatant commands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9950-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (d), in presenting advice with respect to any matter to the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense, the Chairman shall, as he considers appropriate, inform the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense, as the case may be, of the range of military advice and opinion with respect to that matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76e9951-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice and Opinions of Members Other Than Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida76e9952-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After first informing the Secretary of Defense and the Chairman, the members of the Joint Chiefs of Staff, individually or collectively, in their capacity as military advisors, may provide advice to the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense on a particular matter on the judgment of the military member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9953-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Joint Chiefs of Staff (other than the Chairman) may submit to the Chairman advice or an opinion in disagreement with, or advice or an opinion in addition to, the advice presented by the Chairman to the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense. If a member submits such advice or opinion, the Chairman shall present the advice or opinion of such member at the same time he presents his own advice to the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9954-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman shall establish procedures to ensure that the presentation of his own advice to the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense is not unduly delayed by reason of the submission of the individual advice or opinion of another member of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"ida76e9955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"[(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s921/a/2/C"},"text":"Pub. L. 114–328, div. A, title IX, § 921(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2351"},"text":"130 Stat. 2351","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76e9956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After first informing the Secretary of Defense, a member of the Joint Chiefs of Staff may make such recommendations to Congress relating to the Department of Defense as he considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76e9957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings of JCS","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida76e9958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman shall convene regular meetings of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the authority, direction, and control of the President and the Secretary of Defense, the Chairman shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida76e995a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preside over the Joint Chiefs of Staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida76e995b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide agenda for the meetings of the Joint Chiefs of Staff (including, as the Chairman considers appropriate, any subject for the agenda recommended by any other member of the Joint Chiefs of Staff);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida76e995c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Joint Chiefs of Staff in carrying on their business as promptly as practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida76e995d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine when issues under consideration by the Joint Chiefs of Staff shall be decided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida76e995e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal of Members of Joint Chiefs of Staff","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida76e995f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the President removes a member of the Joint Chiefs of Staff from office or transfers a member of the Joint Chiefs of Staff to another position or location before the end of the term of the member as specified in statute, the President shall, not later than five days after the removal or transfer takes effect, submit to Congress, including the congressional defense committees, notice that the member is being removed or transferred and a statement of the reason for the removal or transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida76e9960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s151/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection prohibits a personnel action authorized by another provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida76e9961-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s201"},"text":"Pub. L. 99–433, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1005"},"text":"100 Stat. 1005","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIX/s911/a"},"text":"Pub. L. 102–484, div. A, title IX, § 911(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2473"},"text":"106 Stat. 2473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIX/s908/a"},"text":"Pub. L. 109–163, div. A, title IX, § 908(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3403"},"text":"119 Stat. 3403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s512/a"},"text":"Pub. L. 112–81, div. A, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1393"},"text":"125 Stat. 1393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s921/a"},"text":"Pub. L. 114–328, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2351"},"text":"130 Stat. 2351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s953/c"},"text":"Pub. L. 116–92, div. A, title IX, § 953(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1564"},"text":"133 Stat. 1564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIX/s911/a"},"text":"Pub. L. 119–60, div. A, title IX, § 911(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1015"},"text":"139 Stat. 1015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida76e9962-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida76e9963-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida76e9964-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s921/a/2/A"},"text":"Pub. L. 114–328, § 921(a)(2)(A)","children":[],"tail":", substituted “subsection (d)” for “subsections (d) and (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s921/a/1"},"text":"Pub. L. 114–328, § 921(a)(1)","children":[],"tail":", substituted “as necessary” for “as he considers appropriate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s921/a/2/B"},"text":"Pub. L. 114–328, § 921(a)(2)(B)","children":[],"tail":", added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s921/a/2/C"},"text":"Pub. L. 114–328, § 921(a)(2)(C)","children":[],"tail":", struck out subsec. (e) which required members of the Joint Chiefs of Staff to provide advice on request to the President, the National Security Council, the Homeland Security Council, or the Secretary of Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (b), (c)(2), (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" inserted “the Homeland Security Council,” after “the National Security Council,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" added par. (2) and redesignated former pars. (2) to (5) as (3) to (6), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida76e9965-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida76e9966-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s953/c"},"text":"Pub. L. 116–92, div. A, title IX, § 953(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1564"},"text":"133 Stat. 1564","children":[],"tail":", provided that the amendment made by section 953(c) is effective on the date that is one year after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
