{"tag":"section","attrib":{"id":"idaa64cee4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175"},"text":null,"children":[{"tag":"num","attrib":{"value":"4175"},"text":"§ 4175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of test and evaluation installations by commercial entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa64cee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into contracts with commercial entities that desire to conduct commercial test and evaluation activities at a Major Range and Test Facility Installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64cee6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination or Limitation of Contract Under Certain Circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract entered into under subsection (a) shall contain a provision that the Secretary of Defense may terminate, prohibit, or suspend immediately any commercial test or evaluation activity to be conducted at the Major Range and Test Facility Installation under the contract if the Secretary of Defense certifies in writing that the test or evaluation activity is or would be detrimental—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64cee7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the public health and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cee8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to property (either public or private); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64cee9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any national security interest or foreign policy interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64ceea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Price","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract entered into under subsection (a) shall include a provision that requires a commercial entity using a Major Range and Test Facility Installation under the contract to reimburse the Department of Defense for all direct costs to the United States that are associated with the test and evaluation activities conducted by the commercial entity under the contract. In addition, the contract may include a provision that requires the commercial entity to reimburse the Department of Defense for such indirect costs related to the use of the installation as the Secretary of Defense considers to be appropriate. The Secretary may delegate to the commander of the Major Range and Test Facility Installation the authority to determine the appropriateness of the amount of indirect costs included in such a contract provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64ceeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Funds Collected From Commercial Users","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected under subsection (c) from a commercial entity conducting test and evaluation activities at a Major Range and Test Facility Installation shall be credited to the appropriation accounts under which the costs associated with the test and evaluation activities of the commercial entity were incurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64ceec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa64ceed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa64ceee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Major Range and Test Facility Installation” means a test and evaluation installation under the jurisdiction of the Department of Defense and designated as a Major Range and Test Facility Installation by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa64ceef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “direct costs” includes the cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa64cef0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor, material, facilities, utilities, equipment, supplies, and any other resources damaged or consumed during test or evaluation activities or maintained for a particular commercial entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa64cef1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4175/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction specifically performed for a commercial entity to conduct test and evaluation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa64cef2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s846/a"},"text":"Pub. L. 103–160, div. A, title VIII, § 846(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1722"},"text":"107 Stat. 1722","children":[],"tail":", § 2681; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVIII/s842"},"text":"Pub. L. 105–85, div. A, title VIII, § 842","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1844"},"text":"111 Stat. 1844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tVIII/s820"},"text":"Pub. L. 105–261, div. A, title VIII, § 820","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2090"},"text":"112 Stat. 2090","children":[],"tail":"; renumbered § 4175 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", §§ 1844(b)(1), 1845(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4245"},"text":"134 Stat. 4245","children":[],"tail":", 4247; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/5/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(5)(B)","children":[],"tail":", (6)(B), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2154"},"text":"135 Stat. 2154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa64cef3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa64cef4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa64cef5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1845/b"},"text":"Pub. L. 116–283, § 1845(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/6/B"},"text":"Pub. L. 117–81, § 1701(u)(6)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2681"},"text":"section 2681 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1844/b/1"},"text":"Pub. L. 116–283, § 1844(b)(1)","children":[],"tail":", which directed the renumbering of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2681"},"text":"section 2681 of this title","children":[],"tail":" as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4144"},"text":"section 4144 of this title","children":[],"tail":" instead of this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/5/B"},"text":"Pub. L. 117–81, § 1701(u)(5)(B)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s820/a"},"text":"Pub. L. 105–261, § 820(a)","children":[],"tail":", struck out heading and text of subsec. (g). Text read as follows: “The authority provided to the Secretary of Defense by subsection (a) shall terminate on "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s820/b"},"text":"Pub. L. 105–261, § 820(b)","children":[],"tail":", struck out heading and text of subsec. (h). Text read as follows: “Not later than "},{"tag":"date","attrib":{"date":"1998-03-01"},"text":"March 1, 1998","children":[],"tail":", the Secretary of Defense shall submit to the Committee on Armed Services of the Senate and the Committee on National Security of the House of Representatives a report identifying existing and proposed procedures to ensure that the use of Major Range and Test Facility Installations by commercial entities does not compete with private sector test and evaluation services.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s842/a"},"text":"Pub. L. 105–85, § 842(a)","children":[],"tail":", substituted “2002” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s842/b"},"text":"Pub. L. 105–85, § 842(b)","children":[],"tail":", amended subsec. (h) generally. Prior to amendment, subsec. (h) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(h) ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—Not later than "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", the Secretary of Defense shall submit to Congress a report describing the number and purposes of contracts entered into under subsection (a) and evaluating the extent to which the authority under this section is exercised to open Major Range and Test Facility Installations to commercial test and evaluation activities.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa64cef6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa64cef7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
