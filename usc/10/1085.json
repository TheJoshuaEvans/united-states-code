{"tag":"section","attrib":{"id":"ida88587d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1085"},"text":null,"children":[{"tag":"num","attrib":{"value":"1085"},"text":"§ 1085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical and dental care from another executive department: reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a member or former member of a uniformed service under the jurisdiction of one executive department (or a dependent of such a member or former member) receives inpatient medical or dental care in a facility under the jurisdiction of another executive department, the appropriation for maintaining and operating the facility furnishing the care shall be reimbursed at rates established by the President to reflect the average cost of providing the care.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida88587d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/25/B"},"text":"Pub. L. 85–861, § 1(25)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1450"},"text":"72 Stat. 1450","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/264/s1"},"text":"Pub. L. 89–264, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-19"},"text":"Oct. 19, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/989"},"text":"79 Stat. 989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/36"},"text":"Pub. L. 96–513, title V, § 511(36)","children":[],"tail":", (37), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2923"},"text":"94 Stat. 2923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1268/6"},"text":"Pub. L. 98–94, title XII, § 1268(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/706"},"text":"97 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s19/12"},"text":"Pub. L. 98–557, § 19(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2870"},"text":"98 Stat. 2870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1303/a/8"},"text":"Pub. L. 99–145, title XIII, § 1303(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/739"},"text":"99 Stat. 739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88587da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida88587db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida88587dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1085","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:421(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-06-07/ch374/s301/d"},"text":"June 7, 1956, ch. 374, § 301(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/253"},"text":"70 Stat. 253","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “other than that of the member or former member concerned” are substituted for the words “that is not the service of which he is a member or retired member, or that is not the service of the member or retired member upon whom he is dependent”. The word “medical” before the word “facility” is omitted to make clear that the provision also relates to dental care. The words “pursuant to the provisions of this chapter” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88587dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida88587de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1085, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/87"},"text":"70A Stat. 87","children":[],"tail":", related to prevention of fraud, coercion, and undue influence, to free discussion, and to acts done in good faith, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s36B/5"},"text":"Pub. L. 85–861, § 36B(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1570"},"text":"72 Stat. 1570","children":[],"tail":", as superseded by the Federal Voting Assistance Act of 1955 which is classified to subchapter I–D (§ 1973cc et seq.) of chapter 20 of Title 42, The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88587df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" indented first line of text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “If a member or former member of a uniformed service under the jurisdiction of one executive department (or a dependent of such a member or former member) receives inpatient medical or dental care in a facility under the jurisdiction of another executive department, the appropriation for maintaining and operating the facility furnishing the care shall be reimbursed at rates established by the President to reflect the average cost of providing the care” for “If a member or former member of an armed force under the jurisdiction of a military department, or his dependent, receives inpatient medical or dental care in a facility under the jurisdiction of the Secretary of Health and Human Services, or if a member or former member of a uniformed service not under the jurisdiction of a military department, or his dependent, receives inpatient medical or dental care in a facility of an armed force under the jurisdiction of a military department, the appropriation for maintaining and operating the facility furnishing that care shall be reimbursed at rates established by the President to reflect the average cost of providing such care”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" inserted a comma after “If a member or former member of an armed force under the jurisdiction of a military department, or his dependent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Secretary of Health and Human Services” for “Secretary of Health, Education, and Welfare”, and “President” for “Bureau of the Budget”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/264"},"text":"Pub. L. 89–264","children":[],"tail":" substituted “executive department” for “uniformed service” in section catchline, and provisions requiring reimbursement if a member or former member of an armed force under the jurisdiction of a military department, or his dependent receives care in a facility under the jurisdiction of Secretary of Health, Education, and Welfare, or if a member or former member of a uniformed service not under the jurisdiction of a military department, or his dependent, receives care in a facility of an armed force under the jurisdiction of a military department, for provisions which required reimbursement if a person received care in a facility of a uniformed service other than that of the member or former member concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88587e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida88587e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88587e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Funds Necessary To Provide Medical Care","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tII/s217"},"text":"Pub. L. 114–120, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/46"},"text":"130 Stat. 46","children":[],"tail":", related to transfer of funds from the Secretary of Homeland Security to the Secretary of Defense in lieu of reimbursement required under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1085"},"text":"section 1085 of title 10","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s722/c"},"text":"Pub. L. 114–328, div. A, title VII, § 722(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2229"},"text":"130 Stat. 2229","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida88587e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ida88587e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section to establish uniform rates of reimbursement for inpatient medical or dental care delegated to Secretary of Health and Human Services in respect of such care in a facility under his jurisdiction and to Secretary of Defense in respect of such care in a facility of an armed force under jurisdiction of a military department, see section 6 of Ex. Ord. No. 11609, ","children":[{"tag":"date","attrib":{"date":"1971-07-22"},"text":"July 22, 1971","children":[],"tail":", 36 F.R. 13747, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
