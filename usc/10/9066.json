{"tag":"section","attrib":{"id":"idab61a5b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9066"},"text":null,"children":[{"tag":"num","attrib":{"value":"9066"},"text":"§ 9066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Air Force: composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab61a5b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9066/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Regular Air Force is the component of the Air Force that consists of persons whose continuous service on active duty in both peace and war is contemplated by law, and of retired members of the Regular Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab61a5b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9066/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Regular Air Force includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab61a5b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9066/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers and enlisted members of the Regular Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9066/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professors, registrar, and cadets at the United States Air Force Academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab61a5b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9066/b/3"},"text":null,"children":[{"tag"