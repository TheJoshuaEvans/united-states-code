{"tag":"section","attrib":{"id":"ida8510a20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047"},"text":null,"children":[{"tag":"num","attrib":{"value":"1047"},"text":"§ 1047.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance for civilian clothing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8510a21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members Traveling In Connection With Medical Evacuation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may furnish civilian clothing and luggage to a member at a cost not to exceed $250, or reimburse a member for the purchase of civilian clothing and luggage in an amount not to exceed $250, in the case of a member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8510a22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is medically evacuated for treatment in a medical facility by reason of an illness or injury incurred or aggravated while on active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after being medically evacuated as described in paragraph (1), is in an authorized travel status from a medical facility to another location approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8510a24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may furnish civilian clothing, at a cost of not more than $40, to an enlisted member who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8510a25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharged for misconduct or unsuitability or under conditions other than honorable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sentenced by a civil court to confinement in a prison;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interned or discharged as an alien enemy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1047/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discharged before completion of recruit training under honorable conditions for dependency, hardship, minority, or disability or for the convenience of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8510a29-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/d/1"},"text":"Pub. L. 98–525, title XIV, § 1401(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2615"},"text":"98 Stat. 2615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s584/a"},"text":"Pub. L. 108–375, div. A, title V, § 584(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1929"},"text":"118 Stat. 1929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVI/s634"},"text":"Pub. L. 110–181, div. A, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/155"},"text":"122 Stat. 155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8510a2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8510a2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8510a2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":n