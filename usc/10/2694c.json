{"tag":"section","attrib":{"id":"ida9bb96a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2694c"},"text":"§ 2694c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in conservation banking programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9bb96a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Participate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriated funds, the Secretary concerned, when engaged or proposing to engage in an activity described in subsection (b) that may or will result in an adverse impact to one or more species protected (or pending protection) under any applicable provision of law, or habitat for such species, may make payments to a conservation banking program or “in-lieu-fee” mitigation sponsor approved in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb96a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Guidance for the Establishment, Use and Operation of Mitigation Banks (60 Fed. Reg. 58605; ","children":[{"tag":"date","attrib":{"date":"1995-11-28"},"text":"November 28, 1995","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Guidance for the Establishment, Use, and Operation of Conservation Banks (68 Fed. Reg. 24753; ","children":[{"tag":"date","attrib":{"date":"2003-05-02"},"text":"May 2, 2003","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Guidance on the Use of In-Lieu-Fee Arrangements for Compensatory Mitigation Under Section 404 of the Clean Water Act and Section 10 of the Rivers and Harbors Act (65 Fed. Reg. 66915; ","children":[{"tag":"date","attrib":{"date":"2000-11-07"},"text":"November 7, 2000","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any successor or related administrative guidance or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments to a conservation banking program or “in-lieu-fee” mitigation sponsor under subsection (a) may be made only for the purpose of facilitating one or more of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb96ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military testing, operations, training, or other military activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military construction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Amounts for Conservation Banking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments made under subsection (a) to a conservation banking program or “in-lieu-fee” mitigation sponsor for the purpose of facilitating military construction may be treated as eligible costs of the military construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts available from any of the following shall be available for activities under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb96b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research, development, test, and evaluation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Support for United States Relocation to Guam Account established under section 2824 of the Military Construction Authorization Act for Fiscal Year 2009 (division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Public Law 110–417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/4730"},"text":"122 Stat. 4730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9bb96b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary Concerned Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Secretary concerned” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9bb96b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of a military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9bb96b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2694c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense with respect to a Defense Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9bb96b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title III, § 311(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4408"},"text":"122 Stat. 4408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tIII/s311"},"text":"Pub. L. 111–84, div. A, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2247"},"text":"123 Stat. 2247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/b/45"},"text":"Pub. L. 111–383, div. A, title X, § 1075(b)(45)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4371"},"text":"124 Stat. 4371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9bb96b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9bb96ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9bb96bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" inserted “Authorization” after “Military Construction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s311/1"},"text":"Pub. L. 111–84, § 311(1)","children":[],"tail":", struck out “to carry out this section” after “appropriated funds” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/s311/2"},"text":"Pub. L. 111–84, § 311(2)","children":[],"tail":", (3), added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9bb96bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9bb96bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title III, § 311(c), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4409"},"text":"122 Stat. 4409","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2694c"},"text":"Section 2694c of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", and only funds appropriated for fiscal years beginning after "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", may be used to carry out such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
