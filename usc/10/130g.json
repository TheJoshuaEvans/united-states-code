{"tag":"section","attrib":{"id":"ida75b868b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g"},"text":null,"children":[{"tag":"num","attrib":{"value":"130g"},"text":"§ 130g.","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 130g is set out after this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight of sensitive activities of the Department of Defense.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida75b868c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall keep the congressional defense committees fully and currently informed of Department of Defense sensitive activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75b868d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the requirement under subsection (a), the Secretary shall submit to the congressional defense committees a written notification of any compromise or failure of a sensitive activity of the Department of Defense by not later than 48 hours after the date on which the Secretary determines that such a compromise or failure has occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75b868e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the congressional defense committees, shall establish and submit to such committees procedures for complying with the requirements of subsections (a) and (b), including clearly established reporting thresholds and timelines for the prompt delivery of written notifications consistent with the national security of the United States and the protection of operational security. The Secretary shall promptly notify the congressional defense committees in writing of any changes to such procedures at least 14 days prior to the adoption of any such changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75b868f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sensitive Activities Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Department of Defense sensitive activities” means operations, actions, activities, or programs of the Department of Defense that if compromised, could have enduring adverse effects on United States foreign policy, Department of Defense activities, or military operations, or cause significant embarrassment to the United States, its allies, or the Department of Defense. Such activities are generally handled through special access, compartmented, or other sensitive control mechanisms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida75b8690-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1622/a"},"text":"Pub. L. 119–60, div. A, title XVI, § 1622(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1182"},"text":"139 Stat. 1182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida75b8691-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida75b8692-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida75b8693-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 130g was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s394"},"text":"section 394 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida75b8694-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida75b8695-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Notifications","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1622/b"},"text":"Pub. L. 119–60, div. A, title XVI, § 1622(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1182"},"text":"139 Stat. 1182","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tXVI/s1622/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], establish the procedures under subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s130g"},"text":"section 130g of title 10","children":[],"tail":", United States Code, as added by subsection (a) of this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after the date of such establishment, begin making notifications under subsection (b) of such section 130g.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
