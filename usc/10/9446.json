{"tag":"section","attrib":{"id":"idab77028b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9446"},"text":null,"children":[{"tag":"num","attrib":{"value":"9446"},"text":"§ 9446.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadets: requirements for admission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab77028c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9446/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for admission to the Academy a candidate must be at least 17 years of age and must not have passed his twenty-third birthday on July 1 of the year in which he enters the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab77028d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9446/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be admitted to the Academy, an appointee must show, by an examination held under regulations prescribed by the Secretary of the Air Force, that he is qualified in the subjects prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab77028e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9446/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A candidate designated as a principal or an alternate for appointment as a cadet shall appear for physical examination at a time and place designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab77028f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9446/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be admitted to the Academy, an appointee must take and subscribe to an oath prescribed by the Secretary of the Air Force. If a candidate for admission refuses to take and subscribe to the prescribed oath, his appointment is terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab770290-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/565"},"text":"70A Stat. 565","children":[],"tail":", § 9346; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s47"},"text":"Pub. L. 89–718, § 47","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1121"},"text":"80 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s555/d"},"text":"Pub. L. 104–201, div. A, title V, § 555(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2527"},"text":"110 Stat. 2527","children":[],"tail":"; renumbered § 9446, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/a/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab770291-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab770292-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab770293-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"t