{"tag":"section","attrib":{"id":"idabb9d84e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103"},"text":null,"children":[{"tag":"num","attrib":{"value":"15103"},"text":"§ 15103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for consideration for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d84f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by this section, eligibility for promotion of officers in any competitive category of officers designated for purposes of this chapter shall be governed by the provisions of sections 14301, 14303, and 14304 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d850-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Time-in-grade Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 14303 and 14304 of this title shall not apply to the promotion of officers described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d851-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Officers Above and Below Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of this title shall not apply to the promotion of officers described in subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d852-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reference in section 14301(b) to an officer above the promotion zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d853-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 14301(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d854-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility of Certain Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following officers are not eligible for promotion under this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d855-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14301/c"},"text":"section 14301(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d856-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer not included within the promotion zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d857-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who has failed of promotion to a higher grade the maximum number of times specified for opportunities for promotion for such grade within the competitive category concerned pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s15104"},"text":"section 15104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d858-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15103/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer recommended by a selection board to be removed from consideration for promotion in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s15102/c"},"text":"section 15102(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d859-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s514/a"},"text":"Pub. L. 118–31, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/246"},"text":"137 Stat. 246","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
