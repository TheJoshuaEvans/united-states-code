{"tag":"section","attrib":{"id":"ida92a0518-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113a"},"text":"§ 2113a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Regents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92a0519-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To assist the Secretary of Defense in an advisory capacity, there is a Board of Regents of the University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a051a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92a051b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nine persons outstanding in the fields of health care, higher education administration, or public policy who shall be appointed from civilian life by the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a051c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense, or his designee, who shall be an ex officio member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a051d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Defense Health Agency, who shall be an ex officio member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a051e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surgeons general of the uniformed services, who shall be ex officio members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a051f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President of the University, who shall be a nonvoting ex officio member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a0520-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Office","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of office of each member of the Board (other than ex officio members) shall be six years except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92a0521-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member appointed to fill a vacancy occurring before the expiration of the term for which his predecessor was appointed shall be appointed for the remainder of such term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a0522-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member whose term of office has expired shall continue to serve until his successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a0523-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"One of the members of the Board (other than an ex officio member) shall be designated by the Secretary as Chairman. He shall be the presiding officer of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a0524-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Board (other than ex officio members) while attending conferences or meetings or while otherwise performing their duties as members shall be entitled to receive compensation at a rate to be fixed by the Secretary and shall also be entitled to receive an allowance for necessary travel expenses while so serving away from their place of residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a0525-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall meet at least once a quarter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92a0526-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s954/a/1"},"text":"Pub. L. 110–181, div. A, title IX, § 954(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/293"},"text":"122 Stat. 293","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s523"},"text":"Pub. L. 111–84, div. A, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2285"},"text":"123 Stat. 2285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s715/a"},"text":"Pub. L. 116–283, div. A, title VII, § 715(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3694"},"text":"134 Stat. 3694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida92a0527-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida92a0528-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida92a0529-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" substituted “health care, higher education administration, or public policy” for “health and health education”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida92a052a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida92a052b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s715/c"},"text":"Pub. L. 116–283, div. A, title VII, § 715(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3694"},"text":"134 Stat. 3694","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tVII/s715/c"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida92a052c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVII/s715/b"},"text":"Pub. L. 116–283, div. A, title VII, § 715(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3694"},"text":"134 Stat. 3694","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tVII/s715/b"},"text":"“The amendments made by this section [amending this section] may not be construed to invalidate any action taken by the Uniformed Services University of the Health Sciences or its Board of Regents prior to the effective date of this section [see Effective Date of 2021 Amendment note above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
