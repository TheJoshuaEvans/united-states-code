{"tag":"section","attrib":{"id":"idabc34d1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18231"},"text":null,"children":[{"tag":"num","attrib":{"value":"18231"},"text":"§ 18231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc34d1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18231/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, by purchase, lease, transfer, construction, expansion, rehabilitation, or conversion of facilities necessary for the proper development, training, operation, and maintenance of the reserve components of the armed forces, including troop housing and messing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18231/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the joint use of those facilities by units of two or more of those reserve components, to the greatest practicable extent for efficiency and economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18231/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of those facilities, in time of war or national emergency, by those units and other units of the armed forces, to the greatest practicable extent for efficiency and economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc34d20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18231/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other use of those facilities by the United States, in time of war or national emergency, to the greatest practicable extent for efficiency and economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc34d21-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/120"},"text":"70A Stat. 120","children":[],"tail":", § 2231; "},{"tag":"ref","attrib":{"href":"/us/pl/85/215/s1"},"text":"Pub. L. 85–215, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-29"},"text":"Aug. 29, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/489"},"text":"71 Stat. 489","children":[],"tail":"; renumbered § 18231, "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1664/b/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1664(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3010"},"text":"108 Stat. 3010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc34d22-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabc34d23-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idabc34d24-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag"