{"tag":"section","attrib":{"id":"idaac90f1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251"},"text":null,"children":[{"tag":"num","attrib":{"value":"6251"},"text":"§ 6251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive management training in Department of Energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90f1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Training Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall establish and implement a management training program for personnel of the Department of Energy involved in the management of atomic energy defense activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90f20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training program shall at a minimum include instruction in the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90f21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Department of Energy policy and procedures for management and operation of atomic energy defense facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods of evaluating technical performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and State environmental laws and requirements for compliance with such environmental laws, including timely compliance with reporting requirements in such laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of program milestones and methods to evaluate success in meeting such milestones.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods for conducting long-range technical and budget planning.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90f26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6251/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for reviewing and applying innovative technology to defense environmental cleanup.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90f27-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1417"},"text":"139 Stat. 1417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90f28-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90f29-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90f2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6251 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8301"},"text":"section 8301 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2721"},"text":"section 2721 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
