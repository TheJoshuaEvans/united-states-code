{"tag":"section","attrib":{"id":"ida8e02b03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1508"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508"},"text":"§ 1508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e02b04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right of Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who is the primary next of kin (or the previously designated person) of a person who is the subject of a finding described in subsection (b) may obtain judicial review in a United States district court of that finding, but only on the basis of a claim that there is information that could affect the status of the missing person’s case that was not adequately considered during the administrative review process under this chapter. Any such review shall be as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02b05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings for Which Judicial Review May Be Sought","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e02b06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A finding by a board appointed under section 1504 or 1505 of this title that a missing person is dead.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e02b07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A finding by a board appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1509"},"text":"section 1509 of this title","children":[],"tail":" that confirms that a missing person formerly declared dead is in fact dead."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e02b08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appeals from a decision of the district court shall be taken to the appropriate United States court of appeals and to the Supreme Court as provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e02b09-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s569/b/1"},"text":"Pub. L. 104–106, div. A, title V, § 569(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/348"},"text":"110 Stat. 348","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
