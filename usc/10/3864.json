{"tag":"section","attrib":{"id":"idaa3ea955-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864"},"text":null,"children":[{"tag":"num","attrib":{"value":"3864"},"text":"§ 3864.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assumption of uninsurable risk on certain contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa3ea956-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall ensure that a contractor is not required to assume the risk of loss for work in process under a covered contract if, due to the classified nature of the performance of such contractor under such covered contract—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea957-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contractor is unable to obtain insurance for such risk of loss from a commercial provider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea958-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial provider is unable to process a claim of such contractor for loss of work in process under such covered contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea959-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply with respect to a loss of work in process under a covered contract to the extent that such loss—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea95a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the result of willful misconduct or lack of good faith on the part of the managerial personnel of the contractor, including with respect to the oversight of subcontractors by the contractor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea95b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the result of workmanship error by the contractor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea95c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea95d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “classified contract” means a contract the performance of which requires a contractor performing under such contract, or an employee of such contractor, to have access to classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea95e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered contract” means a classified, fixed-price type contract for the acquisition of a product entered into by the Department of Defense after the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea95f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “work in process” means an item at any stage of production or manufacture at any time from the initiation of contract performance until delivery to and acceptance by the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea960-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3864/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “workmanship error” means damage to work in process that is a result of an incorrectly performed skill-based task, operation, or action that was originally planned or intended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa3ea961-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s801/a"},"text":"Pub. L. 119–60, div. A, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/939"},"text":"139 Stat. 939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa3ea962-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa3ea963-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa3ea964-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of this Act, referred to in subsec. (c)(2), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which added this section and was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa3ea965-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 3881 and 3882 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIV/s401/1"},"text":"Pub. L. 85–155, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/390"},"text":"71 Stat. 390","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3881, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/222"},"text":"70A Stat. 222","children":[],"tail":", authorized Secretary of the Army to retire regular commissioned officers of Army Nurse Corps or Women’s Medical Specialist Corps whose regular grade is below major."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3882, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/222"},"text":"70A Stat. 222","children":[],"tail":", authorized Secretary of the Army to retire regular commissioned officers of Army Nurse Corps or Women’s Medical Specialist Corps whose regular grade is above captain."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 3883 to 3886 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s216"},"text":"Pub. L. 96–513, title II, § 216","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2886"},"text":"94 Stat. 2886","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3883, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/222"},"text":"70A Stat. 222","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/6"},"text":"Pub. L. 85–600, § 1(6)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/522"},"text":"72 Stat. 522","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/551/s2"},"text":"Pub. L. 95–551, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2069"},"text":"92 Stat. 2069","children":[],"tail":", provided that, unless retired or separated at an earlier date, each commissioned officer whose regular grade is below major general, other than a professor or the director of admissions of the United States Military Academy, be retired when he becomes 60 years of age, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1251"},"text":"section 1251 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3884, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/222"},"text":"70A Stat. 222","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":", provided that, unless retired or separated at an earlier date, each commissioned officer whose regular grade is major general, and whose retirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3923"},"text":"section 3923 of this title","children":[],"tail":" has been deferred under cl. (1) of that section, be retired when he becomes 60 years of age, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1251"},"text":"section 1251 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3885, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/222"},"text":"70A Stat. 222","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":", provided that, unless retired or separated at an earlier date or unless retained under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3923/2"},"text":"section 3923(2) of this title","children":[],"tail":", each commissioned officer whose regular grade is major general be retired when he becomes 62 years of age, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1251"},"text":"section 1251 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3886, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/222"},"text":"70A Stat. 222","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/7"},"text":"Pub. L. 85–600, § 1(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/522"},"text":"72 Stat. 522","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s3"},"text":"Pub. L. 89–718, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1115"},"text":"80 Stat. 1115","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/551/s2"},"text":"Pub. L. 95–551, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2069"},"text":"92 Stat. 2069","children":[],"tail":", provided that, unless retired or separated at an earlier date, each commissioned officer whose regular grade is major general, and whose retirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3923"},"text":"section 3923 of this title","children":[],"tail":" has been deferred under cl. (2) of that section, and each permanent professor and the director of admissions of the United States Military Academy, be retired when he becomes 64 years of age, except as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8301"},"text":"section 8301 of title 5","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1251"},"text":"section 1251 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 3887, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/223"},"text":"70A Stat. 223","children":[],"tail":", related to computation of years of service of commissioned officers of Army Nurse Corps or Women’s Medical Specialist Corps for purposes of retirement under former sections 3881 or 3882 of this title, or retirement pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3991"},"text":"section 3991 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIV/s401/1"},"text":"Pub. L. 85–155, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/390"},"text":"71 Stat. 390","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 3888 and 3889 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s216"},"text":"Pub. L. 96–513, title II, § 216","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2886"},"text":"94 Stat. 2886","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3888, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/223"},"text":"70A Stat. 223","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tI/s101/18"},"text":"Pub. L. 85–155, title I, § 101(18)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/379"},"text":"71 Stat. 379","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-05-20"},"text":"May 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/422/s11/a/3"},"text":"Pub. L. 85–422, § 11(a)(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/131"},"text":"72 Stat. 131","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/96"},"text":"Pub. L. 85–861, § 1(96)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1487"},"text":"72 Stat. 1487","children":[],"tail":", related to computation of service for determining retired pay of a commissioned officer of Regular Army retired under former section 3883, 3884, 3885, or 3886 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3889, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/224"},"text":"70A Stat. 224","children":[],"tail":", provided that a member of Army retired under this chapter be entitled to retired pay computed under chapter 745 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa3ea966-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa3ea967-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s801/b"},"text":"Pub. L. 119–60, div. A, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/940"},"text":"139 Stat. 940","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tVIII/s801/b"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"], the Secretary of Defense shall revise the Defense Federal Acquisition Regulation Supplement to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3864"},"text":"section 3864 of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
