{"tag":"section","attrib":{"id":"idab831103-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773"},"text":null,"children":[{"tag":"num","attrib":{"value":"9773"},"text":"§ 9773.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition and construction: installations and depots","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab831104-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force shall determine the sites of such additional permanent Air Force and Space Force military installations and depots in all strategic areas of the United States and the Commonwealths, possessions, and holdings as he considers necessary. He shall determine when the enlargement of existing installations and depots is necessary for the effective peacetime training of the Air Force or the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab831105-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining the sites of new installations and depots, the Secretary shall consider the following regions for the purposes indicated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab831106-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Atlantic northeast, for training in cold weather and in fog;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab831107-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Atlantic southeast and Caribbean areas, for training in long-range operations, especially those incident to reinforcing the defenses of the Panama Canal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab831108-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the southeastern United States, to provide a depot necessary to maintain the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab831109-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pacific northwest, to establish and maintain air communication with Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab83110a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alaska, for training under conditions of extreme cold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab83110b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rocky Mountain area, to provide a depot necessary to maintain the Air Force, and for training in operations from fields in high altitudes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab83110c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other regions, for the establishment of intermediate installations to provide for transcontinental movements of the Air Force or Space Force for maneuvers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab83110d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In selecting sites for installations and depots covered by this section and in determining the alteration or enlargement of existing installations or depots, the Secretary shall consider the need—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8559fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to form the nucleus for concentration of Air Force or Space Force units in time of war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8559ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit, in time of peace, training and effective planning in each strategic area for the use and expansion of commercial, municipal, and private flying installations in time of war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to locate, in each strategic area in which it is considered necessary, adequate storage facilities for munitions and other articles necessary to facilitate the movement, concentration, maintenance, and operation of the Air Force or the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to afford the maximum warning against surprise attack by enemy aircraft upon aviation of the United States and its necessary installations consistent with maintaining, in connection with existing or contemplated landing fields, the full power of the Air Force or the Space Force for operations necessary in the defense of the United States, and in the defense and reinforcement of the Commonwealths, possessions, and holdings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this section, the Secretary, on behalf of the United States, may acquire title, in fee simple and free of encumbrance, to any land that he considers necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab855a03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by accepting title without cost to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by exchanging military reservations or parts thereof for that land, upon the written approval of the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab855a05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by purchase or condemnation, if acquisition by gift or exchange is impracticable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, by purchase, gift, lease, or otherwise, acquire at desired locations bombing and machine gun ranges necessary for practice by, and the training of, tactical units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At each installation or depot established under this section, the Secretary shall remove or remodel existing structures as necessary; do necessary grading; and provide buildings, utilities, communication systems, landing fields and mats, roads, walks, aprons, docks, runways, facilities for the storage and distribution of ammunition, fuel, oil, necessary protection against bombs, and all appurtenances to the foregoing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab855a08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9773/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may direct the transportation of personnel, and the purchase, renovation, and transportation of material, that he considers necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab855a09-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/588"},"text":"70A Stat. 588","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/3"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/e/17/A"},"text":"Pub. L. 116–283, div. A, title IX, § 923(e)(17)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3818"},"text":"134 Stat. 3818","children":[],"tail":", 3819.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab855a0a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab855a0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab855a0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1343a (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1343a (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-12/ch511"},"text":"Aug. 12, 1935, ch. 511","children":[],"tail":", §§ 1–3, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/610"},"text":"49 Stat. 610","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1343a (less 1st and 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1343b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1343c (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1343c (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9773(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1343c (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “shall” is substituted for the words “is authorized and directed to”. The words “Territories, Commonwealths,” are substituted for the word “Alaska” to make it clear that the section covers all territory of the United States. The words “Air Force” are substituted for the words “General Headquarters Air Force and the Air Corps components of our overseas garrisons”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “to provide”, “to permit”, “in addition”, and “incident to the concentration of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the introductory clause is substituted for 10:1343a (1st 41 words of 3d sentence). The words “to locate” are substituted for the words “there shall be provided”. The words “aviation of the United States” are substituted for the words “our own aviation”. The words, “Territories, Commonwealths,” are inserted to conform to subsection (a). The words “The stations shall be suitably located”, “of the set-up”, “by responsible personnel”, “there shall be provided”, “General Headquarters”, “in peace and war”, “such close and distant * * * over land and sea”, and “The stations and depots shall be located with a view”, and 10:1343a (4th clause of 3d sentence) are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), clause (3) is substituted for 10: 1343b (last 26 words). 10:1043b (24 words before 1st proviso) is omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the word “shall” is substituted for the words “is further authorized and directed to”. The word “provide” is substituted for the words “construct, install, and equip, or complete the construction, installation, and equipment”. The words “technical buildings and utilities” are omitted as covered by the words “buildings” and “utilities”. The words “sewer, water, power, station and aerodrome lighting” are omitted as covered by the word “utilities”. The words “communication systems” are substituted for the words “telephone and signal communications”. The words “appurtenances to the foregoing” are substituted for the words “other essentials”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab855a0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab855a0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/B"},"text":"Pub. L. 116–283, § 923(e)(17)(B)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Acquisition and construction: air bases and depots”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/i"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(i)","children":[],"tail":", substituted “permanent Air Force and Space Force military installations” for “permanent air bases” and “existing installations” for “existing air bases”, and inserted “or the Space Force” after “training of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/ii"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(ii)","children":[],"tail":", substituted “installations” for “air bases” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/ii"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(ii)","children":[],"tail":", (iii), substituted “installations” for “air bases” and inserted “or Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/ii"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(ii)","children":[],"tail":", substituted “installations” for “air bases” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/iv/I"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(iv)(I)","children":[],"tail":", inserted “or Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/iv/II"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(iv)(II)","children":[],"tail":", inserted “or the Space Force” after “the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/17/A/v"},"text":"Pub. L. 116–283, § 923(e)(17)(A)(v)","children":[],"tail":", substituted “installation” for “air base”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a), (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" struck out “Territories,” before “Commonwealths, possessions,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab855a0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab855a10-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan and Requirements for Fielding Air Base Air Defense Sites at Air Force Installations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tI/s152"},"text":"Pub. L. 118–159, div. A, title I, § 152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1813"},"text":"138 Stat. 1813","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tI/s152"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force, in consultation with the Commander of the United States Northern Command, the Commander of United States European Command, and the Commander of United States Indo-Pacific Command, shall develop and implement a plan to support the fielding of air base air defense sites at Air Force installations and other priority sites identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air Base Air Defense Site Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each air base air defense site fielded under the plan required under subsection (a) shall have the following capabilities:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expeditionary mobile protection for dispersed air bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fixed protection for primary air bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ground-based protection systems that incorporate kinetic and non-kinetic capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counter-unmanned aircraft systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counter-fixed and Counter-rotary wing aircraft capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counter-cruise missile capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interoperability with joint command and control networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 360-degree active and passive sensors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Systems and software that enable reduced staffing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fielding Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the plan developed under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than ","children":[{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":", field a total of not fewer than four air base air defense sites, of which not fewer than two such sites shall be located in the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each of fiscal years 2028 through 2031, field at least four air base air defense sites per year, of which not fewer than two of the sites fielded each year shall be located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-03-01"},"text":"March 1, 2025","children":[],"tail":", the Secretary of the Air Force shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report on the plan required under subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
