{"tag":"section","attrib":{"id":"ida960f359-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276"},"text":null,"children":[{"tag":"num","attrib":{"value":"2276"},"text":"§ 2276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial space launch cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f35a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may take such actions as the Secretary considers to be in the best interest of the Federal Government to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f35b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the use of the capacity of the space transportation infrastructure of the Department of Defense by the private sector in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f35c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the effectiveness and efficiency of the space transportation infrastructure of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f35d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the cost of services provided by the Department of Defense related to space transportation infrastructure at launch support facilities and space recovery support facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f35e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage commercial space activities by enabling investment by covered entities in the space transportation infrastructure of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f35f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster cooperation between the Department of Defense and covered entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f360-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Contracts and Other Agreements Relating to Space Transportation Infrastructure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f361-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into an agreement with a covered entity to provide the covered entity with support and services related to the space transportation infrastructure of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f362-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" upon the request of such covered entity, may include such support and services in the space launch and reentry range support requirements of the Department of Defense if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f363-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that the inclusion of such support and services in such requirements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida960f364-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the best interest of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida960f365-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not interfere with the requirements of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida960f366-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not compete with the commercial space activities of other covered entities, unless that competition is in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f367-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commercial requirement included in the agreement has full non-Federal funding before the execution of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f368-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f369-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may enter into an agreement with a covered entity on a cooperative and voluntary basis to accept contributions of funds, services, and equipment to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f36a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of contributions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any funds, services, or equipment accepted by the Secretary under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f36b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used only for the objectives specified in this section in accordance with terms of use set forth in the agreement entered into under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f36c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be managed by the Secretary in accordance with regulations of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f36d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements with respect to agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement entered into with a covered entity under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f36e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall address the terms of use, ownership, and disposition of the funds, services, or equipment contributed pursuant to the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f36f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a provision that the covered entity will not recover the costs of its contribution through any other agreement with the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f370-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Cooperation Space Launch Account.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f371-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury of the United States a special account to be known as the “Defense Cooperation Space Launch Account”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f372-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds received by the Secretary of Defense under subsection (c) shall be credited to the Defense Cooperation Space Launch Account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f373-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds deposited in the Defense Cooperation Space Launch Account under paragraph (2) are authorized to be appropriated and shall be available for obligation only to the extent provided in advance in an appropriation Act for costs incurred by the Department of Defense in carrying out subsection (b). Funds in the Account shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"ida960f374-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"[(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s813/a/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 813(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1851"},"text":"132 Stat. 1851","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f375-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f376-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f377-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered entity” means a non-Federal entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f378-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized under the laws of the United States or of any jurisdiction within the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f379-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in commercial space activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f37a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Launch support facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “launch support facilities” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50501/7"},"text":"section 50501(7) of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f37b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space recovery support facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “space recovery support facilities” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50501/11"},"text":"section 50501(11) of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f37c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2276/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space transportation infrastructure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “space transportation infrastructure” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50501/12"},"text":"section 50501(12) of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f37d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIX/s912/a"},"text":"Pub. L. 112–239, div. A, title IX, § 912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1872"},"text":"126 Stat. 1872","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s813/a/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 813(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1851"},"text":"132 Stat. 1851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida960f37e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida960f37f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida960f380-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2276, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/126"},"text":"70A Stat. 126","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s131"},"text":"Pub. L. 87–651, title I, § 131","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/514"},"text":"76 Stat. 514","children":[],"tail":", which related to inspection and audit of plants and books of contractors and provided criminal penalties for violations, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s821/a/1"},"text":"Pub. L. 103–160, div. A, title VIII, § 821(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1704"},"text":"107 Stat. 1704","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida960f381-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out subsec. (e). Text read as follows: “Not later than January 31 of each year, the Secretary of Defense shall submit to the congressional defense committees a report on the funds, services, and equipment accepted and used by the Secretary under this section during the preceding fiscal year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida960f382-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida960f383-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan To Improve Threat-Sharing Arrangements With Commercial Space Operators","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVI/s1610"},"text":"Pub. L. 118–31, div. A, title XVI, § 1610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/589"},"text":"137 Stat. 589","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXVI/s1610"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan for Threat Sharing With Commercial Space Operators","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary of the Air Force for Space Acquisition and Integration, in consultation with the Commander of the United States Space Command, shall develop and implement a plan to expand threat-sharing arrangements with commercial space operators that are under contract with the Department of Defense as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act, the Assistant Secretary of the Air Force for Space Acquisition and Integration, in coordination with the Commander of the United States Space Command, shall submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report on the plan required under subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida960f384-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Security Space Launch Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1605/b"},"text":"Pub. L. 118–159, div. A, title XVI, § 1605(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2161"},"text":"138 Stat. 2161","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tXVI/s1605/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Changes in Phase Three Acquisition Strategy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than seven days before implementing any modification to the final phase three acquisition strategy under the National Security Space Launch program, the Assistant Secretary of the Air Force for Space Acquisition and Integration shall submit to the appropriate congressional committees notice of the proposed modification together with an explanation of the reasons for such modification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives]; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees (as defined in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘final phase three acquisition strategy’ means the acquisition strategy for phase three of the National Security Space Launch program, as approved by the Assistant Secretary of the Air Force for Space Acquisition and Integration on ","children":[{"tag":"date","attrib":{"date":"2024-03-04"},"text":"March 4, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘phase three’ has the meaning given that term in section 1601(e) of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/71"},"text":"Public Law 118–71","children":[],"tail":" [probably should be 117–81]; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2276"},"text":"10 U.S.C. 2276","children":[],"tail":" note) [set out below].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1601/b"},"text":"Pub. L. 117–81, div. A, title XVI, § 1601(b)","children":[],"tail":", (c), (e), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2073-2075"},"text":"135 Stat. 2073–2075","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1605/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2161"},"text":"138 Stat. 2161","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tXVI/s1605/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to entering into contracts for launch services during the period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"] and ending "},{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":", it shall be the policy of the Department of Defense and the National Reconnaissance Office to—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the National Security Space Launch program to the extent practical to procure launch services only from launch service providers that can meet Federal requirements with respect to delivering required payloads to reference orbits covered under the requirements of phase two; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize continuous competition for launch services as the Space Force initiates planning for phase three, specifically for those technology areas that are unique to existing and emerging national security requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Defense or the Director of the National Reconnaissance Office determines that a program requiring launch services that could be met using the National Security Space Launch program will instead use an alternative launch procurement approach, not later than seven days after the date of such determination, the Secretary of Defense or, as appropriate, the Director of National Intelligence, shall submit to the appropriate congressional committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification of such determination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the alternative launch procurement approach is in the national security interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an outline of the cost analysis and any other rationale for such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives]; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘phase three’ means, with respect to the National Security Space Launch program, launch missions ordered under the program after fiscal year 2024.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘phase two’ means, with respect to the National Security Space Launch program, launch missions ordered under the program during fiscal years 2020 through 2024.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
