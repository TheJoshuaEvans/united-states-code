{"tag":"section","attrib":{"id":"idabc82fc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20211"},"text":null,"children":[{"tag":"num","attrib":{"value":"20211"},"text":"§ 20211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convening of selection boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82fc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20211/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the needs of the service require, the Secretary of the Air Force shall convene selection boards to recommend for promotion to the next higher permanent grade officers of the Space Force in each permanent grade from first lieutenant through brigadier general.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82fc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20211/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Officers in Grade of First Lieutenant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not require the convening of a selection board in the case of Space Force officers in the permanent grade of first lieutenant when the Secretary of the Air Force recommends for promotion to the grade of captain under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20239/c/4/A"},"text":"section 20239(c)(4)(A) of this title","children":[],"tail":" all such officers whom the Secretary finds to be fully qualified for promotion."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82fc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20211/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Boards for Early Retirement or Discharge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may convene selection boards to recommend officers for early retirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20404/a"},"text":"section 20404(a) of this title","children":[],"tail":" or for discharge under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s20404/b"},"text":"section 20404(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82fc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20211/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The convening of selection boards under subsection (a) shall be under regulations prescribed by the Secretary of the Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82fc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/634"},"text":"137 Stat. 634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521/n"},"text":"Pub. L. 118–159, div. A, title V, § 521(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1882"},"text":"138 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc82fc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc82fc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc82fca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “20239(c)(4)(A)” for “20238(a)(4)(A)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
