{"tag":"section","attrib":{"id":"idabc5be68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18233b"},"text":null,"children":[{"tag":"num","attrib":{"value":"18233b"},"text":"§ 18233b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to carry out small projects with operation and maintenance funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under such regulations as the Secretary of Defense may prescribe, the Secretary may expend, from appropriations available for operation and maintenance, amounts necessary to carry out any project authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s18233/a"},"text":"section 18233(a) of this title","children":[],"tail":" that costs not more than the amount specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2805/c"},"text":"section 2805(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabc5be69-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dB/tXXVIII/s2808/b"},"text":"Pub. L. 108–375, div. B, title XXVIII, § 2808(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2125"},"text":"118 Stat. 2125","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dB/tXXVIII/s2802/c/4"},"text":"Pub. L. 112–81, div. B, title XXVIII, § 2802(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1685"},"text":"125 Stat. 1685","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc5be6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes