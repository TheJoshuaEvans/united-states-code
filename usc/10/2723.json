{"tag":"section","attrib":{"id":"ida9c77dda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723"},"text":null,"children":[{"tag":"num","attrib":{"value":"2723"},"text":"§ 2723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to congressional committees of certain security and counterintelligence failures within defense programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c77ddb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to the Committees on Armed Services of the Senate and House of Representatives a notification of each security or counterintelligence failure or compromise of classified information relating to any defense operation, system, or technology of the United States that the Secretary considers likely to cause significant harm or damage to the national security interests of the United States. The Secretary shall consult with the Director of National Intelligence and the Director of the Federal Bureau of Investigation, as appropriate, before submitting any such notification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77ddc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notification of a failure or compromise of classified information under subsection (a) shall be provided, in accordance with the procedures established pursuant to subsection (c), not later than 30 days after the date on which the Department of Defense determines that the failure or compromise has taken place.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77ddd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the Committees on Armed Services of the Senate and House of Representatives shall each establish such procedures as may be necessary to protect from unauthorized disclosure classified information, information relating to intelligence sources and methods, and sensitive law enforcement information that is submitted to those committees pursuant to this section and that are otherwise necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77dde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77ddf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed as authority to withhold any information from the Committees on Armed Services of the Senate and House of Representatives on the grounds that providing the information to those committees would constitute the unauthorized disclosure of classified information, information relating to intelligence sources and methods, or sensitive law enforcement information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77de0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2723/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to modify or supersede any other requirement to report information on intelligence activities to the Congress, including the requirement under section 501 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c77de1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1042/a"},"text":"Pub. L. 106–65, div. A, title X, § 1042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/759"},"text":"113 Stat. 759","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s931/a/13"},"text":"Pub. L. 110–181, div. A, title IX, § 931(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/285"},"text":"122 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 932(a)(12), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4576"},"text":"122 Stat. 4576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c/10"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2475"},"text":"123 Stat. 2475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/12"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c77de2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c77de3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c77de4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s413"},"text":"50 U.S.C. 413","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/12"},"text":"Pub. L. 110–417, § 932(a)(12)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/12"},"text":"Pub. L. 110–417, § 932(a)(12)","children":[],"tail":", amended subsec. (a) identically, substituting “Director of National Intelligence” for “Director of Central Intelligence”. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/12"},"text":"Pub. L. 110–417, § 932(a)(12)","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":". See 2009 Amendment note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c77de5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9c77de6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":", provided in part that the amendment made by section 1073(c)(10) is effective as of "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
