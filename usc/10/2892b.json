{"tag":"section","attrib":{"id":"ida9f25e4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2892b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2892b"},"text":"§ 2892b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on requirement to disclose personally identifiable information in requests for certain maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A landlord responsible for a housing unit may not require the disclosure of personally identifiable information as a part of the submission of a request for maintenance regarding a housing unit or common area when the disclosure of personally identifiable information is not needed to identify the location at which such maintenance will be performed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9f25e4d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3020/a"},"text":"Pub. L. 116–92, div. B, title XXX, § 3020(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1931"},"text":"133 Stat. 1931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9f25e4e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9f25e4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9f25e50-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3020/b"},"text":"Pub. L. 116–92, div. B, title XXX, § 3020(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1931"},"text":"133 Stat. 1931","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dB/tXXX/s3020/b"},"text":"“The prohibition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2892b"},"text":"section 2892b of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on the date that is one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
