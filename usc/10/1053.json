{"tag":"section","attrib":{"id":"ida8510a77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053"},"text":null,"children":[{"tag":"num","attrib":{"value":"1053"},"text":"§ 1053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution charges incurred because of Government error in direct deposit of pay: reimbursement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8510a78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8510a79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces (or a former member of the armed forces entitled to retired pay under chapter 1223 of this title) who, in accordance with law or regulation, participates in a program for the automatic deposit of pay to a financial institution may be reimbursed by the Secretary concerned for a covered late-deposit charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered late-deposit charge for purposes of paragraph (1) is a charge (including an overdraft charge or a minimum balance or average balance charge) that is levied by a financial institution and that results from an administrative or mechanical error on the part of the Government that causes the pay of the person concerned to be deposited late or in an incorrect manner or amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8510a7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursements under this section shall be made from appropriations available for the pay and allowances of members of the armed force concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8510a7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries concerned shall prescribe regulations to carry out this section, including regulations for the manner in which reimbursement under this section is to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8510a7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8510a7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “financial institution” means a bank, savings and loan association, or similar institution or a credit union chartered by the United States or a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8510a7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1053/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “pay” includes (A) retired pay, and (B) allowances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8510a80-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVI/s662/a/1"},"text":"Pub. L. 99–661, div. A, title VI, § 662(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3893"},"text":"100 Stat. 3893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s664/a/1"},"text":"Pub. L. 101–189, div. A, title VI, § 664(a)(1)","children":[],"tail":"–(3)(A), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1466"},"text":"103 Stat. 1466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/e/8/A"},"text":"Pub. L. 102–25, title VII, § 701(e)(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/115"},"text":"105 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/c/8"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/499"},"text":"110 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s564/a"},"text":"Pub. L. 105–261, div. A, title V, § 564(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2029"},"text":"112 Stat. 2029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 579(c)(2)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–141.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8510a81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8510a82-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8510a83-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “Financial institution charges incurred because of Government error in direct deposit of pay: reimbursement” for “Reimbursement for financial institution charges incurred because of Government error in direct deposit of pay” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The term ‘financial institution’ has the meaning given the term ‘financial organization’ in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3332/a"},"text":"section 3332(a) of title 31","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “chapter 1223” for “chapter 67”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" struck out “mandatory” after “error in” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s664/a/3/A"},"text":"Pub. L. 101–189, § 664(a)(3)(A)","children":[],"tail":", amended section catchline generally, substituting “Reimbursement for financial institution charges incurred because of Government” for “Relief for expenses because of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s664/a/1"},"text":"Pub. L. 101–189, § 664(a)(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “A member of the armed forces who, by law or regulation, is required to participate in a program for the automatic deposit of pay to a financial institution may be reimbursed for overdraft charges levied by the financial institution when such charges result from an administrative or mechanical error on the part of the Government that causes such member’s pay to be deposited late or in an incorrect amount or manner.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s664/a/2"},"text":"Pub. L. 101–189, § 664(a)(2)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “In this section, the term ‘financial institution’ has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3332"},"text":"section 3332 of title 31","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8510a84-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8510a85-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/c"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", and as if included as an amendment made by the Reserve Officer Personnel Management Act, title XVI of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", as originally enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8510a86-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s664/c"},"text":"Pub. L. 101–189, div. A, title VI, § 664(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1467"},"text":"103 Stat. 1467","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/189/dA/tVI/s664/c"},"text":"“The amendments made by subsection (a) [amending this section], and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1594"},"text":"section 1594 of title 10","children":[],"tail":", United States Code, as added by subsection (b), shall apply with respect to pay and allowances deposited (or scheduled to be deposited) on or after the first day of the first month beginning after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8510a87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVI/s662/c"},"text":"Pub. L. 99–661, div. A, title VI, § 662(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3894"},"text":"100 Stat. 3894","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/661/dA/tVI/s662/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1053"},"text":"Section 1053 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply only with respect to charges levied as a result of errors occurring on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
