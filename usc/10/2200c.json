{"tag":"section","attrib":{"id":"ida93ace69-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2200c"},"text":"§ 2200c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special considerations in awarding scholarships and grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93ace6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Centers of Academic Excellence in Cyber Education","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the selection of a recipient for the award of a scholarship or grant under this chapter, consideration shall be given to whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93ace6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a scholarship, the institution at which the recipient pursues a degree is a Center of Academic Excellence in Cyber Education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant, the recipient is a Center of Academic Excellence in Cyber Education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93ace6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Institutions of Higher Education","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the selection of a recipient for the award of a scholarship or grant under this chapter, consideration shall be given to whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93ace6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a scholarship, the institution of higher education at which the recipient pursues a degree is an institution described in section 371(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"20 U.S.C. 1067q(a)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2200c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a grant, the recipient is an institution described in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93ace70-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 922(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–236; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1649/d/1/E"},"text":"Pub. L. 115–91, div. A, title XVI, § 1649(d)(1)(E)","children":[],"tail":", (F), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1753"},"text":"131 Stat. 1753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1633/a"},"text":"Pub. L. 115–232, div. A, title XVI, § 1633(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2125"},"text":"132 Stat. 2125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93ace71-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93ace72-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93ace73-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Special considerations in awarding scholarships and grants” for “Centers of Academic Excellence in Cyber Education” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “Cyber” for “Information Assurance” in heading and in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida93ace74-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"ida93ace75-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1649/e/2"},"text":"Pub. L. 115–91, div. A, title XVI, § 1649(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1753"},"text":"131 Stat. 1753","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tXVI/s1649/e/2"},"text":"“Any institution of higher education designated by the Director of the National Security Agency as a Center of Academic Excellence in Information Assurance Education is redesignated as a Center of Academic Excellence in Cyber Education. Any reference in a law (other than this section), map, regulation, document, paper, or other record of the United States to a Center of Academic Excellence in Information Assurance Education shall be deemed to be a reference to a Center of Academic Excellence in Cyber Education.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
