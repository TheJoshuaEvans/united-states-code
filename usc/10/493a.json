{"tag":"section","attrib":{"id":"ida7c6cc1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a"},"text":null,"children":[{"tag":"num","attrib":{"value":"493a"},"text":"§ 493a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industrial base monitoring for B–21 and Sentinel programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c6cc1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force, acting through the Assistant Secretary of the Air Force for Acquisition, Technology, and Logistics, shall designate a senior official, who shall report to the Assistant Secretary, to monitor the combined industrial base supporting the acquisition of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cc1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" B–21 aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sentinel intercontinental ballistic missile weapon system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cc1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In monitoring the combined industrial base described in subsection (a), the senior official designated under such subsection shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c6cc1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the authority to select staff to assist the senior official from among civilian employees of the Department and members of the armed forces, who may provide such assistance concurrently while serving in another position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" monitor the acquisition by the combined industrial base of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7c6cc21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials, technologies, and components associated with nuclear weapons systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7c6cc22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commodities purchased on a large scale;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the hiring or contracting by the combined industrial base of personnel with critical skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c6cc24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether personnel with critical skills and knowledge, intellectual property on manufacturing processes, and facilities and equipment necessary to design, develop, manufacture, repair, and support a program are available and affordable within the scopes of the B–21 aircraft program and the Sentinel intercontinental ballistic missile weapon system program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c6cc25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s493a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the same time as the submission of the budget of the President pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for a fiscal year, the Secretary shall submit to the congressional defense committees a report with respect to the status of the combined industrial base described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c6cc26-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVI/s1632"},"text":"Pub. L. 117–263, div. A, title XVI, § 1632","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2934"},"text":"136 Stat. 2934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c6cc27-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7c6cc28-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7c6cc29-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conditional Requirements for Sentinel Intercontinental Ballistic Missile Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1629"},"text":"Pub. L. 118–159, div. A, title XVI, § 1629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2176"},"text":"138 Stat. 2176","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tXVI/s1629"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary of Defense for Acquisition and Sustainment shall ensure, to the maximum extent practicable that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contract structure for the Sentinel intercontinental ballistic missile (previously referred to as the ‘ground-based strategic weapon’) program allows for maximum Federal Government oversight of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Aerospace Vehicle Segment program area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Launch Control Center program area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Launch Control Facility program area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such Federal Government oversight includes Federal Government control of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary and critical design reviews entrance criteria, exit criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification of completion at the subsystem level through total system architecture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are opportunities for competition throughout the lifecycle of the Sentinel intercontinental ballistic missile program, including competition across each of the program areas specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Under Secretary completes a revised Milestone B approval for such program, the Under Secretary shall, not later than 60 days after the date on which the Under Secretary completes such approval, submit to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a report that includes a description of how the Under Secretary intends to satisfy the requirements of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Milestone B Approval Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Milestone B approval’ has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4172"},"text":"section 4172 of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
