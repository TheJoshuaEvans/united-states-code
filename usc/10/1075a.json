\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Inpatient skilled nursing/rehab civilian","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$0","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"$30 per day network","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a0be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each dollar amount expressed as a fixed dollar amount in the table set forth in paragraph (1) shall be annually indexed to the amount by which retired pay is increased under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401a"},"text":"section 1401a of this title","children":[],"tail":", rounded to the next lower multiple of $1. The remaining amount above such multiple of $1 shall be carried over to, and accumulated with, the amount of the increase for the subsequent year or years and made when the aggregate amount of increases carried over under this clause for a year is $1 or more."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a0bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enrollment fees, deductible amounts, and catastrophic caps under this section are on a calendar-year basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a0c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost-sharing requirements applicable to services not specifically addressed in the table set forth in paragraph (1) shall be established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a0c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Amounts Without Referrals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (b)(1), the cost-sharing amount for a beneficiary enrolled in TRICARE Prime who does not obtain a referral for care under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1095f/a"},"text":"section 1095f(a) of this title","children":[],"tail":" (or a waiver pursuant to paragraph (2) of such section for such care) shall be an amount equal to 50 percent of the allowed point-of-service charge for such care."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a0c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Cost-sharing for Certain Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a0c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida879a0c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, the cost-sharing amount under this section for any beneficiary enrolled in TRICARE Prime for a service described in subparagraph (B) that is provided under TRICARE Prime is $0.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida879a0c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A service described in this subparagraph is any contraceptive method approved, cleared, or authorized under section 505, 510(k), 513(f)(2), or 515 of the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s355"},"text":"21 U.S.C. 355","children":[],"tail":", 360(k), 360c(f)(2), 360e), any contraceptive care (including with respect to insertion, removal, and follow up), any sterilization procedure, or any patient education or counseling service provided in connection with any such contraceptive, care, or procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a0c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida879a0c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consistent with other provisions of this chapter and subject to requirements to be prescribed by the Secretary, the Secretary may waive cost-sharing requirements for the first three outpatient mental health visits each year of a beneficiary in the active-duty family member category (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075/b/1/A"},"text":"section 1075(b)(1)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida879a0c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This paragraph shall terminate on the date that is five years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida879a0c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/b/1"},"text":"Pub. L. 114–328, div. A, title VII, § 701(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2184"},"text":"130 Stat. 2184","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s739/b/2"},"text":"Pub. L. 115–91, div. A, title VII, § 739(b)(2)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1447"},"text":"131 Stat. 1447","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tVII/s701/b"},"text":"Pub. L. 118–31, div. A, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/299"},"text":"137 Stat. 299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s707/c"},"text":"Pub. L. 118–159, div. A, title VII, § 707(c)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1944"},"text":"138 Stat. 1944","children":[],"tail":", 1945.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida879a0ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida879a0cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida879a0cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2024, referred to in subsec. (d)(2)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida879a0cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s707/d/2"},"text":"Pub. L. 118–159, § 707(d)(2)","children":[],"tail":", redesignated par. (4) of subsec. (a) as par. (2) of subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s707/c"},"text":"Pub. L. 118–159, § 707(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":