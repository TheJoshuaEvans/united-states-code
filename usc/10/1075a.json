{"tag":"section","attrib":{"id":"ida879a0b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1075a"},"text":"§ 1075a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE Prime: cost sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida879a0b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-sharing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cost-sharing requirements under TRICARE Prime are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a0b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are no cost-sharing requirements for beneficiaries who are covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074/a"},"text":"section 1074(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a0b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to beneficiaries in the active-duty family member category or the retired category (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075/b/1"},"text":"section 1075(b)(1) of this title","children":[],"tail":") by reason of being a member or former member of the uniformed services who originally enlists or is appointed in the uniformed services on or after "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", or by reason of being a dependent of such a member, the cost-sharing requirements shall be calculated pursuant to subsection (b)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida879a0b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida879a0b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to beneficiaries described in subparagraph (B) in the active-duty family member category or the retired category (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1075/b/1"},"text":"section 1075(b)(1) of this title","children":[],"tail":"), the cost-sharing requirements shall be calculated in accordance with the other provisions of this chapter without regard to subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida879a0ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beneficiaries described in this subparagraph are beneficiaries who are eligible to enroll in the TRICARE program by reason of being a member or former member of the uniformed services who originally enlists or is appointed in the uniformed services before ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", or by reason of being a dependent of such a member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida879a0bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-sharing Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida879a0bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1075a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beneficiaries described in subsection (a)(2) enrolled in TRICARE Prime shall be subject to cost-sharing requirements in accordance with the amounts and percentages under the following table during calendar year 2018 and as such amounts are adjusted under paragraph (2) for subsequent years:","children":[{"tag":"html:table","attrib":{"width":"100%","id":"ida879a0bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"TRICARE Prime","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" Active-Duty Family Member","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" (Individual/Family) ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"htm