{"tag":"section","attrib":{"id":"ida7d76d25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520"},"text":null,"children":[{"tag":"num","attrib":{"value":"520"},"text":"§ 520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on enlistment and induction of persons whose score on the Armed Forces Qualification Test is below a prescribed level","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7d76d26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7d76d27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of persons originally enlisted or inducted to serve on active duty (other than active duty for training) in any armed force during any fiscal year whose score on the Armed Forces Qualification Test is at or above the tenth percentile and below the thirty-first percentile may not exceed 4 percent of the total number of persons originally enlisted or inducted to serve on active duty (other than active duty for training) in such armed force during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d76d28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of the Secretary concerned, the Secretary of Defense may authorize an armed force to increase the limitation specified in paragraph (1) to not exceed 20 percent of the total number of persons originally enlisted or inducted to serve on active duty (other than active duty for training) in such armed force during such fiscal year. The Secretary of Defense shall notify the Committees on Armed Services of the Senate and the House of Representatives not later than 30 days after using such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7d76d29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who is not a high school graduate may not be accepted for enlistment in the armed forces unless the score of that person on the Armed Forces Qualification Test is at or above the thirty-first percentile; however, a person may not be denied enlistment in the armed forces solely because of his not having a high school diploma if his enlistment is needed to meet established strength requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7d76d2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/342/tIII/s302/b/1"},"text":"Pub. L. 96–342, title III, § 302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1082"},"text":"94 Stat. 1082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/579/s9"},"text":"Pub. L. 96–579, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3368"},"text":"94 Stat. 3368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIV/s402/b/1"},"text":"Pub. L. 97–86, title IV, § 402(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1104"},"text":"95 Stat. 1104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1268/3"},"text":"Pub. L. 98–94, title XII, § 1268(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/705"},"text":"97 Stat. 705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/a/1"},"text":"Pub. L. 100–370, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/840"},"text":"102 Stat. 840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s542"},"text":"Pub. L. 118–31, div. A, title V, § 542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/264"},"text":"137 Stat. 264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/12"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2203"},"text":"138 Stat. 2203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7d76d2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7d76d2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida7d76d2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1988 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of subsection (b) is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/307/tIV/s401"},"text":"Pub. L. 93–307, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-08"},"text":"June 8, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/234"},"text":"88 Stat. 234","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/93/365/tVII/s705"},"text":"Pub. L. 93–365, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-05"},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/406"},"text":"88 Stat. 406","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7d76d2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7d76d2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “armed force” for “armed forced”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" designated existing provisions as par. (1), substituted “may not exceed 4 percent” for “may not exceed 20 percent”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370"},"text":"Pub. L. 100–370","children":[],"tail":" inserted before period at end “; however, a person may not be denied enlistment in the armed forces solely because of his not having a high school diploma if his enlistment is needed to meet established strength requirements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" struck out provisions under which, for fiscal years beginning on "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":", the total number of persons originally enlisted or inducted to serve on active duty (other than active duty for training) in the armed forces during such fiscal years whose score on the Armed Forces Qualification Test was at or above the tenth percentile and below the thirty-first percentile could not exceed 25 percent of the number of such persons enlisted or inducted into the armed forces during such fiscal years, and, in the provisions remaining applicable to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"Sept. 30, 1982","children":[],"tail":", substituted “20 percent of the total number of persons originally enlisted or inducted to serve on active duty (other than active duty for training) in such armed force” for “20 percent of the number of such persons enlisted or inducted into such armed force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86"},"text":"Pub. L. 97–86","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/579"},"text":"Pub. L. 96–579","children":[],"tail":" struck out subsec. (a) designation and subsec. (b) authorizing the Secretary of Defense for national security reasons to waive the enlistment and induction limitation based on percentile limits conditioned upon notification of the Congress and a concurrent resolution of approval."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7d76d30-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7d76d31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIV/s402/b/2"},"text":"Pub. L. 97–86, title IV, § 402(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1105"},"text":"95 Stat. 1105","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/86/tIV/s402/b/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall take effect at the end of the 30-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7d76d32-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Future Servicemember Preparatory Course","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s546"},"text":"Pub. L. 118–31, div. A, title V, § 546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/266"},"text":"137 Stat. 266","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s531"},"text":"Pub. L. 118–159, div. A, title V, § 531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1886"},"text":"138 Stat. 1886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s534"},"text":"Pub. L. 119–60, div. A, title V, § 534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/870"},"text":"139 Stat. 870","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tV/s534"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the number of nonprior service enlisted personnel covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s520"},"text":"section 520 of title 10","children":[],"tail":", United States Code, exceeds 10 percent of the total number of persons originally enlisted in an Armed Force during a fiscal year, the Secretary concerned shall establish a future servicemember preparatory course within the Armed Force concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The course established under subsection (a) shall be designed to improve the physical and aptitude qualifications of military recruits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each course established under this section shall comply with the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enrollment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All nonprior service enlisted persons whose score on the Armed Forces Qualification Test is below the thirty-first percentile must be enrolled in the course prior to attending initial basic training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Graduation requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to attending initial basic training, all enlisted persons attending the course established under this section must achieve a score on the Armed Forces Qualification Test that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 10 points higher than the individual’s most recent score taken prior to the individual’s date of enlistment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no longer subject to the restrictions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s520"},"text":"section 520 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of course failure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any enlisted person who fails to achieve meaningful progress, as determined by the Secretary concerned, within 90 days of enlistment shall be separated under regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of course graduation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may exclude from the population to be considered for purposes of determining the percentage limitations imposed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s520/a"},"text":"section 520(a) of title 10","children":[],"tail":", United States Code, any enlisted person who has graduated from a future servicemember preparatory course established pursuant to this section with a score on the Armed Forces Qualification Test that is at or above the thirty-first percentile, provided that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Armed Forces Qualifications Test score that is at or above the thirty-first percentile is obtained within the same fiscal year in which the individual was originally enlisted to serve on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such score is obtained during the period the individual was originally enlisted to serve on active duty, as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a preparatory course under this section is established by the Secretary concerned, the Secretary shall submit to the Committees on Armed Services of the Senate and House of Representatives a report on the structure and results of the course for the preceding fiscal year by December 1st of the subsequent fiscal year. The report shall include the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of nonprior service enlisted persons who scored below the thirty-first percentile on the Armed Forces Qualification Test upon original enlistment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The percentage of nonprior service enlisted persons who scored below the thirty-first percentile on the Armed Forces Qualification Test following graduation from the preparatory course or subsequent reclassification, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals who attended the preparatory course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of individuals who graduated the preparatory course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average improvement in the Armed Forces Qualification Test score for individuals who graduated from the preparatory course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The determination of the Secretary regarding the effectiveness of the preparatory course.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Recommendations of the Secretary regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to improve the preparatory course;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to expand the preparatory course.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other matter the Secretary determines relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of this section shall expire on September 30th, 2028.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7d76d33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program for Treating GED and Home School Diploma Recipients as High School Graduates for Determinations of Eligibility for Enlistment in Armed Forces","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s571"},"text":"Pub. L. 105–261, div. A, title V, § 571","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2033"},"text":"112 Stat. 2033","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/3"},"text":"Pub. L. 106–65, div. A, title X, § 1067(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":", directed the Secretary of Defense to establish a pilot program during the period "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","c