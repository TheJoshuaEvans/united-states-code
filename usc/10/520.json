2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/629"},"text":"97 Stat. 629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tIV/s402"},"text":"Pub. L. 98–525, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2516"},"text":"98 Stat. 2516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tIV/s402"},"text":"Pub. L. 99–145, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/618"},"text":"99 Stat. 618","children":[],"tail":", provided that the number of male individuals enlisted or inducted into the Army during the fiscal year beginning on "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", who were not high school graduates could not exceed, as of "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", 35 percent of all male individuals enlisted or inducted into the Army during such fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7d76d35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Denial of Enlistment for Lack of High School Diploma Prohibited","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/307/tIV/s401"},"text":"Pub. L. 93–307, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-06-08"},"text":"June 8, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/234"},"text":"88 Stat. 234","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href"