tion 10212 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 279, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/5/C"},"text":"Pub. L. 85–861, § 1(5)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1439"},"text":"72 Stat. 1439","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s11/2"},"text":"Pub. L. 94–273, § 11(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/378"},"text":"90 Stat. 378","children":[],"tail":", directed Secretary of Defense to report to President and Congress, in January of each year, on the status of training of each reserve component and the progress made in strengthening the reserve components during the preceding fiscal year, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/485/s406/b/1"},"text":"Pub. L. 95–485, § 406(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7970903-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s379"},"text":"section 379 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (b)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/u