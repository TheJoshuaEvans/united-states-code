{"tag":"section","attrib":{"id":"ida79708f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279"},"text":null,"children":[{"tag":"num","attrib":{"value":"279"},"text":"§ 279.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of Coast Guard personnel to naval vessels for law enforcement purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida79708f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and the Secretary of Homeland Security shall provide that there be assigned on board every appropriate surface naval vessel at sea in a drug-interdiction area members of the Coast Guard who are trained in law enforcement and have powers of the Coast Guard under title 14, including the power to make arrests and to carry out searches and seizures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79708f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Members of the Coast Guard assigned to duty on board naval vessels under this section shall perform such law enforcement functions (including drug-interdiction functions)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida79708fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as may be agreed upon by the Secretary of Defense and the Secretary of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida79708fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as are otherwise within the jurisdiction of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79708fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No fewer than 500 active duty personnel of the Coast Guard shall be assigned each fiscal year to duty under this section. However, if at any time the Secretary of Homeland Security, after consultation with the Secretary of Defense, determines that there are insufficient naval vessels available for purposes of this section, such personnel may be assigned other duty involving enforcement of laws listed in section 374(b)(4)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida79708fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s279/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “drug-interdiction area” means an area outside the land area of the United States (as defined in section 374(b)(4)(B) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title) in which the Secretary of Defense (in consultation with the Attorney General) determines that activities involving smuggling of drugs into the United States are ongoing."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida79708fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIII/s3053/b/1"},"text":"Pub. L. 99–570, title III, § 3053(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-75"},"text":"100 Stat. 3207–75","children":[],"tail":", § 379; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXI/s1104/a"},"text":"Pub. L. 100–456, div. A, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2045"},"text":"102 Stat. 2045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; renumbered § 279, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida79708ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7970900-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7970901-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"