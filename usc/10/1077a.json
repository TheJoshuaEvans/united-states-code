{"tag":"section","attrib":{"id":"ida87e5c3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1077a"},"text":"§ 1077a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to military medical treatment facilities and other facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida87e5c3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Urgent Care","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87e5c3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall ensure that military medical treatment facilities, at locations the Secretary determines appropriate, provide urgent care services for members of the armed forces and covered beneficiaries until 11:00 p.m. each day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5c40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to areas in which a military medical treatment facility covered by paragraph (1) is not located, the Secretary shall ensure that members of the armed forces and covered beneficiaries may access urgent care clinics through the health care provider network under the TRICARE program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5c41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A covered beneficiary may access urgent care services without the need for preauthorization for such services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5c42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87e5c43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish information about changes in access to urgent care under the TRICARE program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida87e5c44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the primary publicly available Internet website of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida87e5c45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the primary publicly available Internet website of each military medical treatment facility; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87e5c46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such information is made available on the publicly available Internet website of each current managed care support contractor that has established a health care provider network under the TRICARE program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5c47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nurse Advice Line","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the nurse advice line of the Department directs covered beneficiaries seeking access to care to the source of the most appropriate level of health care required to treat the medical conditions of the beneficiaries, including urgent care services described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida87e5c48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary Care Clinics","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida87e5c49-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that primary care clinics at military medical treatment facilities are available for members of the armed forces and covered beneficiaries between the hours determined appropriate under paragraph (2), including with respect to expanded hours described in subparagraph (B) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida87e5c4a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida87e5c4b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall determine the hours that each primary care clinic at a military medical treatment facility is available for members of the armed forces and covered beneficiaries based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida87e5c4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of the military medical treatment facility to meet the access standards under the TRICARE Prime program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida87e5c4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary care utilization patterns of members and covered beneficiaries at such military medical treatment facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida87e5c4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1077a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The primary care clinic hours at a military medical treatment facility determined under subparagraph (A) shall include expanded hours beyond regular business hours during weekdays and the weekend if the Secretary determines under such subparagraph that sufficient demand exists at the military medical treatment facility for such expanded primary care clinic hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida87e5c4f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s704/a"},"text":"Pub. L. 114–328, div. A, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2200"},"text":"130 Stat. 2200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida87e5c50-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida87e5c51-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida87e5c52-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s704/c"},"text":"Pub. L. 114–328, div. A, title VII, § 704(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2201"},"text":"130 Stat. 2201","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tVII/s704/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense shall implement—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1077a"},"text":"section 1077a of title 10","children":[],"tail":", United States Code, as added by subsection (a) of this section, by not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c) of such section by not later than 180 days after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
