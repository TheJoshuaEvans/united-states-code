{"tag":"section","attrib":{"id":"idaa8af468-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4704"},"text":null,"children":[{"tag":"num","attrib":{"value":"4704"},"text":"§ 4704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense contractors: listing of suitable employment openings with local employment service office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa8af469-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall promulgate regulations containing the requirement described in subsection (b) and such other provisions as the Secretary considers necessary to administer such requirement. Such regulations shall require that each contract described in subsection (c) shall contain a clause requiring the contractor to comply with such regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af46a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations promulgated under this section shall require each contractor carrying out a contract described in subsection (c) to list immediately with the appropriate local employment service office, and where appropriate the Interstate Job Bank (established by the United States Employment Service), all of its suitable employment openings under such contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa8af46b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations promulgated under this section shall apply to any contract entered into with the Department of Defense in an amount of $500,000 or more.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa8af46c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4470/a/1"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4470(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2753"},"text":"106 Stat. 2753","children":[],"tail":", § 2410d; renumbered § 2410k and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII"},"text":"Pub. L. 103–35, title II","children":[],"tail":", §§ 201(b)(1)(A), 202(a)(18)(A), "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/97"},"text":"107 Stat. 97","children":[],"tail":", 102; renumbered § 4704, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1863/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1863(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4278"},"text":"134 Stat. 4278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa8af46d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa8af46e-3a6f-11f1-a58a-d8