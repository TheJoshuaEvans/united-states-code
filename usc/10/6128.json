{"tag":"section","attrib":{"id":"idaabf7239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128"},"text":null,"children":[{"tag":"num","attrib":{"value":"6128"},"text":"§ 6128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plutonium pit production capacity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabf723a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the requirements of the Secretary of Defense, the Secretary of Energy shall ensure that the nuclear security enterprise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf723b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during 2021, begins production of qualification plutonium pits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf723c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during 2024, produces not less than 10 war reserve plutonium pits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf723d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during 2025, produces not less than 20 war reserve plutonium pits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf723e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during 2026, produces not less than 30 war reserve plutonium pits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf723f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during 2030, produces not less than 80 war reserve plutonium pits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf7240-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2015-03-01"},"text":"March 1, 2015","children":[],"tail":", and each year thereafter through 2030, the Secretary of Energy shall certify to the congressional defense committees and the Secretary of Defense that the programs and budget of the Secretary of Energy will enable the nuclear security enterprise to meet the requirements under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf7241-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Energy does not make a certification under subsection (b) by March 1 of any year in which a certification is required under that subsection, by not later than May 1 of such year, the Chairman of the Nuclear Weapons Council shall submit to the congressional defense committees a plan to enable the nuclear security enterprise to meet the requirements under subsection (a). Such plan shall include identification of the resources of the Department of Energy that the Chairman determines should be redirected to support the plan to meet such requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf7242-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certifications on Plutonium Enterprise","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf7243-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the date on which a covered project achieves a critical decision milestone, the Assistant Secretary for Environmental Management and the Deputy Administrator for Defense Programs shall jointly certify to the congressional defense committees that the operations, infrastructure, and workforce of such project are adequate to carry out the delivery and disposal of planned waste shipments relating to the plutonium enterprise, as outlined in the critical decision memoranda of the Department of Energy with respect to such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf7244-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Assistant Secretary for Environmental Management and the Deputy Administrator for Defense Programs fail to make a certification under paragraph (1) by the date specified in such paragraph with respect to a covered project achieving a critical decision milestone, the Assistant Secretary and the Deputy Administrator shall jointly submit to the congressional defense committees, by not later than 30 days after such date, a plan to ensure that the operations, infrastructure, and workforce of such project will be adequate to carry out the delivery and disposal of planned waste shipments described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf7245-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf7246-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 1 of each year during the period beginning on the date on which the first covered project achieves critical decision 2 in the acquisition process and ending on the date on which the second project achieves critical decision 4 and begins operations, the Administrator for Nuclear Security shall submit to the congressional defense committees a report on the planned production goals of both covered projects during the first 10 years of the operation of the projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf7247-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabf7248-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of war reserve plutonium pits planned to be produced during each year, including the associated warhead type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7249-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of risks and challenges to meeting the performance baseline for the covered projects, as approved in critical decision 2 in the acquisition process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf724a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options available to the Administrator to balance scope, costs, and production requirements at the projects to decrease overall risk to the plutonium enterprise and enduring plutonium pit requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf724b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of any changes to the production goals or requirements as compared to the report submitted during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf724c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capacity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary of Energy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf724d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that Los Alamos National Laboratory, Los Alamos, New Mexico, has the capability to reliably produce no fewer than 30 war reserve plutonium pits annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf724e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Savannah River Plutonium Processing Facility at the Savannah River Site, Aiken, South Carolina, has the capability to reliably produce no fewer than 50 war reserve plutonium pits annually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf724f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on ARIES Expansion Before Achievement of 30 Pit-per-year Base Capability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf7250-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Until the date on which the Administrator certifies to the congressional defense committees that the base capability to produce not less than 30 war reserve plutonium pits per year has been established at Los Alamos National Laboratory, the Administrator may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabf7251-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a project to expand the pit disassembly and processing capability of the spaces at PF–4 occupied by ARIES as of ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7252-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise expand such spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf7253-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) shall not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabf7254-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing or planned small projects to sustain or improve the efficiency of plutonium oxide production, provided that such projects do not expand the spaces at PF–4 occupied by ARIES as of ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7255-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning and design of an additional ARIES capability at a location other than PF–4; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7256-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of the ARIES capability to a location other than PF–4.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf7257-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabf7258-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “ARIES” means the Advanced Recovery and Integrated Extraction System method, developed and piloted at Los Alamos National Laboratory, Los Alamos, New Mexico, for disassembling surplus defense plutonium pits and converting the plutonium from such pits into plutonium oxide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabf7259-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “PF–4” means the Plutonium Facility at Technical Area 55 located at Los Alamos National Laboratory, Los Alamos, New Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf725a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management of Plutonium Modernization Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 570 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Administrator for Nuclear Security shall ensure that the plutonium modernization program established by the Office of Defense Programs of the National Nuclear Security Administration, or any subsequently developed program designed to meet the requirements under subsection (a), is managed in accordance with the best practices for schedule development and cost estimating of the Government Accountability Office."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabf725b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Project Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered project” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabf725c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Savannah River Plutonium Processing Facility, Savannah River Site, Aiken, South Carolina (Project 21–D–511); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabf725d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6128/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Plutonium Pit Production Project, Los Alamos National Laboratory, Los Alamos, New Mexico (Project 21–D–512).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabf725e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI"},"text":"Pub. L. 119–60, div. C, title XXXI","children":[],"tail":", §§ 3111(a), (d)(1)(B), (2), 3112, "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1363"},"text":"139 Stat. 1363","children":[],"tail":", 1461, 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabf725f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabf7260-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaabf7261-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3112"},"text":"section 3112 of Pub. L. 119–60","children":[],"tail":" directed to "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4219"},"text":"section 4219 of Pub. L. 107–314","children":[],"tail":" executed to this section pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/1/B"},"text":"section 3111(d)(1)(B) of Pub. L. 119–60","children":[],"tail":". See Further Technical Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6114"},"text":"section 6114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabf7262-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2538a"},"text":"section 2538a of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaabf7263-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Failure to certify","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", §§ 3111(d)(1)(B), 3112(4), added subsec. (f). Former subsec. (f) redesignated (g). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (3) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":"”, “"},{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":"”, and “"},{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":"”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", §§ 3111(d)(1)(B), 3112(1), redesignated subsec. (f) as (g). Former subsec. (g) redesignated (i). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", §§ 3111(d)(1)(B), 3112(1)–(3), redesignated subsec. (g) as (i) and moved subsec. (i) so as to appear after subsec. (h) and substituted “this section” for “this subsection” in introductory provisions. See Codification note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
