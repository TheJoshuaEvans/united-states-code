{"tag":"section","attrib":{"id":"ida8ff2511-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1602"},"text":null,"children":[{"tag":"num","attrib":{"value":"1602"},"text":"§ 1602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ff2512-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Fix Rates of Basic Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense (subject to the provisions of this section) shall fix the rates of basic pay for positions established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1601"},"text":"section 1601 of this title","children":[],"tail":" in relation to the rates of pay provided for comparable positions in the Department of Defense and subject to the same limitations on maximum rates of pay established for employees of the Department of Defense by law or regulation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff2513-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prevailing Rate Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5341"},"text":"section 5341 of title 5","children":[],"tail":", adopt such provisions of that title as provide for prevailing rate systems of basic pay and may apply those provisions to positions for civilian employees in or under which the Department of Defense may employ individuals described by section 5342(a)(2)(A) of that title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ff2514-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/a/3"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2746"},"text":"110 Stat. 2746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tXI/s1103/a"},"text":"Pub. L. 108–375, div. A, title XI, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2072"},"text":"118 Stat. 2072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/g/12"},"text":"Pub. L. 109–364, div. A, title X, § 1071(g)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2403"},"text":"120 Stat. 2403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ff2515-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ff2516-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8ff2517-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1602 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1621"},"text":"section 1621 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 1590(b) and (c) and 1604(b)(1) and (c) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", §§ 1632(a)(3), 1633(a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ff2518-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1103/a/1"},"text":"Pub. L. 108–375, § 1103(a)(1)","children":[],"tail":". See 2004 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1103/a/1"},"text":"Pub. L. 108–375, § 1103(a)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":", substituted “in relation to the rates of pay provided for comparable positions in the Department of Defense and subject to the same limitations on maximum rates of pay established for employees of the Department of Defense by law or regulation” for “in relation to the rates of basic pay provided in subpart D of part III of title 5 for positions subject to that subpart which have corresponding levels of duties and responsibilities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1103/a/2"},"text":"Pub. L. 108–375, § 1103(a)(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and struck out heading and text