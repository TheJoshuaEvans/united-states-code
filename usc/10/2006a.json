{"tag":"section","attrib":{"id":"ida91e1dfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006a"},"text":"§ 2006a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for education and training: availability of certain assistance for use only for certain programs of education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida91e1dfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective as of ","children":[{"tag":"date","attrib":{"date":"2014-08-01"},"text":"August 1, 2014","children":[],"tail":", an individual eligible for assistance under a Department of Defense educational assistance program or authority covered by this section may, except as provided in subsection (b), only use such assistance for educational expenses incurred for a program as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91e1dff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An eligible program (as defined in section 481 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1088"},"text":"20 U.S.C. 1088","children":[],"tail":")) that is offered by an institution of higher education that has entered into, and is complying with, a program participation agreement under section 487 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1094"},"text":"20 U.S.C. 1094","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91e1e00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a program designed to prepare individuals for licensure or certification in any State, if the program meets the instructional curriculum licensure or certification requirements of such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91e1e01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a program designed to prepare individuals for employment pursuant to standards developed by a State board or agency in an occupation that requires approval or licensure for such employment, if the program is approved or licensed by such State board or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91e1e02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may, by regulation, authorize the use of educational assistance under a Department of Defense educational assistance program or authority covered by this chapter for educational expenses incurred for a program of education that is not described in subsection (a) if the program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91e1e03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited and approved by a nationally or regionally recognized accrediting agency or association recognized by the Department of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91e1e04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not an eligible program described in subsection (a) at any time during the most recent two-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91e1e05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a program that the Secretary determines would further the purposes of the educational assistance programs or authorities covered by this chapter, or would further the education interests of students eligible for assistance under such programs or authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91e1e06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institution providing the program does not provide any commission, bonus, or other incentive payment based directly or indirectly on success in securing enrollments or financial aid to any persons or entities engaged in any student recruiting or admission activities or in making decisions regarding the award of student financial assistance, except for the recruitment of foreign students residing in foreign countries who are not eligible to receive Federal student assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91e1e07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91e1e08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Department of Defense educational assistance programs and authorities covered by this section” means the programs and authorities as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida91e1e09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The programs to assist military spouses in achieving education and training to expand employment and portable career opportunities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1784a"},"text":"section 1784a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91e1e0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to pay tuition for off-duty training or education of members of the armed forces under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2007"},"text":"section 2007 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91e1e0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program of educational assistance for members of the Selected Reserve under chapter 1606 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91e1e0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program of educational assistance for reserve component members supporting contingency operations and certain other operations under chapter 1607 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida91e1e0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other program or authority of the Department of Defense for assistance in education or training carried out under the laws administered by the Secretary of Defense that is designated by the Secretary, by regulation, for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91e1e0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2006a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given that term in section 102 of the Higher Education Act for 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida91e1e0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV/s541/a"},"text":"Pub. L. 113–66, div. A, title V, § 541(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/760"},"text":"127 Stat. 760","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1081/a/6"},"text":"Pub. L. 114–92, div. A, title X, § 1081(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1001"},"text":"129 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/15"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1984"},"text":"132 Stat. 1984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida91e1e10-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida91e1e11-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida91e1e12-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “such programs” for “the such programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “August 1” for “August, 1” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida91e1e13-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida91e1e14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tV/s541/c"},"text":"Pub. L. 113–66, div. A, title V, § 541(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/762"},"text":"127 Stat. 762","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/66/dA/tV/s541/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2014-08-01"},"text":"August 1, 2014","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
