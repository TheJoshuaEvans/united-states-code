{"tag":"section","attrib":{"id":"idaac1e341-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6152"},"text":null,"children":[{"tag":"num","attrib":{"value":"6152"},"text":"§ 6152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Completion of material protection, control, and accounting activities in the Russian Federation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac1e342-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b) or specifically authorized by Congress, international material protection, control, and accounting activities in the Russian Federation shall be completed not later than fiscal year 2018.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac1e343-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation in subsection (a) shall not apply to international material protection, control, and accounting activities in the Russian Federation associated with the Agreement Concerning the Management and Disposition of Plutonium Designated as No Longer Required for Defense Purposes and Related Cooperation, signed at Moscow and Washington August 29 and ","children":[{"tag":"date","attrib":{"date":"2000-09-01"},"text":"September 1, 2000","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"2011-07-13"},"text":"July 13, 2011","children":[],"tail":" (TIAS 11–713.1), between the United States and the Russian Federation."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac1e344-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1372"},"text":"139 Stat. 1372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac1e345-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac1e346-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac1e347-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6152 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8263"},"text":"section 8263 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s3122/b"},"text":"section 3122(b) of Pub. L. 113–291","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2565"},"text":"section 2565 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/14"},"text":"Pub. L. 119–60, § 3111(b)(14)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
