{"tag":"section","attrib":{"id":"idaba6c448-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642"},"text":null,"children":[{"tag":"num","attrib":{"value":"12642"},"text":"§ 12642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and qualifications: result of failure to comply with","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba6c449-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be retained in an active status, a reserve commissioned officer must, in any applicable yearly period, attain the number of points under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732/a/2"},"text":"section 12732(a)(2) of this title","children":[],"tail":" prescribed by the Secretary concerned, with the approval of the Secretary of Defense in the case of a Secretary of a military department, and must conform to such other standards and qualifications as the Secretary concerned may prescribe. The Secretary may not prescribe a minimum of more than 50 points under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c44a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12645"},"text":"section 12645 of this title","children":[],"tail":", a reserve commissioned officer who fails to attain the number of points, or to conform to the standards and qualifications, prescribed in subsection (a) shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba6c44b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be transferred to the Retired Reserve if he is qualified and applies therefor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c44c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is not qualified or does not apply for transfer to the Retired Reserve, be transferred to an inactive status, if he is qualified therefor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba6c44d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is not transferred to the Retired Reserve or an inactive status, be discharged from his reserve appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c44e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to commissioned warrant officers or to adjutants general or assistant adjutants general of States, Puerto Rico, and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba6c44f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/22/A"},"text":"Pub. L. 85–861, § 1(22)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1443"},"text":"72 Stat. 1443","children":[],"tail":", § 1002; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},