{"tag":"section","attrib":{"id":"ida8916ea3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"§ 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource allocation methods: capitation or diagnosis-related groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8916ea4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Capitation or DRG Method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, after consultation with the other administering Secretaries, shall establish by regulation the use of capitation or diagnosis-related groups as the primary criteria for allocation of resources to facilities of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ea5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Mobilization Missions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Capitation or diagnosis-related groups shall not be used to allocate resources to the facilities of the uniformed services to the extent that such resources are required by such facilities for mobilization missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8916ea6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such regulations may establish a system of diagnosis-related groups similar to the system established under section 1886(d)(4) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww/d/4"},"text":"42 U.S.C. 1395ww(d)(4)","children":[],"tail":"). Such regulations may include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8916ea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A classification of inpatient treatments by diagnosis-related groups and a similar classification of outpatient treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916ea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A methodology for classifying specific treatments within such groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916ea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appropriate weighting factor for each such diagnosis-related group which reflects the relative resources used by a facility of a uniformed service with respect to treatments classified within that group compared to treatments classified within other groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8916eaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1101/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appropriate method for calculating or estimating the annual per capita costs of providing comprehensive health care services to members of the uniformed services on active duty and covered beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8916eab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVII/s701/a/1"},"text":"Pub. L. 99–661, div. A, title VII, § 701(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3897"},"text":"100 Stat. 3897","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1233/e/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1233(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2057"},"text":"102 Stat. 2057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVII/s714/a"},"text":"Pub. L. 103–160, div. A, title VII, § 714(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1690"},"text":"107 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8916eac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8916ead-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8916eae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s714/b/1"},"text":"Pub. L. 103–160, § 714(b)(1)","children":[],"tail":", substituted “Resource allocation methods: capitation or diagnosis-related groups” for “Diagnosis-related groups” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s714/a/1"},"text":"Pub. L. 103–160, § 714(a)(1)","children":[],"tail":", substituted “Capitation or DRG Method” for “DRGs” in heading and inserted “capitation or” before “diagnosis-related groups” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s714/a/2"},"text":"Pub. L. 103–160, § 714(a)(2)","children":[],"tail":", substituted “Capitation or diagnosis-related groups” for “Diagnosis-related groups”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s714/a/3"},"text":"Pub. L. 103–160, § 714(a)(3)","children":[],"tail":", substituted “may” for “shall” in two places in introductory provisions and added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “(1)” before “Such regulations” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8916eaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8916eb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVII/s724"},"text":"Pub. L. 101–189, div. A, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1478"},"text":"103 Stat. 1478","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVII/s719"},"text":"Pub. L. 102–190, div. A, title VII, § 719","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1404"},"text":"105 Stat. 1404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tVII/s719"},"text":"“The regulations required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1101/a"},"text":"section 1101(a) of title 10","children":[],"tail":", United States Code, to establish the use of diagnosis-related groups as the primary criteria for the allocation of resources to health care facilities of the uniformed services shall be prescribed to take effect not later than "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", in the case of outpatient treatments.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVII/s701/d/4"},"text":"Pub. L. 99–661, div. A, title VII, § 701(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3898"},"text":"100 Stat. 3898","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII/s724"},"text":"Pub. L. 100–180, div. A, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1116"},"text":"101 Stat. 1116","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/180/dA/tVII/s724"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense shall prescribe regulations as required by section 1101(a) of such title (as added by subsection (a)(1)) to take effect—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of inpatient treatments, not later than ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of outpatient treatments, not later than ","children":[{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
