{"tag":"section","attrib":{"id":"ida8fa6972-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1592"},"text":null,"children":[{"tag":"num","attrib":{"value":"1592"},"text":"§ 1592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on payment of severance pay to foreign nationals in the event of certain overseas base closures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds available to the Department of Defense (including funds in the Foreign National Employees Separation Pay Account, Defense, established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1581"},"text":"section 1581 of this title","children":[],"tail":") may not be used to pay severance pay to a foreign national employed by the Department of Defense under a contract, a treaty, or a memorandum of understanding with a foreign nation that provides for payment of separation pay if the termination of the employment of the foreign national is the result of the closing of, or the curtailment of activities at, a United States military facility in that country at the request of the government of that country."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8fa6973-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s311/b/1"},"text":"Pub. L. 101–189, div. A, title III, § 311(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1411"},"text":"103 Stat. 1411","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1003/b"},"text":"Pub. L. 102–190, div. A, title X, § 1003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1456"},"text":"105 Stat. 1456","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/21"},"text":"Pub. L. 102–484, div. A, title X, § 1052(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2500"},"text":"106 Stat. 2500","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fa6974-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fa6975-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida8fa6976-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 1592 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1596"},"text":"section 1596 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fa6977-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" inserted “section” after “established under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" inserted “(including funds in the Foreign National Employees Separation Pay Account, Defense, established under 1581 of this title)” and substituted “a contract, a treaty, or a memorandum of understanding with a foreign nation that provides for payment of separation pay” for “a contract performed in a foreign country”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fa6978-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8fa6979-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIII/s311/b/3"},"text":"Pub. L. 101–189, div. A, title III, § 311(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1412"},"text":"103 Stat. 1412","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXIII/s1352/a"},"text":"Pub. L. 102–484, div. A, title XIII, § 1352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2558"},"text":"106 Stat. 2558","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tXIII/s1352/a"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1592"},"text":"Section 1592 of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“[(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXIII/s1352/a"},"text":"Pub. L. 102–484, div. A, title XIII, § 1352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2558"},"text":"106 Stat. 2558","children":[],"tail":".]”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8fa697a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Payment of Severance Pay to Certain Foreign Nationals in the Philippines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXIII/s1351"},"text":"Pub. L. 102–484, div. A, title XIII, § 1351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2558"},"text":"106 Stat. 2558","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tXIII/s1351"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds available to the Department of Defense may not be used to pay severance pay to a foreign national employed by the Department of Defense in the Republic of the Philippines if the discontinuation of the employment of the foreign national is the result of the termination of basing rights of the United States military in the Republic of the Philippines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Allowance of Certain Severance Pay as Contract Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds available to the Department of Defense may not be used to pay the costs of severance pay paid by a contractor to a foreign national employed by the contractor under a defense service contract in the Philippines if the discontinuation of the employment of the foreign national is the result of the termination of basing rights of the United States military in the Philippines.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
