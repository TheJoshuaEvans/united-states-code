{"tag":"section","attrib":{"id":"ida901958e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610"},"text":null,"children":[{"tag":"num","attrib":{"value":"1610"},"text":"§ 1610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions and other adjustments in force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida901958f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations for the separation of employees in defense intelligence positions, including members of the Defense Intelligence Senior Executive Service and employees in Intelligence Senior Level positions, during a reduction in force or other adjustment in force. The regulations shall apply to such a reduction in force or other adjustment in force notwithstanding sections 3501(b) and 3502 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019590-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Given Effect","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations shall give effect to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9019591-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tenure of employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019592-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military preference, subject to sections 3501(a)(3) and 3502(b) of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019593-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The veteran’s preference under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3502/b"},"text":"section 3502(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019594-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019595-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Length of service computed in accordance with the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3502/a"},"text":"section 3502(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019596-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Relating to Defense Intelligence SES","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations relating to removal from the Defense Intelligence Senior Executive Service in a reduction in force or other adjustment in force shall be consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3595/a"},"text":"section 3595(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9019597-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right of Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9019598-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations shall provide a right of appeal regarding a personnel action under the regulations. The appeal shall be determined within the Department of Defense. An appeal determined at the highest level provided in the regulations shall be final and not subject to review outside the Department of Defense. A personnel action covered by the regulations is not subject to any other provision of law that provides appellate rights or procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019599-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), a preference eligible referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7511/a/1/B"},"text":"section 7511(a)(1)(B) of title 5","children":[],"tail":" may elect to have an appeal of a personnel action taken against the preference eligible under the regulation determined by the Merit Systems Protection Board instead of having the appeal determined within the Department of Defense. "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701"},"text":"Section 7701 of title 5","children":[],"tail":" shall apply to any such appeal to the Merit Systems Protection Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida901959a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1610/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With OPM","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations under this section shall be prescribed in consultation with the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida901959b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/b"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2749"},"text":"110 Stat. 2749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida901959c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida901959d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida901959e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
