{"tag":"section","attrib":{"id":"ida91236e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782"},"text":null,"children":[{"tag":"num","attrib":{"value":"1782"},"text":"§ 1782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveys of military families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida91236ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, in order to determine the effectiveness of Federal programs relating to military families and the need for new programs, may conduct surveys of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida91236eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the armed forces who are on active duty, in an active status, or retired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91236ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family members of such members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida91236ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survivors of deceased retired members and of members who died while on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91236ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responses To Be Voluntary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Responses to surveys conducted under this section shall be voluntary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91236ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Recordkeeping Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a survey authorized under subsection (a) that includes a person referred to in that subsection who is not an employee of the United States or is not otherwise considered an employee of the United States for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502/3/A/i"},"text":"section 3502(3)(A)(i) of title 44","children":[],"tail":", the person shall be considered as being an employee of the United States for the purposes of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida91236f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1782/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Survey Required for Fiscal Year","children":[],"tail":" 2010.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), during fiscal year 2010, the Secretary of Defense shall conduct a survey otherwise authorized under such subsection. Thereafter, additional surveys may be conducted not less often than once every three fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida91236f1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s568/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 568(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/330"},"text":"110 Stat. 330","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s572"},"text":"Pub. L. 107–107, div. A, title V, § 572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1122"},"text":"115 Stat. 1122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tV/s581/c"},"text":"Pub. L. 110–181, div. A, title V, § 581(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/122"},"text":"122 Stat. 122","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida91236f2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida91236f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida91236f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s572/a"},"text":"Pub. L. 107–107, § 572(a)","children":[],"tail":", reenacted heading without change and amended text generally. Text read as follows: “The Secretary of Defense may conduct surveys of members of the armed forces on active duty or in an active status, members of the families of such members, and retired members of the armed forces to determine the effectiveness of Federal programs relating to military families and the need for new programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s572/b"},"text":"Pub. L. 107–107, § 572(b)","children":[],"tail":", reenacted heading without change and amended text generally. Text read as follows: “With respect to such surveys, family members of members of the armed forces and reserve and retired members of the armed forces shall be considered to be employees of the United States for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502/3/A/i"},"text":"section 3502(3)(A)(i) of title 44","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
