{"tag":"section","attrib":{"id":"idaacb5911-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276"},"text":null,"children":[{"tag":"num","attrib":{"value":"6276"},"text":"§ 6276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund transfer authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacb5912-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer to Other Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy may transfer funds authorized to be appropriated to the Department of Energy pursuant to a DOE national security authorization to other Federal agencies for the performance of work for which the funds were authorized. Funds so transferred may be merged with and be available for the same purposes and for the same time period as the authorizations of the Federal agency to which the amounts are transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb5913-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer Within Department of Energy","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5914-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of Energy may transfer funds authorized to be appropriated to the Department of Energy pursuant to a DOE national security authorization to any other DOE national security authorization. Amounts of authorizations so transferred may be merged with and be available for the same purposes and for the same period as the authorization to which the amounts are transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5915-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 5 percent of any such authorization may be transferred to another authorization under paragraph (1). No such authorization may be increased or decreased by more than 5 percent by a transfer under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb5916-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority provided by this subsection to transfer authorizations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacb5917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be used only to provide funds for items relating to activities necessary for national security programs that have a higher priority than the items from which the funds are transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacb5918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used to provide funds for an item for which Congress has specifically denied funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacb5919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6276/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall promptly notify the congressional defense committees of any transfer of funds to or from any DOE national security authorization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacb591a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1428"},"text":"139 Stat. 1428","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacb591b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacb591c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacb591d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2745"},"text":"section 2745 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacb591e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: “"},{"tag":"inline","attrib":{},"text":"Transfers permitted","children":[],"tail":"” and “"},{"tag":"inline","attrib":{},"text":"Maximum amounts","children":[],"tail":"”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
