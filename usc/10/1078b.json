{"tag":"section","attrib":{"id":"ida880ccae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1078b"},"text":"§ 1078b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of food to certain members and dependents not receiving inpatient care in military medical treatment facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida880ccaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida880ccb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of Defense, the Secretary may provide food and beverages to an individual described in paragraph (2) at no cost to the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida880ccb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual described in this paragraph is the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida880ccb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member or former member of the uniformed services or dependent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida880ccb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is receiving outpatient medical care at a military medical treatment facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida880ccb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whom the Secretary determines is unable to purchase food and beverages while at such facility by virtue of receiving such care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida880ccb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member or former member of the uniformed services or dependent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida880ccb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a family member of an infant receiving inpatient medical care at a military medical treatment facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida880ccb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who provides care to the infant while the infant receives such inpatient medical care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida880ccb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whom the Secretary determines is unable to purchase food and beverages while at such facility by virtue of providing such care to the infant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida880ccb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member or former member of the uniformed services or dependent whom the Secretary determines is under similar circumstances as a member, former member, or dependent described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida880ccba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1078b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that regulations prescribed under this section are consistent with generally accepted practices in private medical treatment facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida880ccbb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVII/s704/a"},"text":"Pub. L. 112–81, div. A, title VII, § 704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1472"},"text":"125 Stat. 1472","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tVII/s705"},"text":"Pub. L. 113–291, div. A, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3413"},"text":"128 Stat. 3413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida880ccbc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida880ccbd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida880ccbe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s705/1"},"text":"Pub. L. 113–291, § 705(1)","children":[],"tail":", substituted “A member or former member” for “A member” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s705/2"},"text":"Pub. L. 113–291, § 705(2)","children":[],"tail":", substituted “member, former member, or dependent” for “member or dependent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida880ccbf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida880ccc0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVII/s704/c"},"text":"Pub. L. 112–81, div. A, title VII, § 704(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1473"},"text":"125 Stat. 1473","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tVII/s704/c"},"text":"“The amendments made by this section [enacting this section] shall take effect on the date that is 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
