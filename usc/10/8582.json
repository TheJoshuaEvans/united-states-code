{"tag":"section","attrib":{"id":"idab31e287-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8582"},"text":null,"children":[{"tag":"num","attrib":{"value":"8582"},"text":"§ 8582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred annuity policy required","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each civilian member, as a part of his contract of employment, shall carry, during his employment, a deferred annuity policy, having no cash surrender or loan provision, in a joint-stock life insurance corporation that is incorporated under the laws of a State and has a charter restriction that its business must be conducted without profit to its stockholders.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab31e288-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/439"},"text":"70A Stat. 439","children":[],"tail":", § 7082; renumbered § 8582, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab31e289-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab31e28a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab31e28b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag