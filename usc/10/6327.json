{"tag":"section","attrib":{"id":"idaacdca92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327"},"text":null,"children":[{"tag":"num","attrib":{"value":"6327"},"text":"§ 6327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced procurement authority to manage supply chain risk","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdca93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary of Energy may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out a covered procurement action or special exclusion action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of law, limit, in whole or in part, the disclosure of information relating to the basis for carrying out a covered procurement action or special exclusion action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may exercise the authority under subsection (a) only after—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining a risk assessment that demonstrates that there is a significant supply chain risk to a covered system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" making a determination in writing, in unclassified or classified form, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the authority under subsection (a) is necessary to protect national security by reducing supply chain risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less restrictive measures are not reasonably available to reduce the supply chain risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which the Secretary plans to limit disclosure of information under subsection (a)(2), the risk to national security of the disclosure of the information outweighs the risk of not disclosing the information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submitting to the appropriate congressional committees, not later than seven days after the date on which the Secretary makes the determination under paragraph (2), a notice of such determination, in classified or unclassified form, that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/e/2/A"},"text":"section 3304(e)(2)(A) of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the risk assessment required under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the basis for the determination, including a discussion of less restrictive measures that were considered and why such measures were not reasonably available to reduce supply chain risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaa0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary has exercised the authority under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcaa1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify appropriate parties of the covered procurement action or special exclusion action and the basis for the action only to the extent necessary to carry out the covered procurement action or special exclusion action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcaa2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify other Federal agencies responsible for procurement that may be subject to the same or similar supply chain risk, in a manner and to the extent consistent with the requirements of national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcaa3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the confidentiality of any notifications under paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaa4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No action taken by the Secretary under the authority under subsection (a) shall be subject to review in any Federal court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaa5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may delegate the authority under this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcaa6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Administration, the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcaa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other component of the Department of Energy, the Senior Procurement Executive of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcaa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcaa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcaaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional defense committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcaab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate and the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcaac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered item of supply” means an item—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcaad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is purchased for inclusion in a covered system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcaae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss of integrity of which could result in a supply chain risk for a covered system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcaaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered procurement” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcab0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A source selection for a covered system or a covered item of supply involving either a performance specification, as described in subsection (a)(3)(B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3306"},"text":"section 3306 of title 41","children":[],"tail":", or an evaluation factor, as described in subsection (b)(1) of such section, relating to supply chain risk."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcab1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consideration of proposals for and issuance of a task or delivery order for a covered system or a covered item of supply, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4106/d/3"},"text":"section 4106(d)(3) of title 41","children":[],"tail":", where the task or delivery order contract concerned includes a contract clause establishing a requirement relating to supply chain risk."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcab2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contract action involving a contract for a covered system or a covered item of supply if the contract includes a clause establishing requirements relating to supply chain risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcab3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered procurement action” means, with respect to an action that occurs in the course of conducting a covered procurement, any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcab4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exclusion of a source that fails to meet qualification requirements established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3311"},"text":"section 3311 of title 41","children":[],"tail":" for the purpose of reducing supply chain risk in the acquisition of covered systems."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcab5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exclusion of a source that fails to achieve an acceptable rating with regard to an evaluation factor providing for the consideration of supply chain risk in the evaluation of proposals for the award of a contract or the issuance of a task or delivery order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcab6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The withholding of consent for a contractor to subcontract with a particular source or the direction to a contractor for a covered system to exclude a particular source from consideration for a subcontract under the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcab7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered system” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcab8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National security systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552/b"},"text":"section 3552(b) of title 44","children":[],"tail":") and components of such systems."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcab9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nuclear weapons and components of nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcaba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Items associated with the design, development, production, and maintenance of nuclear weapons or components of nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcabb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Items associated with the surveillance of the nuclear weapon stockpile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcabc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Items associated with the design and development of nonproliferation and counterproliferation programs and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcabd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “special exclusion action” means an action to prohibit, for a period not to exceed two years, the award of any contracts or subcontracts by the Administration or any other component of the Department of Energy related to any covered system to a source the Secretary determines to represent a supply chain risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcabe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “supply chain risk” means the risk that an adversary may sabotage, maliciously introduce unwanted function, or otherwise subvert the design, integrity, manufacturing, production, distribution, installation, operation, or maintenance of a covered system or covered item of supply so as to surveil, deny, disrupt, or otherwise degrade the function, use, or operation of the system or item of supply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcabf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6327/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdcac0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(A), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1444"},"text":"139 Stat. 1444","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdcac1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdcac2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdcac3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6327 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8327"},"text":"section 8327 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2786"},"text":"section 2786 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacdcac4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (7) headings which corresponded to the defined term in each par."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
