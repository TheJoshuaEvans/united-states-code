{"tag":"section","attrib":{"id":"ida9a15798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668"},"text":null,"children":[{"tag":"num","attrib":{"value":"2668"},"text":"§ 2668.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Easements for rights-of-way","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a15799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Types of Easements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of a military department finds that it will not be against the public interest, the Secretary may grant, upon such terms as the Secretary considers advisable, easements for rights-of-way over, in, and upon public lands permanently withdrawn or reserved for the use of that department, and other lands under the Secretary’s control for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a1579a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" railroad tracks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a1579b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas, water, sewer, and oil pipe lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a1579c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substations for electric power transmission lines and pumping stations for gas, water, sewer, and oil pipe lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a1579d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" canals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a1579e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ditches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a1579f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flumes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tunnels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dams and reservoirs in connection with fish and wildlife programs, fish hatcheries, and other improvements relating to fish-culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" roads and streets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poles and lines for the transmission or distribution of electric power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poles and lines for the transmission or distribution of communications signals (including telephone and telegraph signals);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" structures and facilities for the transmission, reception, and relay of such signals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other purpose that the Secretary considers advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a157a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Size of Easement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No easement granted under this section may include more land than is necessary for the easement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a157a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the military department concerned may terminate all or part of any easement granted under this section for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a157a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to comply with the terms of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonuse for a two-year period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a157ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abandonment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a157ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Department of the Interior","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Copies of instruments granting easements over public lands under this section shall be furnished to the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a157ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2668/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (c) and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667"},"text":"section 2667 of this title","children":[],"tail":" shall apply with respect to in-kind consideration and proceeds received by the Secretary of a military department in connection with an easement granted under this section in the same manner as such subsections apply to in-kind consideration and money rentals received pursuant to leases entered into by that Secretary under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a157ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/150"},"text":"70A Stat. 150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/38"},"text":"Pub. L. 98–525, title XIV, § 1405(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2624"},"text":"98 Stat. 2624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dB/tXXVIII/s2861"},"text":"Pub. L. 104–201, div. B, title XXVIII, § 2861",