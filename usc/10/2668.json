8(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2668(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"43:931b (less 2d and 3d provisos of 1st sentence, and less last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"43:931b (2d proviso of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-07-24/ch596/s7"},"text":"July 24, 1946, ch. 596, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/643"},"text":"60 Stat. 643","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-10-25/ch563/s101"},"text":"Oct. 25, 1951, ch. 563, § 101","children":[],"tail":" (31st through 43d words), "},{"tag":"html:a","attrib":{"href":"/us/stat/65/641"},"text":"65 Stat. 641","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2668(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"43:931b (3d proviso of 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2668(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"43:931b (last sentence) [43:931b is made applicable to the Navy by 50:171–1 (16th through 21st words)].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “conditions” is omitted as covered by the word “terms”. The description of the persons covered in the opening paragraph and the lands covered in clauses (1)–(10) is restated to reflect an opinion of the Judge Advocate General of the Army (JAGR 1952/3179, 27 Mar. 1952). The exceptions to clause (10) make express the fact that the revised section does not cover certain easements authorized by earlier law. The word “over” includes the word “across”. The words “of the United States”, “and empowered”, “acquired lands”, “jurisdiction and”, and “municipality” are omitted as surplusage. The word “Commonwealth” is inserted to reflect the present status of Puerto Rico.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “for the easement” are substituted for the words “for the purpose for which granted”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “easement” is substituted for the word “rights-of-way”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “terminate” is substituted for the words “annulled and forfeited”. The words “and conditions” are omitted as covered by the word “terms”. The words “two-year period” are substituted for the words “a period of two consecutive years”. The words “of rights granted under authority hereof” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading",