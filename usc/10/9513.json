{"tag":"section","attrib":{"id":"idab7e2dea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513"},"text":null,"children":[{"tag":"num","attrib":{"value":"9513"},"text":"§ 9513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for the inclusion or incorporation of defense features","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab7e2deb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Contract","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of chapter 137 ","children":[{"tag":"ref","attrib":{"idref":"fn002170"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and to the extent that funds are otherwise available for obligation, the Secretary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7e2dec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may contract with any citizen of the United States for the inclusion or incorporation of defense features in any new or existing aircraft to be owned or controlled by that citizen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2ded-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may contract with United States aircraft manufacturers for the inclusion or incorporation of defense features in new aircraft to be operated by a United States air carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2dee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commitment to Civil Reserve Air Fleet","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contract entered into under this section shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7e2def-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that any aircraft covered by the contract shall be committed to the Civil Reserve Air Fleet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2df0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, so long as the aircraft is owned or controlled by a contractor, the contractor shall operate the aircraft for the Department of Defense as needed during any activation of the Civil Reserve Air Fleet, notwithstanding any other contract or commitment of that contractor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2df1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the contractor operating the aircraft for the Department of Defense shall be paid for that operation at fair and reasonable rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2df2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Required Repayment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contract entered into under subsection (a) shall include a provision that requires the contractor to repay to the United States a percentage (to be established in the contract) of any amount paid by the United States to the contractor under the contract with respect to any aircraft if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7e2df3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is destroyed or becomes unusable, as defined in the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2df4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defense features specified in the contract are rendered unusable or are removed from the aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2df5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control over the aircraft is transferred to any person that is unable or unwilling to assume the contractor’s obligations under the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2df6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registration of the aircraft under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of title 49","children":[],"tail":" is terminated for any reason not beyond the control of the contractor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2df7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Contract and Pay Directly","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab7e2df8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract under subsection (a) for the inclusion or incorporation of defense features in an aircraft may include a provision authorizing the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab7e2df9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contract, with the concurrence of the contractor, directly with another person for the performance of the work necessary for the inclusion or incorporation of defense features in such aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab7e2dfa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay such other person directly for such work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab7e2dfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into pursuant to paragraph (1) may include such specifications for work and equipment as the Secretary considers necessary to meet the needs of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab7e2dfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusivity of Commitment to Civil Reserve Air Fleet","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 101 of the Defense Production Act of 1950 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4511"},"text":"50 U.S.C. 4511","children":[],"tail":"), each aircraft covered by a contract entered into under this section shall be committed exclusively to the Civil Reserve Air Fleet for use by the Department of Defense as needed during any activation of the Civil Reserve Air Fleet unless the aircraft is released from that use by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab7e2dfd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX/s915/2"},"text":"Pub. L. 97–86, title IX, § 915(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1126"},"text":"95 Stat. 1126","children":[],"tail":", § 9512; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/57"},"text":"Pub. L. 98–525, title XIV, § 1405(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2626"},"text":"98 Stat. 2626","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1636/b"},"text":"Pub. L. 101–189, div. A, title XVI, § 1636(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1609"},"text":"103 Stat. 1609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/b/3"},"text":"Pub. L. 103–272, § 5(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1373"},"text":"108 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tIII/s3032/1"},"text":"Pub. L. 103–355, title III, § 3032(1)","children":[],"tail":"–(8), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3334"},"text":"108 Stat. 3334","children":[],"tail":", 3335; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1087"},"text":"Pub. L. 104–106, div. A, title X, § 1087","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/458"},"text":"110 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/b/4/D"},"text":"Pub. L. 114–328, div. A, title X, § 1081(b)(4)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2419"},"text":"130 Stat. 2419","children":[],"tail":"; renumbered § 9513 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1083/a/2/B"},"text":"Pub. L. 117–81, div. A, title X, § 1083(a)(2)(B)","children":[],"tail":", (c)(1)(A), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1922"},"text":"135 Stat. 1922","children":[],"tail":", 1923.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab7e2dfe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab7e2dff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab7e2e00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 137 of this title, referred to in subsec. (a), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1881/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1881(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4293"},"text":"134 Stat. 4293","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", in conjunction with the transfer and reorganization of acquisition provisions in this title by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII"},"text":"Pub. L. 116–283, div. A, title XVIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4149"},"text":"134 Stat. 4149","children":[],"tail":". For definition of “chapter 137 legacy provisions”, see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3016"},"text":"section 3016 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idab7e2e01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsecs. (a) and (b) of prior ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9513"},"text":"section 9513 of this title","children":[],"tail":", which were redesignated as subsecs. (b) and (e) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s3032/4"},"text":"Pub. L. 103–355, § 3032(4)","children":[],"tail":", (5), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX/s915/2"},"text":"Pub. L. 97–86, title IX, § 915(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1128"},"text":"95 Stat. 1128","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1636/c/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1636(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1610"},"text":"103 Stat. 1610","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab7e2e02-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9513, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/tIII/s3033/a"},"text":"Pub. L. 103–355, title III, § 3033(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3335"},"text":"108 Stat. 3335","children":[],"tail":", related to use of military installations by Civil Reserve Air Fleet contractors, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1045/a"},"text":"Pub. L. 113–291, div. A, title X, § 1045(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3494"},"text":"128 Stat. 3494","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 9513, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/86/tIX/s915/2"},"text":"Pub. L. 97–86, title IX, § 915(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-01"},"text":"Dec. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1128"},"text":"95 Stat. 1128","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1636/c/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1636(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1610"},"text":"103 Stat. 1610","children":[],"tail":", directed that each contract under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9512"},"text":"section 9512 of this title","children":[],"tail":" be committed to Civil Reserve Air Fleet, prior to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s3032/4"},"text":"Pub. L. 103–355, § 3032(4)","children":[],"tail":", (5), (9), which struck out section catchline and redesignated subsecs. (a) and (b) as subsecs. (b) and (e) of section 9512, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab7e2e03-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"childre