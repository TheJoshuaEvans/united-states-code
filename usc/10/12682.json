{"tag":"section","attrib":{"id":"idaba6c4ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12682"},"text":null,"children":[{"tag":"num","attrib":{"value":"12682"},"text":"§ 12682.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserves: discharge upon becoming ordained minister of religion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations to be prescribed by the Secretary of Defense, a Reserve who becomes a regular or ordained minister of religion is entitled upon his request to a discharge from his reserve enlistment or appointment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaba6c4bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/i/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2997"},"text":"108 Stat. 2997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba6c4bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba6c4bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaba6c4be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1162/b"},"text":"section 1162(b) of this title","children":[],"tail":", prio