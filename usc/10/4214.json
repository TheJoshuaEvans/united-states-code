"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa6989ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa6989f0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s811/d/2/B"},"text":"Pub. L. 110–417, § 811(d)(2)(B)","children":[],"tail":", (3)(B), (4)(B)(i), which directed amendment of this section by inserting “or subprogram” after “the program” in subsec. (b) and after “the program” each place it appeared in subsecs. (c) and (d), was executed by making the insertions after “the program” each place it appeared in those subsecs. except after “designated major subprogram under the program”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added identical sections."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa6bfaf1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/b/4"},"text":"Pub. L. 116–283, § 1847(b)(4)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2435"},"text":"section 2435 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/b/4/A"},"text":"Pub. L. 116–283, § 1847(b)(4)(A)","children":[],"tail":", substituted “sections 4371 through 4375” for “section 2433”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/b/4/B/i"},"text":"Pub. L. 116–283, § 1847(b)(4)(B)(i)","children":[],"tail":", substituted “In this subpart” for “In this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/b/4/A"},"text":"Pub. L. 116–283, § 1847(b)(4)(A)","children":[],"tail":", (B)(ii), substituted “sections 4371 through 4375” for “section 2433” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4374"},"text":"section 4374 of this title","children":[],"tail":"” for “subsection (d) of such section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/b/4/B/iii"},"text":"Pub. L. 116–283, § 1847(b)(4)(B)(iii)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701"},"text":"Pub. L. 117–81, § 1701","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(6)(C)(i), substituted “section 4351” for “section 2432”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsecs. (b), (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “the Under Secretary of Defense for Acquisition and Sustainment” for “the Under Secretary of Defense for Acquisition, Technology, and Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s811/d/1"},"text":"Pub. L. 110–417, § 811(d)(1)","children":[],"tail":", inserted “and for each designated major subprogram under the program” after “major defense acquisition program” in par. (1) and “or designated major subprogram” after “major defense acquisition program” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s811/d/2"},"text":"Pub. L. 110–417, § 811(d)(2)","children":[],"tail":", inserted “or any designated major subprogram under the program” after “major defense acquisition program” and “or subprogram” after “after the program”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s811/d/3"},"text":"Pub. L. 110–417, § 811(d)(3)","children":[],"tail":", inserted “or any designated major subprogram under the program” after “major defense acquisition program” in introductory provisions and “or subprogram” after “the program” in pars. (1) to (3). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s811/d/4"},"text":"Pub. L. 110–417, § 811(d)(4)","children":[],"tail":", inserted “or any designated major subprogram under the program” after “major defense acquisition program” wherever appearing, in par. (1), inserted “or subprogram” after “to the program”, “before the program”, and “at program”, and, in par. (2), inserted “or subprogram” after “for the program” in two places. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s811/d/5"},"text":"Pub. L. 110–417, § 811(d)(5)","children":[],"tail":", inserted “(or in the case of a major defense acquisition program with one or more designated major subprograms, approved baseline descriptions for such subprograms)” after “baseline description” and “or subprogram” before period at end and substituted “any such baseline description” for “the baseline”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" inserted “prepared before the program enters system development and demonstration, or at program initiation, whichever occurs later” after “program under subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":", §§ 821(d)(1), 1048(b)(2), substituted “system development and demonstration” for “engineering and manufacturing development” and “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s821/d/2/A"},"text":"Pub. L. 107–107, § 821(d)(2)(A)","children":[],"tail":", substituted “system development and demonstration” for “demonstration and validation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s821/d/2/B"},"text":"Pub. L. 107–107, § 821(d)(2)(B)","children":[],"tail":", substituted “production and deployment” for “engineering and manufacturing development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s821/d/2/C"},"text":"Pub. L. 107–107, § 821(d)(2)(C)","children":[],"tail":", substituted “full rate production” for “production and deployment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/b/2"},"text":"Pub. L. 107–107, § 1048(b)(2)","children":[],"tail":", substituted “Under Secretary of Defense for Acquisition, Technology, and Logistics” for “Under Secretary of Defense for Acquisition and Technology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" amended section generally. Prior to amendment, section related to enhanced program stability."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" substituted “Under Secretary of Defense for Acquisition and Technology” for “Under Secretary of Defense for Acquisition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1484/k/11"},"text":"Pub. L. 101–510, § 1484(k)(11)","children":[],"tail":", struck out closing parenthesis after “such Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1207/b"},"text":"Pub. L. 101–510, § 1207(b)","children":[],"tail":", struck out subsec. (c) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Stability of Program Managers","children":[],"tail":".—(1) The tour of duty of an officer of the armed forces as a program manager of a major defense acquisition program shall be (A) not less than four years, or (B) until completion of a major program milestone (as defined in regulations prescribed by the Secretary of Defense)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary of the military department concerned may waive the length of the tour of duty prescribed in paragraph (1). The authority under the preceding sentence may not be delegated.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(2)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s811/b/1"},"text":"Pub. L. 101–189, § 811(b)(1)","children":[],"tail":", substituted “production” for “development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s811/b/2/A"},"text":"Pub. L. 101–189, § 811(b)(2)(A)","children":[],"tail":", substituted “service acquisition executive designated by such Secretary” for “senior procurement executive of such military department (designated pursuant to section 16(3) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s414/3"},"text":"41 U.S.C. 414(3)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s811/b/2/B"},"text":"Pub. L. 101–189, § 811(b)(2)(B)","children":[],"tail":", substituted “180 days” for “90 days” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" clarified amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/s803/a"},"text":"Pub. L. 100–180, § 803(a)","children":[],"tail":". See 1987 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370"},"text":"Pub. L. 100–370","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":", substituted “under paragraph (1), and for which the total cost of completion of the stage will exceed by 15 percent or more, in the case of a development stage, or by 5 percent or more, in the case of a production stage, the amount specified in the baseline description established under subsection (a) for such stage; or any milestone specified in such baseline description will be missed by more than 90 days” for first reference to “under paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/b/6"},"text":"Pub. L. 100–26, § 7(b)(6)","children":[],"tail":", struck out subsec. (c) which defined “major defense acquisition program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa6bfaf2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa6bfaf3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa6bfaf4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVIII/s802/e"},"text":"Pub. L. 109–163, div. A, title VIII, § 802(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3370"},"text":"119 Stat. 3370","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVIII/s802/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433"},"text":"section 2433 of this title","children":[],"tail":"] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"], and shall apply with respect to any major defense acquisition program for which an original Baseline Estimate is first established before, on, or after that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to current major defense acquisition programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a major defense acquisition program for which the program acquisition unit cost or procurement unit cost, as applicable, exceeds the original Baseline Estimate for the program by more than 50 percent on the date of the enactment of this Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current Baseline Estimate for the program as of such date of enactment is deemed to be the original Baseline Estimate for the program for purposes of [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2433"},"text":"section 2433 of title 10","children":[],"tail":", United States Code [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4371"},"text":"10 U.S.C. 4371","children":[],"tail":" to 4375] (as amended by this section); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each Selected Acquisition Report submitted on the program after the date of the enactment of this Act shall reflect each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The original Baseline Estimate, as first established for the program, without adjustment or revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Baseline Estimate for the program that is deemed to be the original Baseline Estimate for the program under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current original Baseline Estimate for the program as adjusted or revised, if at all, in accordance with subsection (d)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2435"},"text":"section 2435 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4214/d/2"},"text":"10 U.S.C. 4214(d)(2)","children":[],"tail":"] (as added by subsection (d) of this section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa6bfaf5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1207/b"},"text":"Pub. L. 101–510, div. A, title XII, § 1207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1665"},"text":"104 Stat. 1665","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa6bfaf6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" applicable as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":", see section 1233("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(5) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4172"},"text":"section 4172 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa6bfaf7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/c/tX/s904/b"},"text":"Pub. L. 99–500, § 101(c) [title X, § 904(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-82"},"text":"100 Stat. 1783–82","children":[],"tail":", 1783–134, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/c/tX/s904/b"},"text":"Pub. L. 99–591, § 101(c) [title X, § 904(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-82"},"text":"100 Stat. 3341–82","children":[],"tail":", 3341–134, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tIX"},"text":"Pub. L. 99–661, div. A, title IX","children":[],"tail":", formerly title IV, § 904(b), "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3914"},"text":"100 Stat. 3914","children":[],"tail":", renumbered title IX, "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s3/5"},"text":"Pub. L. 100–26, § 3(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/273"},"text":"101 Stat. 273","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/26/s3/5"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2435"},"text":"Section 2435 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4214"},"text":"10 U.S.C. 4214","children":[],"tail":"] (as added by subsection (a)(1)), shall apply to major defense acquisition programs that enter full-scale engineering development or full-rate production after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
