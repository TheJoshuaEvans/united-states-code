{"tag":"section","attrib":{"id":"ida82fc693-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931"},"text":null,"children":[{"tag":"num","attrib":{"value":"931"},"text":"§ 931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 131. Perjury","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who in a judicial proceeding or in a course of justice willfully and corruptly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc694-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a lawful oath or in any form allowed by law to be substituted for an oath, gives any false testimony material to the issue or matter of inquiry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc695-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s931/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any declaration, certificate, verification, or statement under penalty of perjury as permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1746"},"text":"section 1746 of title 28","children":[],"tail":", subscribes any false statement material to the issue or matter of inquiry;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of perjury and shall be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc696-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/75"},"text":"70A Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl