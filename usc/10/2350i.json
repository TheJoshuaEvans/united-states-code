{"tag":"section","attrib":{"id":"ida96cda9b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350i"},"text":"§ 2350i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign contributions for cooperative projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida96cda9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the United States participates in a cooperative project with a friendly foreign country or the North Atlantic Treaty Organization (NATO) on a cost-sharing basis, any contribution received by the United States from that foreign country or NATO to meet its share of the costs of the project may be credited to appropriations available to an appropriate military department or another appropriate organization within the Department of Defense, as determined by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96cda9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Amounts Credited","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a contribution credited pursuant to subsection (a) to an appropriation account in connection with a cooperative project referred to in that subsection shall be available only for payment of the share of the project expenses allocated to the foreign country or NATO making the contribution. Payments for which such amount is available include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96cda9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments to contractors and other suppliers (including the Department of Defense and other participants acting as suppliers) for necessary articles and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cda9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments for any damages and costs resulting from the performance or cancellation of any contract or other obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cdaa0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments or reimbursements of other program expenses, including program office overhead and administrative costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cdaa1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Refunds to other participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96cdaa2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96cdaa3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “cooperative project” means a jointly managed arrangement, described in a written cooperative agreement entered into by the participants, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida96cdaa4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is undertaken by the participants in order to improve the conventional defense capabilities of the participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida96cdaa5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida96cdaa6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more participants (other than the United States) to share with the United States the cost of research and development, testing, evaluation, or joint production (including follow-on support) of defense articles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida96cdaa7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and another participant concurrently to produce in the United States and the country of such other participant a defense article jointly developed in a cooperative project described in clause (i); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida96cdaa8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States to procure a defense article or a defense service from another participant in the cooperative project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cdaa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense article” has the meaning given such term in section 47(3) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2794/3"},"text":"22 U.S.C. 2794(3)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96cdaaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense service” has the meaning given such term in section 47(4) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2794/4"},"text":"22 U.S.C. 2794(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida96cdaab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1047/a"},"text":"Pub. L. 102–190, div. A, title X, § 1047(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1467"},"text":"105 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
