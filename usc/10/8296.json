{"tag":"section","attrib":{"id":"idab1a15b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8296"},"text":null,"children":[{"tag":"num","attrib":{"value":"8296"},"text":"§ 8296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy and Marine Corps Medal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1a15b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8296/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may award a medal called the “Navy and Marine Corps Medal” of appropriate design with accompanying ribbon, together with a rosette or other device to be worn in place thereof—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1a15b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8296/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person who, while serving in any capacity with the Navy or the Marine Corps, distinguishes himself by heroism not involving actual conflict with an enemy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1a15b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8296/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any person to whom the Secretary of the Navy, before ","children":[{"tag":"date","attrib":{"date":"1942-08-07"},"text":"August 7, 1942","children":[],"tail":", awarded a letter of commendation for heroism, and who applies for that medal, regardless of the date of the act of heroism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1a15b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8296/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority in subsection (a) includes authority to award the medal to a member of the Ready Reserve who was not in a duty status defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/d"},"text":"section 101(d) of this title","children":[],"tail":" when the member distinguished himself by heroism."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1a15b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/390"},"text":"70A Stat. 390","children":[],"tail":", § 6246; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s574/b"},"text":"Pub. L. 105–85, div. A, title V, § 574(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1758"},"text":"111 Stat. 1758","children":[],"tail":"; renumbered § 8296, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/13"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1a15ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1a15bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1a15bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6246","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s356b"},"text":"34 U.S.C. 356b","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1919-02-04/ch14/s5"},"text":"Feb. 4, 1919, ch. 14, § 5","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1942-08-07/ch551/s1"},"text":"Aug. 7, 1942, ch. 551, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/744"},"text":"56 Stat. 744","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “award” is substituted for the word “present” to cover the determination of the recipient as well as the actual presenting of the award. The words “but not in the name of Congress” are omitted since a decoration is presented in the name of Congress only if the law so directs. The words “including the Naval Reserve and Marine Corps Reserve” are omitted as covered by the definitions of the Navy and the Marine Corps. The last sentence, relating to additional pay, is omitted for the reason that, under the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.), there is no additional pay authorized for any medal. The words “since "},{"tag":"date","attrib":{"date":"1941-12-06"},"text":"December 6, 1941","children":[],"tail":"” are omitted as executed. The words “or herself” are omitted as covered by the rules of construction in "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"1 U.S.C. 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1a15bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab1a15be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8296, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/510"},"text":"70A Stat. 510","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/16"},"text":"Pub. L. 85–600, § 1(16)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/523"},"text":"72 Stat. 523","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/156"},"text":"Pub. L. 85–861, § 1(156)","children":[],"tail":", (175), "},{"tag":"ref","attrib":{"href":"/us/stat/72/1513"},"text":"72 Stat. 1513","children":[],"tail":", 1519, provided for promotion lists in Regular Air Force for all commissioned officers in grades below brigadier general on active list, with exceptions, which officers are known as “promotion-list officers”, a separate list for chaplains, judge advocates, medical officers, dental officers, veterinary officers, medical service officers, Air Force nurses, Air Force medical specialists, and any category established by Secretary of Air Force under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8067/i"},"text":"section 8067(i) of this title","children":[],"tail":", and determination of place on list upon transfer or promotion, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s204"},"text":"Pub. L. 96–513, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2880"},"text":"94 Stat. 2880","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s624"},"text":"section 624 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1a15bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6246"},"text":"section 6246 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1a15c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1a15c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
