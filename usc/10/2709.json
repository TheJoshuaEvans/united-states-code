{"tag":"section","attrib":{"id":"ida9c50d05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2709"},"text":null,"children":[{"tag":"num","attrib":{"value":"2709"},"text":"§ 2709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment control process for environmental technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c50d06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment Control Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the technology planning process developed to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4811"},"text":"section 4811 of this title","children":[],"tail":" and section 270(b) of the National Defense Authorization Act for Fiscal Year 1997 ("},{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Public Law 104–201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/2469"},"text":"110 Stat. 2469","children":[],"tail":") provides for an investment control process for the selection, prioritization, management, and evaluation of environmental technologies by the Department of Defense, the military departments, and the Defense Agencies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c50d07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning and Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The environmental technology investment control process required by subsection (a) shall provide, at a minimum, for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c50d08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The active participation by end-users of environmental technology, including the officials responsible for the environmental security programs of the Department of Defense and the military departments, in the selection and prioritization of environmental technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50d09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of measurable performance goals and objectives for the management and development of environmental technologies and specific mechanisms for assuring the achievement of the goals and objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c50d0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annual performance reviews to determine whether the goals and objectives have been achieved and to take appropriate action in the event that they are not achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c50d0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s323/b/1"},"text":"Pub. L. 106–65, div. A, title III, § 323(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/562"},"text":"113 Stat. 562","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1867/e/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1867(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4282"},"text":"134 Stat. 4282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c50d0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c50d0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9c50d0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 270(b) of the National Defense Authorization Act for Fiscal Year 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Public Law 104–201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/2469"},"text":"110 Stat. 2469","children":[],"tail":"), referred to in subsec. (a), was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2501"},"text":"section 2501 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tII/s241"},"text":"Pub. L. 111–84, div. A, title II, § 241","children":[],"tail":", Oct 28, 2009, "},{"tag":"ref","attrib":{"href":"/us/stat/123/2237"},"text":"123 Stat. 2237","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c50d0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “section 4811” for “section 2501”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c50d10-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9c50d11-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9c50d12-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s323"},"text":"Section 323 of Pub. L. 106–65","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s323/a"},"text":"Pub. L. 106–65, div. A, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/562"},"text":"113 Stat. 562","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tIII/s323/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this section [enacting this section, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2706"},"text":"section 2706 of this title","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2706"},"text":"section 2706 of this title","children":[],"tail":"] are—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hold the Department of Defense and the military departments accountable for achieving performance-based results in the management of environmental technology by providing a connection between program direction and the achievement of specific performance-based results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure the identification of end-user requirements for environmental technology within the military departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure results, quality of effort, and appropriate levels of service and support for end-users of environmental technology within the military departments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote improvement in the performance of environmental technologies by establishing objectives for environmental technology programs, measuring performance against such objectives, and making public reports on the progress made in such performance.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
