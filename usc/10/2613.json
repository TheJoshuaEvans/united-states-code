{"tag":"section","attrib":{"id":"ida9930059-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613"},"text":null,"children":[{"tag":"num","attrib":{"value":"2613"},"text":"§ 2613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of frequent traveler miles, credits, points, and tickets: use to facilitate rest and recuperation travel of deployed members and their families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida993005a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Accept Donation of Travel Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), the Secretary of Defense may accept from any person or government agency the donation of travel benefits for the purposes of use under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993005b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel Benefit Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “travel benefit” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993005c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frequent traveler miles, credits for tickets, or tickets for air or surface transportation issued by an air carrier or a surface carrier, respectively, that serves the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993005d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" points or awards for free or reduced-cost accommodations issued by an inn, hotel, or other commercial establishment that provides lodging to transient guests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993005e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Condition on Authority to Accept Donation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may accept a donation of a travel benefit under this section only if the business entity referred to in subsection (b) that is the source of the benefit consents to such donation. Any such donation shall be under such terms and conditions as the business entity may specify, and the travel benefit so donated may be used only in accordance with the rules established by the business entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993005f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Donated Travel Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A travel benefit accepted under this section may be used only for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930060-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitating the travel of a member of the armed forces who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9930061-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deployed on active duty outside the United States away from the permanent duty station of the member in support of a contingency operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930062-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is granted, during such deployment, rest and recuperative leave, emergency leave, convalescent leave, or another form of leave authorized for the member; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930063-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the armed forces recuperating from an injury or illness incurred or aggravated in the line of duty during such a deployment, facilitating the travel of family members of the member in order to be reunited with the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9930064-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9930065-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate a single office in the Department of Defense to carry out this section. That office shall develop rules and procedures to facilitate the acceptance and distribution of travel benefits under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9930066-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the use of travel benefits under subsection (d)(2) by family members of a member of the armed forces, the Secretary may, as the Secretary determines appropriate, limit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9930067-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility to family members who, by reason of affinity, degree of consanguinity, or otherwise, are sufficiently close in relationship to the member of the armed forces to justify the travel assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930068-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of family members who may travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9930069-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of trips that family members may take.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993006a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may, in an exceptional case, authorize a person not described in subsection (d)(2) to use a travel benefit accepted under this subsection to visit a member of the armed forces described in subsection (d)(1) if that person has a notably close relationship with the member. The travel benefit may be used by such person only in accordance with such conditions and restrictions as the Secretary determines appropriate and the rules established by the business entity referred to in subsection (b) that is the source of the travel benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993006b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services of Nonprofit Organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may enter into an agreement with a nonprofit organization to use the services of the organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida993006c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the donation of travel benefits under this section, except that amounts appropriated to the Department of Defense may not be expended for this purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida993006d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in administering the collection, distribution, and use of travel benefits under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida993006e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2613/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family Member Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “family member” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s451/a"},"text":"section 451(a) of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida993006f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s585/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 585(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1930"},"text":"118 Stat. 1930","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/20"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2399"},"text":"120 Stat. 2399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s576/a"},"text":"Pub. L. 112–81, div. A, title V, § 576(a)","children":[],"tail":"–(d)(1), title VI, § 631(f)(4)(A), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1428"},"text":"125 Stat. 1428","children":[],"tail":", 1429, 1465; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/a/25"},"text":"Pub. L. 115–232, div. A, title X, § 1081(a)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1985"},"text":"132 Stat. 1985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/c/8"},"text":"Pub. L. 117–263, div. A, title VI, § 626(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2628"},"text":"136 Stat. 2628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9930070-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9930071-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9930072-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2613 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2614"},"text":"section 2614 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9930073-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 451(a)” for “section 481h(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “481h(b)” for “481h(b)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s576/d/1"},"text":"Pub. L. 112–81, § 576(d)(1)","children":[],"tail":", substituted “Acceptance of frequent traveler miles, credits, points, and tickets: use to facilitate rest and recuperation travel of deployed members and their families” for “Acceptance of frequent traveler miles, credits, and tickets; use to facilitate rest and recuperation travel of deployed members and their families” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s576/a"},"text":"Pub. L. 112–81, § 576(a)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) defined travel benefit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s576/b"},"text":"Pub. L. 112–81, § 576(b)","children":[],"tail":", substituted “the business entity referred to in subsection (b)” for “the air or surface carrier” and substituted “the business entity” for “the surface carrier” and for “the carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s576/c"},"text":"Pub. L. 112–81, § 576(c)","children":[],"tail":", substituted “the business entity referred to in subsection (b)” for “the air carrier or surface carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/A"},"text":"Pub. L. 112–81, § 631(f)(4)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", substituted “481h(b)(1)” for “411h(b)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “In this” for “In the”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9930074-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9930075-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(9) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
