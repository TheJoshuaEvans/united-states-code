{"tag":"section","attrib":{"id":"idaac69d7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6204"},"text":null,"children":[{"tag":"num","attrib":{"value":"6204"},"text":"§ 6204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification regarding air release of radioactive or hazardous material","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Energy (or a designee of the Secretary) is notified of an improper release into the air of radioactive or hazardous material above applicable statutory or regulatory limits that resulted from waste generated by atomic energy defense activities at the Hanford Nuclear Reservation, Richland, Washington, the Secretary (or designee of the Secretary) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69d7d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6204/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than two business days after being notified of the release, notify the congressional defense committees of the release; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69d7e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6204/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than seven business days after being notified of the release, provide the congressional defense committees a briefing on the status of the release, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac69d7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6204/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cause of the release, if known; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac69d80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6204/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary plans to address and remediate the release, including associated costs and timelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69d81-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1400"},"text":"139 Stat. 1400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69d82-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69d83-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69d84-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2627"},"text":"section 2627 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
