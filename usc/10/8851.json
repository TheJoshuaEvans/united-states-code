{"tag":"section","attrib":{"id":"idab4e930e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851"},"text":null,"children":[{"tag":"num","attrib":{"value":"8851"},"text":"§ 8851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4e930f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This chapter applies to all captures of vessels as prize during war by authority of the United States or adopted and ratified by the President. However, this chapter does not affect the right of the Army, the Air Force, or the Space Force, while engaged in hostilities, to capture wherever found and without prize procedure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e9310-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enemy property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e9311-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neutral property used or transported in violation of the obligations of neutrals under international law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e9312-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e9313-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vessel” includes aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e9314-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “master” includes the pilot or other person in command of an aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e9315-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Property seized or taken upon the inland waters of the United States by its naval forces is not maritime prize. All such property shall be delivered promptly to the proper officers of the courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4e9316-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8851/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter may be construed as contravening any treaty of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4e9317-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/474"},"text":"70A Stat. 474","children":[],"tail":", § 7651; renumbered § 8851, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},