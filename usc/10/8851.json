"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-07-01/ch370/s1"},"text":"July 1, 1944, ch. 370, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/678"},"text":"58 Stat. 678","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1945-11-14/ch472/s1"},"text":"Nov. 14, 1945, ch. 472, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/581"},"text":"59 Stat. 581","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7651(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1131"},"text":"34 U.S.C. 1131","children":[],"tail":" (1st proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4613 (1st proviso); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-06-24/ch232"},"text":"June 24, 1941, ch. 232","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/55/261"},"text":"55 Stat. 261","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1132"},"text":"34 U.S.C. 1132","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4614; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-06-24/ch232"},"text":"June 24, 1941, ch. 232","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/55/261"},"text":"55 Stat. 261","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7651(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t50/s214"},"text":"50 U.S.C. 214","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 5310.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7651(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1158"},"text":"34 U.S.C. 1158","children":[],"tail":" (last sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4652 (last sentence).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “including aircraft” are omitted as covered by subsection (b). The section is written to make the words “during war” applicable to the entire chapter. These words appear in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1159"},"text":"34 U.S.C. 1159","children":[],"tail":", but not in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1131"},"text":"34 U.S.C. 1131","children":[],"tail":". Prize is historically and uniformly treated as a war-time matter, so no substantive change results from the extension. The words “this chapter does not affect” are substituted for the words “nothing herein contained shall be construed as affecting, or in any way impairing”. The words “Air Force” are added under authority of § 305(a) of the National Security Act of 1947, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s171"},"text":"5 U.S.C. 171","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), to provide the same applicability as formerly provided by the word “Army”. The word “legal” is omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the definition of the term “ship” is omitted as covered by the term “vessel”. All of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1132"},"text":"34 U.S.C. 1132","children":[],"tail":" except that part which includes “aircraft” within the term “vessels” is omitted as unnecessary since the defined term “vessels of the Navy” does not appear in the provisions to which the definition is made applicable. The last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s1158"},"text":"34 U.S.C. 1158","children":[],"tail":" applies only to Title LIV (Prize) of the Revised Statutes. In subsection (d) it is broadened to cover the entire body of statutory prize law. Additions to the prize law made by the "},{"tag":"ref","attrib":{"href":"/us/act/1942-08-18/ch553"},"text":"Act of August 18, 1942, ch. 553","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/746"},"text":"56 Stat. 746","children":[],"tail":", as amended, operated only to extend the jurisdiction of courts of the United States to certain cases in which the prizes are not brought into the territorial waters of the United States. Relations of this country with other countries are not affected by the 1942 Act except when jurisdiction is exercised by American courts over prizes brought into cobelligerent ports. As that Act provides that the consent of the cobelligerent is necessary to the exercise of such jurisdiction, the rule against contravention of treaties is properly applied to it."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dc0b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab50dc0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8851, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/192"},"text":"Pub. L. 85–861, § 1(192)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1537"},"text":"72 Stat. 1537","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/86/559/s1/73"},"text":"Pub. L. 86–559, § 1(73)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-06-30"},"text":"June 30, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/280"},"text":"74 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s3/6"},"text":"Pub. L. 90–83, § 3(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/220"},"text":"81 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/486/s9/2"},"text":"Pub. L. 90–486, § 9(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-13"},"t