{"tag":"section","attrib":{"id":"idab2d2811-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476"},"text":null,"children":[{"tag":"num","attrib":{"value":"8476"},"text":"§ 8476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of Naval Academy dairy farm","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2d2812-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretion Regarding Continued Operation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2d2813-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of the Navy may terminate or reduce the dairy or other operations conducted at the Naval Academy dairy farm located in Gambrills, Maryland.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d2814-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the termination or reduction of operations at the Naval Academy dairy farm under paragraph (1), the real property containing the dairy farm (consisting of approximately 875 acres)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab2d2815-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be declared to be excess real property to the needs of the Navy or transferred or otherwise disposed of by the Navy or any Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2d2816-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be maintained in its rural and agricultural nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d2817-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2d2818-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), to the extent that the termination or reduction of operations at the Naval Academy dairy farm permit, the Secretary of the Navy may lease the real property containing the dairy farm, and any improvements and personal property thereon, to such persons and under such terms as the Secretary considers appropriate. In leasing any of the property, the Secretary may give a preference to persons who will continue dairy operations on the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d2819-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any lease of property at the Naval Academy dairy farm shall be subject to a condition that the lessee maintain the rural and agricultural nature of the leased property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d281a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All money received from a lease entered into under subsection (b) shall be retained by the Superintendent of the Naval Academy and shall be available to cover expenses related to the property described in subsection (a), including reimbursing nonappropriated fund instrumentalities of the Naval Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d281b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8476/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8471"},"text":"section 8471 of this title","children":[],"tail":" shall be construed to require the Secretary of the Navy or the Superintendent of the Naval Academy to operate a dairy farm for the Naval Academy in Gambrills, Maryland, or any other location."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2d281c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dB/tXXVIII/s2871/a/1"},"text":"Pub. L. 105–85, div. B, title XXVIII, § 2871(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2014"},"text":"111 Stat. 2014","children":[],"tail":", § 6976; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dB/tXXVIII/s2814"},"text":"Pub. L. 106–65, div. B, title XXVIII, § 2814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/851"},"text":"113 Stat. 851","children":[],"tail":"; renumbered § 8476 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(c)(1), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab2d281d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab2d281e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab2d281f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/c/1"},"text":"Pub. L. 115–232, § 807(c)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6976"},"text":"section 6976 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8471” for “section 6971”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab2d2820-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab2d2821-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
