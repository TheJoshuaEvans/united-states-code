{"tag":"section","attrib":{"id":"ida916f24c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1788a"},"text":"§ 1788a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support programs: special operations forces personnel; immediate family members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida916f24d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programs Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Consistent with such regulations as the Secretary of Defense may prescribe to carry out this section, the Commander of the United States Special Operations Command may conduct programs to provide family support services. In selecting and conducting any program under this subsection, the Commander shall coordinate with the Under Secretary of Defense for Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida916f24e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting the programs to be conducted under subsection (a), the Commander shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida916f24f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify family support services that have a direct and concrete impact on the readiness of special operations forces, but that are not being provided by the Secretary of a military department to covered individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f250-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a cost-benefit analysis of each family support service proposed to be included in a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida916f251-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commander may expend up to $10,000,000 during each fiscal year, from funds available for Major Force Program 11, to carry out family support programs under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"ida916f252-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"[(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1702/c/1"},"text":"Pub. L. 116–92, div. A, title XVII, § 1702(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1796"},"text":"133 Stat. 1796","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida916f253-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida916f254-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Commander” means the Commander of the United States Special Operations Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f255-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “immediate family members” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1789/c"},"text":"section 1789(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f256-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “special operations forces” means those forces of the armed forces identified as special operations forces under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s167/j"},"text":"section 167(j) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f257-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “family support services” includes psychological support, spiritual support, and costs of transportation, food, lodging, child care, supplies, fees, and training materials for covered individuals while participating in programs under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida916f258-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered individuals” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida916f259-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Armed Forces (including the reserve components) assigned to special operations forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida916f25a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service personnel assigned to support special operations forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida916f25b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediate family members of individuals described in subparagraphs (A) and (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida916f25c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" immediate family members of individuals described in subparagraphs (A) or (B) in a case in which such individual died—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida916f25d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a direct result of armed conflict;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida916f25e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in hazardous service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida916f25f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the performance of duty under conditions simulating war; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida916f260-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1788a/e/5/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through an instrumentality of war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida916f261-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tV/s555/a"},"text":"Pub. L. 115–91, div. A, title V, § 555(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1402"},"text":"131 Stat. 1402","children":[],"tail":", 1403; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s572"},"text":"Pub. L. 115–232, div. A, title V, § 572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1778"},"text":"132 Stat. 1778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII"},"text":"Pub. L. 116–92, div. A, title XVII","children":[],"tail":", §§ 1702(c)(1), 1731(a)(28), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1796"},"text":"133 Stat. 1796","children":[],"tail":", 1813; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s583/a"},"text":"Pub. L. 116–283, div. A, title V, § 583(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3653"},"text":"134 Stat. 3653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s561"},"text":"Pub. L. 117–81, div. A, title V, § 561","children":[],"tail":", title X, § 1081(a)(24), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1746"},"text":"135 Stat. 1746","children":[],"tail":", 1920.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida916f262-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida916f263-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida916f264-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", is based on text of subsecs. (a), (b), (d), and (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/s554"},"text":"section 554 of Pub. L. 113–66","children":[],"tail":", div. A, title V, "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/765"},"text":"127 Stat. 765","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1788"},"text":"section 1788 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/e"},"text":"Pub. L. 115–91, div. A, title X, § 1081(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1601"},"text":"131 Stat. 1601","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida916f265-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/1"},"text":"Pub. L. 116–283, § 583(a)(1)","children":[],"tail":", substituted “Support programs: special operations forces personnel; immediate family members” for “Family support programs: immediate family members of members of special operations forces” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/2"},"text":"Pub. L. 116–283, § 583(a)(2)","children":[],"tail":", struck out “for the immediate family members of members of the armed forces assigned to special operations forces” after “family support services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/3"},"text":"Pub. L. 116–283, § 583(a)(3)","children":[],"tail":", substituted “covered individuals” for “the immediate family members of members of the armed forces assigned to special operations forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/4/A"},"text":"Pub. L. 116–283, § 583(a)(4)(A)","children":[],"tail":", substituted “covered individuals” for “family members of members of the armed forces assigned to special operations forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/4/B"},"text":"Pub. L. 116–283, § 583(a)(4)(B)","children":[],"tail":", substituted “covered individuals” for “family members of members of the armed forces assigned to special operations forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1081/a/24/A"},"text":"Pub. L. 117–81, § 1081(a)(24)(A)","children":[],"tail":", substituted “section 167(j)” for “section 167(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1081/a/24/B"},"text":"Pub. L. 117–81, § 1081(a)(24)(B)","children":[],"tail":", substituted “covered individuals” for “covered personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s561/1"},"text":"Pub. L. 117–81, § 561(1)","children":[],"tail":", which directed substitution of “covered individuals” for “covered personnel”, could not be executed because of the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1081/a/24/B"},"text":"Pub. L. 117–81, § 1081(a)(24)(B)","children":[],"tail":". See note above and Coordination of Amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/5/A"},"text":"Pub. L. 116–283, § 583(a)(5)(A)","children":[],"tail":", (B), inserted “psychological support, spiritual support, and” before “costs” and substituted “covered personnel” for “immediate family members of members of the armed forces assigned to special operations forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1081/a/24/C"},"text":"Pub. L. 117–81, § 1081(a)(24)(C)","children":[],"tail":", substituted “ ‘covered individuals’ ” for “ ‘covered personnel’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s561/2/A"},"text":"Pub. L. 117–81, § 561(2)(A)","children":[],"tail":", which directed substitution of “covered individuals” for “covered personnel”, could not be executed because of the prior amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1081/a/24/C"},"text":"Pub. L. 117–81, § 1081(a)(24)(C)","children":[],"tail":". See note above and Coordination of Amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s583/a/5/C"},"text":"Pub. L. 116–283, § 583(a)(5)(C)","children":[],"tail":", which directed amendment of subsec. (e)(4) “by adding at the end” par. (5), was executed by adding par. (5) after par. (4), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s561/2/B"},"text":"Pub. L. 117–81, § 561(2)(B)","children":[],"tail":"–(D), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1702/c/1"},"text":"Pub. L. 116–92, § 1702(c)(1)","children":[],"tail":", struck out subsec. (d) which required an annual report regarding the family support programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/28"},"text":"Pub. L. 116–92, § 1731(a)(28)","children":[],"tail":", substituted “Not later than March 1 each year” for “Not later than "},{"tag":"date","attrib":{"date":"2019-03-01"},"text":"March 1, 2019","children":[],"tail":", and each March 1 thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s572/1"},"text":"Pub. L. 115–232, § 572(1)","children":[],"tail":", substituted “services” for “activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s572/2"},"text":"Pub. L. 115–232, § 572(2)","children":[],"tail":", substituted “service” for “activity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s572/3"},"text":"Pub. L. 115–232, § 572(3)","children":[],"tail":", substituted “$10,000,000” for “$5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s572/4"},"text":"Pub. L. 115–232, § 572(4)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/d/3"},"text":"Pub. L. 115–91, § 555(d)(3)","children":[],"tail":", struck out “Pilot” before “Programs” in heading and substituted “programs to provide” for “up to three pilot programs to assess the feasibility and benefits of providing” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/d/1"},"text":"Pub. L. 115–91, § 555(d)(1)","children":[],"tail":", (2), substituted “armed forces” for “Armed Forces” and struck out “pilot” before “program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/d/1"},"text":"Pub. L. 115–91, § 555(d)(1)","children":[],"tail":", substituted “armed forces” for “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/d/2"},"text":"Pub. L. 115–91, § 555(d)(2)","children":[],"tail":", struck out “pilot” before “program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/b/1"},"text":"Pub. L. 115–91, § 555(b)(1)","children":[],"tail":", (c), redesignated subsec. (d) as (c) and substituted “, from funds available for Major Force Program 11, to carry out family support programs under this section.” for “specified in subsection (f) to carry out the pilot programs under subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/b/2"},"text":"Pub. L. 115–91, § 555(b)(2)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/d/4/A"},"text":"Pub. L. 115–91, § 555(d)(4)(A)","children":[],"tail":", substituted “this title” for “title 10, United States Code”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s555/d/4/B"},"text":"Pub. L. 115–91, § 555(d)(4)(B)","children":[],"tail":", substituted “this title” for “such title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib