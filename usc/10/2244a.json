{"tag":"section","attrib":{"id":"ida959c796-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2244a"},"text":"§ 2244a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment scheduled for retirement or disposal: limitation on expenditures for modifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c797-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, the Secretary of a military department may not carry out a modification of an aircraft, weapon, vessel, or other item of equipment that the Secretary plans to retire or otherwise dispose of within five years after the date on which the modification, if carried out, would be completed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for below-threshold modifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition in subsection (a) does not apply to a modification for which the cost is less than $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c79a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for transfer of reusable items of value","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition in subsection (a) does not apply to a modification in a case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c79b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reusable items of value, as determined by the Secretary, installed on the item of equipment as part of such modification will, upon the retirement or disposal of the item to be modified, be removed from such item of equipment, refurbished, and installed on another item of equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c79c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of such modification (including the cost of the removal and refurbishment of reusable items of value under subparagraph (A)) is less than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c79d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for safety modifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition in subsection (a) does not apply to a safety modification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c79e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2244a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may waive the prohibition in subsection (a) in the case of any modification otherwise subject to that subsection if the Secretary determines that carrying out the modification is in the national security interest of the United States. Whenever the Secretary issues such a waiver, the Secretary shall notify the congressional defense committees in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c79f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIII/s372/a"},"text":"Pub. L. 109–163, div. A, title III, § 372(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3209"},"text":"119 Stat. 3209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c7a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c7a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida959c7a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/56/tVIII/s8053"},"text":"Pub. L. 105–56, title VIII, § 8053","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-08"},"text":"Oct. 8, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1232"},"text":"111 Stat. 1232","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2241"},"text":"section 2241 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIII/s372/c"},"text":"Pub. L. 109–163, div. A, title III, § 372(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3210"},"text":"119 Stat. 3210","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
