{"tag":"section","attrib":{"id":"idab986d22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12104"},"text":null,"children":[{"tag":"num","attrib":{"value":"12104"},"text":"§ 12104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve components: transfers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab986d23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who would otherwise be required to be transferred to a reserve component under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s651"},"text":"section 651 of this title","children":[],"tail":" or under the Military Selective Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.), is entitled, if he is qualified and accepted, to be enlisted in any armed force that he chooses and to participate in the programs authorized for that armed force. However, unless the two Secretaries concerned consent, he may not be enlisted as a Reserve of an armed force other than that from which he is transferred. All periods of his participation shall be credited against the total period of service required of him under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s651"},"text":"section 651 of this title","children":[],"tail":" or under the Military Selective Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.). However, no period may be credited more than once."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab986d24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person covered by subsection (a) shall perform the rest of his required term of service in the armed force in which he is so enlisted or in any other armed force in which he is later enlisted or appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab986d25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not change any term of service under an appointment, enlistment, or agreement, including an agreement made before or at the time when the member entered upon a program authorized by an armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab986d26-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/18"},"text":"70A Stat. 18","children":[],"tail":", § 512; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/15"},"text":"Pub. L. 96–513, title V, § 511(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2921"},"text":"94 Stat. 2921","children":[],"tail":"; renumbered § 12104, "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/b/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2989"},"text":"108 Stat. 2989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1081/b/1/A/viii"},"text":"Pub. L. 114–328, div. A, title X, § 1081(b)(1)(A)(viii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2418"},"text":"130 Stat. 2418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab986d27-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab986d28-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab986d29-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"512(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"512(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:929(a) (less 2d sentence, as applicable to enlistments).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:929(a) (2d sentence, as applicable to enlistments).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s209"},"text":"July 9, 1952, ch. 608, § 209","children":[],"tail":" (as applicable to enlistments), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/484"},"text":"66 Stat. 484","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"512(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:929(b) (as applicable to enlistments).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “is entitled * * * to be enlisted in any armed force that he chooses” are substituted for the words “shall * * * be permitted to enlist * * * in such Armed Force of the United States as he may elect”. The second sentence is substituted for 50:929(a) (words within parentheses). The words “of an Armed Force of the United States” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “rest” is substituted for the words “remaining period”. The words “be required to” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “This section does not” are substituted for the words “Nothing in this section shall be construed”. The word “change” is substituted for the words “reduce, limit, or modify”. The words “which any person may undertake to perform” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab986d2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab986d2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Military Selective Service Act, referred to in subsec. (a), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch625"},"text":"act June 24, 1948, ch. 625","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/604"},"text":"62 Stat. 604","children":[],"tail":", which is classified principally to chapter 49 (§ 3801 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"section 3801 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab986d2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3801"},"text":"50 U.S.C. 3801","children":[],"tail":" et seq.)” for “(50 U.S.C. App. 451 et seq.)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s512"},"text":"section 512 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “the Military Selective Service Act (50 U.S.C. App. 451 et seq.)” for “sections 451–473 of title 50, appendix” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab986d2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab986d2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
