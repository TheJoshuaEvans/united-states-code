{"tag":"section","attrib":{"id":"ida90195fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1623"},"text":null,"children":[{"tag":"num","attrib":{"value":"1623"},"text":"§ 1623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance to certain employees in acquisition of critical skills","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90195fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall establish an undergraduate training program with respect to civilian employees of the Defense Intelligence Agency that is similar in purpose, conditions, content, and administration to the program which the Secretary of Defense is authorized to establish under section 16 of the National Security Agency Act of 1959 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3614"},"text":"50 U.S.C. 3614","children":[],"tail":") for civilian employees of the National Security Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90195fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payments made by the Secretary to carry out the program required to be established by subsection (a) may be made in any fiscal year only to the extent that appropriated funds are available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90195ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/193/tV/s507/a/1"},"text":"Pub. L. 101–193, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":