{"tag":"section","attrib":{"id":"idab724775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415"},"text":null,"children":[{"tag":"num","attrib":{"value":"9415"},"text":"§ 9415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community College of the Air Force: associate degrees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab724776-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Mission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is in the Department of the Air Force a Community College of the Air Force. Such college, in cooperation with civilian colleges and universities, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab724777-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe programs of higher education for enlisted members described in subsection (b) designed to improve the technical, managerial, and related skills of such members and to prepare such members for military jobs which require the utilization of such skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724778-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor on a continuing basis the progress of members pursuing such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab724779-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members Eligible for Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to such other eligibility requirements as the Secretary concerned may prescribe, the following members of the armed forces are eligible to participate in programs of higher education under subsection (a)(1):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab72477a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members of the Air Force or the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab72477b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members of the armed forces other than the Air Force or the Space Force who are serving as instructors at Department of the Air Force training schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab72477c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enlisted members of the armed forces other than the Air Force or the Space Force who are participating in Community College of the Air Force affiliated joint-service training and education courses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab72477d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seriously Wounded, Ill, or Injured Former and Retired Enlisted Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab72477e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Air Force may authorize participation in a program of higher education under subsection (a)(1) by a person who is a former or retired enlisted member of the armed forces who at the time of the person’s separation from active duty—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab72477f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had commenced but had not completed a program of higher education under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab724780-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is categorized by the Secretary concerned as seriously wounded, ill, or injured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724781-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, a person who may be categorized as seriously wounded, ill, or injured is a person with a serious injury or illness (as that term is defined in section 1602(8) of the Wounded Warrior Act (title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Public Law 110–181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1071"},"text":"10 U.S.C. 1071","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724782-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not be authorized under paragraph (1) to participate in a program of higher education after the end of the 10-year period beginning on the date of the person’s separation from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724783-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not pay the tuition for participation in a program of higher education under subsection (a)(1) of a person participating in such program pursuant to an authorization under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab724784-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Associate Degrees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab724785-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), an academic degree at the level of associate may be conferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9417"},"text":"section 9417 of this title","children":[],"tail":" upon any person who has completed a program prescribed by the Community College of the Air Force."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724786-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9415/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No degree may be conferred upon any person under this section unless the Secretary of Education determines that the standards for the award of academic degrees in agencies of the United States have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab724787-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/361/tVI/s602"},"text":"Pub. L. 94–361, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-14"},"text":"July 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/928"},"text":"90 Stat. 928","children":[],"tail":", § 9315; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s514/9"},"text":"Pub. L. 96–513, title V, § 514(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2935"},"text":"94 Stat. 2935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1182/a/12"},"text":"Pub. L. 103–160, div. A, title XI, § 1182(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1772"},"text":"107 Stat. 1772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1078/a"},"text":"Pub. L. 104–106, div. A, title X, § 1078(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/451"},"text":"110 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s552/a"},"text":"Pub. L. 105–85, div. A, title V, § 552(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1748"},"text":"111 Stat. 1748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s556/b"},"text":"Pub. L. 108–375, div. A, title V, § 556(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1915"},"text":"118 Stat. 1915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s555/a"},"text":"Pub. L. 112–81, div. A, title V, § 555(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1415"},"text":"125 Stat. 1415","children":[],"tail":"; renumbered § 9415 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 806(a)(3), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":", 1840; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s557"},"text":"Pub. L. 116–92, div. A, title V, § 557","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1392"},"text":"133 Stat. 1392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/d/6"},"text":"Pub. L. 116–283, div. A, title IX, § 923(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3814"},"text":"134 Stat. 3814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab724788-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab724789-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab72478a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9415 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s349"},"text":"section 349 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab72478b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/6/A"},"text":"Pub. L. 116–283, § 923(d)(6)(A)","children":[],"tail":", substituted “in the Department of the Air Force” for “in the Air Force” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/6/B/i"},"text":"Pub. L. 116–283, § 923(d)(6)(B)(i)","children":[],"tail":", inserted “or the Space Force” after “Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/6/B/ii"},"text":"Pub. L. 116–283, § 923(d)(6)(B)(ii)","children":[],"tail":", substituted “other than the Air Force or the Space Force who are serving as instructors at Department of the Air Force training schools.” for “other than the Air Force who are serving as instructors at Air Force training schools.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/6/B/iii"},"text":"Pub. L. 116–283, § 923(d)(6)(B)(iii)","children":[],"tail":", which directed amendment of par. (3) by inserting “or the Space Force” after “Air Force”, was executed by making the insertion after “Air Force” the first place appearing to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s806/a/3"},"text":"Pub. L. 115–232, § 806(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9315"},"text":"section 9315 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 9417” for “section 9317”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s555/a/2"},"text":"Pub. L. 112–81, § 555(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s555/a/1"},"text":"Pub. L. 112–81, § 555(a)(1)","children":[],"tail":", (b), redesignated subsec. (c) as (d) and substituted “person” for “enlisted member” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" amended heading and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Subject to paragraph (2), the commander of the Air Education and Training Command of the Air Force may confer an academic degree at the level of associate upon any enlisted member who has completed the program prescribed by the Community College of the Air Force.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) No degree may be conferred upon any enlisted member under this section unless (A) the Community College of the Air Force certifies to the commander of the Air Education and Training Command of the Air Force that such member has satisfied all the requirements prescribed for such degree, and (B) the Secretary of Education determines that the standards for the award of academic degrees in agencies of the United States have been met.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s552/b/1"},"text":"Pub. L. 105–85, § 552(b)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s552/a/1"},"text":"Pub. L. 105–85, § 552(a)(1)","children":[],"tail":", substituted “enlisted members described in subsection (b)” for “enlisted members of the Air Force”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s552/a/4"},"text":"Pub. L. 105–85, § 552(a)(4)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated subsec. (c)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s552/a/2"},"text":"Pub. L. 105–85, § 552(a)(2)","children":[],"tail":", (3), (b)(2), redesignated subsec. (b) as subsec. (c)(1), inserted subsec. heading, substituted “Subject to paragraph (2),” for “Subject to subsection (c),”, and redesignated former subsec. (c) as subsec. (c)(2) and pars. (1) and (2) of former subsec. (c) as subpars. (A) and (B), respectively, of subsec. (c)(2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “Air Force” for “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/12/A"},"text":"Pub. L. 103–160, § 1182(a)(12)(A)","children":[],"tail":", substituted “Air Education and Training Command” for “Air Training Command”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/s1182/a/12/B"},"text":"Pub. L. 103–160, § 1182(a)(12)(B)","children":[],"tail":", substituted “Air Education and Training Command of the Air Force” for “Air Force Training Command”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Secretary of Education” for “Commissioner of Education of the Department of Health, Education, and Welfare”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab72478c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab72478d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab72478e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s555/c"},"text":"Pub. L. 112–81, div. A, title V, § 555(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1416"},"text":"125 Stat. 1416","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tV/s555/c"},"text":"“Subsection (c) of section 9315 [now 9415] of title 10, United States Code (as added by subsection (a)(2)), shall apply to persons covered by paragraph (1) of such subsection who are categorized by the Secretary concerned as seriously wounded, ill, or injured after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":". With respect to any such person who is separated from active duty during the period beginning on "},{"tag":"date","attrib":{"date":"2001-09-12"},"text":"September 12, 2001","children":[],"tail":