{"tag":"section","attrib":{"id":"idab238afe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8412"},"text":null,"children":[{"tag":"num","attrib":{"value":"8412"},"text":"§ 8412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation cadets: benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in section 402(a) and (b) of title 37, aviation cadets or their beneficiaries are entitled to the same allowances, pensions, gratuities, and other benefits as are provided for enlisted members in pay grade E–4. While on active duty, an aviation cadet is entitled to uniforms, clothing, and equipment at the expense of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab238aff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/426"},"text":"70A Stat. 426","children":[],"tail":", § 6912; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/147/A"},"text":"Pub. L. 85–861, § 1(147)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1513"},"text":"72 Stat. 1513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s6/f/6"},"text":"Pub. L. 87–649, § 6(f)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/494"},"text":"76 Stat. 494","children":[],"tail":"; renumbered § 8412, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":