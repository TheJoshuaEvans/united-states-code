.C. 850e","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-08-04/ch547/s6"},"text":"Aug. 4, 1942, ch. 547, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/738"},"text":"56 Stat. 738","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “and at the same rates” are omitted as covered by the words “on the same basis”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “enlisted members in pay grade E–4” are substituted for “enlisted men of the fourth pay grade” to conform to the terminology of the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231"},"text":"37 U.S.C. 231","children":[],"tail":" et seq.). The words “by law or regulation” are omitted as surplusage. The words “and the premiums on their life insurance” are omitted as impliedly repealed by § 10 of the Insurance Act of 1951, "},{"tag":"ref","attrib":{"href":"/us/stat/65/37"},"text":"65 Stat. 37","children":[],"tail":", which provided that such premium payments shall not be made by the Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab238b03-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab238b04-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6912","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6912 is amended by eliminating subsections (a) (less clause (4)) and (b) and by substituting a reference to section 301 of the Career Compensation Act of 1949 for the reference to subsection (a) in former subsection (c). The substance of former subsections (a) (less clause (4)) and (b) is covered by the Career Compensation Act, as amended by the Act of ","children":[{"tag":"date","attrib":{"date":"1955-03-31"},"text":"March 31, 1955","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/69/19"},"text":"69 Stat. 19","children":[],"tail":") and section 10 of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab238b05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab238b06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6912"},"text":"section 6912 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":" substituted “section 402(a) and (b) of title 37” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t37/s251/a"},"text":"section 251(a) of title 37","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" substituted “benefits” for “pay and allowances” in section catchline, and struck out provisions which prescribed the rate of pay of cadets, which authorized them to receive the same allowances for subsistence as prescribed for officers, which related to the furnishing of quarters, medical care and hospitalization, and which authorized transportation and expenses while traveling under orders."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeadi