{"tag":"section","attrib":{"id":"ida97676a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392"},"text":null,"children":[{"tag":"num","attrib":{"value":"2392"},"text":"§ 2392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for strategic basing actions for the Department of the Air Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida97676a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programmatic Basing Decisions Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force (or a designee) shall not make any basing decision during the resource allocation plan or program objective memorandum process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97676a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the enactment of this section, and quarterly thereafter, the Secretary of the Air Force (or a designee) shall brief the congressional defense committees on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida97676aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic basing actions approved by the strategic basing panel for review by the strategic basing executive steering group during the quarter covered by the briefing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97676ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each strategic basing action not covered by a previous briefing, a description of the criteria for selection of candidate location for each such strategic basing action and how each criterion will be applied to the candidate locations to determine preferred location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97676ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Updates regarding candidate locations, preferred locations, and the final location selected for each strategic basing action covered by the briefing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97676ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any strategic basing actions with projected decision dates that will occur before the next scheduled briefing under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97676ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon request by either the Committee on Armed Services of the House of Representatives or of the Senate, the Secretary of the Air Force (or a designee) shall provide to such Committee a briefing on the information described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97676af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-briefing Changes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force (or a designee) shall notify the congressional defense committees, not later than seven days after the effective date of a change, if such change is a change—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida97676b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the selection criteria or the application of selection criteria, that would result in a different decision than briefed under subsection (b) regarding the enterprise definition, identified candidate locations, or identified preferred location; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97676b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the governance process used to oversee a strategic basing action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97676b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overseas Strategic Basing Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a strategic basing action relating to a military installation located outside of the United States, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, the Virgin Islands, the Commonwealth of the Northern Mariana Islands, or Guam, a notification required under this section may be provided in a classified form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97676b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2392/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “enterprise definition”, “program objective memorandum process”, “resource allocation plan”, “strategic basing action”, “strategic basing executive steering group”, and “strategic basing panel” have the meanings given, respectively, under the Department of the Air Force Instruction 10–503 (issued ","children":[{"tag":"date","attrib":{"date":"2023-06-12"},"text":"June 12, 2023","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2024-11-01"},"text":"November 1, 2024","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida97676b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2803/a"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2247"},"text":"138 Stat. 2247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida97676b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida97676b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida97676b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida97676b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2392 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4653"},"text":"section 4653 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida97676b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida97676ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2803/b"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2803(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2248"},"text":"138 Stat. 2248","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dB/tXXVIII/s2803/b"},"text":"“This section [enacting this section] and the amendments made by this section shall apply with respect to strategic basing actions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2392"},"text":"section 2392 of title 10","children":[],"tail":", United States Code, as added by this section) made by the Secretary of the Air Force on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
