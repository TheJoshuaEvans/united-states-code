{"tag":"section","attrib":{"id":"idab9622c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12010"},"text":null,"children":[{"tag":"num","attrib":{"value":"12010"},"text":"§ 12010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computations for Navy Reserve and Marine Corps Reserve: rule when fraction occurs in final result","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When there is a fraction in the final result of any computation under this chapter for the Navy Reserve or the Marine Corps Reserve, a fraction of one-half or more is counted as one, and a fraction of less than one-half is disregarded.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab9622c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2987"},"text":"108 Stat. 2987","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/GG"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(GG)","children":[],"tail":", (3)(I), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":", 3234.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9622c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab9622c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":