{"tag":"section","attrib":{"id":"idaa83c8a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603"},"text":null,"children":[{"tag":"num","attrib":{"value":"4603"},"text":"§ 4603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance notification of contract performance outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa83c8a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa83c8a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A firm that is performing a Department of Defense contract for an amount exceeding $10,000,000, or is submitting a bid or proposal for such a contract, shall notify the Department of Defense in advance of any intention of the firm or any first-tier subcontractor of the firm to perform outside the United States and Canada any part of the contract that exceeds $500,000 in value and could be performed inside the United States or Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a firm submitting a bid or proposal for a Department of Defense contract is required to submit a notification under this subsection, and the firm is aware, at the time it submits its bid or proposal, that the firm intends to perform outside the United States and Canada any part of the contract that exceeds $500,000 in value and could be performed inside the United States or Canada, the firm shall include the notification in its bid or proposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The notification by a firm under paragraph (1) with respect to a first-tier subcontractor shall be made, to the maximum extent practicable, at least 30 days before award of the subcontract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa83c8a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recipient of Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The firm shall transmit the notification—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa83c8a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract of a military department, to such officer or employee of that military department as the Secretary of the military department may direct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other Department of Defense contract, to such officer or employee of the Department of Defense as the Secretary of Defense may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa83c8ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Notifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall ensure that the notifications (or copies) are maintained in compiled form for a period of 5 years after the date of submission and are available for use in the preparation of the national defense technology and industrial base assessment carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4816"},"text":"section 4816 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa83c8ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to contracts for any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa83c8ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial products or commercial services (as defined in sections 103 and 103a, respectively, of title 41).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ores.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Natural gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Utilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Petroleum products and crudes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timber.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa83c8b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4603/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsistence.","children":[],"tail":"\n"}],"tail":"\n"}],"t