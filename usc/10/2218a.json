{"tag":"section","attrib":{"id":"ida941f91b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2218a"},"text":"§ 2218a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Sea-Based Deterrence Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida941f91c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the “National Sea-Based Deterrence Fund”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f91d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall administer the Fund consistent with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f91e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f91f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds in the Fund shall be available for obligation and expenditure only for construction (including design of vessels), purchase, alteration, and conversion of national sea-based deterrence vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds in the Fund may not be used for a purpose or program unless the purpose or program is authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be deposited in the Fund all funds appropriated to the Department of Defense for construction (including design of vessels), purchase, alteration, and conversion of national sea-based deterrence vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Funds After ","children":[],"tail":"5"},{"tag":"inline","attrib":{},"text":" Years","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No part of an appropriation that is deposited in the Fund pursuant to subsection (d) shall remain available for obligation more than five years after the end of fiscal year for which appropriated except to the extent specifically provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Enter Into Economic Order Quantity Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f924-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may use funds deposited in the Fund to enter into contracts known as “economic order quantity contracts” with private shipyards and other commercial or government entities to achieve economic efficiencies based on production economies for major components or subsystems. The authority under this subsection extends to the procurement of parts, components, and systems (including weapon systems) common with and required for other nuclear powered vessels under joint economic order quantity contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f925-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into under paragraph (1) shall provide that any obligation of the United States to make a payment under the contract is subject to the availability of appropriations for that purpose, and that total liability to the Government for termination of any contract entered into shall be limited to the total amount of funding obligated at time of termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f926-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Begin Manufacturing and Fabrication Efforts Prior to Ship Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f927-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may use funds deposited into the Fund to enter into contracts for advance construction of national sea-based deterrence vessels to support achieving cost savings through workload management, manufacturing efficiencies, or workforce stability, or to phase fabrication activities within shipyard and manage sub-tier manufacturer capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f928-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into under paragraph (1) shall provide that any obligation of the United States to make a payment under the contract is subject to the availability of appropriations for that purpose, and that total liability to the Government for termination of any contract entered into shall be limited to the total amount of funding obligated at time of termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f929-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Use Incremental Funding to Enter Into Contracts for Certain Items","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f92a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may use funds deposited into the Fund to enter into incrementally funded contracts for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f92b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance procurement of high value, long lead time items for nuclear powered vessels to better support construction schedules and achieve cost savings through schedule reductions and properly phased installment payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f92c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction of the first two Columbia class submarines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f92d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract entered into under paragraph (1) shall provide that any obligation of the United States to make a payment under the contract is subject to the availability of appropriations for that purpose, and that total liability to the Government for termination of any contract entered into shall be limited to the total amount of funding obligated at time of termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f92e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority for Multiyear Procurement of Critical Components to Support Continuous Production","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f92f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To implement the continuous production of critical components, the Secretary of the Navy may use funds deposited in the Fund, in conjunction with funds appropriated for the procurement of other nuclear-powered vessels, to enter into one or more multiyear contracts (including economic ordering quantity contracts), for the procurement of critical contractor-furnished and Government-furnished components for critical components of national sea-based deterrence vessels. The authority under this subsection extends to the procurement of equivalent critical components common with and required for other nuclear-powered vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f930-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each annual budget request submitted to Congress, the Secretary shall clearly identify funds requested for critical components and the individual ships and programs for which such funds are requested.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f931-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contract entered into pursuant to paragraph (1) shall provide that any obligation of the United States to make a payment under the contract is subject to the availability of appropriations for that purpose and that the total liability to the Government for the termination of the contract shall be limited to the total amount of funding obligated for the contract as of the date of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f932-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Budget requests submitted to Congress for the Fund shall separately identify the amount requested for programs, projects, and activities for construction (including design of vessels), purchase, alteration, and conversion of national sea-based deterrence vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida941f933-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida941f934-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Fund” means the National Sea-Based Deterrence Fund established by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f935-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “national sea-based deterrence vessel” means any submersible vessel constructed or purchased after fiscal year 2016 that is owned, operated, or controlled by the Department of Defense and that carries operational intercontinental ballistic missiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida941f936-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “critical component” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida941f937-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A common missile compartment component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f938-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A spherical air flask.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f939-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An air induction diesel exhaust valve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f93a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An auxiliary seawater valve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f93b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A hovering valve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f93c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A missile compensation valve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f93d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A main seawater valve.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f93e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A launch tube.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f93f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A trash disposal unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A logistics escape trunk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A torpedo tube.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A weapons shipping cradle weldment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A control surface.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A launcher component.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A propulsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Major bulkheads and tanks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All major pumps and motors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Large vertical array.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Atmosphere control equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f94a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/T"},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diesel systems and components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida941f94b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2218a/k/3/U"},"text":null,"children":[{"tag":"num","attrib":{"value":"U"},"text":"(U)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hydraulic valves and components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id