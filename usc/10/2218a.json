4b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida941f954-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (k)(3)(P) to (Z). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subpars. (P) to (Z)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “incrementally funded contracts for—” for “incrementally funded contracts for advance procurement of high value, long lead time items for nuclear powered vessels to better support construction schedules and achieve cost savings through schedule reductions and properly phased installment payments.” and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1022/c"},"text":"Pub. L. 115–91, § 1022(c)","children":[],"tail":", struck out “of the Common Missile Compartment” after “Continuous Production” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1022/a/2"},"text":"Pub. L. 115–91, § 1022(a)(2)","children":[],"tail":", substituted “equivalent critical components” for “equivalent critical parts, components, systems, and subsystems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1022/a/1"},"text":"Pub. L. 115–91, § 1022(a)(1)","children":[],"tail":", which directed the substitution of “critical components” for “the common missile compartment” wherever appearing, was executed by making the substitution for “the common missile compartment” the first time appearing and for “the common missile compartments” the second time appearing, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1022/a/1"},"text":"Pub. L. 115–91, § 1022(a)(1)","children":[],"tail":", substituted “critical components” for “the common missile compartment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1022/b"},"text":"Pub. L. 115–91, § 1022(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (i), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1023/a"},"text":"Pub. L. 114–328, § 1023(a)","children":[],"tail":", added subsec. (i) and redesignated former subsec. (i) as (j). Former subsec. (j) redesignated (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1023/a/1"},"text":"Pub. L. 114–328, § 1023(a)(1)","children":[],"tail":", redesignated subsec. (j) as (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1023/b"},"text":"Pub. L. 114–328, § 1023(b)","children":[],"tail":", substituted “any submersible vessel constructed or purchased after fiscal year 2016 that is” for “any vessel” and inserted “and” before “that carries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsecs. (f) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsecs. (f) to (h) and redesignated former subsecs. (f) and (g) as (i) and (j), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
