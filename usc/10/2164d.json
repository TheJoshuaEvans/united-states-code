{"tag":"section","attrib":{"id":"ida933a246-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2164d"},"text":"§ 2164d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on school closures and certain other actions with respect to schools operated by the Department of Defense Education Activity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9361247-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not take any action described in subsection (b) with respect to a school operated by the Department of Defense Education Activity unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9361248-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary submits to the Committees on Armed Services of the Senate and the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9361249-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written notice of the intent of the Secretary to take such action with respect to such school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936124a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report required under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936124b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written assurance that the Director of the Department of Defense Education Activity has met, engaged with, and solicited feedback from students, parents, teachers, administrators, military installation leadership, and the local community concerning the proposed action; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936124c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of one year has elapsed following the date on which the requirements under paragraph (1) have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida936124d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The actions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida936124e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Closing or terminating the operations of a school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida936124f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparing to close or terminate the operations of a school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361250-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing by 20 percent or more the number of spaces available for enrollment in a school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361251-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Significantly reducing the services provided by a school, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9361252-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum offerings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9361253-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special education services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9361254-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extracurricular activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361255-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transferring or conveying a school to a local educational agency or any other entity outside the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9361256-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before taking any action described in subsection (b), the Secretary of Defense shall prepare a report containing a justification and analysis of such action. Such justification and analysis shall include an explanation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9361257-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monetary costs to the Department of Defense of the action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9361258-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effects of the action on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9361259-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936125a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936125b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gifted education programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936125c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special education programs, including individualized education programs (as defined in section 614(d)(1)(A) of the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1414/d/1/A"},"text":"20 U.S.C. 1414(d)(1)(A)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936125d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational and other accommodations provided under section 504 of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936125e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Exceptional Family Member Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida936125f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies in the area of the affected school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9361260-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Local Educational Agency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “local educational agency” has the meaning given that term in section 8101 of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"20 U.S.C. 7801","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9361261-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s585/a"},"text":"Pub. L. 119–60, div. A, title V, § 585(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/891"},"text":"139 Stat. 891","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
