{"tag":"section","attrib":{"id":"idaaf8aabd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554"},"text":null,"children":[{"tag":"num","attrib":{"value":"7554"},"text":"§ 7554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property management contracts and leases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf8aabe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of each eligible facility that is made available for the ARMS Initiative, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8aabf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make full use of facility use contracts, leases, and other such commercial contractual instruments as may be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aac0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall evaluate, on the basis of efficiency, cost, emergency mobilization requirements, and the goals and purposes of the ARMS Initiative, the procurement of services from the property manager, including maintenance, operation, modification, infrastructure, environmental restoration and remediation, and disposal of ammunition manufacturing assets, and other services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aac1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, in carrying out paragraphs (1) and (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf8aac2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts, and provide for subcontracts, for terms up to 25 years, as the Secretary considers appropriate and consistent with the needs of the Department of the Army and the goals and purposes of the ARMS Initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aac3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use procedures that are authorized to be used under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a/5"},"text":"section 3204(a)(5) of this title","children":[],"tail":" when the contractor or subcontractor is a source specified in law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8aac4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration for Use","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8aac5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent provided in a contract entered into under this section for the use of property at an eligible facility that is accountable under the contract, the Secretary may accept consideration for such use that is, in whole or in part, in a form other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf8aac6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental payments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aac7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revenue generated at the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aac8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Forms of consideration acceptable under paragraph (1) for a use of an eligible facility or any property at an eligible facility include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaf8aac9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The improvement, maintenance, protection, repair, and restoration of the facility, the property, or any property within the boundaries of the installation where the facility is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aaca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reductions in overhead costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aacb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reductions in product cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaf8aacc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The demilitarization and storage of conventional ammunition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8aacd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7554/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority under paragraph (1) may be exercised without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":" and any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf8aace-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title III, § 344(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–69, § 4554; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIII/s323/b"},"text":"Pub. L. 109–163, div. A, title III, § 323(b)","children":[],"tail":", "