},{"tag":"p","attrib":{},"text":"The words “has been or shall hereafter”, “by operation of or in accordance with law”, and “and shall receive” are omitted as surplusage. The words “in the grade to which he is advanced” are substituted for the words “in accordance with such advanced rank”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b793b5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b793b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
