,"attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXV/s1532/b"},"text":"Pub. L. 98–525, title XV, § 1532(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2631"},"text":"98 Stat. 2631","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/525/tXV/s1532/b"},"text":"“The amendments made by subsection (a) [enacting this chapter] shall not affect rights that vested before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
