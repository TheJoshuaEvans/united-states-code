{"tag":"section","attrib":{"id":"idab55be56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8921"},"text":null,"children":[{"tag":"num","attrib":{"value":"8921"},"text":"§ 8921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unauthorized use of Marine Corps insignia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab55be57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The seal, emblem, and initials of the United States Marine Corps shall be deemed to be insignia of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may, except with the written permission of the Secretary of the Navy, use or imitate the seal, emblem, name, or initials of the United States Marine Corps in connection with any promotion, goods, services, or commercial activity in a manner reasonably tending to suggest that such use is approved, endorsed, or authorized by the Marine Corps or any other component of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab55be59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8921/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever it appears to the Attorney General of the United States that any person is engaged or is about to engage in an act or practice which constitutes or will constitute conduct prohibited by subsection (b), the Attorney General may initiate a civil proceeding in a district court of the United States to enjoin such act or practice. Such court may, at any time before final determination, enter such restraining orders or prohibitions, or take such other action as is warranted, to prevent injury to the United States or to any person or class of persons for whose protection the action is brought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab55be5a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXV/s1532/a/1"},"text":"Pub. L. 98–525, title XV, § 1532(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2631"},"text":"98 Stat. 2631","children":[],"tail":", § 7881; renumbered § 8921, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/13"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab55be5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab55be5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab55be5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8921 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9321"},"text":"section 9321 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"