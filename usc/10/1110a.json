{"tag":"section","attrib":{"id":"ida89650b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1110a"},"text":"§ 1110a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of certain individuals regarding options for enrollment under Medicare part B","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida89650b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida89650ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As soon as practicable, the Secretary of Defense shall notify each individual described in subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida89650bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the individual is no longer eligible for health care benefits under the TRICARE program under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida89650bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of options available for enrollment of the individual in the supplementary medical insurance program under part B of title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subsection, the Secretary of Defense shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida89650be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for identifying individuals described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida89650bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Health and Human Services to accurately identify and notify such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida89650c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this subsection is an individual who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida89650c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered beneficiary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to benefits under part A of title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":") under section 226(b) or section 226A of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s426/b"},"text":"42 U.S.C. 426(b)","children":[],"tail":" and 426–1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible to enroll in the supplementary medical insurance program under part B of such title (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida89650c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVII/s707/a"},"text":"Pub. L. 111–84, div. A, title VII, § 707(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2376"},"text":"123 Stat. 2376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida89650c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida89650c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida89650c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsecs. (a)(1)(B) and (b)(2), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Parts A and B of title XVIII of the Act are classified generally to parts A (§ 1395c et seq.) and B (§ 1395j et seq.), respectively, of subchapter XVIII of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
