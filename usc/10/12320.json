{"tag":"section","attrib":{"id":"idaba209dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12320"},"text":null,"children":[{"tag":"num","attrib":{"value":"12320"},"text":"§ 12320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve officers: grade in which ordered to active duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A reserve officer who is ordered to active duty or full-time National Guard duty shall be ordered to active duty or full-time National Guard duty in his reserve grade, except that a reserve officer who is credited with service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12207"},"text":"section 12207 of this title","children":[],"tail":" and is ordered to active duty and placed on the active-duty list may be ordered to active duty in a reserve grade and with a date of rank and position on the active-duty list determined under regulations prescribed by the Secretary of Defense based upon the amount of service credited."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaba209de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s106"},"text":"Pub. L. 96–513, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2868"},"text":"94 Stat. 2868","children":[],"tail":", § 689; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s4/g"},"text":"Pub. L. 97–22, § 4(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/127"},"text":"95 Stat. 127","children":[],"tail":"; renumbered § 12320 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1625, 1662(e)(2), 1675(c)(11), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2962"},"text":"108 Stat. 2962","children":[],"tail":", 2992, 3018; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/a/2"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/495"},"text":"110 Stat. 495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba209df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba209e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba209e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1625"},"text":"Pub. L. 103–337, § 1625","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/c/11"},"text":"Pub. L. 103–337, § 1675(c)(11)","children":[],"tail":", substituted “12207” for “3353, 5600, or 8353”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/e/2"},"text":"Pub. L. 103–337, § 1662(e)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{