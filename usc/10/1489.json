{"tag":"section","attrib":{"id":"ida8db6fb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489"},"text":null,"children":[{"tag":"num","attrib":{"value":"1489"},"text":"§ 1489.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death gratuity: members and employees dying outside the United States while assigned to intelligence duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8db6fb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may pay a gratuity to the surviving dependents of any member of the armed forces or of any employee of the Department of Defense—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8db6fb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8db6fb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to duty with an intelligence component of the Department of Defense and whose identity as such a member or employee is disguised or concealed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8db6fba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is within a category of individuals determined by the Secretary of Defense to be engaged in clandestine intelligence activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6fbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who after ","children":[{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":" dies as a result of injuries (excluding disease) sustained outside the United States and whose death—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8db6fbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resulted from hostile or terrorist activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8db6fbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurred in connection with an intelligence activity having a substantial element of risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8db6fbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any payment under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8db6fbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in an amount equal to the amount of the annual basic pay or salary of the member or employee concerned at the time of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6fc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered a gift and shall be in lieu of payment of any lesser death gratuity authorized by this chapter or any other Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6fc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1489/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made under the same conditions as apply to payments authorized by section 413 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3973"},"text":"22 U.S.C. 3973","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8db6fc2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/450/tIV/s403/b/1"},"text":"Pub. L. 96–450, title IV, § 403(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1979"},"text":"94 Stat. 1979","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s11/a/6"},"text":"Pub. L. 97–22, § 11(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/138"},"text":"95 Stat. 138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1268/9"},"text":"Pub. L. 98–94, title XII, § 1268(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/706"},"text":"97 Stat. 706","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1303/a/12"},"text":"Pub. L. 99–145, title XIII, § 1303(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/739"},"text":"99 Stat. 739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8db6fc3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8db6fc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8db6fc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" substituted “armed forces” for “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"October 14, 1980","children":[],"tail":"” for “the date of the enactment of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":" substituted “section 413 of the Foreign Service Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3973"},"text":"22 U.S.C. 3973","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/s14"},"text":"section 14 of the Act of August 1, 1956","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2679a"},"text":"22 U.S.C. 2679a","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
