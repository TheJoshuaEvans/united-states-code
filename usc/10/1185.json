{"tag":"section","attrib":{"id":"ida8ae1de4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185"},"text":null,"children":[{"tag":"num","attrib":{"value":"1185"},"text":"§ 1185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ae1de5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary of Defense, each officer required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1181"},"text":"section 1181 of this title","children":[],"tail":" to show cause for retention on active duty—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ae1de6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be notified in writing, at least 30 days before the hearing of his case by a board of inquiry, of the reasons for which he is being required to show cause for retention on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ae1de7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be allowed a reasonable time, as determined by the board of inquiry, to prepare his showing of cause for his retention on active duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ae1de8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (c), shall be allowed to appear in person and to be represented by counsel at proceedings before the board of inquiry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ae1de9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be allowed full access to, and shall be furnished copies of, records relevant to his case, except that the board of inquiry shall withhold any record that the Secretary concerned determines should be withheld in the interest of national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ae1dea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a record is withheld under subsection (a)(4), the officer whose case is under consideration shall, to the extent that the interest of national security permits, be furnished a summary of the record so withheld.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ae1deb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1185/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may determine that, in exceptional circumstances, the appearance of an officer before the proceedings of a board of inquiry may be via means other than in person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ae1dec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s110"},"text":"Pub. L. 96–513, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2874"},"text":"94 Stat. 2874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s509/a"},"text":"Pub. L. 118–159, div. A, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1872"},"text":"138 Stat. 1872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8ae1ded-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ae1dee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ae1def-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s509/a/1"},"text":"Pub. L. 118–159, § 509(a)(1)","children":[],"tail":", substituted “subject to subsection (c), shall be” for “shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s509/a/2"},"text":"Pub. L. 118–159, § 509(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8ae1df0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8ae1df1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under this section effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
