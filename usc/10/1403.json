{"tag":"section","attrib":{"id":"ida8bebf63-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1403"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403"},"text":"§ 1403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disability retired pay: treatment under Internal Revenue Code of 1986","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"That part of the retired pay of a member of an armed force, computed under formula No. 1 or 2 of section 1401, or under section 1402(d) or 1402a(d) of this title on the basis of years of service, which exceeds the retired pay that he would receive if it were computed on the basis of percentage of disability is not considered as a pension, annuity, or similar allowance for personal injury, or sickness, resulting from active service in the armed forces, under section 104(a) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8bebf64-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/108"},"text":"70A Stat. 108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/342/tVIII/s813/b/3/C"},"text":"Pub. L. 96–342, title VIII, § 813(b)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1104"},"text":"94 Stat. 1104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/52/A"},"text":"Pub. L. 96–513, title V, § 511(52)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2925"},"text":"94 Stat. 2925","children":[],"tail":"; "},{"tag":"ref","at