{"tag":"section","attrib":{"id":"idab1a15cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298"},"text":null,"children":[{"tag":"num","attrib":{"value":"8298"},"text":"§ 8298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations of time","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1a15cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8296"},"text":"section 8296 of this title","children":[],"tail":" or subsection (b), no medal of honor, Navy cross, distinguished-service medal, silver star medal, Navy and Marine Corps Medal, or bar, emblem, or insignia in place thereof may be awarded to a person unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1a15ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award is made within five years after the date of the act or service justifying the award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1a15cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the act or distinguished service and recommending official recognition of it was made by his superior through official channels within three years from the date of that act or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1a15d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary of the Navy determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1a15d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement setting forth the act or distinguished service and recommending official recognition of it was made by the person’s superior through official channels within three years from the date of that act or service and was supported by sufficient evidence within that time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1a15d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8298/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no award was made, because the statement was lost or through inadvertence the recommendation was not acted on;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a medal of honor, Navy cross, distinguished-service medal, silver star medal, Navy and Marine Corps Medal, or bar, emblem, or insignia in place thereof, as the case may be, may be awarded to the person within two years after the date of that determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1a15d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/390"},"text":"70A Stat. 390","children":[],"tail":", § 6248; "},{"tag":"ref","attrib":{"href":"/us/pl/86/582/s1/2"},"text":"Pub. L. 86–582, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tai