{"tag":"section","attrib":{"id":"idaabab7bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111"},"text":null,"children":[{"tag":"num","attrib":{"value":"6111"},"text":"§ 6111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockpile stewardship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabab7c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy, acting through the Administrator, shall establish a stewardship program to ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab7c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of the core intellectual and technical competencies of the United States in nuclear weapons, including weapons design, system integration, manufacturing, security, use control, reliability assessment, and certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the nuclear weapons stockpile is safe, secure, and reliable without the use of underground nuclear weapons testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab7c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab7c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An increased level of effort for the construction of new facilities and the modernization of existing facilities with production and manufacturing capabilities that are necessary to support the deterrence of strategic attacks against the United States by maintaining and enhancing the performance, reliability, and security of the United States nuclear weapons stockpile, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab7c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nuclear weapons production facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production and manufacturing capabilities resident in the national security laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for advanced computational capabilities to enhance the simulation and modeling capabilities of the United States with respect to the performance over time of nuclear weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for above-ground experimental programs, such as hydrotesting, high-energy lasers, inertial confinement fusion, plasma physics, and materials research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for the modernization of facilities and projects that contribute to the experimental capabilities of the United States that support the sustainment and modernization of the United States nuclear weapons stockpile and the capabilities required to assess nuclear weapons effects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab7ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Support for the use of, and experiments facilitated by, the advanced experimental facilities of the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab7cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Ignition Facility at Lawrence Livermore National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Dual Axis Radiographic Hydrodynamic Test Facility at Los Alamos National Laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Z Machine at Sandia National Laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab7ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6111/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the experimental facilities at the Nevada National Security Site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabab7cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1344"},"text":"139 Stat. 1344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabab7d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabab7d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabab7d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6111, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/381"},"text":"70A Stat. 381","children":[],"tail":", related to withholding of pay during absence due to use of alcohol or drugs, and is covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s802"},"text":"section 802 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/35"},"text":"Pub. L. 87–649, § 14c(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2521"},"text":"section 2521 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaabab7d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaabab7d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consultation Requirement With Respect To Transfer to Private Entities of Plutonium or Plutonium Materials; Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3128"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1470"},"text":"139 Stat. 1470","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dC/tXXXI/s3128"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall, on an ongoing basis, consult with the Secretary of Defense with respect to any plans of the Secretary of Energy relating to the transfer to a private entity from Federal stockpiles or storage of any plutonium or plutonium materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation prior to transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy may not carry out any such transfer before the date on which such Secretary consults, pursuant to paragraph (1), with the Secretary of Defense with respect to the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification; Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days before any date on which the Secretary of Energy carries out a transfer to a private entity of plutonium or plutonium materials, such Secretary shall submit to the appropriate congressional committees the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A notification of the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the plutonium and plutonium materials to be transferred that includes the—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amount;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"     “(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"     “(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relative condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"     “(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current location;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private entity to which such plutonium and plutonium materials will be transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the destination location to which such plutonium and plutonium materials will be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of the purpose of the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of any direct costs to the United States Government associated with the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (c), a written certification, prepared in coordination with the Under Secretary of Energy for Nuclear Security and the Secretary of Defense, that such transfer does not negatively impact the needs of the nuclear weapons stockpile, including such needs related to stockpile stewardship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A written certification under subsection (b)(3) shall not be required for the transfer of materials from the 34 metric tons of defense plutonium or defense plutonium materials at the Savannah River Site previously declared excess to defense needs and designated for disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the House of Representatives and the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on [Energy and] Natural Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘private entity’ means any individual or organization other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department or agency of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor or subcontractor for management and operations, site cleanup, or site management activities at facilities owned by the Department of Energy.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaabab7d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan for Developing Exascale Computing and Incorporating Such Computing Into the Stockpile Stewardship Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dC/tXXXI/s3129"},"text":"Pub. L. 113–66, div. C, title XXXI, § 3129","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1066"},"text":"127 Stat. 1066","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/c/2/H"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(c)(2)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1460"},"text":"139 Stat. 1460","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dC/tXXXI/s3111/c/2/H"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator for Nuclear Security shall develop and carry out a plan to develop exascale computing and incorporate such computing into the stockpile stewardship program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6111"},"text":"section 6111 of title 10","children":[],"tail":", United States Code, during the 10-year period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Milestones","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required by subsection (a) shall include major programmatic milestones in—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a prototype exascale computer for the stockpile stewardship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating disruptions resulting from the transition to exascale computing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the plan required by subsection (a), the Administrator shall coordinate, as appropriate, with the Under Secretary of Energy for Science, the Secretary of Defense, and elements of the intelligence community (as defined in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of Costs in Future-Years Nuclear Security Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" address, in the estimated expenditures and proposed appropriations reflected in each future-years nuclear security program submitted under section 3253 of the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2453"},"text":"50 U.S.C. 2453","children":[],"tail":") during the 10-year period beginning on the date of the enactment of this Act, the costs of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing exascale computing and incorporating such computing into the stockpile stewardship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating potential disruptions resulting from the transition to exascale computing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in each such future-years nuclear security program a description of the costs of efforts to develop exascale computing borne by the National Nuclear Security Administration, the Office of Science of the Department of Energy, other Federal agencies, and private industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall submit the plan required by subsection (a) to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] with each summary of the plan required by subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6114"},"text":"section 6114 of title 10","children":[],"tail":", United States Code, submitted under subsection (b)(1) of that section during the 10-year period beginning on the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exascale Computing Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘exascale computing’ means computing through the use of a computing machine that performs near or above 10 to the 18th power floating point operations per second.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
