{"tag":"section","attrib":{"id":"idabb2abcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14309"},"text":null,"children":[{"tag":"num","attrib":{"value":"14309"},"text":"§ 14309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of promotion; oath of office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb2abcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is appointed to a higher grade under this chapter shall be considered to have accepted the appointment on the date on which the appointment is made unless the officer expressly declines the appointment or is granted a delay of promotion under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14312"},"text":"section 14312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb2abcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oath","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who has served continuously since taking the oath of office prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of title 5","children":[],"tail":" is not required to take a new oath upon appointment to a higher grade under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb2abce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2938"},"text":"108 Stat. 2938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb2abcf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb2abd0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idabb2abd1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 3394 and 8394 of this title, prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1629/a/1"},"text":"Pub. L. 103–337, § 1629(a)(1)","children":[],"tail":", (c)(1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb2abd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb2abd3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
