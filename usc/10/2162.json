{"tag":"section","attrib":{"id":"ida9313127-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162"},"text":null,"children":[{"tag":"num","attrib":{"value":"2162"},"text":"§ 2162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of budget requests for operation of professional military education schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9313128-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniform Cost Accounting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, with the advice and assistance of the Chairman of the Joint Chiefs of Staff, shall promulgate a uniform cost accounting system for use by the Secretaries of the military departments in preparing budget requests for the operation of professional military education schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9313129-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparation of Budget Requests","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida931312a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts requested for a fiscal year for the operation of each professional military education school shall be set forth as a separate budget request in the materials submitted by the Secretary of Defense to Congress in support of the budget request for the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida931312b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As executive agent for funding professional development education at the National Defense University, including the Joint Forces Staff College, the Secretary of Defense, with the advice of the Chairman of the Joint Chiefs of Staff, shall prepare the annual budget for professional development education operations at the National Defense University and set forth that request as a separate budget request in the materials submitted to Congress in support of the budget request for the Department of Defense. Nothing in the preceding sentence affects policies in effect on ","children":[{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":", with respect to budgeting for the funding of logistical and base operations support for components of the National Defense University through the military departments."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida931312c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department preparing a budget request for a professional military education school shall carefully consider the views of the Chairman of the Joint Chiefs of Staff, particularly with respect to the amount of the request for the operation of the schools of the National Defense University and the joint professional military education curricula of the other professional military education schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida931312d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comparison of Budget Requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Materials prepared in support of the budget request for a professional military education school shall describe whether the amount requested for that school is comparable to the amounts requested for other professional military education schools, taking into consideration the size and activities of the schools.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida931312e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Professional Military Education Schools","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to each of the following professional military education schools:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida931312f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Defense University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313130-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Army War College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313131-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The College of Naval Warfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313132-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Air War College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313133-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Army Command and General Staff College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313134-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The College of Naval Command and Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313135-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Air Command and Staff College.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313136-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Marine Corps University.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313137-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Space Force Senior Level Education Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9313138-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2162/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Space Force Intermediate Level Education Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9313139-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIX/s911/a"},"text":"Pub. L. 101–510, div. A, title IX, § 911(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1625"},"text":"104 Stat. 1625","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX/s921/b"},"text":"Pub. L. 105–85, div. A, title IX, § 921(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1862"},"text":"111 Stat. 1862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s527/b"},"text":"Pub. L. 107–107, div. A, title V, § 527(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1102"},"text":"115 Stat. 1102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1062/a/7"},"text":"Pub. L. 107–314, div. A, title X, § 1062(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2650"},"text":"116 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s552/b"},"text":"Pub. L. 119–60, div. A, title V, § 552(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/877"},"text":"139 Stat. 877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida931313a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida931313b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida931313c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added pars. (9) and (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"December 28, 2001","children":[],"tail":",” for “the date of the enactment of this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—In this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘professional military education school’ means—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the National Defense University;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the Army War College;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the College of Naval Warfare;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the Air War College;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) the United States Army Command and General Staff College;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) the College of Naval Command and Staff;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) the Air Command and Staff College; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(H) the Marine Corps Command and Staff College.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘National Defense University’ means the National War College, the Armed Forces Staff College, and the Industrial College of the Armed Forces.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida931313d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida931313e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIX/s911/b"},"text":"Pub. L. 101–510, div. A, title IX, § 911(b)[(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1626"},"text":"104 Stat. 1626","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/510/dA/tIX/s911/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2162"},"text":"Section 2162 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to fiscal years after fiscal year 1991.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida931313f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Executive Agent for Funding Professional Development Education","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s527/a"},"text":"Pub. L. 107–107, div. A, title V, § 527(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1101"},"text":"115 Stat. 1101","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tV/s527/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective beginning with fiscal year 2003, the Secretary of Defense shall be the executive agent for funding professional development education operations of all components of the National Defense University, including the Joint Forces Staff College. The Secretary may not delegate the Secretary’s functions and responsibilities under the preceding sentence to the Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subsection affects policies in effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"] with respect to—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reporting of the President of the National Defense University to the Chairman of the Joint Chiefs of Staff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of logistical and base operations support for components of the National Defense University by the military departments.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
