{"tag":"section","attrib":{"id":"ida984a8fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493"},"text":null,"children":[{"tag":"num","attrib":{"value":"2493"},"text":"§ 2493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fisher Houses: administration as nonappropriated fund instrumentality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida984a8ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fisher Houses and Suites Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida984a900-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Fisher House” means a housing facility that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a901-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in proximity to a health care facility of the Army, the Air Force, or the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a902-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is available for residential use on a temporary basis by authorized Fisher House residents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a903-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is constructed and donated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida984a904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Zachary and Elizabeth M. Fisher Armed Services Foundation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida984a905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another source, if the Secretary of the military department concerned designates the housing facility as a Fisher House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Fisher House” includes the Fisher House for the Families of the Fallen and Meditation Pavilion at Dover Air Force Base, Delaware, so long as such facility is available for residential use on a temporary basis by authorized Fisher House residents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Fisher Suite” means one or more rooms that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements of subparagraphs (A) and (B) of paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are constructed, altered, or repaired and donated by a source described in subparagraph (C) of that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida984a90a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are designated by the Secretary of the military department concerned as a Fisher Suite.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida984a90b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “authorized Fisher House residents” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida984a90c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a Fisher House described in paragraph (1) that is located in proximity to a health care facility of the Army, the Air Force, or the Navy, the following persons:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida987190d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patients of that health care facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida987190e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the families of such patients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida987190f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other persons providing the equivalent of familial support for such patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9871910-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the Fisher House described in paragraph (2), the following persons:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9871911-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The primary next of kin of a member of the armed forces who dies while located or serving overseas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9871912-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other family members of the deceased member who are eligible for transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s453/f"},"text":"section 453(f) of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9871913-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An escort of a family member described in clause (i) or (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871914-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonappropriated Fund Instrumentality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall administer all Fisher Houses and Fisher Suites associated with facilities of that military department as a nonappropriated fund instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871915-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Governance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall establish a system for the governance of the nonappropriated fund instrumentality required by subsection (b) for that military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871916-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Central Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of each military department shall establish a single fund as the source of funding for the operation, maintenance, and improvement of all Fisher Houses and Fisher Suites of the nonappropriated fund instrumentality required by subsection (b) for that military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Contributions; Imposition of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9871919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept money, property, and services donated for the support of a Fisher House or Fisher Suite associated with facilities of that military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida987191a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may impose fees relating to the use of such Fisher Houses and Fisher Suites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida987191b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All monetary donations, and the proceeds of the disposal of any other donated property, accepted by the Secretary of a military department under this subsection shall be credited to the fund established under subsection (d) for the Fisher Houses and Fisher Suites associated with facilities of that military department and shall be available to that Secretary to support all such Fisher Houses and Fisher Suites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida987191c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2493/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Base Operating Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may provide base operating support for Fisher Houses associated with facilities of that military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida987191d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIX/s906/a/1"},"text":"Pub. L. 105–261, div. A, title IX, § 906(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2093"},"text":"112 Stat. 2093","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 914(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–230; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIII/s321"},"text":"Pub. L. 107–314, div. A, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2510"},"text":"116 Stat. 2510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1061/17"},"text":"Pub. L. 112–81, div. A, title X, § 1061(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1584"},"text":"125 Stat. 1584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tVI/s652/a"},"text":"Pub. L. 112–239, div. A, title VI, § 652(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1784"},"text":"126 Stat. 1784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s622/b"},"text":"Pub. L. 114–92, div. A, title VI, § 622(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/841"},"text":"129 Stat. 841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/c/7"},"text":"Pub. L. 117–263, div. A, title VI, § 626(c)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2628"},"text":"136 Stat. 2628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida987191e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida987191f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9871920-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 453(f)” for “section 481f(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “section 481f(d)” for “section 481f(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":". § 652(a)(1), substituted “by authorized Fisher House residents;” for “by patients of that health care facility, members of the families of such patients, and others providing the equivalent of familial support for such patients;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s652/a/2"},"text":"Pub. L. 112–239, § 652(a)(2)","children":[],"tail":"–(4), added pars. (2) and (4) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s652/b"},"text":"Pub. L. 112–239, § 652(b)","children":[],"tail":", struck out “health care” before “facilities” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" struck out subsec. (g), which required submission of annual report describing the operation of Fisher Houses and Fisher Suites associated with military department health care facilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" amended heading and text of subsec. (f) generally. Prior to amendment text read as follows: “The Secretary of the Navy shall provide base operating support for Fisher Houses associated with health care facilities of the Navy. The level of the support shall be equivalent to the base operating support that the Secretary provides for morale, welfare, and recreation category B community activities (as defined in regulations, prescribed by the Secretary, that govern morale, welfare, and recreation activities associated with Navy installations).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9871921-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9871922-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 914(c)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–230, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“The amendments made by subsection (a) [amending this section] shall be effective as of ","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"October 17, 1998","children":[],"tail":", as if included in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493"},"text":"section 2493 of title 10","children":[],"tail":", United States Code, as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/s906/a"},"text":"section 906(a) of Public Law 105–261","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"ida9871923-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provisions for Certain Navy Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 914(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–230, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may continue to employ, and pay out of appropriated funds, any employee of the Navy in the competitive service who, as of ","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"October 17, 1998","children":[],"tail":", was employed by the Navy in a position at a Fisher House administered by the Navy, but only for so long as the employee is continuously employed in that position."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After a person vacates a position in which the person was continued to be employed under the authority of paragraph (1), a person employed in that position shall be employed as an employee of a nonappropriated fund instrumentality of the United States and may not be paid for services in that position out of appropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘Fisher House’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493/a/1"},"text":"section 2493(a)(1) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘competitive service’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2102"},"text":"section 2102 of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 914(c)(2)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–230, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“Subsection (b) [set out above] applies with respect to the pay period that includes ","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"October 17, 1998","children":[],"tail":", and subsequent pay periods.”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9871924-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Funds and Funding Transition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIX/s906/b"},"text":"Pub. L. 105–261, div. A, title IX, § 906(b)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2095"},"text":"112 Stat. 2095","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tIX/s906/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":"], the Secretary of each military department shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the fund required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493/d"},"text":"section 2493(d) of title 10","children":[],"tail":", United States Code (as added by subsection (a)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" close the Fisher House Trust Fund established for that department under section 2221 of such title and transfer the amounts in the closed fund to the newly established fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding Transition","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amount authorized to be appropriated pursuant to section 301(2) [","children":[{"tag":"ref","attrib":{"href":"/us/stat/112/1960"},"text":"112 Stat. 1960","children":[],"tail":"] for operation and maintenance for the Navy, the Secretary of the Navy shall transfer to the fund established by that Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493/d"},"text":"section 2493(d) of title 10","children":[],"tail":", United States Code (as added by subsection (a)), such amount as that Secretary considers appropriate for establishing in the fund a corpus sufficient for operating Fisher Houses and Fisher Suites associated with health care facilities of the Department of the Navy."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amount authorized to be appropriated pursuant to section 301(4) for operation and maintenance for the Air Force, the Secretary of the Air Force shall transfer to the fund established by that Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493/d"},"text":"section 2493(d) of title 10","children":[],"tail":", United States Code (as added by subsection (a)), such amount as that Secretary considers appropriate for establishing in the fund a corpus sufficient for operating Fisher Houses and Fisher Suites associated with health care facilities of the Department of the Air Force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of each military department, upon completing the actions required of the Secretary under subsections (b) and (c), shall submit to Congress a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certification of that Secretary that those actions have been completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the amount deposited in the fund established by that Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493/d"},"text":"section 2493(d) of title 10","children":[],"tail":", United States Code (as added by subsection (a))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Transferred Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts transferred under subsection (b) or (c) to a fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2493/d"},"text":"section 2493(d) of title 10","children":[],"tail":", United States Code (as added by subsection (a)), shall be available without fiscal year limitation for the purposes for which the fund is established and shall be administered as nonappropriated funds.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
