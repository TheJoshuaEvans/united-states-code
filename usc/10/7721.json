{"tag":"section","attrib":{"id":"idaafd65db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721"},"text":null,"children":[{"tag":"num","attrib":{"value":"7721"},"text":"§ 7721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and responsibilities of the Secretary of the Army","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaafd65dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall develop, operate, manage, administer, oversee, and fund the Army National Military Cemeteries specified in subsection (b) in a manner and to standards that fully honor the service and sacrifices of the deceased members of the armed forces buried or inurned in the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Army National Military Cemeteries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Army National Military Cemeteries (in this chapter referred to as the “Cemeteries”) consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaafd65de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arlington National Cemetery in Arlington, Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaafd65df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Soldiers’ and Airmen’s Home National Cemetery in the District of Colombia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Cemeteries shall be under the jurisdiction of Headquarters, Department of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Other Policies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall prescribe such regulations and policies as may be necessary to administer the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaafd65e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budgetary and Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall submit to the congressional defense committees and the Committees on Veterans’ Affairs of the Senate and House of Representatives an annual budget request (and detailed justifications for the amount of the request) to fund administration, operation and maintenance, and construction related to the Cemeteries. The Secretary may include, as necessary, proposals for new or amended statutory authority related to the Cemeteries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaafd65e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s591/a/1"},"text":"Pub. L. 112–81, div. A, title V, § 591(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1439"},"text":"125 Stat. 1439","children":[],"tail":", § 4721; renumbered § 7721, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaafd65e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaafd65e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaafd65e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7721 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8891"},"text":"section 8891 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaafd65e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4721"},"text":"section 4721 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaafd65e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaafd65e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaafd65ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"Dec. 31, 2021","children":[],"tail":", of provisions in subsec. (e) of this section relating to submitting annual budget request to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1061"},"text":"section 1061 of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaafd65eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Resumption of Caisson Services at Funeral Services at Arlington National Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1088"},"text":"Pub. L. 118–159, div. A, title X, § 1088","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2080"},"text":"138 Stat. 2080","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tX/s1088"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall conduct at least 20 funeral services with caisson services each week at Arlington National Cemetery beginning on the date on which the Secretary of the Army determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the renovations of the historic stables in buildings 233 and 236 at Joint Base Meyer-Henderson Hall are complete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the caisson herd is fully constituted, trained, and certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Option for Limited Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army may elect to resume limited caisson services at Arlington National Cemetery before the requirements of subsection (a) have been met if the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the health of the caisson herd and the sustainability of caisson services can be maintained without disruption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consults with the Committees on Armed Services of the Senate and House of Representatives before resuming such limited services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, with respect to the caisson herd:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘fully constituted’ means that such herd is comprised of at least—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four caisson squads of eleven horses in each;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 14 caparison horses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four outreach horses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘trained’ means that each caisson squad within such herd has completed the specialized training determined necessary by the Commander of the Military District of Washington to resume caisson support for funeral services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘certified’ means that the Commander of the Military District of Washington, in consultation with equine and veterinary experts, has confirmed to the Secretary of the Army that each caisson squad within such herd has met the training, health, and fitness requirements determined appropriate by the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaafd65ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Caisson Platoon and Support for Military and State Funeral Services at Arlington National Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIII/s366"},"text":"Pub. L. 118–31, div. A, title III, § 366","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/234"},"text":"137 Stat. 234","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tIII/s366"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department of the Army an equine unit, to be known as the ‘Caisson Platoon’, assigned to the 3rd Infantry Regiment of the Army. The duties of such unit shall include the provision of support for military and State funerals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions on Elimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may not eliminate the Caisson Platoon of the 3rd Infantry Regiment of the Army established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], and not less frequently than every 180 days thereafter until "},{"tag":"date","attrib":{"date":"2027-03-31"},"text":"March 31, 2027","children":[],"tail":", the Secretary of the Army shall provide to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] a briefing on the health, welfare, and sustainment of military working equids."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing under paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the ability of the Caisson Platoon of the 3rd Infantry Regiment of the Army to support military funeral operations within Arlington National Cemetery, including milestones associated with achieving full operational capability for such Caisson Platoon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An update on the plan of the task force known as the ‘Task Force-Military Working Equids’ established by the Office of the Surgeon General, as directed by the Director of the Army Staff, in May 2022 (or any successor task force), to promote, support, and sustain animal health and welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An update on the plan of such task force to ensure the Caisson Platoon of the 3rd Infantry Regiment of the Army has the ability to continuously support military and State funeral operations within Arlington National Cemetery.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaafd65ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Digitization of Arlington National Cemetery Interment and Inurnment Records","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s591/b"},"text":"Pub. L. 112–81, div. A, title V, § 591(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1441"},"text":"125 Stat. 1441","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tV/s591/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for conversion and use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-06-01"},"text":"June 1, 2012","children":[],"tail":", all records related to interments and inurnments at Arlington National Cemetery shall be converted to a digitized format. Thereafter, use of the digitized format shall be the method by which all subsequent records related to interments and inurnments at Arlington National Cemetery are preserved and utilized."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Digitized format defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term ‘digitized format’ refers to the use of an electronic database for recordkeeping and includes the full accounting of all records of each specific gravesite and niche location at Arlington National Cemetery and the identification of the individual interred or inurned at each specific gravesite and niche location.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
