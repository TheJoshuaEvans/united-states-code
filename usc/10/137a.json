{"tag":"section","attrib":{"id":"ida764fc23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a"},"text":null,"children":[{"tag":"num","attrib":{"value":"137a"},"text":"§ 137a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Under Secretaries of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida764fc24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida764fc25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are six Deputy Under Secretaries of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Under Secretaries of Defense shall be appointed from civilian life by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officials authorized under this section shall be the only Deputy Under Secretaries of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida764fc28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Deputy Under Secretary of Defense shall be the first assistant to an Under Secretary of Defense and shall assist such Under Secretary in the performance of the duties of the position of such Under Secretary and shall act for, and exercise the powers of, such Under Secretary when such Under Secretary dies, resigns, or is otherwise unable to perform the functions and duties of the office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida764fc29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida764fc2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense for Personnel and Readiness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense (Comptroller).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida764fc2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense for Intelligence and Security, who shall be appointed from among persons who have extensive expertise in intelligence matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida764fc30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s137a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Under Secretaries of Defense take precedence in the Department of Defense after the Secretary of Defense, the Deputy Secretary of Defense, the Secretaries of the military departments, and the Under Secretaries of Defense. The Deputy Under Secretaries shall take precedence among themselves in the order prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida764fc31-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tIX/s906/a/1"},"text":"Pub. L. 111–84, div. A, title IX, § 906(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2425"},"text":"123 Stat. 2425","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s901/b/3"},"text":"Pub. L. 111–383, div. A, title IX, § 901(b)(3)","children":[],"tail":", (k)(1)(A), "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4318"},"text":"124 Stat. 4318","children":[],"tail":", 4325; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIX/s901/i/1"},"text":"Pub. L. 113–291, div. A, title IX, § 901(i)(1)","children":[],"tail":", (j)(2)(C), (k)(3), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3467"},"text":"128 Stat. 3467","children":[],"tail":", 3468; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s906/a"},"text":"Pub. L. 115–91, div. A, title IX, § 906(a)","children":[],"tail":"–(c), (f)(1), title X, § 1081(b)(1)(A), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1513"},"text":"131 Stat. 1513","children":[],"tail":", 1514, 1597; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tX/s1081/f/1/C"},"text":"Pub. L. 115–232, div. A, title X, § 1081(f)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1986"},"text":"132 Stat. 1986","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVI/s1621/e/1/B"},"text":"Pub. L. 116–92, div. A, title XVI, § 1621(e)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1733"},"text":"133 Stat. 1733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s901/a/3"},"text":"Pub. L. 118–31, div. A, title IX, § 901(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/354"},"text":"137 Stat. 354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida764fc32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida764fc33-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida764fc34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" struck out “the Chief Management Officer of the Department of Defense,” after “the Deputy Secretary of Defense,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Deputy Under Secretary of Defense for Intelligence and Security” for “Deputy Under Secretary of Defense for Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “the Chief Management Officer of the Department of Defense, the Secretaries of the military departments, and the Under Secretaries of Defense” for “the Secretaries of the military departments, the Under Secretaries of Defense, and the Deputy Chief Management Officer of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/f/1"},"text":"Pub. L. 115–91, § 906(f)(1)","children":[],"tail":", amended section catchline generally, substituting “Deputy Under Secretaries of Defense” for “Principal Deputy Under Secretaries of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/b"},"text":"Pub. L. 115–91, § 906(b)","children":[],"tail":", substituted “six” for “five”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/a"},"text":"Pub. L. 115–91, § 906(a)","children":[],"tail":", struck out “Principal” before “Deputy Under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/a"},"text":"Pub. L. 115–91, § 906(a)","children":[],"tail":", struck out “Principal” before “Deputy Under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/a"},"text":"Pub. L. 115–91, § 906(a)","children":[],"tail":", struck out “Principal” before “Deputy Under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/c"},"text":"Pub. L. 115–91, § 906(c)","children":[],"tail":", added pars. (1) and (2), redesignated former pars. (2) to (5) as (3) to (6), respectively, and struck out former par. (1) which read as follows: “One of the Deputy Under Secretaries is the Deputy Under Secretary of Defense for Acquisition, Technology, and Logistics.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/a"},"text":"Pub. L. 115–91, § 906(a)","children":[],"tail":", struck out “Principal” before “Deputy Under” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/b/1/A"},"text":"Pub. L. 115–91, § 1081(b)(1)(A)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s901/j/2/C"},"text":"Pub. L. 113–291, § 901(j)(2)(C)","children":[],"tail":". See 2014 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s906/a"},"text":"Pub. L. 115–91, § 906(a)","children":[],"tail":", struck out “Principal” before “Deputy Under” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s901/i/1"},"text":"Pub. L. 113–291, § 901(i)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s901/k/3"},"text":"Pub. L. 113–291, § 901(k)(3)","children":[],"tail":", substituted “dies, resigns, or is otherwise unable to perform the functions and duties of the office” for “is absent or disabled”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s901/j/2/C"},"text":"Pub. L. 113–291, § 901(j)(2)(C)","children":[],"tail":", which directed substitution of “and the Under Secretaries of Defense.” for “the military departments, the Under Secretaries of Defense, and the Deputy Chief Management Officer of the Department of Defense.”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/b/1/A"},"text":"Pub. L. 115–91, § 1081(b)(1)(A)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/k/1/A"},"text":"Pub. L. 111–383, § 901(k)(1)(A)","children":[],"tail":", substituted “Principal Deputy Under Secretaries of Defense” for “Deputy Under Secretaries of Defense” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/A"},"text":"Pub. L. 111–383, § 901(b)(3)(A)","children":[],"tail":", substituted “Principal Deputy Under” for “Deputy Under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/B"},"text":"Pub. L. 111–383, § 901(b)(3)(B)","children":[],"tail":", struck out subpar. (A) and subpar. (B) designation and substituted “The Principal Deputy Under Secretaries of Defense” for “The Deputy Under Secretaries of Defense referred to in paragraphs (4) and (5) of subsection (c)”. Prior to amendment, subpar. (A) read as follows: “The Deputy Under Secretaries of Defense referred to in paragraphs (1) through (3) of subsection (c) shall be appointed as provided in the applicable paragraph.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/A"},"text":"Pub. L. 111–383, § 901(b)(3)(A)","children":[],"tail":", substituted “Principal Deputy Under” for “Deputy Under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/C/i"},"text":"Pub. L. 111–383, § 901(b)(3)(C)(i)","children":[],"tail":", (ii), substituted “One of the Principal Deputy” for “One of the Deputy” and struck out “appointed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s133a"},"text":"section 133a of this title","children":[],"tail":"” after “Logistics”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/C/i"},"text":"Pub. L. 111–383, § 901(b)(3)(C)(i)","children":[],"tail":", (ii), substituted “One of the Principal Deputy” for “One of the Deputy” and struck out “appointed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s134a"},"text":"section 134a of this title","children":[],"tail":"” after “Policy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/C/i"},"text":"Pub. L. 111–383, § 901(b)(3)(C)(i)","children":[],"tail":", (ii), substituted “One of the Principal Deputy” for “One of the Deputy” and struck out “appointed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s136a"},"text":"section 136a of this title","children":[],"tail":"” after “Readiness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/C/i"},"text":"Pub. L. 111–383, § 901(b)(3)(C)(i)","children":[],"tail":", (iii), substituted “One of the Principal Deputy Under Secretaries is” for “One of the Deputy Under Secretaries shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/C/i"},"text":"Pub. L. 111–383, § 901(b)(3)(C)(i)","children":[],"tail":", (iii), (iv), substituted “One of the Principal Deputy Under Secretaries is” for “One of the Deputy Under Secretaries shall be” and inserted before period at end “, who shall be appointed from among persons who have extensive expertise in intelligence matters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s901/b/3/A"},"text":"Pub. L. 111–383, § 901(b)(3)(A)","children":[],"tail":", (D), substituted “Principal Deputy Under” for “Deputy Under” and inserted at end “The Principal Deputy Under Secretaries shall take precedence among themselves in the order prescribed by the Secretary of Defense.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida764fc35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail"