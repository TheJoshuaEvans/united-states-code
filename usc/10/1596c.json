{"tag":"section","attrib":{"id":"ida8fcd9e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1596c"},"text":"§ 1596c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programming language proficiency: special pay for proficiency beneficial for national security interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fcd9e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, under the sole and exclusive discretion of the Secretary, may pay special pay under this section to an employee of the Department of Defense who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcd9e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified by the Secretary to be proficient in a computer or digital programming language identified by the Secretary as being a language in which proficiency by civilian personnel of the Department is necessary because of national security interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcd9e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned duties requiring proficiency in that programming language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rate of special pay for an employee under this section shall be prescribed by the Secretary, but may not exceed 20 percent of the employee’s rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Special pay under this section is in addition to any other pay or allowances to which the employee is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcd9e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tII/s241/c/1"},"text":"Pub. L. 116–283, div. A, title II, § 241(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3487"},"text":"134 Stat. 3487","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
