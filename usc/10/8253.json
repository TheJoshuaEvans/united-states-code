0A Stat. 503","children":[],"tail":", provided for temporary enlistments in Air Force during war or emergency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8255, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/504"},"text":"70A Stat. 504","children":[],"tail":", provided for recruiting campaigns to obtain enlistments in Regular Air Force."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8256, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/504"},"text":"70A Stat. 504","children":[],"tail":", set forth qualifications for and term of enlistments in Regular Air Force and grade in which such enlistments were made."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 8257 and 8258 were renumbered sections 9137 and 9138 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 8259 and 8260 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/b/3"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2990"},"text":"108 Stat. 2990","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8259, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/505"},"text":"70A Stat. 505","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 