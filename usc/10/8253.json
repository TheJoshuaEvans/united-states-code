{"tag":"section","attrib":{"id":"idab155aa9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8253"},"text":null,"children":[{"tag":"num","attrib":{"value":"8253"},"text":"§ 8253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans: Supply Corps officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by law, an officer in the Supply Corps on active duty may not advance or lend any sum of money, public or private, or any article or commodity and may not extend credit to any officer of the naval service on active duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab155aaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/381"},"text":"70A Stat. 381","children":[],"tail":", § 6113; renumbered § 8253, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1835"},"text":"132 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab155aab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab155aac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab155aad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6113","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s67"},"text":"34 U.S.C. 67","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1389.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “paymaster, passed assistant paymaster, or assistant paymaster” are omitted because those titles no longer exist, and the words “officer in the Supply Corps” are substituted therefor.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “except as otherwise provided by law” are added because the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-05/ch600"},"text":"Act of Oct. 5, 1949, ch. 600","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s875a"},"text":"34 U.S.C. 875a","children":[],"tail":"), authorizes advances of pay to personnel upon permanent changes of station or where such personnel are on distant duty stations where disbursements of pay and allowances cannot be regularly made, and § 303(a) of the Career Compensation Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s253"},"text":"37 U.S.C. 253","children":[],"tail":") authorizes advance payments of travel and transportation allowances. The words “on active duty” are supplied since the section has application to officers accountable for public funds or property. Officers not on active duty are not accountable officers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab155aae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab155aaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8253, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/503"},"text":"70A Stat. 503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/143/s1/2"},"text":"Pub. L. 87–143, § 1(2)","children":[],"tail":", "},{"tag":"date"