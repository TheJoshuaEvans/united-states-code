{"tag":"section","attrib":{"id":"ida8ff24e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599j"},"text":"§ 1599j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted reports of incidents of adult sexual assault","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8ff24e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restricted Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may provide a civilian employee of the Department of Defense an opportunity to submit to an individual described in subsection (d) a restricted report of an alleged incident of adult sexual assault for the purpose of assisting the employee in obtaining information and access to authorized victim support services provided by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff24e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions on Disclosures and Initiating Investigations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the Secretary determines that a disclosure is necessary to prevent or mitigate a serious and imminent safety threat to the employee submitting the report or to another person, a restricted report submitted pursuant to subsection (a) shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff24e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be disclosed to the supervisor of the employee or any other management official; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause the initiation of a Federal civil or criminal investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff24e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties Under Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The receipt of a restricted report submitted under subsection (a) shall not be construed as imputing actual or constructive knowledge of an alleged incident of sexual assault to the Department of Defense for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff24e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals Authorized to Receive Restricted Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this subsection is an individual who performs victim advocate duties under a program for one or more of the following purposes (or any other program designated by the Secretary):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff24ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sexual assault prevention and response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Victim advocacy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equal employment opportunity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Workplace violence prevention and response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employee assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family advocacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8ff24f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8ff24f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civilian employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “civilian employee” has the meaning given the term “employee” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8ff24f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual assault","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “sexual assault” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s920"},"text":"section 920 of this title","children":[],"tail":" (article 120 of the Uniform Code of Military Justice), and includes penetrative offenses and sexual contact offenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8ff24f3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXI/s1101/a"},"text":"Pub. L. 117–263, div. A, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2815"},"text":"136 Stat. 2815","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
