542/e"},"text":"section 542(e) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1141"},"text":"section 1141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8a96413-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/35"},"text":"Pub. L. 103–35","children":[],"tail":" applicable as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/s202/b"},"text":"section 202(b) of Pub. L. 103–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s155"},"text":"section 155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8a96414-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXLIV/s4405/c"},"text":"Pub. L. 102–484, div. A, title XLIV, § 4405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2706"},"text":"106 Stat. 2706","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tXLIV/s4405/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":"] shall apply as if included in sections 1174a and 1175 of title 10, United States Code, as enacted on "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"December 5, 1991","children":[],"tail":", but any benefits or services payable by reason of the applicability of the provisions of those amendments during the period beginning on "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"December 5, 1991","children":[],"tail":", and ending on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"] shall be subject to the availability of appropriations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8a96415-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Remedy for Ineffective Counseling of Officers Discharged Following Selection by Early Discharge Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV/s507"},"text":"Pub. L. 103–160, div. A, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1646"},"text":"107 Stat. 1646","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/b/1"},"text":"Pub. L. 103–337, div. A, title X, § 1070(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2856"},"text":"108 Stat. 2856","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tX/s1070/b/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of each military department shall establish a procedure for the review of the individual circumstances of an officer described in paragraph (2) who is discharged, or who the Secretary concerned approves for discharge, following the report of a selection board convened by the Secretary to select officers for separation. The procedure established by the Secretary of a military department under this section shall provide that each review under that procedure be carried out by the Board for the Correction of Military Records of that military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies in the case of any officer (including a warrant officer) who, having been offered the opportunity to be discharged or otherwise separated from active duty through the programs provided under section 1174a and 1175 of title 10, United States Code—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elected not to accept such discharge or separation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits an application under subsection (b) during the two-year period beginning on the later of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":"] and the date of such discharge or separation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review under this section shall be conducted in any case submitted to the Secretary concerned by application from the officer or former officer under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose of Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The review under this section shall be designed to evaluate the effectiveness of the counseling of the officer before the convening of the board to ensure that the officer was properly informed that selection for discharge or other separation from active duty was a potential result of being within the group of officers to be considered by the board and that the officer was not improperly informed that such selection in that officer’s personal case was unlikely.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board for the Correction of Military Records of a military department shall render a decision in each case under this section not later than 60 days after receipt by the Secretary concerned of an application under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a finding of ineffective counseling under subsection (c), the Secretary shall provide the officer the opportunity to participate, at the officer’s option, in any one of the following programs for which the officer meets all eligibility criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Separation Benefits program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174a"},"text":"section 1174a of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Voluntary Separation Incentive program under section 1175 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retirement under the authority provided by section 4403 of the National Defense Authorization Act for Fiscal Year 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/106/2702"},"text":"106 Stat. 2702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1293"},"text":"10 U.S.C. 1293","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply with respect to officers separated after ","children":[{"tag":"date","attrib":{"date":"1990-09-30"},"text":"September 30, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8abad06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separation Payments; Reductions and Prohibitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/335/tVIII/s8106A"},"text":"Pub. L. 103–335, title VIII, § 8106A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2645"},"text":"108 Stat. 2645","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/6/tI/s105/a"},"text":"Pub. L. 104–6, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-04-10"},"text":"Apr. 10, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/79"},"text":"109 Stat. 79","children":[],"tail":", which provided that members who separated after "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", from active duty or full-time National Guard duty in a military department pursuant to a Special Separation Benefits program under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174a"},"text":"section 1174a of this title","children":[],"tail":" or a Voluntary Separation Incentive program under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":" would have their separation payments reduced by the amount of certain bonus payments and eliminated if they are rehired within 180 days by the Department of Defense in a civilian position and that civilian Department of Defense employees would not receive voluntary separation payments if rehired by a Federal agency within 180 days of separating from the Department of Defense, was from the Department of Defense Appropriations Act, 1995, and was not repeated in subsequent appropriation acts. Similar provisions were contained in the following prior appropriation act:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/139/tVIII/s8127"},"text":"Pub. L. 103–139, title VIII, § 8127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-11"},"text":"Nov. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1469"},"text":"107 Stat. 1469","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8abad07-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commencement of Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s661/b"},"text":"Pub. L. 102–190, div. A, title VI, § 661(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1395"},"text":"105 Stat. 1395","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tVI/s661/b"},"text":"“The Secretary of each military department shall commence the program required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174a"},"text":"section 1174a of title 10","children":[],"tail":", United States Code (as added by subsection (a)), not later than 60 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8abad08-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s663"},"text":"Pub. L. 102–190, div. A, title VI, § 663","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1399"},"text":"105 Stat. 1399","children":[],"tail":", directed Secretary, not later than 180 days after "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", to submit to Congress a report containing the Secretary’s assessment of effectiveness of programs established under sections 1174a and 1175 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
