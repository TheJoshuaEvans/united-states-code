{"tag":"section","attrib":{"id":"ida8a963e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1174a"},"text":"§ 1174a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special separation benefits programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8a963e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall carry out a special separation benefits program under this section. An eligible member of the armed forces may request separation under the program. The request shall be subject to the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a963e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the approval of the request of an eligible member, the member shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a963ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be released from active duty or full-time National Guard duty or discharged, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be entitled to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8a963ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separation pay equal to 15 percent of the product of (i) the member’s years of active service, and (ii) 12 times the monthly basic pay to which the member is entitled at the time of his discharge or release from active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8a963ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same benefits and services as are provided under chapter 58 of this title, sections 452 and 453(c) of title 37, and section 503(c) of the National Defense Authorization Act for Fiscal Year 1991 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/104/1558"},"text":"104 Stat. 1558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s476"},"text":"37 U.S.C. 476","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002061"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002061"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" note) for members of the armed forces who are involuntarily separated within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1141"},"text":"section 1141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a963ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (d) and (e), a member of an armed force is eligible for voluntary separation under a program established for that armed force pursuant to this section if the member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a963ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been approved for payment of a voluntary separation incentive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served on active duty or full-time National Guard duty or any combination of active duty and full-time National Guard duty for more than 6 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served on active duty or full-time National Guard duty or any combination of active duty and full-time National Guard duty for not more than 20 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served at least 5 years of continuous active duty or full-time National Guard duty or any combination of active duty and full-time National Guard duty immediately preceding the date of the member’s separation from active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" meets such other requirements as the Secretary may prescribe, which may include requirements relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8a963f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" years of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8a963f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skill or rating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8a963f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grade or rank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8a963f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining period of obligated service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a963f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned may provide for the program under this section to apply to any of the following members:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a963f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A regular officer or warrant officer of an armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A regular enlisted member of an armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of an armed force other than a regular member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a963fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability Subject to Needs of the Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a963fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraphs (2) and (3), the Secretary concerned may limit the applicability of a program under this section to any category of personnel defined by the Secretary in order to meet a need of the armed force under the Secretary’s jurisdiction to reduce the number of members in certain grades, the number of members who have completed a certain number of years of active service, or the number of members who possess certain military skills or are serving in designated competitive categories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any category prescribed by the Secretary concerned for regular officers, regular enlisted members, or other members pursuant to paragraph (1) shall be consistent with the categories applicable to regular officers, regular enlisted members, or other members, respectively, under the voluntary separation incentive program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":" or any other program established by law or by that Secretary for the involuntary separation of such members in the administration of a reduction in force."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a963ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces offered a voluntary separation incentive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1175"},"text":"section 1175 of this title","children":[],"tail":" shall also be offered the opportunity to request separation under a program established pursuant to this section. If the Secretary concerned approves a request for separation under either such section, the member shall be separated under the authority of the section selected by such member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a96400-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a96401-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to be separated under a program established pursuant to this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8a96402-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a regular enlisted member eligible for separation under that program shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8a96403-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a request for separation under the program before the expiration of the member’s term of enlistment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8a96404-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon discharge at the end of such term, enter into a written agreement (pursuant to regulations prescribed by the Secretary concerned) not to request reenlistment in a regular component; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8a96405-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member referred to in subsection (d)(3) eligible for separation under that program shall submit a request for separation to the Secretary concerned before the expiration of the member’s established term of active service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a96406-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the entry of a member into an agreement referred to in paragraph (1)(A)(ii) under a program established pursuant to this section shall be considered a request for separation under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a96407-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Conditions, Requirements, and Administrative Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (e) through (h), other than subsection (e)(2)(A), of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174"},"text":"section 1174 of this title","children":[],"tail":" shall apply in the administration of programs established under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8a96408-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Program","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8a96409-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the Secretary concerned may not conduct a program pursuant to this section after ","children":[{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8a9640a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1174a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No member of the armed forces may be separated under a program established pursuant to this section after the date of the termination of that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8a9640b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s661/a/1"},"text":"Pub. L. 102–190, div. A, title VI, § 661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1394"},"text":"105 Stat. 1394","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1052/15"},"text":"Pub. L. 102–484, div. A, title X, § 1052(15)","children":[],"tail":", div. D, title XLIV, §§ 4405(a), 4422(a), "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2499"},"text":"106 Stat. 2499","children":[],"tail":", 2706, 2718; "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s202/a/17"},"text":"Pub. L. 103–35, title II, § 202(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/102"},"text":"107 Stat. 102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tV"},"text":"Pub. L. 103–160, div. A, title V","children":[],"tail":", §§ 502, 561(g), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1644"},"text":"107 Stat. 1644","children":[],"tail":", 1668; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s542/b"},"text":"Pub. L. 103–337, div. A, title V, § 542(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2768"},"text":"108 Stat. 2768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s561/b"},"text":"Pub. L. 105–261, div. A, title V, § 561(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2025"},"text":"112 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 571(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–134; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tVI/s631/f/4/A"},"text":"Pub. L. 112–81, div. A, title VI, § 631(f)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1465"},"text":"125 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a/9"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1948"},"text":"126 Stat. 1948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/c/2"},"text":"Pub. L. 117–263, div. A, title VI, § 626(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2628"},"text":"136 Stat. 2628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8a9640c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8a9640d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8a9640e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 503(c) of th