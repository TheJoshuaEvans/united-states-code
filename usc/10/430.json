{"tag":"section","attrib":{"id":"ida7bae54b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430"},"text":null,"children":[{"tag":"num","attrib":{"value":"430"},"text":"§ 430.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tactical Exploitation of National Capabilities Executive Agent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bae54c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Intelligence and Security shall designate a civilian employee of the Department or a member of the armed forces to serve as the Tactical Exploitation of National Capabilities Executive Agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae54d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Agent designated under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae54e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Under Secretary of Defense for Intelligence and Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae54f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" work with the combatant commands, military departments, and the intelligence community (as defined in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":") to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bae550-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop methods to increase warfighter effectiveness through the exploitation of national capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae551-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s430/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote cross-domain integration of such capabilities into military operations, training, intelligence, surveillance, and reconnaissance activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bae552-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXVI/s1621/a"},"text":"Pub. L. 113–291, div. A, title XVI, § 1621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3631"},"text":"128 Stat. 3631","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVI/s1621/e/1/A/viii"},"text":"Pub. L. 116–92, div. A, title XVI, § 1621(e)(1)(A)(viii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1733"},"text":"133 Stat. 1733","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1081/a/17"},"text":"Pub. L. 116–283, div. A, title X, § 1081(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3871"},"text":"134 Stat. 3871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bae553-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bae554-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bae555-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “and Security” after “for Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Under Secretary of Defense for Intelligence and Security” for “Under Secretary of Defense for Intelligence”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
