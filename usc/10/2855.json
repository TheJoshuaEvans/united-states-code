{"tag":"section","attrib":{"id":"ida9e67781-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2855"},"text":null,"children":[{"tag":"num","attrib":{"value":"2855"},"text":"§ 2855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law applicable to contracts for architectural and engineering services and construction design","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e67782-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2855/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts for architectural and engineering services and construction design in connection with a military construction project or a military family housing project shall be awarded in accordance with chapter 11 of title 40.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67783-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2855/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67784-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2855/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a contract referred to in subsection (a), if the Secretary concerned estimates that the initial award of the contract will be in an amount less than the threshold amount determined under paragraph (2), the contract shall be awarded in accordance with the set aside provisions of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"15 U.S.C. 631","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67785-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2855/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The threshold amount under paragraph (1) is $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67786-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2855/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not restrict the award of contracts to small business concerns under section 8(a) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/a"},"text":"15 U.S.C. 637(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e67787-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s2/a"},"text":"Pub. L. 97–214, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/166"},"text":"96 Stat. 166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/407/tVIII/s808/a"},"text":"Pub. L. 98–407, title VIII, § 808(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1521"},"text":"98 Stat. 1521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/22"},"text":"Pub. L. 107–217, § 3(b)(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1297"},"text":"116 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXIV/s1427/a"},"text":"Pub. L. 108–136, div. A, title XIV, § 1427(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1670"},"text":"117 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dB/tXXVIII/s2804/a"},"text":"Pub. L. 115–232, div. B, title XXVIII, § 2804(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2261"},"text":"132 Stat. 2261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e67788-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e67789-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9e6778a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Act, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2"},"text":"Pub. L. 85–536, § 2","children":[],"tail":"(1 et seq.), "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/384"},"text":"72 Stat. 384","children":[],"tail":", which is classified generally to chapter 14A (§ 631 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e6778b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s2804/a"},"text":"Pub. L. 115–232, § 2804(a)","children":[],"tail":", substituted “subsection (a),” for “subsection (a)—”, struck out subpar. (B) designation before “if the Secretary”, and struck out subpar. (A) which read as follows: “if the Secretary concerned estimates that the initial award of the contract will be in an amount greater than or equal to the threshold amount determined under paragraph (2), the contract may not be set aside exclusively for award to small business concerns; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s2804/b"},"text":"Pub. L. 115–232, § 2804(b)","children":[],"tail":", substituted “threshold” for “initial threshold” and “$1,000,000” for “$300,000” and struck out last sentence which read as follows: “The Secretary of Defense may revise that amount in order to ensure that small business concerns receive a reasonable share of contracts referred to in subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “$300,000” for “$85,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “chapter 11 of title 40” for “title IX of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s541"},"text":"40 U.S.C. 541","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407"},"text":"Pub. L. 98–407","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9e6778c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9e6778d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dB/tXXVIII/s2804/c"},"text":"Pub. L. 115–232, div. B, title XXVIII, § 2804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2262"},"text":"132 Stat. 2262","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dB/tXXVIII/s2804/c"},"text":"“The amendments made by this section [amending this section] shall apply with respect to fiscal year 2019 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9e6778e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407/tVIII/s808/b"},"text":"Pub. L. 98–407, title VIII, § 808(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1522"},"text":"98 Stat. 1522","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/407/tVIII/s808/b"},"text":"“Subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2855"},"text":"section 2855 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to contracts awarded after "},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":", except that the authority of the Secretary of Defense under paragraph (2) of that subsection shall apply only with respect to contracts awarded after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9e6778f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
