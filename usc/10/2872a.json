{"tag":"section","attrib":{"id":"ida9eb3229-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2872a"},"text":"§ 2872a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilities and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eb322a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Furnish","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may furnish utilities and services referred to in subsection (b) in connection with any military housing acquired or constructed pursuant to the exercise of any authority or combination of authorities under this subchapter if the military housing is located on a military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eb322b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Utilities and Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The utilities and services that may be furnished under subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eb322c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electric power.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb322d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Steam.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb322e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compressed air.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb322f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3230-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sewage and garbage disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3231-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Natural gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3232-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pest control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3233-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Snow and ice removal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3234-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanical refrigeration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3235-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Telecommunications service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3236-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Firefighting and fire protection services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3237-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Police protection services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3238-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Street sweeping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb3239-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tree trimming and removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eb323a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eb323b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall be reimbursed for any utilities or services furnished under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb323c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of any cash payment received under paragraph (1) as reimbursement for the cost of furnishing utilities or services shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9eb323d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a cost paid using funds appropriated or otherwise made available before ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":", be credited to the appropriation or working capital account from which the cost of furnishing utilities or services concerned was paid; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9eb323e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a cost paid using funds appropriated or otherwise made available on or after ","children":[{"tag":"date","attrib":{"date":"2014-10-01"},"text":"October 1, 2014","children":[],"tail":", be credited to the appropriation or working capital account currently available for the purpose of furnishing utilities or services under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eb323f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2872a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts credited under paragraph (2) to an appropriation or account shall be merged with funds in such appropriation or account, and shall be available to the same extent, and subject to the same terms and conditions, as such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eb3240-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dB/tXXVIII/s2805/a"},"text":"Pub. L. 106–398, § 1 [div. B, title XXVIII, § 2805(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–414; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dB/tXXVIII/s2802/a"},"text":"Pub. L. 107–314, div. B, title XXVIII, § 2802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2703"},"text":"116 Stat. 2703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dB/tXXVIII/s2804"},"text":"Pub. L. 113–66, div. B, title XXVIII, § 2804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1007"},"text":"127 Stat. 1007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3032"},"text":"Pub. L. 116–92, div. B, title XXX, § 3032","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1936"},"text":"133 Stat. 1936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eb3241-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eb3242-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eb3243-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added pars. (13) and (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “under paragraph (1) as reimbursement for the cost of furnishing utilities or services shall—” for “under paragraph (1) shall be credited to the appropriation or working capital account from which the cost of furnishing the utilities or services concerned was paid.”, added subpars. (A) and (B), designated second sentence of par. (2) as par. (3), and substituted “Amounts credited under paragraph (2)” for “Amounts so credited”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(11), (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" added pars. (11) and (12)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
