{"tag":"section","attrib":{"id":"ida810a666-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s806a"},"text":null,"children":[{"tag":"num","attrib":{"value":"806a"},"text":"§ 806a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 6a. Investigation and disposition of matters pertaining to the fitness of military judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida810a667-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s806a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall prescribe procedures for the investigation and disposition of charges, allegations, or information pertaining to the fitness of a military appellate judge, military judge, or military magistrate to perform the duties of the position involved. To the extent practicable, the procedures shall be uniform for all armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida810a668-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s806a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall transmit a copy of the procedures prescribed pursuant to this section to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida810a669-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXIII/s1303"},"text":"Pub. L. 101–189, div. A, title XIII, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1576"},"text":"103 Stat. 1576","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1502/a/1"},"text":"Pub. L. 104–106, div. A, title XV, § 1502(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/502"},"text":"110 Stat. 502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLI/s5104"},"text":"Pub. L. 114–328, div. E, title LI, § 5104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2895"},"text":"130 Stat. 2895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida810a66a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida810a66b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida810a66c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “military appellate judge, military judge, or military magistrate to perform the duties of the position involved.” for “military judge or military appellate judge to perform the duties of the judge’s position.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “and the Committee on Armed Services” for “and the Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “Committee on Armed Services of the Senate and the Committee on National Security of the House of Representatives” for “Committees on Armed Services of the Senate and House of Representatives”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida810a66d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida810a66e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
