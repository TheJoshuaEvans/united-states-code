{"tag":"section","attrib":{"id":"ida8000414-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of leave; regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8000415-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary concerned, or his designated representative, leave may be taken by a member on a calendar-day basis as vacation or absence from duty with pay, annually as accruing, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8000416-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations prescribed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8000417-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide equal treatment of officers and enlisted members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000418-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish to the fullest extent practicable uniform policies for the several armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000419-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that leave shall be taken annually as accruing to the extent consistent with military requirements and other exigencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida800041a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the determination of the number of calendar days of leave to which a member is entitled, including the number of calendar days of absence from duty or vacation to be counted or charged against leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida800041b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facilitating Granting of Leave for Attendance at Hearings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida800041c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall prescribe regulations to facilitate the granting of leave to a member of the armed forces under the jurisdiction of that Secretary in a case in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida800041d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave is needed for the member to attend a hearing described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida800041e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member is not serving in or with a unit deployed in a contingency operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida800041f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exigencies of military service (as determined by the Secretary concerned) do not otherwise require that such leave not be granted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000420-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered hearings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) applies to a hearing that is conducted by a court or pursuant to an administrative process established under State law, in connection with a civil action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8000421-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether a member of the armed forces is a natural parent of a child; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8000422-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine an obligation of a member of the armed forces to provide child support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8000423-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8000424-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “court” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1408/a"},"text":"section 1408(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8000425-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s704/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child support” has the meaning given that term in section 459(i) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s659/i"},"text":"42 U.S.C. 659(i)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8000426-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/649/s3/1"},"text":"Pub. L. 87–649, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/493"},"text":"76 Stat. 493","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/k"},"text":"Pub. L. 108–375, div. A, title X, § 1084(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2064"},"text":"118 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8000427-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8000428-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8000429-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"704(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"704(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:31a(a) (5th sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:31a(a) (6th sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:33(e).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:32(f) (last 8 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-09/ch391"},"text":"Aug. 9, 1946, ch. 391","children":[],"tail":", §§ 3(a) (5th and 6th sentences), 4(e), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/963"},"text":"60 Stat. 963","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1947-08-04/ch475/s1"},"text":"Aug. 4, 1947, ch. 475, § 1","children":[],"tail":" (5th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/749"},"text":"61 Stat. 749","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-09/ch931/s2/f"},"text":"Aug. 9, 1946, ch. 931, § 2(f)","children":[],"tail":" (last 8 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/963"},"text":"60 Stat. 963","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the 1st 18 words of the 5th sentence of section 31a(a) of existing title 37 are omitted as executed. The words “, or his designated representative,” are substituted for the last 8 words of section 32(f) of existing title 37.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), 37:33(e) (less 1st sentence) is omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida800042a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida800042b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s363/b"},"text":"section 363(b) of Pub. L. 104–193","children":[],"tail":", which was set out as a note under this section and was transferred to the end of this section and redesignated as subsec. (c), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s363/b"},"text":"Pub. L. 104–193, title III, § 363(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2248"},"text":"110 Stat. 2248","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/e/1/B"},"text":"Pub. L. 107–296, title XVII, § 1704(e)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2315"},"text":"116 Stat. 2315","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida800042c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/1"},"text":"Pub. L. 108–375, § 1084(k)(1)","children":[],"tail":"–(3), transferred "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/s363/b"},"text":"section 363(b) of Pub. L. 104–193","children":[],"tail":" to the end of this section and redesignated it as subsec. (c). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/4/A"},"text":"Pub. L. 108–375, § 1084(k)(4)(A)","children":[],"tail":", (B)(i), in introductory provisions, substituted “Secretary concerned” for “Secretary of each military department, and the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy,” and “armed forces” for “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/4/B/ii"},"text":"Pub. L. 108–375, § 1084(k)(4)(B)(ii)","children":[],"tail":", struck out “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":", United States Code)” after “contingency operation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/4/A"},"text":"Pub. L. 108–375, § 1084(k)(4)(A)","children":[],"tail":", substituted “armed forces” for “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/4/C/i"},"text":"Pub. L. 108–375, § 1084(k)(4)(C)(i)","children":[],"tail":", substituted “In this subsection:” for “For purposes of this subsection—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/4/C/ii"},"text":"Pub. L. 108–375, § 1084(k)(4)(C)(ii)","children":[],"tail":", substituted “this title” for “title 10, United States Code”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1084/k/4/C/iii"},"text":"Pub. L. 108–375, § 1084(k)(4)(C)(iii)","children":[],"tail":", substituted “that term” for “such term”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida800042d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida800042e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1962-11-01"},"text":"Nov. 1, 1962","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s15"},"text":"section 15 of Pub. L. 87–649","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida800042f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Facilitating Granting of Leave for Attendance at Hearings Involving Parental Support Obligations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s363/b"},"text":"Pub. L. 104–193, title III, § 363(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2248"},"text":"110 Stat. 2248","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/e/1/B"},"text":"Pub. L. 107–296, title XVII, § 1704(e)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2315"},"text":"116 Stat. 2315","children":[],"tail":", formerly set out as a note under this section, was transferred to subsec. (c) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
