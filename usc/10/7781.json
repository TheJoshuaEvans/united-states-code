{"tag":"section","attrib":{"id":"idaaffd6bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781"},"text":null,"children":[{"tag":"num","attrib":{"value":"7781"},"text":"§ 7781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber Center for Education and Innovation-Home of the National Cryptologic Museum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaffd6bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish at a publicly accessible location at Fort George G. Meade the “Cyber Center for Education and Innovation-Home of the National Cryptologic Museum” (in this section referred to as the “Center”). The Center may be used for the identification, curation, storage, and public viewing of materials relating to the activities of the National Security Agency, its predecessor or successor organizations, and the history of cryptology. The Center may contain meeting, conference, and classroom facilities that will be used to support such education, training, public outreach, and other purposes as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd6be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design, Construction, and Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into an agreement with the National Cryptologic Museum Foundation (in this section referred to as the “Foundation”), a nonprofit organization, for the design, construction, and operation of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd6bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaffd6c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Foundation constructs the Center pursuant to an agreement with the Foundation under subsection (b), upon satisfactory completion of the Center’s construction or any phase thereof, as determined by the Secretary, and upon full satisfaction by the Foundation of any other obligations pursuant to such agreement, the Secretary may accept the Center (or any phase thereof) from the Foundation, and all right, title, and interest in the Center or such phase shall vest in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary may accept services from the Foundation in connection with the design, construction, and operation of the Center. For purposes of this section and any other provision of law, employees or personnel of the Foundation shall not be considered to be employees of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd6c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees and User Charges.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaffd6c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to assess fees and user charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may assess fees and user charges sufficient to cover the cost of the use of Center facilities and property, including rental, user, conference, and concession fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received by the Secretary under paragraph (1) shall be deposited into the Fund established under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd6c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaffd6c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the Secretary’s acceptance of the Center under subsection (c)(1), there is established in the Treasury a fund to be known as the Cyber Center for Education and Innovation-Home of the National Cryptologic Museum Fund (in this section referred to as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Fund shall consist of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaaffd6c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees and user charges deposited by the Secretary under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaaffd6c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other amounts received by the Secretary which are attributable to the operation of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in the Fund shall be available to the Secretary for the benefit and operation of the Center, including the costs of operation and the acquisition of books, manuscripts, works of art, historical artifacts, drawings, plans, models, and condemned or obsolete combat materiel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaffd6cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7781/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing availability of amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in the Fund shall be available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaffd6cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dB/tXXVIII/s2831/a"},"text":"Pub. L. 114–328, div. B, title XXVIII, § 2831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2738"},"text":"130 Stat. 2738","children":[],"tail":", § 4781; renumbered § 7781, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaffd6cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaffd6ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaffd6cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4781"},"text":"section 4781 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaffd6d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaffd6d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
