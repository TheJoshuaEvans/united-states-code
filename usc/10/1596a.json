{"tag":"section","attrib":{"id":"ida8fa69bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1596a"},"text":"§ 1596a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign language proficiency: special pay for proficiency beneficial for other national security interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa69bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may pay special pay under this section to an employee of the Department of Defense who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa69be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been certified by the Secretary to be proficient in a foreign language identified by the Secretary as being a language in which proficiency by civilian personnel of the Department is necessary because of national security interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned duties requiring proficiency in that foreign language; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa69c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not receiving special pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1596"},"text":"section 1596 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa69c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rate of special pay for an employee under this section shall be prescribed by the Secretary, but may not exceed five percent of the employee’s rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa69c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Pay and Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Special pay under this section is in addition to any other pay or allowances to which the employee is entitled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa69c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa69c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1131(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–317; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tXI/s1102/a"},"text":"Pub. L. 108–375, div. A, title XI, § 1102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2072"},"text":"118 Stat. 2072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fa69c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fa69c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fa69c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" struck out “during a contingency operation supported by the armed forces” after “foreign language”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8fa69c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8fa69c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tXI/s1102/b"},"text":"Pub. L. 108–375, div. A, title XI, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2072"},"text":"118 Stat. 2072","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dA/tXI/s1102/b"},"text":"“The amendment by this section [amending this section] shall take effect on the first day of the first month that begins after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
