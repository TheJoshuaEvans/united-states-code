{"tag":"section","attrib":{"id":"ida78666fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201"},"text":null,"children":[{"tag":"num","attrib":{"value":"201"},"text":"§ 201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain intelligence officials: consultation and concurrence regarding appointments; evaluation of performance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78666fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation Regarding Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before submitting a recommendation to the President regarding the appointment of an individual to the position of Director of the Defense Intelligence Agency, the Secretary of Defense shall consult with the Director of National Intelligence regarding the recommendation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78666ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence in Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7866700-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event of a vacancy in a position referred to in paragraph (2), before appointing an individual to fill the vacancy or recommending to the President an individual to be nominated to fill the vacancy, the Secretary of Defense shall obtain the concurrence of the Director of National Intelligence as provided in section 106(b) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3041/b"},"text":"50 U.S.C. 3041(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7866701-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to the following positions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7866702-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7866703-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7866704-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7866705-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7866706-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence shall provide annually to the Secretary of Defense, for the Secretary’s consideration, an evaluation of the performance of the individuals holding the positions referred to in paragraph (2) in fulfilling their respective responsibilities with regard to the National Intelligence Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7866707-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The positions referred to in paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7866708-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7866709-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Reconnaissance Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida786670a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s201/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Geospatial-Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida786670b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIX/s922/a/2"},"text":"Pub. L. 102–190, div. A, title IX, § 922(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1453"},"text":"105 Stat. 1453","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1103/a"},"text":"Pub. L. 104–201, div. A, title XI, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2676"},"text":"110 Stat. 2676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/4"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1569"},"text":"117 Stat. 1569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s931/a/4"},"text":"Pub. L. 110–181, div. A, title IX, § 931(a)(4)","children":[],"tail":", (5), (c)(2), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/285"},"text":"122 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 932(a)(3)–(5), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4576"},"text":"122 Stat. 4576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c/10"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2475"},"text":"123 Stat. 2475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/4"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3508"},"text":"128 Stat. 3508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida786670c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida786670d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida786670e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 201 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s202"},"text":"section 202 of this title","children":[],"tail":" and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida786670f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3041/b"},"text":"50 U.S.C. 3041(b)","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403–6/b"},"text":"50 U.S.C. 403–6(b)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsecs. (a), (b)(1), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/3"},"text":"Pub. L. 110–417, § 932(a)(3)","children":[],"tail":"–(5). See 2008 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s931/a/4"},"text":"Pub. L. 110–181, § 931(a)(4)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/3"},"text":"Pub. L. 110–417, § 932(a)(3)","children":[],"tail":", amended subsec. (a) identically, substituting “Director of National Intelligence” for “Director of Central Intelligence”. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/3"},"text":"Pub. L. 110–417, § 932(a)(3)","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/4"},"text":"Pub. L. 110–417, § 932(a)(4)","children":[],"tail":", which directed substitution of “Director of National Intelligence” for “Director of Central Intelligence”, could not be executed because of the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s931/c/2/A"},"text":"Pub. L. 110–181, § 931(c)(2)(A)","children":[],"tail":", and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s931/c/2/A"},"text":"Pub. L. 110–181, § 931(c)(2)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Before submitting a recommendation to the President regarding the appointment of an individual to a position referred to in paragraph (2), the Secretary of Defense shall seek the concurrence of the Director of Central Intelligence in the recommendation. If the Director does not concur in the recommendation, the Secretary may make the recommendation to the President without the Director’s concurrence, but shall include in the recommendation a statement that the Director does not concur in the recommendation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s931/c/2/B"},"text":"Pub. L. 110–181, § 931(c)(2)(B)","children":[],"tail":", substituted “National Intelligence Program” for “National Foreign Intelligence Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s931/a/5"},"text":"Pub. L. 110–181, § 931(a)(5)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/5"},"text":"Pub. L. 110–417, § 932(a)(5)","children":[],"tail":", amended par. (1) identically, substituting “Director of National Intelligence” for “Director of Central Intelligence”. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/5"},"text":"Pub. L. 110–417, § 932(a)(5)","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (b)(2)(C), (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “Certain intelligence officials: consultation and concurrence regarding appointments; evaluation of performance” for “Consultation regarding appointment of certain intelligence officials” in section catchline and amended text generally. Prior to amendment, text read as follows: “Before submitting a recommendation to the President regarding the appointment of an individual to the position of Director of the Defense Intelligence Agency or Director of the National Security Agency, the Secretary of Defense shall consult with the Director of Central Intelligence regarding the recommendation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7866710-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7866711-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":", provided that the amendment made by section 1073(c)(10) is effective as of "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7866712-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7866713-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Defense Intelligence Agency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIX/s921"},"text":"Pub. L. 102–190, div. A, title IX, § 921","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1452"},"text":"105 Stat. 1452","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/d/1"},"text":"Pub. L. 103–337, div. A, title X, § 1070(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2858"},"text":"108 Stat. 2858","children":[],"tail":", provided that, during the period beginning on "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", the Assistant Secretary of Defense referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s138/b/3"},"text":"section 138(b)(3) of this title","children":[],"tail":" could be assigned supervision of the Defense Intelligence Agency other than day-to-day operational control over the Agency, set forth the responsibilities of the Director of the Defense Intelligence Agency during the period beginning on "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", and directed the Secretary of the Army and the Director of the Defense Intelligence Agency to take all required actions in order to transfer the Armed Forces Medical Intelligence Center and the Missile and Space Intelligence Center from the Department of the Army to the control of the Defense Intelligence Agency not later than "},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"Jan. 1, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7866714-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Joint Intelligence Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIX/s923"},"text":"Pub. L. 102–190, div. A, title IX, § 923","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1453"},"text":"105 Stat. 1453","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tIX/s923"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Center","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall direct the consolidation of existing single-service current intelligence centers that are located within the District of Columbia or its vicinity into a joint intelligence center that is responsible for preparing current intelligence assessments (including indications and warning). The joint intelligence center shall be located within the District of Columbia or its vicinity. As appropriate for the support of military operations, the joint intelligence center shall provide for and manage the collection and analysis of intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The center shall be managed by the Defense Intelligence Agency in its capacity as the intelligence staff activity of the Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsiveness to Command Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the center is fully responsive to the intelligence needs of the Secretary, the Chairman of the Joint Chiefs of Staff, and the commanders of the combatant commands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
