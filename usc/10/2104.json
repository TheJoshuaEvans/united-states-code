{"tag":"section","attrib":{"id":"ida92549ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced training; eligibility for","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92549f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced training shall be provided to eligible members of the program and, if the institution concerned so requests, to eligible applicants for membership in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible for continuation, or initial enrollment, in the program for advanced training, a person must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92549f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be selected for advanced training under procedures prescribed by the Secretary of the military department concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enlist in an armed force under the jurisdiction of the Secretary of the military department concerned for the period prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract, with the consent of his parent or guardian if he is a minor, with the Secretary of the military department concerned, or his designated representative, to serve for the period required by the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree in writing that he will accept an appointment, if offered, as a commissioned officer in the Army, Navy, Air Force, Marine Corps, or Space Force, as the case may be, and that he will serve in the armed forces for the period prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida92549f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" complete successfully—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida92549f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first two years of a four-year Senior Reserve Officers’ Training Corps course; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida92549fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" field training or a practice cruise of a duration which is prescribed by the Secretary concerned as a preliminary requirement for admission to the advanced course; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida92549fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the discretion of the Secretary concerned, agree in writing to complete field training or a practice cruise, as prescribed by the Secretary concerned, within two years after admission to the advanced course; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92549fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute a certificate of loyalty in such form as the Secretary of Defense prescribes or take a loyalty oath as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the program who is ineligible under subsection (b) for advanced training shall be released from the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92549fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to cadets and midshipmen appointed under section 2107, or foreign students enrolled under section 2103(b), of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92549ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/647/tII/s201/1"},"text":"Pub. L. 88–647, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-13"},"text":"Oct. 13, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1065"},"text":"78 Stat. 1065","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1003/a/2"},"text":"Pub. L. 98–94, title X, § 1003(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/656"},"text":"97 Stat. 656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s543/a"},"text":"Pub. L. 98–525, title V, § 543(a)","children":[],"tail":", title XIV, § 1401(h), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2530"},"text":"98 Stat. 2530","children":[],"tail":", 2619; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s544"},"text":"Pub. L. 104–106, div. A, title V, § 544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","c