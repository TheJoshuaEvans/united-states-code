{"tag":"section","attrib":{"id":"idab10787b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8113"},"text":null,"children":[{"tag":"num","attrib":{"value":"8113"},"text":"§ 8113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navy and Marine Corps: warrant officer grades","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The warrant officer grades in the Navy and the Marine Corps are:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab10787c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8113/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chief warrant officer, W–5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab10787d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8113/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chief warrant officer, W–4.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab10787e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8113/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chief warrant officer, W–3.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab10787f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8113/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chief warrant officer, W–2.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab107880-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8113/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warrant officer, W–