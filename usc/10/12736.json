{"tag":"section","attrib":{"id":"idabadf0a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12736"},"text":null,"children":[{"tag":"num","attrib":{"value":"12736"},"text":"§ 12736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service credited for retired pay benefits not excluded for other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No period of service included wholly or partly in determining a person’s right to, or the amount of, retired pay under this chapter may be excluded in determining his eligibility for any annuity, pension, or old-age benefit, under any other law, on account of civilian employment by the United States or otherwise, or in determining the amount payable under that law, if that service is otherwise properly credited under it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabadf0a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/104"},"text":"70A Stat. 104","children":[],"tail":", § 1336; renumbered § 12736 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/j/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2998"},"text":"108 Stat. 2998","children":[],"tail":", 3003.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabadf0a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idabadf0aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idabadf0ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"ht