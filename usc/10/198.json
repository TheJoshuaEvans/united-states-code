{"tag":"section","attrib":{"id":"ida783f6b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198"},"text":null,"children":[{"tag":"num","attrib":{"value":"198"},"text":"§ 198.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Local Defense Community Cooperation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida783f6ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Department of Defense an Office of Local Defense Community Cooperation (in this section referred to as the “Office”). The Secretary shall designate the Office as a Department of Defense Field Activity pursuant to section 191, effective as of the date of the enactment of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f6bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall be headed by the Director of the Office of Local Defense Community Cooperation, who shall be appointed by the Secretary of Defense from among civilian employees of the Federal Government or private individuals who have the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida783f6bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experience in the interagency in the Executive Branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f6bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experience in the administration and management of Federal grants programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f6be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida783f6bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve as the office in the Department of Defense with primary responsibility for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida783f6c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance to States, counties, municipalities, regions, and other communities to foster cooperation with military installations to enhance the military mission, achieve facility and infrastructure savings and reduced operating costs, address encroachment and compatible land use issues, support military families, and increase military, civilian, and industrial readiness and resiliency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida783f6c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing adjustment and diversification assistance to State and local governments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2391/b"},"text":"section 2391(b) of this title","children":[],"tail":" to achieve the objectives described in subparagraph (A);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f6c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the provision of such assistance with other organizations and elements of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f6c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support to the Economic Adjustment Committee established under Executive Order No. 12788 (57 Fed. Reg. 2213; ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2391"},"text":"10 U.S.C. 2391","children":[],"tail":" note) or any successor to such Committee; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida783f6c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other activities as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida783f6c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s198/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than June 1 each year, the Director of the Office of Local Defense Community Cooperation shall submit to the congressional defense committees a report on the activities of the Office during the preceding year, including the assistance provided pursuant to subsection (c)(1) during such year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida783f6c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s905/a/1"},"text":"Pub. L. 116–283, div. A, title IX, § 905(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3798"},"text":"134 Stat. 3798","children":[],"tail":", § 146; renumbered § 198 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIX/s902/a/1"},"text":"Pub. L. 117–81, div. A, title IX, § 902(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1868"},"text":"135 Stat. 1868","children":[],"tail":", 1869.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida783f6c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida783f6c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida783f6c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida783f6ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s902/a/1"},"text":"Pub. L. 117–81, § 902(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s146"},"text":"section 146 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s902/a/2"},"text":"Pub. L. 117–81, § 902(a)(2)","children":[],"tail":", substituted “in the Department of Defense an” for “in the Office of the Secretary of Defense an office to be known as the” and inserted at end “The Secretary shall designate the Office as a Department of Defense Field Activity pursuant to section 191, effective as of the date of the enactment of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 ("},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s902/a/3/A"},"text":"Pub. L. 117–81, § 902(a)(3)(A)","children":[],"tail":", substituted “Secretary of Defense” for “Under Secretary of Defense for Acquisition and Sustainment” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s902/a/3/B"},"text":"Pub. L. 117–81, § 902(a)(3)(B)","children":[],"tail":", substituted “Secretary” for “Under Secretary of Defense for Acquisition and Sustainment”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida783f6cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida783f6cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Involuntary Separation of Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIX/s902/b"},"text":"Pub. L. 117–81, div. A, title IX, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1869"},"text":"135 Stat. 1869","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tIX/s902/b"},"text":"“No personnel of the Office of Local Defense Community Cooperation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s198"},"text":"section 198 of title 10","children":[],"tail":", United States Code (as added by subsection (a)), may be involuntarily separated from service with that Office during the one-year period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"], except for cause.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida783f6cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration of Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tIX/s902/c"},"text":"Pub. L. 117–81, div. A, title IX, § 902(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1869"},"text":"135 Stat. 1869","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tIX/s902/c"},"text":"“Any program, project, or other activity administered by the Office of Economic Adjustment of the Department of Defense as of the date of the enactment of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Public Law 116–283","children":[],"tail":") ["},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"] shall be administered by the Office of Local Defense Community Cooperation under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s198"},"text":"section 198 of title 10","children":[],"tail":", United States Code (as added by subsection (a)).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
