{"tag":"section","attrib":{"id":"idab63ef2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085"},"text":null,"children":[{"tag":"num","attrib":{"value":"9085"},"text":"§ 9085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Chief of Space Operations: general duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63ef2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Professional Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of the Chief of Space Operations shall furnish professional assistance to the Secretary, the Under Secretary, and the Assistant Secretaries of the Air Force and to the Chief of Space Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the authority, direction, and control of the Secretary of the Air Force, the Office of the Chief of Space Operations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9014"},"text":"section 9014 of this title","children":[],"tail":", prepare for such employment of the Space Force, and for such recruiting, organizing, supplying, equipping (including research and development), training, servicing, mobilizing, demobilizing, administering, and maintaining of the Space Force, as will assist in the execution of any power, duty, or function of the Secretary of the Air Force or the Chief of Space Operations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate and report upon the efficiency of the Space Force and its preparation to support military operations by commanders of the combatant commands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare detailed instructions for the execution of approved plans and supervise the execution of those plans and instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as directed by the Secretary of the Air Force or the Chief of Space Operations, coordinate the action of organizations of the Space Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9085/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties, not otherwise assigned by law, as may be prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef32-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s921/a"},"text":"Pub. L. 116–283, div. A, title IX, § 921(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3805"},"text":"134 Stat. 3805","children":[],"tail":", § 9084; renumbered § 9085, "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s509C/a/1"},"text":"Pub. L. 118–159, div. A, title V, § 509C(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1873"},"text":"138 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab63ef33-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab63ef34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab63ef35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9085 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9086"},"text":"section 9086 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab63ef36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9084"},"text":"section 9084 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
