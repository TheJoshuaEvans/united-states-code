{"tag":"section","attrib":{"id":"ida887f85b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1088"},"text":null,"children":[{"tag":"num","attrib":{"value":"1088"},"text":"§ 1088.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air evacuation patients: furnished subsistence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, and under regulations to be prescribed by the Secretary concerned, a person entitled to medical and dental care under this chapter may be furnished subsistence without charge while being evacuated as a patient by military aircraft of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida887f85c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/481/s2/1"},"text":"Pub. L. 91–481, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1081"},"text":"84 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
