{"tag":"section","attrib":{"id":"ida9019566-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607"},"text":null,"children":[{"tag":"num","attrib":{"value":"1607"},"text":"§ 1607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence Senior Level positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9019567-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may designate as an Intelligence Senior Level position any defense intelligence position that, as determined by the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9019568-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is classifiable above grade GS–15 of the General Schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9019569-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not satisfy functional or program management criteria for being designated a Defense Intelligence Senior Executive Service position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida901956a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no more than minimal supervisory responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida901956b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall be carried out in accordance with regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida901956c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award of Rank to Employees in Intelligence Senior Level Positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, based on the recommendations of the Secretary of Defense, may award a rank referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4507a"},"text":"section 4507a of title 5","children":[],"tail":" to employees in Intelligence Senior Level positions designated under subsection (a). The award of such rank shall be made in a manner consistent with the provisions of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida901956d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1632/b"},"text":"Pub. L. 104–201, div. A, title XVI, § 1632(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2747"},"text":"110 Stat. 2747","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tV/s503"},"text":"Pub. L. 107–306, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2407"},"text":"116 Stat. 2407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida901956e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida901956f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9019570-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Grade GS–15 of the General Schedule, referred to in subsec. (a)(1), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9019571-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1607 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s424"},"text":"section 424 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in section 1604(f)(1), (3) of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1632/a/3"},"text":"Pub. L. 104–201, § 1632(a)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9019572-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306"},"text":"Pub. L. 107–306","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9019573-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9019574-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
