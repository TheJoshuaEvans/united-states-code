{"tag":"section","attrib":{"id":"idab1c868e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325"},"text":null,"children":[{"tag":"num","attrib":{"value":"8325"},"text":"§ 8325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers: retired grade and pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1c868f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b) or section 1370 ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, each officer who is retired under section 8321 or 8322 of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1c8690-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to a higher grade, shall be retired in the grade in which he was serving at the time of retirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1c8691-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to higher pay, is entitled to retired pay computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8333"},"text":"section 8333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c8692-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each officer who is retired while serving in the grade of admiral, vice admiral, general, or lieutenant general by virtue of an appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s601"},"text":"section 601 of this title","children":[],"tail":" or who is retired while serving in a grade to which he was appointed or promoted under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s603"},"text":"section 603 of this title","children":[],"tail":" or promoted under section 602 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (as in effect before "},{"tag":"date","attrib":{"date":"1992-02-01"},"text":"February 1, 1992","children":[],"tail":") or section 5721 "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1c8693-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to a higher grade, shall be retired in the grade he would hold if he had not received such an appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1c8694-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to higher pay, is entitled to retired pay computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8333"},"text":"section 8333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1c8695-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A warrant officer who retires under section 8321, 8322, or 8323 of this title may elect to be placed on the retired list in the highest grade and with the highest retired pay to which he is entitled under any provision of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1c8696-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/394"},"text":"70A Stat. 394","children":[],"tail":", § 6325; "},{"tag":"ref","attrib":{"href":"/us/pl/85/422/s11/a/6/B"},"text":"Pub. L. 85–422, § 11(a)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-05-20"},"text":"May 20, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/131"},"text":"72 Stat. 131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/143"},"text":"Pub. L. 85–861, § 1(143)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1509"},"text":"72 Stat. 1509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/132/s5/h/4"},"text":"Pub. L. 88–132, § 5(h)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-02"},"text":"Oct. 2, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/214"},"text":"77 Stat. 214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/377/s7"},"text":"Pub. L. 95–377, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-19"},"text":"Sept. 19, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/721"},"text":"92 Stat. 721","children":[],"tail":"; "},{"tag":"ref","att