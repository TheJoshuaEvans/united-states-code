visos), 520(b) (less proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/888"},"text":"61 Stat. 888","children":[],"tail":", 912."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-04-16/ch38/s108/b"},"text":"Apr. 16, 1947, ch. 38, § 108(b)","children":[],"tail":" (1st 5, and 8th through 76th, words; and proviso); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1950-05-16/ch186/s3/d/b"},"text":"May 16, 1950, ch. 186, § 3(d)(b)","children":[],"tail":" (1st 5, and 8th through 76th, words; and proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/161"},"text":"64 Stat. 161","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-12/ch449/s103/b"},"text":"June 12, 1948, ch. 449, § 103(b)","children":[],"tail":" (1st 6, and 9th through 54th, words), "},{"tag":"html:a","attrib":{"href":"/us/stat/62/357"},"text":"62 Stat. 357","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “who has served (1) as Chief of Staff to the President, (2) as Chief of Staff of the Army, (3) as a senior member of the Military Staff Committee of the United Nations, or (4) in a position of importance and responsibility designated by the President to carry the grade of general or lieutenant general under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3066"},"text":"section 3066 of this title","children":[],"tail":"” are substituted for the words “while serving in accordance with the provisions of subsection (b) or (c) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), or 10:156c (1st 6, and 9th through 43d, words) is omitted as covered by 10:1026 (less 24 words before proviso, and less proviso), since the Medical Service Corps is a branch of the Army. The references to the Commanding General of the General Headquarters Air Force are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), 10:166g(b) (proviso) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Upon retirement” are substituted for the words “When * * * is retired”. The word “allowances” is omitted, since retired officers are not entitled to allowances. The words “grade is below brigadier general” are inserted, since any permanent professor who has the grade of brigadier general retires in that grade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4335"},"text":"section 4335 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaae5978a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaae5978b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3962","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amendment reflects ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-31/ch348/s1"},"text":"section 1 of the Act of May 31, 1956, ch. 348","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/70/222"},"text":"70 Stat. 222","children":[],"tail":"), which in effect amended "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3963"},"text":"section 3963 of this title","children":[],"tail":" to cover regular officers covered by section 3962(c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae5978c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaae5978d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7342, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/454"},"text":"70A Stat. 454","children":[],"tail":", related to percentage of naval aircraft required to be constructed or manufactured in United States plants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s824/a/9"},"text":"Pub. L. 103–160, div. A, title VIII, § 824(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1708"},"text":"107 Stat. 1708","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaae5978e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3962"},"text":"section 3962 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" designated subsec. (b) as entire section and struck out subsec. (a) which read as follows: “Upon retirement, a commissioned officer of the Army who has served (1) as Chief of Staff to the President, (2) as Chief of Staff of the Army, (3) as a senior member of the Military Staff Committee of the United Nations, or (4) as Surgeon General of the Army in the grade of lieutenant general may, in the discretion of the President, be retired, by and with the advice and consent of the Senate, in the highest grade in which he served on active duty.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343/s13/a/3"},"text":"Pub. L. 96–343, § 13(a)(3)","children":[],"tail":", substituted “positions” for “positions: regular commissioned officers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s502/19/A"},"text":"Pub. L. 96–513, § 502(19)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/22"},"text":"Pub. L. 97–22","children":[],"tail":", struck out cl. (4) which had referred to service in a position of importance and responsibility designated by the President to carry out the grade of general or lieutenant general under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3066"},"text":"section 3066 of this title","children":[],"tail":", and redesignated cl. (5) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343/s13/a/1"},"text":"Pub. L. 96–343, § 13(a)(1)","children":[],"tail":", substituted “Army who has” for “Regular Army who has” and “in which he served on active duty” for “held by him at any time on the active list”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s502/19/B"},"text":"Pub. L. 96–513, § 502(19)(B)","children":[],"tail":", (C), redesignated subsec. (c) as (b). Former subsec. (b), which provided that, upon retirement, a commissioned officer of the Army who had served at least four years as chief or assistant chief of a branch was entitled to retire in the highest grade, prescribed for such an office, that he had held while so serving, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343/s13/a/2"},"text":"Pub. L. 96–343, § 13(a)(2)","children":[],"tail":", struck out “Regular” before “Army”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s502/19/C"},"text":"Pub. L. 96–513, § 502(19)(C)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/288"},"text":"Pub. L. 89–288","children":[],"tail":" added the Surgeon General of the Army to the list of commissioned officers who may, in the discretion of the President, be retired, by and with the advice and consent of the Senate, in the highest grade held by him at any time on the active list."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861"},"text":"Pub. L. 85–861","children":[],"tail":" redesignated former subsec. (d) as (c) and repealed former subsec. (c) which related to retirement of commissioned officers who served as Director or Deputy Director of the Women’s Army Corps, Chief of the Army Nurse Corps, or Chief or assistant chief of the Women’s Medical Specialist Corps."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaae5978f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae59790-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaae59791-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaae59792-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appointment by President of Retired Commissioned Officer of Reserve Component to Higher Retired Grade; Recalculation of Pay","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/343/s13/c"},"text":"Pub. L. 96–343, § 13(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1132"},"text":"94 Stat. 1132","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/343/s13/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may, by and with the advice and consent of the Senate, appoint any commissioned officer of a reserve component of the Armed Forces who retired after ","children":[{"tag":"date","attrib":{"date":"1967-12-31"},"text":"December 31, 1967","children":[],"tail":", to the retired grade in which such officer could have been retired had such officer retired on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The retired pay of any retired officer who is appointed to a higher retired grade under paragraph (1) shall be recalculated as if such officer had retired in the grade to which appointed, but any increase in such retired pay by virtue of such appointment or this subsection shall be effective only with respect to periods beginning on or after the date on which such appointment is made.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
