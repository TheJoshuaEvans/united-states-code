{"tag":"section","attrib":{"id":"idaae59785-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7342"},"text":null,"children":[{"tag":"num","attrib":{"value":"7342"},"text":"§ 7342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher grade for service in special positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon retirement, any permanent professor of the United States Military Academy whose grade is below brigadier general, and whose service as such a professor has been long and distinguished, may, in the discretion of the President, be retired in the grade of brigadier general.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaae59786-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/230"},"text":"70A Stat. 230","children":[],"tail":", § 3962; "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/99"},"text":"Pub. L. 85–861, § 1(99)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1489"},"text":"72 Stat. 1489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/288/s2"},"text":"Pub. L. 89–288, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1050"},"text":"79 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/343/s13/a/1"},"text":"Pub. L. 96–343, § 13(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1980-09-08"},"text":"Sept. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1131"},"text":"94 Stat. 1131","children":[],"tail":"; "},{"tag":"ref","at