{"tag":"section","attrib":{"id":"ida7970906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280"},"text":null,"children":[{"tag":"num","attrib":{"value":"280"},"text":"§ 280.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of cooperation with civilian law enforcement officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7970907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, in cooperation with the Attorney General, shall conduct an annual briefing of law enforcement personnel of each State (including law enforcement personnel of the political subdivisions of each State) regarding information, training, technical support, and equipment and facilities available to civilian law enforcement personnel from the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7970908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each briefing conducted under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7970909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An explanation of the procedures for civilian law enforcement officials—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida797090a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain information, equipment, training, expert advice, and other personnel support under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida797090b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain surplus military equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida797090c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the types of information, equipment and facilities, and training and advice available to civilian law enforcement officials from the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida797090d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current, comprehensive list of military equipment which is suitable for law enforcement officials from the Department of Defense or available as surplus property from the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida797090e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Attorney General and the Administrator of General Services shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida797090f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or designate an appropriate office or offices to maintain the list described in subsection (b)(3) and to furnish information to civilian law enforcement officials on the availability of surplus military equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7970910-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s280/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to civilian law enforcement personnel nationwide, tollfree telephone communication with such office or offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7970911-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXII/s1243/a"},"text":"Pub. L. 100–180, div. A, title XII, § 1243(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1163"},"text":"101 Stat. 1163","children":[],"tail":", § 380; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXI/s1104/a"},"text":"Pub. L. 100–456, div. A, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2046"},"text":"102 Stat. 2046","children":[],"tail":"; renumbered § 280, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/a/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2497"},"text":"130 Stat. 2497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida79