{"tag":"section","attrib":{"id":"ida9cea969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779"},"text":null,"children":[{"tag":"num","attrib":{"value":"2779"},"text":"§ 2779.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds because of fluctuations in currency exchange rates of foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cea96a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers Back to Foreign Currency Fluctuations Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea96b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds transferred from the appropriation “Foreign Currency Fluctuations, Defense” may be transferred back to the appropriation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9cea96c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the funds are not needed to pay obligations incurred because of fluctuations in currency exchange rates of foreign countries in the appropriation to which the funds were originally transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9cea96d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of subsequent favorable fluctuations in the rates or because other funds are, or become, available to pay the obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea96e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A transfer back to the Foreign Currency Fluctuations, Defense appropriation may not be made after the end of the second fiscal year after the fiscal year that the appropriation to which the funds were originally transferred is available for obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea96f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding for Losses in Military Construction and Family Housing","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea970-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One hundred million dollars, plus $25,000,000 from Family Housing, Defense, are appropriated to the Secretary of Defense, to remain available until spent. The appropriation is available only to provide funds to eliminate losses in military construction or expenses of family housing for the Department of Defense caused by fluctuations in currency exchange rates of foreign countries that changed after a budget request was submitted to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea971-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds provided under this subsection are merged with and are available for the same purpose and for the same time period as the appropriation to which they are applied. An authorization or limitation limiting the amount that may be obligated or spent is increased to the extent necessary to reflect fluctuations in exchange rates from those used in preparing the budget submission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea972-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An obligation payable in the currency of a foreign country may be recorded as an obligation based on exchange rates used in preparing a budget submission. A change reflecting fluctuations in the exchange rate may be recorded as a disbursement is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea973-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers to Military Personnel Accounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may transfer funds to military personnel appropriations for a fiscal year out of funds available to the Department of Defense for that fiscal year under the appropriation “Foreign Currency Fluctuations, Defense”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea974-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers to Foreign Currency Fluctuations Account","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9cea975-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may transfer to the appropriation “Foreign Currency Fluctuations, Defense” unobligated amounts of funds appropriated for operation and maintenance and unobligated amounts of funds appropriated for military personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea976-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any transfer from an appropriation under paragraph (1) shall be made not later than the end of the second fiscal year following the fiscal year for which the appropriation is provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9cea977-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any transfer made pursuant to the authority provided in this subsection shall be limited so that the amount in the appropriation “Foreign Currency Fluctuations, Defense” does not exceed $970,000,000 at the time the transfer is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea978-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2779/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions of Availability for Transferred Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts transferred under subsection (c) or (d) shall be merged with and be available for the same purposes and for the same period as the appropriations to which transferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cea979-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/b/8/B"},"text":"Pub. L. 97–258, § 2(b)(8)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1056"},"text":"96 Stat. 1056","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1301/15"},"text":"Pub. L. 101–510, div. A, title XIII, § 1301(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1668"},"text":"104 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIX/s911/a"},"text":"Pub. L. 104–106, div. A, title IX, § 911(a)","children":[],"tail":"–(c), (e), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/406"},"text":"110 Stat. 406","children":[],"tail":", 407.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cea97a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9cea97b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9cea97c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2779(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:628–2.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 25, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/38/s100"},"text":"Pub. L. 96–38, § 100","children":[],"tail":" (last par. under heading “General Provisions”), "},{"tag":"html:a","attrib":{"href":"/us/stat/93/100"},"text":"93 Stat. 100","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2779(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:628–3.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/130/s100"},"text":"Pub. L. 96–130, § 100","children":[],"tail":" (par. under heading “Foreign Currency Fluctuation, Construction, Defense”), "},{"tag":"html:a","attrib":{"href":"/us/stat/93/1019"},"text":"93 Stat. 1019","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “during the current fiscal year or on and after ","children":[{"tag":"date","attrib":{"date":"1979-07-25"},"text":"July 25, 1979","children":[],"tail":"” are omitted as executed. The words “from an appropriation to which they were transferred” are omitted as surplus. In clause (A), the words “of foreign countries” are added for consistency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “back to the Foreign Currency Fluctuations, Defense appropriation” are substituted for “authorized by this provision” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “the sum of”, “which shall be derived”, and “to appropriations and funds” are omitted as surplus. The word “only” is added for clarity. The words “for those appropriations or funds” are omitted as surplus. The words “available during fiscal year 1980, or thereafter” are omitted as executed. The words “Department of Defense” are substituted for “military departments and Defense agencies” because of 10:101(5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “or fund” are omitted as surplus. The words “now or on and after ","children":[{"tag":"date","attrib":{"date":"1979-11-30"},"text":"November 30, 1979","children":[],"tail":"” are omitted as executed. The words “contained within appropriations or other provisions of law”, “hereby”, and “applicable” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “contracts or other . . . entered into” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d0f36d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9d0f36e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsec. (d) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s101/c/tVII/s791"},"text":"Pub. L. 97–377, title I, § 101(c) [title VII, § 791]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1865"},"text":"96 Stat. 1865","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s114"},"text":"section 114 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/d/2"},"text":"Pub. L. 104–106, § 911(d)(2)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9d0f36f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/e/1"},"text":"Pub. L. 104–106, § 911(e)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/e/2"},"text":"Pub. L. 104–106, § 911(e)(2)","children":[],"tail":", substituted “second fiscal year” for “2d fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/e/3"},"text":"Pub. L. 104–106, § 911(e)(3)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/a"},"text":"Pub. L. 104–106, § 911(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/b"},"text":"Pub. L. 104–106, § 911(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s911/c"},"text":"Pub. L. 104–106, § 911(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out par. (4) which read as follows: “The Secretary each year shall report to Congress on funds made available under this subsection.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d0f370-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9d0f371-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIX/s911/f"},"text":"Pub. L. 104–106, div. A, title IX, § 911(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/407"},"text":"110 Stat. 407","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tIX/s911/f"},"text":"“Subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2779"},"text":"section 2779 of title 10","children":[],"tail":", United States Code, as added by subsections (a) and (b), and the repeals made by subsection (d) [repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s114"},"text":"section 114 of this title","children":[],"tail":"], shall apply only with respect to amounts appropriated for a fiscal year after fiscal year 1995.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
