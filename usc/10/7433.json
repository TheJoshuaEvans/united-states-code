{"tag":"section","attrib":{"id":"idaaecc32a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433"},"text":null,"children":[{"tag":"num","attrib":{"value":"7433"},"text":"§ 7433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Superintendent; faculty: appointment and detail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaecc32b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Superintendent and the Commandant of Cadets of the Academy shall be detailed to those positions by the President from any branch of the Army. Other officers on duty at the Academy, except the permanent professors, may be detailed from any branch of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc32c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The permanent professors of the Academy shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc32d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The director of admissions of the Academy shall be appointed by the President, by and with the advice and consent of the Senate, and shall perform such duties as the Superintendent of the Academy may prescribe with the approval of the Secretary of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc32e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any officer of the Regular Army in a grade above captain may be detailed to perform the duties of director of admissions without being appointed as director of admissions. Such a detail does not affect his position on the active-duty list.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaecc32f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7433/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No graduate of the Academy may be appointed or detailed to serve at the Academy as a professor or instructor, or as an assistant to a professor or instructor, within two years after his graduation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaecc330-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/238"},"text":"70A Stat. 238","children":[],"tail":", § 4333; "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/9"},"text":"Pub. L. 85–600, § 1(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/522"},"text":"72 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/551/s2"},"text":"Pub. L. 95–551, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-30"},"text":"Oct. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2069"},"text":"92 Stat. 2069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s502/24"},"text":"Pub. L. 96–513, title V, § 502(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2910"},"text":"94 Stat. 2910","children":[],"tail":"; renumbered § 7433, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaecc331-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaecc332-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaaecc333-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4333(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4333(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4333(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1062.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1063 (1st sentence, and 1st 26 words of last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1063 (last sentence, less 1st 26 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1064.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 1313.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"R.S. 1314 (words before semicolon).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1894-07-26/ch167"},"text":"July 26, 1894, ch. 167","children":[],"tail":" (words after semicolon in 7th clause), "},{"tag":"html:a","attrib":{"href":"/us/stat/28/151"},"text":"28 Stat. 151","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “detailed” is substituted for the word “selected”, in 10:1062, and for the word “appointed”, in 10:1063, since historically the offices of superintendent and commandant of cadets have been filled by detail. The words “assistant professors, acting assistant professors, and the adjutant”, in 10:1063, are omitted as covered by the word “officers”, in 10:1062. The words “except the permanent professors” are inserted to conform to 10:1062.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “by and with the advice and consent of the Senate” are inserted, since many of the statutes establishing particular permanent professorships from time to time have so provided, and historically it has been the uniform practice to make these appointments in this manner. 10:1063 (last 14 words) is omitted as obsolete and as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4349/b"},"text":"section 4349(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “appointed” is substituted for the word “assigned”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaecc334-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaecc335-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7433 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8733"},"text":"section 8733 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaecc336-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4333"},"text":"section 4333 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" struck out “regular or temporary” in first sentence, and substituted “active-duty list” for “applicable promotion list” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/551"},"text":"Pub. L. 95–551","children":[],"tail":" substituted “director of admissions” for “registrar” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/600"},"text":"Pub. L. 85–600","children":[],"tail":" added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaecc337-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaecc338-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib