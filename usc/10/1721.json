{"tag":"section","attrib":{"id":"ida9064fc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721"},"text":null,"children":[{"tag":"num","attrib":{"value":"1721"},"text":"§ 1721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of acquisition positions and acquisition workforce career fields","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9064fc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate in regulations those positions in the Department of Defense that are acquisition positions for purposes of this chapter. The Secretary shall also designate in regulations those career fields in the Department of Defense that are acquisition workforce career fields for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9064fca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating the positions under subsection (a), the Secretary shall include, at a minimum, all acquisition-related positions in the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9064fcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Systems planning, research, development, engineering, and testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procurement, including contracting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Industrial property management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Logistics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quality control and assurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Manufacturing and production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Business, cost estimating, financial management, and auditing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education, training, and career development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Security cooperation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Intellectual property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9064fd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other positions, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9064fd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Management Headquarters Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary also shall designate as acquisition positions under subsection (a) those acquisition-related positions which are in management headquarters activities and in management headquarters support activities. For purposes of this subsection, the terms “management headquarters activities” and “management headquarters support activities” have the meanings given those terms in Department of Defense Directive 5100.73, entitled “Department of Defense Management Headquarters and Headquarters Support Activities”, dated ","children":[{"tag":"date","attrib":{"date":"1996-11-12"},"text":"November 12, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9064fd9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1640"},"text":"104 Stat. 1640","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/25/tVII/s701/j/1"},"text":"Pub. L. 102–25, title VII, § 701(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/116"},"text":"105 Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIX/s912/f"},"text":"Pub. L. 105–85, div. A, title IX, § 912(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1862"},"text":"111 Stat. 1862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s802/b"},"text":"Pub. L. 115–91, div. A, title VIII, § 802(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1451"},"text":"131 Stat. 1451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVIII/s861/d"},"text":"Pub. L. 116–92, div. A, title VIII, § 861(d)","children":[],"tail":", (f)(1), (2)(A), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1517"},"text":"133 Stat. 1517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9064fda-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9064fdb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9064fdc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/f/2/A"},"text":"Pub. L. 116–92, § 861(f)(2)(A)","children":[],"tail":", substituted “Designation of acquisition positions and acquisition workforce career fields” for “Designation of acquisition positions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/f/1"},"text":"Pub. L. 116–92, § 861(f)(1)","children":[],"tail":", inserted at end “The Secretary shall also designate in regulations those career fields in the Department of Defense that are acquisition workforce career fields for purposes of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/d/1"},"text":"Pub. L. 116–92, § 861(d)(1)","children":[],"tail":", amended par. (11) generally. Prior to amendment, par. (11) read as follows: “Joint development and production with other government agencies and foreign countries.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s861/d/2"},"text":"Pub. L. 116–92, § 861(d)(2)","children":[],"tail":", added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1996-11-12"},"text":"November 12, 1996","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1988-11-25"},"text":"November 25, 1988","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":" substituted “Activities’, dated” for “Activities,’ dated” in last sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9064fdd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous",