{"tag":"section","attrib":{"id":"ida773545d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163"},"text":null,"children":[{"tag":"num","attrib":{"value":"163"},"text":"§ 163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Chairman of Joint Chiefs of Staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida773545e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communications Through Chairman of JCS; Assignment of Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s152/c"},"text":"section 152(c) of this title","children":[],"tail":", the President may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida773545f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct that communications between the President or the Secretary of Defense and the commanders of the unified and specified combatant commands be transmitted through the Chairman of the Joint Chiefs of Staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7735460-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign duties to the Chairman to assist the President and the Secretary of Defense in performing their command function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7735461-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight by Chairman of Joint Chiefs of Staff","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7735462-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may assign to the Chairman of the Joint Chiefs of Staff responsibility for overseeing the activities of the combatant commands. Such assignment by the Secretary to the Chairman does not confer any command authority on the Chairman and does not alter the responsibility of the commanders of the combatant commands prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s164/b/2"},"text":"section 164(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7735463-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the authority, direction, and control of the Secretary of Defense, the Chairman of the Joint Chiefs of Staff serves as the spokesman for the commanders of the combatant commands, especially on the operational requirements of their commands. In performing such function, the Chairman shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7735464-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confer with and obtain information from the commanders of the combatant commands with respect to the requirements of their commands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7735465-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and integrate such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7735466-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and make recommendations to the Secretary of Defense with respect to the requirements of the combatant commands, individually and collectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7735467-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s163/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate, as appropriate, the requirements of the combatant commands to other elements of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7735468-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tII/s211/a"},"text":"Pub. L. 99–433, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1013"},"text":"100 Stat. 1013","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
