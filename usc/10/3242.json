{"tag":"section","attrib":{"id":"idaa188379-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242"},"text":null,"children":[{"tag":"num","attrib":{"value":"3242"},"text":"§ 3242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplies: economic order quantities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa18837a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quantity to Procure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa18837b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":" shall procure supplies in such quantity as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa18837c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in the total cost and unit cost most advantageous to the United States, where practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa18837d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not exceed the quantity reasonably expected to be required by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa18837e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall take paragraph (1) into account in approving rates of obligation of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2204"},"text":"section 2204 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa18837f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opinion of Offeror With Respect to Quantity to Be Procured","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each solicitation for a contract for supplies shall, if practicable, include a provision inviting each offeror responding to the solicitation to state an opinion on whether the quantity of the supplies proposed to be procured is economically advantageous to the United States and, if applicable, to recommend a quantity or quantities which would be more economically advantageous to the United States. Each such recommendation shall include a quotation of the total price and the unit price for supplies procured in each recommended quantity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa188380-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1233/a"},"text":"Pub. L. 98–525, title XII, § 1233(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2600"},"text":"98 Stat. 2600","children":[],"tail":", § 2384a; renumbered § 3242 and amended "},{"tag":"ref","attrib":{"hr