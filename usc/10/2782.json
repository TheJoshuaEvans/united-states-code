{"tag":"section","attrib":{"id":"ida9d0f388-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2782"},"text":null,"children":[{"tag":"num","attrib":{"value":"2782"},"text":"§ 2782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Damage to real property: disposition of amounts recovered","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2775"},"text":"section 2775 of this title","children":[],"tail":", amounts recovered for damage caused to real property under the jurisdiction of the Secretary of a military department or, with respect to the Defense Agencies, under the jurisdiction of the Secretary of Defense shall be credited to the account available for the repair or replacement of the real property at the time of recovery. In such amounts as are provided in advance in appropriation Acts, amounts so credited shall be available for use for the same purposes and under the same circumstances as other funds in the account."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9d0f389-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2821/a"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/556"},"text":"110 Stat. 556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d0f38a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d0f38b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9d0f38c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2782, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1603/a/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1603(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1597"},"text":"103 Stat. 1597","children":[],"tail":", related to limits on restoration of unobligated balances withdrawn from availability for obligation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1405/c/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1405(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1680"},"text":"104 Stat. 1680","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
