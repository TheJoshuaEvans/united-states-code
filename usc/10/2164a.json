{"tag":"section","attrib":{"id":"ida933a1d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2164a"},"text":"§ 2164a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of parents of children attending schools operated by the Department of Defense Education Activity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida933a1d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The parent of a child who attends a school operated by the Department of Defense Education Activity has the following rights:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a1da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to review the curriculum of the school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to be informed if the school or the Department of Defense Education Activity alters the school’s academic standards or learning benchmarks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to meet with each teacher of their child not less than twice during each school year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to review all instructional materials used by their students.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to inspect a list of the books and other reading materials contained in the library of the school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to address the school advisory committee or the school board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to data about the school’s discipline policy and any disciplinary action that results in a suspension or expulsion from the school, unless such disclosure is prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The right to information about any plans to eliminate gifted and talented programs or accelerated coursework at the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a1e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosures and Notifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the parental rights specified in subsection (a) and except as provided by subsection (c), a school operated by the Department of Defense Education Activity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a1e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" post on a publicly accessible website of the school—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a1e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the curriculum for each course and grade level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a1e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the academic standards or other learning benchmarks used by the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a1e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of any proposed revisions to such standards or benchmarks and a copy of any such revisions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide the parent of a child attending the school with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a1e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity to meet in person with each teacher of their child not less frequently than twice during each school year at a time mutually agreed upon by both parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a1e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of such opportunity at the beginning of each school year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide parents access to the online school library catalog;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify parents in a timely manner of any plans to eliminate gifted and talented programs or accelerated coursework at the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided by paragraph (6) or subsection (c), notify parents of any medical examinations or screenings the school may administer to their child and receive written consent from parents for any such examination or screening prior to conducting the examination or screening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event of an emergency that requires a medical examination or screening without time for parental notification, promptly notify parents of such examination or screening and provide an explanation of the emergency that prevented notification prior to such examination or screening; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify parents of any medical information that will be collected on their child, receive written parental consent prior to collecting such information, and provide parents an opportunity to inspect such information at the parent’s request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a1ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a1f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (5) of subsection (a) and paragraph (3) of subsection (b) shall not be effective until the day that is two years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2024.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A requirement set forth in subsection (b) shall not apply in a case in which the requirement would violate any applicable provision of a Federal or State statute or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a1f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"School Advisory Committees and Boards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than four times per year, a school advisory committee or school board for a school operated by the Department of Defense Education Activity shall provide parents of children attending the school with the opportunity to address the advisory committee or school board on any matters relating to the school or the educational services provided to their children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida933a1f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida933a1f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “medical examination or screening”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a1f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a physical examination provided by a health care provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a1f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an evaluation by, or an encounter with, non-clinical school staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida933a1f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “school” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida933a1f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Department of Defense domestic dependent elementary or secondary school, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2164"},"text":"section 2164 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida933a1f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2164a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any elementary or secondary school or program for dependents operated by the Department of Defense Education Activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida933a1fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s589/a"},"text":"Pub. L. 118–31, div. A, title V, § 589(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/284"},"text":"137 Stat. 284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida933a1fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida933a1fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida933a1fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2024, referred to in subsec. (c)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida933a1fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida933a1ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Parental Right to Notice of Student Nonproficiency in Reading or Language Arts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s599B"},"text":"Pub. L. 118–159, div. A, title V, § 599B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1923"},"text":"138 Stat. 1923","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tV/s599B"},"text":"“The Secretary of Defense shall ensure that each elementary school operated by the Department of Defense Education Activity notifies the parents of any student enrolled in such school when the student does not score as grade-level proficient in reading or language arts at the end of the third grade based on the reading or language arts assessments administered under section 1111(b)(2)(B)(v)(I)(aa) of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6311/b/2/B/v/I/aa"},"text":"20 U.S.C. 6311(b)(2)(B)(v)(I)(aa)","children":[],"tail":") or another assessment administered to all third grade students by such school.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
