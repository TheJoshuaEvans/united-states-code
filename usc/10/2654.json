{"tag":"section","attrib":{"id":"ida997bb39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654"},"text":null,"children":[{"tag":"num","attrib":{"value":"2654"},"text":"§ 2654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft safety: requirements for certain highly trafficked domestic airspace","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida997bb3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 1046 of the National Defense Authorization Act for Fiscal Year 2019 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Public Law 115–232","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"49 U.S.C. 40101","children":[],"tail":" note), except as provided in subsection (b), the Secretary of a military department may not authorize any manned rotary wing aircraft of the Department of Defense to operate a training mission in a covered airspace unless such aircraft, while being operated, is actively providing warning of the proximity of such aircraft to nearby commercial aircraft in a manner compatible with the traffic alert and collision avoidance system of such commercial aircraft."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida997bb3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of a military department, with the concurrence of the Secretary of Transportation, may waive the limitation under subsection (a) with respect to the operation of an aircraft if that Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997bb3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida997bb3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such waiver is in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida997bb3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial aviation compatibility risk assessment has been conducted with respect to the operation of the aircraft pursuant to the waiver to mitigate the risk associated with such operation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99a2b3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a waiver to be in effect for a period exceeding 30 days, submits to appropriate congressional committees notice of such waiver, including a copy of the applicable commercial aviation compatibility risk assessment specified in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99a2b40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of a military department may not delegate the waiver authority under subsection (b) to an official whose rank is below a general or flag officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99a2b41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99a2b42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99a2b43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99a2b44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99a2b45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2654/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered airspace” means the Washington, DC Metropolitan Area Special Flight Rules Area, as such term is defined in section 93.335 of title 14, Code of Federal Regulations, or any successor regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida99a2b46-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s373/a"},"text":"Pub. L. 119–60, div. A, title III, § 373(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/837"},"text":"139 Stat. 837","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
