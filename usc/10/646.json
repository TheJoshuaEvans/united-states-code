{"tag":"section","attrib":{"id":"ida7f41d65-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s646"},"text":null,"children":[{"tag":"num","attrib":{"value":"646"},"text":"§ 646.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of performance as a member of the Joint Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense, in consultation with the Chairman of the Joint Chiefs of Staff, shall ensure that officer personnel policies of the Army, Navy, Air Force, Marine Corps, and Space Force concerning promotion, retention, and assignment give appropriate consideration to the performance of an officer as a member of the Joint Staff.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida7f41d66-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIII/s1301/d/1"},"text":"Pub. L. 98–525, title XIII, § 1301(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2612"},"text":"98 Stat. 2612","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/1/C"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f41d67-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f41d68-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f41d69-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, and Space Force” for “and Marine Corps”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
