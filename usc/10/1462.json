{"tag":"section","attrib":{"id":"ida8d443d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1462"},"text":null,"children":[{"tag":"num","attrib":{"value":"1462"},"text":"§ 1462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assets of Fund","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There shall be deposited into the Fund the following, which shall constitute the assets of the Fund:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d443d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1462/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts paid into the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1466"},"text":"section 1466 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d443d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1462/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d443d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1462/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any return on investment of the assets of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d443da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s925/a/1"},"text":"Pub. L. 98–94, title IX, § 925(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/645"},"text":"97 Stat. 645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d443db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8d443dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8d443dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s925/b/3"},"text":"Pub. L. 98–94, title IX, § 925(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/648"},"text":"97 Stat. 648","children":[],"tail":", required transfer into the Fund on "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", of any unobligated balances of appropriations made to the Department of Defense that had been currently available for retired pay, and provided that amounts so transferred would be deemed part of the assets of the Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
