{"tag":"section","attrib":{"id":"idaad0142d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6338"},"text":null,"children":[{"tag":"num","attrib":{"value":"6338"},"text":"§ 6338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University-based research collaboration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad0142e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6338/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad0142f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6338/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maintenance of scientific and engineering competence in the United States is vital to long-term national security and the defense and national security missions of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01430-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6338/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engaging the universities and colleges of the Nation in research on long-range problems of vital national security interest will be critical to solving the technology challenges faced within the defense and national security programs of the Department of Energy in the next century.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad01431-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6338/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhancing collaboration among the national laboratories, universities and colleges, and industry will contribute significantly to the performance of these Department of Energy missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01432-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6338/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall establish a university program at a location that can develop the most effective collaboration among national laboratories, universities and colleges, and industry in support of scientific and engineering advancement in key Department of Energy defense and national security program areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad01433-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1451"},"text":"139 Stat. 1451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad01434-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad01435-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad01436-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2795"},"text":"section 2795 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
