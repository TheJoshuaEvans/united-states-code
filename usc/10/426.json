{"tag":"section","attrib":{"id":"ida7bae4cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426"},"text":null,"children":[{"tag":"num","attrib":{"value":"426"},"text":"§ 426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of Department of Defense intelligence, surveillance, and reconnaissance capabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bae4d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"ISR Integration Council","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae4d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Under Secretary of Defense for Intelligence and Security shall establish an Intelligence, Surveillance, and Reconnaissance Integration Council—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bae4d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Secretary of Defense in carrying out the responsibilities of the Secretary under section 105(a) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3038/a"},"text":"50 U.S.C. 3038(a)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist the Under Secretary with respect to matters relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7bae4d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of intelligence and counterintelligence capabilities and activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s137/b"},"text":"section 137(b) of this title","children":[],"tail":" of the military departments, intelligence agencies of the Department of Defense, and relevant combatant commands; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of related developmental activities of such departments, agencies, and combatant commands; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise provide a means to facilitate such integration and coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bae4d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary, who shall chair the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the directors of the intelligence agencies of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the senior intelligence officers of the armed forces and the regional and functional combatant commands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director for Intelligence of the Joint Chiefs of Staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director for Operations of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary shall invite the participation of the Director of National Intelligence (or a representative of the Director) in the proceedings of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary may designate additional participants to attend the proceedings of the Council, as the Under Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bae4df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Briefings on the Intelligence and Counterintelligence Requirements of the Combatant Commands","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bae4e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chairman of the Joint Chiefs of Staff shall provide to the congressional defense committees and the congressional intelligence committees a briefing on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bae4e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The intelligence and counterintelligence requirements, by specific intelligence capability type, of each of the relevant combatant commands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the year preceding the year in which the briefing is provided, the fulfillment rate for each of the relevant combatant commands of the validated intelligence and counterintelligence requirements, by specific intelligence capability type, of such combatant command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A risk analysis identifying the critical gaps and shortfalls in efforts to address operational and strategic requirements of the Department of Defense that would result from the failure to fulfill the validated intelligence and counterintelligence requirements of the relevant combatant commands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A mitigation plan to balance and offset the gaps and shortfalls identified under subparagraph (C), including with respect to spaceborne, airborne, ground, maritime, and cyber intelligence, surveillance, and reconnaissance capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the year preceding the year in which the briefing is provided—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7bae4e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of intelligence and counterintelligence requests of each commander of a relevant combatant command determined by the Joint Chiefs of Staff to be a validated requirement, and the total of capacity of such requests provided to each such commander;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to such validated requirements—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida7bae4e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of intelligence and counterintelligence capabilities or activities, by specific intelligence capability type, that the Joint Chiefs of Staff requested each military department to provide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida7bae4e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total of capacity of such requests so provided by each such military department; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a qualitative assessment of the alignment of intelligence and counterintelligence capabilities and activities with the program of analysis for each combat support agency and intelligence center of a military service that is part of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida7bae4eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Intelligence Enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida7bae4ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/1/E/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Intelligence and Security shall provide to the congressional defense committees and the congressional intelligence committees a briefing on short-, mid-, and long-term strategies to address the validated intelligence and counterintelligence requirements of the relevant combatant commands, including with respect to spaceborne, airborne, ground, maritime, and cyber intelligence, surveillance, and reconnaissance capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The briefings required by paragraphs (1) and (2) shall be provided at the same time that the President’s budget is submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for each of fiscal years 2021 through 2025."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bae4ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bae4f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “congressional intelligence committees” has the meaning given that term in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Defense Intelligence Enterprise” means the organizations, infrastructure, and measures, including policies, processes, procedures, and products, of the intelligence, counterintelligence, and security components of each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida7bae4f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Joint Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The combatant commands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida7bae4f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other elements of the Department of Defense that perform national intelligence, defense intelligence, intelligence-related, counterintelligence, or security functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “fulfillment rate” means the percentage of combatant command intelligence and counterintelligence requirements satisfied by available, acquired, or realigned intelligence and counterintelligence capabilities or activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bae4f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s426/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “intelligence community” has the meaning given that term in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bae4f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s923/c/1"},"text":"Pub. L. 108–136, div. A, title IX, § 923(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1575"},"text":"117 Stat. 1575","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1071/a/3"},"text":"Pub. L. 109–364, div. A, title X, § 1071(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2398"},"text":"120 Stat. 2398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s931/a/7"},"text":"Pub. L. 110–181, div. A, title IX, § 931(a)(7)","children":[],"tail":", (8), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/285"},"text":"122 Stat. 285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s922/b"},"text":"Pub. L. 111–383, div. A, title IX, § 922(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4331"},"text":"124 Stat. 4331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1625/b"},"text":"Pub. L. 115–232, div. A, title XVI, § 1625(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2121"},"text":"132 Stat. 2121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVI"},"text":"Pub. L. 116–92, div. A, title XVI","children":[],"tail":", §§ 1621(e)(1)(A)(vii), 1622, "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1733"},"text":"133 Stat. 1733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bae4fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bae4fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7bae4fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section was based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXVI/s1626"},"text":"Pub. L. 113–291, div. A, title XVI, § 1626","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3635"},"text":"128 Stat. 3635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVI/s1624"},"text":"Pub. L. 115–91, div. A, title XVI, § 1624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1732"},"text":"131 Stat. 1732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1625/a"},"text":"Pub. L. 115–232, div. A, title XVI, § 1625(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2121"},"text":"132 Stat. 2121","children":[],"tail":", which was transferred to this chapter, redesignated as subsec. (c) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1625/b"},"text":"Pub. L. 115–232, § 1625(b)","children":[],"tail":", and subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bae4fd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1621/e/1/A/vii"},"text":"Pub. L. 116–92, § 1621(e)(1)(A)(vii)","children":[],"tail":", substituted “Under Secretary of Defense for Intelligence and Security” for “Under Secretary of Defense for Intelligence” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1622/a"},"text":"Pub. L. 116–92, § 1622(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) related to establishment and composition of an Intelligence, Surveillance, and Reconnaissance (ISR) Integration Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1622/b"},"text":"Pub. L. 116–92, § 1622(b)","children":[],"tail":", added subsec. (b) and struck out former subsecs. (b) and (c) which related to ISR Integration Roadmap and annual briefing on intelligence, surveillance, and reconnaissance requirements of the combatant commands, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" transferred "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1626"},"text":"section 1626 of Pub. L. 113–291","children":[],"tail":", as amended, to this section and redesignated it as subsec. (c). See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a)(3), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “Director of National Intelligence” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “coordination” for “coordiation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bae4fe-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7bae4ff-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Integration of Defense Intelligence, Surveillance, and Reconnaissance Capabilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s923/a"},"text":"Pub. L. 108–136, div. A, title IX, § 923(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1574"},"text":"117 Stat. 1574","children":[],"tail":", 1575, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tIX/s922/a"},"text":"Pub. L. 111–383, div. A, title IX, § 922(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4330"},"text":"124 Stat. 4330","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tIX/s922/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As part of transformation efforts within the Department of Defense, each of the Armed Forces is developing intelligence, surveillance, and reconnaissance capabilities that best support future war fighting as envisioned by the leadership of the military department concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Concurrently, intelligence agencies of the Department of Defense outside the military departments are developing transformation roadmaps to best support the future decisionmaking and war fighting needs of their principal customers, but are not always closely coordinating those efforts with the intelligence, surveillance, and reconnaissance development efforts of the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A senior official of each military department has been designated as the integrator of intelligence, surveillance, and reconnaissance for each of the Armed Forces in such military department, but there is not currently a well-defined forum through which the integrators of intelligence, surveillance, and reconnaissance capabilities for each of the Armed Forces can routinely interact with each other and with senior representatives of Department of Defense intelligence agencies, as well as with other members of the intelligence community, to ensure unity of effort and to preclude unnecessary duplication of effort.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current funding structure of a National Intelligence Program (NIP) and a Military Intelligence Program (MIP) may not be the best approach for supporting the development of an intelligence, surveillance, and reconnaissance structure that is integrated to meet the national security requirements of the United States in the 21st century.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position of Under Secretary of Defense for Intelligence [now Under Secretary of Defense for Intelligence and Security] was established in 2002 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Public Law 107–314","children":[],"tail":" [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s137"},"text":"10 U.S.C. 137","children":[],"tail":"] in order to facilitate resolution of the challenges to achieving an integrated intelligence, surveillance, and reconnaissance structure in the Department of Defense to meet such 21st century requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be a goal of the Department of Defense to fully integrate the intelligence, surveillance, and reconnaissance capabilities and coordinate the developmental activities of the military departments, intelligence agencies of the Department of Defense, and relevant combatant commands as those departments, agencies, and commands transform their intelligence, surveillance, and reconnaissance systems to meet current and future needs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
