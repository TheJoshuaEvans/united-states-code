{"tag":"section","attrib":{"id":"idabcceaae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20603"},"text":null,"children":[{"tag":"num","attrib":{"value":"20603"},"text":"§ 20603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlisted members: voluntary retirement for length of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabcceaaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Twenty to Thirty Years","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations to be prescribed by the Secretary of the Air Force, an enlisted member of the Space Force who has at least 20, but less than 30, years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20604"},"text":"section 20604 of this title","children":[],"tail":" may, upon the member’s request, be retired."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabcceab0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Thirty Years or More","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An enlisted member of the Space Force who has at least 30 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20604"},"text":"section 20604 of this title","children":[],"tail":" shall be retired upon the member’s request."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcceab1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1719A/a"},"text":"Pu