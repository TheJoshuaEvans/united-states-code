{"tag":"section","attrib":{"id":"ida959c7ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2252"},"text":null,"children":[{"tag":"num","attrib":{"value":"2252"},"text":"§ 2252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rewards: missing property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense and the Secretary of each military department may pay a reward of not more than $500 in any case for information leading to the discovery of missing property under the jurisdiction of that Secretary or leading to the recovery of such property.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida959c7ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/e/1"},"text":"Pub. L. 100–370, § 1(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/845"},"text":"102 Stat. 845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c7ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida959c7ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/b/tVIII/s8005/b"},"text":"Pub. L. 99–190, § 101(b) [title VIII, § 8005(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1185"},"text":"99 Stat. 1185","children":[],"tail":", 1202."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959