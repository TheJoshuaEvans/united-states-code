{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/41"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1902"},"text":"111 Stat. 1902","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa030060-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1804/a/1/A"},"text":"Pub. L. 119–60, § 1804(a)(1)(A)","children":[],"tail":", substituted “$275,000,000 (based on fiscal year 2024 constant dollars)” for “$115,000,000 (based on fiscal year 1990 constant dollars)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1804/a/1/B"},"text":"Pub. L. 119–60, § 1804(a)(1)(B)","children":[],"tail":", substituted “$1,300,000,000 (based on fiscal year 2024 constant dollars)” for “$540,000,000 (based on fiscal year 1990 constant dollars)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1804/a/2"},"text":"Pub. L. 119–60, § 1804(a)(2)","children":[],"tail":", substituted “$2,000,000 (based on fiscal year 2024 constant dollars)” for “$750,000 (based on fiscal year 1980 constant dollars)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1806/c/2/A"},"text":"Pub. L. 116–283, § 1806(c)(2)(A)","children":[],"tail":", redesignated par. (5) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"section 2302 of this title","children":[],"tail":" as subsec. (a) of this section, realigned margin, inserted heading, and substituted “In this part (other than in sections 4292(e) and 4321), the term” for “The term”. Former third sentence of subsec. (a) designated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1806/c/2/B"},"text":"Pub. L. 116–283, § 1806(c)(2)(B)","children":[],"tail":", (C), after transfer of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302/5"},"text":"section 2302(5) of this title","children":[],"tail":" to subsec. (a) of this section, designated third sentence of subsec. (a) as (b), inserted heading, and substituted “system if—” and pars. (1) and (2) for “system if (A) the conditions of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302d"},"text":"section 2302d of this title","children":[],"tail":" are satisfied, or (B) the system is designated a ‘major system’ by the head of the agency responsible for the system.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1806/c/3"},"text":"Pub. L. 116–283, § 1806(c)(3)","children":[],"tail":", redesignated subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302d"},"text":"section 2302d of this title","children":[],"tail":" as subsec. (c) of this section, substituted “subsection (b)” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302/5"},"text":"section 2302(5) of this title","children":[],"tail":"” in introductory provisions, designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1806/c/3"},"text":"Pub. L. 116–283, § 1806(c)(3)","children":[],"tail":", redesignated subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302d"},"text":"section 2302d of this title","children":[],"tail":" as subsec. (d) of this section and substituted “subsection (b)” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302/5"},"text":"section 2302(5) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa030061-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa030062-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
