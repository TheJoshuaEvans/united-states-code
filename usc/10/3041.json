{"tag":"section","attrib":{"id":"idaa03004f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041"},"text":null,"children":[{"tag":"num","attrib":{"value":"3041"},"text":"§ 3041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa030050-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this part (other than in sections 4292(e) and 4321), the term “major system” means a combination of elements that will function together to produce the capabilities required to fulfill a mission need. The elements may include hardware, equipment, software or any combination thereof, but excludes construction or other improvements to real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa030051-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System Considered to Be a Major System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A system shall be considered a major system if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa030052-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions of subsection (c) or (d), as applicable, are satisfied; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa030053-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the system is designated a “major system” by the head of the agency responsible for the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa030054-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of Defense Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa030055-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b), a system for which the Department of Defense is responsible shall be considered a major system if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa030056-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total expenditures for research, development, test, and evaluation for the system are estimated to be more than $275,000,000 (based on fiscal year 2024 constant dollars); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa030057-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eventual total expenditure for procurement for the system is estimated to be more than $1,300,000,000 (based on fiscal year 2024 constant dollars).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa030058-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustment authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Authority for the Secretary of Defense to adjust amounts and the base fiscal year in effect under this subsection is provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4202/b"},"text":"section 4202(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa030059-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civilian Agency Systems","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b), a system for which a civilian agency is responsible shall be considered a major system if total expenditures for the system are estimated to exceed the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa03005a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 (based on fiscal year 2024 constant dollars); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa03005b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3041/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dollar threshold for a “major system” established by the agency pursuant to Office of Management and Budget (OMB) Circular A–109, entitled “Major Systems Acquisitions”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa03005c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1806/c"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1806(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4154"},"text":"134 Stat. 4154","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1804/a"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1234"},"text":"139 Stat. 1234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa03005d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa03005e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa03005f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of par. (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2302"},"text":"section 2302 of this title","children":[],"tail":", which was transfer