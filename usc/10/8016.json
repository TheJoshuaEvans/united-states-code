{"tag":"section","attrib":{"id":"idab049121-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016"},"text":null,"children":[{"tag":"num","attrib":{"value":"8016"},"text":"§ 8016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretaries of the Navy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab049122-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are four Assistant Secretaries of the Navy. They shall be appointed from civilian life by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab049123-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab049124-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretaries shall perform such duties and exercise such powers as the Secretary of the Navy may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab049125-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Navy for Manpower and Reserve Affairs. He shall have as his principal duty the overall supervision of manpower and reserve component affairs of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab049126-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab049127-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Navy for Financial Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab049128-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall be appointed from among persons who have significant budget, financial management, or audit experience in complex organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab049129-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal responsibility of the Assistant Secretary shall be the exercise of the comptroller functions of the Department of the Navy, including financial management functions. The Assistant Secretary shall be responsible for all financial management activities and operations of the Department of the Navy and shall advise the Secretary of the Navy on financial management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab04912a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab04912b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary of the Navy for Research, Development, and Acquisition. The principal duty of the Assistant Secretary shall be the overall supervision of research, development, acquisition, and sustainment (including maintenance) matters of the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab04912c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary shall have a Principal Military Deputy, who shall be an officer of the Navy or the Marine Corps on active duty. The Principal Military Deputy shall be appointed from among officers who have significant experience in the areas of acquisition and program management. The position of Principal Military Deputy shall be designated as a critical acquisition position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1731"},"text":"section 1731 of this title","children":[],"tail":". In the event of a vacancy in the position of Assistant Secretary of the Navy for Research, Development, and Acquisition, the Principal Military Deputy may serve as Acting Assistant Secretary for a period of not more than one year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07022d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab07022e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One of the Assistant Secretaries shall be the Assistant Secretary for Energy, Installations, and Environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab07022f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8016/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal duty of the Assistant Secretary for Energy, Installations, and Environment shall be the overall supervision of energy, installation, and environment matters for the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab070230-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s511/c/4"},"text":"Pub. L. 99–433, title V, § 511(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1047"},"text":"100 Stat. 1047","children":[],"tail":", § 5016; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tVII/s702/b/s1"},"text":"Pub. L. 100–456, div. A, title VII, § 702(b)[(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1994"},"text":"102 Stat. 1994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s908/b"},"text":"Pub. L. 110–181, div. A, title IX, § 908(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/278"},"text":"122 Stat. 278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s502/t"},"text":"Pub. L. 114–328, div. A, title V, § 502(t)","children":[],"tail":", tit