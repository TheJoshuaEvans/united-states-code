rs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" designated first sentence as subpar. (A), designated second and third sentences as subpar. (C) and, in subpar. (C), substituted “The principal responsibility of the Assistant Secretary shall be” for “The Assistant Secretary shall have as his principal responsibility”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s802/b"},"text":"Pub. L. 114–328, § 802(b)","children":[],"tail":", inserted at end “In the event of a vacancy in the position of Assistant Secretary of the Navy for Research, Development, and Acquisition, the Principal Military Deputy may serve as Acting Assistant Secretary for a period of not more than one year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s502/t"},"text":"Pub. L. 114–328, § 502(t)","children":[],"tail":", substituted “an officer of the Navy or the Marine Corps” for “a vice admiral of the Navy or a lieutenant general of the Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab070235-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"t