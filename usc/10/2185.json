{"tag":"section","attrib":{"id":"ida936134d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2185"},"text":null,"children":[{"tag":"num","attrib":{"value":"2185"},"text":"§ 2185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs to be consistent with programs administered by the Department of Veterans Affairs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Regulations prescribed to carry out this chapter shall provide that the programs under this chapter shall be consistent with the educational assistance programs under chapters 35 and 36 of title 38.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida936134e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s806/d/1"},"text":"Pub. L. 99–399, title VIII, § 806(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/888"},"text":"100 Stat. 888","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1621/a/7/A"},"text":"Pub. L. 101–189, div. A, title XVI, § 1621(a)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1603"},"text":"103 Stat. 1603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida936134f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9361350-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9361351-3a6f-11f1-a58a-