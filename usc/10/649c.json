{"tag":"section","attrib":{"id":"ida7f68d8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c"},"text":null,"children":[{"tag":"num","attrib":{"value":"649c"},"text":"§ 649c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for consideration for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f68d8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by this section, eligibility for promotion of officers in any competitive category of officers designated for purposes of this subchapter shall be governed by the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s619"},"text":"section 619 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Time-in-grade Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraphs (2) through (4) ","children":[{"tag":"ref","attrib":{"idref":"fn002038"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002038"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s619/a"},"text":"section 619(a) of this title","children":[],"tail":" shall not apply to the promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Officers Above and Below Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s619/c"},"text":"section 619(c) of this title","children":[],"tail":" shall not apply to the promotion of officers described in subsection (a):"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f68d8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reference in paragraph (1) of that section to an officer above the promotion zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f68d90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (2)(A) of that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Requirement Relating to Opportunities for Consideration for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s645/1/A/i/I"},"text":"Section 645(1)(A)(i)(I) of this title","children":[],"tail":" shall not apply to the promotion of officers described in subsection (a) to the extent that such section is inconsistent with a number of opportunities for promotion specified pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s649d"},"text":"section 649d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f68d92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility of Certain Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following officers are not eligible for promotion under this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f68d93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s619/d"},"text":"section 619(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f68d94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer not included within the promotion zone.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f68d95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who has failed of promotion to a higher grade the maximum number of times specified for opportunities for promotion for such grade within the competitive category concerned pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s649d"},"text":"section 649d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f68d96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s649c/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer recommended by a selection board to be removed from consideration for promotion in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s649b/c"},"text":"section 649b(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f68d97-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s507/a/1"},"text":"Pub. L. 115–232, div. A, title V, § 507(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1745"},"text":"132 Stat. 1745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tV/s506"},"text":"Pub. L. 116–283, div. A, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3573"},"text":"134 Stat. 3573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f68d98-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f68d99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"ta