{"tag":"section","attrib":{"id":"ida84522f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989"},"text":null,"children":[{"tag":"num","attrib":{"value":"989"},"text":"§ 989.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on former members of the armed forces accepting post-service employment with certain foreign governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84522f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by subsection (b), a covered individual may not occupy a covered post-service position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84522fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84522fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall establish a process under which a covered individual may be granted a temporary waiver of the prohibition under subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84522fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual, or a Federal agency on behalf of, and with the consent of, the individual, submits to the Secretary a written application for a waiver in such form and manner as the Secretary determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84522fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the waiver is necessary to advance the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84522fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A waiver issued under paragraph (1) shall apply for a period not exceeding 5 years. The Secretary may renew such a waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84522ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may revoke a waiver issued under paragraph (1) to a covered individual with respect to a covered-post service position if the Secretary determines that the employment of the individual in the covered-post service position poses a threat to national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8452300-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8452301-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the Secretary issues a waiver under paragraph (1) or revokes a waiver under paragraph (3), the Secretary shall submit to the Committees on Armed Services of the Senate and the House of Representatives written notification of the waiver or revocation, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8452302-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification required by subparagraph (A) shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8452303-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a waiver issued to a covered individual—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida8452304-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the details of the application, including the position held by the individual in the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida8452305-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the post-service position of the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida8452306-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the national security interests that will be advanced by reason of issuing such a waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida8452307-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific reasons why the Secretary determines that issuing the waiver will advance such interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8452308-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a revocation of a waiver issued to a covered individual—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida8452309-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the details of the waiver, including any renewals of the waiver, and the dates of such waiver and renewals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida845230a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific reasons why the Secretary determined that the revocation is warranted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida845230b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing the prohibition under subsection (a), the Secretary shall establish a process under which each member of the armed forces is, before the member retires or is otherwise separated from the armed forces—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida845230c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informed in writing of the prohibition, and the penalties for violations of the prohibition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida845230d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to certify that the member understands the prohibition and those penalties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida845230e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a covered individual who knowingly and willfully fails to comply with the prohibition under subsection (a), the Secretary may, as applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida845230f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold any pay, allowances, or benefits that would otherwise be provided to the individual by the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8452310-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke any security clearance of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8452311-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8452312-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2024-03-31"},"text":"March 31, 2024","children":[],"tail":", and annually thereafter, the Secretary shall submit to the congressional defense committees a report on covered post-service employment occurring during the year covered by the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8452313-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8452314-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of former covered individuals who occupy a covered post-service position, broken down by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8452315-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the employer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8452316-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign government, including by the specific foreign individual, agency, or entity, for whom the covered post-service employment is being performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida8452317-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the services provided as part of the covered post-service employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8452318-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment by the Secretary of whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida8452319-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense maintains adequate systems and processes for ensuring that former members of the armed forces are submitting required reports relating to their employment by foreign governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida845231a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all covered individuals who occupy a covered post-service position are in compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida845231b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services provided by the covered individuals who occupy a covered post-service position pose a current or future threat to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida845231c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is any credible information or reporting that any covered individual who occupies a covered post-service position has engaged in activities that violate Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida845231d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report required by paragraph (1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida845231e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notifications of Determinations of Certain Threats.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida845231f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the annual reports under subsection (d), if the Secretary determines that the services provided by a covered individual who occupies a covered post-service position pose a threat described in clause (iii) of paragraph (2)(B) of that subsection, or include activities described in clause (iv) of such paragraph, the Secretary shall notify the congressional defense committees of that determination by not later than 30 days after making the determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8452320-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A notification required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8452321-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the covered individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8452322-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8452323-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The foreign government, including the specific foreign individual, agency, or entity, for whom the covered post-service employment is being performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8452324-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As applicable, a description of the risk to national security and the activities that may violate Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8452325-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to indemnify or shield covered individuals from prosecution under any relevant provision of title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8452326-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8452327-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered individual","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered individual” means an individual who has retired or otherwise separated from an active or reserve component of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8452328-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered post-service employment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered post-service employment” means direct or indirect employment by, representation of, or any provision of advice or services relating to national security, intelligence, the military, or internal security to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8452329-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the government of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida845232a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country of concern (as defined in section 1(m) of the State Department Basic Authorities Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a/m"},"text":"22 U.S.C. 2651a(m)","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida845232b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country the Secretary of Defense determines acts as a proxy or passthrough for services for a country of concern; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida845232c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any company, entity, or other person the activities of which are directly or indirectly supervised, directed, controlled, financed, or subsidized, in whole or in major part, by a government described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida845232d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s989/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered post-service position","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered post-service position” means a position of employment described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida845232e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s523/a"},"text":"Pub. L. 118–31, div. A, title V, § 523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/250"},"text":"137 Stat. 250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida845232f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8452330-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8452331-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Counterintelligence Briefings for Members of the Armed Forces","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXV/s6511"},"text":"Pub. L. 119–60, div. F, title LXV, § 6511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1629"},"text":"139 Stat. 1629","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dF/tLXV/s6511"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered individual","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered individual’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s989/h"},"text":"section 989(h) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government of concern; company of concern","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘government of concern’ and ‘company of concern’ mean, respectively, a government described in subparagraph (A) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s989/h/2"},"text":"section 989(h)(2) of title 10","children":[],"tail":", United States Code, and a company, entity, or other person described in subparagraph (B) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Defense for Intelligence and Security shall issue appropriate policy to require the military departments to conduct counterintelligence briefings for members of the Armed Forces as part of the process required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s989/c"},"text":"section 989(c) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing provided under subsection (b) shall provide members of the Armed Forces with—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awareness of methods commonly used by governments and companies of concern to solicit and learn from covered individuals sensitive military techniques, tactics, and procedures of the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended practices for covered individuals to avoid an activity that could subject such individuals to civil or criminal penalties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contact information for the counterintelligence authorities to whom covered individuals should report attempted recruitment or a related suspicious contact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of the prohibition and penalties under subsections (a) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s989"},"text":"section 989 of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Briefings at Certain Trainings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary may mandate the briefings required by subsection (b) during the trainings required by Department of Defense Directive 5240.06 (relating to counterintelligence awareness and reporting), or successor document.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
