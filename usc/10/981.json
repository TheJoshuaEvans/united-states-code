{"tag":"section","attrib":{"id":"ida8406854-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s981"},"text":null,"children":[{"tag":"num","attrib":{"value":"981"},"text":"§ 981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on number of enlisted aides","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8406855-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b), the total number of enlisted members that may be assigned or otherwise detailed to duty as enlisted aides on the personal staffs of officers of the Army, Navy, Air Force, Marine Corps, Space Force, and Coast Guard (when operating as a service of the Navy) during a fiscal year is the number equal to the sum of (1) four times the number of officers serving on active duty at the end of the preceding fiscal year in the grade of general or admiral, and (2) two times the number of officers serving on active duty at the end of the preceding fiscal year in the grade of lieutenant general or vice admiral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406856-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 300 enlisted members may be assigned to duty at any time as enlisted aides for officers of the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8406857-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than March 1 of each year, the Secretary of Defense shall submit to the Committees on Armed Services of the Senate and the House of Representatives a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8406858-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s981/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifying the number of enlisted aides authorized and allocated for general officers and flag officers of the Army, Navy, Air Force, Marine Corps, Space Force, and joint pool as of September 30 of the previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8406859-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s981/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justifying, on a billet-by-billet basis, the authorization and assignment of each enlisted aide to each general officer and flag officer position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida840685a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/c/1"},"text":"Pub. L. 98–525, title XIV, § 1401(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2615"},"text":"98 Stat. 2615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s504/a"},"text":"Pub. L. 113–291, div. A, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3355"},"text":"128 Stat. 3355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1741/b/4"},"text":"Pub. L. 118–31, div. A, title XVII, §