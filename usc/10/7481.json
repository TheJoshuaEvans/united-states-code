{"tag":"section","attrib":{"id":"idaaf3ef68-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7481"},"text":null,"children":[{"tag":"num","attrib":{"value":"7481"},"text":"§ 7481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment: purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army may maintain schools and camps for the military instruction and training of persons selected, upon their application, from warrant officers and enlisted members of the Army and civilians, to qualify them for appointment as reserve officers, or enlistment as reserve noncommissioned officers, for service in the Army Reserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaaf3ef69-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/249"},"text":"70A Stat. 249","children":[],"tail":", § 4411; renumbered § 7481, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf3ef6a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaf3ef6b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaaf3ef6c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":