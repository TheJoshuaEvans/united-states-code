{"tag":"section","attrib":{"id":"ida855eb93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1060c"},"text":"§ 1060c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of veterinary services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida855eb94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veterinary professional described in subsection (b) may provide veterinary services in any State, the District of Columbia, or a territory or possession of the United States, without regard to where such veterinary professional or the patient animal are located, if the provision of such services is within the scope of the authorized duties of such veterinary professional for the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855eb95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veterinary Professional Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A veterinary professional described in this subsection is an individual who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855eb96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida855eb97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the armed forces, a civilian employee of the Department of Defense, or otherwise credentialed and privileged at a Federal veterinary institution or location designated by the Secretary of Defense for purposes of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida855eb98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the National Guard performing training or duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s502/f"},"text":"section 502(f) of title 32","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855eb99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified as a veterinary professional by a certification recognized by the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855eb9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1060c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" currently licensed by a State, the District of Columbia, or a territory or possession of the United States to provide veterinary services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida855eb9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s735/a"},"text":"Pub. L. 116–92, div. A, title VII, § 735(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1462"},"text":"133 Stat. 1462","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVII/s733"},"text":"Pub. L. 118–159, div. A, title VII, § 733","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1956"},"text":"138 Stat. 1956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida855eb9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida855eb9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida855eb9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s733/1"},"text":"Pub. L. 118–159, § 733(1)","children":[],"tail":", struck out “in emergencies” after “veterinary services” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s733/2"},"text":"Pub. L. 118–159, § 733(2)","children":[],"tail":", struck out “for the purposes described in subsection (c)” after “veterinary services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s733/3"},"text":"Pub. L. 118–159, § 733(3)","children":[],"tail":", struck out subsec. (c) which described the purposes of veterinary services in response to certain emergencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
