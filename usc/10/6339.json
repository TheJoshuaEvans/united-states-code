{"tag":"section","attrib":{"id":"idaad01437-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339"},"text":null,"children":[{"tag":"num","attrib":{"value":"6339"},"text":"§ 6339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on establishing an enduring bioassurance program within the administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaad01438-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not establish, administer, manage, or facilitate a program within the Administration for the purposes of executing an enduring national security research and development effort to broaden the role of the Department of Energy in national biodefense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaad01439-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitation described in subsection (a) shall not be interpreted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaad0143a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit the establishment of a bioassurance program for the purpose of executing enduring national security research and development in any component of the Department of Energy other than the Administration or in any other Federal agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaad0143b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to impede the use of resources of the Administration, including resources provided by a national security laboratory or a nuclear weapons production facility site, to support the execution of a bioassurance program, if such support is provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaad0143c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a cost-reimbursable basis to an entity that is not a component of the Department of Energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaad0143d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6339/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner that does not interfere with mission of such laboratory or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaad0143e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1452"},"text":"139 Stat. 1452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaad0143f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaad01440-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaad01441-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2796"},"text":"section 2796 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
