{"tag":"section","attrib":{"id":"ida78b21c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d"},"text":null,"children":[{"tag":"num","attrib":{"value":"222d"},"text":"§ 222d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on industrial base constraints for munitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida78b21ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the submission of all reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s222c/a"},"text":"section 222c(a) of this title","children":[],"tail":", the Under Secretary of Defense for Acquisition and Sustainment, in coordination with the service acquisition executive of each military department, shall submit to the congressional defense committees a report detailing the industrial base constraints for each munition identified in the Out-Year Unconstrained Total Munitions Requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b21cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall include the following elements, broken down by munition:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida78b21cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programmed purchase quantities per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Average procurement unit cost per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contract type.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current minimum sustaining rate of production per month and year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current maximum rate of production per month and year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expected date to meet the Out-Year Unconstrained Total Munitions Requirement in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s222c"},"text":"section 222c of this title","children":[],"tail":" under the programmed purchase quantities established for the period covered by the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of industrial base constraints on increased production of each munition, including any supply chain weaknesses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of investments or policy changes made by a defense contractor or by the United States Government to increase production, enable more efficient production, or mitigate significant loss of stability in potential production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of potential investments or policy changes identified by a defense contractor or the United States Government to increase munitions production, enable more efficient production, or mitigate significant loss of stability in potential production, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida78b21d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct investments in test and tooling equipment, workforce development, or improvements to existing production facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pool of rotable critical components or subcomponents for munitions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiyear contracts or other contracting strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct investments in components, subcomponents, or raw materials commonly used across the industrial base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct investments in additive manufacturing or expeditionary manufacturing capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct investments in simplification of supply chains; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida78b21db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/9/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct investments in technologies or methods to enable increased scalability and reduced complexity of production processes for current or future munitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of each contract for a munition with a priority rating of “critical to national defense” (commonly referred to as a “DO-rated order”) or a priority rating of “highest national defense urgency” (commonly referred to as a “DX-rated order”) in the Defense Priorities and Allocation System pursuant to part 700 of title 15, Code of Federal Regulations (or any successor regulation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prioritized list of munitions judged to have high value for export for which additional investments would be necessary to enable export, including a description of such investments required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida78b21de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of munitions subject to the requirements of chapter 2 of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761"},"text":"22 U.S.C. 2761","children":[],"tail":" et seq.) relating to foreign military sales that are anticipated to be exported based on developments in the conflict in Ukraine."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida78b21df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s222d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Munition Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “munition” has the meaning given that term by the Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida78b21e0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVII/s1701/d/1"},"text":"Pub. L. 117–263, div. A, title XVII, § 1701(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2965"},"text":"136 Stat. 2965","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/6"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1208"},"text":"139 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida78b21e1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida78b21e2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida78b21e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (b)(12), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":". Chapter 2 of the Act is classified generally to subchapter II (§ 2761 et seq.) of chapter 39 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida78b21e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “that term” after “meaning given” and “and Sustainment” after “Under Secretary of Defense for Acquisition”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
