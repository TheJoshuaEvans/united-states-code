{"tag":"section","attrib":{"id":"idab3dcabd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683"},"text":null,"children":[{"tag":"num","attrib":{"value":"8683"},"text":"§ 8683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ship overhaul work: availability of appropriations for unusual cost overruns and for changes in scope of work","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3dcabe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unusual Cost Overruns","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dcabf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations available to the Department of Defense for a fiscal year may be used for payment of unusual cost overruns incident to ship overhaul, maintenance, and repair for a vessel inducted into an industrial-fund activity or contracted for during a prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dcac0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall notify Congress promptly before an obligation is incurred for any payment under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dcac1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes in Scope of Work","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An appropriation available to the Department of Defense for a fiscal year may be used after the otherwise-applicable expiration of the availability for obligation of that appropriation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dcac2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payments to an industrial-fund activity for amounts required because of changes in the scope of work for ship overhaul, maintenance, and repair, in the case of work inducted into the industrial-fund activity during the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dcac3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for payments under a contract for amounts required because of changes in the scope of work, in the case of a contract entered into during the fiscal year for ship overhaul, maintenance, and repair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dcac4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8683/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Amounts Appropriated After End of Period of Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1553/c"},"text":"section 1553(c) of title 31","children":[],"tail":" to funds appropriated in the Operation and Maintenance, Navy account that are available for ship overhaul, the Secretary of the Navy may treat the limitation specified in paragraph (1) of such section to be “$10,000,000” rather than “$4,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3dcac5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/370/s1/n/1"},"text":"Pub. L. 100–370, § 1(n)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-19"},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/850"},"text":"102 Stat. 850","children":[],"tail":", § 7313; renumbered § 8683, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s367"},"text":"Pub. L. 116–283, div. A, title III, § 367","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3551"},"text":"134 Stat. 3551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3dcac6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab3dcac7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section is based on ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/b/tVIII/s8005/j"},"text":"Pub. L. 99–190, § 101(b) [title VIII, § 8005(j), (k)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1185"},"text":"99 Stat. 1185","children":[],"tail":", 1203."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In two instances, the source law to be codified by the bill includes provisions that on their face require that the Department of Defense notify Congress of certain actions. These notification requirements were terminated by section 602 of the Goldwater-Nichols Department of Defense Reorganization Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Public Law 99–433","children":[],"tail":"), which terminated all recurring reporting requirements applicable to the Department of Defense except for those requirements that were specifically exempted in that section. The source law sections are sections 8009(c) and 8005(j) (proviso) of the FY86 defense appropriations Act ("},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Public Law 99–190","children":[],"tail":"), enacted "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"December 19, 1985","children":[],"tail":", which would be codified as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2201"},"text":"section 2201 of title 10","children":[],"tail":" (by section 1(d) of the bill) and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7313/a"},"text":"section 7313(a) of title 10","children":[],"tail":" (by section 1(n) of the bill). In codifying the authorities provided the Department of Defense by these two provisions of law, the committee believes that it is appropriate to reinstate the congressional notification requirements that go with those authorities. These sections were recurring annual appropriation provisions for many years and were made permanent only months before the enactment of the 1986 Reorganization Act. It is the committee’s belief that the failure to exempt these provisions from the general reports termination provision was inadvertent and notes that the notification provisions had in fact previously applied to the Department of Defense for many years. The action of the committee restores the status quo as it existed before the Reorganization Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3dcac8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab3dcac9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8683, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/535"},"text":"70A Stat. 535","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/156"},"text":"Pub. L. 85–861, § 1(156)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1513"},"text":"72 Stat. 1513","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-08-25"},"text":"Aug. 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/197/s1/7"},"text":"Pub. L. 86–197, § 1(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/426"},"text":"73 Stat. 426","children":[],"tail":", related to service credit for certain service as a nurse, woman medical specialist, or civilian employee of Army Medical Department, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1301/d/1/A"},"text":"Pub. L. 99–145, title XIII, § 1301(d)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/736"},"text":"99 Stat. 736","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3dcaca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7313"},"text":"section 7313 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab3dcacb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3dcacc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
