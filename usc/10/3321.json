cond sentence, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3322/a"},"text":"section 3322(a) of this title","children":[],"tail":"” for “the preceding sentence”, “provisions of this chapter” for “provisions of this section”, and “under chapter 137 legacy provisions” for “under this chapter”. Former first sentence of subsec. (a) designated "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3322/a"},"text":"section 3322(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1817/b"},"text":"Pub. L. 116–283, § 1817(b)","children":[],"tail":", (d)(2), transferred subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2306"},"text":"section 2306 of this title","children":[],"tail":" to this section, inserted heading, and designated first, second, and third sentences as pars. (1) to (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1817/d/2/A"},"text":"Pub. L. 116–283, § 1817(d)(2)(A)","children":[],"tail":"–(C), inserted heading and substituted “under chapter 137 legacy provisions” for “under this chapter” and “maintained by the contractor” for “maintained by him”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1817/d/2/E"},"text":"Pub. L. 116–283, § 1817(d)(2)(E)","children":[],"tail":", inserted heading, inserted dash after “the United States” and subpar. (A) designation before “may annul”, substituted “liability; or” for “liability or”, and inserted subpar. (B) designation before “may deduct”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1817/d/2/F"},"text":"Pub. L. 116–283, § 1817(d)(2)(F)","children":[],"tail":", inserted heading, inserted dash after “does not apply” and subpar. (A) designation before “to a contract that is”, substituted “threshold; or” for “threshold or”, and inserted subpar. (B) designation before “to a contract for the acquisition”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa1d3e92-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa1d3e93-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
