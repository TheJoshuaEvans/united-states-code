{"tag":"section","attrib":{"id":"idaa1d3e83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321"},"text":null,"children":[{"tag":"num","attrib":{"value":"3321"},"text":"§ 3321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts awarded using procedures other than sealed-bid procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1d3e84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Types","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3322/a"},"text":"section 3322(a) of this title","children":[],"tail":", the other provisions of this chapter, and other applicable provisions of law, the head of an agency, in awarding contracts under chapter 137 legacy provisions after using procedures other than sealed-bid procedures, may enter into any kind of contract that he considers will promote the best interests of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1d3e85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Warranty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1d3e86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each contract awarded under chapter 137 legacy provisions after using procedures other than sealed-bid procedures shall contain a warranty, determined to be suitable by the head of the agency, that the contractor has employed or retained no person or selling agency to solicit or obtain the contract under an understanding or agreement for a commission, percentage, brokerage, or contingent fee, except a bona fide employee or established commercial or selling agency maintained by the contractor to obtain business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1d3e87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy for Breaking Warranty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a contractor breaks such a warranty the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa1d3e88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may annul the contract without liability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa1d3e89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may deduct the commission, percentage, brokerage, or contingent fee from the contract price or consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1d3e8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability to Certain Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not apply—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa1d3e8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a contract that is for an amount not greater than the simplified acquisition threshold; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa1d3e8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3321/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a contract for the acquisition of commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1d3e8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1817/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1817(a)","children":[],"tail":", (b), (d), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4186"},"text":"134 Stat. 4186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa1d3e8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa1d3e8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n