{"tag":"section","attrib":{"id":"ida759151f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b"},"text":null,"children":[{"tag":"num","attrib":{"value":"130b"},"text":"§ 130b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel in overseas, sensitive, or routinely deployable units: nondisclosure of personally identifying information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7591520-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption From Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense and, with respect to the Coast Guard when it is not operating as a service in the Navy, the Secretary of Homeland Security may, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", authorize to be withheld from disclosure to the public personally identifying information regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7591521-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the armed forces assigned to an overseas unit, a sensitive unit, or a routinely deployable unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591522-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of the Department of Defense or of the Coast Guard whose duty station is with any such unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7591523-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7591524-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority in subsection (a) is subject to such exceptions as the President may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591525-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not authorize any official to withhold, or to authorize the withholding of, information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7591526-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7591527-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “personally identifying information”, with respect to any person, means the person’s name, rank, duty address, and official title and information regarding the person’s pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591528-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “unit” means a military organization of the armed forces designated as a unit by competent authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591529-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “overseas unit” means a unit that is located outside the United States and its territories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida759152a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “sensitive unit” means a unit that is primarily involved in training for the conduct of, or conducting, special activities or classified missions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida759152b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit involved in collecting, handling, disposing, or storing of classified information and materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida759152c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a unit engaged in training—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida759152d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special operations units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida759152e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security group commands weapons stations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida759152f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications stations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7591530-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other unit that is designated as a sensitive unit by the Secretary of Defense or, in the case of the Coast Guard when it is not operating as a service in the Navy, by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7591531-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “routinely deployable unit” means a unit that normally deploys from its permanent home station on a periodic or rotating basis to meet peacetime operational requirements that, or to participate in scheduled training exercises that, routinely require deployments outside the United States and its territories. Such term includes a unit that is alerted for deployment outside the United States and its territories during an actual execution of a contingency plan or in support of a crisis operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7591532-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1044/a"},"text":"Pub. L. 106–65, div. A, title X, § 1044(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/761"},"text":"113 Stat. 761","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7591533-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7591534-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7591535-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a), (c)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7591536-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7591537-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
