{"tag":"section","attrib":{"id":"idab9ade46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12215"},"text":null,"children":[{"tag":"num","attrib":{"value":"12215"},"text":"§ 12215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioned officers: reserve grade of adjutants general and assistant adjutants general","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9ade47-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adjutant general or an assistant adjutant general of the Army National Guard of a State may, upon being extended Federal recognition, be appointed as a reserve officer of the Army as of the date on which he is so recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9ade48-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adjutant general or an assistant adjutant general of the Air National Guard of a State may be appointed in the reserve commissioned grade in which Federal recognition in the Air National Guard is extended to him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9ade49-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2990"},"text":"108 Stat. 2990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9ade4a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note"