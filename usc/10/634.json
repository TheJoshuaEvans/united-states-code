{"tag":"section","attrib":{"id":"ida7f1ac58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634"},"text":null,"children":[{"tag":"num","attrib":{"value":"634"},"text":"§ 634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement for years of service: regular and Space Force colonels; regular Navy captains","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f1ac59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 30 ","children":[{"tag":"inline","attrib":{},"text":"Years of Active Commissioned Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f1ac5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) and as provided under section 637(b) or 637a of this title, each officer of the Regular Army, Regular Air Force, or Regular Marine Corps who holds the regular grade of colonel, and each officer of the Regular Navy who holds the regular grade of captain, who is not on a list of officers recommended for promotion to the regular grade of brigadier general or rear admiral (lower half), respectively, shall, if not earlier retired, be retired on the first day of the month after the month in which he completes 30 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f1ac5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under section 637(b) or 637a of this title, each officer of the Space Force who holds the grade of colonel who is not on a list of officers recommended for promotion to the grade of brigadier general shall, if not earlier retired, be retired on the first day of the month after the month in which the officer completes 30 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f1ac5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Navy who is designated for limited duty to whom ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8372/a/4"},"text":"section 8372(a)(4) of this title","children":[],"tail":" applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f1ac5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Navy or Marine Corps who is a permanent professor at the United States Naval Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f1ac5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},