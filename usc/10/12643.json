{"tag":"section","attrib":{"id":"idaba6c457-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12643"},"text":null,"children":[{"tag":"num","attrib":{"value":"12643"},"text":"§ 12643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Boards for appointment, promotion, and certain other purposes: composition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba6c458-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12643/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s612/a/3"},"text":"section 612(a)(3) of this title","children":[],"tail":" and except for boards that may be convened to select Reserves for appointment in the Regular Army, Regular Navy, Regular Air Force, or Regular Marine Corps, each board convened for the appointment, promotion, demotion, involuntary release from active duty, discharge, or retirement of Reserves shall include at least one member of the Reserves, with the exact number of Reserves determined by the Secretary concerned in his discretion."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba6c459-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12643/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of a board convened for the selection for promotion, or for the demotion or discharge, of Reserves must be senior in rank to the persons under consideration by that board. However, a member serving in a legal advisory capacity may be junior in rank to any person, other than a judge advocate or law specialist, being considered by that board; and a member serving in a medical advisory capacity may be junior in rank to any person, other than a medical officer, being considered by that board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba6c45a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/11"},"text":"70A Stat. 11","children":[],"tail":", § 266; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s501/4"},"text":"Pub. L. 96–513, title V, § 501(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2907"},"text":"94 Stat. 2907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/22/s2/c"},"text":"Pub. L. 97–22, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-07-10"},"text":"July 10, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/124"},"text":"95 Stat. 124","children":[],"tail":"; renumbered § 12643, "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/h/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2996"},"text":"108 Stat. 2996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba6c45b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaba6c45c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaba6c45d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag"