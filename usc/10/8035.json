{"tag":"section","attrib":{"id":"idab070330-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035"},"text":null,"children":[{"tag":"num","attrib":{"value":"8035"},"text":"§ 8035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chief of Naval Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab070331-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Vice Chief of Naval Operations, appointed by the President, by and with the advice and consent of the Senate, from officers on the active-duty list in the line of the Navy serving in grades above captain and eligible to command at sea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070332-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Naval Operations, while so serving, has the grade of admiral without vacating his permanent grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070333-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chief of Naval Operations has such authority and duties with respect to the Department of the Navy as the Chief of Naval Operations, with the approval of the Secretary of the Navy, may delegate to or prescribe for him. Orders issued by the Vice Chief of Naval Operations in performing such duties have the same effect as those issued by the Chief of Naval Operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070334-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When there is a vacancy in the office of Chief of Naval Operations or during the absence or disability of the Chief of Naval Operations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab070335-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Vice Chief of Naval Operations shall perform the duties of the Chief of Naval Operations until a successor is appointed or the absence or disability ceases; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070336-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8035/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is a vacancy in the office of the Vice Chief of Naval Operations or the Vice Chief of Naval Operations is absent or disabled, unless the President directs otherwise, the most senior officer of the Navy in the Office of the Chief of Naval Operations who is not absent or disabled and who is not restricted in performance of duty shall perform the duties of the Chief of Naval Operations until a successor to the Chief of Naval Operations or the Vice Chief of Naval Operations is appointed or until the absence or disability of the Chief of Naval Operations or Vice Chief of Naval Operations ceases, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab070337-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s512/b"},"text":"Pub. L. 99–433, title V, § 512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1050"},"text":"100 Stat. 1050","children":[],"tail":", § 5035; renumbered § 8035, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab070338-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab070339-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab07033a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5085"},"text":"section 5085 of this title","children":[],"tail":" prior to enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8035 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9035"},"text":"section 9035 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 8035 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9034"},"text":"section 9034 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab07033b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5035"},"text":"section 5035 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab07033c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab07033d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
