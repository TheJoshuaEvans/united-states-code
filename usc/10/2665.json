{"tag":"section","attrib":{"id":"ida99ee6fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665"},"text":null,"children":[{"tag":"num","attrib":{"value":"2665"},"text":"§ 2665.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of certain interests in land; logs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida99ee6ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, through an executive department, may sell to any person or foreign government any interest in land that is acquired for the production of lumber or timber products, except land under the control of the Department of the Army or the Department of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee700-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, through an executive department, may sell to any person or foreign government any forest products produced on land owned or leased by a military department or the Department in which the Coast Guard is operating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee701-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sales under subsection (a) or (b) shall be at prices determined by the President acting through the selling agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee702-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations of the Department of Defense may be reimbursed for all costs of production of forest products pursuant to this section from amounts received as proceeds from the sale of any such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee703-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee704-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each State in which is located a military installation or facility from which forest products are sold in a fiscal year is entitled at the end of such year to an amount equal to 40 percent of (A) the amount received by the United States during such year as proceeds from the sale of forest products produced on such installation or facility, less (B) the amount of reimbursement of appropriations of the Department of Defense under subsection (d) during such year attributable to such installation or facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee705-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount paid to a State pursuant to paragraph (1) shall be expended as the State legislature may prescribe for the benefit of the public schools and public roads of the county or counties in which the military installation or facility is situated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee706-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case in which a military installation or facility is located in more than one State or county, the amount paid pursuant to paragraph (1) shall be distributed in a manner proportional to the area of such installation or facility in each State or county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida99ee707-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida99ee708-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is in the Treasury a reserve account administered by the Secretary of Defense for the purposes of this section. Balances in the account may be used for costs of the military departments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee709-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for improvements of forest lands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee70a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for unanticipated contingencies in the administration of forest lands and the production of forest products for which other sources of funds are not available in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee70b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for natural resources management that implements approved plans and agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee70c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be deposited into the reserve account the total amount received by the United States as proceeds from the sale of forest products sold under subsections (a) and (b) less—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida99ee70d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursements of appropriations made under subsection (d), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida99ee70e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments made to States under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida99ee70f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2665/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reserve account may not exceed $4,000,000 on December 31 of any calendar year. Unobligated balances exceeding $4,000,000 on that date shall be deposited into the United States Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida99ee710-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/149"},"text":"70A Stat. 149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/82/tVI/s610"},"text":"Pub. L. 95–82, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/378"},"text":"91 Stat. 378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/91"},"text":"Pub. L. 96–513, title V, § 511(91)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2928"},"text":"94 Stat. 2928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/31/s12/3/B"},"text":"Pub. L. 97–31, § 12(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-06"},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/153"},"text":"95 Stat. 153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/99/tIX/s910/a"},"text":"Pub. L. 97–99, title IX, § 910(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-23"},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1386"},"text":"95 Stat. 1386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/33"},"text":"Pub. L. 97–295, § 1(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1296"},"text":"96 Stat. 1296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/407/tVIII/s809/a"},"text":"Pub. L. 98–407, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1522"},"text":"98 Stat. 1522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/561/s4"},"text":"Pub. L. 99–561, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3151"},"text":"100 Stat. 3151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/4"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1056/c/6"},"text":"Pub. L. 109–163, div. A, title X, § 1056(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3439"},"text":"119 Stat. 3439","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida99ee711-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida99ee712-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida99ee713-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2665(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:172 (last par., less 36th through 64th, and 73d through 109th, words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":", subch. XV, § 8 (last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/888"},"text":"40 Stat. 888","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2665(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:172 (36th through 64th words of last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2665(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:172 (73d through 90th words of last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2665(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:172 (91st through 109th words of last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an executive department or the Federal Maritime Board” are substituted for the words “any department or the United States Maritime Commission” to reflect an opinion of the Judge Advocate General of the Army (JAGA 1954/1723) and to name the successor of the United States Maritime Commission. The last 18 words are inserted to reflect that opinion (see the Act of ","children":[{"tag":"date","attrib":{"date":"1931-02-20"},"text":"February 20, 1931","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1354"},"text":"10 U.S.C. 1354","children":[],"tail":")). The words “and dispose of” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “an executive department or the Federal Maritime Board” are inserted for clarity and to name the successor of the United States Maritime Commission.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the word “person” is substituted for the words “individuals, corporations,” since ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":" defines the word “person” to cover both individuals and corporations. The words “States or” are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the selling agency” are substituted for the words “his above representatives selling or disposing of the same”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida99ee714-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1982","children":[{"tag":"inline","attrib":{},"text":" Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This corrects an error in an amendment to 10:2665 made by section 12(3)(B) of the Maritime Act of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/31"},"text":"Pub. L. 97–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-06"},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/153"},"text":"95 Stat. 153","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida99ee715-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" struck out “under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2664"},"text":"section 2664 of this title","children":[],"tail":"” after “land that is acquired”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “Department in which the Coast Guard is operating” for “Department of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/561/s4/1"},"text":"Pub. L. 99–561, § 4(1)","children":[],"tail":", struck out “available for operation and maintenance during a fiscal year” after “Defense”, substituted “costs” for “expenses”, and struck out “during such fiscal year” after “such property”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/561/s4/2"},"text":"Pub. L. 99–561, § 4(2)","children":[],"tail":", struck out “for all expenses of production of forest products” after “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/561/s4/3/A"},"text":"Pub. L. 99–561, § 4(3)(A)","children":[],"tail":", (B), substituted “costs” for “expenses” in provisions preceding subpar. (A) and amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “for expenses to enable operations of forest lands and the production of forest products to continue from the end of one fiscal year through the beginning of the next fiscal year without disruption.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/561/s4/3/C"},"text":"Pub. L. 99–561, § 4(3)(C)","children":[],"tail":", amended pars. (2) and (3) generally. Prior to amendment, pars. (2) and (3) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Subject to paragraph (3), there shall be deposited into the reserve account not later than December 31 of each year, for credit to the preceding fiscal year, an amount equal to one-half of the amount (if any) remaining of the total amount received by the United States during that fiscal year as proceeds from the sale of forest products after (A) the reimbursement of appropriations of the Department of Defense under subsection (d) for expenses of production of forest products during that fiscal year, and (B) the payment to States under subsection (e) for that fiscal year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The balance in the reserve account may not exceed $4,000,000. If a deposit under paragraph (2) would cause the balance in the account to exceed that amount, the deposit shall be made only to the extent the amount of the deposit would not cause the balance in the account to exceed $4,000,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407/s809/a/1"},"text":"Pub. L. 98–407, § 809(a)(1)","children":[],"tail":", substituted “forest products produced on land owned or leased by a military department or the” for “logs wholly or partly manufactured by, or otherwise procured for, the Army, Navy, or Air Force, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407/s809/a/2"},"text":"Pub. L. 98–407, § 809(a)(2)","children":[],"tail":", substituted “forest products” for “lumber and timber products”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407/s809/a/3"},"text":"Pub. L. 98–407, § 809(a)(3)","children":[],"tail":", substituted “forest products” for “timber and timber products” in two places and “40 percent” for “25 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407/s809/a/4"},"text":"Pub. L. 98–407, § 809(a)(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295"},"text":"Pub. L. 97–295","children":[],"tail":" substituted “executive department, may sell” for “executive department” and all that followed through “may sell” in subsecs. (a) and (b), and substituted “Air Force, or Department of Transportation.” for “Air Force” and all that followed in subsec. (b), clarifying the ambiguity created by the conflicting language of "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/97/31"},"text":"Pub. L. 97–31","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/31"},"text":"Pub. L. 97–31","children":[],"tail":" struck out reference to Federal Maritime Commission in subsec. (a), and substituted “or Department of Transportation” for “or Federal Maritime Commission” and struck out “or the Federal Maritime Commission” after “department” in subsec. (b). Amendment was executed to text in accordance with the probable intent of Congress, notwithstanding amendment of section by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" which substituted different language than language contained in amendatory provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/97/31"},"text":"Pub. L. 97–31","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/99"},"text":"Pub. L. 97–99","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “Federal Maritime Commission” for “Federal Maritime Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/82"},"text":"Pub. L. 95–82","children":[],"tail":" substituted provisions relating to reimbursement of production expenses during any fiscal year from proceeds from sales for property during such fiscal year, for provisions requiring proceeds from sales under subsecs. (a) or (b) of this section to be credited to the appropriations under which the property concerned was procured."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida99ee716-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida99ee717-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":nul