{"tag":"section","attrib":{"id":"idaae80807-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7371"},"text":null,"children":[{"tag":"num","attrib":{"value":"7371"},"text":"§ 7371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army War College and United States Army Command and General Staff College: civilian faculty members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae80808-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may employ as many civilians as professors, instructors, and lecturers at the Army War College or the United States Army Command and General Staff College as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae80809-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation of Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compensation of persons employed under this section shall be as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae8080a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Certain Faculty Members","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae8080b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), this section shall apply with respect to persons who are selected by the Secretary for employment as professors, instructors, and lecturers at the Army War College or the United States Army Command and General Staff College after the end of the 90-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1989-11-29"},"text":"November 29, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae8080c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply with respect to professors, instructors, and lecturers employed at the Army War College or the United States Army Command and General Staff College if the duration of the principal course of instruction offered at the college involved is less than 10 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae8080d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXI/s1124/b/1"},"text":"Pub. L. 101–189, div. A, title XI, § 1124(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1558"},"text":"103 Stat. 1558","children":[],"tail":", § 4021; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/c/12"},"text":"Pub. L. 107–107, div. A, title X, § 1048(c)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1226"},"text":"115 Stat. 1226","children":[],"tail":"; renumbered § 7371, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/15"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaae8080e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae8080f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaae80810-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4021"},"text":"section 4021 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"November 29, 1989","children":[],"tail":"” for “the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaae80811-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","chil