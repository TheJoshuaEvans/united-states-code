{"tag":"section","attrib":{"id":"idabb766f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507"},"text":null,"children":[{"tag":"num","attrib":{"value":"14507"},"text":"§ 14507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal from the reserve active-status list for years of service: reserve lieutenant colonels and colonels of the Army, Air Force, and Marine Corps and reserve commanders and captains of the Navy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb766f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lieutenant Colonels and Commanders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless continued on the reserve active-status list under section 14701, 14701a, or 14702 of this title or retained as provided in section 12646 or 12686 of this title, each reserve officer of the Army, Navy, Air Force, or Marine Corps who holds the grade of lieutenant colonel or commander and who is not on a list of officers recommended for promotion to the next higher grade shall (if not earlier removed from the reserve active-status list) be removed from that list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":" on the first day of the month after the month in which the officer completes 28 years of commissioned service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb766fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Colonels and Navy Captains","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless continued on the reserve active-status list under section 14701, 14701a, or 14702 of this title or retained as provided in section 12646 or 12686 of this title, each reserve officer of the Army, Air Force, or Marine Corps who holds the grade of colonel, and each reserve officer of the Navy who holds the grade of captain, and who is not on a list of officers recommended for promotion to the next higher grade shall (if not earlier removed from the reserve active-status list) be removed from that list under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14514"},"text":"section 14514 of this title","children":[],"tail":" on the first day of the month after the month in which the officer completes 30 years of commissioned service. This subsection does not apply to the adjutant general or assistant adjutants general of a State."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb766fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Authority To Retain Certain Officers Designated as Judge Advocates","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb766fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of subsections (a) and (b), the Secretary of the Air Force may retain on the reserve active-status list any reserve officer of the Air Force who is designated as a judge advocate and who obtained the first professional degree in law while on an educational delay program subsequent to being commissioned through the Reserve Officers’ Training Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb766fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No more than 50 officers may be retained on the reserve active-status list under the authority of paragraph (1) at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb766fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No officer may be retained on the reserve active-status list under the authority of paragraph (1) for a period exceeding three years from the date on which, but for that authority, that officer would have been removed from the reserve active-status list under subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb766ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14507/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary of the Air Force under paragraph (1) expires on ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb76700-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2951"},"text":"108 Stat. 2951","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s508/a"},"text":"Pub. L. 104–201, div. A, title V, § 508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2513"},"text":"110 Stat. 2513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s513/c/4"},"text":"Pub. L. 118–159, div. A, title V, § 513(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1876"},"text":"138 Stat. 1876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb76701-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb76702-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabb76703-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “, 14701a,” after “14701”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb76704-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabb76705-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s508/b"},"text":"Pub. L. 104–201, div. A, title V, § 508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2513"},"text":"110 Stat. 2513","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tV/s508/b"},"text":"“Subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14507"},"text":"section 14507 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect on "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb76706-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
