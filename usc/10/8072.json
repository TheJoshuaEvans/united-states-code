{"tag":"section","attrib":{"id":"idab0bbd4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8072"},"text":null,"children":[{"tag":"num","attrib":{"value":"8072"},"text":"§ 8072.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureaus: distribution of business; orders; records; expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0bbd4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8072/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by law, the business of the executive part of the Department of the Navy shall be distributed among the bureaus as the Secretary of the Navy considers expedient and proper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbd4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8072/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each bureau shall perform its duties under the authority of the Secretary, and its orders are considered as coming from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbd4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8072/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under the Secretary, each bureau has custody and charge of its records and accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbd50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8072/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each bureau shall furnish to the Secretary estimates for its specific, general, and contingent expenses.","chil