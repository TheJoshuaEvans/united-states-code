{"tag":"section","attrib":{"id":"ida91236f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1783"},"text":null,"children":[{"tag":"num","attrib":{"value":"1783"},"text":"§ 1783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family members serving on advisory committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A committee within the Department of Defense which advises or assists the Department in the performance of any function which affects members of military families and which includes members of military families in its membership shall not be considered an advisory committee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001/2"},"text":"section 1001(2) of title 5","children":[],"tail":" solely because of such membership."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida91236f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s568/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 568(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/330"},"text":"110 Stat. 330","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/50"},"text":"Pub. L. 117–286, § 4(a)(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4311"},"text":"136 Stat. 4311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida91236f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida91236f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"