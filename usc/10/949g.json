{"tag":"section","attrib":{"id":"ida836cc53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g"},"text":null,"children":[{"tag":"num","attrib":{"value":"949g"},"text":"§ 949g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida836cc54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida836cc55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before performing their respective duties in a military commission under this chapter, military judges, members, trial counsel, defense counsel, reporters, and interpreters shall take an oath to perform their duties faithfully.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida836cc56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The form of the oath required by paragraph (1), the time and place of the taking thereof, the manner of recording thereof, and whether the oath shall be taken for all cases in which duties are to be performed or for a particular case, shall be as provided in regulations prescribed by the Secretary of Defense. The regulations may provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida836cc57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an oath to perform faithfully duties as a military judge, trial counsel, or defense counsel may be taken at any time by any judge advocate or other person certified to be qualified or competent for the duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida836cc58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such an oath is taken, such oath need not again be taken at the time the judge advocate or other person is detailed to that duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Witnesses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each witness before a military commission under this chapter shall be examined on oath.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida836cc5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oath Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “oath” includes an affirmation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida836cc5b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2587"},"text":"123 Stat. 2587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida836cc5c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida836cc5d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida836cc5e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 949g, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2613"},"text":"120 Stat. 2613","children":[],"tail":", related to oaths, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
