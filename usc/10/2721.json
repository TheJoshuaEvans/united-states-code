{"tag":"section","attrib":{"id":"ida9c77dba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721"},"text":null,"children":[{"tag":"num","attrib":{"value":"2721"},"text":"§ 2721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property records: maintenance on quantitative and monetary basis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9c77dbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by him, the Secretary of Defense shall have the records of the fixed property, installations, major equipment items, and stored supplies of the military departments maintained on both a quantitative and a monetary basis, so far as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9c77dbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations prescribed pursuant to subsection (a) shall include a requirement that the records maintained under such subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9c77dbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, provide up-to-date information on all items in the inventory of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77dbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate whether the inventory of each item is sufficient or excessive in relation to the needs of the Department for that item; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9c77dbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" permit the Secretary of Defense to include in the budget submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":" for each fiscal year, information relating to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9c77dc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts proposed for each appropriation account in such budget for inventory purchases of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9c77dc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2721/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts obligated for such inventory purchases out of the corresponding appropriations account for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9c77dc2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/152"},"text":"70A Stat. 152","children":[],"tail":", § 2701; renumbered § 2721, "},{"tag":"ref","attrib":{"href":"/us/pl/99/499/tII/s211/a/1/A"},"text":"Pub. L. 99–499, title II, § 211(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1719"},"text":"100 Stat. 1719","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIII/s1322/a/12"},"text":"Pub. L. 101–510, div. A, title XIII, § 1322(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1671"},"text":"104 Stat. 1671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIII/s347/b"},"text":"Pub. L. 102–190, div. A, title III, § 347(b)","children":[],"tail":", title X, § 1061(a)(17)(A), "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1347"},"text":"105 Stat. 1347","children":[],"tail":", 1473.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9c77dc3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida9c77dc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida9c77dc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2701(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2701(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:172i (less last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"5:172i (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-26/ch343/s410"},"text":"July 26, 1947, ch. 343, § 410","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/act/1949-08-10/ch412/s11/410"},"text":"Aug. 10, 1949, ch. 412, § 11(410)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/590"},"text":"63 Stat. 590","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “equipment” and “materials” are omitted, since the word “supplies”, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/26"},"text":"section 101(26) of this title","children":[],"tail":", includes equipment and materials. The word “stored” is substituted for the words “held in store by the armed services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “on property records maintained under this section” are substituted for the word “thereon”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9c77dc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9c77dc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1061/a/17/A"},"text":"Pub. L. 102–190, § 1061(a)(17)(A)","children":[],"tail":", substituted section catchline for one which read “Basis: reports”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s347/b"},"text":"Pub. L. 102–190, § 347(b)","children":[],"tail":", designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" struck out “(a)” before “Under regulations” and struck out subsec. (b) which read as follows: “The Secretary shall report once a year to Congress and the President on property records maintained under this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9c77dc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9c77dc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tIII/s347/c"},"text":"Pub. L. 102–190, div. A, title III, § 347(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1347"},"text":"105 Stat. 1347","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tIII/s347/c"},"text":"“The Secretary of Defense shall establish the uniform system of valuation described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2458/a/3"},"text":"section 2458(a)(3) of title 10","children":[],"tail":", United States Code (as added by subsection (a)), and prescribe the regulations required by section 2721(b) of such title (as added by subsection (b)), not later than 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9c77dca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inventory Investigations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tIII/s343"},"text":"Pub. L. 100–456, div. A, title III, § 343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1961"},"text":"102 Stat. 1961","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/456/dA/tIII/s343"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undercover Investigations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress finds that the use of undercover investigative techniques by the Department of Defense enhances the ability of the Department of Defense to detect and investigate theft of Government property (including munitions) from the Department of Defense supply system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense is urged to continue to conduct undercover investigations to detect and investigate thefts referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inventory Security Incident Repository","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish and maintain a centralized computer system for recording and organizing information on theft, fraud, and breach of security and incidents involving the loss of Department of Defense supplies (including munitions).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
