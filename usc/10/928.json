{"tag":"section","attrib":{"id":"ida82fc631-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928"},"text":null,"children":[{"tag":"num","attrib":{"value":"928"},"text":"§ 928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 128. Assault","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc632-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assault","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter who, unlawfully and with force or violence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc633-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts to do bodily harm to another person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc634-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers to do bodily harm to another person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc635-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does bodily harm to another person;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of assault and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc636-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aggravated Assault","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc637-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, with the intent to do bodily harm, offers to do bodily harm with a dangerous weapon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc638-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, in committing an assault, inflicts substantial bodily harm or grievous bodily harm on another person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc639-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who commits an assault by strangulation or suffocation;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is guilty of aggravated assault and shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc63a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assault With Intent to Commit Specified Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc63b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person subject to this chapter who commits assault with intent to commit an offense specified in paragraph (2) shall be punished as a court-martial may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc63c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s928/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses specified","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The offenses referred to in paragraph (1) are murder, voluntary manslaughter, rape, sexual assault, rape of a child, sexual assault of a child, robbery, arson, burglary, and kidnapping.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc63d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/75"},"text":"70A Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5441"},"text":"Pub. L. 114–328, div. E, title LX, § 5441","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2954"},"text":"130 Stat. 2954","children":[],"tail":"; "},