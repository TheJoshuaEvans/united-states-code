{"tag":"section","attrib":{"id":"ida93ace1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2199"},"text":null,"children":[{"tag":"num","attrib":{"value":"2199"},"text":"§ 2199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93ace1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2199/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “defense laboratory” means a laboratory operated by the Department of Defense or owned by the Department of Defense and operated by a contractor or a facility of a Defense Agency at which research and development activities are conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2199/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “institution of higher education” has the meaning given such term in section 101 of the Higher Education Act of 1965.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93ace21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2199/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “regional center for the transfer of manufacturing technology” means a manufacturing extension center for the transfer of manufacturing technology and best business practices referred to in section 25(b) of the National Institute of Standards and Technology Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s278k"},"text":"15 U.S.C. 278k","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93ace22-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVIII/s825/a/1"},"text":"Pub. L. 102–190, div. A, title VIII, § 825(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1441"},"text":"105 Stat. 1441","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/2/B"},"text":"Pub. L. 105–244, title I, § 102(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1617"},"text":"112 Stat. 1617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/329/tV/s501/e/1"},"text":"Pub. L. 114–329, title V, § 501(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3032"},"text":"130 Stat. 3032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93ace23-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93ace24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida93ace25-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of the Higher Education Act of 1965, referred to in par. (2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", 