{"tag":"section","attrib":{"id":"idab0bbdb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083"},"text":null,"children":[{"tag":"num","attrib":{"value":"8083"},"text":"§ 8083.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Navy Reserve: appointment of Chief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0bbdb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Office: Chief of Navy Reserve","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is in the executive part of the Department of the Navy, on the staff of the Chief of Naval Operations, an Office of the Navy Reserve, which is headed by a Chief of Navy Reserve. The Chief of Navy Reserve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0bbdb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the principal adviser on Navy Reserve matters to the Chief of Naval Operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0bbdb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the commander of the Navy Reserve Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbdba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0bbdbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, by and with the advice and consent of the Senate, shall appoint the Chief of Navy Reserve from flag officers of the Navy (as defined in section 8001(1)) who have had at least 10 years of commissioned service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0bbdbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may not recommend an officer to the President for appointment as Chief of Navy Reserve unless the officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0bbdbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recommended by the Secretary of the Navy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0bbdbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Chairman of the Joint Chiefs of Staff, in accordance with criteria and as a result of a process established by the Chairman, to have significant joint duty experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0bbdbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer on active duty for service as the Chief of Navy Reserve shall be counted for purposes of the grade limitations under sections 525 and 526 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0bbdc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Until ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":", the Secretary of Defense may waive subparagraph (B) of paragraph (2) with respect to the appointment of an officer as Chief of Navy Reserve if the Secretary of the Navy requests the waiver and, in the judgment of the Secretary of Defense—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab0bbdc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer is qualified for service in the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab0bbdc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is necessary for the good of the service.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Any such waiver shall be made on a case-by-case basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbdc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term; Reappointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Navy Reserve is appointed for a term determined by the Chief of Naval Operations, normally four years, but may be removed for cause at any time. An officer serving as Chief of Navy Reserve may be reappointed for one additional term of up to four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbdc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Navy Reserve is the official within the executive part of the Department of the Navy who, subject to the authority, direction, and control of the Secretary of the Navy and the Chief of Naval Operations, is responsible for preparation, justification, and execution of the personnel, operation and maintenance, and construction budgets for the Navy Reserve. As such, the Chief of Navy Reserve is the director and functional manager of appropriations made for the Navy Reserve in those areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0bbdc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8083/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief of Navy Reserve shall submit to the Secretary of Defense, through the Secretary of the Navy, an annual report on the state of the Navy Reserve and the ability of the Navy Reserve to meet its missions. The report shall be prepared in conjunction with the Chief of Naval Operations and may be submitted in classified and unclassified versions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0bbdc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXII/s1212/b/1"},"text":"Pub. L. 104–201, div. A, title XII, § 1212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2691"},"text":"110 Stat. 2691","children":[],"tail":", § 5143; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s554/c"},"text":"Pub. L. 106–65, div. A, title V, § 554(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/617"},"text":"113 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 507(b), title X, § 1087(a)(18)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–103, 1654A–291; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s501/a"},"text":"Pub. L. 107–314, div. A, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2529"},"text":"116 Stat. 2529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s536/a"},"text":"Pub. L. 108–375, div. A, title V, § 536(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1901"},"text":"118 Stat. 1901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/F"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(F)","children":[],"tail":", (2), (3)(A), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":", 3234; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1061/26"},"text":"Pub. L. 112–81, div. A, title X, § 1061(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1584"},"text":"125 Stat. 1584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s502/dd"},"text":"Pub. L. 114–328, div. A, title V, § 502(dd)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2105"},"text":"130 Stat. 2105","children":[],"tail":"; renumbered § 8083 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(a)(2), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":", 1840; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1061"},"text":"Pub. L. 118–159, div. A, title X, § 1061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2064"},"text":"138 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab0bbdc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab0bbdc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab0bbdc9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/a/2"},"text":"Pub. L. 115–232, § 807(a)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5143"},"text":"section 5143 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8001(1)” for “section 5001(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", in heading, struck out “; Grade” after “Reappointment”, and in text, struck out par. (1) designation before “The Chief of Navy Reserve” and struck out par. (2) which read as follows: “The Chief of Navy Reserve, while so serving, holds the grade of vice admiral.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" struck out subsec. (e). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Chief of Navy Reserve shall submit to the Secretary of Defense, through the Secretary of the Navy, an annual report on the state of the Navy Reserve and the ability of the Navy Reserve to meet its missions. The report shall be prepared in conjunction with the Chief of Naval Operations and may be submitted in classified and unclassified versions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary of Defense shall transmit the annual report of the Chief of Navy Reserve under paragraph (1) to Congress, together with such comments on the report as the Secretary considers appropriate. The report shall be transmitted at the same time each year that the annual report of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":" is submitted to Congress.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/3/A"},"text":"Pub. L. 109–163, § 515(b)(3)(A)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/1/F"},"text":"Pub. L. 109–163, § 515(b)(1)(F)","children":[],"tail":", substituted “Navy Reserve” for “Naval Reserve” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/b/2"},"text":"Pub. L. 109–163, § 515(b)(2)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Navy Reserve","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Naval Reserve","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 507(b)], amended heading and text of subsec. (b) generally. Prior to amendment, text read as follows: “The President, by and with the advice and consent of the Senate, shall appoint the Chief of Naval Reserve from officers who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) have had at least 10 years of commissioned service;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) are in a grade above captain; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) have been recommended by the Secretary of the Navy.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title V, § 507(b)], amended heading and text of subsec. (c) generally. Prior to amendment, subsec. (c) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—(1) The Chief of Naval Reserve holds office for a term determined by the Chief of Naval Operations, normally four years, but may be removed for cause at any time. He is eligible to succeed himself."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Chief of Naval Reserve, while so serving, has the grade of rear admiral, without vacating the officer’s permanent grade. However, if selected in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":", he may be appointed in the grade of vice admiral.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(a)(18)], substituted “has the grade of” for “has a grade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “rear admiral” for “above rear admiral (lower half)” and inserted at end “However, if selected in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12505"},"text":"section 12505 of this title","children":[],"tail":", he may be appointed in the grade of vice admiral.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab0bbdca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab0bbdcb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab0bbdcc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment; Applicability to Incumbents","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", with special provision for an officer who is a covered position incumbent who is appointed under that amendment to the grade of lieutenant general or vice admiral, see section 554(g), (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7038"},"text":"section 7038 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
