{"tag":"section","attrib":{"id":"ida8fa69ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1596b"},"text":"§ 1596b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign language proficiency: National Foreign Language Skills Registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa69cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa69cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may establish and maintain a registry of persons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa69cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have proficiency in one or more critical foreign languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa69ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are willing to provide linguistic services to the United States in the interests of national security during war or a national emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcd9cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the eligibility requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcd9d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The registry shall be known as the “National Foreign Language Skills Registry” (in this section referred to as the “Registry”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Persons","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for listing on the Registry, a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcd9d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" must be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcd9d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national of the United States (as defined in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcd9d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien lawfully admitted for permanent residence (as defined in section 101(a)(20) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/20"},"text":"8 U.S.C. 1101(a)(20)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcd9d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall express willingness, in a form and manner prescribed by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fcd9d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide linguistic services for a foreign language as described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fcd9d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be listed on the Registry; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcd9d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall meet such language proficiency and other selection criteria as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registered Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Registry shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fcd9da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The names of eligible persons selected by the Secretary for listing on the Registry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fcd9db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information on such persons as the Secretary determines pertinent to the use of such persons to provide linguistic services as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Privacy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may withhold from public disclosure the information maintained in the Registry in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Critical Foreign Languages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate those languages that are critical foreign languages for the purposes of this section. The Secretary shall make such a designation for any foreign language for which there is a shortage of experts in translation or interpretation available to meet requirements of the Secretary or of the head of any other department or agency of the United States for translation or interpretation in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcd9de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1596b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Linguistic Services Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “linguistic services” means translation or interpretation of communication in a foreign language.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcd9df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1064/a/1"},"text":"Pub. L. 107–314, div. A, title X, § 1064(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2653"},"text":"116 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
