{"tag":"section","attrib":{"id":"ida959c849-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260"},"text":null,"children":[{"tag":"num","attrib":{"value":"2260"},"text":"§ 2260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of intellectual property: retention of fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c84a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Secretary of Defense or the Secretary of Homeland Security, the Secretary concerned may license trademarks, service marks, certification marks, and collective marks owned or controlled by the Secretary concerned and may retain and expend fees received from such licensing in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c84b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated Marks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall designate the trademarks, service marks, certification marks, and collective marks regarding which the Secretary will exercise the authority to retain licensing fees under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c84c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licenses for Qualifying Companies","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c84d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may license trademarks, service marks, certification marks, and collective marks owned or controlled by the Secretary relating to military designations and likenesses of military weapons systems to any qualifying company upon receipt of a request from the company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c84e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), a qualifying company is any United States company that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c84f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a toy or hobby manufacturer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c850-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined by the Secretary concerned to be qualified in accordance with such criteria as determined appropriate by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c851-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fee for a license under this subsection shall not exceed by more than a nominal amount the amount needed to recover all costs of the Department of Defense in processing the request for the license and supplying the license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c852-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A license to a qualifying company under this subsection shall provide that the license may not be transferred, sold, or relicensed by the qualifying company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c853-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A license under this subsection shall not be an exclusive license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c854-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall use fees retained under this section for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c855-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For payment of the following costs incurred by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c856-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of securing trademark registrations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c857-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of operating the licensing program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c858-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For morale, welfare, and recreation activities under the jurisdiction of the Secretary, to the extent (if any) that the total amount of the licensing fees available under this section for a fiscal year exceed the total amount needed for such fiscal year under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c859-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fees received in a fiscal year and retained under this section shall be available for obligation in such fiscal year and the following two fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c85a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c85b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “trademark”, “service mark”, “certification mark”, and “collective mark” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/s45"},"text":"section 45 of the Act of July 5, 1946","children":[],"tail":" (commonly referred to as the Trademark Act of 1946; "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1127"},"text":"15 U.S.C. 1127","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c85c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Secretary concerned” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/9"},"text":"section 101(a)(9) of this title","children":[],"tail":" and also includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c85d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense, with respect to matters concerning the Defense Agencies and Department of Defense Field Activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c85e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2260/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security, with respect to matters concerning the Coast Guard when it is not operating as a service in the Department of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c85f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1004/a"},"text":"Pub. L. 108–375, div. A, title X, § 1004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2035"},"text":"118 Stat. 2035","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVIII/s882/a"},"text":"Pub. L. 110–181, div. A, title VIII, § 882(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/263"},"text":"122 Stat. 263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VIII, § 881, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4559"},"text":"122 Stat. 4559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c860-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c861-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida959c862-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s881/1"},"text":"Pub. L. 110–417, § 881(1)","children":[],"tail":", inserted “or the Secretary of Homeland Security” after “Secretary of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s882/a"},"text":"Pub. L. 110–181, § 882(a)","children":[],"tail":", added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively. Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s881/2"},"text":"Pub. L. 110–417, § 881(2)","children":[],"tail":", substituted “this section:” for “this section,” and “(1) The” for “the” and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s882/a/1"},"text":"Pub. L. 110–181, § 882(a)(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida959c863-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida959c864-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVIII/s882/b"},"text":"Pub. L. 110–181, div. A, title VIII, § 882(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/264"},"text":"122 Stat. 264","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tVIII/s882/b"},"text":"“The Secretary of Defense shall prescribe regulations to implement the amendment made by this section [amending this section] not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
