{"tag":"section","attrib":{"id":"idab6b1b03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9277"},"text":null,"children":[{"tag":"num","attrib":{"value":"9277"},"text":"§ 9277.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medal of honor; Air Force cross; distinguished-service cross; distinguished-service medal; silver star: replacement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any medal of honor, Air Force cross, distinguished-service cross, distinguished-service medal, or silver star, or any bar, ribbon, rosette, or other device issued for wear with or in place of any of them, that is stolen, lost, or destroyed, or becomes unfit for use, without fault or neglect of the person to whom it was awarded, shall be replaced without charge.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idab6b1b04-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/541"},"text":"70A Stat. 541","children":[],"tail":", § 8747; "},{"tag":"ref","attrib":{"href":"/us/pl/86/593/s1/4"},"text":"Pub. L. 86–593, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-06"},"text":"July 6, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/332"},"text":"74 Stat. 332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s553/c/2"},"text":"Pub. L. 107–107, div. A, title V, § 553(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1116"},"text":"115 Stat. 1116","children":[],"tail":"; renumbered § 9277, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(b)(