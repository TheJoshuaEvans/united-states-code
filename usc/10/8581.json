{"tag":"section","attrib":{"id":"idab31e277-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8581"},"text":null,"children":[{"tag":"num","attrib":{"value":"8581"},"text":"§ 8581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian member: definition; exceptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab31e278-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this chapter, the term “civilian member” means a civilian member of the teaching staff of the United States Naval Academy or the United States Naval Postgraduate School. It includes the Provost and Chief Academic Officer, senior professors, professors, associate professors, assistant professors, chief instructors, assistant chief instructors, and instructors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e279-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter does not apply to any civilian member who was employed at the Naval Academy or the Postgraduate School on ","children":[{"tag":"date","attrib":{"date":"1936-01-16"},"text":"January 16, 1936","children":[],"tail":", and who did not elect to participate in the benefits provided by the "},{"tag":"ref","attrib":{"href":"/us/act/1936-01-16/ch3"},"text":"Act of January 16, 1936, ch. 3","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/49/1092"},"text":"49 Stat. 1092","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e27a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8581/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"co