ml:a","attrib":{"href":"/us/act/1936-01-16/ch3/s4"},"text":"Jan. 16, 1936, ch. 3, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1092"},"text":"49 Stat. 1092","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1073c–1"},"text":"34 U.S.C. 1073c–1","children":[],"tail":" (2d proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-01-16/ch3/s4A"},"text":"Jan. 16, 1936, ch. 3, § 4A","children":[],"tail":" (2d proviso); added "},{"tag":"html:a","attrib":{"href":"/us/act/1943-11-28/ch331/s1"},"text":"Nov. 28, 1943, ch. 331, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/57/594"},"text":"57 Stat. 594","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1936-01-16/ch3/s4"},"text":"Section 4 of the Act of January 16, 1936, ch. 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1092"},"text":"49 Stat. 1092","children":[],"tail":", provided that persons who were then members of the teaching staff should have the right to participate in benefits under the Act if they requested such participation within 60 days. Members who were then under the civil-service retirement system were required to choose whether they would remain under it or would participate in the system established by the 1936 Act. They could not come under both. The section also authorized the Secretary of the Navy to supplement the retired income of members who elected to come under the 1936 Act and whose age in 1936 was such that they could not purchase adequate annuities before retiring. The provisions whereby members could elect to participate were temporary and are executed. The provisions relating to retired income are superseded by § 4A, added by the "},{"tag":"ref","attrib":{"href":"/us/act/1943-11-28/ch331"},"text":"Act of November 28, 1943, ch. 331","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/594"},"text":"57 Stat. 594","children":[],"tail":". The only remaining effect of § 4 and the second proviso of § 4A is to exclude from the benefits and requirements of the 1936 Act persons who were members of the teaching staff in 1936 and did not elect to participate."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab31e27f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab31e280-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"t