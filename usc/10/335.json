{"tag":"section","attrib":{"id":"ida7a31736-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335"},"text":null,"children":[{"tag":"num","attrib":{"value":"335"},"text":"§ 335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of personnel expenses necessary for participation in training program conducted by Colombia under the United States-Colombia Action Plan for Regional Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a31737-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may pay the expendable training supplies, travel, subsistence, and similar personnel expenses of, and special compensation for, the following that the Secretary considers necessary for participation in the training program conducted by Colombia under the United States-Colombia Action Plan for Regional Security:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a31738-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defense personnel of friendly foreign governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a31739-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the concurrence of the Secretary of State, other personnel of friendly foreign governments and nongovernmental personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a3173a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a3173b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the authority provided in subsection (a) may only be used for the payment of such expenses of, and special compensation for, such personnel from developing countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a3173c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may authorize the payment of such expenses of, and special compensation for, such personnel from a country other than a developing country if the Secretary determines that such payment is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a3173d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to respond to extraordinary circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a3173e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s335/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the national security interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a3173f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXII/s1201/a"},"text":"Pub. L. 117–263, div. A, title XII, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2822"},"text":"136 Stat. 2822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a31740-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a31741-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7a31742-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 335 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s255"},"text":"section 255 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
