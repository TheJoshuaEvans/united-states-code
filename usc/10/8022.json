{"tag":"section","attrib":{"id":"idab07026a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022"},"text":null,"children":[{"tag":"num","attrib":{"value":"8022"},"text":"§ 8022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Naval Research: duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab07026b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Office of the Secretary of the Navy an Office of Naval Research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab07026c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of Naval Research shall perform such duties as the Secretary of the Navy prescribes relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab07026d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the encouragement, promotion, planning, initiation, and coordination of naval research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07026e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of naval research in augmentation of and in conjunction with the research and development conducted by the bureaus and other agencies and offices of the Department of the Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab07026f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supervision, administration, and control of activities within or for the Department relating to patents, inventions, trademarks, copyrights, and royalty payments, and matters connected therewith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab070270-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the execution of, and management responsibility for, programs for which funds are provided in the basic and applied research and advanced technology categories of the Department of the Navy research, development, test, and evaluation budget in such a manner that will foster the transition of science and technology to higher levels of research, development, test, and evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070271-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sufficient information relative to estimates of appropriations for research by the several bureaus and offices shall be furnished to the Office of Naval Research to assist it in coordinating naval research and carrying out its other duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab070272-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8022/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Naval Research shall perform its duties under the authority of the Secretary, and its orders are considered as coming from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab070273-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/291"},"text":"70A Stat. 291","children":[],"tail":", § 5151; renumbered § 5022, "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s511/d"},"text":"Pub. L. 99–433, title V, § 511(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1048"},"text":"100 Stat. 1048","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIX/s910/b/1"},"text":"Pub. L. 101–510, div. A, title IX, § 910(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1625"},"text":"104 Stat. 1625","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s501/a"},"text":"Pub. L. 104–201, div. A, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2510"},"text":"110 Stat. 2510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title IX, § 904(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–225; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s504/f"},"text":"Pub. L. 107–314, div. A, title V, § 504(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"