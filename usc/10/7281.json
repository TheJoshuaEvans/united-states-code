{"tag":"section","attrib":{"id":"idaae0dcb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7281"},"text":null,"children":[{"tag":"num","attrib":{"value":"7281"},"text":"§ 7281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service medals: issue; replacement; availability of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae0dcb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall procure, and issue without charge to any person entitled thereto, any service medal authorized for members of the Army after ","children":[{"tag":"date","attrib":{"date":"1928-05-12"},"text":"May 12, 1928","children":[],"tail":", and any ribbon, clasp, star, or similar device prescribed as a part of that medal."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae0dcb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary may prescribe, any medal or other device issued under subsection (a) that is lost, destroyed, or becomes unfit for use, without fault or neglect of the owner, may be replaced at cost. However, if the owner is a member of the Army or the Air Force, the medal or device may be replaced without charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae0dcb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7281/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may spend, from any appropriation for the support of the Army, amounts necessary to provide medals and devices under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae0dcb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/217"},"text":"70A Stat. 217","children":[],"tail":", § 3751; renumbered § 7281, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/11"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1838"},"text":"132 Stat. 1838","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaae0dcb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaae0dcba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaae0dcbb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":