":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab986d77-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1631/b"},"text":"section 1631(b) of Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab986d78-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab986d79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Baccalaureate Degree Required for Appointment or Promotion of Reserve Component Officers to Grades Above First Lieutenant or Lieutenant (Junior Grade)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s523"},"text":"Pub. L. 102–190, div. A, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1363"},"text":"105 Stat. 1363","children":[],"tail":", provided that after "},{"tag":"date","attrib":{"date":"1995-09-30"},"text":"Sept. 30, 1995","children":[],"tail":", no person could be appointed to a grade above grade of first lieutenant in Army Reserve, Air Force Reserve, or Marine Corps Reserve or to a grade above grade of lieutenant (junior grade) in Naval Reserve, or be federally recognized in a grade above grade of first lieutenant as a member of Army National Guard or Air National Guard, unless that person had been awarded a baccalaureate degree by an accredited educational institution, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/35/tII/s203/a"},"text":"Pub. L. 103–35, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-05-31"},"text":"May 31, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/102"},"text":"107 Stat. 102","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12205"},"text":"section 12205 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab986d7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Priority in Making Original Appointments in Guard and Reserve Components for ROTC Scholarship Program Graduates","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tV/s524"},"text":"Pub. L. 102–190, div. A, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1363"},"text":"105 Stat. 1363","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/h"},"text":"Pub. L. 109–163, div. A, title V, § 515(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3237"},"text":"119 Stat. 3237","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tV/s515/h"},"text":"“In making appointments of persons as second lieutenants in the Army Reserve, Air Force Reserve, or Marine Corps Reserve or to the grade of ensign in the Navy Reserve, or in granting federal recognition in the grade of second lieutenant to members of the Army National Guard or Air National Guard, the Secretary of the military department concerned shall give preference to persons who have completed a post-secondary program of education pursued under a ROTC scholarship program at a college or university accredited to award baccalaureate degrees or pursued under a ROTC scholarship program at an accredited two-year or four-year military college.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab986d7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Initial Appointment of All Officers as Reserve Officers and on Appropriate Active Duty Obligation of Graduates of Service Academies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s524"},"text":"Pub. L. 101–510, div. A, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1562"},"text":"104 Stat. 1562","children":[],"tail":", directed Secretary of Defense to submit to Congress a report on advantages, disadvantages, and desirability of initially appointing all persons commissioned as officers in the Army, Navy, Air Force, or Marine Corps as Reserve officers, and the appropriate active duty service obligation for graduates of the service academies, directed Secretary to submit report not later than 60 days after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", and provided that if the report was not submitted by that date, all persons initially appointed as commissioned officers in the Army, Navy, Air Force, and Marine Corps after that date would be appointed as commissioned officers in a Reserve component of the Armed Forces, and all persons entering the service academies after that date would incur an obligation to serve on active duty for a period of five years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab986d7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Regulations Implementing Subsection (e) of This Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII/s718/b"},"text":"Pub. L. 100–180, div. A, title VII, § 718(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1115"},"text":"101 Stat. 1115","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/180/dA/tVII/s718/b"},"text":"“The Secretary concerned shall prescribe regulations implementing subsection (e) of section 591 [now 12201(d)] of title 10, United States Code, as added by subsection (a), not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
