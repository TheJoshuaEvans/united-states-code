{"tag":"section","attrib":{"id":"idaa6e6bb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4272"},"text":null,"children":[{"tag":"num","attrib":{"value":"4272"},"text":"§ 4272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent technical risk assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa6e6bb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a major defense acquisition program, the Secretary of Defense shall conduct or approve independent technical risk assessments before any decision to grant Milestone B approval for the program pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4252"},"text":"section 4252 of this title","children":[],"tail":", any decision to enter into low-rate initial production or full-rate production, or at any other time considered appropriate by the Secretary, that includes the identification of any critical technologies or manufacturing processes that have not been successfully demonstrated in a relevant environment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa6e6bb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue guidance and a framework for the conduct, execution, and approval of independent technical risk assessments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa6e6bb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s807/a/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2261"},"text":"130 Stat. 2261","children":[],"tail":", § 2448b; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/73"},"text":"Pub. L. 116–92, div. A, title IX, § 902(73)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1552"},"text":"133 Stat. 1552","children":[],"tail":"; renumbered § 4272 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1847/e/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1847(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4256"},"text":"134 Stat. 4256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s806/b/1"},"text":"Pub. L. 118–159, div. A, title VIII, § 806(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1974"},"text":"138 Stat. 1974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa6e6bb5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa6e6bb6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa6e6bb7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out dash after “risk assessments” and par. (2) designation before “before any decision” and struck out par. (1) which read as follows: “before any decision to grant Milestone A approval for the program pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4251"},"text":"section 4251 of this title","children":[],"tail":", that identifies critical technologies and manufacturing processes that need to be matured; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/2"},"text":"Pub. L. 116–283, § 1847(e)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2448b"},"text":"section 2448b of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/2/A"},"text":"Pub. L. 116–283, § 1847(e)(2)(A)","children":[],"tail":", substituted “section 4251” for “section 2366a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1847/e/2/B"},"text":"Pub. L. 116–283, § 1847(e)(2)(B)","children":[],"tail":", substituted “section 4252” for “section 2366b”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—With respect to a major defense acquisition program, the Secretary of Defense shall ensure that an independent technical risk assessment is conducted—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) before any decision to grant Milestone A approval for the program pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2366a"},"text":"section 2366a of this title","children":[],"tail":", that identifies critical technologies and manufacturing processes that need to be matured; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) before any decision to grant Milestone B approval for the program pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2366b"},"text":"section 2366b of this title","children":[],"tail":", any decision to enter into low-rate initial production or full-rate production, or at any other time considered appropriate by the Secretary, that includes the identification of any critical technologies or manufacturing processes that have not been successfully demonstrated in a relevant environment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Categorization of Technical Risk Levels","children":[],"tail":".—The Secretary shall issue guidance and a framework for categorizing the degree of technical and manufacturing risk in a major defense acquisition program.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa6e6bb8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa6e6bb9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa6e6bba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to major defense acquisition programs that reach Milestone A after ","children":[{"tag":"date","attrib":{"date":"2017-10-01"},"text":"Oct. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s807/a/2"},"text":"section 807(a)(2) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4271"},"text":"section 4271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
