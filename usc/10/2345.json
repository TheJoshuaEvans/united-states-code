{"tag":"section","attrib":{"id":"ida96a698c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2345"},"text":null,"children":[{"tag":"num","attrib":{"value":"2345"},"text":"§ 2345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liquidation of accrued credits and liabilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida96a698d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2345/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credits and liabilities of the United States accrued as a result of acquisitions and transfers of logistic support, supplies, and services under the authority of this subchapter shall be liquidated not less often than once every 12 months by direct payment to the entity supplying such support, supplies, or services by the entity receiving such support, supplies, or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96a698e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2345/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment-in-kind or exchange entitlements accrued as a result of acquisitions and transfers of logistic support, supplies, and services under authority of this subchapter shall be satisfied within 12 months after the date of the delivery of the logistic support, supplies, or services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96a698f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2345/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96a6990-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2345/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any credits of the United States accrued as a result of the provision of logistic support, supplies, and services under the authority of this subchapter that remain unliquidated more than 18 months after the date of delivery of the logistic support, supplies, or services may, at the option of the Secretary of Defense, with the concurrence of the Secretary of State, be liquidated by offsetting the credits against any amount owed by the Department of Defense, pursuant to a transaction or transactions concluded under the authority of this subchapter, to the government or international organization to which the logistic support, supplies, or services were provided by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96a6991-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2345/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any credits offset pursuant to paragraph (1) shall be credited as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2346"},"text":"section 2346 of this title","children":[],"tail":" as if it were a receipt of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida96a6992-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/323/s2/a"},"text":"Pub. L. 96–323, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-04"},"text":"Aug. 4, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1018"},"text":"94 Stat. 1018","children":[],"tail":", § 2325; renumbered § 2345, "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXIII/s1304/a/1"},"text":"Pub. L. 99–145, title XIII, § 1304(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/741"},"text":"99 Stat. 741","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXI/s1104/c"},"text":"Pub. L. 99–661, div. A, title XI, § 1104(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3965"},"text":"100 Stat. 3965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tIX/s931/e/1"},"text":"Pub. L. 101–189, div. A, title IX, § 931(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1535"},"text":"103 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXIII/s1317/e"},"text":"Pub. L. 103–337, div. A, title XIII, § 1317(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2900"},"text":"108 Stat. 2900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1083/a"},"text":"Pub. L. 114–328, div. A, title X, § 1083(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2420"},"text":"130 Stat. 2420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida96a6993-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida96a6994-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida96a6995-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “12 months” for “three months”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “this subchapter” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2325"},"text":"section 2325 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida96a6996-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida96a6997-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1083/b"},"text":"Pub. L. 114–328, div. A, title X, § 1083(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2420"},"text":"130 Stat. 2420","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tX/s1083/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2345"},"text":"section 2345 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to credits accrued by the United States that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were accrued prior to, and remain unpaid as of, the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are accrued after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida96a6998-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" applicable with regard to any acquisition or transfer of logistic support, supplies, and services under authority of this subchapter that is initiated after "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1317/j"},"text":"section 1317(j) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2341"},"text":"section 2341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
