{"tag":"section","attrib":{"id":"ida8c85d36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1444a"},"text":"§ 1444a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations regarding payment of annuity to a representative payee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8c85d37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1444/a"},"text":"section 1444(a) of this title","children":[],"tail":" shall provide procedures for the payment of an annuity under this subchapter in the case of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8c85d38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person for whom a guardian or other fiduciary has been appointed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8c85d39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minor, mentally incompetent, or otherwise legally disabled person for whom a guardian or other fiduciary has not been appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c85d3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those regulations may include the provisions set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1455/d/2"},"text":"section 1455(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8c85d3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1444a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annuity paid to a person on behalf of an annuitant in accordance with the regulations prescribed pursuant to subsection (a) discharges the obligation of the United States for payment to the annuitant of the amount of the annuity so paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8c85d3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s654/b/1"},"text":"Pub. L. 102–190, div. A, title VI, § 654(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1390"},"text":"105 Stat. 1390","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/26"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1901"},"text":"111 Stat. 1901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8c85d3d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8c85d3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8c85d3f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “section 1455(d)(2)” for “section 1455(c)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
