{"tag":"section","attrib":{"id":"ida81efd9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853"},"text":null,"children":[{"tag":"num","attrib":{"value":"853"},"text":"§ 853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 53. Findings and sentencing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81efda0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Announcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court-martial shall announce its findings and sentence to the parties as soon as determined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81efda1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sentencing Generally.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81efda2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General and special courts-martial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c) for capital offenses, if the accused is convicted of an offense in a trial by general or special court-martial, the military judge shall sentence the accused. The sentence determined by the military judge constitutes the sentence of the court-martial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81efda3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Summary courts-martial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the accused is convicted of an offense in a trial by summary court-martial, the court-martial shall sentence the accused.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81efda4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sentencing for Capital Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81efda5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a capital case, if the accused is convicted of an offense for which the court-martial may sentence the accused to death—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81efda6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the members shall determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida81efda7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the sentence for that offense shall be death or life in prison without eligibility for parole; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida81efda8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the matter shall be returned to the military judge for determination of a lesser punishment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81efda9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the military judge shall sentence the accused for that offense in accordance with the determination of the members under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81efdaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lesser authorized punishments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with regulations prescribed by the President, the military judge may include in any sentence to death or life in prison without eligibility for parole other lesser punishments authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81efdab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s853/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other non-capital offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a capital case, if the accused is convicted of a non-capital offense, the accused shall be sentenced for such non-capital offense in accordance with subsection (b), regardless of whether the accused is convicted of an offense for which the court-martial may sentence the accused to death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81efdac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/56"},"text":"70A Stat. 56","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVII/s5236"},"text":"Pub. L. 114–328, div. E, title LVII, § 5236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2916"},"text":"130 Stat. 2916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1081/c/1/G"},"text":"Pub. L. 115–91, div. A, title X, § 1081(c)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1598"},"text":"131 Stat. 1598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s539E/a"},"text":"Pub. L. 117–81, div. A, title V, § 539E(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1700"},"text":"135 Stat. 1700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81efdad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81efdae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81efdaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"853","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:628.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 53), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/125"},"text":"64 Stat. 125","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “A” is substituted for the word “Every”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81efdb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81efdb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539E/a/1"},"text":"Pub. L. 117–81, § 539E(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) provided that, except for capital offenses, accused who is convicted in trial by general or special court-martial shall be sentenced by military judge or, if court-martial consisted of military judge and members, accused may elect sentencing by members."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539E/a/2/A"},"text":"Pub. L. 117–81, § 539E(a)(2)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, text read as follows: “In a capital case, if the accused is convicted of an offense for which the court-martial may sentence the accused to death, the members shall determine whether the sentence for that offense shall be death or a lesser authorized punishment.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539E/a/2/B"},"text":"Pub. L. 117–81, § 539E(a)(2)(B)","children":[],"tail":", substituted “the military judge” for “the court-martial”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out “in a trial” after “convicted of an offense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “A court-martial shall announce its findings and sentence to the parties as soon as determined.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81efdb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81efdb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s539E/f"},"text":"Pub. L. 117–81, div. A, title V, § 539E(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1706"},"text":"135 Stat. 1706","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tV/s539E/f"},"text":"“The amendments made by this section [amending this section and sections 853a, 856, and 866 of this title and repealing provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s856"},"text":"section 856 of this title","children":[],"tail":"] shall take effect on the date that is two years after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"] and shall apply to sentences adjudged in cases in which all findings of guilty are for offenses that occurred after the date that is two years after the date of the enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81efdb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" effective immediately after the amendments made by div. E (§§ 5001–5542) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" take effect as provided for in section 5542 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), see "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1081/c/4"},"text":"section 1081(c)(4) of Pub. L. 115–91","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81efdb5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
