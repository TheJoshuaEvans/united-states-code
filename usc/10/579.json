{"tag":"section","attrib":{"id":"ida7e10a23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s579"},"text":null,"children":[{"tag":"num","attrib":{"value":"579"},"text":"§ 579.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal from a promotion list","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e10a24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s579/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of a warrant officer recommended for promotion by a selection board convened under this chapter may be removed from the report of the selection board by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e10a25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s579/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may remove the name of a warrant officer who is on a promotion list as a result of being recommended for promotion by a selection board convened under this chapter at any time before the promotion is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e10a26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s579/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer whose name is removed from the list of officers recommended for promotion by a selection board continues to be eligible for consideration for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e10a27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s579/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the next selection board that considers the warrant officer for promotion under this chapter selects the warrant officer for promotion and the warrant officer is promoted, the Secretary concerned may, upon his promotion, grant him the same effective date for pay and allowances and the same date of rank, and the same position on the warrant officer active-duty list as the warrant officer would have had if his name had not been so removed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e10a28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s579/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the next selection board does not select the warrant officer for promotion, or if his name is again removed under subsection (a) from the list of officers recommended for promotion by the selection board or under subsection (b) from the warrant officer promotion list, he shall be treated for all purposes as if he has twice failed of selection for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e10a29-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tXI/s1112/a"},"text":"Pub. L. 102–190, div. A, title XI, § 1112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1497"},"text":"105 Stat. 1497","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e10a2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e10a2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7e10a2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s562"},"text":"section 562 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1112/a"},"text":"Pub. L. 102–190, § 1112(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7e10a2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7e10a2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1132"},"text":"section 1132 of Pub. L. 102–190","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
