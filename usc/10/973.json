{"tag":"section","attrib":{"id":"ida84067a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973"},"text":null,"children":[{"tag":"num","attrib":{"value":"973"},"text":"§ 973.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties: officers on active duty; performance of civil functions restricted","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida84067a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No officer of an armed force on active duty may accept employment if that employment requires him to be separated from his organization, branch, or unit, or interferes with the performance of his military duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida84067a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84067a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a regular officer of an armed force on the active-duty list (and a regular officer of the Coast Guard on the active duty promotion list);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a retired regular officer of an armed force serving on active duty under a call or order to active duty for a period in excess of 270 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a reserve officer of an armed force serving on active duty under a call or order to active duty for a period in excess of 270 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an officer on the Space Force officer list serving on active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s20105/b"},"text":"section 20105(b) of this title","children":[],"tail":" or under a call or order to active duty for a period in excess of 270 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84067ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise authorized by law, an officer to whom this subsection applies may not hold, or exercise the functions of, a civil office in the Government of the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is an elective office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that requires an appointment by the President by and with the advice and consent of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a position in the Executive Schedule under sections 5312 through 5317 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer to whom this subsection applies may hold or exercise the functions of a civil office in the Government of the United States that is not described in subparagraph (A) when assigned or detailed to that office or to perform those functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise authorized by law, an officer to whom this subsection applies by reason of subparagraph (A) of paragraph (1) may not hold or exercise, by election or appointment, the functions of a civil office in the government of a State (or of any political subdivision of a State).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida84067b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer to whom this subsection applies by reason of subparagraph (B) or (C) of paragraph (1) may not hold, by election or appointment, a civil office in the government of a State (or of any political subdivision of a State) if the holding of such office while this subsection so applies to the officer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida84067b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is prohibited under the laws of that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida84067b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the Secretary of Defense or by the Secretary of Homeland Security with respect to the Coast Guard when it is not operating as a service in the Navy, interferes with the performance of the officer’s duties as an officer of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida84067b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise authorized by law, while an officer referred to in subparagraph (A) is serving on active duty, the officer may not exercise the functions of a civil office held by the officer as described in that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to invalidate any action undertaken by an officer in furtherance of assigned official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida84067b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “State” includes the District of Columbia and a territory, possession, or commonwealth of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer to whom subsection (b) applies may seek and hold nonpartisan civil office on an independent school board that is located exclusively on a military reservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida84067b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s973/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, and the Secretary of Homeland Security with respect to the Coast Guard when it is not operating in the Navy, shall prescribe regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida84067ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s4/a/5/A"},"text":"Pub. L. 90–235, § 4(a)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/759"},"text":"81 Stat. 759","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s116"},"text":"Pub. L. 96–513, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2878"},"text":"94 Stat. 2878","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1002/a"},"text":"Pub. L. 98–94, title X, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/655"},"text":"97 Stat. 655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tV/s556"},"text":"Pub. L. 101–510, div. A, title V, § 556","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1570"},"text":"104 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s506"},"text":"Pub. L. 106–65, div. A, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/591"},"text":"113 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s545"},"text":"Pub. L. 108–136, div. A, title V, § 545","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1479"},"text":"117 Stat. 1479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/f"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/672"},"text":"137 Stat. 672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida84067bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida84067bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida84067bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1722/f"},"text":"section 1722(f) of Pub. L. 118–31","children":[],"tail":" amended sections 802, 803, and 937 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida84067be-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s545/2"},"text":"Pub. L. 108–136, § 545(2)","children":[],"tail":", inserted “by reason of subparagraph (A) of paragraph (1)” after “applies” and substituted “(or of any political subdivision of a State)” for “, the District of Columbia, or a territory, possession, or commonwealth of the United States (or of any political subdivision of any such government)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s545/1"},"text":"Pub. L. 108–136, § 545(1)","children":[],"tail":", (3), added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s545/4"},"text":"Pub. L. 108–136, § 545(4)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" substituted “270 days” for “180 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" amended subsec. (b) generally. Prior to amendment subsec. (b) provided that, except as otherwise provided by law, no regular officer of an armed force on active duty could hold a civil office by election or appointment, whether under the United States, a Territory or possession, or a State, and that acceptance of such a civil office or the exercise of its functions by such an officer terminated his military appointment."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s116/c"},"text":"Pub. L. 96–513, § 116(c)","children":[],"tail":", substituted “officers on active duty” for “regular officers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s116/a"},"text":"Pub. L. 96–513, § 116(a)","children":[],"tail":", substituted “of an armed force on active duty” for “on the active list of the Regular Army, Regular Navy, Regular Air Force, Regular Marine Corps, or Regular Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s116/b"},"text":"Pub. L. 96–513, § 116(b)","children":[],"tail":", substituted “regular officer of an armed force on active duty” for “on the active list of the Regular Army, Regular Navy, Regular Air Force, Regular Marine Corps, or Regular Coast Guard”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84067bf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida84067c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida84067c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida84067c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction and Applicability of Section 973(b)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1002/b"},"text":"Pub. L. 98–94, title X, § 1002(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/655"},"text":"97 Stat. 655","children":[],"tail":", 656, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/94/tX/s1002/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s973/b"},"text":"section 973(b) of title 10","children":[],"tail":", United States Code, as in effect before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"], shall be construed—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to invalidate any action undertaken by an officer of an Armed Force in furtherance of assigned official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have terminated the military appointment of an officer of an Armed Force by reason of the acceptance of a civil office, or the exercise of its functions, by that officer in furtherance of assigned official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s973/b/3"},"text":"section 973(b)(3) of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall preclude a Reserve office to whom such section applies from holding or exercising the functions of an office described in such section for the term to which the Reserve officer was elected or appointed if, before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"], the Reserve officer accepted appointment or election to that office in accordance with the laws and regulations in effect at the time of such appointment or election.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
