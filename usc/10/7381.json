{"tag":"section","attrib":{"id":"idaae80837-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381"},"text":"§ 7381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fatality reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaae80838-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Fatalities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Army shall conduct a multidisciplinary, impartial review (referred to as a “fatality review”) in the case of each fatality known or suspected to have resulted from domestic violence or child abuse against any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae80839-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Army on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae8083a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former dependent of a member of the Army on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae8083b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current or former intimate partner who has a child in common or has shared a common domicile with a member of the Army on active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae8083c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report of a fatality review under subsection (a) shall, at a minimum, include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaae8083d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An executive summary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae8083e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data setting forth victim demographics, injuries, autopsy findings, homicide or suicide methods, weapons, police information, assailant demographics, and household and family information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae8083f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal disposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae80840-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" System intervention and failures, if any, within the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae80841-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A discussion of significant findings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaae80842-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations for systemic changes, if any, within the Department of the Army and the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaae80843-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7381/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OSD ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe guidance, which shall be uniform for the military departments, for the conduct of reviews by the Secretary under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaae80844-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s576/a/1"},"text":"Pub. L. 108–136, div. A, title V, § 576(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1486"},"text":"117 Stat. 1486","children":[],"tail":", § 4061; renumbered § 7381, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/b/16"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaae80845-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaae80846-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaae80847-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7391 to 7394 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/295/s1/50/A"},"text":"Pub. L. 97–295, § 1(50)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1299"},"text":"96 Stat. 1299","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7391, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/456"},"text":"70A Stat. 456","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-07-10"},"text":"July 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/533/s1/a/2"},"text":"Pub. L. 87–533, § 1(a)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/154"},"text":"76 Stat. 154","children":[],"tail":", provided for a United States Naval Oceanographic Office attached to the O