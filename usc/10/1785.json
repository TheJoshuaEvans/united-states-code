{"tag":"section","attrib":{"id":"ida914a83f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1785"},"text":null,"children":[{"tag":"num","attrib":{"value":"1785"},"text":"§ 1785.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth sponsorship program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida914a840-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1785/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall require that there be at each military installation a youth sponsorship program to facilitate the integration of dependent children of members of the armed forces into new surroundings when moving to that military installation as a result of a parent’s permanent change of station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida914a841-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1785/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program at each installation shall provide for involvement of dependent children of members presently stationed at the military installation and shall be directed primarily toward children in their preteen and teenage years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida914a842-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s568/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 568(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/331"},"text":"110 Stat. 331","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
