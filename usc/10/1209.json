{"tag":"section","attrib":{"id":"ida8b068b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1209"},"text":null,"children":[{"tag":"num","attrib":{"value":"1209"},"text":"§ 1209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to inactive status list instead of separation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any member of the armed forces who has at least 20 years of service computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of this title","children":[],"tail":", and who would be qualified for retirement under this chapter but for the fact that his disability is less than 30 percent under the standard schedule of rating disabilities in use by the Department of Veterans Affairs at the time of the determination, may elect, instead of being separated under this chapter, to be transferred to the inactive status list under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12735"},"text":"section 12735 of this title","children":[],"tail":" and, if otherwise eligible, to receive retired pay under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12739"},"text":"section 12739 of this title","children":[],"tail":" upon becoming 60 years of age."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida8b068b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/95"},"text":"70A Stat. 95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1621/a/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1621(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1602"},"text":"103 Stat. 1602","children":[],"tail":