{"tag":"section","attrib":{"id":"idaa0570a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3066"},"text":null,"children":[{"tag":"num","attrib":{"value":"3066"},"text":"§ 3066.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment and delegation of procurement functions and responsibilities: procurements for or with other agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3065"},"text":"section 3065 of this title","children":[],"tail":", to facilitate the procurement of property and services covered by any provision of this part that is a chapter 137 legacy provision by each agency named in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3063"},"text":"section 3063 of this title","children":[],"tail":" for any other agency, and to facilitate joint procurement by those agencies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa0570a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3066/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an agency may delegate functions and assign responsibilities relating to procurement to any officer or employee within such agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3066/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of two or more agencies may by agreement delegate procurement functions and assign procurement responsibilities from one agency to another of those agencies or to an officer or civilian employee of another of those agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa0570a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3066/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of two or more agencies may create joint or combined offices to exercise procurement functions and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa0570a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1807/d/2/A"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1807(d)(2)(A)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4158"},"text":"134 Stat. 4158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa0570aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa0570ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa0570ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2311"},"text":"section 2311 of this title","children":[],"tail":", which was transferred first to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3065/b"},"text":"section 3065(b) of this title","children":[],"tail":" and then to this section and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1807/d/1"},"text":"Pub. L. 116–283, § 1807(d)(1)","children":[],"tail":", (2)(A), (D), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1503/a/1"},"