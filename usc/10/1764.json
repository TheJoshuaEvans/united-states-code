{"tag":"section","attrib":{"id":"ida90d7d06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764"},"text":null,"children":[{"tag":"num","attrib":{"value":"1764"},"text":"§ 1764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to establish different minimum requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90d7d07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7d08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may prescribe a different minimum number of years of experience, different minimum education qualifications, and different tenure of service qualifications to be required for eligibility for appointment or advancement to an acquisition position referred to in subsection (b) than is required for such position under or pursuant to any provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any requirement prescribed under paragraph (1) for a position referred to in any paragraph of subsection (b) shall be applied uniformly to all positions referred to in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7d0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to the following acquisition positions in the Department of Defense:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7d0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracting officer, except a position referred to in paragraph (6).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d0c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Portfolio acquisition executive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d0d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior contracting official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d0e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program manager.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d0f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deputy program manager.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7d10-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A position in the contract contingency force of an armed force that is filled by a member of that armed force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7d11-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1764/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “contract contingency force”, with respect to an armed force, has the meaning given such term in regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida90d7d12-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s835/2"},"text":"Pub. L. 108–136, div. A, title VIII, § 835(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1551"},"text":"117 Stat. 1551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVIII/s812/c"},"text":"Pub. L. 108–375, div. A, title VIII, § 812(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2013"},"text":"118 Stat. 2013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1802/b/1/B"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1802(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1227"},"text":"139 Stat. 1227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida90d7d13-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida90d7d14-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida90d7d15-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1764, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1202/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1656"},"text":"104 Stat. 1656","children":[],"tail":", related to authority to establish different minimum experience requirements, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/e/7/A"},"text":"Pub. L. 107–107, div. A, title X, § 1048(e)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1227"},"text":"115 Stat. 1227","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida90d7d16-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “Portfolio acquisition executive” for “Program executive officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s812/c/2"},"text":"Pub. L. 108–375, § 812(c)(2)","children":[],"tail":", substituted “in paragraph (6)” for “in paragraph (5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s812/c/1"},"text":"Pub. L. 108–375, § 812(c)(1)","children":[],"tail":", added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
