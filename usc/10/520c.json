{"tag":"section","attrib":{"id":"ida7d76d41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520c"},"text":null,"children":[{"tag":"num","attrib":{"value":"520c"},"text":"§ 520c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruiting functions: provision of meals and refreshments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the Secretary concerned, funds appropriated to the Department of Defense for recruitment of military personnel may be expended for small meals and refreshments during recruiting functions for the following persons:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7d76d42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who have enlisted under the Delayed Entry Program authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s513"},"text":"section 513 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d76d43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who are objects of armed forces recruiting efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d76d44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons whose assistance in recruiting efforts of the military departments is determined to be influential by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d76d45-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the armed forces and Federal employees when attending recruiting functions in accordance with a requirement to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7d76d46-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s520c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other persons whose presence at recruiting functions will contribute to recruiting efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7d76d47-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s361/a"},"text":"Pub. L. 104–201, div. A, title III, § 361(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2491"},"text":"110 Stat. 2491","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tV/s545"},"text":"Pub. L. 107–107, div. A, title V, § 545","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1113"},"text":"115 Stat. 1113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/8/A"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(8)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1596"},"text":"117 Stat. 1596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7d76d48-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7d76d49-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7d76d4a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “provision of meals and refreshments” for “use of funds” in section catchline, struck out “(a) "},{"tag":"inline","attrib":{},"text":"Provision of Meals and Refreshments","children":[],"tail":".—” before “Under regulations”, and struck out heading and text of subsec. (b). Text read as follows: “Not later than February 1 of each of the years 1998 through 2002, the Secretary of Defense shall submit to Congress a report on the extent to which the authority under subsection (a) was exercised during the fiscal year ending in the preceding year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s545/b/1"},"text":"Pub. L. 107–107, § 545(b)(1)","children":[],"tail":", substituted “recruiting functions” for “recruiting events”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s545/b/2"},"text":"Pub. L. 107–107, § 545(b)(2)","children":[],"tail":", substituted “presence at recruiting functions” for “presence at recruiting efforts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s545/a"},"text":"Pub. L. 107–107, § 545(a)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “The authority in subsection (a) may not be exercised after "},{"tag":"date","attrib":{"date":"2001-09-30"},"text":"September 30, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
