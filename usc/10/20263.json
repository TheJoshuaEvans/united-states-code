{"tag":"section","attrib":{"id":"idabccea09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20263"},"text":null,"children":[{"tag":"num","attrib":{"value":"20263"},"text":"§ 20263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entitlement of officers discharged or retired under this chapter to separation pay or retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabccea0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20263/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separation Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is discharged under this chapter is entitled, if eligible therefor, to separation pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174"},"text":"section 1174 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabccea0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20263/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retired Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer who is retired under this chapter is entitled to retired pay computed under chapter 71 or 1223 of this title, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabccea0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1716/c"},"text":"Pub. L. 118–31, div. A, title XVII, § 1716(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/653"},"text":"137 Stat. 653","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
