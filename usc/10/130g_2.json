{"tag":"section","attrib":{"id":"ida75b8696-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g"},"text":null,"children":[{"tag":"num","attrib":{"value":"130g"},"text":"§ 130g.","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 130g is set out preceding this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements for waivers issued under Department of Defense guidance related to autonomy in weapon systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida75b8697-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to the congressional defense committees written notification of any waiver under Department of Defense Directive 3000.09 (relating to autonomy in weapon systems), or any successor directive, by not later than 30 days after the date on which the waiver is issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75b8698-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each notification submitted under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida75b8699-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rationale for the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida75b869a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the autonomous weapon system or technology covered by the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida75b869b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The anticipated duration of the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75b869c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s130g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A notification under subsection (a) shall be submitted in unclassified form, but may include a classified annex, as the Secretary determines necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida75b869d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1061/a"},"text":"Pub. L. 119–60, div. A, title X, § 1061(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1045"},"text":"139 Stat. 1045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida75b869e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida75b869f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida75b86a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 130g was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s394"},"text":"section 394 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
