{"tag":"section","attrib":{"id":"ida9871945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2495b"},"text":"§ 2495b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale or rental of sexually explicit material prohibited","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9871946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Sale or Rental","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may not permit the sale or rental of sexually explicit material on property under the jurisdiction of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871947-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Officially Provided Sexually Explicit Material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the armed forces or a civilian officer or employee of the Department of Defense acting in an official capacity may not provide for sale, remuneration, or rental sexually explicit material to another person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871948-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resale Activities Review Board","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871949-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall establish a nine-member board to make recommendations to the Secretary regarding whether material sold or rented, or proposed for sale or rental, on property under the jurisdiction of the Department of Defense is barred from sale or rental by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida987194a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida987194b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall appoint six members of the board to broadly represent the interests of the patron base served by the defense commissary system and the exchange system. The Secretary shall appoint one of the members to serve as the chairman of the board. At least one member appointed under this subparagraph shall be a person with experience managing or advocating for military family programs and who is also an eligible patron of the defense commissary system and the exchange system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida987194c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of each of the military departments shall appoint one member of the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida987194d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy on the board shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida987194e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may detail persons to serve as staff for the board. At a minimum, the Secretary shall ensure that the board is assisted at meetings by military resale and legal advisors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida987194f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recommendations made by the board under paragraph (1) shall be made available to the public. The Secretary of Defense shall publicize the availability of such recommendations by such means as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871950-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the board shall be allowed travel expense, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 while away from their homes or regular places of business in the performance of services for the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871951-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9871952-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9871953-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sexually explicit material” means an audio recording, a film or video recording, or a periodical with visual depictions, produced in any medium, the dominant theme of which depicts or describes nudity, including sexual or excretory activities or organs, in a lascivious way.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9871954-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2495b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “property under the jurisdiction of the Department of Defense” includes commissaries, all facilities operated by the Army and Air Force Exchange Service, the Navy Exchange Service Command, the Navy Resale and Services Support Office, Marine Corps exchanges, and ships’ stores.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9871955-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s343/a/1"},"text":"Pub. L. 104–201, div. A, title III, § 343(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2489"},"text":"110 Stat. 2489","children":[],"tail":", § 2489a; renumbered § 2495b, "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tVI/s651/b/2"},"text":"Pub. L. 108–375, div. A, title VI, § 651(b)(2)","children":[],"tail":", (c)(5), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1971"},"text":"118 Stat. 1971","children":[],"tail":", 1972; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 642(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4493"},"text":"122 Stat. 4493","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9871956-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9871957-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9871958-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2489a"},"text":"section 2489a of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9871959-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida987195a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIII/s343/b"},"text":"Pub. L. 104–201, div. A, title III, § 343(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2490"},"text":"110 Stat. 2490","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tIII/s343/b"},"text":"“Subsection (a) of section 2489a [now 2495b] of title 10, United States Code, as added by subsection (a) of this section, shall take effect 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida987195b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Resale Activities Review Board: Establishment and Initial Meeting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title VI, § 642(b), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4494"},"text":"122 Stat. 4494","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/417"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board required by subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2495b"},"text":"section 2495b of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall be established, and its initial nine members appointed, not later than 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board shall conduct an initial meeting within one year after the date of the appointment of the initial members of the board. At the discretion of the board, the board may consider all materials previously reviewed under such section as available for reconsideration for a minimum of 180 days following the initial meeting of the board.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
