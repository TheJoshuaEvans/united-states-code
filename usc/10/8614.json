{"tag":"section","attrib":{"id":"idab34549c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8614"},"text":null,"children":[{"tag":"num","attrib":{"value":"8614"},"text":"§ 8614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprehension of deserters and prisoners; operation of shore patrols","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab34549d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may make such expenditures out of available appropriations as he considers necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab34549e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8614/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apprehend and deliver deserters, stragglers, and prisoners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab34549f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8614/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate shore patrols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3454a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, to the extent he considers proper, may delegate the authority conferred by this section to any person in the Department of the Navy, with or without the authority to make successive redelegations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3454a1-3a6f-11f1-a58a-d8db