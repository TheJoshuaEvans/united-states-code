{"tag":"section","attrib":{"id":"ida92a052d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113b"},"text":"§ 2113b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic Health System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida92a052e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may establish an Academic Health System to integrate the health care, health professions education, and health research activities of the military health system, including under this chapter, in the National Capital Region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a052f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leadership","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida92a0530-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may appoint employees of the Department of Defense to leadership positions in the Academic Health System established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida92a0531-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such positions may include responsibilities for management of the health care, health professions education, and health research activities described in subsection (a) and are in addition to similar leadership positions for members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida92a0532-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2113b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Capital Region Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “National Capital Region” means the area, or portion thereof, as determined by the Secretary, in the vicinity of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida92a0533-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s734/a"},"text":"Pub. L. 116–92, div. A, title VII, § 734(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1461"},"text":"133 Stat. 1461","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
