{"tag":"section","attrib":{"id":"ida88f24b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1095e"},"text":"§ 1095e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: beneficiary counseling and assistance coordinators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida88f24b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall require in regulations that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida88f24b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each lead agent under the TRICARE program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida88f24b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a person to serve full-time as a beneficiary counseling and assistance coordinator for beneficiaries under the TRICARE program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88f24b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate for each of the TRICARE program regions at least one person (other than a person designated under subparagraph (A)) to serve full-time as a beneficiary counseling and assistance coordinator solely for members of the reserve components and their dependents who are beneficiaries under the TRICARE program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida88f24b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for toll-free telephone communication between such beneficiaries and the beneficiary counseling and assistance coordinator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida88f24b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commander of each military medical treatment facility under this chapter designate a person to serve, as a primary or collateral duty, as beneficiary counseling and assistance coordinator for beneficiaries under the TRICARE program served at that facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida88f24b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1095e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe the duties of the position of beneficiary counseling and assistance coordinator in the regulations required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida88f24b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s715/a/1"},"text":"Pub. L. 106–65, div. A, title VII, § 715(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/690"},"text":"113 Stat. 690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVII/s707"},"text":"Pub. L. 108–136, div. A, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1529"},"text":"117 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida88f24b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida88f24ba-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida88f24bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida88f24bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida88f24bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Initial Designations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVII/s715/b"},"text":"Pub. L. 106–65, div. A, title VII, § 715(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/690"},"text":"113 Stat. 690","children":[],"tail":", directed that each beneficiary counseling and assistance coordinator required under the regulations described in subsec. (a) of this section be designated not later than "},{"tag":"date","attrib":{"date":"2000-01-15"},"text":"Jan. 15, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
