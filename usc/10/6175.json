{"tag":"section","attrib":{"id":"idaac42d70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175"},"text":null,"children":[{"tag":"num","attrib":{"value":"6175"},"text":"§ 6175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated schedule for defense environmental cleanup activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac42d71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accelerated Cleanup","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall accelerate the schedule for defense environmental cleanup activities and disposition projects for a site at a Department of Energy defense nuclear facility if the Secretary determines that such an accelerated schedule will accelerate the recapitalization, modernization, or replacement of National Nuclear Security Administration facilities supporting the nuclear weapons stockpile, achieve meaningful, long-term cost savings to the Federal Government, or could substantially accelerate the release of land for local reuse without undermining national security objectives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a determination under subsection (a), the Secretary shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac42d73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which accelerated cleanup schedules can contribute to a more rapid modernization of National Nuclear Security Administration facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost savings achievable by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential for reuse of the site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The risks that the site poses to local health and safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac42d77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proximity of the site to populated areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac42d78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6175/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to affect a specific statutory requirement for a specific defense environmental cleanup activity or project or to modify or otherwise affect applicable statutory or regulatory defense environmental cleanup requirements, including substantive standards intended to protect public health and the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac42d79-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1388"},"text":"139 Stat. 1388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac42d7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac42d7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac42d7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2585"},"text":"section 2585 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
