{"tag":"section","attrib":{"id":"idab4e92a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8805"},"text":null,"children":[{"tag":"num","attrib":{"value":"8805"},"text":"§ 8805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of Government checks outside the United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/a"},"text":"section 3302(a) of title 31","children":[],"tail":", the Secretary of the Navy may authorize the officer in charge of any commissary store or ship’s store ashore located outside the United States to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab4e92aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8805/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept any Government check tendered by a retired member of the Navy or the Marine Corps, a member of the Navy Reserve or the Marine Corps Reserve, or a member of the Fleet Reserve or the Fleet Marine Corps Reserve, if the member is the payee of the check and the check is tendered in payment of amounts due from the member to the store; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab4e92ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8805/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refund in cash any difference between the amount due and the amount of the tendered check.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4e92ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/471"},"text":"70A Stat. 471","children":[],"tail":", § 7605; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s513/42"},"text":"Pub. L. 96–513, title V, § 513(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2935"},"text":"94 Stat. 2935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/b/10"},"text":"Pub. L. 97–258, § 3(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1064"},"text":"96 Stat. 1064","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/V"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(V)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; renumbered § 8805, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab4e92ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab4e92ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab4e92af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"