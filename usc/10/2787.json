{"tag":"section","attrib":{"id":"ida9d0f3d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2787"},"text":null,"children":[{"tag":"num","attrib":{"value":"2787"},"text":"§ 2787.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9d0f3d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2787/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action on Reports of Survey","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed pursuant to subsection (c), any officer of the Army, Navy, Air Force, Marine Corps, or Space Force or any civilian employee of the Department of Defense designated in accordance with those regulations may act upon reports of surveys and vouchers pertaining to the loss, spoilage, unserviceability, unsuitability, or destruction of, or damage to, property of the United States under the control of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d0f3d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2787/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality of Action","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f3d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2787/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Action taken under subsection (a) is final except as provided in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f3d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2787/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An action holding a person pecuniarily liable for loss, spoilage, destruction, or damage is not final until approved by a person designated to do so by the Secretary of a military department, commander of a combatant command, or Director of a Defense Agency, as the case may be, who has jurisdiction of the person held pecuniarily liable. The person designated to provide final approval shall be an officer of an armed force, or a civilian employee, under the jurisdiction of the official making the designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d0f3d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2787/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9d0f3da-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1006/a/1"},"text":"Pub. L. 107–314, div. A, title X, § 1006(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2632"},"text":"116 Stat. 2632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/HH"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(HH)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3822"},"text":"134 Stat. 3822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d0f3db-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d0f3dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9d0f3dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d0f3de-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9d0f3df-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1006/d"},"text":"Pub. L. 107–314, div. A, title X, § 1006(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2633"},"text":"116 Stat. 2633","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/314/dA/tX/s1006/d"},"text":"“The amendments made by this section [enacting this section, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s1007"},"text":"section 1007 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, and repealing sections 4835 and 9835 of this title] shall apply with respect to the loss, spoilage, unserviceability, unsuitability, or destruction of, or damage to, property of the United States under the control of the Department of Defense occurring on or after the effective date of regulations prescribed pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2787"},"text":"section 2787 of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
