2780(b) of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall not be construed to apply to or invalidate any action taken under such section before "},{"tag":"date","attrib":{"date":"2007-03-01"},"text":"March 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida9d0f381-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contracts for Recovery of Indebtedness","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9019"},"text":"Pub. L. 101–165, title IX, § 9019","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1133"},"text":"103 Stat. 1133","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/165/tIX/s9019"},"text":"“During the current fiscal year and hereafter, the Department of Defense may enter into contracts to recover indebtedness to the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3718"},"text":"section 3718 of title 31","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
