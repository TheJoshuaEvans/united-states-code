{"tag":"section","attrib":{"id":"ida9d0f372-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780"},"text":null,"children":[{"tag":"num","attrib":{"value":"2780"},"text":"§ 2780.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9d0f373-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f374-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of Defense shall enter into one or more contracts with a person for collection services to recover indebtedness owed to the United States (arising out of activities related to Department of Defense) that is delinquent by more than three months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f375-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the Secretary to enter into a contract under this section for any fiscal year is subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f376-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such contract shall provide that the person submit to the Secretary a status report on the person’s success in collecting such debts at least once each six months. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3718"},"text":"Section 3718 of title 31","children":[],"tail":" shall apply to any such contract, to the extent not inconsistent with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9d0f377-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9d0f378-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the Secretary of Defense shall disclose to consumer reporting agencies, in accordance with paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711/e"},"text":"section 3711(e) of title 31","children":[],"tail":", information concerning any debt described in subsection (a) of more than $100 that is delinquent by more than 31 days."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9d0f379-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2780/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No disclosure shall be made under paragraph (1) with respect to an indebtedness while a decision regarding waiver of collection of the indebtedness is pending under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2774"},"text":"section 2774 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s716"},"text":"section 716 of title 32","children":[],"tail":", or while a decision regarding remission or cancellation of the indebtedness is pending under section 7837, 8271, or 9837 of this title, unless the Secretary concerned (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/5"},"text":"section 101(5) of title 37","children":[],"tail":") determines that disclosure under that paragraph pending such decision is in the best interests of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9d0f37a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1309/a"},"text":"Pub. L. 99–661, div. A, title XIII, § 1309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3982"},"text":"100 Stat. 3982","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s115/g/2/C"},"text":"Pub. L. 104–316, title I, § 115(g)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3835"},"text":"110 Stat. 3835","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s672/a"},"text":"Pub. L. 109–364, div. A, title VI, § 672(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2270"},"text":"120 Stat. 2270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d0f37b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9d0f37c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9d0f37d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7837, 8271, or 9837” for “section 4837, 6161, or 9837”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" designated existing provisions as par. (1), substituted “Except as provided in paragraph (2), the Secretary of Defense” for “The Secretary”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" substituted “section 3711(e)” for “section 3711(f)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d0f37e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9d0f37f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for c