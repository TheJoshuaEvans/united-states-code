{"tag":"section","attrib":{"id":"idaa32c287-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3741"},"text":null,"children":[{"tag":"num","attrib":{"value":"3741"},"text":"§ 3741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa32c288-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3741/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “compensation”, for a year, means the total amount of wages, salary, bonuses and deferred compensation for the year, whether paid, earned, or otherwise accruing, as recorded in an employer’s cost accounting records for the year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c289-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3741/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered contract” means a contract for an amount in excess of $500,000 that is entered into by the head of an agency, except that such term does not include a fixed-price contract without cost incentives or any firm fixed-price contract for the purchase of commercial products or commercial services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c28a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3741/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “fiscal year” means a fiscal year established by a contractor for accounting purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c28b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3741/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Head of the agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “head of the agency” or “agency head” does not include the Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa32c28c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3741/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” means the Department of Defense, the Coast Guard, and the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa32c28d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1832/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1832(a)","children":[],"tail":", (b)(1)–(3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4218"},"text":"134 Stat. 4218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa32c28e-3a6f-11f1-a58a-d8db54b14ab5"},"t