{"tag":"section","attrib":{"id":"idaade6b5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7191"},"text":null,"children":[{"tag":"num","attrib":{"value":"7191"},"text":"§ 7191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-regular officers: status","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A commissioned officer of the Army, other than of the Regular Army, who is on active duty in any commissioned grade has the rights and privileges, and is entitled to the benefits, provided by law for a commissioned officer of the Army Reserve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaade6b5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7191/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose reserve grade is that in which the officer not of the Regular Army is serving;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaade6b5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7191/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has the same length of service as the officer not of the Regular Army; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaade6b5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7191/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is on active duty in his reserve grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaade6b60-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/198"},"text":"70A Stat. 198","childr