{"tag":"section","attrib":{"id":"idab50dc80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860"},"text":null,"children":[{"tag":"num","attrib":{"value":"8860"},"text":"§ 8860.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of prize commissioners","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"One or more of the prize commissioners shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dc81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive from the prize master the documents and papers of the captured vessel and the inventory thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take the affidavit of the prize master required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8858"},"text":"section 8858 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take promptly, in the manner prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8861"},"text":"section 8861 of this title","children":[],"tail":", the testimony of the witnesses sent in;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take, at the request of the United States attorney, on interrogatories prescribed by the court, the depositions de bene esse of the prize crew and others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine and inventory the prize property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to the court for an order to the marshal to unload the cargo, if this is necessary to that examination and inventory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the court, and notify the United States attorney, whether any of the prize property requires immediate sale in the interest of all parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the court, from time to time, any matter relating to the condition, custody, or disposal of the prize property requiring action by the court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" return to the court sealed and secured from inspection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab50dc8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the documents and papers received, duly scheduled and numbered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab50dc8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparatory evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab50dc8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evidence taken de bene esse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab50dc8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their inventory of the prize property; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dc8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8860/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Secretary of the Navy, if, in their judgment, any of the prize property is useful to the United States in the prosecution of war.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dc8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/477"},"text":"70A Stat. 477","children":[],"tail":", § 7660; renumbered § 8860 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(d)(9), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dc90-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dc91-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dc92-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7660","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s1138"},"text":"34 U.S.C. 1138","children":[],"tail":" (less applicability to procedure for interrogating witnesses)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. 4622 (less applicability to procedure for interrogating witnesses).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “but the custody of the property shall be in the marshal only” are omitted as surplusage, since this fact is made clear in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7662"},"text":"§ 7662 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dc93-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dc94-3a6f-11f1-a58a-d8db54b14ab5"},