},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/643"},"text":"110 Stat. 643","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa1d3e1c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3303, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/188"},"text":"70A Stat. 188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/616/s1/3"},"text":"Pub. L. 86–616, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/386"},"text":"74 Stat. 386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/509/s4/a"},"text":"Pub. L. 87–509, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/121"},"text":"76 Stat. 121","children":[],"tail":", related to effect of failure of a promotion-list officer considered for promotion to grade of captain, major, or lieutenant colonel under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3299"},"text":"section 3299 of this title","children":[],"tail":" to be recommended for promotion, which officer was to be known as a “deferred officer”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tII/s204"},"text":"Pub. L. 96–513, title II, § 204","children":[],"tail":", title VII, § 701, "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2880"},"text":"94 Stat. 2880","children":[],"tail":", 2955, effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":". See sections 631 and 632 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa1d3e1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/5/A"},"text":"Pub. L. 116–283, § 1816(c)(5)(A)","children":[],"tail":", transferred subsec. (b)(4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305"},"text":"section 2305 of this title","children":[],"tail":" to this section and struck out par. (4) designation at beginning."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/5/B"},"text":"Pub. L. 116–283, § 1816(c)(5)(B)","children":[],"tail":", (D), redesignated subpar. (A) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/4"},"text":"section 2305(b)(4) of this title","children":[],"tail":" as subsec. (a) of this section, inserted heading, substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3301/a"},"text":"section 3301(a) of this title","children":[],"tail":"” for “paragraph (1)” in introductory provisions, and redesignated cls. (i) and (ii) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/5/B"},"text":"Pub. L. 116–283, § 1816(c)(5)(B)","children":[],"tail":", (E), redesignated subpar. (B) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/4"},"text":"section 2305(b)(4) of this title","children":[],"tail":" as subsec. (b) of this section, inserted heading, and substituted “subsection (a)(1)” for “subparagraph (A)(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/5/B"},"text":"Pub. L. 116–283, § 1816(c)(5)(B)","children":[],"tail":", (F), redesignated subpar. (C) of former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2305/b/4"},"text":"section 2305(b)(4) of this title","children":[],"tail":" as subsec. (c) of this section, inserted heading, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3301/b"},"text":"section 3301(b) of this title","children":[],"tail":"” for “paragraph (2)”. Former second and third sentences designated subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/5/C"},"text":"Pub. L. 116–283, § 1816(c)(5)(C)","children":[],"tail":", (G), as amended and added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/6/A"},"text":"Pub. L. 117–81, § 1701(b)(6)(A)","children":[],"tail":", designated the second sentence of subsec. (c) as subsec. (d) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1816/c/5/C"},"text":"Pub. L. 116–283, § 1816(c)(5)(C)","children":[],"tail":", (H), as amended and added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/b/6/A"},"text":"Pub. L. 117–81, § 1701(b)(6)(A)","children":[],"tail":", designated the third sentence of subsec. (c) as subsec. (e), inserted heading, and substituted “Subsections (c) and (d) do not” for “This subparagraph does not”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa1d3e1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa1d3e1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa1d3e20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section and amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as an Effective Date of 2021 Amendment note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa1d3e21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Procurement of Tents or Other Temporary Structures","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tIII/s368"},"text":"Pub. L. 112–81, div. A, title III, § 368","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1381"},"text":"125 Stat. 1381","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tIII/s368"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In procuring tents or other temporary structures for use by the Armed Forces, and in establishing or maintaining an alternative source for such tents and structures, the Secretary of Defense shall award contracts that provide the best value to the United States. In determining the best value to the United States under this section, the Secretary shall consider the total life-cycle costs of such tents or structures, including the costs associated with any equipment or fuel needed to heat or cool such tents or structures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Procurement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of this section shall apply to any agency or department of the United States that procures tents or other temporary structures on behalf of the Department of Defense.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
