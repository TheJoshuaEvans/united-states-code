{"tag":"section","attrib":{"id":"ida9eda2a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2880"},"text":null,"children":[{"tag":"num","attrib":{"value":"2880"},"text":"§ 2880.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit size and type","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eda2a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2880/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conformity With Similar Housing Units in Locale","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall ensure that the room patterns and floor areas of military family housing units and military unaccompanied housing units acquired or constructed under this subchapter are generally comparable to the room patterns and floor areas of similar housing units in the locality concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2880/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Limitations on Space by Pay Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sections 2826 and 2856 of this title shall not apply to military family housing or military unaccompanied housing units acquired or constructed under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eda2a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/548"},"text":"110 Stat. 548","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dB/tXXVIII/s2806"},"text":"Pub. L. 108–136, div. B, title XXVIII, § 2806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1722"},"text":"117 Stat. 1722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2807/b"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2807(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2469"},"text":"120 Stat. 2469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9eda2a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9eda2a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9eda2a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “Sections 2826 and 2856” for “(1) Section 2826”, inserted “or military unaccompanied housing” after “military family housing”, and struck out par. (2) which read as follows: “The regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2856"},"text":"section 2856 of this title","children":[],"tail":" shall not apply to any military unaccompanied housing unit acquired or constructed under this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" struck out “unless the unit is located on a military installation” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
