e1e2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8ae1e2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1956 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1201","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:272(a) (less clause (5), and less 2d proviso).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:272(b) (less clause (5), and less 2d and last provisos).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"37:272(f) (less applicability to 37:272(c) and (e)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s402/a"},"text":"Oct. 12, 1949, ch. 681, § 402(a)","children":[],"tail":" (less clause (5), and less 2d proviso), (b) (less clause (5), and less 2d and last provisos), (f) (less applicability to § 402(c) and (e)), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/816"},"text":"63 Stat. 816","children":[],"tail":", 817, 820."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “any other member” are substituted for the words “a member of a Reserve component”, in 37:272(a) and (b), since the words “Reserve component” are defined by section 102(k) of the Career Compensation Act of 1949, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/805"},"text":"63 Stat. 805","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s231/k"},"text":"37 U.S.C. 231(k)","children":[],"tail":"), to include members appointed, enlisted, or inducted without component. The words “active duty (other than for training)” are substituted for the words “extended active duty” for clarity and to reflect the opinion of the Comptroller General in 31 Comp. Gen. 95, 99. The words “if the Secretary also determines that” are substituted for the words “That if condition (5) above is met by a finding that”, in 37:272(a) and (b). The words “of such member”, “upon retirement”, and “to receive”, in 37:272(a), are omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “based upon accepted medical principles” are inserted as a necessary implication of the rule stated in 37:272(a)(5) and (b)(5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (3)(A) is substituted for 37:272(f) (less applicability to 37:272(c) and (e)). 37:272(f) is omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3)(B), the words “at the time of the determination” are substituted for the word “current”, in 37:272(a) and (b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (3)(B)(iii) is substituted for 37:272(a) (last proviso).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8ae1e2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8ae1e2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1958 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1201","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[No source].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amendment reflects the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-04-23/ch209"},"text":"Act of April 23, 1956, ch. 209","children":[],"tail":" (70 Stat 115). (See opinion of Comp. Gen., B–130269, "},{"tag":"date","attrib":{"date":"1957-03-18"},"text":"March 18, 1957","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8ae1e2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"The changes correct typographical errors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8ae1e30-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8ae1e31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" struck out “the member has six months or more of active military service and” before “the disability was not noted” and substituted “(unless clear and unmistakable evidence demonstrates that the disability existed before the member’s entrance on active duty and was not aggravated by active military service)” for “(unless compelling evidence or medical judgment is such to warrant a finding that the disability existed before the member’s entrance on active duty)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" amended cl. (i) generally. Prior to amendment, cl. (i) read as follows: “the member has at least eight years of service computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1208"},"text":"section 1208 of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsecs. (a) and (c), designated existing provisions as subsec. (b), and substituted introductory provisions of subsec. (b) for “Upon a determination by the Secretary concerned that a member of a regular component of the armed forces entitled to basic pay, or any other member of the armed forces entitled to basic pay who has been called or ordered to active duty (other than for training under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10148/a"},"text":"section 10148(a) of this title","children":[],"tail":") for a period of more than 30 days, is unfit to perform the duties of his office, grade, rank, or rating because of physical disability incurred while entitled to basic pay, the Secretary may retire the member, with retired pay computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1401"},"text":"section 1401 of this title","children":[],"tail":", if the Secretary also determines that—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" substituted “10148(a)” for “270(b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" inserted “and stable” after “permanent nature”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (3)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “after "},{"tag":"date","attrib":{"date":"1978-09-14"},"text":"September 14, 1978","children":[],"tail":"” for “during the period beginning on "},{"tag":"date","attrib":{"date":"1978-09-15"},"text":"September 15, 1978","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", except that the condition provided for in this item shall not be effective during such period unless the President determines that such condition should be effective during such period and issues an Executive order to that effect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":n