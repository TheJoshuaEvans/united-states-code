{"tag":"section","attrib":{"id":"idaa88aab6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663"},"text":null,"children":[{"tag":"num","attrib":{"value":"4663"},"text":"§ 4663.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on contracting with covered entities that contract with lobbyists for Chinese military companies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa88aab7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Entering Into Contracts With Covered Entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), the Secretary of Defense may not enter into a contract with an entity, a parent company of such entity, or a subsidiary of such entity if such entity is a party to a contract with a covered lobbyist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa88aab8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition in subsection (a) shall not apply with respect to an entity that made reasonable inquires regarding the lobbying activities of another entity and determined such entity was not a covered lobbyist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa88aab9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon notification to Congress, the Secretary of Defense may waive the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa88aaba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa88aabb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered lobbyist” means an entity that engages in lobbying activities for any entity determined to be a Chinese military company listed in accordance with section 1260H of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"10 U.S.C. 113","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa88aabc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4663/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “lobbying activities” has the meaning given in section 1045(c) of the National Defense Authorization Act for Fiscal Year 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s971"},"text":"10 U.S.C. 971","children":[],"tail":" note prec.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa88aabd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s851/a"},"text":"Pub. L. 118–159, div. A, title VIII, § 851(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1995"},"text":"138 Stat. 1995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVII/s1701/a/29"},"text":"Pub. L. 119–60, div. A, title XVII, § 1701(a)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1209"},"text":"139 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa88aabe-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa88aabf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaa88aac0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1260H of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1260H"},"text":"section 1260H of Pub. L. 116–283","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1045(c) of the National Defense Authorization Act for Fiscal Year 2018, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1045/c"},"text":"section 1045(c) of Pub. L. 115–91","children":[],"tail":", which is set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s971"},"text":"section 971 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa88aac1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted “if such entity” before “is a party”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa88aac2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa88aac3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVIII/s851/b"},"text":"Pub. L. 118–159, div. A, title VIII, § 851(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1995"},"text":"138 Stat. 1995","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVIII/s851/b"},"text":"“This section [enacting this section] and the amendments made by this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2026-06-30"},"text":"June 30, 2026","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
