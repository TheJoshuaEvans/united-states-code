{"tag":"section","attrib":{"id":"ida82fc5ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924"},"text":null,"children":[{"tag":"num","attrib":{"value":"924"},"text":"§ 924.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 124. Frauds against the United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person subject to this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc5ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who, knowing it to be false or fraudulent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc5f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any claim against the United States or any officer thereof; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc5f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presents to any person in the civil or military service thereof, for approval or payment, any claim against the United States or any officer thereof;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc5f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who, for the purpose of obtaining the approval, allowance, or payment of any claim against the United States or any officer thereof—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida82fc5f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes or uses any writing or other paper knowing it to contain any false or fraudulent statements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc5f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes any oath to any fact or to any writing or other paper knowing the oath to be false; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida82fc5f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forges or counterfeits any signature upon any writing or other paper, or uses any such signature knowing it to be forged or counterfeited;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc5f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, having charge, possession, custody or control of any money, or other property of the United States, furnished or intended for the armed forces thereof, knowingly delivers to any person having authority to receive it, any amount thereof less than that for which he receives a certificate or receipt; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc5f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s924/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, being authorized to make or deliver any paper certifying the receipt of any property of the United States furnished or intended for the armed forces thereof, makes or delivers to any person such writing without having full knowledge of the truth of the statements therein contained and with intent to defraud the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, upon conviction, be punished as a court-martial may direct.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc5f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/75"},"text":"70A Stat. 75","children":[],"tail":", § 932; renumbered § 924, "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLX/s5401/14"},"text":"Pub. L. 114–328, div. E, title LX, § 5401(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2939"},"text":"130 Stat. 2939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida82fc5f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida82fc5fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida82fc5fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","child