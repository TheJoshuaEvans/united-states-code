{"tag":"section","attrib":{"id":"idabc5bee5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s18501"},"text":null,"children":[{"tag":"num","attrib":{"value":"18501"},"text":"§ 18501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve components: personnel and logistic support by military departments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary concerned is responsible for providing the personnel, equipment, facilities, and other general logistic support necessary to enable units and Reserves in the Ready Reserve of the reserve components under his jurisdiction to satisfy the training requirements and mobilization readiness requirements for those units and Reserves as recommended by the Secretary concerned and by the Chairman of the Joint Chiefs of Staff and approved by the Secretary of Defense, and as recommended by the Commandant of the Coast Guard and approved by the Secretary of Homeland Security when the Coast Guard is not operated as a service of the Navy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabc5bee6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1664/c/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1664(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3011"},"text":"108 Stat. 3011","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc5be