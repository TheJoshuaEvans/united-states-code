{"tag":"section","attrib":{"id":"idaaf660d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7532"},"text":null,"children":[{"tag":"num","attrib":{"value":"7532"},"text":"§ 7532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factories and arsenals: manufacture at","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Army shall have supplies needed for the Department of the Army made in factories or arsenals owned by the United States, so far as those factories or arsenals can make those supplies on an economical basis.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idaaf660d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/254"},"text":"70A Stat. 254","children":[],"tail":", § 4532; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIII/s323/a"},"text":"Pub. L. 113–291, div. A, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3343"},"text":"128 Stat. 3343","children":[],"tail":"; renumbered § 7532, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf660d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaf660d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50