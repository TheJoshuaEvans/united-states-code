{"tag":"section","attrib":{"id":"ida7e354e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604"},"text":null,"children":[{"tag":"num","attrib":{"value":"604"},"text":"§ 604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior joint officer positions: recommendations to the Secretary of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e354e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint","children":[],"tail":" 4-"},{"tag":"inline","attrib":{},"text":"Star Officer Positions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e354e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever a vacancy occurs, or is anticipated to occur, in a position specified in subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7e354e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense shall require the Secretary of the Army to submit the name of at least one Army officer, the Secretary of the Navy to submit the name of at least one Navy officer and the name of at least one Marine Corps officer, and the Secretary of the Air Force to submit the name of at least one Air Force officer and the name of at least one Space Force officer for consideration by the Secretary for recommendation to the President for appointment to that position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7e354e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Joint Chiefs of Staff may submit to the Secretary of Defense the name of one or more officers (in addition to the officers whose names are submitted pursuant to subparagraph (A)) for consideration by the Secretary for recommendation to the President for appointment to that position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Secretaries of the military departments are required to submit the names of officers under paragraph (1)(A), the Chairman of the Joint Chiefs of Staff shall submit to the Secretary of Defense the Chairman’s evaluation of the performance of each officer whose name is submitted under that paragraph (and of any officer whose name the Chairman submits to the Secretary under paragraph (1)(B) for consideration for the same vacancy). The Chairman’s evaluation shall primarily consider the performance of the officer as a member of the Joint Staff and in other joint duty assignments, but may include consideration of other aspects of the officer’s performance as the Chairman considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to the following positions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e354e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commander of a combatant command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commander, United States Forces, Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e354e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIV/s405/c/1"},"text":"Pub. L. 103–337, div. A, title IV, § 405(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2745"},"text":"108 Stat. 2745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tIV/s404/a"},"text":"Pub. L. 104–201, div. A, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2506"},"text":"110 Stat. 2506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s509/a"},"text":"Pub. L. 106–65, div. A, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/592"},"text":"113 Stat. 592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIV/s405/a"},"text":"Pub. L. 107–314, div. A, title IV, § 405(a)","children":[],"tail":", "},{"ta