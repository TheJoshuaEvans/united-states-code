{"tag":"section","attrib":{"id":"idaba20980-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312"},"text":null,"children":[{"tag":"num","attrib":{"value":"12312"},"text":"§ 12312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Active duty agreements: release from duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba20981-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each agreement made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12311/a"},"text":"section 12311(a) of this title","children":[],"tail":" shall provide that the member may not be released from active duty without his consent during the period of the agreement—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba20982-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of a reduction in the actual personnel strength of the armed force concerned, unless the release is in accordance with the recommendation of a board of officers appointed by an authority designated by the Secretary concerned to determine the members to be released from active duty under regulations prescribed by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20983-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other reason, without an opportunity to be heard by a board of officers before the release, unless he is (A) dismissed or discharged under the sentence of a court-martial, (B) released because of an unexplained absence without leave for at least three months, (C) released because he is convicted and sentenced to confinement in a Federal or State penitentiary or correctional institution and the sentence has become final, or (D) released because he has been considered at least twice and has not been recommended for promotion to the next higher grade or because he is considered as having failed of selection for promotion to the next higher grade and has not been recommended for promotion to that grade, under conditions that would require the release or separation of a reserve officer who is not serving under such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba20984-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member who is released from active duty without his consent before the end of his agreement made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12311/a"},"text":"section 12311(a) of this title","children":[],"tail":" is entitled to an amount computed by multiplying the number of years and fractions of a year of his unexpired period of service under the agreement by the sum of one month’s basic pay, special pay, and allowances to which he is entitled on the day of his release. The amount to which a member is entitled under this subsection is in addition to any pay and allowances to which he is otherwise entitled. For the purposes of this subsection, a fraction of a month of 15 days or more is counted as a whole month, and a fraction of a month of less than 15 days is disregarded. This subsection does not apply to a member if he is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba20985-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" released for a reason described in subsection (a)(2)(A)–(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20986-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" released because of a physical disability resulting from his intentional misconduct or wilful neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20987-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for retired pay, separation pay, or severance pay under another provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20988-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" placed on a temporary disability retired list; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba20989-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12312/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" released to accept an appointment, or to be enlisted, in a regular component of an armed force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba2098a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/30"},"text":"70A Stat. 30","children":[],"tail":", § 680; "},{"tag":"ref","attrib":{"href":"/us/pl/87/509/s2"},"text":"Pub. L. 87–509, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-28"},"text":"June 28, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/121"},"text":"76 Stat. 121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tV/s533/b"},"text":"Pub. L. 98–525, title V, § 533(b)","children":[],"tail":", title XIV, § 1405(17), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2528"},"text":"98 Stat. 2528","children":[],"tail":", 2622; renumbered § 12312 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1662(e)(2), 1675(c)(8), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2992"},"text":"108 Stat. 2992","children":[],"tail":", 3017.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba2098b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaba2098c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaba2098d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"680(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"680(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:963(a) (last sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:963(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s235/a"},"text":"July 9, 1952, ch. 608, § 235(a)","children":[],"tail":" (last sentence), (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/66/491"},"text":"66 Stat. 491","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “without his consent” are substituted for the word “involuntary”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “because” is substituted for the words “by reason”. The words “actual personnel strength” are substituted for the words “numerical strength of the military personnel”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “for any other reason” are substituted for the words “for reasons other than that prescribed in paragraph (1)”. The words “dismissed or discharged” are inserted for clarity. The words “at least” are substituted for the word “duration”. The words “is convicted and sentenced * * * and the sentence has become final” are substituted for the words “final conviction and sentence”. The words “from active duty” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “before the end of” are substituted for the words “prior to the expiration of the period of service under”. The words “computed by multiplying * * * and fractions of a year of his unexpired period of service under the agreement by the sum of one month’s * * * pay, and allowances” are substituted for the words “equal to one month’s pay and allowances multiplied by * * * (including any pro rata part thereof) remaining as the unexpired period of his agreement for active duty”. The words “basic * * * special pay * * * to which he is entitled on the day of his release” are substituted for 50:963(b) (2d sentence). The third sentence is substituted for 50:963(b) (last sentence). The last sentence is substituted for 50:963(b) (words within 1st parentheses).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “because of” are substituted for the words “when such release is due to”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(5), the words “to accept” are substituted for the words “for the purpose of accepting”. The words “of an armed force” are inserted for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba2098e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba2098f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1662/e/2"},"text":"Pub. L. 103–337, § 1662(e)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s680"},"text":"section 680 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1675/c/8"},"text":"Pub. L. 103–337, § 1675(c)(8)","children":[],"tail":", substituted “12311(a)” for “679(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1405/17"},"text":"Pub. L. 98–525, § 1405(17)","children":[],"tail":", substituted “reserve officer” for “Reserve Officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s533/b"},"text":"Pub. L. 98–525, § 533(b)","children":[],"tail":", inserted “, separation pay,” after “retired pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/509"},"text":"Pub. L. 87–509","children":[],"tail":" added cl. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaba20990-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaba20991-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
