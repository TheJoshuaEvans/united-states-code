{"tag":"section","attrib":{"id":"idaaffd6ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7804"},"text":null,"children":[{"tag":"num","attrib":{"value":"7804"},"text":"§ 7804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salvage claims by United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaffd700-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may settle, or compromise, and receive payment of a claim by the United States for salvage services performed by the Department of the Army. Amounts received under this section shall be covered into the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaffd701-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case where the amount to be received by the United States is not more than $10,000, the Secretary of the Army may delegate his authority under subsection (a) to any person designated by him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaffd702-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/271"},"text":"70A Stat. 271","children":[],"tail":", § 4804; "},{"tag":"ref","attrib":{"href":"/us/pl/92/417/s1/3"},"text":"Pub. L. 92–417, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/654"},"text":"86 Stat. 654","children":[],"tail":"; renumbered § 7804, "},{"tag":"ref","a