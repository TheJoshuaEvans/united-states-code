{"tag":"section","attrib":{"id":"ida9e67762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2854a"},"text":"§ 2854a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of damaged or deteriorated military family housing; use of proceeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e67763-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Convey","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may convey any family housing facility that, due to damage or deterioration, is in a condition that is uneconomical to repair. Any conveyance of a family housing facility under this section may include a conveyance of the real property associated with the facility conveyed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of this section does not apply to family housing facilities located at military installations approved for closure under a base closure law or family housing facilities located at an installation outside the United States at which the Secretary of Defense terminates operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate total value of the family housing facilities conveyed by the Department of Defense under the authority in this subsection in any fiscal year may not exceed $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67767-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, a family housing facility is in a condition that is uneconomical to repair if the cost of the necessary repairs for the facility would exceed the amount equal to 70 percent of the cost of constructing a family housing facility to replace such facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67769-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As consideration for the conveyance of a family housing facility under subsection (a), the person to whom the facility is conveyed shall pay the United States an amount equal to the fair market value of the facility conveyed, including any real property conveyed along with the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e6776a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall determine the fair market value of any family housing facility and associated real property that is conveyed under subsection (a). Such determination shall be final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e6776b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Wait Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e6776c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may enter into an agreement to convey a family housing facility under this section only after the end of the 14-day period beginning on the date on which the Secretary submits, in an electronic medium pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":", to the appropriate committees of Congress a notice containing a justification for the conveyance under the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e6776d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notice under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e6776e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the consideration to be provided the United States under the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e6776f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the cost of repairing the family housing facility to be conveyed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67770-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the cost of replacing the family housing facility to be conveyed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67771-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Property Disposal Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of law do not apply to the conveyance of a family housing facility under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67772-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subtitle I of title 40 and division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67773-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title V of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11411"},"text":"42 U.S.C. 11411","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e67774-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e67775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The proceeds of any conveyance of a family housing facility under this section shall be credited to the appropriate fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2883"},"text":"section 2883 of this title","children":[],"tail":" and shall be available—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e67776-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct family housing units to replace the family housing facility conveyed under this section, but only to the extent that the number of units constructed with such proceeds does not exceed the number of units of military family housing of the facility conveyed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67777-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repair or restore existing military family housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e67778-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse the Secretary concerned for the costs incurred by the Secretary in conveying the family housing facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e67779-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2883/d"},"text":"section 2883(d) of this title","children":[],"tail":", proceeds derived from a conveyance of a family housing facility under this section shall be available under paragraph (1) without any further appropriation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e6777a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exact acreage and legal description of any family housing facility conveyed under this section, including any real property associated with such facility, shall be determined by such means as the Secretary concerned considers satisfactory, including by survey in the case of real property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e6777b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2854a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may require such additional terms and conditions in connection with the conveyance of family housing facilities under this section as the Secretary considers appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e6777c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2818/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2818(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/553"},"text":"110 Stat. 553","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/d/1"},"text":"Pub. L. 107–107, div. A, title X, § 1048(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1227"},"text":"115 Stat. 1227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/21"},"text":"Pub. L. 107–217, § 3(b)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1297"},"text":"116 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1031/a/46"},"text":"Pub. L. 108–136, div. A, title X, § 1031(a)(46)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1602"},"text":"117 Stat. 1602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/49"},"text":"Pub. L. 111–350, § 5(b)(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3846"},"text":"124 Stat. 3846","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2801/c/3"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2801(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1843"},"text":"131 Stat. 1843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e6777d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e6777e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9e6777f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The McKinney-Vento Homeless Assistance Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/482"},"text":"101 Stat. 482","children":[],"tail":". Title V of the Act is classified generally to subchapter V (§ 11411 et seq.) of chapter 119 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"section 11301 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9e67780-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added subsec. (c) and struck out former subsec. (c) which set out written notice and wait requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" struck out “calendar” after “21” and inserted before period at end “or, if over sooner, a period of 14 days has elapsed after the date on which a copy of the justification is provided in an electronic medium pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s480"},"text":"section 480 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “Subtitle I of title 40 and title III of the” for “The” and “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “McKinney-Vento Homeless Assistance Act” for “Stewart B. McKinney Homeless Assistance Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
