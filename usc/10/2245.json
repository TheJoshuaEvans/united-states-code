{"tag":"section","attrib":{"id":"ida959c7a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2245"},"text":null,"children":[{"tag":"num","attrib":{"value":"2245"},"text":"§ 2245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of aircraft for proficiency flying: limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c7a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An aircraft under the jurisdiction of a military department may not be used by a member of the armed forces for the purpose of proficiency flying except in accordance with regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c7a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2245/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not require proficiency flying by a member except to the extent required for the member to maintain flying proficiency in anticipation of the member’s assignment to combat operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c7a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2245/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not permit proficiency flying in the case of a member who is assigned to a course of instruction of 90 days or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c7a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2245/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “proficiency flying” means flying performed under competent orders by a rated or designated member of the armed forces while serving in a non-aviation assignment or in an assignment in which skills would normally not be maintained in the performance of assigned duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c7a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1481/e/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1481(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1706"},"text":"104 Stat. 1706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1077"},"text":"Pub. L. 110–181, div. A, title X, § 1077","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/333"},"text":"122 Stat. 333","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c7aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c7ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida959c7ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/165/tIX/s9006"},"text":"Pub. L. 101–165, title IX, § 9006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1130"},"text":"103 Stat. 1130","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2241"},"text":"section 2241 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1481/e/3"},"text":"Pub. L. 101–510, § 1481(e)(3)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida959c7ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “In this section, the term ‘proficiency flying’ has the meaning given that term in Department of Defense Directive 1340.4.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
