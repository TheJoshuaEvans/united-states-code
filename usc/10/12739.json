},"text":"2017—Subsec. (f)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “within 30 days after the date of the reentry” for “on the date of the reentry”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" designated existing provisions as par. (1), substituted “Except as provided in paragraph (2), the” for “The”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s632/a/2"},"text":"Pub. L. 107–314, § 632(a)(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s632/a/1"},"text":"Pub. L. 107–314, § 632(a)(1)","children":[],"tail":", (b), redesignated subsec. (b) as (c) and substituted “total amount of the monthly retired pay computed under subsections (a) and (b)” for “amount computed under subsection (a)”. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s632/a/1"},"text":"Pub. L. 107–314, § 632(a)(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabadf0e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"hea