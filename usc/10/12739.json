{"tag":"section","attrib":{"id":"idabadf0c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739"},"text":null,"children":[{"tag":"num","attrib":{"value":"12739"},"text":"§ 12739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabadf0c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The monthly retired pay of a person entitled to that pay under this chapter is the product of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay base for that person as computed under section 1406(b)(2) or 1407 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2½ percent of the years of service credited to that person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person entitled to retired pay under this chapter has been credited by the Secretary concerned with extraordinary heroism in the line of duty and if the highest grade held satisfactorily by that person at any time in the armed forces is an enlisted grade, the person’s retired pay shall be increased by 10 percent of the amount determined under subsection (a). The Secretary’s determination as to extraordinary heroism is conclusive for all purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the total amount of the monthly retired pay computed under subsections (a) and (b) may not exceed 75 percent of the retired pay base upon which the computation is based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a person who retires after ","children":[{"tag":"date","attrib":{"date":"2006-12-31"},"text":"December 31, 2006","children":[],"tail":", with more than 30 years of service credited to that person under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":", the total amount of the monthly retired pay computed under subsections (a) and (b) may not exceed the sum of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf0cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the retired pay base upon which the computation is based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idabadf0cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retired pay base upon which the computation is based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabadf0ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2½ percent of the years of service credited to that person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":", for service under conditions authorized for purposes of this paragraph during a period designated by the Secretary of Defense for purposes of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts computed under this section, if not a multiple of $1, shall be rounded down to the next lower multiple of $1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a member of the Retired Reserve is recalled to an active status in the Selected Reserve of the Ready Reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10145/d"},"text":"section 10145(d) of this title","children":[],"tail":" and completes not less than two years of service in such active status, the member is entitled to the recomputation under this section of the retired pay of the member."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may reduce the two-year service requirement specified in paragraph (1) in the case of a member who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf0d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is recalled to serve in a position of adjutant general required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s314"},"text":"section 314 of title 32","children":[],"tail":" or in a position of assistant adjutant general subordinate to such a position of adjutant general;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes at least one year of service in such position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to complete the minimum two years of service solely because the appointment of the member to such position is terminated or vacated as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s324/b"},"text":"section 324(b) of title 32","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabadf0d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modernized Retirement System.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabadf0d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reduced multiplier for full tsp members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a) or (c), in the case of a person who first performs reserve component service on or after ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", after not having performed regular or reserve component service on or before that date, or a person who makes the election described in paragraph (2) (referred to as a “full TSP member”)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf0d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a)(2) shall be applied by substituting “2 percent” for “2½ percent”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (A) of subsection (c)(2) shall be applied by substituting “60 percent” for “75 percent”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (B)(ii) of such subsection shall be applied by substituting “2 percent” for “2½ percent”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election to participate in modernized retirement system.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabadf0dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pursuant to subparagraph (B), a person performing reserve component service on ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":", who has performed fewer than 12 years of service as of "},{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":" (as computed in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":"), may elect, in exchange for the reduced multipliers described in paragraph (1) for purposes of calculating the retired pay of the person, to receive Thrift Savings Plan contributions pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440e/e"},"text":"section 8440e(e) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election period.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idabadf0de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in clauses (ii) and (iii), a person described in subparagraph (A) may make the election described in that subparagraph during the period that begins on ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", and ends on "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabadf0df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hardship extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may extend the election period described in clause (i) for a person who experiences a hardship as determined by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idabadf0e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons experiencing break in service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person returning to reserve component service after a break in reserve component service in which falls the election period specified in clause (i) shall make the election described in subparagraph (A) within 30 days after the date of the reentry into service of the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabadf0e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No retroactive contributions pursuant to election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Thrift Savings Plan contributions may not be made for a person making an election pursuant to subparagraph (A) for any pay period beginning before the date of the person’s election under that subparagraph by reason of the person’s election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabadf0e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12739/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall prescribe regulations to implement this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabadf0e3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/j/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3004"},"text":"108 Stat. 3004","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tVI/s632/a"},"text":"Pub. L. 107–314, div. A, title VI, § 632(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2572"},"text":"116 Stat. 2572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tVI/s642/b"},"text":"Pub. L. 109–364, div. A, title VI, § 642(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2259"},"text":"120 Stat. 2259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tVI/s642/a"},"text":"Pub. L. 111–84, div. A, title VI, § 642(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/