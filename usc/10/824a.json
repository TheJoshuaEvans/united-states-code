{"tag":"section","attrib":{"id":"ida81587cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a"},"text":null,"children":[{"tag":"num","attrib":{"value":"824a"},"text":"§ 824a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 24a. Special trial counsel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81587ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Special Trial Counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Secretary concerned shall promulgate regulations for the detail of commissioned officers to serve as special trial counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81587cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A special trial counsel shall be a commissioned officer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81587d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81587d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a judge advocate who is qualified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s806/a/1"},"text":"section 806(a)(1) of this title","children":[],"tail":" (article 6(a)(1)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is certified to be qualified, by reason of education, training, experience, and temperament, for duty as a special trial counsel by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida81587d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Judge Advocate General of the armed force of which the officer is a member; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida81587d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Marine Corps, the Staff Judge Advocate to the Commandant of the Marine Corps; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a lead special trial counsel appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044f/a/2"},"text":"section 1044f(a)(2) of this title","children":[],"tail":", is in a grade no lower than O–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81587d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Authorities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81587d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Special trial counsel shall carry out the duties described in this chapter and any other duties prescribed by the Secretary concerned, by regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of covered offense; related charges.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81587d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A special trial counsel shall have exclusive authority to determine if a reported offense is a covered offense and shall exercise authority over any such offense in accordance with this chapter. Any determination to prefer or refer charges shall not act to disqualify the special trial counsel as an accuser.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Known and related offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a special trial counsel determines that a reported offense is a covered offense, the special trial counsel may also exercise authority over any offense that the special trial counsel determines to be related to the covered offense and any other offense alleged to have been committed by a person alleged to have committed the covered offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dismissal; referral; plea bargains","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (5), with respect to charges and specifications alleging any offense over which a special trial counsel exercises authority, a special trial counsel shall have exclusive authority to, in accordance with this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81587dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on behalf of the Government, withdraw or dismiss the charges and specifications or make a motion to withdraw or dismiss the charges and specifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer the charges and specifications for trial by a special or general court-martial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a plea agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine if an authorized rehearing is impracticable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Binding determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination of a special trial counsel to refer charges and specifications to a court-martial for trial shall be binding on any applicable convening authority for the referral of such charges and specifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deferral to commander or convening authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a special trial counsel exercises authority over an offense and elects not to prefer charges and specifications for such offense or, with respect to charges and specifications for such offense preferred by a person other than a special trial counsel, elects not to refer such charges and specifications, a commander or convening authority may exercise any of the authorities of such commander or convening authority under this chapter with respect to such offense, except that such commander or convening authority may not refer charges and specifications for a covered offense for trial by special or general court-martial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81587e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Trial Counsel Authority Over Certain Other Offenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81587e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offenses occurring before effective date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A special trial counsel may, at the sole and exclusive discretion of the special trial counsel, exercise authority over the following offenses:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81587e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offense under section 917a (article 117a), 918 (article 118), section 919 (article 119), section 919a (article 119a), section 920 (article 120), section 920a (article 120a), section 920b (article 120b), section 920c (article 120c), section 928b (article 128b), or the standalone offense of child pornography punishable under section 934 (article 134) of this title that occurred on or before ","children":[{"tag":"date","attrib":{"date":"2023-12-27"},"text":"December 27, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offense under section 925 (article 125), section 930 (article 130), or section 932 (article 132) of this title that occurred on or after ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"January 1, 2019","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"2023-12-28"},"text":"December 28, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offense under section 920a (article 120a) of this title, an offense under section 925 (article 125) of this title alleging an act of nonconsensual sodomy, or the standalone offense of kidnapping punishable under section 934 (article 134) of this title that occurred before ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"January 1, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conspiracy to commit an offense specified in subparagraph (A), (B), or (C) as punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s881"},"text":"section 881 of this title","children":[],"tail":" (article 81)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A solicitation to commit an offense specified in subparagraph (A), (B), or (C) as punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s882"},"text":"section 882 of this title","children":[],"tail":" (article 82)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An attempt to commit an offense specified in subparagraph (A), (B), (C), (D), or (E) as punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s880"},"text":"section 880 of this title","children":[],"tail":" (article 80)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"The standalone offense of sexual harassment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":", a special trial counsel may, at the sole and exclusive discretion of the special trial counsel, exercise authority over the following offenses:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81587eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The standalone offense of sexual harassment punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s934"},"text":"section 934 of this title","children":[],"tail":" (article 134) in each instance in which—"}],"tail":null},{"tag":"clause","attrib":{"id":"ida81587ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offense occurs after ","children":[{"tag":"date","attrib":{"date":"2022-01-26"},"text":"January 26, 2022","children":[],"tail":", and on or before "},{"tag":"date","attrib":{"date":"2025-01-01"},"text":"January 1, 2025","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida81587ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formal complaint is substantiated in accordance with regulations prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A conspiracy to commit an offense specified in subparagraph (A) as punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s881"},"text":"section 881 of this title","children":[],"tail":" (article 81)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A solicitation to commit an offense specified in subparagraph (A) as punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s882"},"text":"section 882 of this title","children":[],"tail":" (article 82)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An attempt to commit an offense specified in subparagraph (A), (B), or (C) as punishable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s880"},"text":"section 880 of this title","children":[],"tail":" (article 80)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81587f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of exercise of authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81587f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment as covered offense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a special trial counsel exercises authority over an offense pursuant to paragraph (1) or (2), the offense over which the special trial counsel exercises authority shall be considered a covered offense for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81587f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s824a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Known or related offenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a special trial counsel exercises authority over an offense pursuant to subsection (c)(2)(A) or paragraph (1) or (2) of this subsection, the special trial counsel may exercise the authority of the special trial counsel under subparagraph (B) of subsection (c)(2) with respect to other offenses described in that subparagraph without regard to the date on which the other offenses occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81587f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s531/a"},"text":"Pub. L. 117–81, div. A, title V, § 531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1692"},"text":"135 Stat. 1692","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s542/a"},"text":"Pub. L. 117–263, div. A, title V, § 542(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2581"},"text":"136 Stat. 2581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s531/c/1"},"text":"Pub. L. 118–31, div. A, title V, § 531(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"}