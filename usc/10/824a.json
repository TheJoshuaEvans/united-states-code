ction 919a (article 119a), section 920 (article 120), section 920a (article 120a),” for “section 920 (article 120),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s562/2"},"text":"Pub. L. 118–159, § 562(2)","children":[],"tail":", (3), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s562/4/A"},"text":"Pub. L. 118–159, § 562(4)(A)","children":[],"tail":", inserted “or (2)” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s562/4/B"},"text":"Pub. L. 118–159, § 562(4)(B)","children":[],"tail":", substituted “subsection (c)(2)(A) or paragraph (1) or (2) of this subsection” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s542/a/1"},"text":"Pub. L. 117–263, § 542(a)(1)","children":[],"tail":", substituted “Subject to paragraph (5)” for “Subject to paragraph (4)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s542/a/2"},"text":"Pub. L. 117–263, § 542(a)(2)","children":[],"tail":", substituted “an authorized rehearing” for “an ordered rehearing”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81587f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81587f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" effective immediately after amendment by part 1 of subtitle D of title V of "},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s531/e"},"text":"section 531(e) of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s816"},"text":"section 816 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81587fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s542/b"},"text":"Pub. L. 117–263, div. A, title V, § 542(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2581"},"text":"136 Stat. 2581","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tV/s542/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect immediately after the coming into effect of the amendments made by section 531 of the National Defense Authorization Act for Fiscal Year 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/135/1692"},"text":"135 Stat. 1692","children":[],"tail":") [enacting this section] as provided in section 539C of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida81587fb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is two years after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", and applicable with respect to offenses that occur after that date, with provisions for delayed effect and applicability if regulations are not prescribed by the President before the date that is two years after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s539C"},"text":"section 539C of Pub. L. 117–81","children":[],"tail":", set out as an Effective Date of 2021 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida81587fc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Residual Prosecutorial Duties and Other Judicial Functions of Convening Authorities in Covered Cases","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s541/c"},"text":"Pub. L. 117–263, div. A, title V, § 541(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2580"},"text":"136 Stat. 2580","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tV/s541/c"},"text":"“The President shall prescribe regulations to ensure that residual prosecutorial duties and other judicial functions of convening authorities, including granting immunity, ordering depositions, and hiring experts, with respect to charges and specifications over which a special trial counsel exercises authority pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s824a"},"text":"section 824a of title 10","children":[],"tail":", United States Code (article 24a of the Uniform Code of Military Justice) (as added by section 531 of the National Defense Authorization Act for Fiscal Year 2022 ("},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/135/1692"},"text":"135 Stat. 1692","children":[],"tail":")), are transferred to the military judge, the special trial counsel, or other authority as appropriate in such cases by no later than the effective date established in section 539C of the National Defense Authorization Act for Fiscal Year 2022 ("},{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Public Law 117–81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"10 U.S.C. 801","children":[],"tail":" note), in consideration of due process for all parties involved in such a case.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
