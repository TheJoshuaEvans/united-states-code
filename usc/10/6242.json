{"tag":"section","attrib":{"id":"idaac90eb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242"},"text":null,"children":[{"tag":"num","attrib":{"value":"6242"},"text":"§ 6242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whistleblower protection program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaac90eb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Energy shall establish a program to ensure that covered individuals may not be discharged, demoted, or otherwise discriminated against as a reprisal for making protected disclosures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90eb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a covered individual is an individual who is an employee of the Department of Energy, or of a contractor of the Department, who is engaged in the defense activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90eb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protected Disclosures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a protected disclosure is a disclosure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90eb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made by a covered individual who takes appropriate steps to protect the security of the information in accordance with guidance provided under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90eba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made to a person or entity specified in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ebb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" of classified or other information that the covered individual reasonably believes to provide direct and specific evidence of any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90ebc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A violation of law or Federal regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90ebd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Gross mismanagement, a gross waste of funds, or abuse of authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90ebe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A false statement to Congress on an issue of material fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ebf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons and Entities to Which Disclosures May Be Made","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person or entity specified in this subsection is any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ec0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of a committee of Congress having primary responsibility for oversight of the department, agency, or element of the Government to which the disclosed information relates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ec1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of Congress who is a staff member of such a committee and has an appropriate security clearance for access to information of the type disclosed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ec2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Inspector General of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ec3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ec4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other element of the Government designated by the Secretary as authorized to receive information of the type disclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ec5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Official Capacity of Persons to Whom Information Is Disclosed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of, or an employee of Congress who is a staff member of, a committee of Congress specified in subsection (d) who receives a protected disclosure under this section does so in that member or employee’s official capacity as such a member or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ec6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance and Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Inspector General of the Department of Energy, shall provide assistance and guidance to each covered individual who seeks to make a protected disclosure under this section. Such assistance and guidance shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ec7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying the persons or entities under subsection (d) to which that disclosure may be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ec8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advising that individual regarding the steps to be taken to protect the security of the information to be disclosed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ec9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taking appropriate actions to protect the identity of that individual throughout that disclosure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90eca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taking appropriate actions to coordinate that disclosure with any other Federal agency or agencies that originated the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ecb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to ensure the security of any information disclosed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ecc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Covered Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall notify each covered individual of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ecd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rights of that individual under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ece-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assistance and guidance provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ecf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the individual has a responsibility to obtain that assistance and guidance before seeking to make a protected disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ed0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaint by Covered Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a covered individual believes that that individual has been discharged, demoted, or otherwise discriminated against as a reprisal for making a protected disclosure under this section, the individual may submit a complaint relating to such matter to the Director of the Office of Hearings and Appeals of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ed1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigation by Office of Hearings and Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ed2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each complaint submitted under subsection (i), the Director of the Office of Hearings and Appeals shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90ed3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether or not the complaint is frivolous; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90ed4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Director determines the complaint is not frivolous, conduct an investigation of the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ed5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall submit a report on each investigation undertaken under paragraph (1)(B) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90ed6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual who submitted the complaint on which the investigation is based;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90ed7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractor concerned, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90ed8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ed9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedial Action","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90eda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the Secretary determines that a covered individual has been discharged, demoted, or otherwise discriminated against as a reprisal for making a protected disclosure under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90edb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Department employee, take appropriate actions to abate the action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90edc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contractor employee, order the contractor concerned to take appropriate actions to abate the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90edd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaac90ede-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a contractor fails to comply with an order issued under paragraph (1)(B), the Secretary may file an action for enforcement of the order in the appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaac90edf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any action brought under subparagraph (A), the court may grant appropriate relief, including injunctive relief and compensatory and exemplary damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ee0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The protections provided by this section are independent of, and not subject to any limitations that may be provided in, the Whistleblower Protection Act of 1989 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12"},"text":"Public Law 101–12","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/103/16"},"text":"103 Stat. 16","children":[],"tail":") or any other law that may provide protection for disclosures of information by employees of the Department of Energy or of a contractor of the Department."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaac90ee1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac90ee2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the commencement of each fiscal year, the Director shall submit to the Committee on Armed Services of the Senate and the Committee on Armed Services of the House of Representatives a report on the investigations undertaken under subsection (j)(1)(B) during the preceding fiscal year, including a summary of the results of each such investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac90ee3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6242/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report under paragraph (1) may not identify or otherwise provide any information about an individual submitting a complaint under this section without the consent of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac90ee4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1413"},"text":"139 Stat. 1413","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac90ee5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac90ee6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaac90ee7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Whistleblower Protection Act of 1989, referred to in subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), is "},{"tag":"ref","attrib":{"href":"/us/pl/101/12"},"text":"Pub. L. 101–12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/16"},"text":"103 Stat. 16","children":[],"tail":", which enacted subchapters II (§ 1211 et seq.) and III (§ 1221 et seq.) of chapter 12 and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3352"},"text":"section 3352 of Title 5","children":[],"tail":", Government Organization and Employees, amended sections 1201 to 1206, 1209, 1211, 2302, 2303, 3393, 7502, 7512, 7521, 7542, 7701, and 7703 of Title 5 and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4139"},"text":"section 4139 of Title 22","children":[],"tail":", Foreign Relations and Intercourse, repealed sections 1207 and 1208 of Title 5, and enacted provisions set out as notes under sections 1201, 1211, and 5509 of Title 5. For complete classification of this Act to the Code, see Short Title of 1989 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1201"},"text":"section 1201 of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac90ee8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":nu