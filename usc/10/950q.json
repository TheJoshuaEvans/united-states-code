{"tag":"section","attrib":{"id":"ida83bacfb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950q"},"text":null,"children":[{"tag":"num","attrib":{"value":"950q"},"text":"§ 950q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person punishable under this chapter who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83bacfc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950q/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits an offense punishable by this chapter, or aids, abets, counsels, commands, or procures its commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83bacfd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950q/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes an act to be done which if directly performed by him would be punishable by this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83bacfe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s950q/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a superior commander who, with regard to acts punishable by this chapter, knew, had reason to know, or should have known, that a subordinate was about to commit such acts or had done so and who failed to take the necessary and reasonable measures to prevent such acts or to punish the perpetrators thereof,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is a principal.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83bacff-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2606"},"text":"123 Stat. 2606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83bad00-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83bad01-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida83bad02-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 950q, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2624"},"text":"120 Stat. 2624","children":[],"tail":", related to principals, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
