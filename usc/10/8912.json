l,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7861","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:44 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18/s304"},"text":"June 10, 1921, ch. 18, § 304","children":[],"tail":" (1st par. 1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/24"},"text":"42 Stat. 24","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:104.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 284; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1875-02-18/ch80/s1"},"text":"Feb. 18, 1875, ch. 80, § 1","children":[],"tail":" (4th complete par. on p. 317), "},{"tag":"html:a","attrib":{"href":"/us/stat/18/317"},"text":"18 Stat. 317","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “naval” is substituted for “belonging to the Navy of the United States” to eliminate unnecessary words. The words “Secretary of the Navy” are substituted for “Paymaster General of the Navy” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1894-03-29/s1"},"text":"section 1 of the Act of March 29, 1894","children":[],"tail":" (ch. 49, "},{"tag":"ref","attrib":{"href":"/us/stat/28/47"},"text":"28 Stat. 47","children":[],"tail":"), and 10:5061. The words “the account of the paymaster” are substituted for “him” for clarity. The words “such portion of the”, “on their books”, and “of a public vessel” are omitted as surplus. The words “free of” are substituted for “fully exonerated by such credit from all” to eliminate unnecessary words. The words “so proved to have been captured or lost” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab55be42-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8912, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/549"},"text":"70A Stat. 549","children":[],"tail":", permitted Secretary of Air Force, upon officer’s request, to retire an Air Force nurse, or a woman medical specialist, of Regular Air Force, who has at least 20 years of service computed under former "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8928"},"text":"section 8928 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/85/155/tIV/s401/1"},"text":"Pub. L. 85–155, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-21"},"text":"Aug. 21, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/390"},"text":"71 Stat. 390","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id