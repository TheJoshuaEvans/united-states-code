{"tag":"section","attrib":{"id":"ida7a7d189-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s349"},"text":null,"children":[{"tag":"num","attrib":{"value":"349"},"text":"§ 349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inter-American Air Forces Academy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d18a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may operate the Air Force education and training facility known as the Inter-American Air Forces Academy for the purpose of providing military education and training to military personnel of Central and South American countries, Caribbean countries, and other countries eligible for assistance under chapter 5 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2347"},"text":"22 U.S.C. 2347","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d18b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d18c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s349/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence of secretary of state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Military personnel of a foreign country may be provided education and training under this section only with the concurrence of the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d18d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s349/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance otherwise prohibited by law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Education and training may not be provided under this section to the military personnel of any country that is otherwise prohibited from receiving such type of assistance under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d18e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s349/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The fixed costs of operating and maintaining the Inter-American Air Forces Academy may be paid from funds available for operation and maintenance of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d18f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s330/a"},"text":"Pub. L. 101–510, div. A, title III, § 330(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1535"},"text":"104 Stat. 1535","children":[],"tail":", § 9415; renumbered § 349 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/j"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2508"},"text":"130 Stat. 2508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a7d190-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a7d191-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7a7d192-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 5 of part II of such Act is classified generally to part V of subchapter II (§ 2347 et seq.) of chapter 32 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a7d193-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/j/1"},"text":"Pub. L. 114–328, § 1241(j)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9415"},"text":"section 9415 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1241/j/2"},"text":"Pub. L. 114–328, § 1241(j)(2)","children":[],"tail":", added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
