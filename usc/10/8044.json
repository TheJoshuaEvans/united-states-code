{"tag":"section","attrib":{"id":"idab0973c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044"},"text":null,"children":[{"tag":"num","attrib":{"value":"8044"},"text":"§ 8044.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Commandant of the Marine Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0973c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is an Assistant Commandant of the Marine Corps, appointed by the President, by and with the advice and consent of the Senate, from officers on the active-duty list of the Marine Corps not restricted in the performance of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0973c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Commandant of the Marine Corps, while so serving, has the grade of general without vacating his permanent grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0973ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Commandant has such authority and duties with respect to the Marine Corps as the Commandant, with the approval of the Secretary of the Navy, may delegate to or prescribe for him. Orders issued by the Assistant Commandant in performing such duties have the same effect as those issued by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0973cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When there is a vacancy in the office of Commandant of the Marine Corps, or during the absence or disability of the Commandant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab0973cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Commandant of the Marine Corps shall perform the duties of the Commandant until a successor is appointed or the absence or disability ceases; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab0973cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8044/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is a vacancy in the office of the Assistant Commandant of the Marine Corps or the Assistant Commandant is absent or disabled, unless the President directs otherwise, the most senior officer of the Marine Corps in the Headquarters, Marine Corps, who is not absent or disabled and who is not restricted in performance of duty shall perform the duties of the Commandant until a successor to the Commandant or the Assistant Commandant is appointed or until the absence or disability of the Commandant or Assistant Commandant ceases, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0973ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s513/b"},"text":"Pub. L. 99–433, title V, § 513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1054"},"text":"100 Stat. 1054","children":[],"tail":", § 5044; renumbered § 8044, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/a/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1834"},"text":"132 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab0973cf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab0973d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab0973d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5202"},"text":"section 5202 of this title","children":[],"tail":" prior to enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab0973d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5044"},"text":"section 5044 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab0973d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab0973d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
