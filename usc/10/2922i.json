{"tag":"section","attrib":{"id":"ida9fe44fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2922i"},"text":"§ 2922i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear contracts: purchase of electricity from renewable energy sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9fe44fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiyear Contracts Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), the Secretary of Defense may enter into a contract for a period not to exceed 10 years for the purchase of electricity from sources of renewable energy, as that term is defined in section 203(b)(2) of the Energy Policy Act of 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15852/b/2"},"text":"42 U.S.C. 15852(b)(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fe44fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Contracts for Periods in Excess of Five Years","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may exercise the authority in subsection (a) to enter into a contract for a period in excess of five years only if the Secretary determines, on the basis of a business case analysis prepared by the Department of Defense, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9fe44fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed purchase of electricity under such contract is cost effective for the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9fe44fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it would not be possible to purchase electricity from the source in an economical manner without the use of a contract for a period in excess of five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9fe44ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2922i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Multiyear Contracting Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to preclude the Department of Defense from using other multiyear contracting authority of the Department to purchase renewable energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9fe4500-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tVIII/s828/a"},"text":"Pub. L. 110–181, div. A, title VIII, § 828(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/229"},"text":"122 Stat. 229","children":[],"tail":", § 2410q; renumbered § 2922i, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1879/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1879(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4293"},"text":"134 Stat. 4293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9fe4501-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9fe4502-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida9fe4503-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2410q"},"text":"section 2410q of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9fe4504-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida9fe4505-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
