{"tag":"section","attrib":{"id":"ida9cea916-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2773b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2773b"},"text":"§ 2773b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parking of funds: prohibition; penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cea917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2773b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer or employee of the Department of Defense may not direct the designation of funds for a particular purpose in the budget of the President, as submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", or the supporting documents of the Department of Defense component of such budget, with the knowledge or intent that such funds, if made available to the Department, will not be used for the purpose for which they are designated."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cea918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2773b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The direction of the designation of funds in violation of the prohibition in subsection (a) shall be treated for purposes of chapter 13 of title 31 as a violation of section 1341(a)(1)(A) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cea919-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1053/a/1"},"text":"Pub. L. 109–364, div. A, title X, § 1053(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2396"},"text":"120 Stat. 2396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cea91a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cea91b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9cea91c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tX/s1053/b"},"text":"Pub. L. 109–364, div. A, title X, § 1053(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2396"},"text":"120 Stat. 2396","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/364/dA/tX/s1053/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) [enacting this section] shall take effect on the date that is 31 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of certain policies and regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":"], the Secretary of Defense shall modify the policies and regulations of the Department of Defense regarding the preparation and submittal to Congress of budget materials for the Department of Defense to take into account "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2773b"},"text":"section 2773b of title 10","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
