{"tag":"section","attrib":{"id":"idab2d27aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8470a"},"text":"§ 8470a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent professors: retirement for years of service; authority for deferral","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2d27ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retirement for Years of Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2d27ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), an officer of the Navy or Marine Corps serving as a permanent professor at the Naval Academy in the grade of commander or lieutenant colonel who is not on a list of officers recommended for promotion to the grade of captain or colonel, as the case may be, shall, if not earlier retired, be retired on the first day of the month after the month in which the officer completes 28 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), an officer of the Navy or Marine Corps serving as a permanent professor at the Naval Academy in the grade of captain or colonel who is not on a list of officers recommended for promotion to the grade of rear admiral (lower half) or brigadier general, as the case may be, shall, if not earlier retired, be retired on the first day of the month after the month in which the officer completes 30 years of active commissioned service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation on Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2d27af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer subject to retirement under subsection (a) may have his retirement deferred and be continued on active duty by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1252"},"text":"section 1252 of this title","children":[],"tail":", the Secretary of the Navy shall determine the period of any continuation on active duty under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility for Promotion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A permanent professor at the Naval Academy in the grade of commander or lieutenant colonel who is continued on active duty as a permanent professor under subsection (b) remains eligible for consideration for promotion to the grade of captain or colonel, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2d27b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retired Grade and Retired Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each officer retired under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2d27b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise entitled to a higher grade, shall be retired in the grade determined under section 1370 ","children":[{"tag":"ref","attrib":{"idref":"fn002164"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002164"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2d27b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8470a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to retired pay computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8333"},"text":"section 8333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":