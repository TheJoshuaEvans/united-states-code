{"tag":"section","attrib":{"id":"ida9e8e874-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2866a"},"text":"§ 2866a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk-based approach to water management and water security at military installations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9e8e875-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e8e876-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall adopt a risk-based approach to water management and water security for each military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e877-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In implementing paragraph (1), the Secretary shall prioritize those military installations that the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e878-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are experiencing the greatest risks to water management and water security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e879-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" face, or potentially face, the most severe adverse effects on mission assurance because of such risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e87a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determinations under paragraph (2) shall be made on the basis of the water management and water security assessments made by the Secretary concerned under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e87b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Water Management and Water Security Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e8e87c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense, in coordination with each Secretary of a military department, shall develop a methodology to assess, for each military installation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e87d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risks to water management and water security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e87e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adverse effects on mission assurance because of such risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e87f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such methodology shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e880-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An evaluation of all water sources available to a military installation, disaggregated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e881-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total available water volume;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e882-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated potable water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e883-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treated nonpotable water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e884-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of relevant water supply connections for a military installation, including the number, type, water flow rate, seasonal variability, and the extent of competition for each such connection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e885-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A calculation of the total water requirement of a military installation that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e886-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an identification of the water usage by each tenant command located on the military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e887-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes the water uses that comprise such total water requirement, disaggregated by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida9e8e888-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drinking water uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida9e8e889-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nonpotable water uses, including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"ida9e8e88a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"ida9e8e88b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigation groundskeeping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"ida9e8e88c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wash water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"ida9e8e88d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/C/ii/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other industrial and agricultural uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e88e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the age, condition, and jurisdictional control of water infrastructure serving a military installation, including an estimate of the percentage of water lost due to water infrastructure that is in poor or failing condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e88f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An evaluation of water security risks that could have an adverse effect on mission assurance for a military installation, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e890-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the military installation is located in a drought-prone region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e891-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreasing water levels or sources that supply water to the military installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e892-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effects of new defense water uses on the total water requirement of the military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e893-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increases to the demand for water that result from nondefense or defense-adjacent requirements and that could affect—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida9e8e894-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply of water available for use by the military installation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida9e8e895-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of such water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida9e8e896-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/E/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legal rights to use of such water by the military installation, such as water rights disputes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e897-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the capacity of the water supply of a military installation to withstand or quickly recover from water constraints, and the overall health of the aquifer basin of which the water supply is a part, including the robustness of the resource, redundancy, and ability to recover from disruption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e898-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An evaluation of existing water metering and water consumption at a military installation, disaggregated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e899-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by type of activity, including training, maintenance, medical, housing, and grounds maintenance and landscaping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e89a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by fluctuations in consumption, including peak consumption by quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e89b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination of the appropriate frequency for reassessment of military installations with the highest water security risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e89c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, in coordination with each Secretary of a military department, shall update the methodology under paragraph (1) not less frequently than once every ten years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e89d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reassessment of Water Security Risk","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall update assessments of the military installations with the highest water security risk not less frequently than as determined under subsection (b)(2)(H).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e89e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mitigation of Highest Water Security Risk Installations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e8e89f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each Secretary of a military department shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e8a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the three military installations under the jurisdiction of the Secretary with the highest water security risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop, for each military installation identified, a plan of action and milestones to address—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e8a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risks to water security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e8a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adverse effects on mission assurance because of such risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e8a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such plan of action shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e8a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of each risk and the effect on the capacity of the military installation and mission assurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A list of the factors contributing to the risk, disaggregated by risks originating from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e8a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic area under the control of the military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e8a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic area not under the control of the military installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for implementing installation-level water metering to ensure more accurate assessments of demand for water at the military installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e8ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of planned future missions and tenant commands on the demand for water at the military installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e8ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corresponding requirements for water infrastructure serving the military installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of infrastructure projects to mitigate loss of available water supply to leakage, including new construction, recapitalization, required maintenance, and modernization of existing infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cost-benefit analysis of using “no dig” technologies to mitigate infrastructure degradation that leads to water loss.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e8af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation of Installations for Nonpotable Water Reuse","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e8e8b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall evaluate each military installation identified under subsection (d) to determine the potential to mitigate risks to water security for such installation through the reuse of nonpotable water for nondrinking water uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e8b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such evaluation shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e8b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of alternative water sources to offset use of freshwater, including water recycling and harvested rainwater for use as nonpotable water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the feasibility of incorporating, when practicable, water-efficient technologies and systems to minimize water consumption and wastewater discharge on the installation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An evaluation of the practicality of implementing water reuse systems and other water-saving infrastructure into new construction in water-constrained areas, as determined pursuant to the applicable water management and security assessment under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e8b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Effective Landscaping Management Practices","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e8e8b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall, to the maximum extent practicable, implement, at each military installation identified under subsection (d), landscaping management practices that mitigate risks to water management and water security and enhance mission assurance by enabling greater quantities of water availability for operational, training, and maintenance requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e8b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For military installations located in arid or semi-arid regions, such landscaping management practices shall, to the extent practicable, include practices that avoid the cost of irrigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e8b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, each Secretary of a military department shall institute landscaping management practices that include plants native to, or appropriate for, the region in which the installation is located and native grass and plants that decrease water consumption requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e8b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9e8e8ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the date of the enactment of this section, the Secretary of Defense shall provide to the Committees of the Armed Services of the House of Representatives and the Senate a briefing that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e8bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification, in ranked order, of the military installations identified under subsection (d) with the highest water security risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the schedule for developing each plan of action required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9e8e8bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than one year after the date of the enactment of this section, and annually thereafter not later than the date of President’s budget for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary of Defense shall provide to the Committees of the Armed Services of the House of Representatives and the Senate a briefing that includes, with respect to the period covered by the briefing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9e8e8be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an update on the progress of the Secretary concerned toward completing the water security assessment required by subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated cost estimates for infrastructure projects to mitigate loss of available water supply to leakage identified pursuant to subsection (d)(1)(E); ","children":[{"tag":"ref","attrib":{"idref":"fn002099"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (d)(2)(E);”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9e8e8c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9e8e8c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any agreement between a Secretary of a military department and the head of a non-Department of Defense entity with respect to property under the jurisdiction of such Secretary that may affect—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida9e8e8c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply of water available to a military installation under the jurisdiction of such Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida9e8e8c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for water of such installation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9e8e8c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any change to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ida9e8e8c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water supply of a military installation under the jurisdiction such Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ida9e8e8c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/g/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demand for water of such military installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9e8e8c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2866a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to require the repetition or replacement of any prior water assessment or evaluation conducted before the date of the enactment of section 2827 of the Military Construction Authorization Act for Fiscal Year 2021 (division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Public Law 118–159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2866"},"text":"10 U.S.C. 2866","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn002100"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" that is accurate and reflects current mission requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9e8e8c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2804/a"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1294"},"text":"139 Stat. 1294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9e8e8c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9e8e8ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida9e8e8cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (g), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved on "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2827 of the Military Construction Authorization Act for Fiscal Year 2021, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/s2827"},"text":"section 2827 of div. B of Pub. L. 116–283","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2866"},"text":"section 2866 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dB/tXXVIII/s2804/b"},"text":"Pub. L. 119–60, div. B, title XXVIII, § 2804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1297"},"text":"139 Stat. 1297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
