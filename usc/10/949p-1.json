{"tag":"section","attrib":{"id":"ida8393bbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949p–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"949p–1"},"text":"§ 949p–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of classified information: applicability of subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8393bbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949p–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Classified Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Classified information shall be protected and is privileged from disclosure if disclosure would be detrimental to the national security. Under no circumstances may a military judge order the release of classified information to any person not authorized to receive such information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393bc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949p–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any information admitted into evidence pursuant to any rule, procedure, or order by the military judge shall be provided to the accused.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393bc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949p–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Declassification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Trial counsel shall work with the original classification authorities for evidence that may be used at trial to ensure that such evidence is declassified to the maximum extent possible, consistent with the requirements of national security. A decision not to declassify evidence under this section shall not be subject to review by a military commission or upon appeal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8393bc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s949p–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The judicial construction of the Classified Information Procedures Act (18 U.S.C. App.) shall be authoritative in the interpretation of this subchapter, except to the extent that such construction is inconsistent with the specific requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8393bc3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2590"},"text":"123 Stat. 2590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8393bc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8393bc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida8393bc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Classified Information Procedures Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/456"},"text":"Pub. L. 96–456","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2025"},"text":"94 Stat. 2025","children":[],"tail":", which is set out in the Appendix to Title 18, Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
