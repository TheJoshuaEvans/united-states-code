viso), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/1056"},"text":"40 Stat. 1056","children":[],"tail":"; renumbered § 8 and amended "},{"tag":"html:a","attrib":{"href":"/us/act/1942-08-07/ch551/s1"},"text":"Aug. 7, 1942, ch. 551, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/744"},"text":"56 Stat. 744","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “the appropriations for the pay of the Navy or the Marine Corps, as appropriate”, are substituted for the words “the appropriation ‘Pay, subsistence, and transportation of naval personnel’ ”, to identify by a general description, rather than by the specific appropriation title, the appropriation authorized to be used. Specific appropriation titles vary from one appropriation act to the next. The permanent authority contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s359"},"text":"34 U.S.C. 359","children":[],"tail":" for the Secretary of the Navy to use appropriations available for the pay of the Navy and the Marine Corps is not affected by a change in the titles of those appropriations nor is it affected by a specific authorization in an appropriation act to use, during the life of the act, a different type of appropriation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1a160d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab1a160e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8304, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"