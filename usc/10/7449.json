{"tag":"section","attrib":{"id":"idaaf17e3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7449"},"text":null,"children":[{"tag":"num","attrib":{"value":"7449"},"text":"§ 7449.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cadets: organization of Corps; service; instruction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf17e3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7449/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corps of Cadets shall be divided into companies, as directed by the Superintendent, for the purpose of military instruction. Each company shall be commanded by a commissioned officer of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf17e3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7449/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cadet shall perform duties at such places and of such type as the President may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf17e40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7449/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The course of instruction at the Academy is four years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf17e41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7449/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army shall so arrange the course of studies at the Academy that cadets are not required to pursue their studies on Sunday.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf17e42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7449/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Corps of Cadets shall be trained in the duties of members of the Army, shall be encamped at least three months in each year, and shall be trained in all duties incident to a camp.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf17e43-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/243"},"text":"70A Stat. 243","children":[],"tail":", § 4349; renumbered § 7449, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf17e44-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idaaf17e45-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idaaf17e46-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p