{"tag":"section","attrib":{"id":"ida762b2a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b"},"text":null,"children":[{"tag":"num","attrib":{"value":"133b"},"text":"§ 133b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Defense for Acquisition and Sustainment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida762b2a7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an Under Secretary of Defense for Acquisition and Sustainment, appointed from civilian life by the President, by and with the advice and consent of the Senate. The Under Secretary shall be appointed from among persons who have an extensive system development, engineering, production, or management background and experience with managing complex programs. A person may not be appointed as Under Secretary within seven years after relief from active duty as a commissioned officer of a regular component of an armed force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b2a8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the authority, direction, and control of the Secretary of Defense, the Under Secretary shall perform such duties and exercise such powers as the Secretary may prescribe, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida762b2a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the chief acquisition and sustainment officer of the Department of Defense with the mission of delivers end-user capabilities with speed and innovation to counter threats and cost-effectively sustain the military advantage of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing policies on, and supervising, all elements of the Department relating to acquisition (including system design, development, appropriate prototyping activities, and production, and procurement of goods and services) and sustainment (including logistics, maintenance, and materiel readiness);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing policies for access to, and maintenance of, the defense industrial base and materials critical to national security, and policies on contract administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing policies for, and providing oversight, guidance, and coordination with respect to, the nuclear command, control, and communications system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serving as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida762b2ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal advisor to the Secretary on acquisition and sustainment in the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the senior procurement executive for the Department for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1702/c"},"text":"section 1702(c) of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Acquisition Executive for purposes of regulations and procedures of the Department providing for a Defense Acquisition Executive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2b1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chairman of the Nuclear Weapons Council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s179"},"text":"section 179 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" co-chairman of the Council on Oversight of the National Leadership Command, Control, and Communications System established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s171a"},"text":"section 171a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" overseeing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida762b2b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sustainment and modernization of United States nuclear forces, including the nuclear command, control, and communications system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military department and Defense Agency programs to develop defenses against chemical and biological weapons and capabilities to counter weapons of mass destruction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority to direct the Secretaries of the military departments and the heads of all other elements of the Department with regard to matters for which the Under Secretary has responsibility, except that the Under Secretary shall exercise advisory authority over service acquisition programs for which the service acquisition executive is the milestone decision authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent directed by the Secretary, exercising overall supervision of all personnel (civilian and military) in the Office of the Secretary of Defense with regard to matters for which the Under Secretary has responsibility, unless otherwise provided by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advising the Secretary on all aspects of acquisition and sustainment relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida762b2b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defense acquisition system, in accordance with the objectives established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" core logistics capabilities (as described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2464"},"text":"section 2464 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida762b2bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national technology and industrial base (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4801"},"text":"section 4801 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the Secretary on, establishing policies on, and supervising, the activities of the Department relating to international cooperation and agreements regarding industrial base collaboration and coordination, including cooperative development and co-production, reciprocal production, exportability considerations, supply chain integration, security of supply chain agreements, and acquisition and cross-service agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida762b2bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in Department of Defense.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida762b2be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in matters of responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With regard to all matters for which the Under Secretary has responsibility by the direction of the Secretary of Defense or by law, the Under Secretary takes precedence in the Department of Defense after the Secretary, the Deputy Secretary of Defense, and the Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida762b2bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s133b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Precedence in other matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With regard to all matters other than the matters for which the Under Secretary has responsibility by the direction of the Secretary or by law, the Under Secretary takes precedence in the Department of Defense after the Secretary, the Deputy Secretary, the Under Secretary of Defense for Research and Engineering, and the Secretaries of the military departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida762b2c0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s901/b"},"text":"Pub. L. 114–328, div. A, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2340"},"text":"130 Stat. 2340","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX"},"text":"Pub. L. 115–91, div. A, title IX","children":[],"tail":", §§ 902, 910(c)(3), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1511"},"text":"131 Stat. 1511","children":[],"tail":", 1518; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/92"},"text":"Pub. L. 116–92, div. A, title IX, § 902(92)","children":[],"tail":", title XVI, § 1662(a), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1554"},"text":"133 Stat. 1554","children":[],"tail":", 1772; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s811/a/2"},"text":"Pub. L. 116–283, div. A, title VIII, § 811(a)(2)","children":[],"tail":", title XVIII, § 1883(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3749"},"text":"134 Stat. 3749","children":[],"tail":", 4294; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s901/a/2"},"text":"Pub. L. 118–31, div. A, title IX, § 901(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/354"},"text":"137 Stat. 354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIX/s903/a/1"},"text":"Pub. L. 118–159, div. A, title IX, § 903(a)(1)","children":[],"tail":", title XVI, § 1621(b), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2026"},"text":"138 Stat. 2026","children":[],"tail":", 2171; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVIII/s1801/a/2/A"},"text":"Pub. L. 119–60, div. A, title XVIII, § 1801(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1221"},"text":"139 Stat. 1221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida762b2c1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida762b2c2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida762b2c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 133b was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s138a"},"text":"section 138a of this title","children":[],"tail":" and was subsequently repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 133b was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s118"},"text":"section 118 of this title","children":[],"tail":" and was subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida762b2c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/a/2/A/i"},"text":"Pub. L. 119–60, § 1801(a)(2)(A)(i)","children":[],"tail":", substituted “delivers end-user capabilities with speed and innovation to counter threats and cost-effectively sustain the military advantage of the United States” for “delivering and sustaining timely, cost-effective capabilities for the armed forces (and the Department)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1801/a/2/A/ii"},"text":"Pub. L. 119–60, § 1801(a)(2)(A)(ii)","children":[],"tail":", substituted “the defense acquisition system, in accordance with the objectives established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3102"},"text":"section 3102 of this title","children":[],"tail":"” for “defense acquisition programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(5)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1621/b/1"},"text":"Pub. L. 118–159, § 1621(b)(1)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1621/b/2"},"text":"Pub. L. 118–159, § 1621(b)(2)","children":[],"tail":", amended par. (6) generally. Prior to amendment, par. (6) read as follows: “overseeing the modernization of nuclear forces, including the nuclear command, control, and communications system, and the development of capabilities to counter weapons of mass destruction, and serving as the chairman of the Nuclear Weapons Council and the co-chairman of the Council on Oversight of the National Leadership Command, Control, and Communications System;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s903/a/1"},"text":"Pub. L. 118–159, § 903(a)(1)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s901/a/2/A"},"text":"Pub. L. 118–31, § 901(a)(2)(A)","children":[],"tail":", struck out “the Chief Management Officer of the Department of Defense,” after “the Deputy Secretary of Defense,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s901/a/2/B"},"text":"Pub. L. 118–31, § 901(a)(2)(B)","children":[],"tail":", struck out “the Chief Management Officer,” after “the Deputy Secretary,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s811/a/2"},"text":"Pub. L. 116–283, § 811(a)(2)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"Pub. L. 116–283, § 1883(b)(2)","children":[],"tail":", substituted “section 4801” for “section 2500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s902/92"},"text":"Pub. L. 116–92, § 902(92)","children":[],"tail":", inserted “appropriate prototyping activities,” after “development,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1662/a"},"text":"Pub. L. 116–92, § 1662(a)","children":[],"tail":", added par. (4), redesignated former pars. (4) to (7) as (5) to (8), respectively, and in par. (6) inserted “, including the nuclear command, control, and communications system,” after “modernization of nuclear forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s902"},"text":"Pub. L. 115–91, § 902","children":[],"tail":", substituted “advisory authority” for “supervisory authority”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s910/c/3/A"},"text":"Pub. L. 115–91, § 910(c)(3)(A)","children":[],"tail":", inserted “the Chief Management Officer of the Department of Defense,” after “the Deputy Secretary of Defense,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s910/c/3/B"},"text":"Pub. L. 115–91, § 910(c)(3)(B)","children":[],"tail":", inserted “the Chief Management Officer,” after “the Deputy Secretary,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida762b2c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida762b2c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1883/b/2"},"text":"section 1883(b)(2) of Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida762b2c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s902"},"text":"Pub. L. 115–91, div. A, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1511"},"text":"131 Stat. 1511","children":[],"tail":", provided that the amendment made by section 902 is effective "},{"tag":"date","attrib":{"date":"2018-02-01"},"text":"Feb. 1, 2018","children":[],"tail":", and immediately after the coming into effect of the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s901/b"},"text":"section 901(b) of Pub. L. 114–328","children":[],"tail":" (enacting this section)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tIX/s910/c"},"text":"Pub. L. 115–91, div. A, title IX, § 910(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1518"},"text":"131 Stat. 1518","children":[],"tail":", provided that the amendment made by section 910(c)(3) is effective on "},{"tag":"date","attrib":{"date":"2018-02-01"},"text":"Feb. 1, 2018","children":[],"tail":", and immediately after the coming into effect of the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s901"},"text":"section 901 of Pub. L. 114–328","children":[],"tail":" (see Tables for classification)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida762b2c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tIX/s901/b"},"text":"Pub. L. 114–328, div. A, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2339"},"text":"130 Stat. 2339","children":[],"tail":", provided that this section is effective on "},{"tag":"date","attrib":{"date":"2018-02-01"},"text":"Feb. 1, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida762b2c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidance Required","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tIX/s903/a/2"},"text":"Pub. L. 118–159, div. A, title IX, § 903(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2026"},"text":"138 Stat. 2026","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tIX/s903/a/2"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2025-07-01"},"text":"July 1, 2025","children":[],"tail":", the Secretary of Defense shall update relevant policies and guidance related to the duties of the Under Secretary of Defense for Acquisition and Sustainment prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s133b/b/10"},"text":"section 133b(b)(10) of title 10","children":[],"tail":", United States Code, as added by paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida762b2ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Defense Support for Requirements of White House Military Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXVI/s1672/b"},"text":"Pub. L. 117–263, div. A, title XVI, § 1672(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2959"},"text":"136 Stat. 2959","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tXVI/s1672/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Portfolio Manager","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, acting through the Under Secretary of Defense for Acquisition and Sustainment, shall designate a senior official to coordinate and advocate for the portfolio of national level programs of the Department of Defense that are either or both—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in direct support of requirements from the White House Military Office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operationally relevant to the mission areas of the White House Military Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accessibility of Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programmatic and budgetary information required to assess the efficacy of the national level programs covered by subsection (b) shall be provided to the senior official designated under such subsection by the following officials:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of each military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of Cost Assessment and Program Evaluation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
