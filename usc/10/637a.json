{"tag":"section","attrib":{"id":"ida7f1ac9c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s637a"},"text":null,"children":[{"tag":"num","attrib":{"value":"637a"},"text":"§ 637a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation on active duty: officers in certain military specialties and career tracks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f1ac9d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s637a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the military department concerned may authorize an officer in a grade above grade O–2 to remain on active duty after the date otherwise provided for the separation or retirement of the officer in section 632, 633, 634, 635, or 636 of this title, as applicable, if the officer has a military occupational specialty, rating, or specialty code in a military specialty designated pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac9e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s637a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Specialties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Secretary of a military department shall designate the military specialties in which a military occupational specialty, rating, or specialty code, as applicable, assigned to members of the armed forces under the jurisdiction of such Secretary authorizes the members to be eligible for continuation on active duty as provided in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac9f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s637a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Continuation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An officer continued on active duty pursuant to this section shall, if not earlier retired, be retired on the first day of the month after the month in which the officer completes 40 years of active service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1aca0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s637a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries of the military departments shall carry out this section in accordance with regulations prescribed by the Secretary of Defense. The regulations shall specify the criteria to be used by the Secretaries of the military departments in designating military specialties for purposes of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f1aca1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s505/a/1"},"text":"Pub. L. 114–328, div. A, title V, § 505(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2107"},"text":"130 Stat. 2107","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s506"},"text":"Pub. L. 115–232, div. A, title V, § 506","children":[],"tail":", title X, § 1081(a)(8), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1743"},"text":"132 Stat. 1743","children":[],"tail":", 1983; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s504"},"text":"Pub. L. 116–92, div. A, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1345"},"text":"133 Stat. 1345","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f1aca2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f1aca3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f1aca4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “separation or” after “provided for the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s506"},"text":"Pub. L. 115–232, § 506","children":[],"tail":", substituted “grade O–2” for “grade O–4” and inserted “632,” before “633,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1081/a/8"},"text":"Pub. L. 115–232, § 1081(a)(8)","children":[],"tail":", substituted “specialties” for “specialities”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
