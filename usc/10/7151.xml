<section xmlns="http://xml.house.gov/schemas/uslm/1.0" xmlns:html="http://www.w3.org/1999/xhtml" style="-uslm-lc:I80" id="idaadc2230-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151"><num value="7151">§ 7151.</num><heading> Commissioned officer grades</heading>
<chapeau style="-uslm-lc:I11" class="indent0">The commissioned grades in the Regular Army are:</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2231-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/1"><num value="1">(1)</num><content> Major general.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2232-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/2"><num value="2">(2)</num><content> Brigadier general.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2233-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/3"><num value="3">(3)</num><content> Colonel.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2234-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/4"><num value="4">(4)</num><content> Lieutenant colonel.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2235-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/5"><num value="5">(5)</num><content> Major.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2236-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/6"><num value="6">(6)</num><content> Captain.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2237-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/7"><num value="7">(7)</num><content> First lieutenant.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idaadc2238-3a6f-11f1-a58a-d8db54b14ab5" identifier="/us/usc/t10/s7151/8"><num value="8">(8)</num><content> Second lieutenant.</content>
</paragraph>
<sourceCredit id="idaadc2239-3a6f-11f1-a58a-d8db54b14ab5">(<ref href="/us/act/1956-08-10/ch1041">Aug. 10, 1956, ch. 1041</ref>, <ref href="/us/stat/70A/181">70A Stat. 181</ref>, § 3281; renumbered § 7151, <ref href="/us/pl/115/232/dA/tVIII/s808/b/3">Pub. L. 115–232, div. A, title VIII, § 808(b)(3)</ref>, <date date="2018-08-13">Aug. 13, 2018</date>, <ref href="/us/stat/132/1838">132 Stat. 1838</ref>.)</sourceCredit>
