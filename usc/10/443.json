“foreign countries” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s921/a"},"text":"Pub. L. 112–239, § 921(a)","children":[],"tail":", substituted “foreign countries, regional organizations with defense or security components, and security alliances of which the United States is a member” for “foreign countries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/10"},"text":"Pub. L. 110–417, § 932(a)(10)","children":[],"tail":", (b)(2). See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/10"},"text":"Pub. L. 110–417, § 932(a)(10)","children":[],"tail":", (b)(2), amended subsec. (d) identically, substituting “Director of National Intelligence” for “Director of Central Intelligence” in heading and text. "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/10"},"text":"Pub. L. 110–417, § 932(a)(10)","children":[],"tail":", (b)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted semicolon for period after “denied funds”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bf9f1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7bf9f20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":", provided that the amendment made by section 1073(c)(10) is effective as of "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7bf9f21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
