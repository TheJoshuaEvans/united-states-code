{"tag":"section","attrib":{"id":"ida7bf9f13-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443"},"text":null,"children":[{"tag":"num","attrib":{"value":"443"},"text":"§ 443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imagery intelligence and geospatial information: support for foreign countries, regional organizations, and security alliances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bf9f14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Appropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the National Geospatial-Intelligence Agency may use appropriated funds available to the National Geospatial-Intelligence Agency to provide foreign countries, regional organizations with defense or security components, and security alliances of which the United States is a member with imagery intelligence and geospatial information support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds Other Than Appropriated Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may use funds other than appropriated funds to provide foreign countries with imagery intelligence and geospatial information support, notwithstanding provisions of law relating to the expenditure of funds of the United States, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bf9f16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no such funds may be expended, in whole or in part, by or for the benefit of the National Geospatial-Intelligence Agency for a purpose for which Congress had previously denied funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the sale of imagery intelligence or geospatial information items may be used only to purchase replacement items similar to the items that are sold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bf9f18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority provided by this subsection may not be used to acquire items or services for the principal benefit of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accommodation Procurements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority under this section may be exercised to conduct accommodation procurements on behalf of foreign countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bf9f1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s443/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Director of National Intelligence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Agency shall coordinate with the Director of National Intelligence any action under this section that involves imagery intelligence or intelligence products or involves providing support to an intelligence or security service of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bf9f1b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1112/a/2"},"text":"Pub. L. 104–201, div. A, title XI, § 1112(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2679"},"text":"110 Stat. 2679","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/7"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1900"},"text":"111 Stat. 1900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tIX/s921/d/2/A"},"text":"Pub. L. 108–136, div. A, title IX, § 921(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1568"},"text":"117 Stat. 1568","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tIX/s931/a/11"},"text":"Pub. L. 110–181, div. A, title IX, § 931(a)(11)","children":[],"tail":", (c)(1)(B), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "}