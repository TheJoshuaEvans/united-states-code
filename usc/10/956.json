{"tag":"section","attrib":{"id":"ida83df761-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s956"},"text":null,"children":[{"tag":"num","attrib":{"value":"956"},"text":"§ 956.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deserters, prisoners, members absent without leave: expenses and rewards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Funds appropriated to the Department of Defense may be used for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83df762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s956/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses for the apprehension and delivery of deserters, prisoners, and members absent without leave, including the payment of rewards, in an amount not to exceed $75, for the apprehension of any such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df763-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s956/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of prisoners confined in nonmilitary facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s956/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of a gratuity of not to exceed $25 to each prisoner upon release from confinement in a military or contract prison facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s956/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The issue of authorized articles to prisoners and other persons in military custody.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s956/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Secretary concerned may prescribe, expenses incident to the maintenance, pay, and allowances of prisoners of war, other persons in the custody of the Army, Navy, or Air Force whose status is determined by the Secretary concerned to be similar to prisoners of war, and persons detained in the custody of the Army, Navy, or Air Force pursuant to Presidential proclamation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida83df767-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1401/b/1"},"text":"Pub. L. 98–525, title XIV, § 1401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2614"},"text":"98 Stat. 2614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida83df768-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida83df769-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida83df76a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in pars. (1) to (5) of this secti