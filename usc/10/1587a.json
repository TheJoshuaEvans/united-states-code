{"tag":"section","attrib":{"id":"ida8fa690c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1587a"},"text":"§ 1587a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees of nonappropriated fund instrumentalities: senior executive pay levels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa690d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To achieve the objective stated in subsection (b), the Secretary of Defense may regulate the amount of total compensation that is provided for senior executives of nonappropriated fund instrumentalities who, for the fixing of pay by administrative action, are under the jurisdiction of the Secretary of Defense or the Secretary of a military department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa690e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay Parity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The objective of an action taken with respect to the compensation of senior executives under subsection (a) is to provide for parity between the total compensation provided for such senior executives and total compensation that is provided for Department of Defense employees in Senior Executive Service positions or other senior executive positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa690f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards of Comparability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (d), the Secretary of Defense shall prescribe the standards of comparison that are to apply in the making of the determinations necessary to achieve the objective stated in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6910-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Pay Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall apply subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":" in the regulation of compensation under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6911-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Pay Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may exercise the authority provided in subsection (a) without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5373"},"text":"section 5373 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6912-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa6913-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “compensation” includes rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6914-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1587a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Senior Executive Service position” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132"},"text":"section 3132 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa6915-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tXI/s1104/a"},"text":"Pub. L. 108–375, div. A, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2073"},"text":"118 Stat. 2073","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
