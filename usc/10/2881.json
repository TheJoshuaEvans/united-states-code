{"tag":"section","attrib":{"id":"ida9eda2a9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881"},"text":null,"children":[{"tag":"num","attrib":{"value":"2881"},"text":"§ 2881.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ancillary supporting facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9eda2aa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Acquire or Construct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any project for the acquisition or construction of military family housing units or military unaccompanied housing units under this subchapter may include the acquisition or construction of ancillary supporting facilities for the housing units concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9eda2ab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project referred to in subsection (a) may not include the acquisition or construction of an ancillary supporting facility (other than a child development center) if, as determined by the Secretary concerned, the facility is to be used for providing merchandise or services in direct competition with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9eda2ac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Army and Air Force Exchange Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda2ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Navy Exchange Service Command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda2ae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Marine Corps exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda2af-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Commissary Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9eda2b0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2881/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nonappropriated fund activity of the Department of Defense for the morale, welfare, and recreation of members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9eda2b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dB/tXXVIII/s2801/a/1"},"text":"Pub. L. 104–106, div. B, title XXVIII, § 2801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/548"},"text":"110 Stat. 548","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/1