{"tag":"section","attrib":{"id":"idaacdcac5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328"},"text":null,"children":[{"tag":"num","attrib":{"value":"6328"},"text":"§ 6328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-benefit analyses for competition of management and operating contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdcac6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings on Requests for Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 7 days after issuing a request for proposals for a contract to manage and operate a facility of the Administration, the Administrator shall brief the congressional defense committees on the preliminary assessment of the Administrator of the costs and benefits of the competition for the contract, including a preliminary assessment of the matters described in subsection (c) with respect to the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcac7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports After Transition to New Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Administrator awards a new contract to manage and operate a facility of the Administration, the Administrator shall submit to the congressional defense committees a report that includes the matters described in subsection (c) with respect to the contract by not later than 30 days after the completion of the period required to transition to the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcac8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The matters described in this subsection, with respect to a contract, are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcac9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A clear and complete description of the cost savings the Administrator expects to result from the competition for the contract over the life of the contract, including associated analyses, assumptions, and information sources used to determine such expected cost savings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcaca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any key limitations or uncertainties that could affect such costs savings, including costs savings that are anticipated but not fully known.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcacb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs of the competition for the contract, including the immediate costs of conducting the competition, the costs of the transition to the contract from the previous contract, and any increased costs over the life of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcacc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any disruptions or delays in mission activities or deliverables resulting from the competition for the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcacd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A clear and complete description of the benefits expected by the Administrator with respect to mission performance or operations resulting from the competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcace-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How the competition for the contract complied with the Federal Acquisition Regulation regarding Federally funded research and development centers, if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcacf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The factors considered and processes used by the Administrator to determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcad0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to compete or extend the previous contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcad1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which activities at the facility should be covered under the contract rather than under a different contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcad2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the matters included under paragraphs (1) through (7), a detailed description of the analyses conducted by the Administrator to reach the conclusions presented in the report, including any assumptions, limitations, and uncertainties relating to such conclusions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcad3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other matters the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcad4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Quality","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing required by subsection (a) and report required by subsection (b) shall be prepared in accordance with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcad5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information quality guidelines of the Department of Energy that are relevant to the clear and complete presentation of the matters described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcad6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices of the Government Accountability Office and relevant industries for cost estimating, if appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcad7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Reports by Comptroller General of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcad8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General of the United States shall determine, in consultation with the congressional defense committees, whether to conduct an initial review, a comprehensive review, or both, of a report required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcad9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall provide any initial review of a report required by subsection (b) as a briefing to the congressional defense committees not later than 180 days after that report is submitted to the congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcada-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdcadb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall submit any comprehensive review of a report required by subsection (b) to the congressional defense committees not later than 3 years after that report is submitted to the congressional defense committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdcadc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comprehensive review of a report required by subsection (b) shall include an assessment, based on the most current information available, of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idaacdcadd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The actual cost savings achieved compared to cost savings estimated under subsection (c)(1), and any increased costs incurred under the contract that were unexpected or uncertain at the time the contract was awarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaacdcade-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any disruptions or delays in mission activities or deliverables resulting from the competition for the contract compared to the disruptions and delays estimated under subsection (c)(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaacdcadf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether expected benefits of the competition with respect to mission performance or operations have been achieved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idaacdcae0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/e/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Comptroller General considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdcae1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdcae2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements for briefings under subsection (a) and reports under subsection (b) shall apply with respect to requests for proposals issued or contracts awarded, as applicable, by the Administrator during fiscal years 2019 through 2032.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdcae3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6328/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements for briefings under subsection (a) and reports under subsection (b) shall not apply with respect to a management and operations contract for a Naval Reactor facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdcae4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1446"},"text":"139 Stat. 1446","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdcae5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdcae6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdcae7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6328 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8328"},"text":"section 8328 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 6328, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/396"},"text":"70A Stat. 396","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tIX/s923/c/2"},"text":"Pub. L. 98–94, title IX, § 923(c)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/643"},"text":"97 Stat. 643","children":[],"tail":", related to treatment of fractions of years of service in computing retired pay, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/348/tII/s203/b/5"},"text":"Pub. L. 99–348, title II, § 203(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-07-01"},"text":"July 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/696"},"text":"100 Stat. 696","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2787"},"text":"section 2787 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 6329 and 6330 were renumbered sections 8329 and 8330 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacdcae8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) to (3) headings which read as follows: "},{"tag":"inline","attrib":{},"text":"“Determination”, “Initial review”","children":[],"tail":", and “Comprehensive review” and struck out subpars. (A) and (B) headings in par. (3) which read as follows: "},{"tag":"inline","attrib":{},"text":"“Submission”","children":[],"tail":" and "},{"tag":"inline","attrib":{},"text":"“Elements”","children":[],"tail":", respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/A"},"text":"Pub. L. 119–60, § 3111(d)(2)(A)","children":[],"tail":", struck out pars. (1) and (2) headings which read as follows: "},{"tag":"inline","attrib":{},"text":"“In general”","children":[],"tail":" and "},{"tag":"inline","attrib":{},"text":"“Naval reactors”","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
