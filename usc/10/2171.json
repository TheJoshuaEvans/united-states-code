{"tag":"section","attrib":{"id":"ida93612b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171"},"text":null,"children":[{"tag":"num","attrib":{"value":"2171"},"text":"§ 2171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education loan repayment program: enlisted members on active duty in specified military specialties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida93612b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida93612b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the provisions of this section, the Secretary of Defense may repay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida93612b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made, insured, or guaranteed under part B of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93612b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made under part D of such title (the William D. Ford Federal Direct Loan Program, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087a"},"text":"20 U.S.C. 1087a","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93612b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any loan made under part E of such title (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087aa"},"text":"20 U.S.C. 1087aa","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida93612ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any loan incurred for educational purposes made by a lender that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida93612bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or instrumentality of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida93612bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial or credit institution (including an insurance company) that is subject to examination and supervision by an agency of the United States or any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida93612bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pension fund approved by the Secretary for purposes of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida93612be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a non-profit private entity designated by a State, regulated by such State, and approved by the Secretary for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Repayment of any such loan shall be made on the basis of each complete year of service performed by the borrower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida93612bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may repay loans described in paragraph (1) in the case of any person for service performed on active duty as a member in an officer program or military specialty specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The portion or amount of a loan that may be repaid under subsection (a) is 33⅓ percent or $1,500, whichever is greater, for each year of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a portion of a loan is repaid under this section for any year, interest on the remainder of such loan shall accrue and be paid in the same manner as is otherwise required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to authorize refunding any repayment of a loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who transfers from service making the person eligible for repayment of loans under this section (as described in subsection (a)(2)) to service making the person eligible for repayment of loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of this title","children":[],"tail":" (as described in subsection (a)(2) of that section) during a year shall be eligible to have repaid a portion of such loan determined by giving appropriate fractional credit for each portion of the year so served, in accordance with regulations of the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall, by regulation, prescribe a schedule for the allocation of funds made available to carry out the provisions of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of this title","children":[],"tail":" during any year for which funds are not sufficient to pay the sum of the amounts eligible for repayment under subsection (a) and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301/a"},"text":"section 16301(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except a person described in subsection (e) who transfers to service making the person eligible for repayment of loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of this title","children":[],"tail":", a member of the armed forces who fails to complete the period of service required to qualify for loan repayment under this section shall be subject to the repayment provisions of section 303a(e) or 373 of title 37."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida93612c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2171/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may prescribe, by regulations, procedures for implementing this section, including standards for qualified loans and authorized payees and other terms and conditions for making loan repayments. Such regulations may include exceptions that would allow for the payment as a lump sum of any loan repayment due to a member under a written agreement that existed at the time of a member’s death or disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida93612c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s671/a/1"},"text":"Pub. L. 99–145, title VI, § 671(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/661"},"text":"99 Stat. 661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1663/e"},"text":"Pub. L. 103–337, div. A, title XVI, § 1663(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3009"},"text":"108 Stat. 3009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1079/a"},"text":"Pub. L. 104–106, div. A, title X, § 1079(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/451"},"text":"110 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s537"},"text":"Pub. L. 109–163, div. A, title V, § 537","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3249"},"text":"119 Stat. 3249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tV/s552/a"},"text":"Pub. L. 111–383, div. A, title V, § 552(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4220"},"text":"124 Stat. 4220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/a/1/H"},"text":"Pub. L. 115–91, div. A, title VI, § 618(a)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1426"},"text":"131 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida93612c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida93612c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida93612ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Parts B, D, and E of title IV of the Act are classified to parts B (§ 1071 et seq.), D (§ 1087a et seq.), and E (§ 1087aa et seq.), respectively, of subchapter IV of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida93612cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 373” before “of title 37”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s537/a"},"text":"Pub. L. 109–163, § 537(a)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s537/b"},"text":"Pub. L. 109–163, § 537(b)","children":[],"tail":", substituted “a member in an officer program or military specialty” for “an enlisted member in a military specialty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out “or” at end of subpar. (A), added subpar. (B), and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/e/6"},"text":"Pub. L. 103–337, § 1663(e)(6)","children":[],"tail":", substituted “Education loan repayment program: enlisted members on active duty in specified military specialties” for “General educational loan repayment program” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/e/1"},"text":"Pub. L. 103–337, § 1663(e)(1)","children":[],"tail":", struck out “or” after “(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/e/2"},"text":"Pub. L. 103–337, § 1663(e)(2)","children":[],"tail":", substituted “case of any person for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) service performed—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) as an enlisted member of the Selected Reserve of the Ready Reserve of an armed force; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) in a reserve component and military specialty specified by the Secretary of Defense; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) service performed”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"and struck out at end “In the case of service described in clause (A) of the first sentence of this paragraph, the Secretary may repay a loan described in paragraph (1) only if the person to whom the loan was made performed such service after the loan was made.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/e/3"},"text":"Pub. L. 103–337, § 1663(e)(3)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “The portion or amount of a loan that may be repaid under subsection (a) is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 15 percent or $500, whichever is greater, for each year of service, in the case of service described in subsection (a)(2)(A); or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 33⅓ percent or $1,500, whichever is greater, for each year of service, in the case of service described in subsection (a)(2)(B).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/e/4"},"text":"Pub. L. 103–337, § 1663(e)(4)","children":[],"tail":", substituted “A person who transfers from service making the person eligible for repayment of loans under this section (as described in subsection (a)(2)) to service making the person eligible for repayment of loans under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of this title","children":[],"tail":" (as described in subsection (a)(2) of that section)” for “Any individual who transfers from service described in clause (A) or (B) of subsection (a)(2) to service described in the other clause of such subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/e/5"},"text":"Pub. L. 103–337, § 1663(e)(5)","children":[],"tail":", inserted “and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301"},"text":"section 16301 of this title","children":[],"tail":"” after “this section” and “and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16301/a"},"text":"section 16301(a) of this title","children":[],"tail":"” after “subsection (a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida93612cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida93612cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida93612ce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tVI/s671/b/1"},"text":"Pub. L. 99–145, title VI, § 671(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/663"},"text":"99 Stat. 663","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/145/tVI/s671/b/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2171"},"text":"section 2171 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply only—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of persons who enlist or reenlist in the Selected Reserve of the Ready Reserve of an Armed Force or enlist or reenlist for service on active duty after ","children":[{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to service performed after that date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to loans made after ","children":[{"tag":"date","attrib":{"date":"1975-10-01"},"text":"October 1, 1975","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
