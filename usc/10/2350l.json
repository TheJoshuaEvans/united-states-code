{"tag":"section","attrib":{"id":"ida96f4af2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350l"},"text":"§ 2350l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements for reciprocal use of test facilities: foreign countries and international organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida96f4af3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, with the concurrence of the Secretary of State, may enter into a memorandum of understanding (or other formal agreement) with a foreign country or international organization to provide for the testing, on a reciprocal basis, of defense equipment (1) by the United States using test facilities of that country or organization, and (2) by that country or organization using test facilities of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96f4af4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A memorandum or other agreement under subsection (a) shall provide that, when a party to the agreement uses a test facility of another party to the agreement, the party using the test facility is charged by the party providing the test facility in accordance with the following principles:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96f4af5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The user party shall be charged the amount equal to the direct costs incurred by the provider party in furnishing test and evaluation services by the providing party’s officers, employees, or governmental agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96f4af6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The user party may also be charged indirect costs relating to the use of the test facility, but only to the extent specified in the memorandum or other agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96f4af7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Indirect Costs; Delegation of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida96f4af8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall determine the appropriateness of the amount of indirect costs charged by the United States pursuant to subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida96f4af9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may delegate the authority under paragraph (1) only to the Deputy Secretary of Defense and to one other official of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida96f4afa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Funds Collected by the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected by the United States from a party using a test facility of the United States pursuant to a memorandum or other agreement under this section shall be credited to the appropriation accounts from which the costs incurred by the United States in providing such test facility were paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida97194eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida97194ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “direct cost”, with respect to the use of a test facility pursuant to a memorandum or other agreement under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida97194ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any item of cost that is easily and readily identified to a specific unit of work or output within the test facility where the use occurred, that would not have been incurred if such use had not occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida97194ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include costs of labor, materials, facilities, utilities, equipment, supplies, and any other resources of the test facility that are consumed or damaged in connection with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida97194ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida97194f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of the test facility for purposes of the use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97194f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “indirect cost”, with respect to the use of a test facility pursuant to a memorandum or other agreement under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida97194f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any item of cost that is not easily and readily identified to a specific unit of work or output within the test facility where the use occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida97194f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include general and administrative expenses for such activities as supporting base operations, manufacturing, supervision, procurement of office supplies, and utilities that are accumulated costs allocated among several users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida97194f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2350l/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “test facility” means a range or other facility at which testing of defense equipment may be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida97194f5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXII/s1213/a"},"text":"Pub. L. 107–107, div. A, title XII, § 1213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1250"},"text":"115 Stat. 1250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1844/b/1"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1844(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4245"},"text":"134 Stat. 4245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/u/5/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(u)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2154"},"text":"135 Stat. 2154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida97194f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida97194f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida97194f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1844/b/1"},"text":"Pub. L. 116–283, § 1844(b)(1)","children":[],"tail":", which directed the renumbering of this section as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4145"},"text":"section 4145 of this title","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/u/5/B"},"text":"Pub. L. 117–81, § 1701(u)(5)(B)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida97194f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida97194fa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
