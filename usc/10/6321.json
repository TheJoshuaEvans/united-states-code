{"tag":"section","attrib":{"id":"idaacdca4c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321"},"text":null,"children":[{"tag":"num","attrib":{"value":"6321"},"text":"§ 6321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs not allowed under covered contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaacdca4d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following costs are not allowable under a covered contract:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca4e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of entertainment, including amusement, diversion, and social activities and any costs directly associated with such costs (such as tickets to shows or sports events, meals, lodging, rentals, transportation, and gratuities).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca4f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs incurred to influence (directly or indirectly) legislative action on any matter pending before Congress or a State legislature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca50-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs incurred in defense of any civil or criminal fraud proceeding or similar proceeding (including filing of any false certification) brought by the United States where the contractor is found liable or has pleaded nolo contendere to a charge of fraud or similar proceeding (including filing of false certification).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca51-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments of fines and penalties resulting from violations of, or failure to comply with, Federal, State, local, or foreign laws and regulations, except when incurred as a result of compliance with specific terms and conditions of the contract or specific written instructions from the contracting officer authorizing in advance such payments in accordance with applicable regulations of the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca52-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of membership in any social, dining, or country club or organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca53-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of alcoholic beverages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca54-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contributions or donations, regardless of the recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca55-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of advertising designed to promote the contractor or its products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca56-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of promotional items and memorabilia, including models, gifts, and souvenirs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca57-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs for travel by commercial aircraft or by travel by other than common carrier that is not necessary for the performance of the contract and the cost of which exceeds the amount of the standard commercial fare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations; Costs of Information Provided to Congress or State Legislatures and Related Costs","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaacdca59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 150 days after ","children":[{"tag":"date","attrib":{"date":"1985-11-08"},"text":"November 8, 1985","children":[],"tail":", the Secretary of Energy shall prescribe regulations to implement this section. Such regulations may establish appropriate definitions, exclusions, limitations, and qualifications. Such regulations shall be published in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s1707"},"text":"section 1707 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaacdca5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any regulations implementing subsection (a)(2), the Secretary may not treat as not allowable (by reason of such subsection) the following costs of a contractor:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaacdca5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of providing to Congress or a State legislature, in response to a request from Congress or a State legislature, information of a factual, technical, or scientific nature, or advice of experts, with respect to topics directly related to the performance of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaacdca5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs for transportation, lodging, or meals incurred for the purpose of providing such information or advice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Contract Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered contract” means a contract for an amount more than $100,000 entered into by the Secretary of Energy obligating funds appropriated for national security programs of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaacdca5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply with respect to costs incurred under a covered contract on or after 30 days after the regulations required by subsection (b) are issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaacdca5f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1440"},"text":"139 Stat. 1440","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaacdca60-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaacdca61-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaacdca62-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6321 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8321"},"text":"section 8321 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2781"},"text":"section 2781 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaacdca63-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
