{"tag":"section","attrib":{"id":"idabc10398-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203"},"text":null,"children":[{"tag":"num","attrib":{"value":"16203"},"text":"§ 16203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties and limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc10399-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to Complete Program of Training","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc1039a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the program who, under regulations prescribed by the Secretary of Defense, is dropped from the program for deficiency in training, or for other reasons, shall be required, at the discretion of the Secretary concerned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idabc1039b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform one year of active duty for each year (or part thereof) for which such person was provided financial assistance under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idabc1039c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with the repayment provisions of section 303a(e) or 373 of title 37.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc1039d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department, under regulations prescribed by the Secretary of Defense, may relieve a member participating in the program who is dropped from the program from any requirement that may be imposed under paragraph (1), but such relief shall not relieve him from any military obligation imposed by any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc1039e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s16203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions of Duplicate Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Financial assistance may not be provided under this section to a member receiving financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2107"},"text":"section 2107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc1039f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tVII/s711/a/3"},"text":"Pub. L. 100–180, div. A, title VII, § 711(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1111"},"text":"101 Stat. 1111","children":[],"tail":", § 2130; renumbered § 16203 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1663/c/4"},"text":"Pub. L. 103–337, div. A, title XVI, § 1663(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3008"},"text":"108 Stat. 3008","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s687/c/13"},"text":"Pub. L. 109–163, div. A, title VI, § 687(c)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3335"},"text":"119 Stat. 3335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVI/s618/a/1/O"},"text":"Pub. L. 115–91, div. A, title VI, § 618(a)(1)(O)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1426"},"text":"131 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabc103a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabc103a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabc103a2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" inserted “or 373” before “of title 37”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “to repay the United States an amount equal to the total amount paid to such person under the program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/c/4"},"text":"Pub. L. 103–337, § 1663(c)(4)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2130"},"text":"section 2130 of this title","children":[],"tail":" as this section and substituted “Penalties and limitations” for “Penalties, limitations, and other administrative provisions” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1663/c/4/A"},"text":"Pub. L. 103–337, § 1663(c)(4)(A)","children":[],"tail":", struck out subsec. (c) which related to regulations. See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s16204"},"text":"section 16204 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabc103a3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idabc103a4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idabc103a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For savings provision relating to payment or repayment of any bonus, incentive pay, special pay, or similar pay obligated to be paid before ","children":[{"tag":"date","attrib":{"date":"2006-04-01"},"text":"Apr. 1, 2006","children":[],"tail":", under a provision of this section amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/c"},"text":"section 687(c) of Pub. L. 109–163","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s687/f"},"text":"section 687(f) of Pub. L. 109–163","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s510"},"text":"section 510 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
