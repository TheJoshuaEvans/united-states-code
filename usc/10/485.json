6","children":[],"tail":", 774; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tIX/s922"},"text":"Pub. L. 107–107, div. A, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1198"},"text":"115 Stat. 1198","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title II, § 241(a), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4395"},"text":"122 Stat. 4395","children":[],"tail":", related to biennial reports on joint and service concept development and experimentation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1061/7/A"},"text":"Pub. L. 112–81, div. A, title X, § 1061(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1583"},"text":"125 Stat. 1583","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c45a75-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1204/a/1"},"text":"Pub. L. 118–159, § 1204(a)(1)","children":[],"tail":", substituted “Quarterly briefings on counterterrorism operations, irregular warfare, and sensitive activities” for “Monthly counterterrorism operations briefings” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1204/a/2"},"text":"Pub. L. 118–159, § 1204(a)(2)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary of Defense shall provide to the congressional defense committees monthly briefings outlining Department of Defense counterterrorism operations and related activities, including the use of military force under the notion of collective self-defense of foreign partners.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" inserted “, including the use of military force under the notion of collective self-defense of foreign partners” after “activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1031/b"},"text":"Pub. L. 114–328, § 1031(b)","children":[],"tail":", substituted “Monthly” for “Quarterly” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1031/a"},"text":"Pub. L. 114–328, § 1031(a)","children":[],"tail":", substituted “monthly” for “quarterly”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
