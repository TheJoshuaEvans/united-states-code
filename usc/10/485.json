{"tag":"section","attrib":{"id":"ida7c45a6a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485"},"text":null,"children":[{"tag":"num","attrib":{"value":"485"},"text":"§ 485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly briefings on counterterrorism operations, irregular warfare, and sensitive activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c45a6b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide to the congressional defense committees quarterly briefings on counterterrorism operations and related activities (including the use of military force under the notion of collective self-defense of foreign partners), irregular warfare activities, and other sensitive activities conducted by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c45a6c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing under subsection (a) shall include each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7c45a6d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A global update on activity within each geographic combatant command and how such activity supports the respective theater campaign plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c45a6e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overview of authorities and legal issues, including limitations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c45a6f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An overview of interagency activities and initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7c45a70-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s485/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other matters the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c45a71-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tX/s1042/a/1"},"text":"Pub. L. 113–66, div. A, title X, § 1042(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/857"},"text":"127 Stat. 857","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1031/a"},"text":"Pub. L. 114–328, div. A, title X, § 1031(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2389"},"text":"130 Stat. 2389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/d