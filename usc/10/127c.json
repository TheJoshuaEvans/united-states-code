{"tag":"section","attrib":{"id":"ida75459f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127c"},"text":null,"children":[{"tag":"num","attrib":{"value":"127c"},"text":"§ 127c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of weapons overseas: force protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida75459f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When elements of the armed forces are engaged in ongoing military operations in a country, the Secretary of Defense may, for the purpose of protecting United States forces in that country, purchase weapons from any foreign person, foreign government, international organization, or other entity located in that country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75459f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total amount expended during any fiscal year for purchases under this section may not exceed $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida75459f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Semiannual Congressional Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the authority provided in subsection (a) is used during the period of the first six months of a fiscal year, or during the period of the second six months of a fiscal year, the Secretary of Defense shall submit to the Committee on Armed Services of the Senate and Committee on Armed Services of the House of Representatives a report on the use of that authority during that six-month period. Each such report shall be submitted not later than 30 days after the end of the six-month period during which the authority is used. Each such report shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida75459f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and type of weapons purchased under subsection (a) during that six-month period covered by the report, together with the amount spent for those weapons and the Secretary’s estimate of the fair market value of those weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida75459f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s127c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the dispositions (if any) during that six-month period of weapons purchased under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida75459f6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tXII/s1231/a"},"text":"Pub. L. 109–163, div. A, title XII, § 1231(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3467"},"text":"119 Stat. 3467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida75459f7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida75459f8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida75459f9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 127c was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s127d"},"text":"section 127d of this title","children":[],"tail":" prior to being renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
