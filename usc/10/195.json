{"tag":"section","attrib":{"id":"ida783f6ad-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s195"},"text":null,"children":[{"tag":"num","attrib":{"value":"195"},"text":"§ 195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense Automated Printing Service: applicability of Federal printing requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Defense Automated Printing Service shall comply fully with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":" relating to the production and procurement of printing, binding, and blank-book work."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida783f6ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIII/s383/a"},"text":"Pub. L. 105–85, div. A, title III, § 383(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1711"},"text":"111 Stat. 1711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida783f6af-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida783f6b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida783f6b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Procure Services From Government Publishing Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tIII/s387/c"},"text":"Pub. L. 105–85, div. A, title III, § 387(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1713"},"text":"111 Stat. 1713","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1301/b"},"text":"“Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":", United States Code, the Secretary of a military department or head of a Defense Agency may contract directly with the Government Publishing Office for printing and duplication services otherwise available through the Defense Automated Printing Service.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
