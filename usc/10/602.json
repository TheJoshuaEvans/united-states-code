{"tag":"section","attrib":{"id":"ida7e354c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s602"},"text":null,"children":[{"tag":"num","attrib":{"value":"602"},"text":"§ 602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility in determining terms of appointment for certain senior officer positions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may extend or reduce the duration of an appointment made under section 152, 154, 7033, 8033, 8043, 9033, or 9082 of this title by up to six months if the Secretary determines that such an extension or reduction is necessary either in the interests of national defense, or to ensure an appropriate staggering of terms of senior military leadership.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida7e354c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s504/a"},"text":"Pub. L. 118–31, div. A, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/241"},"text":"137 Stat. 241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e354c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e354c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida7e354c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 602, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2849"},"text":"94 Stat. 2849","children":[],"tail":", related to temporary promotions of warrant officers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tXI/s1113/a"},"text":"Pub. L. 102–190, div. A, title XI, § 1113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1502"},"text":"105 Stat. 1502","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
