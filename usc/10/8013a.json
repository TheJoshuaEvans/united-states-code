"href":"/us/usc/t14/s3"},"text":"14 U.S.C. 3","children":[],"tail":". These provisions are duplicated in this title for the purpose of producing a statement of the general powers of the Secretary of the Navy in this important area."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab0490d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab0490d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s3"},"text":"Section 3 of title 14","children":[],"tail":", referred to in subsec. (a), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s103"},"text":"section 103 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s103/b"},"text":"Pub. L. 115–282, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4195"},"text":"132 Stat. 4195","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s3"},"text":"section 3 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Gu