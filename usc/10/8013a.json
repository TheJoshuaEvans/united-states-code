{"tag":"section","attrib":{"id":"idab0490d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8013a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8013a"},"text":"§ 8013a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of the Navy: powers with respect to Coast Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab0490d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8013a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever the Coast Guard operates as a service in the Navy under section 3 ","children":[{"tag":"ref","attrib":{"idref":"fn002157"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002157"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, the Secretary of the Navy has the same powers and duties with respect to the Coast Guard as the Secretary of Homeland Security has when the Coast Guard is not so operating."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab0490d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8013a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While operating as a service in the Navy, the Coast Guard is subject to the orders of the Secretary of the Navy, who may order changes in Coast Guard operations to make them uniform, to the extent he considers advisable, with Navy operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab0490d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/279"},"text":"70A Stat. 279","ch