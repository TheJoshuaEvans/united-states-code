{"tag":"section","attrib":{"id":"ida8b2d963-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218"},"text":null,"children":[{"tag":"num","attrib":{"value":"1218"},"text":"§ 1218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge or release from active duty: claims for compensation, pension, or hospitalization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b2d964-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of an armed force may not be discharged or released from active duty because of physical disability until he—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b2d965-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made a claim for compensation, pension, or hospitalization, to be filed with the Department of Veterans Affairs, or has refused to make such a claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d966-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has signed a statement that his right to make such a claim has been explained to him, or has refused to sign such a statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d967-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A right that a member may assert after failing or refusing to sign a claim, as provided in subsection (a), is not affected by that failure or refusal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d968-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not prevent the immediate transfer of a member to a facility of the Department of Veterans Affairs for necessary hospital care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b2d969-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b2d96a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of a military department shall ensure that each member of a reserve component under the jurisdiction of the Secretary who is determined, after a mobilization and deployment to an area in which imminent danger pay is authorized under section 310 or 351 of title 37, to require evaluation for a physical or mental disability which could result in separation or retirement for disability under this chapter or placement on the temporary disability retired list or inactive status list under this chapter is retained on active duty during the disability evaluation process until such time as such member is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8b2d96b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cleared by appropriate authorities for continuation on active duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b2d96c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separated, retired, or placed on the temporary disability retired list or inactive status list.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d96d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8b2d96e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member described in paragraph (1) may request termination of active duty under such paragraph at any time during the demobilization or disability evaluation process of such member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b2d96f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon a request under subparagraph (A), a member described in paragraph (1) shall only be released from active duty after the member receives counseling about the consequences of termination of active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b2d970-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each release from active duty under subparagraph (B) shall be thoroughly documented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b2d971-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1218/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements in paragraph (1) shall expire on ","children":[{"tag":"date","attrib":{"date":"2014-10-28"},"text":"October 28, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b2d972-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/56/tXXII/s2201/31/A"},"text":"Pub. L. 85–56, title XXII, § 2201(31)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-06-17"},"text":"June 17, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/160"},"text":"71 Stat. 160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/651/tI/s107/c"},"text":"Pub. L. 87–651, title I, § 107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/508"},"text":"76 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1621/a/1"},"text":"Pub. L. 101–189, div. A, title XVI, § 1621(a)(1)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1602"},"text":"103 Stat. 1602","children":[],"tail":", 1603; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tV/s511"},"text":"Pub. L. 111–84, div. A, title V, § 511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2280"},"text":"123 Stat. 2280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/e/1"},"text":"Pub. L. 113–291, div. A, title X, § 1071(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s618/c"},"text":"Pub. L. 114–328, div. A, title VI, § 618(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2160"},"text":"130 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b2d973-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b2d974-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b2d975-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1962 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1218 and 1219 are restated, without substantive change, to conform to the style adopted for title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b2d976-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b2d977-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted “or 351” after “section 310” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “on "},{"tag":"date","attrib":{"date":"2014-10-28"},"text":"October 28, 2014","children":[],"tail":"” for “on the date that is five years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2010”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1621/a/1"},"text":"Pub. L. 101–189, § 1621(a)(1)","children":[],"tail":", substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/s1621/a/4"},"text":"Pub. L. 101–189, § 1621(a)(4)","children":[],"tail":", substituted “facility of the Department of Veterans Affairs” for “Veterans’ Administration facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/651"},"text":"Pub. L. 87–651","children":[],"tail":" amended section generally, and among other changes, substituted “Discharge or release from active duty: claims for compensation, pension, or hospitalization” for “Explanation of rights before discharge” in section catchline, and struck out provisions which prohibited a person from being discharged or released from active duty until his certificate of discharge or release from active duty and his final pay (or a substantial portion of his final pay) are ready for delivery to him or to his next of kin or legal representative."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b2d978-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8b2d979-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1958-01-01"},"text":"Jan. 1, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/56/s2301"},"text":"section 2301 of Pub. L. 85–56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/172"},"text":"71 Stat. 172","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
