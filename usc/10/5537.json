{"tag":"section","attrib":{"id":"idaab5fd06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5537"},"text":null,"children":[{"tag":"num","attrib":{"value":"5537"},"text":"§ 5537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on Missile Defense Agency production of satellites and ground systems associated with operation of such satellites","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaab5fd07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Production of Satellites and Ground Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Missile Defense Agency may not authorize or obligate funding for a program of record for the production of satellites or ground systems associated with the operation of such satellites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaab5fd08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prototype Satellites","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaab5fd09-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5537/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director, with the concurrence of the Space Acquisition Council established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9021"},"text":"section 9021 of this title","children":[],"tail":", may authorize the production of one or more prototype satellites, consistent with the requirements of the Missile Defense Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fd0a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5537/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the date on which the Space Acquisition Council concurs with the Director with respect to authorizing the production of a prototype satellite under paragraph (1), the chair of the Council shall submit to the congressional defense committees a report explaining the reasons for such concurrence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaab5fd0b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s5537/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may not obligate funds for the production of a prototype satellite under paragraph (1) before the date on which the Space Acquisition Council submits the report for such prototype satellite under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaab5fd0c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/a"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2197"},"text":"138 Stat. 2197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaab5fd0d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaab5fd0e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaab5fd0f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5537, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/319"},"text":"70A Stat. 319","children":[],"tail":", provided for extension of naval service during disability incident to service, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/90/235/s2/a/3"},"text":"Pub. L. 90–235, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/756"},"text":"81 Stat. 756","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVI/s1662/a"},"text":"Pub. L. 117–81, div. A, title XVI, § 1662(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2103"},"text":"135 Stat. 2103","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4022"},"text":"section 4022 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVI/s1649/b/2"},"text":"Pub. L. 118–159, div. A, title XVI, § 1649(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2199"},"text":"138 Stat. 2199","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 5538 and 5539 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s2/a/3"},"text":"Pub. L. 90–235, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/756"},"text":"81 Stat. 756","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5538, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/319"},"text":"70A Stat. 319","children":[],"tail":", provided for extension of enlistments in Regular Navy or Regular Marine Corps during war or national emergency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5539, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/320"},"text":"70A Stat. 320","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/116"},"text":"Pub. L. 85–861, § 1(116)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1493"},"text":"72 Stat. 1493","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14c/27"},"text":"Pub. L. 87–649, § 14c(27)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/501"},"text":"76 Stat. 501","children":[],"tail":", provided for voluntary extension or re-extension of enlistments in Regular Navy or Regular Marine Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 5540 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8120"},"text":"section 8120 of this title","children":[],"tail":