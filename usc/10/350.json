{"tag":"section","attrib":{"id":"ida7a7d194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350"},"text":null,"children":[{"tag":"num","attrib":{"value":"350"},"text":"§ 350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inter-European Air Forces Academy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7a7d195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may operate the Air Force education and training facility known as the Inter-European Air Forces Academy (in this section referred to as the “Academy”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Academy shall be to provide military education and training to military personnel of countries that are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d197-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the North Atlantic Treaty Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d198-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signatories to the Partnership for Peace Framework Documents; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d199-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7a7d19a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the United States Africa Command area of responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7a7d19b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for assistance under chapter 5 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2347"},"text":"22 U.S.C. 2347","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d19c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d19d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence of secretary of state","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Military personnel of a country may be provided education and training under this section only with the concurrence of the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d19e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance otherwise prohibited by law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Education and training may not be provided under this section to the military personnel of any country that is otherwise prohibited from receiving such type of assistance under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d19f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplies and Clothing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force may, under such conditions as the Secretary may prescribe, provide to a person receiving education and training under this section the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7a7d1a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation incident to such education and training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplies and equipment to be used during such education and training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7a7d1a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Billeting, food, and health services in connection with the receipt of such education and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Living Allowance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Air Force may pay to a person receiving education and training under this section a living allowance at a rate to be prescribed by the Secretary, taking into account the rates of living allowances authorized for a member of the Armed Forces under similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7a7d1a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s350/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts for the operations and maintenance of the Academy, and for the provision of education and training through the Academy, may be paid from funds available for the Air Force for operation and maintenance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7a7d1a5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/k/1"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2508"},"text":"130 Stat. 2508","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1205"},"text":"Pub. L. 116–283, div. A, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3912"},"text":"134 Stat. 3912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7a7d1a6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7a7d1a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida7a7d1a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (b)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 5 of part II of the Act is classified generally to part V (§ 2347 et seq.) of subchapter II of chapter 32 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7a7d1a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", is based on text of subsecs. (a) to (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/s1268"},"text":"section 1268 of Pub. L. 113–291","children":[],"tail":", div. A, title XII, "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3585"},"text":"128 Stat. 3585","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9411"},"text":"section 9411 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1241/k/2"},"text":"Pub. L. 114–328, div. A, title XII, § 1241(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2509"},"text":"130 Stat. 2509","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7a7d1aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “that are—” for “that are members of the North Atlantic Treaty Organization or signatories to the Partnership for Peace Framework Documents.” and added pars (1) to (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
