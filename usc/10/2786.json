{"tag":"section","attrib":{"id":"ida9d0f3cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2786"},"text":null,"children":[{"tag":"num","attrib":{"value":"2786"},"text":"§ 2786.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense payments by electronic transfers of funds: exercise of authority for waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to any Federal payment of funds covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3332/f"},"text":"section 3332(f) of title 31","children":[],"tail":" (relating to electronic funds transfers) for which payment is made or authorized by the Department of Defense, the waiver authority provided in paragraph (2)(A)(i) of that section shall be exercised by the Secretary of Defense. The Secretary of Defense shall carry out the authority provided under the preceding sentence in consultation with the Secretary of the Treasury."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida9d0f3d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1008/a/1"},"text":"Pub. L. 106–65, div. A, title X, § 1008(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/737"},"text":"113 Stat. 737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9d0f3d1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9d0f3d2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"ida9d0f3d3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1008/a/3"},"text":"Pub. L. 106–65, div. A, title X, § 1008(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/738"},"text":"113 Stat. 738","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dA/tX/s1008/a/3"},"text":"“Any waiver in effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":"] under paragraph (2)(A)(i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3332/f"},"text":"section 3332(f) of title 31","children":[],"tail":", United States Code, shall remain in effect until otherwise provided by the Secretary of Defense under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2786"},"text":"section 2786 of title 10","children":[],"tail":", United States Code, as added by paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
