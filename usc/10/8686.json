{"tag":"section","attrib":{"id":"idab3dcaf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686"},"text":null,"children":[{"tag":"num","attrib":{"value":"8686"},"text":"§ 8686.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for transfers of decommissioned vessels and shipboard equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3dcaf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Provide Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may provide an entity described in subsection (b) with assistance in support of a transfer of a vessel or shipboard equipment described in such subsection that is being executed under section 2572, 8676, 8677, or 8765 of this title, or under any other authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dcafa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Vessels and Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority under this section applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dcafb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a decommissioned vessel that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3dcafc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned and maintained by the Navy, is located at a Navy facility, and is not in active use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dcafd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is being transferred to an entity designated by the Secretary of the Navy or by law to receive transfer of the vessel; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dcafe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any shipboard equipment that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3dcaff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on a vessel described in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dcb00-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is being transferred to an entity designated by the Secretary of the Navy or by law to receive transfer of the equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dcb01-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a recipient of assistance under subsection (a) to reimburse the Navy for amounts expended by the Navy in providing the assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dcb02-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8686/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of Funds Received","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds received in a fiscal year under subsection (c) shall be credited to the appropriation available for such fiscal year for operation and maintenance for the office of the Navy managing inactive ships, shall be merged with other sums in the appropriation that are available for such office, and shall be available for the same purposes and period as the sums with which merged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3dcb03-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1015/a"},"text":"Pub. L. 108–136, div. A, title X, § 1015(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1591"},"text":"117 Stat. 1591","children":[],"tail":", § 7316; renumbered § 8686 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(d)(2), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3dcb04-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3dcb05-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab3dcb06-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8686, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/536"},"text":"70A Stat. 536","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1980-09-24"},"text":"Sept. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/357/s5/a"},"text":"Pub. L. 96–357, § 5(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1182"},"text":"94 Stat. 1182","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tIV/s414/a/7/B"},"text":"Pub. L. 98–525, title IV, § 414(a)(7)(B)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2519"},"text":"98 Stat. 2519","children":[],"tail":", related to credit to members of Air National Guard of United States for service as members of Air National Guard, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1662/g/2"},"text":"Pub. L. 103–337, div. A, title XVI, § 1662(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"tex