{"tag":"section","attrib":{"id":"ida855ebd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065"},"text":null,"children":[{"tag":"num","attrib":{"value":"1065"},"text":"§ 1065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of commissary stores and MWR facilities: certain veterans, caregivers for veterans, and Foreign Service officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida855ebd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Veterans Awarded the Purple Heart","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran who was awarded the Purple Heart shall be permitted to use commissary stores and MWR facilities on the same basis as a member of the armed forces entitled to retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Veterans Who Are Medal of Honor Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran who is a Medal of Honor recipient shall be permitted to use commissary stores and MWR facilities on the same basis as a member of the armed forces entitled to retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Veterans Who Are Former Prisoners of War","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran who is a former prisoner of war shall be permitted to use commissary stores and MWR facilities on the same basis as a member of the armed forces entitled to retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Veterans With Service-Connected Disabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A veteran with a service-connected disability shall be permitted to use commissary stores and MWR facilities on the same basis as a member of the armed forces entitled to retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Caregivers for Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A caregiver or family caregiver shall be permitted to use commissary stores and MWR facilities on the same basis as a member of the armed forces entitled to retired or retainer pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Foreign Service Officers on Mandatory Home Leave","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Foreign Service officer on mandatory home leave may be permitted to use military lodging referred to in subsection (h).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"User Fee Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855ebde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall prescribe regulations that impose a user fee on individuals who are eligible solely under this section to purchase merchandise at a commissary store or MWR retail facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall set the user fee under this subsection at a rate that the Secretary determines will offset any increase in expenses arising from this section borne by the Department of the Treasury on behalf of commissary stores associated with the use of credit or debit cards for customer purchases, including expenses related to card network use and related transaction processing fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebe0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall deposit funds collected pursuant to a user fee under this subsection in the General Fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebe1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any fee under this subsection is in addition to the uniform surcharge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2484/d"},"text":"section 2484(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebe2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855ebe3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “MWR facilities” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida855ebe4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" MWR retail facilities, as that term is defined in section 1063(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002048"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida855ebe5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military lodging operated by the Department of Defense for the morale, welfare, and recreation of members of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebe6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Medal of Honor recipient” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074h/c"},"text":"section 1074h(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebe7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “veteran”, “former prisoner of war”, and “service-connected” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebe8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “caregiver” and “family caregiver” have the meanings given those terms in section in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720G/d"},"text":"section 1720G(d) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebe9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Foreign Service officer” has the meaning given that term in section 103 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3903"},"text":"22 U.S.C. 3903","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1065/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “mandatory home leave” means leave under section 903 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4083"},"text":"22 U.S.C. 4083","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida855ebeb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s621/b/1"},"text":"Pub. L. 115–232, div. A, title VI, § 621(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1798"},"text":"132 Stat. 1798","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s641/a"},"text":"Pub. L. 116–92, div. A, title VI, § 641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1430"},"text":"133 Stat. 1430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida855ebec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida855ebed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida855ebee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1063/e"},"text":"Section 1063(e) of this title","children":[],"tail":", referred to in subsec. (h)(1)(A), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1063/f"},"text":"section 1063(f) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII"},"text":"Pub. L. 118–31, div. A, title XVII","children":[],"tail":", 1722(h)(2), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/672"},"text":"137 Stat. 672","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida855ebef-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1065 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1063"},"text":"section 1063 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida855ebf0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s641/a/1"},"text":"Pub. L. 116–92, § 641(a)(1)","children":[],"tail":", substituted “veterans, caregivers for veterans, and Foreign Service officers” for “veterans and caregivers for veterans” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s641/a/2"},"text":"Pub. L. 116–92, § 641(a)(2)","children":[],"tail":", (3), added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s641/a/4"},"text":"Pub. L. 116–92, § 641(a)(4)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida855ebf1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida855ebf2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s641/b"},"text":"Pub. L. 116–92, div. A, title VI, § 641(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1431"},"text":"133 Stat. 1431","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tVI/s641/b"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":", as if originally incorporated in "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s621"},"text":"section 621 of Public Law 115–232","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida855ebf3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s621/b/3"},"text":"Pub. L. 115–232, div. A, title VI, § 621(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1799"},"text":"132 Stat. 1799","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/232/dA/tVI/s621/b/3"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1065"},"text":"Section 1065 of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall take effect on "},{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
