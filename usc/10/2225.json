{"tag":"section","attrib":{"id":"ida9529b83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225"},"text":null,"children":[{"tag":"num","attrib":{"value":"2225"},"text":"§ 2225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insider threat detection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9529b84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish a program for information sharing protection and insider threat mitigation for the information systems of the Department of Defense to detect unauthorized access to, use of, or transmission of classified or controlled unclassified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9529b85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9529b86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Technology solutions for deployment within the Department of Defense that allow for centralized monitoring and detection of unauthorized activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9529b87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the use of external ports and read and write capability controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disabling the removable media ports of computers physically or electronically;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronic auditing and reporting of unusual and unauthorized user activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using data-loss prevention and data-rights management technology to prevent the unauthorized export of information from a network or to render such information unusable in the event of the unauthorized export of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a roles-based access certification system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-domain guards for transfers of information between different networks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patch management for software and security updates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9529b8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Policies and procedures to support such program, including special consideration for policies and procedures related to international and interagency partners and activities in support of ongoing operations in areas of hostilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9529b8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A governance structure and process that integrates information security and sharing technologies with the policies and procedures referred to in paragraph (2). Such structure and process shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9529b90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with the existing security clearance and suitability review process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of existing anomaly detection techniques, including those used in counterintelligence investigation or personnel screening activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updating and expediting of the classification review and marking process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9529b93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A continuing analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9529b94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gaps in security measures under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9529b95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology, policies, and processes needed to increase the capability of the program beyond the initially established full operating capability to address such gaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9529b96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A baseline analysis framework that includes measures of performance and effectiveness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9529b97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for how to ensure related security measures are put in place for other departments or agencies with access to Department of Defense networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9529b98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2225/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for enforcement to ensure that the program is being applied and implemented on a uniform and consistent basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9529b99-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1623/a"},"text":"Pub. L. 119–60, div. A, title XVI, § 1623(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1183"},"text":"139 Stat. 1183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9529b9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9529b9b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida9529b9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Text of section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", is based on text of subsecs. (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s922"},"text":"section 922 of Pub. L. 112–81","children":[],"tail":", div. A, title IX, "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1537"},"text":"125 Stat. 1537","children":[],"tail":", which was formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2224"},"text":"section 2224 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1623/b"},"text":"Pub. L. 119–60, div. A, title XVI, § 1623(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1183"},"text":"139 Stat. 1183","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9550c9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2225, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VIII, § 812(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":