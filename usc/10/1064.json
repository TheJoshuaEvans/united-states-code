{"tag":"section","attrib":{"id":"ida855ebc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064"},"text":null,"children":[{"tag":"num","attrib":{"value":"1064"},"text":"§ 1064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of commissary stores and MWR retail facilities: members of National Guard serving in federally declared disaster or national emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida855ebca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the National Guard who, although not in Federal service, is called or ordered to duty in response to a federally declared disaster or national emergency shall be permitted to use commissary stores and MWR retail facilities during the period of such duty on the same basis as members of the armed forces on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility of Dependents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A dependent of a member of the National Guard who is permitted under subsection (a) to use commissary stores and MWR retail facilities shall be permitted to use such stores and facilities, during the same period as the member, on the same basis as dependents of members of the armed forces on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida855ebcc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida855ebcd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federally declared disaster","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “federally declared disaster” means a disaster or other situation for which a Presidential declaration of major disaster is issued under section 401 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"42 U.S.C. 5170","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"MWR retail facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “MWR retail facilities” has the meaning given that term in section 1063(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida855ebcf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1064/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “national emergency” means a national emergency declared by the President or Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida855ebd0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tIII/s362/c"},"text":"Pub. L. 105–261, div. A, title III, § 362(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1985"},"text":"112 Stat. 1985","children":[],"tail":", § 1063a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIII/s322/a"},"text":"Pub. L. 107–314, div. A, title III, § 322(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2510"},"text":"116 Stat. 2510","children":[],"tail":"; renumbered § 1064 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVI/s651/b/2"},"text":"Pub. L. 108–136, div. A, title VI, § 651(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1521"},"text":"117 Stat. 1521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida855ebd1-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida855ebd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":