{"tag":"section","attrib":{"id":"idaa3ea8fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848"},"text":null,"children":[{"tag":"num","attrib":{"value":"3848"},"text":"§ 3848.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defense audit agencies: Small Business Ombudsmen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa3ea8ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small Business Ombudsman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall designate within each defense audit agency an official as the Small Business Ombudsman to have the duties described in subsection (b) and such other responsibilities as may be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea900-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Small Business Ombudsman of a defense audit agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3ea901-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Director of the defense audit agency on policy issues related to small business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea902-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the defense audit agency’s primary point of contact and source of information for small business concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea903-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect and monitor relevant data regarding the defense audit agency’s conduct of audits of small business concerns, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa3ea904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data regarding the timeliness of audit closeouts for small business concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa3ea905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data regarding the responsiveness of the defense audit agency to issues or other matters raised by small business concerns; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3ea906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Director regarding policies, processes, and procedures related to the timeliness of audits of small business concerns and the responsiveness of the defense audit agency to issues or other matters raised by small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audit Independence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Small Business Ombudsman of a defense audit agency shall be segregated from ongoing audits in the field and shall not engage in activities with regard to particular audits that could compromise the independence of the defense audit agency or undermine compliance with applicable audit standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3ea908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3848/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Audit Agency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “defense audit agency” means the Defense Contract Audit Agency and the Defense Contract Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa3ea909-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVI/s1612/a"},"text":"Pub. L. 112–239, div. A, title XVI, § 1612(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2064"},"text":"126 Stat. 2064","children":[],"tail":", § 204; renumbered § 3848 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1835/c"},"text":"Pub. L. 116–283, div. A, title XV