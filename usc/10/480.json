{"tag":"section","attrib":{"id":"ida7c210c6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s480"},"text":null,"children":[{"tag":"num","attrib":{"value":"480"},"text":"§ 480.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress: submission in electronic form","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7c210c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s480/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary of Defense or any other official of the Department of Defense submits to Congress (or any committee of either House of Congress) a report that the Secretary (or other official) is required by law to submit, the Secretary (or other official) shall provide to Congress (or such committee) a copy of the report in an electronic medium.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c210c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s480/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to a report submitted in classified form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7c210c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s480/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “report” includes any certification, notification, or other communication in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7c210ca-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1042/a"},"text":"Pub. L. 107–107, div. A, title X, § 1042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1218"},"text":"115 Stat. 1218","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1042"},"text":"Pub. L. 107–314, div. A, title X, § 1042","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2646"},"text":"116 Stat. 2646","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7c210cb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7c210cc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7c210cd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “shall provide to Congress (or” for “shall, upon request by any committee of Congress to which the report is submitted or referred, provide to Congress (or each”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
