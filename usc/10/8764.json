{"tag":"section","attrib":{"id":"idab4c2191-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8764"},"text":null,"children":[{"tag":"num","attrib":{"value":"8764"},"text":"§ 8764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Devices and trophies: transfer to other agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab4c2192-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8764/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may, without reimbursement, transfer to the Secretary of the Treasury devices and trophies for the promotion of the sale of war bonds or victory bonds. The Secretary of the Treasury may sell or donate the devices and trophies for the promotion of the sale of such bonds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab4c2193-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8764/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may, without reimbursement, transfer to any agency of the United States devices and trophies for scientific, experimental, monumental, or display purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab4c2194-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/465"},"text":"70A Stat. 465","children":[],"tail":", § 7544; renumbered § 8764, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/8"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","