{"tag":"section","attrib":{"id":"ida9efee03-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2891b"},"text":"§ 2891b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations of eligible entity housing history in contracts for privatized military housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9efee04-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To assist in making a determination whether to enter into a new contract, or renew an existing contract, with an eligible entity, the Secretary of Defense shall develop a standard process by which the Secretary concerned may evaluate the past performance of the eligible entity for purposes of informing future decisions regarding the award of such a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9efee05-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of Process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process developed under subsection (a) shall include, at a minimum, consideration of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9efee06-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any history of the eligible entity of providing substandard housing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9efee07-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recommendation of the commander of the installation for which housing units will be provided under the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9efee08-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2891b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recommendation of the commander of any other installation for which the eligible entity has provided housing units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9efee09-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dB/tXXX/s3015"},"text":"Pub. L. 116–92, div. B, title XXX, § 3015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1927"},"text":"133 Stat. 1927","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
