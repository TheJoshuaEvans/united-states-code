:{"href":"/us/stat/58/281"},"text":"58 Stat. 281","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a) the words “by the Congress” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b) the words “There is authorized to be appropriated” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab47665d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab47665e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7432"},"text":"section 7432 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted a period for the semicolon at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/137"},"text":"Pub. L. 96–137","children":[],"tail":" struck out provisions relating to the naval petroleum reserves special account."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258"},"text":"Pub. L. 94–258","children":[],"tail":" substituted “Naval petroleum reserves special account” for “Expenditures: appropriations chargeable” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258"},"text":"Pub. L. 94–258","children":[],"tail":" substituted provisions establishing a special account on the books of the Treasury Department to be designated as the “naval petroleum reserves special account”, and authorizing to be credited proceeds resulting from the sale or exchange of the United States share of petroleum, refined petroleum products, appropriation funds, royalties, or other revenue from the operation of the reserves, for provisions authorizing the expenditure of funds from available appropriations for expenses incurred in the administration of the reserves."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258"},"text":"Pub. L. 94–258","children":[],"tail":" substituted provisions which made funds in the naval petroleum reserve special account available in sums specified in annual appropriations acts for enumerated expense items, for provisions which authorized expenditures to be made under the direction of the President and requiring the President to submit an estimate of expenditures necessary to carry out the purposes of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/258"},"text":"Pub. L. 94–258","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/796"},"text":"Pub. L. 87–796","children":[],"tail":" substituted “with respect to the naval petroleum and oil shale reserves shall be paid from appropriations made available for the purposes specified in this chapter” for “in exploring, prospecting, conserving, developing, using and operating lands owned or controlled by the United States in the naval petroleum reserves, and in producing petroleum, and the share of the United States of expenses incurred under any contract entered into under this chapter, shall be paid from appropriations made available for those purposes”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab47665f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab476660-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab476661-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab476662-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Abolition of Naval Petroleum Reserves Special Account","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/137/s3/c"},"text":"Pub. L. 96–137, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-12"},"text":"Dec. 12, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1062"},"text":"93 Stat. 1062","children":[],"tail":", abolished the naval petroleum reserves special account established by this section as in existence on the day before "},{"tag":"date","attrib":{"date":"1979-12-12"},"text":"Dec. 12, 1979","children":[],"tail":", and transferred unappropriated balances of funds on that date to the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
