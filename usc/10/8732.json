{"tag":"section","attrib":{"id":"idab476653-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8732"},"text":null,"children":[{"tag":"num","attrib":{"value":"8732"},"text":"§ 8732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab476654-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds for the following purposes may not be appropriated unless such appropriations have been specifically authorized by law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab476655-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8732/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exploration, prospecting, conservation, development, use, operations, and production of the naval petroleum reserves as authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab476656-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8732/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Production (including preparation for production) as authorized by this chapter or as may be authorized after ","children":[{"tag":"date","attrib":{"date":"1976-04-05"},"text":"April 5, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab476657-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8732/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction and operation of facilities both within and outside the naval petroleum reserves incident to the production and the delivery of petroleum, including pipelines and shipping terminals.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Sums appropriated for such purposes shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab476658-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts under this chapter providing for the obligation of funds may be entered into for a period of five years, renewable for an additional five-year period; however, such contracts may obligate funds only to the extent that such funds are made available in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab476659-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/461"},"text":"70A Stat. 461","children":[],"tail":", § 7432; "},{"tag":"ref","attrib":{"href":"/us/pl/87/796/s1/8"},"text":"Pub. L. 87–796, § 1(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/905"},"text":"76 Stat. 905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/258/tII/s201/13"},"text":"Pub. L. 94–258, title II, § 201(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-05"},"text":"Apr. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/312"},"text":"90 Stat. 312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/137/s3/b/1"},"text":"Pub. L. 96–137, § 3(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-12"},"