l":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s1142"},"text":"34 U.S.C. 1142","children":[],"tail":" and this section reflect the "},{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch413/s13"},"text":"Act of March 3, 1899, ch. 413, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1007"},"text":"30 Stat. 1007","children":[],"tail":", which repealed laws authorizing distribution of prize proceeds to captors, and the "},{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch214/s1"},"text":"Act of May 29, 1920, ch. 214, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/654"},"text":"41 Stat. 654","children":[],"tail":", which requires substitution of “Treasurer of the United States or public depositary” for “assistant treasurer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab50dcc6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab50dcc7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7664"},"text":"section 7664 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab50dcc8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}