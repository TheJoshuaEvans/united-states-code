{"tag":"section","attrib":{"id":"idab50dcbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864"},"text":null,"children":[{"tag":"num","attrib":{"value":"8864"},"text":"§ 8864.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of property on stipulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab50dcbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Prize property may be delivered to a claimant on stipulation, deposit, or other security, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab50dcbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimant satisfies the court that the property has a peculiar and intrinsic value to him, independent of its market value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dcbe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court is satisfied that the rights and interests of the United States or of other claimants will not be prejudiced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dcbf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opportunity is given to the United States attorney and the naval prize commissioner or the naval special prize commissioner to be heard as to the appointment of appraisers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab50dcc0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a satisfactory appraisal is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab50dcc1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8864/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money collected on a stipulation, or deposited instead of it, that does not represent costs shall be deposited with the Treasurer of the United States or a public depositary in the same manner as proceeds of a sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab50dcc2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/479"},"text":"70A Stat. 479","children":[],"tail":", § 7664; renumbered § 8864, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/9"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1837"},"text":"132 Stat. 1837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab50dcc3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab50dcc4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab50dcc5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"te