{"tag":"section","attrib":{"id":"idab31e254-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551"},"text":null,"children":[{"tag":"num","attrib":{"value":"8551"},"text":"§ 8551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and operation of the Naval Innovation Center at the Naval Postgraduate School","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab31e255-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Support the Naval Innovation Center","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab31e256-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may enter into a contract or other agreement with one or more eligible nonprofit organizations for the design, construction, and maintenance of a multipurpose facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab31e257-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be known as the “Naval Innovation Center” (in this section referred to as the “NIC”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab31e258-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be located at the United States Naval Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e259-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The NIC shall be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab31e25a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to convene interested persons to develop and accelerate the adoption of new and innovative technologies and practices for the benefit of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab31e25b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support such education, training, research, and associated activities, as determined by the Secretary, in support of the Naval Postgraduate School and the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e25c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the contract or other agreement described in subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab31e25d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept funds from a partner organization for any phase of development of the NIC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e25e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept funds, personal property, or services from a covered entity that is not a partner organization for maintenance of the NIC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e25f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Accept Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab31e260-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy may accept, hold, administer, and spend any gift, device, or bequest of real property, personal property, services, or money on the condition that the gift, device, or bequest be used for the benefit, or in connection with, the establishment, operation, or maintenance of the NIC. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2601"},"text":"Section 2601 of this title","children":[],"tail":" (other than subsections (b), (c), and (e) of such section) shall apply to gifts accepted under this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e261-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may display at the NIC recognition for an individual or entity that contributes money to a partner organization or for a corporate partner that contributes money directly to the Navy for the benefit of the NIC, whether or not the contribution is subject to the condition that the recognition be provided. The Secretary shall prescribe regulations governing the circumstances under which contributor recognition may be provided, appropriate forms of recognition, and suitable display standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e262-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may authorize the sale of donated property received under paragraph (1). A sale under this paragraph need not be conducted in accordance with disposal requirements that would otherwise apply, so long as the sale is conducted at arms-length and includes an auditable transaction record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e263-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any money received under paragraph (1) and any proceeds from the sale of property under paragraph (3) shall be deposited into a fund established in the Treasury to support the NIC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e264-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may require such additional terms and conditions in connection with a contract or other agreement described in subsection (a) as the Secretary considers appropriate to protect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab31e265-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab31e266-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab31e267-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity incorporated or operating under the laws of any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab31e268-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e269-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible nonprofit organization” means an organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab31e26a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described in section 501(c)(3) of the Internal Revenue Code of 1986 and that is exempt from taxation under section 501(a) of such Code; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab31e26b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has as its primary purpose the support and operation of the Naval Postgraduate School.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab31e26c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8551/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “partner organization” means an eligible nonprofit organization with which the Secretary of the Navy enters into a contract or other agreement under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab31e26d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dB/tXXVIII/s2872"},"text":"Pub. L. 118–159, div. B, title XXVIII, § 2872","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2281"},"text":"138 Stat. 2281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab31e26e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab31e26f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab31e270-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (e)(2)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
