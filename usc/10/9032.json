n subsection (b)(1), the words “power, duty, or function of” are substituted for the words “power vested in, duty imposed upon, or function assigned to”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “all questions affecting” and “state of” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab5cc36e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab5cc36f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s806/c"},"text":"Pub. L. 115–232, § 806(c)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8032"},"text":"section 8032 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 9014” for “section 8014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s522/b/3"},"text":"Pub. L. 99–433, § 522(b)(3)","children":[],"tail":", substituted “The Air Staff: general duties” for “General duties” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s522/b/1"},"text":"Pub. L. 99–433, § 522(b)(1)","children":[],"tail":", inserted “of the Air Force” after “Chief of Staff”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433/s522/b/2"},"text":"Pub. L. 99–433, § 522(b)(2)","children":[],"tail":", substituted “Under the authority, direction, and control of the Secretary of the Air Force, the Air Staff” for “The Air Staff” before par. (1), inserted “subject to subsections (c) and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8014"},"text":"section 8014 of this title","children":[],"tail":",” and substituted “(including those aspects of research and development assigned by the Secretary of the Air Force), training, servicing, mobilizing, demobilizing, administering, and maintaining” for “, training, serving, mobilizing, and demobilizing” in par. (1), substituted “to support military operations by combatant commands” for “for military operations” in par. (2), and amended par. (4) generally. Prior to amendment, par. (4) read as follows: “act as agent of the Secretary and the Chief of Staff in coordinating the action of all organizations of the Department of the Air Force; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/599"},"text":"Pub. L. 85–599","children":[],"tail":" substituted “prepare for such employment of the Air Force” for “prepare such plans for the national security, for employment of the Air Force for that purpose, both separately and in conjunction with the land and naval forces”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab5cc370-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab5cc371-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{