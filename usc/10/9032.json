{"tag":"section","attrib":{"id":"idab5cc362-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032"},"text":null,"children":[{"tag":"num","attrib":{"value":"9032"},"text":"§ 9032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Air Staff: general duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab5cc363-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Air Staff shall furnish professional assistance to the Secretary, the Under Secretary, and the Assistant Secretaries of the Air Force, and the Chief of Staff of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab5cc364-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under the authority, direction, and control of the Secretary of the Air Force, the Air Staff shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab5cc365-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9014"},"text":"section 9014 of this title","children":[],"tail":", prepare for such employment of the Air Force, and for such recruiting, organizing, supplying, equipping (including those aspects of research and development assigned by the Secretary of the Air Force), training, servicing, mobilizing, demobilizing, administering, and maintaining of the Air Force, as will assist in the execution of any power, duty, or function of the Secretary or the Chief of Staff;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc366-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate and report upon the efficiency of the Air Force and its preparation to support military operations by combatant commands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc367-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare detailed instructions for the execution of approved plans and supervise the execution of those plans and instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc368-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as directed by the Secretary or the Chief of Staff, coordinate the action of organizations of the Air Force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab5cc369-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9032/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties, not otherwise assigned by law, as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab5cc36a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/490"},"text":"70A Stat. 490","children":[],"tail":", § 8032; "},{"tag":"ref","attrib":{"href":"/us/pl/85/599/s4/h"},"text":"Pub. L. 85–599, § 4(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/517"},"text":"72 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s522/b"},"text":"Pub. L. 99–433, title V, § 522(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1060"},"text":"100 Stat. 1060","children":[],"tail":"; renumbered § 9032 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 806(c), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1833"},"text":"132 Stat. 1833","children":[],"tail":", 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab5cc36b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab5cc36c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab5cc36d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}]