{"tag":"section","attrib":{"id":"ida9550d1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2229b"},"text":"§ 2229b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for contested logistics posture management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9550d1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Deputy Secretary of Defense, the Vice Chair of the Joint Chiefs of Staff, and the Commander of the United States Transportation Command shall be responsible for the integration of global contested logistics posture management. Such responsibilities shall include each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9550d1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying vulnerabilities and risks across the Department of Defense enterprise for the core logistics capabilities of supply, maintenance operations, prepositioned stocks, deployment and distribution, health services support, engineering, logistics services, and operational service contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9550d1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and executing a strategy to mitigate the vulnerabilities and risks identified under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9550d1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Integrating and deconflicting global contested logistics posture investment and management across the military departments, including with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9550d20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the locations of sites outside the continental United States at which stocks of supplies and equipment are stored as well as the composition of those stocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of adequate intra-theater sea and air capability to move material and personnel throughout the theater; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monitoring and coordination of resourcing decisions by the military departments in support of operational plans and contingencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9550d23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deputy Management Action Group Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the responsibilities under subsection (a)(1) and (2), the Deputy Secretary of Defense and the Vice Chair of the Joint Chiefs of Staff shall co-chair at least two Deputy Management Action Group meetings each year, which shall be focused on contested logistics management and investment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9550d24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contested Logistics Posture Strategy","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9550d25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Secretary of Defense, the Vice Chair of the Joint Chiefs of Staff, and the Commander of the United States Transportation Command, in coordination with any other Department official identified by the Secretary, shall develop and implement a strategy for carrying out the responsibilities described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9550d26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The strategy required under paragraph (1) shall include each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9550d27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9550d28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the locations of sites outside the continental United States at which stocks of supplies and equipment are prepositioned as of the date of the strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9550d29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status and disposition of such prepositioned stocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9550d2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operational or contingency plan such stocks are intended to support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An identification of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9550d2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any shortcomings associated with the sites and prepositioned stocks described in subparagraph (A) that must be addressed to optimally execute operational and contingency plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9550d2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional sites, infrastructure, or equipment that may be needed to address such shortcomings and support such plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of any additional funding or other resources required—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9550d2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address the shortcomings identified under subparagraph (B)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9550d30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the additional sites, infrastructure, and equipment identified under subparagraph (B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prioritized list of investment recommendations for each item described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of each case in which the military department concerned lacks the authority or ability to access a location outside the United States for purposes of providing logistics support as required under operational and contingency plans, set forth separately by location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9550d33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of any existing and projected threats to sites outside the continental United States that are expected to support such operational and contingency plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9550d34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The strategy required under paragraph (1) shall cover the period of two years following the date of the strategy and shall be updated on an biennial basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9550d35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this section, and quarterly thereafter until ","children":[{"tag":"date","attrib":{"date":"2031-12-31"},"text":"December 31, 2031","children":[],"tail":", the Deputy Secretary of Defense, the Vice Chair of the Joint Chiefs of Staff, and the Commander of the United States Transportation Command, or their representatives, shall provide to the Committees on Armed Services of the Senate and House of Representatives a briefing on the execution of the responsibilities under subsection (a)(1) and (2), including updates on the development and implementation of the strategy required under subsection (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9550d36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2229b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget Justification Materials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall include in the budget justification materials submitted to Congress in support of the budget of the President for a fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", United States Code, a cumulative accounting of contested logistics investments represented in such budget and how such investments relate to the duties and responsibilities under subsection (a)(1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9575627-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s334/a"},"text":"Pub. L. 119–60, div. A, title III, § 334(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/816"},"text":"139 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9575628-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9575629-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida957562a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved on "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida957562b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2229b was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3072"},"text":"section 3072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida957562c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida957562d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s334/b"},"text":"Pub. L. 119–60, div. A, title III, § 334(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/818"},"text":"139 Stat. 818","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tIII/s334/b"},"text":"“The development of the strategy required under subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2229b"},"text":"section 2229b of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall be completed by not later than "},{"tag":"date","attrib":{"date":"2027-01-31"},"text":"January 31, 2027","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
