{"tag":"section","attrib":{"id":"idaabab75b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management structure for nuclear security enterprise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaabab75c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish a management structure for the nuclear security enterprise in accordance with the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"50 U.S.C. 2401","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab75d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Nuclear Security Administration Council","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaabab75e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall establish a council to be known as the “National Nuclear Security Administration Council”. The Council may advise the Administrator on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab75f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific and technical issues relating to policy matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab760-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab761-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategic planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of priorities relating to the mission and operations of the Administration and the nuclear security enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab763-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council shall be composed of the directors of the national security laboratories and the nuclear weapons production facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council may provide the Administrator or the Secretary of Energy recommendations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaabab766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for improving the governance, management, effectiveness, and efficiency of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaabab767-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to any other matter in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaabab768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 60 days after the date on which any recommendation under paragraph (3) is received, the Administrator or the Secretary, as the case may be, shall respond to the Council with respect to whether such recommendation will be implemented and the reasoning for implementing or not implementing such recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaabab769-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may not be construed as affecting the authority of the Secretary of Energy, in carrying out national security programs, with respect to the management, planning, and oversight of the Administration or as affecting the delegation by the Secretary of authority to carry out such activities, as set forth under subsection (a) of section 4102 of the Atomic Energy Defense Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"50 U.S.C. 2512","children":[],"tail":") as it existed before the date of the enactment of the National Defense Authorization Act for Fiscal Year 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Public Law 112–239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/126/2169"},"text":"126 Stat. 2169","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaabab76a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (d)(2)(B), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1340"},"text":"139 Stat. 1340","children":[],"tail":", 1462.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaabab76b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaabab76c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idaabab76d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Nuclear Security Administration Act, referred to in subsec. (a), is title XXXII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC"},"text":"Pub. L. 106–65, div. C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/953"},"text":"113 Stat. 953","children":[],"tail":", which is classified principally to chapter 41 (§ 2401 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"section 2401 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4102 of the Atomic Energy Defense Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"50 U.S.C. 2512","children":[],"tail":") as it existed before the date of the enactment of the National Defense Authorization Act for Fiscal Year 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Public Law 112–239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/126/2169"},"text":"126 Stat. 2169","children":[],"tail":"), referred to in subsec. (c), means "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s4102"},"text":"section 4102 of Pub. L. 107–314","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"section 2512 of Title 50","children":[],"tail":", War and National Defense, as it existed before the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", which amended that section generally and was approved "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"Section 2512 of Title 50","children":[],"tail":" was repealed and restated as this section by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1340"},"text":"139 Stat. 1340","children":[],"tail":", 1458."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaabab76e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2512"},"text":"section 2512 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaabab76f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/d/2/B"},"text":"Pub. L. 119–60, § 3111(d)(2)(B)","children":[],"tail":", realigned margins."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaabab770-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaabab771-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Governance and Management of Nuclear Security Enterprise","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dC/tXXXI/s3137"},"text":"Pub. L. 114–92, div. C, title XXXI, § 3137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1213"},"text":"129 Stat. 1213","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/c/2/F"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(c)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1460"},"text":"139 Stat. 1460","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dC/tXXXI/s3111/c/2/F"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correcting the longstanding problems with the governance and management of the nuclear security enterprise will require robust, personal, and long-term engagement by the President, the Secretary of Energy, the Administrator for Nuclear Security, and leaders from the appropriate congressional committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recent and past studies of the governance and management of the nuclear security enterprise have provided a list of reasonable, practical, and actionable steps that the Secretary and the Administrator should take to make the nuclear security enterprise more efficient and more effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lasting and effective change to the nuclear security enterprise will require personal engagement by senior leaders, a clear plan, and mechanisms for ensuring follow-through and accountability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation action team","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary and the Administrator shall jointly establish a team of senior officials from the Department of Energy and the National Nuclear Security Administration to develop and carry out an implementation plan to reform the governance and management of the nuclear security enterprise to improve the effectiveness and efficiency of the nuclear security enterprise. Such plan shall be developed and implemented in accordance with the National Nuclear Security Administration Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2401"},"text":"50 U.S.C. 2401","children":[],"tail":" et seq.), the Atomic Energy Defense Act ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2501"},"text":"50 U.S.C. 2501","children":[],"tail":" et seq. [see "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6101"},"text":"10 U.S.C. 6101","children":[],"tail":" et seq.]), and any other provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The team established under paragraph (1) shall be co-chaired by the Deputy Secretary of Energy and the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In developing and carrying out the implementation plan, the team shall consult with the implementation assessment panel established under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The implementation plan developed under paragraph (1)(A) shall address all recommendations contained in the covered study (except such recommendations that require legislative action to carry out) by identifying specific actions, milestones, timelines, and responsible personnel to implement such plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-03-31"},"text":"March 31, 2016","children":[],"tail":", the Secretary and the Administrator shall jointly submit to the appropriate congressional committees the implementation plan developed under paragraph (1)(A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Assessment Panel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":"], the Administrator shall seek to enter into a joint agreement with the National Academy of Sciences and the National Academy of Public Administration to establish a panel of external, independent experts to evaluate the implementation plan developed under subsection (b)(1)(A) and the implementation of such plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panel established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance to the Secretary and the Administrator with respect to the implementation plan developed under subsection (b)(1)(A), including how such plan compares or contrasts with the covered study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track the implementation of such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the effectiveness of such plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2016-07-01"},"text":"July 1, 2016","children":[],"tail":", the panel established under paragraph (1) shall submit to the appropriate congressional committees, the Secretary, and the Administrator an initial assessment of the implementation plan developed under subsection (b)(1)(A), including with respect to the completeness of the plan, how the plan aligns with the intent and recommendations made by the covered study, and the prospects for success for the plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning ","children":[{"tag":"date","attrib":{"date":"2017-02-28"},"text":"February 28, 2017","children":[],"tail":", and semiannually thereafter through 2020, the panel established under paragraph (1) shall brief the appropriate congressional committees, the Secretary, and the Administrator on the efforts of the Secretary and the Administrator to implement the implementation plan developed under subsection (b)(1)(A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", the panel established under paragraph (1) shall submit to the appropriate congressional committees, the Secretary, and the Administrator a final report on the efforts of the Secretary and the Administrator to implement the implementation plan developed under subsection (b)(1)(A), including an assessment of the effectiveness of the reform efforts under such plan and whether further action is needed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Administrator shall provide to the panel established under paragraph (1) full and timely access to all information, personnel, and systems of the Department of Energy and the National Nuclear Security Administration that the panel determines necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Appropriations, and the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on Appropriations, and the Committee on Energy and Commerce of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘covered study’ means the following:","children":[],"tail":null},{