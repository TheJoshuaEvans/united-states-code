{"tag":"section","attrib":{"id":"idabca79b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244"},"text":null,"children":[{"tag":"num","attrib":{"value":"20244"},"text":"§ 20244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for consideration for promotion: duty assignments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabca79b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Air Force shall prescribe regulations to ensure that an officer on the Space Force officer list is not considered for promotion to the grade of brigadier general unless the officer has completed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca79b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duty assignment with a command or other organization that has responsibility for acquisition matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca79b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duty assignment with a command or other organization that has responsibility for operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabca79b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idabca79b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Air Force shall prescribe the regulations required under subsection (a) not later than one year after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2026; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabca79ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations required under subsection (a) shall apply to officers considered for promotion to brigadier general on or after ","children":[{"tag":"date","attrib":{"date":"2035-01-01"},"text":"January 1, 2035","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabcce9bb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1601/d/1"},"text":"Pub. L. 119–60, div. A, title XVI, § 1601(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1174"},"text":"139 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabcce9bc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabcce9bd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabcce9be-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2026, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
