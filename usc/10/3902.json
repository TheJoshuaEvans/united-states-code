{"tag":"section","attrib":{"id":"idaa411a7f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902"},"text":null,"children":[{"tag":"num","attrib":{"value":"3902"},"text":"§ 3902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit for Indian contracting in meeting certain subcontracting goals for small disadvantaged businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa411a80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (c), in any case in which a subcontracting goal is specified in a Department of Defense contract in the implementation of section 8(d) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"15 U.S.C. 637(d)","children":[],"tail":"), credit toward meeting that subcontracting goal shall be given for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa411a81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work performed in connection with that Department of Defense contract, and work performed in connection with any subcontract awarded under that Department of Defense contract, if such work is performed on any Indian lands and meets the requirements of paragraph (1) of subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa411a82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work performed in connection with that Department of Defense contract, and work performed in connection with any subcontract awarded under that Department of Defense contract, if the performance of such contract or subcontract is undertaken as a joint venture that meets the requirements of paragraph (2) of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa411a83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Work","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa411a84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Work performed on Indian lands meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa411a85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 40 percent of the workers directly engaged in the performance of the work are Indians; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa411a86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contractor or subcontractor has an agreement with the tribal government having jurisdiction over such Indian lands that provides goals for training and development of the Indian workforce and Indian management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa411a87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A joint venture undertaking to perform a contract or subcontract meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idaa411a88-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe or tribally owned corporation owns at least 50 percent of the joint venture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa411a89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of the joint venture under the contract or subcontract provide employment opportunities for Indians either directly or through the purchase of products or services for the performance of such contract or subcontract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idaa411a8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe or tribally owned corporation manages the performance of such contract or subcontract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa411a8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extent of Credit","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the credit given toward the attainment of any subcontracting goal under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa411a8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of work performed as described in subsection (a)(1), the value of the work performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa411a8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract or subcontract undertaken to be performed by a joint venture as described in subsection (a)(2), an amount equal to the amount of the contract or subcontract multiplied by the percentage of the tribe’s or tribally owned corporation’s ownership interest in the joint venture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa411a8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations for the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa411a8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa411a90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian lands” has the meaning given that term by section 4(4) of the Indian Gaming Regulatory Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/4"},"text":"25 U.S.C. 2703(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa411a91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian” has the meaning given that term by section 4(d) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/d"},"text":"25 U.S.C. 5304(d)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa411a92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Indian tribe” has the meaning given that term by section 4(e) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"25 U.S.C. 5304(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa411a93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3902/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “tribally owned corporation” means a corporation owned entirely by an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa411a94-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s801/g/1"},"text":"Pub. L. 102–484, div. A, title VIII, § 801(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2445"},"text":"106 Stat. 2445","children":[],"tail":", § 2323a; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1074/a/13"},"text":"Pub. L. 104–201, div. A, title X, § 1074(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2659"},"text":"110 Stat. 2659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s812/a/2/C/vii"},"text":"Pub. L. 115–232, div. A, title VIII, § 812(a)(2)(C)(vii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1847"},"text":"132 Stat. 1847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXVII/s1731/a/39/B"},"text":"Pub. L. 116–92, div. A, title XVII, § 1731(a)(39)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1814"},"text":"133 Stat. 1814","children":[],"tail":"; renumbered § 3902, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1838/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1838(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4242"},"text":"134 Stat. 4242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/v/2/A"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(v)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2154"},"text":"135 Stat. 2154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa411a95-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa411a96-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa411a97-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", consists of text of "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVIII/s832"},"text":"Pub. L. 101–189, div. A, title VIII, § 832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1508"},"text":"103 Stat. 1508","children":[],"tail":", revised by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" by substituting “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2323"},"text":"section 2323 of this title","children":[],"tail":"” for “section 1207 of the National Defense Authorization Act for Fiscal Year 1987 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2301"},"text":"10 U.S.C. 2301","children":[],"tail":" note)” in subsec. (a). "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/s832"},"text":"Section 832 of Pub. L. 101–189","children":[],"tail":", which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2301"},"text":"section 2301 of this title","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s801/h/5"},"text":"Pub. L. 102–484, div. A, title VIII, § 801(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2445"},"text":"106 Stat. 2445","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa411a98-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1838/b"},"text":"Pub. L. 116–283, § 1838(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/v/2/A"},"text":"Pub. L. 117–81, § 1701(v)(2)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2323a"},"text":"section 2323a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/39/B/i"},"text":"Pub. L. 116–92, § 1731(a)(39)(B)(i)","children":[],"tail":", struck out “and certain institutions of higher education” after “businesses” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/39/B/ii/I"},"text":"Pub. L. 116–92, § 1731(a)(39)(B)(ii)(I)","children":[],"tail":", struck out “"},{"tag":"ref","attrib":{"href":"/us/stat/102/2468"},"text":"102 Stat. 2468","children":[],"tail":";” before “"},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/4"},"text":"25 U.S.C. 2703(4)","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/39/B/ii/II"},"text":"Pub. L. 116–92, § 1731(a)(39)(B)(ii)(II)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/d"},"text":"25 U.S.C. 5304(d)","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b/d"},"text":"25 U.S.C. 450b(d)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1731/a/39/B/ii/III"},"text":"Pub. L. 116–92, § 1731(a)(39)(B)(ii)(III)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"25 U.S.C. 5304(e)","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b/e"},"text":"25 U.S.C. 450b(e)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2323"},"text":"section 2323 of this title","children":[],"tail":" and” after “implementation of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", which directed amendment of subsec. (a) by substituting “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2323"},"text":"section 2323 of this title","children":[],"tail":"” for “section 1207 of the National Defense Authorization Act for Fiscal Year 1987 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2301"},"text":"10 U.S.C. 2301","children":[],"tail":" note)”, could not be executed because the language “section 1207 of the National Defense Authorization Act for Fiscal Year 1987 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2301"},"text":"10 U.S.C. 2301","children":[],"tail":" note)” did not appear. See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa411a99-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa411a9a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
