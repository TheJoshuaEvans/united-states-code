{"tag":"section","attrib":{"id":"ida7e354c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603"},"text":null,"children":[{"tag":"num","attrib":{"value":"603"},"text":"§ 603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments in time of war or national emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7e354c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In time of war, or of national emergency declared by the Congress or the President after ","children":[{"tag":"date","attrib":{"date":"1980-11-30"},"text":"November 30, 1980","children":[],"tail":", the President may appoint any qualified person (whether or not already a member of the armed forces) to any officer grade in the Army, Navy, Air Force, Marine Corps, or Space Force, except that appointments under this section may not be made in grades above major general or rear admiral. Appointments under this section shall be made by the President alone, except that an appointment in the grade warrant officer, W–1, shall be made by warrant by the Secretary concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any appointment under this section is a temporary appointment and may be vacated by the President at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e354cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person receiving an original appointment under this section is entitled to service credit as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s533"},"text":"section 533 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appointment under this section of a person who is not on active duty becomes effective when that person begins active duty under that appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appointment under this section does not change the permanent status of a member of the armed forces so appointed. A member who is appointed under this section shall not incur any reduction in the pay and allowances to which the member was entitled, by virtue of his permanent status, at the time of his appointment under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e354d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who receives an appointment to a higher grade under this section is considered to have accepted such appointment on the date of the order announcing the appointment unless he expressly declines the appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who has served continuously since he subscribed to the oath of office prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of title 5","children":[],"tail":" is not required to take a new oath upon appointment to a higher grade under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7e354d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless sooner terminated, an appointment under this section terminates on the earliest of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7e354d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The second anniversary of the appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The end of the six-month period beginning on the last day of the war or national emergency during which the appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7e354d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s603/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date the person appointed is released from active duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7e354d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2850"},"text":"94 Stat. 2850","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVI/s653/a/2"},"text":"Pub. L. 101–189, div. A, title VI, § 653(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1462"},"text":"103 Stat. 1462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tXI/s1113/b"},"text":"Pub. L. 102–190, div. A, title XI, § 1113(b)","children":[],"tail":", (d)(1)(A), "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1502"},"text":"105 Stat. 1502","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/3/D"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3821"},"text":"134 Stat. 3821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7e354d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7e354d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7e354d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, or Space Force” for “or Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1113/d/1/A"},"text":"Pub. L. 102–190, § 1113(d)(1)(A)","children":[],"tail":", substituted “Appointments in time of war or national emergency” for “Commissioned officer grades: time of war or national emergency” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1113/b"},"text":"Pub. L. 102–190, § 1113(b)","children":[],"tail":", struck out “commissioned” before “officer grade in the Army” and “in warrant officer grades or” before “in grades above major general” and inserted before period at end “, except that an appointment in the grade warrant officer, W–1, shall be made by warrant by the Secretary concerned”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “terminates on the earliest of the following:” for “terminates—” in introductory provisions, and made numerous amendments to style and punctuation. Prior to amendment, subsec. (f) read as follows: “Unless sooner terminated, an appointment under this section terminates—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) on the second anniversary of the appointment;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) at the end of the six-month period beginning on the last day of the war or national emergency during which the appointment was made; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) on the date the person appointed is released from active duty;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"whichever is earliest.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7e354da-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7e354db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1132"},"text":"section 1132 of Pub. L. 102–190","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s521"},"text":"section 521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7e354dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under this section effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida7e354dd-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ida7e354de-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsecs. (a) and (b) to make or vacate certain temporary commissioned appointments delegated to Secretary of Defense to perform during a time of war or national emergency, without approval, ratification, or other action by President, and with authority for Secretary to redelegate, provided that, during a national emergency declared by President, exercise of any such authority be specifically directed by President in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1631"},"text":"section 1631 of Title 50","children":[],"tail":", War and National Defense, and that Secretary ensure any authority so delegated be accounted for as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1641"},"text":"section 1641 of Title 50","children":[],"tail":", see Ex. Ord. No. 12396, §§ 2, 3, "},{"tag":"date","attrib":{"date":"1982-12-09"},"text":"Dec. 9, 1982","children":[],"tail":", 47 F.R. 55897, 55898, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"ida7e354df-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 13321. Appointments During National Emergency","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13321, ","children":[{"tag":"date","attrib":{"date":"2003-12-17"},"text":"Dec. 17, 2003","children":[],"tail":", 68 F.R. 74465, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including the National Emergencies Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" "},{"tag":"i","attrib":{},"text":"et seq","children":[],"tail":".), and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, and in order to further respond to the national emergency I declared in Proclamation 7463 of "},{"tag":"date","attrib":{"date":"2001-09-14"},"text":"September 14, 2001","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1621"},"text":"50 U.S.C. 1621","children":[],"tail":" note], I hereby order as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"Emergency Appointments Authority","children":[],"tail":". The emergency appointments authority at "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s603"},"text":"section 603 of title 10","children":[],"tail":", United States Code, is invoked and made available to the Secretary of Defense in accordance with the terms of that statute and of Executive Order 12396 of "},{"tag":"date","attrib":{"date":"1982-12-09"},"text":"December 9, 1982","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"3 U.S.C. 301","children":[],"tail":" note]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. "},{"tag":"i","attrib":{},"text":"Judicial Review","children":[],"tail":". This order is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by a party against the United States, its departments, agencies, entities, officers, employees or agents, or any person."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. "},{"tag":"i","attrib":{},"text":"Administration","children":[],"tail":". This order shall be transmitted to the Congress and published in the Federal Register."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George W. Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
