119/60/dA/tX/s1014"},"text":"Pub. L. 119–60, div. A, title X, § 1014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1031"},"text":"139 Stat. 1031","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3dca85-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3dca86-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3dca87-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1014/1"},"text":"Pub. L. 119–60, § 1014(1)","children":[],"tail":", substituted “United States, Guam, or Commonwealth of the Northern Mariana Islands” for “United States or Guam” in heading and “the United States, Guam, or the Commonwealth of the Northern Mariana Islands” for “the United States or Guam” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1014/2"},"text":"Pub. L. 119–60, § 1014(2)","children":[],"tail":", substituted “the United States, Guam, or the Commonwealth of the Northern Mariana Islands” for “the United States or Guam”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" designated existing provisions as subpar. (A), redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), inserted “and subject to subparagraph (B)” after “paragraph (1)” in introductory provisions of subpar. (A), and added cl. (iii) of subpar. (A) and subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1025/a/1"},"text":"Pub. L. 116–283, § 1025(a)(1)","children":[],"tail":", struck out “, other than in the case of voyage repairs” after “outside the United States or Guam”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1025/b"},"text":"Pub. L. 116–283, § 1025(b)","children":[],"tail":", designated existing provisions as subcl. (I) and added subcls. (II) and (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", §§ 1025(c), 1081(a)(45), amended introductory provisions identically, striking out period after “means—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1025/a/2"},"text":"Pub. L. 116–283, § 1025(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1035/1"},"text":"Pub. L. 116–92, § 1035(1)","children":[],"tail":", substituted “means—” for “means preservation or corrosion control efforts and cleaning services” and added subcls. (I) to (III)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1035/2"},"text":"Pub. L. 116–92, § 1035(2)","children":[],"tail":", struck ou