g":"html:p","attrib":{},"text":"34 App.:183b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-24/ch692/s1"},"text":"July 24, 1956, ch. 692, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/631"},"text":"70 Stat. 631","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida840679e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida840679f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":"” for “the date of the enactment of the National Defense Authorization Act for Fiscal Year 1996” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s561/c/1"},"text":"Pub. L. 104–106, § 561(c)(1)","children":[],"tail":", substituted “Members: effect of time lost” for “Enlisted members: required to make up time lost” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s561/a"},"text":"Pub. L. 104–106, § 561(a)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, added par. (3), redesignated par. (5) as (4), struck out former pars. (3) and (4), and added subsec. (b). Prior to amendment, subsec. (a)(3) and (4) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) is confined for more than one day while awaiting trial and disposition of his case, and whose conviction has become final;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) is confined for more than one day under a sentence that has become final; or”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida84067a0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida84067a1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s561/e"},"text":"Pub. L. 104–106, div. A, title V, § 561(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/323"},"text":"110 Stat. 323","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/106/dA/tV/s561/e"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s6328"},"text":"section 6328 of this title","children":[],"tail":" and amending this section and sections 1405, 3925, 3926, 8925, and 8926 of this title] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":"] and shall apply to any period of time covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s972"},"text":"section 972 of title 10","children":[],"tail":", United States Code, that occurs after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
