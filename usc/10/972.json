{"tag":"section","attrib":{"id":"ida83df788-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972"},"text":null,"children":[{"tag":"num","attrib":{"value":"972"},"text":"§ 972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members: effect of time lost","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida83df789-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enlisted Members Required To Make Up Time Lost","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An enlisted member of an armed force who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83df78a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deserts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df78b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is absent from his organization, station, or duty for more than one day without proper authority, as determined by competent authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df78c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is confined by military or civilian authorities for more than one day in connection with a trial, whether before, during, or after the trial; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df78d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unable for more than one day, as determined by competent authority, to perform his duties because of intemperate use of drugs or alcoholic liquor, or because of disease or injury resulting from his misconduct;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is liable, after his return to full duty, to serve for a period that, when added to the period that he served before his absence from duty, amounts to the term for which he was enlisted or inducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83df78e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers Not Allowed Service Credit for Time Lost","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an officer of an armed force who after ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83df78f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deserts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df790-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is absent from his organization, station, or duty for more than one day without proper authority, as determined by competent authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df791-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is confined by military or civilian authorities for more than one day in connection with a trial, whether before, during, or after the trial; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df792-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unable for more than one day, as determined by competent authority, to perform his duties because of intemperate use of drugs or alcoholic liquor, or because of disease or injury resulting from his misconduct;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the period of such desertion, absence, confinement, or inability to perform duties may not be counted in computing, for any purpose other than basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s205"},"text":"section 205 of title 37","children":[],"tail":", the officer’s length of service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida83df793-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Recoupment of Time Lost for Confinement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall waive liability for a period of confinement in connection with a trial under subsection (a)(3), or exclusion of a period of confinement in connection with a trial under subsection (b)(3), in a case upon the occurrence of any of the following events:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida83df794-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each charge—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida83df795-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charge is dismissed before or during trial in a final disposition of the charge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida83df796-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trial results in an acquittal of the charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida83df797-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each charge resulting in a conviction in such trial—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida83df798-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conviction is set aside in a final disposition of such charge, other than in a grant of clemency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8406799-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s972/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judgment of acquittal or a dismissal is entered upon a reversal of the conviction on appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida840679a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s1/20"},"text":"Pub. L. 85–861, § 1(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1443"},"text":"72 Stat. 1443","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s561/a"},"text":"Pub. L. 104–106, div. A, title V, § 561(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/321"},"text":"110 Stat. 321","children":[],"tail":", 322; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/a/14"},"text":"Pub. L. 105–85, div. A, title X, § 1073(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1900"},"text":"111 Stat. 1900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s572"},"text":"Pub. L. 108–375, div. A, title V, § 572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1921"},"text":"118 Stat. 1921","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida840679b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida84067