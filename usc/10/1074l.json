{"tag":"section","attrib":{"id":"ida8773020-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074l"},"text":null,"children":[{"tag":"num","attrib":{"value":"1074l"},"text":"§ 1074l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress of hospitalization of combat wounded members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8773021-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall provide notification of the hospitalization of any member of the armed forces evacuated from a theater of combat and admitted to any military medical treatment facility to the appropriate Members of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8773022-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “appropriate Members of Congress”, with respect to the member of the armed forces about whom notification is being made, means the Senators representing the State, and the Member, Delegate, or Resident Commissioner of the House of Representatives representing the district, that includes the member’s home of record or a different location as provided by the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8773023-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1074l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent of Member Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The notification under subsection (a) may be provided only with the consent of the member of the armed forces about whom notification is to be made. In the case of a member who is unable to provide consent, information and consent may be provided by next of kin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8773024-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVI/s1617/a/1"},"text":"Pub. L. 110–181, div. A, title XVI, § 1617(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/449"},"text":"122 Stat. 449","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVII/s720"},"text":"Pub. L. 115–232, div. A, title VII, § 720","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1817"},"text":"132 Stat. 1817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8773025-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8773026-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8773027-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “admitted to any military medical treatment facility” for “admitted to a military treatment facility within the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8773028-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8773029-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVI/s1617/a/2"},"text":"Pub. L. 110–181, div. A, title XVI, § 1617(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/449"},"text":"122 Stat. 449","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tXVI/s1617/a/2"},"text":"“The notification requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1074l/a"},"text":"section 1074l(a) of title 10","children":[],"tail":", United States Code, as added by paragraph (1), shall apply beginning 60 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
