{"tag":"section","attrib":{"id":"ida7ef6194-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s626"},"text":null,"children":[{"tag":"num","attrib":{"value":"626"},"text":"§ 626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of promotions; oath of office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7ef6195-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s626/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who is appointed to a higher grade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s624"},"text":"section 624 of this title","children":[],"tail":" is considered to have accepted such appointment on the date on which the appointment is made unless he expressly declines the appointment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7ef6196-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s626/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer who has served continuously since he subscribed to the oath of office prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of title 5","children":[],"tail":" is not required to take a new oath upon appointment to a higher grade under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s624"},"text":"section 624 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7ef6197-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2858"},"text":"94 Stat. 2858","children"