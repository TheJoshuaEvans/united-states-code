ity of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa863a26-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1234/c"},"text":"Pub. L. 98–525, title XII, § 1234(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2604"},"text":"98 Stat. 2604","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/525/tXII/s1234/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2402"},"text":"Section 2402 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4655"},"text":"10 U.S.C. 4655","children":[],"tail":"] (as added by subsection (a)), shall take effect at the end of the 180-day period beginning on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
