{"tag":"section","attrib":{"id":"idaa863a14-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655"},"text":null,"children":[{"tag":"num","attrib":{"value":"4655"},"text":"§ 4655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of contractors limiting subcontractor sales directly to the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa863a15-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contract for the purchase of supplies or services made by the Department of Defense shall provide that the contractor will not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a16-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into any agreement with a subcontractor under the contract that has the effect of unreasonably restricting sales by the subcontractor directly to the United States of any item or process (including computer software) made or furnished by the subcontractor under the contract (or any follow-on production contract); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise act to restrict unreasonably the ability of a subcontractor to make sales to the United States described in clause (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not prohibit a contractor from asserting rights it otherwise has under law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a contract that is for an amount not greater than the simplified acquisition threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa863a1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa863a1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agreement between the contractor in a contract for the acquisition of commercial products or commercial services and a subcontractor under such contract that restricts sales by such subcontractor directly to persons other than the contractor may not be considered to unreasonably restrict sales by that subcontractor to the United States in violation of the provision included in such contract pursuant to subsection (a) if the agreement does not result in the United States being treated differently with regard to the restriction than any other prospective purchaser of such commercial products or commercial services from that subcontractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa863a1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4655/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In paragraph (1), the terms “commercial product” and “commercial service” have the meanings given those terms in sections 103 and 103a, respectively, of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa863a1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXII/s1234/a"},"text":"Pub. L. 98–525, title XII, § 1234(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2601"},"text":"98 Stat. 2601","children":[],"tail":", § 2402; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tIV/s4102/f"},"text":"Pub. L. 103–355, title IV, § 4102(f)","children":[],"tail":", title VIII, § 8105(g), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3340"},"text":"108 Stat. 3340","children":[],"tail":", 3392; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/25"},"text":"Pub. L. 111–350, § 5(b)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3844"},"text":"124 Stat. 3844","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s836/e/4"},"text":"Pub. L. 115–232, div. A, title VIII, § 836(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1869"},"text":"132 Stat. 1869","children":[],"tail":"; renumbered § 4655, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1862/b"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1862(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4277"},"text":"134 Stat. 4277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa863a1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa863a1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaa863a20-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4655 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s7655"},"text":"section 7655 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa863a21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2402"},"text":"section 2402 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/e/4/A"},"text":"Pub. L. 115–232, § 836(e)(4)(A)","children":[],"tail":", substituted “commercial products or commercial services” for “commercial items” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s836/e/4/B"},"text":"Pub. L. 115–232, § 836(e)(4)(B)","children":[],"tail":", substituted “the terms ‘commercial product’ and ‘commercial service’ have the meanings given those terms in sections 103 and 103a, respectively, of title 41.” for “the term ‘commercial item’ has the meaning given such term in "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/25/A"},"text":"Pub. L. 111–350, § 5(b)(25)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":")” for “section 4(11) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/11"},"text":"41 U.S.C. 403(11)","children":[],"tail":"))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/b/25/B"},"text":"Pub. L. 111–350, § 5(b)(25)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":"” for “section 4(12) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/12"},"text":"41 U.S.C. 403(12)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa863a22-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmend