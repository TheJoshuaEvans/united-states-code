{"tag":"section","attrib":{"id":"ida834817b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948i"},"text":null,"children":[{"tag":"num","attrib":{"value":"948i"},"text":"§ 948i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Who may serve on military commissions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida834817c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any commissioned officer of the armed forces on active duty is eligible to serve on a military commission under this chapter, including commissioned officers of the reserve components of the armed forces on active duty, commissioned officers of the National Guard on active duty in Federal service, or retired commissioned officers recalled to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida834817d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When convening a military commission under this chapter, the convening authority shall detail as members thereof such members of the armed forces eligible under subsection (a) who, in the opinion of the convening authority, are best qualified for the duty by reason of age, education, training, experience, length of service, and judicial temperament. No member of an armed force is eligible to serve as a member of a military commission when such member is the accuser or a witness for the prosecution or has acted as an investigator or counsel in the same case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida834817e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s948i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excuse of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a military commission under this chapter is assembled for the trial of a case, the convening authority may excuse a member from participating in the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida834817f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tXVIII/s1802"},"text":"Pub. L. 111–84, div. A, title XVIII, § 1802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2576"},"text":"123 Stat. 2576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8348180-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8348181-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida8348182-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 948i, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/366/s3/a/1"},"text":"Pub. L. 109–366, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2603"},"text":"120 Stat. 2603","children":[],"tail":", related to who may serve on military commissions, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
