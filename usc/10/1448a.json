{"tag":"section","attrib":{"id":"ida8cd1834-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1448a"},"text":"§ 1448a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election to discontinue participation: one-year opportunity after second anniversary of commencement of payment of retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8cd1835-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A participant in the Plan may, subject to the provisions of this section, elect to discontinue participation in the Plan at any time during the one-year period beginning on the second anniversary of the date on which payment of retired pay to the participant commences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd1836-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence of Spouse.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8cd1837-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A married participant may not (except as provided in paragraph (2)) make an election under subsection (a) without the concurrence of the participant’s spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8cd1838-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A participant may make such an election without the concurrence of the participant’s spouse by establishing to the satisfaction of the Secretary concerned that one of the conditions specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/a/3/C"},"text":"section 1448(a)(3)(C) of this title","children":[],"tail":" exists."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8cd1839-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of concurrence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The concurrence of a spouse under paragraph (1) shall be made in such written form and shall contain such information as may be required under regulations prescribed by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd183a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Election When Former Spouse Coverage in Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1450/f/2"},"text":"section 1450(f)(2) of this title","children":[],"tail":" applies to an election to discontinue participation in the Plan under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd183b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withdrawal of Election To Discontinue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/b/1/D"},"text":"Section 1448(b)(1)(D) of this title","children":[],"tail":" applies to an election under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd183c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consequences of Discontinuation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/b/1/E"},"text":"Section 1448(b)(1)(E) of this title","children":[],"tail":" applies to an election under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd183d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Affected Beneficiaries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall notify any former spouse or other natural person previously designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/b"},"text":"section 1448(b) of this title","children":[],"tail":" of an election to discontinue participation under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd183e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date of Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under subsection (a) is effective as of the first day of the first calendar month following the month in which the election is received by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8cd183f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1448a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Irrevocability Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraphs (4)(B) and (5)(C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448/a"},"text":"section 1448(a) of this title","children":[],"tail":" do not apply to prevent an election under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8cd1840-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s641/a/1"},"text":"Pub. L. 105–85, div. A, title VI, § 641(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1797"},"text":"111 Stat. 1797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8cd1841-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8cd1842-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8cd1843-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s641/c"},"text":"Pub. L. 105–85, div. A, title VI, § 641(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1799"},"text":"111 Stat. 1799","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVI/s641/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448a"},"text":"Section 1448a of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8cd1844-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provision for Current Participants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s641/b"},"text":"Pub. L. 105–85, div. A, title VI, § 641(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1798"},"text":"111 Stat. 1798","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVI/s641/b"},"text":"“Notwithstanding the limitation on the time for making an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1448a"},"text":"section 1448a of title 10","children":[],"tail":", United States Code (as added by subsection (a)), that is specified in subsection (a) of such section, a participant in the Survivor Benefit Plan under subchapter II of chapter 73 of such title may make an election in accordance with that section within one year after the effective date of that section under subsection (c) [set out as an Effective Date note above] if the second anniversary of the commencement of payment of retired pay to the participant precedes that effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
