{"tag":"section","attrib":{"id":"idaba453e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533"},"text":null,"children":[{"tag":"num","attrib":{"value":"12533"},"text":"§ 12533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba453e4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall terminate the insurance program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453e5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of New Enrollments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not enroll a member of the Ready Reserve for coverage under the insurance program after ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba453e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The enrollment under the insurance program of insured members other than insured members described in paragraph (2) is terminated as of ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":". The enrollment of an insured member described in paragraph (2) is terminated as of the date of the termination of the period of covered service of that member described in that paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba453e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An insured member described in this paragraph is an insured member who on ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":", is serving on covered service for a period of service, or has been issued an order directing the performance of covered service, that satisfies or would satisfy the entitlement-to-benefits provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Payment of Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not make any benefit payment under the insurance program after ","children":[{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":", other than to an insured member who on that date (1) is serving on an order to covered service, (2) has been issued an order directing performance of covered service, or (3) has served on covered service before that date for which benefits under the program have not been paid to the member."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12533/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Insurance Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall close the Fund not later than 60 days after the date on which the last benefit payment from the Fund is made. Any amount remaining in the Fund when closed shall be covered into the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba453eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s512/a"},"text":"Pub. L. 105–85, div. A, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1729"},"text":"111 Stat. 1729","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/c/15"},"text":"Pub. L. 107–107, div. A, title X, § 1048(c)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1226"},"text":"115 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaba453ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaba453ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaba453ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsecs. (b), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/c/15/A"},"text":"Pub. L. 107–107, § 1048(c)(15)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":".” for “the date of the enactment of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1048/c/15/B"},"text":"Pub. L. 107–107, § 1048(c)(15)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"November 18, 1997","children":[],"tail":",” for “the date of the enactment of this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
