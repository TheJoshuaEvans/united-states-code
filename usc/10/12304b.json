{"tag":"section","attrib":{"id":"idab9f98fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b"},"text":null,"children":[{"tag":"num","attrib":{"value":"12304b"},"text":"§ 12304b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selected Reserve: order to active duty for preplanned missions in support of the combatant commands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab9f98fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary of a military department determines that it is necessary to augment the active forces for a preplanned mission in support of a combatant command, the Secretary may, subject to subsection (b), order any unit of the Selected Reserve (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10143/a"},"text":"section 10143(a) of this title","children":[],"tail":"), without the consent of the members, to active duty for not more than 365 consecutive days."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f98fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f98fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab9f98fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided under subparagraph (B), units may be ordered to active duty under this section only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idab9f98ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manpower and associated costs of such active duty are specifically included and identified in the defense budget materials for the fiscal year or years in which such units are anticipated to be ordered to active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idab9f9900-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budget information on such costs includes a description of the mission for which such units are anticipated to be ordered to active duty and the anticipated length of time of the order of such units to active duty on an involuntary basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab9f9901-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event the President’s budget is delivered later than April 1st in the year prior to the year of the mobilization of one or more units under this section, the Secretary concerned may submit to Congress the information required under subparagraph (A) in a separate notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9902-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 60,000 members of the reserve components of the armed forces may be on active duty under this section at any one time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9903-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion From Strength Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members ordered to active duty under this section shall not be counted in computing authorized strength in members on active duty or total number of members in grade under this title or any other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9904-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary of a military department orders any unit of the Selected Reserve to active duty under subsection (a), such Secretary shall submit to Congress a report, in writing, setting forth the circumstances necessitating the action taken under this section and describing the anticipated use of such unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9905-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Duty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever any unit of the Selected Reserve is ordered to active duty under subsection (a), the service of all units so ordered to active duty may be terminated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f9906-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by order of the Secretary of the military department concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f9907-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9908-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to War Powers Resolution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing contained in this section shall be construed as amending or limiting the application of the provisions of the War Powers Resolution (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1541"},"text":"50 U.S.C. 1541","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f9909-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations for Involuntary Order to Active Duty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which units of the Selected Reserve will be ordered to duty without their consent under this section, appropriate consideration shall be given to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab9f990a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length and nature of previous service, to assure such sharing of exposure to hazards as national security and military requirements will reasonably allow;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f990b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of assignments during service career;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f990c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab9f990d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment necessary to maintain the national health, safety, or interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f990e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies and Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretaries of the military departments shall prescribe policies and procedures to carry out this section, including on determinations with respect to orders to active duty under subsection (g). Such policies and procedures shall not go into effect until approved by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab9f990f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12304b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Budget Materials Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “defense budget materials” has the meaning given that term in section 231(f)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab9f9910-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s516/a/1"},"text":"Pub. L. 112–81, div. A, title V, § 516(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1395"},"text":"125 Stat. 1395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1014/b"},"text":"Pub. L. 112–239, div. A, title X, § 1014(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1908"},"text":"126 Stat. 1908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s513"},"text":"Pub. L. 118–31, div. A, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/245"},"text":"137 Stat. 245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab9f9911-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab9f9912-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab9f9913-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The War Powers Resolution, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/148"},"text":"Pub. L. 93–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-07"},"text":"Nov. 7, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/555"},"text":"87 Stat. 555","children":[],"tail":", which is classified generally to chapter 33 (§ 1541 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1541"},"text":"section 1541 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s231/f/2"},"text":"Section 231(f)(2) of this title","children":[],"tail":", referred to in subsec. (i), was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s231/g/2"},"text":"section 231(g)(2) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tIII/s352/a/2"},"text":"Pub. L. 117–263, div. A, title III, § 352(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2533"},"text":"136 Stat. 2533","children":[],"tail":", and subsequently was redesignated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s231/h/2"},"text":"section 231(h)(2) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tX/s1021/1"},"text":"Pub. L. 118–159, div. A, title X, § 1021(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2052"},"text":"138 Stat. 2052","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab9f9914-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “(A) Except as provided under subparagraph (B), units” for “Units”, redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “section 231(f)(2)” for “section 231(g)(2)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
