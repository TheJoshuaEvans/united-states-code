{"tag":"section","attrib":{"id":"ida959c811-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2254a"},"text":"§ 2254a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data files of military flight operations quality assurance systems: exemption from disclosure under Freedom of Information Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida959c812-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Exempt Certain Data Files From Disclosure Under FOIA.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida959c813-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may exempt information contained in any data file of the military flight operations quality assurance system of a military department from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":", upon a written determination that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c814-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is sensitive information concerning military aircraft, units, or aircrew; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c815-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public interest consideration in the disclosure of such information does not outweigh preventing the disclosure of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c816-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “data file” means a file of the military flight operations quality assurance (in this section referred to as “MFOQA”) system that contains information acquired or generated by the MFOQA system, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida959c817-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any data base containing raw MFOQA data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida959c818-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any analysis or report generated by the MFOQA system or which is derived from MFOQA data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c819-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information that is exempt under paragraph (1) from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":" shall be exempt from such disclosure even if such information is contained in a data file that is not exempt in its entirety from such disclosure."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida959c81a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of paragraph (1) may not be superseded except by a provision of law which is enacted after the date of the enactment of this section and which specifically cites and repeals or modifies those provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c81b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall prescribe regulations for the administration of this section. Such regulations shall ensure consistent application of the authority in subsection (a) across the military departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida959c81c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2254a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each determination of the Secretary under subsection (a) shall be made in writing and accompanied by a statement of the basis for the determination. All such determinations and statements of basis shall be available to the public, upon request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida959c81d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1082/a/1"},"text":"Pub. L. 112–81, div. A, title X, § 1082(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1600"},"text":"125 Stat. 1600","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tIX/s901/e/2"},"text":"Pub. L. 118–31, div. A, title IX, § 901(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/355"},"text":"137 Stat. 355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida959c81e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida959c81f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida959c820-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida959c821-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" redesignated subsec. (d) as (c), struck out “, or the Secretary’s designee,” after “Secretary” and “, through the Office of the Director of Administration and Management” after “request”, and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “The Secretary of Defense may delegate the authority to make a determination under subsection (a) to the Director of Administration and Management of the Department.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida959c822-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida959c823-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tX/s1082/b"},"text":"Pub. L. 112–81, div. A, title X, § 1082(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1601"},"text":"125 Stat. 1601","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tX/s1082/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2254a"},"text":"Section 2254a of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply to any information entered into any data file of the military flight operations quality assurance system before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
