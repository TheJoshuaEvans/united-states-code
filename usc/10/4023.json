{"tag":"section","attrib":{"id":"idaa51bbea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4023"},"text":null,"children":[{"tag":"num","attrib":{"value":"4023"},"text":"§ 4023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement for experimental purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa51bbeb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4023/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense and the Secretaries of the military departments may each buy demonstrations, prototypes, products, supplies, parts, accessories, auxiliary services, and design for products or services that the Secretary of Defense or the Secretary concerned considers necessary for experimental or test purposes in the development of the best supplies that are needed for the national defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa51bbec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4023/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Purchases under this section may be made or modified inside or outside the United States and by contract or otherwise. Chapter 137 ","children":[{"tag":"ref","attrib":{"idref":"fn002115"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title applies only when such purchases are made in quantities greater than necessary for prototyping, experimentation, technical evaluation, assessment of operational utility, or safety or to provide a residual operational capability."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa51bbed-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tVIII/s822/c/1"},"text":"Pub. L. 103–160, div. A, title VIII, § 822(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1706"},"text":"107 Stat. 1706","children":[],"tail":", § 2373; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1070/g"},"text":"Pub. L. 103–337, div. A, title X, § 1070(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2859"},"text":"108 Stat. 2859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tVIII/s812"},"text":"Pub. L. 104–106, div. A, title VIII, § 812","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/395"},"text":"110 Stat. 395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s814"},"text":"Pub. L. 114–92, div. A, title VIII, § 814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/893"},"text":"129 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s886"},"text":"Pub. L. 115–232, div. A, title VIII, § 886","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1916"},"te