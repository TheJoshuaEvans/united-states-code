{"tag":"section","attrib":{"id":"idab1559f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8220"},"text":null,"children":[{"tag":"num","attrib":{"value":"8220"},"text":"§ 8220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dental services: responsibilities of senior dental officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1559f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8220/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Navy shall prescribe regulations for dental services on ships and at shore stations. Such services shall be under the senior dental officer, who is responsible to the commanding officer of the ship or station for all professional, technical, and administrative matters concerning dental services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1559f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8220/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not impose any administrative requirements that would interfere with the proper functioning of battle organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1559f4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/377"},"text":"70A Stat. 377","children":[],"tail":", § 6029; renumbered § 8220, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/b/7"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":