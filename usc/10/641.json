is Act ["},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the military department concerned may provide that a Reserve officer who was placed on the active-duty list on or after ","children":[{"tag":"date","attrib":{"date":"1997-10-30"},"text":"October 30, 1997","children":[],"tail":", shall be placed on the reserve active-status list if the officer otherwise meets the conditions specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s641/1/D"},"text":"section 641(1)(D) of title 10","children":[],"tail":", United States Code, as amended by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7f41d3e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions Under Defense Officer Personnel Management Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions to prevent extinction or premature termination of rights, duties, penalties, or proceedings that existed or were begun prior to the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" and otherwise to allow for an orderly transition to the system of officer personnel management put in place under "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":", see section 601 et seq. of "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s611"},"text":"section 611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
