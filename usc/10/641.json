. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809/a"},"text":"Pub. L. 115–232, div. A, title VIII, § 809(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1840"},"text":"132 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f41d33-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f41d34-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ida7f41d35-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI"},"text":"Pub. L. 103–337, div. A, title XVI","children":[],"tail":", §§ 1624, 1691(b)(1), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2961"},"text":"108 Stat. 2961","children":[],"tail":", 3026, which directed amendment of this section effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", by inserting “(a)” before “Officers in the following” and by adding at the end a new subsec. (b), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/a/1/A"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/495"},"text":"110 Stat. 495","children":[],"tail":", and, as so amended, amends "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s620"},"text":"section 620 of this title","children":[],"tail":" instead of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f41d36-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 7038, 8083, 8084, 9038,” for “section 3038, 5143, 5144, 8038,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" struck out par. (6) which read as follows: “Officers appointed pursuant to an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s329"},"text":"section 329 of title 37","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “, the registrar” for “and the registrar” and inserted “, and permanent professors of the Navy (as defined in regulations prescribed by the Secretary of the Navy)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s416/j"},"text":"Pub. L. 108–375, § 416(j)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Reserve officers—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) on active duty for training;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) on active duty under section 3038, 5143, 5144, 8038, 10211, 10301 through 10305, 10502, 10505, 10506(a), 10506(b), 10507, or 12402 of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s708"},"text":"section 708 of title 32","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) on active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/d"},"text":"section 12301(d) of this title","children":[],"tail":" in connection with organizing, administering, recruiting, instructing, or training the reserve components;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) on active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/d"},"text":"section 12301(d) of this title","children":[],"tail":", other than as provided under subparagraph (C), if the call or order to active duty, under regulations prescribed by the Secretary concerned, specifies a period of three years or less and continued placement on the reserve active-status list;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) on active duty to pursue special work;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(F) ordered to active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304"},"text":"section 12304 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(G) on active duty under section 10(b)(2) of the Military Selective Service Act (50 U.S.C. App. 460(b)(2)) for the administration of the Selective Service System; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(H) on full-time National Guard duty.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s501/d"},"text":"Pub. L. 108–375, § 501(d)","children":[],"tail":", which directed substitution of “sections 12302 and 12304” for “section 12304” in subpar. (F), could not be executed because par. (1) did not contain a subpar. (F) subsequent to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s416/j"},"text":"Pub. L. 108–375, § 416(j)","children":[],"tail":". See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “on the reserve active-status list who are on active duty under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12301/d"},"text":"section 12301(d) of this title","children":[],"tail":", other than as provided in subparagraph (C), under a call or order to active duty specifying a period of three years or less;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (1)(D) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" added subpar. (D) and redesignated former subpars. (D) to (G) as (E) to (H), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" inserted “5143, 5144,” after “3038,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “10502, 10505, 10506(a), 10506(b), 10507” for “10501”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1671/c/5/A"},"text":"Pub. L. 103–337, § 1671(c)(5)(A)","children":[],"tail":", substituted “3038, 8038, 10211, 10301 through 10305, 10501, or 12402” for “175, 265, 3021, 3038, 3040, 3496, 5251, 5252, 8021, 8038, or 8496”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1671/c/5/B"},"text":"Pub. L. 103–337, § 1671(c)(5)(B)","children":[],"tail":", substituted “12301(d)” for “672(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1671/c/5/C"},"text":"Pub. L. 103–337, § 1671(c)(5)(C)","children":[],"tail":", substituted “12304” for “673b”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" substituted “3021, 3038, 3040, 3496, 5251, 5252, 8021, 8038” for “3015, 3019, 3033, 3496, 5251, 5252, 8019, 8033”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s527/b"},"text":"Pub. L. 98–525, § 527(b)","children":[],"tail":", substituted “(other than section 640 and, in the case of warrant officers, section 628)” for “(other than section 640)” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s414/a/5/A"},"text":"Pub. L. 98–525, § 414(a)(5)(A)","children":[],"tail":", struck out “or under section 502 or 503 of title 32” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s672/d"},"text":"section 672(d) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s414/a/5/B"},"text":"Pub. L. 98–525, § 414(a)(5)(B)","children":[],"tail":"–(D), added subpar. (G)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f41d37-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7f41d38-3a6f-11f1-a58a-d8db54b14ab5"},"text":nul