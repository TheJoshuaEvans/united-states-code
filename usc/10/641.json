{"tag":"section","attrib":{"id":"ida7f41d29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s641"},"text":null,"children":[{"tag":"num","attrib":{"value":"641"},"text":"§ 641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Officers in the following categories are not subject to this chapter (other than section 640 and, in the case of warrant officers, section 628):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f41d2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s641/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Reserve officers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7f41d2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s641/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on active duty authorized under section 115(a)(1)(B) or 115(b)(1) of this title, or excluded from counting for active duty end strengths under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s115/i"},"text":"section 115(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s641/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on active duty under section 7038, 8083, 8084, 9038, 10211, 10301 through 10305, 10502, 10505, 10506(a), 10506(b), 10507, or 12402 of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s708"},"text":"section 708 of title 32","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7f41d2d-3a6f-11f1-a58a-d8db54b14ab5","identi