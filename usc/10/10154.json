{"tag":"section","attrib":{"id":"idab8c864f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10154"},"text":null,"children":[{"tag":"num","attrib":{"value":"10154"},"text":"§ 10154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retired Reserve","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Retired Reserve consists of the following Reserves:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c8650-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10154/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserves who are or have been retired under section 7311, 8323, or 9311 of this title or under section 291 ","children":[{"tag":"ref","attrib":{"idref":"fn002172"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c8651-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10154/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reserves who have been transferred to the Retired Reserve, retain their status as Reserves, and are otherwise qualified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c8652-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2975"},"text":"108 Stat. 2975","children":[],"tail":"; amended "},{"tag":"ref","attrib