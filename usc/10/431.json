n":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/7"},"text":"Pub. L. 110–417, § 932(a)(7)","children":[],"tail":". See 2008 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s932/a/7"},"text":"Pub. L. 110–417, § 932(a)(7)","children":[],"tail":", which directed the amendment of subsec. (b)(1) by substituting “Director of National Intelligence” for “Director of Central Intelligence”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “Director of the Central Intelligence Agency” for “Director of Central Intelligence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" substituted “2010” for “2006”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" substituted “2006” for “2004”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" substituted “2004” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “2002” for “2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272"},"text":"Pub. L. 105–272","children":[],"tail":" substituted “2000” for “1998”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93"},"text":"Pub. L. 104–93","children":[],"tail":" substituted “1998” for “1995”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7bd2e9c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida7bd2e9d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2474"},"text":"123 Stat. 2474","children":[],"tail":", provided that the amendment made by section 1073(c)(10) is effective as of "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7bd2e9e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s504/b"},"text":"Pub. L. 102–88, title V, § 504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/440"},"text":"105 Stat. 440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/88/tV/s504/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Secretary of Defense may not authorize any activity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s431"},"text":"section 431 of title 10","children":[],"tail":", United States Code, as added by subsection (a), until the later of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the 90-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations first prescribed under section 436 of such title, as added by subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
