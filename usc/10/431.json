{"tag":"section","attrib":{"id":"ida7bd2e89-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431"},"text":null,"children":[{"tag":"num","attrib":{"value":"431"},"text":"§ 431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to engage in commercial activities as security for intelligence collection activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7bd2e8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, subject to the provisions of this subchapter, may authorize the conduct of those commercial activities necessary to provide security for authorized intelligence collection activities abroad undertaken by the Department of Defense. No commercial activity may be initiated pursuant to this subchapter after ","children":[{"tag":"date","attrib":{"date":"2028-12-31"},"text":"December 31, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2e8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency Coordination and Support","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any such activity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2e8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bd2e8d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be pre-coordinated with the Director of the Central Intelligence Agency using procedures mutually agreed upon by the Secretary of Defense and the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e8e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, be supported by the Director; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e8f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent the activity takes place within the United States, be coordinated with, and (where appropriate) be supported by, the Director of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7bd2e90-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2e91-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “commercial activities” means activities that are conducted in a manner consistent with prevailing commercial practices and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7bd2e92-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, use, sale, storage and disposal of goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e93-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into employment contracts and leases and other agreements for real and personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e94-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depositing funds into and withdrawing funds from domestic and foreign commercial business or financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring licenses, registrations, permits, and insurance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7bd2e96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing corporations, partnerships, and other legal entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2e97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s431/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “intelligence collection activities” means the collection of foreign intelligence and counterintelligence information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2e98-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s504/a/2"},"text":"Pub. L. 102–88, title V, § 504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/437"},"text":"105 Stat. 437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tV/s503"},"text":"Pub. L. 104–93, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/973"},"text":"109 Stat. 973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/272/tV/s501"},"text":"Pub. L. 105–272, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2404"},"text":"112 Stat. 2404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1077], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–282; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tX/s1053"},"text":"Pub. L. 107–314, div. A, title X, § 1053","children":[],"tail":", "},{"tag":