{"tag":"section","attrib":{"id":"ida82fc713-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936"},"text":null,"children":[{"tag":"num","attrib":{"value":"936"},"text":"§ 936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 136. Authority to administer oaths","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida82fc714-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following persons on active duty or performing inactive-duty training may administer oaths for the purposes of military administration, including military justice:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc715-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All judge advocates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc716-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All summary courts-martial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc717-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All adjutants, assistant adjutants, acting adjutants, and personnel adjutants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc718-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All commanding officers of the Navy, Marine Corps, and Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc719-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All staff judge advocates and legal officers, and acting or assistant staff judge advocates and legal officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc71a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other persons designated by regulations of the armed forces or by statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc71b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following persons on active duty or performing inactive-duty training may administer oaths necessary in the performance of their duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida82fc71c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The president, military judge, trial counsel, and assistant trial counsel for all general and special courts-martial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc71d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The president and the counsel for the court of any court of inquiry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc71e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All officers designated to take a deposition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc71f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All persons detailed to conduct an investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc720-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All recruiting officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida82fc721-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other persons designated by regulations of the armed forces or by statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida82fc722-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s936/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each judge and senior judge of the United States Court of Appeals for the Armed Forces shall have the powers relating to oaths, affirmations, and acknowledgments provided to justices and judges of the United States by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s459"},"text":"section 459 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida82fc723-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/77"},"text":"70A Stat. 77","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/589"},"text":"Pub. L. 86–589","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/329"},"text":"74 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/179/s1/7"},"text":"Pub. L. 90–179, § 1(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-08"},"text":"Dec. 8, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/546"},"text":"81 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/632/s2/34"},"text":"Pub. L. 90–632, § 2(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-24"},"text":"Oct. 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1343"},"text":"82 Stat. 1343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/209/s2/f"},"text":"Pub. L. 98–209, § 2(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-06"},"text":"Dec. 6, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1393"},"text":"97 Stat. 1393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tVIII/s804/c"},"text":"Pub. L. 99–661, div. A, title VIII, § 804(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3907"},"text":"100 Stat. 3907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":