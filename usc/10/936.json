n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"936(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"936(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"936(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:732(a).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:732(b).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"50:732(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 136), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/143"},"text":"64 Stat. 143","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"936(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:732(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “may” is substituted for the words “shall have authority to”. The word “shall” before the words “have the general powers” is omitted as surplusage. The words “the continental limits” are omitted, since ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/1"},"text":"section 101(1) of this title","children":[],"tail":" defines the United States to include the States and the District of Columbia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “in the armed forces” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “may” is substituted for the words “shall have authority to”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “of any character” are omitted as surplusage. The word “may” is substituted for the word “shall”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “is” is substituted for the words “shall be”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida82fc727-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida82fc728-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5502"},"text":"Pub. L. 114–328, § 5502","children":[],"tail":", struck out “and to act as notary” after “oaths” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s541/a"},"text":"Pub. L. 114–328, § 541(a)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The judges of the United States Court of Appeals for the Armed Forces may administer the oaths authorized by subsections (a) and (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s551/b/1"},"text":"Pub. L. 101–510, § 551(b)(1)","children":[],"tail":", struck out “, and have the general powers of a notary public and of a consul of the United States, in the performance of all notarial acts to be executed by members of any of the armed forces, wherever they may be, by persons serving with, employed by, or accompanying the armed forces outside the United States and outside Puerto Rico, Guam, and the Virgin Islands, and by other persons subject to this chapter outside of the United States” after “including military justice” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s551/b/2"},"text":"Pub. L. 101–510, § 551(b)(2)","children":[],"tail":", struck out subsecs. (c) and (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) No fee may be paid to or received by any person for the performance of any notarial act herein authorized.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) The signature without seal of any such person acting as notary, together with the title of his office, is prima facie evidence of his authority.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” before “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" inserted “or performing inactive-duty training” after “active duty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209/s2/f/1"},"text":"Pub. L. 98–209, § 2(f)(1)","children":[],"tail":", struck out “of the Army, Navy, Air Force, and Marine Corps” after “All judge advocates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/209/s2/f/2"},"text":"Pub. L. 98–209, § 2(f)(2)","children":[],"tail":", struck out par. (2) which included law specialists among those persons authorized to administer oaths and to act as notaries under this section, and redesignated pars. (3) to (7) as (2) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/632"},"text":"Pub. L. 90–632","children":[],"tail":" substituted “military judge” for “law officer” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/179"},"text":"Pub. L. 90–179","children":[],"tail":" inserted references to judge advocates of the Navy and the Marine Corps."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/589"},"text":"Pub. L. 86–589","children":[],"tail":" permitted the administration of oaths and the performance of notarial acts for persons serving, employed by, or accompanying the armed forces outside the United States and outside the Canal Zone, Puerto Rico, Guam, and the Virgin Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8321019-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida832101a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5502"},"text":"section 5502 of Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n