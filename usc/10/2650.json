{"tag":"section","attrib":{"id":"ida997bb18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2650"},"text":null,"children":[{"tag":"num","attrib":{"value":"2650"},"text":"§ 2650.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian personnel in Alaska","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Persons residing in Alaska who are and have been employed there by the United States for at least two years, and their families, may be transported on vessels or airplanes operated by the Department of Defense, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida997bb19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2650/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense considers that accommodations are available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bb1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2650/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation is without expense to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bb1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2650/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation is limited to one round trip between Alaska and the United States during any two-year period, except in an emergency such as sickness or death; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida997bb1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2650/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in case of travel by air, the transportation cannot be reasonably handled by a United States commercial air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida997bb1d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/267"},"text":"70A Stat. 267","children":[],"tail":", § 4746; "},{"tag":"ref","attrib":{"href":"/us/pl/98/443/s9/k"},"text":"Pub. L. 98–443, § 9(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-04"},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1708"},"text":"98 Stat. 1708","children":[],"tail":"; renumbered § 2650 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1072/a"},"text":"Pub. L. 108–375, div. A, title X, § 1072(a)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2057"},"text":"118 Stat. 2057","children":[],"tail":", 2058.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida997bb1e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida997bb1f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida997bb20-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4746","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1371a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-11-21/ch483"},"text":"Nov. 21, 1941, ch. 483","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-25/ch321"},"text":"July 25, 1947, ch. 321","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/423"},"text":"61 Stat. 423","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before the enactment of the National Security Act of 1947, the transport functions covered by this section were performed only by the Army. Under section 2(a)(3) of the National Security Act (as it existed before ","children":[{"tag":"date","attrib":{"date":"1949-08-10"},"text":"August 10, 1949","children":[],"tail":"), the sea and air transportation functions of the Army, Navy, and Air Force were respectively consolidated into the “Military Sea Transportation Service”, under the Department of the Navy, and the “Military Air Transport Service”, under the Department of the Air Force. Instead of having space on its own transport vessels and airplanes, the Army is now allotted bulk space on vessels and airplanes operated by those transport services. The words “or, within bulk space allocations made to the Department of the Army, on vessels or airplanes operated by any military transport agency of the Department of Defense” are inserted, in accordance with an opinion of the Judge Advocate General of the Army (JAGA 1953/5885, 22 July 1953), to make clear that the rule applicable to Army vessels and airplanes applies to the bulk space allocated to the Army. Since the authority to perform transportation functions could again be transferred as between the military departments, the reference to “vessels or airplanes of Army transport agencies” is retained. The word “considers” is substituted for the words “in the opinion of”. The words “Persons residing in Alaska who are and have been employed there by the United States” are substituted for the words “employees of the United States, residing in Alaska, who have been in such employment”. The word “commercial” is substituted for the word “civil” for clarity. The words “from and after "},{"tag":"date","attrib":{"date":"1941-11-21"},"text":"November 21, 1941","children":[],"tail":"”, “and the carriage of all such air traffic shall be terminated”, “dire”, “the privilege herein granted”, and “as to each eligible individual” are omitted as surplusage. The words “the continental” are omitted, since "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/1"},"text":"section 101(1) of this title","children":[],"tail":" defines the United States as “the States and the District of Columbia”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida997bb21-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida997bb22-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1072/a"},"text":"Pub. L. 108–375, § 1072(a)","children":[],"tail":", (b)(3)(A), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4746"},"text":"section 4746 of this title","children":[],"tail":" as this section and, in introductory provisions, struck out “Army transport agencies or, within bulk space allocations made to the Department of the Army, on vessels or airplanes operated by any military transport agency of” before “the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1072/b/3/B"},"text":"Pub. L. 108–375, § 1072(b)(3)(B)","children":[],"tail":", substituted “Secretary of Defense” for “Secretary of the Army”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s1072/b/3/C"},"text":"Pub. L. 108–375, § 1072(b)(3)(C)","children":[],"tail":", substituted “by air, the transportation cannot” for “by air—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Secretary of Transportation has not certified that commercial air carriers of the United States that can handle the transportation are operating between Alaska and the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the transportation cannot”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Pub. L. 98–443","children":[],"tail":" substituted “Secretary of Transportation” for “Civil Aeronautics Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida997bb23-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida997bb24-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Pub. L. 98–443","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/443/s9/v"},"text":"section 9(v) of Pub. L. 98–443","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
