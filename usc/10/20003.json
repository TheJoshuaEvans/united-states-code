{"tag":"section","attrib":{"id":"idabc82f1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20003"},"text":null,"children":[{"tag":"num","attrib":{"value":"20003"},"text":"§ 20003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members: minimum service requirement as applied to Space Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Active/reserve Service Distinction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s651"},"text":"section 651 of this title","children":[],"tail":" to a person who becomes a member of the Space Force, the provisions of the second sentence of subsection (a) and of subsection (b) of that section (relating to service in a reserve component) are inapplicable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment Upon Transfer Out of Space Force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Space Force who transfers to one of the other armed forces before completing the service required by subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s651"},"text":"section 651 of this title","children":[],"tail":" shall upon such transfer be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s651"},"text":"section 651 of this title","children":[],"tail":" in the same manner as if such member had initially entered the armed force to which the member transfers."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f20-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1714"},"text":"Pub. L. 118–31, div. A, title XVII, § 1714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/626"},"text":"137 Stat. 626","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
