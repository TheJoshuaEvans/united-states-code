{"tag":"section","attrib":{"id":"idab534d95-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8891"},"text":null,"children":[{"tag":"num","attrib":{"value":"8891"},"text":"§ 8891.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab534d96-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8891/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This chapter applies to any suit against the United States under chapter 311 of title 46 for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab534d97-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8891/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage caused by a vessel in the naval service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab534d98-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8891/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for towage or salvage services, including contract salvage, rendered to a vessel in the naval service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab534d99-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8891/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this chapter, the term “vessel in the naval service” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab534d9a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8891/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"co