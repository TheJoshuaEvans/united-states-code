{"tag":"section","attrib":{"id":"ida9a3a1b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669"},"text":null,"children":[{"tag":"num","attrib":{"value":"2669"},"text":"§ 2669.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of land and facilities to support contracts with federally funded research and development centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9a3a1b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lease of Land, Facilities, and Improvements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department may lease, for no consideration, land, facilities, infrastructure, and improvements to a covered FFRDC if the lease is to further the purposes of a contract between the Department of Defense and the covered FFRDC.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A lease entered into under paragraph (1) shall terminate on the earlier of the following dates:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a3a1b6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date that is 50 years after the date on which the Secretary enters into the lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a3a1b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of the termination or non-renewal of the contract between the Department of Defense and the covered FFRDC related to the lease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conveyance of Facilities and Improvements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of a military department may convey, for no consideration, ownership of facilities and improvements located on land leased to a covered FFRDC to further the purposes of a contract between the Department of Defense and the covered FFRDC.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ownership of any facilities and improvements conveyed by the Secretary of a military department or any improvements made to the leased land by the covered FFRDC under this subsection shall, as determined by the Secretary of a military department, revert or transfer to the United States upon the termination or non-renewal of the underlying land lease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any facilities and improvements conveyed by the Secretary of a military department shall be demolished by the covered FFDRC as determined by such Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A lease entered into under this section may provide that any facilities constructed on the leased land may be constructed using commercial standards in a manner that provides force protection safeguards appropriate to the activities conducted in, and the location of, such facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Property Management Laws","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9a3a1be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The conveyance or lease of property or facilities, improvements, and infrastructure under this section shall not be subject to the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9a3a1bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667"},"text":"Section 2667 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a3a1c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s1302"},"text":"Section 1302 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9a3a1c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 501 of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11411"},"text":"42 U.S.C. 11411","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9a3a1c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 2662 and 2802 of this title shall not apply to any improvements or facilities constructed by the covered FFRDC on land leased or conveyed to a covered FFRDC described in subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1c3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive Procedures for Selection of Certain Lessees; Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a proposed lease under this section is with respect to a covered FFRDC, the use of competitive procedures for the selection of the lessee is not required and the provisions of chapter 33 of title 41, United States Code, or chapter 221 of title 10, United States Code, and the related provisions of the Federal Acquisition Regulation shall not apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9a3a1c4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2669/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered FFRDC Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered FFRDC” means a federally funded research and development center that is sponsored by, and has entered into a contract with, the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9a3a1c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dB/tXXVIII/s2831/a"},"text":"Pub. L. 117–263, div. B, title XXVIII, § 2831(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3002"},"text":"136 Stat. 3002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9a3a1c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida9a3a1c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida9a3a1c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2269, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/151"},"text":"70A Stat. 151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dB/tXXVIII/s2812/f/2"},"text":"Pub. L. 106–398, § 1 [div. B, title XXVIII, § 2812(f)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–418; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dB/tXXVIII/s2813/b"},"text":"Pub. L. 108–136, div. B, title XXVIII, § 2813(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1725"},"text":"117 Stat. 1725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/3"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":", related to easements for gas, water, and sewer pipe lines, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dB/tXXVIII/s2822/c"},"text":"Pub. L. 109–364, div. B, title XXVIII, § 2822(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2475"},"text":"120 Stat. 2475","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
