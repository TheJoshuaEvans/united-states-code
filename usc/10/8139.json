{"tag":"section","attrib":{"id":"idab1078cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139"},"text":null,"children":[{"tag":"num","attrib":{"value":"8139"},"text":"§ 8139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular Navy and Regular Marine Corps: officers designated for limited duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1078ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Original appointments as regular officers of the Navy in a grade below lieutenant commander in the line and in staff corps established by the Secretary of the Navy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8090/b"},"text":"section 8090(b) of this title","children":[],"tail":" and designated by the Secretary for the purposes of this section may be made from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1078cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warrant officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chief petty officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first-class petty officers;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in the Regular Navy, for the performance of duty in the technical fields indicated by their warrants or ratings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1078d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Original appointments as regular officers of the Marine Corps in a grade below major may be made from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1078d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warrant officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" master sergeants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078d5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical sergeants;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in the Regular Marine Corps, for the performance of duty in the technical fields in which they are proficient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1078d6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1078d7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer described in paragraph (2) may be given an original appointment as a regular officer of the Navy or the Marine Corps, as the case may be, in the grade, and with the date of rank in that grade, in which the officer is serving on the day before such original appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078d8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection applies to an officer of the Navy and Marine Corps who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab1078d9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on the active-duty list;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab1078da-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a permanent enlisted or warrant officer grade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab1078db-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated for limited duty under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8146"},"text":"section 8146 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab1078dc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in the grade of lieutenant commander or commander, or in the grade of major or lieutenant colonel, under a temporary appointment under subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8146"},"text":"section 8146 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1078dd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible for an appointment under this section a member must have the qualifications specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s532/a"},"text":"section 532(a) of this title","children":[],"tail":" and have completed at least 8 years of active naval service, excluding active duty for training in a reserve component."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1078de-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each officer appointed under this section is known as an officer designated for limited duty. He may not suffer any reduction in the pay and allowances to which he was entitled at the time of his appointment because of his former permanent status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1078df-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any officer designated for limited duty, upon his application and upon determination by the Secretary of the Navy that he is qualified, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1078e0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is in the line of the Navy, be designated for engineering duty, aeronautical engineering duty, or special duty, or be assigned to unrestricted performance of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078e1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is in a staff corps of the Navy, be assigned to unrestricted performance of duty in that corps; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1078e2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if he is in the Marine Corps, be assigned to unrestricted performance of duty.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"When an officer is so designated or assigned, his status as an officer designated for limited duty terminates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1078e3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8139/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations for the appointment, designation, and assignment of officers under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1078e4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/326"},"text":"70A Stat. 326","children":[],"tail":", § 5589; "},{"tag":"ref","attrib":{"href":"/us/pl/87/123/s5/10"},"text":"Pub. L. 87–123, § 5(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-03"},"text":"Aug. 3, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/265"},"text":"75 Stat. 265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tIII/s325"},"text":"Pub. L. 96–513, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2893"},"text":"94 Stat. 2893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/433/tV/s514/c/3"},"text":"Pub. L. 99–433, title V, § 514(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1055"},"text":"100 Stat. 1055","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tV/s502"},"text":"Pub. L. 103–337, div. A, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2748"},"text":"108 Stat. 2748","children":[],"tail":"; renumbered § 8139 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s512"},"text":"Pub. L. 115–232, div. A, title V, § 512","children":[],"tail":", title VIII, §§ 807(b)(4), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1751"},"text":"132 Stat. 1751","children":[],"tail":", 1834, 1840.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab1078e5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idab1078e6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idab1078e7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5589","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t34/s211c"},"text":"34 U.S.C. 211c","children":[],"tail":" ((a) (less statement of appointing authority), and less (e)–(h))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-07/ch512/s404"},"text":"Aug. 7, 1947, ch. 512, § 404","children":[],"tail":" ((a) (less statement of appointing authority), and less (e)–(h)), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/870"},"text":"61 Stat. 870","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1949-08-05/ch402/s1/f"},"text":"Aug. 5, 1949, ch. 402, § 1(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/568"},"text":"63 Stat. 568","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b) the authority to make appointments under this section is confined to appointments in the grades of ensign and second lieutenant, since the authority in the source statute to make appointments in higher grades was limited and has been completely executed. The words “commissioned warrant officers” are omitted as surplusage, since the term “warrant officers” includes commissioned warrant officers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “male” is inserted to limit the application of the section to men. Authority to appoint women is covered in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s5590"},"text":"§ 5590 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab1078e8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab1078e9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s807/b/4"},"text":"Pub. L. 115–232, § 807(b)(4)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5589"},"text":"section 5589 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8090(b)” for “section 5150(b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s809/a"},"text":"Pub. L. 115–232, § 809(a)","children":[],"tail":", substituted “section 8146” for “section 5596”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s512"},"text":"Pub. L. 115–232, § 512","children":[],"tail":", substituted “8 years” for “10 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" added subsec. (c) and redesignated former subsecs. (c) to (f) as (d) to (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/433"},"text":"Pub. L. 99–433","children":[],"tail":" substituted “section 5150(b)” for “section 5155(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s325/1"},"text":"Pub. L. 96–513, § 325(1)","children":[],"tail":", substituted “as regular officers of the Navy in a grade below lieutenant commander in the line and in staff corps established by the Secretary of the Navy under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s5155/b"},"text":"section 5155(b) of this title","children":[],"tail":" and designated by the Secretary for the purposes of this section may be made from” for “to the active list of the Navy in the grade of ensign in the line, in the Supply Corps, and in the Civil Engineer Corps may be made from male”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s325/2"},"text":"Pub. L. 96–513, § 325(2)","children":[],"tail":", substituted “as regular officers of the Marine Corps in a grade below major may be made from” for “to the active list of the Marine Corps in the grade of second lieutenant may be made from male”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s325/3"},"text":"Pub. L. 96–513, § 325(3)","children":[],"tail":", inserted “the qualifications specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s532/a"},"text":"section 532(a) of this title","children":[],"tail":" and have”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1961—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/123"},"text":"Pub. L. 87–123","children":[],"tail":" struck out “be designated for supply duty or” before “be assigned to”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab1078ea-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1078eb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 807(b)(4) and 809(a) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab1078ec-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab1078ed-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions Under Defense Officer Personnel Management Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to Regular Navy or Regular Marine Corps officers designated as limited-duty officers under this section prior to ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"September 15, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s616"},"text":"section 616 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s611"},"text":"section 611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
