{"tag":"section","attrib":{"id":"idab74b7c7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431"},"text":null,"children":[{"tag":"num","attrib":{"value":"9431"},"text":"§ 9431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; Superintendent; faculty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab74b7c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is in the Department of the Air Force an Air Force Academy (hereinafter in this chapter referred to as the “Academy”) for the instruction and preparation for military service of selected persons called “cadets”. The organization of the Academy shall be prescribed by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab74b7c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be at the Academy the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab74b7ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Superintendent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab74b7cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Dean of the Faculty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab74b7cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Commandant of Cadets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab74b7cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 permanent professors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab74b7ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A chaplain.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab74b7cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9431/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A director of admissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab74b7d0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/561"},"text":"70A Stat. 561","children":[],"tail":", § 9331; "},{"tag":"ref","attrib":{"href":"/us/pl/85/600/s1/19"},"text":"Pub. L. 85–600, § 1(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-06"},"text":"Aug. 6, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/523"},"text":"72 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s514/10"},"text":"Pub. L. 96–513, title V, § 514(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"t