arious departments at the United States Military Academy (see revision note for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4331"},"text":"section 4331 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab74b7d4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab74b7d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/7"},"text":"Pub. L. 116–283, § 923(d)(7)","children":[],"tail":", substituted “cadets” for “Air Force cadets”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s573"},"text":"Pub. L. 116–283, § 573","children":[],"tail":", substituted “25” for “23”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9331"},"text":"section 9331 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “23 permanent professors” for “21 permanent professors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" substituted “Dean of the Faculty” for “dean of the Faculty, who is a permanent professor”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" struck out subsec. (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The Secretary of the Air Force may employ as many civilians as professors, instructors, and lecturers at the Academy as the Secretary considers necessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The compensation of persons employed under this subsection shall be as prescribed by the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Secretary may delegate the authority conferred by this subsection to any person in the Department of the Air Force to the extent the Secretary considers proper. Such delegation may be made with or without the authority to make successive redelegations.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “director of admissions” for “registrar”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “(hereinafter in this chapter referred to as the ‘Academy’)” for “, in this chapter called the ‘Academy’,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/600"},"text":"Pub. L. 85–600","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab74b7d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag"