{"tag":"section","attrib":{"id":"ida8b0689f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208"},"text":null,"children":[{"tag":"num","attrib":{"value":"1208"},"text":"§ 1208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8b068a0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this chapter, a member of a regular component shall be credited with the service described in paragraph (1) or that described in paragraph (2), whichever is greater:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8b068a1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The service that he is considered to have for the purpose of separation, discharge, or retirement for length of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8b068a2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8b068a3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his active service as a member of the armed forces, a nurse, a reserve nurse, a contract surgeon, a contract dental surgeon, or an acting dental surgeon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b068a4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his active service as a member of the National Oceanic and Atmospheric Administration or the Public Health Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8b068a5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his service while participating in exercises or performing duties under sections 502, 503, 504, and 505 of title 32.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the purpose of paragraph (2), active service as a member of the National Oceanic and Atmospheric Administration includes active service as a member of the Environmental Science Services Administration and of the Coast and Geodetic Survey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8b068a6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1208/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the armed forces who is not a member of a regular component shall be credited, for the purposes of this chapter, with the number of years of service that he would count if he were computing his years of service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12733"},"text":"section 12733 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8b068a7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/94"},"text":"70A Stat. 94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8"},"text":"Pub. L. 89–718, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV"},"text":"Pub. L. 96–513, title V","children":[],"tail":", §§ 501(16), 511(42), "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2908"},"text":"94 Stat. 2908","children":[],"tail":", 2923; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1343/a/6"},"text":"Pub. L. 99–661, div. A, title XIII, § 1343(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3992"},"text":"100 Stat. 3992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/j/3"},"text":"Pub. L. 100–26, § 7(j)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/283"},"text":"101 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/c/13"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(c)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/499"},"text":"110 Stat. 499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8b068a8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida8b068a9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida8b068aa-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1208(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:282 (less clauses (2) and (3), less applicability to persons referred to in 37:281, and less applicability to service as a cadet before ","children":[{"tag":"html:span","attrib":{},"text":"August 24, 1912","children":[],"tail":", as a midshipman before "},{"tag":"html:span","attrib":{},"text":"March 4, 1913","children":[],"tail":", as an Army field clerk, or as a field clerk, Army Quartermaster Corps)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-12/ch681/s412"},"text":"Oct. 12, 1949, ch. 681, § 412","children":[],"tail":" (less clause (3), less applicability to persons referred to in § 411, and less applicability to service as a cadet before "},{"tag":"html:span","attrib":{},"text":"August 24, 1912","children":[],"tail":", as a midshipman before "},{"tag":"html:span","attrib":{},"text":"March 4, 1913","children":[],"tail":", as an Army field clerk, or as a field clerk, Army Quartermaster Corps), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/824"},"text":"63 Stat. 824","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1208(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"37:282 (clause (2), less applicability to persons referred to in 37:281, and less applicability to service as a cadet before ","children":[{"tag":"html:span","attrib":{},"text":"August 24, 1912","children":[],"tail":", as a midshipman before "},{"tag":"html:span","attrib":{},"text":"March 4, 1913","children":[],"tail":", as an Army field clerk, or as a field clerk, Army Quartermaster Corps)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “shall be credited with the service described in clause (1) or that described in clause (2), whichever is greater” are substituted for the words “shall be interpreted to mean”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “he is considered to have” are substituted for the words “such member, former member, or person has or is deemed to have pursuant to law”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A), the words “his active service” are substituted for the words “while on the active list or on active duty or while participating in full-time training or other full-time duty provided for or authorized in the National Defense Act, as amended, the Naval Reserve Act of 1938, as amended, or in—other provisions of law” because of the definitions of “active service” and “active duty” in sections 101(24) and 101(22) of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(C), the references to 10:22–23, 24–26, and 30–36 are omitted as repealed by section 401 of the Army Organization Act of 1950, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/271"},"text":"64 Stat. 271","children":[],"tail":". The reference to 32:70 is omitted as repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1933-06-15/ch87/s16"},"text":"section 16 of the act of June 15, 1933, ch. 87","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/159"},"text":"48 Stat. 159","children":[],"tail":". The reference to 10:23a is omitted as executed. The references to 10:38 and 32:66 and 172–175 are omitted as covered by the words “active service”. The references to 32:144–147, 171, and 176 are omitted, since they deal with pay and do not authorize duty or training. The reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s502"},"text":"section 502 of title 32","children":[],"tail":", not contained in 37:282, is inserted, since section 92 of the National Defense Act, as amended (32:62) is referred to in section 412 of the Career Compensation Act of 1949 (37:282)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “any other member” are substituted for the words “members of the reserve components”, since the words “reserve components” are defined by section 102(k) of the Career Compensation Act of 1949, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/805"},"text":"63 Stat. 805","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t37/s231/k"},"text":"37 U.S.C. 231(k)","children":[],"tail":") to include members appointed, enlisted, or inducted without component."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8b068ab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8b068ac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “section 12733” for “section 1333”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" substituted “paragraph (1)” and “paragraph (2)” for “clause (1)” and “clause (2)”, respectively, in introductory provisions, and “paragraph (2)” for “clause 2(B) of this subsection” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" struck out “after "},{"tag":"date","attrib":{"date":"1901-02-02"},"text":"February 2, 1901","children":[],"tail":"” after “a reserve nurse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “separation, discharge, or retirement for length of service” for “separation or mandatory elimination from the active list” in par. (1), substituted “National Oceanic and Atmospheric Administration” for “Environmental Science Services Administration” in par. (2)(B), and, in provisions following par. (2)(C), substituted “as a member of the National Oceanic and Atmospheric Administration includes active service as a member of the Environmental Science Services Administration and” for “as a member of the Environmental Science Services Administration includes service as a member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718"},"text":"Pub. L. 89–718","children":[],"tail":" substituted “Environmental Science Services Administration” for “Coast and Geodetic Survey” in clause (2)(B) and inserted provision that, for purposes of clause (2)(B) of subsec. (a), active service as a member of the Environmental Science Services Administration includes active service as a member of the Coast and Geodetic Survey."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8b068ad-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8b068ae-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1501/c"},"text":"Pub. L. 104–106, div. A, title XV, § 1501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/498"},"text":"110 Stat. 498","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", and as if included as an amendment made by the Reserve Officer Personnel Management Act, title XVI of "},{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":", as originally enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8b068af-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s501/16"},"text":"section 501(16) of Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s511/42"},"text":"section 511(42) of Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"ida8b068b0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The directory language of, but not the amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/718/s8/a"},"text":"Pub. L. 89–718, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1117"},"text":"80 Stat. 1117","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/295/s6/b"},"text":"Pub. L. 97–295, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-12"},"text":"Oct. 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1314"},"text":"96 Stat. 1314","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b068b1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Service Creditable to Certain Regulars","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041/s39"},"text":"Act Aug. 10, 1956, ch. 1041, § 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/635"},"text":"70A Stat. 635","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-08-10/ch1041/s39"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In addition to service with which he may be credited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1208/a/2"},"text":"section 1208(a)(2) of title 10","children":[],"tail":", United States Code [subsec. (a)(2) of this section], a member of a regular component of the armed forces shall be credited, for the purposes of chapter 61 of title 10, United States Code [this chapter], with all service as—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cadet at the United States Military Academy, if appointed before ","children":[{"tag":"date","attrib":{"date":"1912-08-24"},"text":"August 24, 1912","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a midshipman at the United States Naval Academy, if appointed before ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"March 4, 1913","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Army field clerk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a field clerk, Army Quartermaster Corps.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida8b068b2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Officers of the Public Health Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Applicability of subsec. (a)(2) of this section to officers of the Reserve Corps and to officers of the Regular Corps of the Public Health Service, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s212"},"text":"section 212 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ida8b068b3-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida8b068b4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of Public Health Service, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s802"},"text":"section 802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
