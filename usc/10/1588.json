{"tag":"section","attrib":{"id":"ida8fa6916-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588"},"text":null,"children":[{"tag":"num","attrib":{"value":"1588"},"text":"§ 1588.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept certain voluntary services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fa6917-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Accept Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b) and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary concerned may accept from any person the following services:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa6918-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary medical services, dental services, nursing services, or other health-care related services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6919-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary services to be provided for a museum or a natural resources program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa691a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Voluntary services to be provided for programs providing services to members of the uniformed services and the families of such members, including the following programs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa691b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family support programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa691c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Child development and youth services programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa691d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Library and education programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa691e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Religious programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa691f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Housing referral programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6920-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs providing employment assistance to spouses of such members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6921-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Morale, welfare, and recreation programs, to the extent not covered by another subparagraph of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6922-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary services as a member of a funeral honors detail under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1491"},"text":"section 1491 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6923-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Legal services voluntarily provided as legal assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1044"},"text":"section 1044 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6924-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary services as a proctor for administration to secondary school students of the test known as the “Armed Services Vocational Aptitude Battery”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6925-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary translation or interpretation services offered with respect to a foreign language by a person (A) who is registered for such foreign language on the National Foreign Language Skills Registry under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1596b"},"text":"section 1596b of this title","children":[],"tail":", or (B) who otherwise is approved to provide voluntary translation or interpretation services for national security purposes, as determined by the Secretary of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6926-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary services to support programs of a committee of the Employer Support of the Guard and Reserve as authorized by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6927-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary services to facilitate accounting for missing persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6928-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary legal support services provided by law students through internship and externship programs approved by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6929-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements and Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa692a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned shall notify the person of the scope of the services accepted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa692b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a person providing voluntary services accepted under subsection (a), the Secretary concerned shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa692c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the person to the same extent as the Secretary would supervise a compensated employee providing similar services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa692d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the person is licensed, privileged, has appropriate credentials, or is otherwise qualified under applicable law or regulations to provide such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa692e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a person providing voluntary services accepted under subsection (a), the Secretary concerned may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa692f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place the person in a policy-making position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6930-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (e), compensate the person for the provision of such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6931-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Recruit and Train Persons Providing Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may recruit and train persons to provide voluntary services accepted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6932-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status of Persons Providing Services","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa6933-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), while providing voluntary services accepted under subsection (a) or receiving training under subsection (c), a person, other than a person referred to in paragraph (2), shall be considered to be an employee of the Federal Government only for purposes of the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa6934-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter I of chapter 81 of title 5 (relating to compensation for work-related injuries).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6935-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2733"},"text":"Section 2733 of this title","children":[],"tail":" and chapter 171 of title 28 (relating to claims for damages or loss) and chapters 309 and 311 of title 46 (relating to claims for damages or loss on navigable waters)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6936-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"Section 552a of title 5","children":[],"tail":" (relating to maintenance of records on individuals)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6937-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 11 of title 18 (relating to conflicts of interest).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa6938-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1054"},"text":"Section 1054 of this title","children":[],"tail":" (relating to legal malpractice), for a person voluntarily providing legal services accepted under subsection (a)(5), as if the person were providing the services as an attorney of a legal staff within the Department of Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6939-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), while providing a nonappropriated fund instrumentality of the United States with voluntary services accepted under subsection (a), or receiving training under subsection (c) to provide such an instrumentality with services accepted under subsection (a), a person shall be considered an employee of that instrumentality only for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa693a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter II of chapter 81 of title 5 (relating to compensation of nonappropriated fund employees for work-related injuries).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa693b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2733"},"text":"Section 2733 of this title","children":[],"tail":" and chapter 171 of title 28 (relating to claims for damages or loss)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa693c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person providing voluntary services accepted under subsection (a) shall be considered to be an employee of the Federal Government under paragraph (1) or (2) only with respect to services that are within the scope of the services so accepted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa693d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of determining the compensation for work-related injuries payable under chapter 81 of title 5 (pursuant to this subsection) to a person providing voluntary services accepted under subsection (a), the monthly pay of the person for such services shall be deemed to be the amount determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8fa693e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average monthly number of hours that the person provided the services, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8fa693f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum wage determined in accordance with section 6(a)(1) of the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"29 U.S.C. 206(a)(1)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6940-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Incidental Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may provide for reimbursement of a person for incidental expenses incurred by the person in providing voluntary services accepted under subsection (a). The Secretary shall determine which expenses are eligible for reimbursement under this subsection. Any such reimbursement may be made from appropriated or nonappropriated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6941-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Install Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8fa6942-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may install telephone lines and any necessary telecommunication equipment in the private residences of persons, designated in accordance with the regulations prescribed under paragraph (4), who provide voluntary services accepted under paragraph (3) or (8) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6943-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of equipment installed under the authority of paragraph (1), the Secretary concerned may pay the charges incurred for the use of the equipment for authorized purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6944-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out this subsection, the Secretary concerned may use appropriated funds (notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1348"},"text":"section 1348 of title 31","children":[],"tail":") or nonappropriated funds of the military department under the jurisdiction of the Secretary or, with respect to the Coast Guard, the department in which the Coast Guard is operating."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8fa6945-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and, with respect to the Coast Guard when it is not operating as a service in the Navy, the Secretary of Homeland Security shall prescribe regulations to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fa6946-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1588/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary Concerned for Acceptance of Services for Programs Serving Members of NOAA Corps and Their Families","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of the acceptance of services described in subsection (a)(3), the term “Secretary concerned” in subsection (a) shall include the Secretary of Commerce with respect to members of the commissioned officer corps of the National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fa6947-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1266/a"},"text":"Pub. L. 98–94, title XII, § 1266(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/704"},"text":"97 Stat. 704","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXVI/s1624/a"},"text":"Pub. L. 99–145, title XVI, § 1624(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/778"},"text":"99 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXIII/s1355"},"text":"Pub. L. 99–6