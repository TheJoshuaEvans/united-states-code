{"tag":"section","attrib":{"id":"ida9957140-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640"},"text":null,"children":[{"tag":"num","attrib":{"value":"2640"},"text":"§ 2640.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter air transportation of members of the armed forces or cargo","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9957141-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957142-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may not enter into a contract with an air carrier for the charter air transportation of members of the armed forces or cargo unless the air carrier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9957143-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets, at a minimum, the safety standards established by the Secretary of Transportation under chapter 447 of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9957144-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 12 months of experience operating services in air transportation that are substantially equivalent to the service sought by the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9957145-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undergoes a technical safety evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957146-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1)(C), a technical safety evaluation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9957147-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include inspection of a representative number of aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9957148-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be conducted in accordance with regulations prescribed by the Secretary, after consultation with the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957149-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for inspections of each air carrier that contracts with the Department of Defense for the charter air transportation of members of the armed forces or cargo. The inspections shall be conducted in accordance with standards established by the Secretary, after consultation with the Secretary of Transportation, and shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida995714a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An on-site capability survey of the air carrier conducted at least once every two years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida995714b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A performance evaluation of the air carrier conducted at least once every six months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida995714c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A preflight safety inspection of each aircraft conducted at any time during the operation of, but not more than 72 hours before, each internationally scheduled charter mission departing the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida995714d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A preflight safety inspection of each aircraft used for domestic charter missions conducted to the greatest extent practical.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida995714e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational check-rides on aircraft conducted periodically.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida995714f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Airlift Review Board","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a Commercial Airlift Review Board within the Department of Defense. The Board shall consist of personnel from the Department of Defense and other Government personnel as may be appropriate. The duties of the Board shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957150-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make recommendations to the Secretary on suspension and reinstatement of air carriers under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957151-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make recommendations to the Secretary on waivers under subsection (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957152-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out such other duties and make recommendations on such other matters as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957153-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension and Reinstatement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957154-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish guidelines for the suspension of air carriers under contract with the Department of Defense for the charter air transportation of members of the armed forces or cargo and for the reinstatement of air carriers that have been so suspended. The guidelines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9957155-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require the immediate determination of whether to suspend an air carrier if an aircraft of the air carrier is involved in a fatal accident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9957156-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may require the suspension of an air carrier—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida9957157-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the carrier is in violation of any order, rule, regulation, or standard prescribed under chapter 447 of title 49; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida9957158-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an aircraft of the air carrier is involved in a serious accident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957159-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commercial Airlift Review Board shall make recommendations to the Secretary on suspension and reinstatement under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida995715a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall include in each contract subject to this section the provisions on suspension and reinstatement established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida995715b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Leave Unsafe Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A representative of the Military Airlift Command, the Military Traffic Management Command, or such other agency as may be designated by the Secretary of Defense (or if there is no such representative reasonably available, the senior officer on board a chartered aircraft) may order members of the armed forces or cargo to leave a chartered aircraft if the representative (or officer) determines that a condition exists on the aircraft which may endanger the safety of the members or cargo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida995715c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FAA Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall request the Secretary of Transportation to provide to the Secretary a report on each inspection performed by Federal Aviation Administration personnel, and the status of corrective actions taken, on each aircraft of an air carrier under contract with the Department of Defense for the charter air transportation of members of the armed forces or cargo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida995715d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After considering recommendations by the Commercial Airlift Review Board, the Secretary may waive any provision of this section in an emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida995715e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Protect Safety-Related Information Voluntarily Provided by an Air Carrier","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida995715f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary of Defense may (notwithstanding any other provision of law) withhold from public disclosure safety-related information that is provided to the Secretary voluntarily by an air carrier for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957160-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information may be withheld under paragraph (1) from public disclosure only if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9957161-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disclosure of the information would inhibit an air carrier from voluntarily providing, in the future, safety-related information for the purposes of this section or for other air safety purposes involving the Department of Defense or another Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9957162-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt of such information generally enhances the fulfillment of responsibilities under this section or other air safety responsibilities involving the Department of Defense or another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957163-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary provides to the head of another agency safety-related information described in paragraph (1) with respect to which the Secretary has made a determination described in paragraph (2), the head of that agency shall (notwithstanding any other provision of law) withhold the information from public disclosure unless the disclosure is specifically authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957164-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section, including requirements and identification of inspecting personnel with respect to preflight safety inspections required by subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9957165-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9957166-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “air carrier”, “aircraft”, “air transportation”, “cargo”, and “charter air transportation” have the meanings given such terms by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9957167-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2640/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “members of the armed forces” means members of the Army, Navy, Air Force, Marine Corps, and Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9957168-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/661/dA/tXII/s1204/a/1"},"text":"Pub. L. 99–661, div. A, title XII, § 1204(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3969"},"text":"100 Stat. 3969","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/b/1"},"text":"Pub. L. 103–272, § 5(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1373"},"text":"108 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1075/a"},"text":"Pub. L. 105–85, div. A, title X, § 1075(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1911"},"text":"111 Stat. 1911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/1/P"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(1)(P)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3820"},"text":"134 Stat. 3820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1083/d/1"},"text":"Pub. L. 117–81, div. A, title X, § 1083(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1923"},"text":"135 Stat. 1923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9957169-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida995716a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida995716b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/A"},"text":"Pub. L. 117–81, § 1083(d)(1)(A)","children":[],"tail":", inserted “or cargo” after “armed forces” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/B"},"text":"Pub. L. 117–81, § 1083(d)(1)(B)","children":[],"tail":", inserted “or cargo” after “members of the armed forces” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/C"},"text":"Pub. L. 117–81, § 1083(d)(1)(C)","children":[],"tail":", inserted “or cargo” after “members of the armed forces” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/D"},"text":"Pub. L. 117–81, § 1083(d)(1)(D)","children":[],"tail":", inserted “or cargo” after “members of the armed forces” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/E"},"text":"Pub. L. 117–81, § 1083(d)(1)(E)","children":[],"tail":", inserted “or cargo” after “members of the armed forces” and before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/F"},"text":"Pub. L. 117–81, § 1083(d)(1)(F)","children":[],"tail":", inserted “or cargo” after “members of the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1083/d/1/G"},"text":"Pub. L. 117–81, § 1083(d)(1)(G)","children":[],"tail":", inserted “ ‘cargo’,” after “ ‘air transportation’,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Marine Corps, and Space Force” for “and Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" added subsec. (h) and redesignated former