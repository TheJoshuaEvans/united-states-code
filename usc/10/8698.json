{"tag":"section","attrib":{"id":"idab403c2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698"},"text":null,"children":[{"tag":"num","attrib":{"value":"8698"},"text":"§ 8698.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Roles and responsibilities relating to sustainment and readiness of certain naval surface vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab403c2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Type Commander Leadership","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403c30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning on the date that is one year after the date of the enactment of this section, the Secretary of the Navy shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate type commanders as the primary authorities responsible for the maintenance, repair, sustainment, and readiness of covered vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that regional maintenance centers act under the direction of, and in support of, type commanders with respect to such maintenance, repair, and sustainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The responsibilities of each type commander under paragraph (1)(A) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c34-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing all maintenance and repair activities at private shipyards for covered vessels in the naval force of that type commander; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c35-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting priorities and approving contracts for the maintenance and repair of such vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c36-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance and Repair at Private Shipyards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403c37-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning on the date that is one year after the date of the enactment of this section, for each covered vessel undergoing maintenance or repair at a private shipyard, the project manager concerned, the port engineer concerned, and the commanding officer of such vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c38-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may jointly determine the work to be performed during the overhaul period for the covered vessel, including by jointly adjusting priorities for such work consistent with the applicable budget and schedule for such maintenance or repair; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report directly to the type commander of the naval force to which the covered vessel belongs with respect to such maintenance or repair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracting officers of the Department of Defense shall manage contracts as necessary to ensure consistency with any determination or adjustment made pursuant to paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab403c3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab403c3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “covered vessel” means a naval surface vessel that is not propelled or powered by a nuclear reactor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “port engineer concerned” means, with respect to a naval vessel, the technical expert on the condition of such vessel responsible for advising on repairs and related standards for such vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “project manager concerned” means, with respect to a naval vessel undergoing maintenance or repair, the individual responsible for overseeing the overhaul period with respect to such maintenance or repair.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “regional maintenance center”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an organization of the Navy that supports ship maintenance in a designated geographic region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c41-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the Mid-Atlantic Regional Maintenance Center in Nofolk, Virginia, the Southwest Regional Maintenance Center in San Diego, California, the Southeast Regional Maintenance Center in Mayport, Florida, and the Hawaii Regional Maintenance Center in Pearl Harbor, Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab403c42-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “type commander” means the flag officer in command of a naval surface force, such as the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab403c43-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commander, Naval Surface Force, Atlantic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab403c44-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8698/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commander, Naval Surface Force, Pacific Fleet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab403c45-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tIII/s337"},"text":"Pub. L. 119–60, div. A, title III, § 337","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/819"},"text":"139 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab403c46-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab403c47-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab403c48-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in text, means the date of enactment of the National Defense Authorization Act for Fiscal Year 2026, which was approved on ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
