{"tag":"section","attrib":{"id":"ida7bd2ec1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436"},"text":null,"children":[{"tag":"num","attrib":{"value":"436"},"text":"§ 436.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall prescribe regulations to implement the authority provided in this subchapter. Such regulations shall be consistent with this subchapter and shall at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7bd2ec2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify all elements of the Department of Defense who are authorized to engage in commercial activities pursuant to this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ec3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the personal approval of the Secretary or Deputy Secretary of Defense for all sensitive activities to be authorized pursuant to this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ec4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify all officials who are authorized to grant waivers of laws or regulations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s433/b"},"text":"section 433(b) of this title","children":[],"tail":", or to approve the establishment or conduct of commercial activities pursuant to this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ec5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a single office within the Department of Defense to be responsible for the oversight of all activities authorized under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ec6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that each commercial activity proposed to be authorized under this subchapter be subject to appropriate legal review before the activity is authorized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7bd2ec7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s436/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for appropriate internal audit controls and oversight for such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7bd2ec8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/88/tV/s504/a/2"},"text":"Pub. L. 102–88, title V, § 504(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-14"},"text":"Aug. 14, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/439"},"text":"105 Stat. 439","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tIX/s921/b"},"text":"Pub. L. 113–66, div. A, title IX, § 921(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/827"},"text":"127 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7bd2ec9-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7bd2eca-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7bd2ecb-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" substituted “Department of Defense” for “Defense Intelligence Agency” and “oversight” for “management and supervision”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
