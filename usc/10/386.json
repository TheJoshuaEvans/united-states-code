/s332/a"},"text":"section 332(a) of this title","children":[],"tail":", the number of Department of Defense personnel assigned as advisors to a ministry of defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s332/b"},"text":"section 332(b) of this title","children":[],"tail":", the number of activities conducted by the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of new programs carried out during the period of the report that required notice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s333"},"text":"section 333 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s335"},"text":"section 335 of this title","children":[],"tail":", the number of partner country officials who participated in training provided by the Government of Colombia that began during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s341"},"text":"section 341 of this title","children":[],"tail":", the number of Department of Defense bilateral state partnership program engagements with the partner country that began during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s342"},"text":"section 342 of this title","children":[],"tail":", the number of partner country officials who participated in regional center activity that began during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to the authorities under sections 343, 345, 348, 349, 350 and 352 of this title, the total number of partner country personnel who began training during the period of the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s347"},"text":"section 347 of this title","children":[],"tail":", the number of cadets from the partner country that were enrolled in the Service Academies during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bc9-3a6f-11f1-a58a-d8db54b14ab