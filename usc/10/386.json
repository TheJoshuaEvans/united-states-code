{"tag":"section","attrib":{"id":"ida7aa1bae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386"},"text":null,"children":[{"tag":"num","attrib":{"value":"386"},"text":"§ 386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7aa1baf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than March 31 of each year, the Secretary of Defense shall submit to the appropriate congressional committees a report that sets forth, on a country-by-country basis, an overview of security cooperation activities carried out by the Department of Defense during the fiscal year in which such report is submitted, using the authorities specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7aa1bb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements of Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under subsection (a) shall include, with respect to each country and for the entirety of the period covered by such report, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7aa1bb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A narrative summary that provides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief overview of the primary security cooperation objectives for the activities encompassed by the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how such activities advance the theater security cooperation strategy of the relevant geographic combatant command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7aa1bb4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A table that includes an aggregated amount with respect to each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s331"},"text":"section 331 of this title","children":[],"tail":", the value of all logistic support, supplies, and services for which notice is required by such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to amounts made available for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s332/a"},"text":"section 332(a) of this title","children":[],"tail":", the Department of Defense cost to provide any Department personnel as advisors to a ministry of defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to amounts made available for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s332/b"},"text":"section 332(b) of this title","children":[],"tail":", the Department of Defense incremental execution costs to conduct activities under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s333"},"text":"section 333 of this title","children":[],"tail":", the value of all programs for which notice is required by such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bb9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s335"},"text":"section 335 of this title","children":[],"tail":", the total Department of Defense costs to fund expenses to attend training provided by the Government of Colombia that began during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to amounts made available for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s341"},"text":"section 341 of this title","children":[],"tail":", the Department of Defense manpower and travel costs to conduct bilateral state partnership program engagements with the partner country."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bbb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to amounts made available for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s342"},"text":"section 342 of this title","children":[],"tail":", the Department of Defense-funded, foreign-partner travel costs to attend a regional center activity that began during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bbc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to amounts made available for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s345"},"text":"section 345 of this title","children":[],"tail":", the estimated Department of Defense execution cost to complete all training that began during the period of the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida7aa1bbd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s386/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to amounts made available for ","childr