{"tag":"section","attrib":{"id":"idaa39ee77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3786"},"text":null,"children":[{"tag":"num","attrib":{"value":"3786"},"text":"§ 3786.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use or release restriction: definition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the term “use or release restriction”, with respect to technical data delivered to the United States under a contract subject to this section, means a restriction by the contractor or subcontractor on the right of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa39ee78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3786/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use such technical data; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa39ee79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3786/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to release or disclose such technical data to persons outside the Government or permit the use of such technical data by persons outside the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa39ee7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1833/g"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1833(g)","children":[],"tail":", (m), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4231"},"text":"134 Stat. 4231","children":[],"tail":", 4233.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa39ee7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","chil