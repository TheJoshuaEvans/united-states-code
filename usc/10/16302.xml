84; <ref href="/us/pl/111/84/dA/tVI/s612/a/2">Pub. L. 111–84, div. A, title VI, § 612(a)(2)</ref>, <date date="2009-10-28">Oct. 28, 2009</date>, <ref href="/us/stat/123/2353">123 Stat. 2353</ref>; <ref href="/us/pl/111/383/dA/tVI/s612/a/2">Pub. L. 111–383, div. A, title VI, § 612(a)(2)</ref>, <date date="2011-01-07">Jan. 7, 2011</date>, <ref href="/us/stat/124/4236">124 Stat. 4236</ref>; <ref href="/us/pl/112/81/dA/tVI/s612/a/2">Pub. L. 112–81, div. A, title VI, § 612(a)(2)</ref>, <date date="2011-12-31">Dec. 31, 2011</date>, <ref href="/us/stat/125/1449">125 Stat. 1449</ref>; <ref href="/us/pl/112/239/dA/tVI/s612/a/2">Pub. L. 112–239, div. A, title VI, § 612(a)(2)</ref>, <date date="2013-01-02">Jan. 2, 2013</date>, <ref href="/us/stat/126/1776">126 Stat. 1776</ref>; <ref href="/us/pl/113/66/dA/tVI/s612/a/2">Pub. L. 113–66, div. A, title VI, § 612(a)(2)</ref>, <date date="2013-12-26">Dec. 26, 2013</date>, <ref href="/us/stat/127/780">127 Stat. 780</ref>; <ref href="/us/pl/113/291/dA/tVI/s612/a/2">Pub. L. 113–291, div. A, title VI, § 612(a)(2)</ref>, <date date="2014-12-19">Dec. 19, 2014</date>, <ref href="/us/stat/128/3400">128 Stat. 3400</ref>; <ref href="/us/pl/114/92/dA/tVI/s612/a/2">Pub. L. 114–92, div. A, title VI, § 612(a)(2)</ref>, <date date="2015-11-25">Nov. 25, 2015</date>, <ref href="/us/stat/129/838">129 Stat. 838</ref>; <ref href="/us/pl/114/328/dA/tVI/s612/a/2">Pub. L. 114–328, div. A, title VI, § 612(a)(2)</ref>, <date date="2016-12-23">Dec. 23, 2016</date>, <ref href="/us/stat/130/2158">130 Stat. 2158</ref>; <ref href="/us/pl/115/91/dA/tVI/s612/a/2">Pub. L. 115–91, div. A, title VI, § 612(a)(2)</ref>, <date date="2017-12-12">Dec. 12, 2017</date>, <ref href="/us/stat/131/1421">131 Stat. 1421</ref>; <ref href="/us/pl/115/232/dA/tVI/s611/b/2">Pub. L. 115–232, div. A, title VI, § 611(b)(2)</ref>, <date date="2018-08-13">Aug. 13, 2018</date>, <ref href="/us/stat/132/1797">132 Stat. 1797</ref>; <ref href="/us/pl/116/92/dA/tVI/s611/b/2">Pub. L. 116–92, div.