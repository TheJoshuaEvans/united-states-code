{"tag":"section","attrib":{"id":"ida804bea7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723"},"text":null,"children":[{"tag":"num","attrib":{"value":"723"},"text":"§ 723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of civil authorities: requirement for use of members of the Armed Forces and Federal law enforcement personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida804bea8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response to Civil Disturbances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever a member of the armed forces (including the National Guard) or Federal law enforcement personnel provide support to Federal authorities to respond to a civil disturbance, each individual employed in the capacity of providing such support shall visibly display—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804bea9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual’s name or other individual identifier that is unique to that individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804beaa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the armed force, Federal entity, or other organization by which such individual is employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804beab-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support to Civilian Law Enforcement Agencies by Members of the Armed Forces","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever a member of the armed forces (including the National Guard) provides support to civilian law enforcement agencies, each such member providing such support shall visibly display the name of the armed force in which such member operates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida804beac-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements under subsections (a) and (b) shall not apply to individuals referred to in any such subsection who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida804bead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not wear a uniform or other distinguishing clothing or equipment in the regular performance of their official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida804beae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are engaged in undercover operations in the regular performance of their official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida804beaf-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1064/a"},"text":"Pub. L. 116–283, div. A, title X, § 1064(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3860"},"text":"134 Stat. 3860","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1043/a/1"},"text":"Pub. L. 119–60, div. A, title X, § 1043(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1037"},"text":"139 Stat. 1037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida804beb0-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida804beb1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida804beb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1043/b/1"},"text":"Pub. L. 119–60, § 1043(b)(1)","children":[],"tail":", substituted “civil authorities” for “Federal authorities in response to civil disturbances” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1043/a/1"},"text":"Pub. L. 119–60, § 1043(a)(1)","children":[],"tail":", substituted “Response to Civil Disturbances” for “Requirement” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1043/a/3"},"text":"Pub. L. 119–60, § 1043(a)(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1043/a/2"},"text":"Pub. L. 119–60, § 1043(a)(2)","children":[],"tail":", (4), redesignated subsec. (b) as (c) and, in introductory provisions, substituted “requirements under subsections (a) and (b)” for “requirement under subsection (a)” and “any such subsection” for “such subsection”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
