er “Medical Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/33/273"},"text":"33 Stat. 273","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1905-03-02/ch1307"},"text":"Mar. 2, 1905, ch. 1307","children":[],"tail":" (last proviso under “Medical Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/33/839"},"text":"33 Stat. 839","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1915-03-04/ch143"},"text":"Mar. 4, 1915, ch. 143","children":[],"tail":" (2d proviso under “Medical Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/38/1080"},"text":"38 Stat. 1080","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1897-06-04/ch2"},"text":"June 4, 1897, ch. 2","children":[],"tail":" (par. under “Soldiers’ Home, District of Columbia”), "},{"tag":"html:a","attrib":{"href":"/us/stat/30/54"},"text":"30 Stat. 54","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-06-28/ch383/s402/d"},"text":"June 28, 1950, ch. 383, § 402(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/272"},"text":"64 Stat. 272","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “on active duty” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “rates of charge”, “to cover the cost of purchase, inspection, and so forth”, and “as can be spared without detriment to the military service” are omitted as surplusage. The words “the contract prices paid therefor” are omitted to reflect Title IV of the National Security Act of 1947, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"), which authorized the Secretary of Defense to prescribe regulations governing the use and sale of certain inventories, at cost, including applicable administrative expenses. (See opinion of the Assistant General Counsel (Fiscal Matters) of the Office of the Secretary of Defense, "},{"tag":"date","attrib":{"date":"1955-01-04"},"text":"January 4, 1955","children":[],"tail":".) The word “equipments” is omitted as covered by the word “supplies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “The Secretary” are substituted for the words “Medical Department of the Army”, since the functions which, for the Army, are assigned by statute to subordinate organizational units of the Army, are, for the Air Force, assigned to the Secretary of the Air Force.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “in the District of Columbia” are omitted as surplusage, since there is only one Soldiers’ Home. The words “Upon proper application therefor” are omitted as surplusage. The words “its contract prices” are omitted to reflect Title IV of the National Security Act of 1947, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/585"},"text":"63 Stat. 585","children":[],"tail":"), which authorized the Secretary of Defense to prescribe regulations governing the use and sale of certain inventories at cost, including applicable administrative expenses. (See opinion of the Assistant General Counsel (Fiscal Matters) of the Office of the Secretary of Defense, "},{"tag":"date","attrib":{"date":"1955-01-04"},"text":"January 4, 1955","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab83101f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab831020-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Air Force or Space Force military installation” for “air base” and “Department of the Air Force when” for “Air Force when”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1533/a/8/B"},"text":"Pub. L. 101–510, § 1533(a)(8)(B)","children":[],"tail":", substituted “Armed Forces Retirement Home” for “Soldiers’ and Airmen’s Home” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1533/a/8/A"},"text":"Pub. L. 101–510, § 1533(a)(8)(A)","children":[],"tail":", substituted “Armed Forces Retirement Home” for “United States Soldiers’ and Airmen’s Home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s514/17/B"},"text":"Pub. L. 96–513, § 514(17)(B)","children":[],"tail":", inserted “the” before “Air” and “and Airmen’s” after “Soldiers’ ” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s514/17/A"},"text":"Pub. L. 96–513, § 514(17)(A)","children":[],"tail":", substituted “United States Soldiers’ and Airmen’s” for “Soldiers’ ”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab831021-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab831022-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1541"},"text":"section 1541 of Pub. L. 101–510","children":[],"tail":", formerly set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of Title 24","children":[],"tail":", Hospitals and Asylums."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab831023-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","child