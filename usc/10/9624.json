{"tag":"section","attrib":{"id":"idab80a017-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9624"},"text":null,"children":[{"tag":"num","attrib":{"value":"9624"},"text":"§ 9624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical supplies: civilian employees of the Air Force; American National Red Cross; Armed Forces Retirement Home","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab80a018-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations to be prescribed by the Secretary of the Air Force, a civilian employee of the Department of the Air Force who is stationed at an Air Force or Space Force military installation may buy necessary medical supplies from the Department of the Air Force when they are prescribed by a medical officer on active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab80a019-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may sell medical supplies to the American National Red Cross for cash.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab80a01a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may sell medical and hospital supplies to the Armed Forces Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab80a01b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag"