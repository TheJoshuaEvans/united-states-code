{"tag":"section","attrib":{"id":"idab8c86ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204"},"text":null,"children":[{"tag":"num","attrib":{"value":"10204"},"text":"§ 10204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab8c86bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned shall maintain adequate and current personnel records of each member of the reserve components under the Secretary’s jurisdiction showing the following with respect to the member:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab8c86bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physical condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dependency status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military qualifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civilian occupational skills.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Availability for service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab8c86c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary concerned may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab8c86c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s10204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations to be prescribed by the Secretary of Defense, the Secretary of each military department shall maintain a record of the number of members of each class of each reserve component who, during each fiscal year, have participated satisfactorily in active duty for training and inactive duty training with pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab8c86c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1661/a/1"},"text":"Pub. L. 103–337, div. A, title XVI, § 1661(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2977"},"text":"108 Stat. 2977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab8c86c4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab8c86c5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab8c86c6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s275"},"text":"section 275 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1661/a/2/A"},"text":"Pub. L. 103–337, § 1661(a)(2)(A)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab8c86c7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab8c86c8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1994-12-01"},"text":"Dec. 1, 1994","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691"},"text":"section 1691 of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idab8c86c9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Records of Service for Reserves","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s570"},"text":"Pub. L. 116–92, div. A, title V, § 570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1397"},"text":"133 Stat. 1397","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s570"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", the Secretary of Defense shall establish and implement a standard record of service for members of the reserve components of the Armed Forces, similar to DD Form 214, that summarizes the record of service of each such member, including dates of active duty service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Secretary of Defense shall coordinate with the Secretary of Veterans Affairs to ensure that the record established under this section is acceptable as proof of service for former members of the reserve components of the Armed Forces who are eligible for benefits under laws administered by the Secretary of Veterans Affairs to receive such benefits.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
