{"tag":"section","attrib":{"id":"ida81cb404-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846"},"text":null,"children":[{"tag":"num","attrib":{"value":"846"},"text":"§ 846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Art. 46. Opportunity to obtain witnesses and other evidence in trials by court-martial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida81cb405-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity To Obtain Witnesses and Other Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case referred for trial by court-martial, the trial counsel, the defense counsel, and the court-martial shall have equal opportunity to obtain witnesses and other evidence in accordance with such regulations as the President may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb406-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoena and Other Process Generally","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any subpoena or other process issued under this section (article)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb407-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be similar to that which courts of the United States having criminal jurisdiction may issue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb408-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be executed in accordance with regulations prescribed by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb409-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall run to any part of the United States and to the Commonwealths and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb40a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoena and Other Process for Witnesses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A subpoena or other process may be issued to compel a witness to appear and testify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb40b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before a court-martial, military commission, or court of inquiry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb40c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a deposition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s849"},"text":"section 849 of this title","children":[],"tail":" (article 49); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb40d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb40e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoena and Other Process for Evidence.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb40f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A subpoena or other process may be issued to compel the production of evidence—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida81cb410-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a court-martial, military commission, or court of inquiry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb411-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a deposition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s849"},"text":"section 849 of this title","children":[],"tail":" (article 49);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb412-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an investigation of an offense under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida81cb413-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb414-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigative subpoena","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An investigative subpoena under paragraph (1)(C) may be issued before referral of charges to a court-martial only if a general court-martial convening authority has authorized counsel for the Government to issue such a subpoena or a military judge issues such a subpoena pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s830a"},"text":"section 830a of this title","children":[],"tail":" (article 30a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb415-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Warrant or order for wire or electronic communications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to an investigation of an offense under this chapter, a military judge detailed in accordance with section 826 or 830a of this title (article 26 or 30a) may issue warrants or court orders for the contents of, and records concerning, wire or electronic communications in the same manner as such warrants and orders may be issued by a district court of the United States under chapter 121 of title 18, subject to such limitations as the President may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida81cb416-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Relief From Subpoena or Other Process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person requests relief from a subpoena or other process under this section (article) on grounds that compliance is unreasonable or oppressive or is prohibited by law, a military judge detailed in accordance with section 826 or 830a of this title (article 26 or 30a) shall review the request and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida81cb417-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order that the subpoena or other process be modified or withdrawn, as appropriate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida81cb418-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s846/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order the person to comply with the subpoena or other process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida81cb419-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/53"},"text":"70A Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/a/6"},"text":"Pub. L. 109–163, div. A, title X, § 1057(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dA/tXVII/s1704"},"text":"Pub. L. 113–66, div. A, title XVII, § 1704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/958"},"text":"127 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tV/s531/b"},"text":"Pub. L. 113–291, div. A, title V, § 531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3363"},"text":"128 Stat. 3363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dE/tLVII/s5228/a"},"text":"Pub. L. 114–328, div. E, title LVII, § 5228(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2911"},"text":"130 Stat. 2911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida81cb41a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida81cb41b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida81cb41c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"846","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50:621.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-05/ch169/s1"},"text":"May 5, 1950, ch. 169, § 1","children":[],"tail":" (Art. 46), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/122"},"text":"64 Stat. 122","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “Commonwealths” is inserted to reflect the present status of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida81cb41d-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida81cb41e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5228/a/5"},"text":"Pub. L. 114–328, § 5228(a)(5)","children":[],"tail":", amended section catchline generally, substituting “Opportunity to obtain witnesses and other evidence in trials by court-martial” for “Opportunity to obtain witnesses and other evidence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5228/a/1"},"text":"Pub. L. 114–328, § 5228(a)(1)","children":[],"tail":", substituted “In a case referred for trial by court-martial, the trial counsel, the defense counsel,” for “The counsel for the Government, the counsel for the accused,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5228/a/2"},"text":"Pub. L. 114–328, § 5228(a)(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) related to request by counsel for accused to interview the victim of an alleged sex-related offense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5228/a/3"},"text":"Pub. L. 114–328, § 5228(a)(3)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “Process issued in court-martial cases to compel witnesses to appear and testify and to compel the production of other evidence shall be similar to that which courts of the United States having criminal jurisdiction may lawfully issue and shall run to any part of the United States, or the Commonwealths and possessions.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5228/a/4"},"text":"Pub. L. 114–328, § 5228(a)(4)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/b/2"},"text":"Pub. L. 113–291, § 531(b)(2)","children":[],"tail":", (3)(B), substituted “counsel for the Government” for “trial counsel” and “counsel for the accused” for “defense counsel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/b/3/A"},"text":"Pub. L. 113–291, § 531(b)(3)(A)","children":[],"tail":", which directed substitution of “"},{"tag":"inline","attrib":{},"text":"Counsel for Accused","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Defense Counsel","children":[],"tail":"” in heading of section, was executed by making the substitution in the heading of subsec. (b) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/b/2"},"text":"Pub. L. 113–291, § 531(b)(2)","children":[],"tail":", (3)(B), substituted “counsel for the Government” for “trial counsel” and “counsel for the accused” for “defense counsel” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/s531/b/1"},"text":"Pub. L. 113–291, § 531(b)(1)","children":[],"tail":", substituted “through the Special Victims’ Counsel or other counsel for the victim, if applicable” for “through trial counsel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" designated first sentence as subsec. (a) and second sentence as subsec. (c), inserted headings, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" substituted “Commonwealths and possessions” for “Territories, Commonwealths, and possessions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida81cb41f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida81cb420-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", as designated by the President, with implementing regulations and provisions relating to applicability to various situations, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s5542"},"text":"section 5542 of Pub. L. 114–328","children":[],"tail":" and Ex. Ord. No. 13825, set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s801"},"text":"section 801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
