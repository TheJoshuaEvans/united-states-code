{"tag":"section","attrib":{"id":"ida960f3e6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279b"},"text":"§ 2279b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council on Oversight of the Department of Defense Positioning, Navigation, and Timing Enterprise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida960f3e7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is within the Department of Defense a council to be known as the “Council on Oversight of the Department of Defense Positioning, Navigation, and Timing Enterprise” (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f3e8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Council shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f3e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Research and Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Defense for Acquisition and Sustainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Strategic Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3ee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Northern Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3ef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of the United States Space Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3f0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commander of United States Cyber Command.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3f1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3f2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Information Officer of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3f3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries of the military departments, who shall be ex officio members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3f4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other officers of the Department of Defense as the Secretary may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f3f5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Co-chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall be co-chaired by the Under Secretary of Defense for Research and Engineering, the Under Secretary of Defense for Acquisition and Sustainment, and the Vice Chairman of the Joint Chiefs of Staff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f3f6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f3f7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council shall be responsible for oversight of the Department of Defense positioning, navigation, and timing enterprise, including positioning, navigation, and timing services provided to civil, commercial, scientific, and international users.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f3f8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the responsibility for oversight of the Department of Defense positioning, navigation, and timing enterprise as specified in paragraph (1), the Council shall be responsible for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f3f9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversight of performance assessments (including interoperability).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f3fa-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vulnerability identification and mitigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f3fb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Architecture development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f3fc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alternative methods to perform position navigation and timing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f3fd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Resource prioritization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f3fe-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other responsibilities as the Secretary of Defense shall specify for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f3ff-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the same time each year that the budget of the President is submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Council shall submit to the congressional defense committees a report on the activities of the Council. Each report shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f400-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description and assessment of the activities of the Council during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f401-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the activities proposed to be undertaken by the Council during the period covered by the current future-years defense program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s221"},"text":"section 221 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f402-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any changes to the requirements of the Department of Defense positioning, navigation, and timing enterprise made during the previous year, along with an explanation for why the changes were made and a description of the effects of the changes to the capability of such enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f403-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A breakdown of each program element in such budget that relates to the Department of Defense positioning, navigation, and timing enterprise, including how such program element relates to the operation and sustainment, research and development, procurement, or other activity of such enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f404-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget and Funding Matters","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f405-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 30 days after the President submits to Congress the budget for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", the Commander of the United States Space Command shall submit to the Chairman of the Joint Chiefs of Staff an assessment of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f406-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such budget allows the Federal Government to meet the required capabilities of the Department of Defense positioning, navigation, and timing enterprise during the fiscal year covered by the budget and the four subsequent fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f407-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Commander determines that such budget does not allow the Federal Government to meet such required capabilities, a description of the steps being taken to meet such required capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f408-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 30 days after the date on which the Chairman of the Joint Chiefs of Staff receives the assessment of the Commander of the United States Space Command under paragraph (1), the Chairman shall submit to the congressional defense committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida960f409-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assessment as it was submitted to the Chairman; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida960f40a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any comments of the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f40b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a House of Congress adopts a bill authorizing or appropriating funds for the activities of the Department of Defense positioning, navigation, and timing enterprise that, as determined by the Council, provides insufficient funds for such activities for the period covered by such bill, the Council shall notify the congressional defense committees of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f40c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Anomalies","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida960f40d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall submit to the congressional defense committees written notification of an anomaly in the Department of Defense positioning, navigation, and timing enterprise that is reported to the Secretary or the Council by not later than 14 days after the date on which the Secretary or the Council learns of such anomaly, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida960f40e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “anomaly” means any unplanned, irregular, or abnormal event, whether unexplained or caused intentionally or unintentionally by a person or a system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida960f40f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2279b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall terminate on the date that is 10 years after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida960f410-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXVI/s1603/a"},"text":"Pub. L. 114–92, div. A, title XVI, § 1603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1096"},"text":"129 Stat. 1096","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/31"},"text":"Pub. L. 116–92, div. A, title IX, § 902(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1546"},"text":"133 Stat. 1546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVI/s1604/b"},"text":"Pub. L. 116–283, div. A, title XVI, § 1604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4043"},"text":"134 Stat. 4043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1081/a/27"},"text":"Pub. L. 117–81, div. A, title X, § 1081(a)(27)","children":[],"tail":", title XVI, § 1604, "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1921"},"text":"135 Stat. 1921","children":[],"tail":", 2077.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida960f411-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida960f412-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida960f413-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2022, referred to in subsec. (h), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida960f414-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(7) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1604/b/1"},"text":"Pub. L. 116–283, § 1604(b)(1)","children":[],"tail":", added par. (7) and redesignated former pars. (7) to (10) as (8) to (11) (relating to the Secretaries of the military departments), respectively."}],"tail":"\n"},{"tag":"p","attri