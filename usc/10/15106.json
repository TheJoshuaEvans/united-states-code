{"tag":"section","attrib":{"id":"idabb9d863-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106"},"text":null,"children":[{"tag":"num","attrib":{"value":"15106"},"text":"§ 15106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure of selection for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb9d864-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this section, sections 14501 through 14513 of this title shall apply to promotions of officers in competitive categories of officers designated for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d865-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Failure of Selection for Promotion to Officers Above Promotion Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14501"},"text":"section 14501 of this title","children":[],"tail":" to an officer above the promotion zone shall not apply in the promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d866-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Selection Board Matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14502/a/1"},"text":"section 14502(a)(1) of this title","children":[],"tail":" to a person above the promotion zone shall not apply in the promotion of officers described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb9d867-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Failure of Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the administration of this chapter pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb9d868-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer described in subsection (a) shall not be deemed to have failed twice of selection for promotion for purposes of section 14502(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002178"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title until the officer has failed selection of promotion to the next higher grade the maximum number of times specified for opportunities for promotion to such grade within the competitive category concerned pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s15104"},"text":"section 15104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb9d869-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference in sections 14504 through 14506 of this title to an officer who has failed of selection for promotion to the next higher grade for the second time shall be deemed to refer instead to an officer described in subsection (a) who has failed of selection for promotion to the next higher grade for the maximum number of times specified for opportunities for promotion to such grade within the competitive category concerned pursuant to such section 15104.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb9d86a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s514/a"},"text":"Pub. L. 118–31, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/247"},"text":"137 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb9d86b-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabb9d86c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idabb9d86d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14502/b"},"text":"Section 14502(b) of this title","children":[],"tail":", referred to in subsec. (d)(1), probably should be "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14501/b"},"text":"section 14501(b) of this title","children":[],"tail":", which relates to officers twice failed of selection. "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s14502/b"},"text":"Section 14502(b) of this title","children":[],"tail":" relates to officers considered but not selected due to material error."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
