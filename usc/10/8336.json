{"tag":"section","attrib":{"id":"idab1ed02f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8336"},"text":null,"children":[{"tag":"num","attrib":{"value":"8336"},"text":"§ 8336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highest grade held satisfactorily: Reserve enlisted members reduced in grade not as a result of the member’s misconduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab1ed030-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Navy Reserve or Marine Corps Reserve described in subsection (b) who is transferred to the Fleet Reserve or the Fleet Marine Corps Reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8330"},"text":"section 8330 of this title","children":[],"tail":" shall be transferred in the highest enlisted grade in which the member served on active duty satisfactorily, as determined by the Secretary of the Navy."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ed031-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to a Reserve enlisted member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab1ed032-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8336/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of transfer to the Fleet Reserve or Fleet Marine Corps Reserve is serving on active duty in a grade lower than the highest enlisted grade held by the member while on active duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab1ed033-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8336/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was previously administratively reduced in grade not as a result of the member’s own misconduct, as determined by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab1ed034-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies with respect to enlisted members of the Navy Reserve and Marine Corps Reserve who are transferred to the Fleet Reserve or the Fleet Marine Corps Reserve after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab1ed035-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tV/s532/b/1"},"text":"Pub. L. 104–201, div. A, title V, § 532(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2519"},"text":"110 Stat. 2519","children":[],"tail":", § 6336; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/b/1/L"},"text":"Pub. L. 109–163, div. A, title V, § 515(b)(1)(L)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3233"},"text":"119 Stat. 3233","children":[],"tail":"; renumbered § 8336 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII"},"text":"Pub. L. 115–232, div. A, title VIII","children":[],"tail":", §§ 807(b)(15), 809(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"t