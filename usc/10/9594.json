{"tag":"section","attrib":{"id":"idab809fe4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594"},"text":null,"children":[{"tag":"num","attrib":{"value":"9594"},"text":"§ 9594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of the Air Force Military History Institute: fee for providing historical information to the public","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab809fe5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Secretary of the Air Force may charge a person a fee for providing the person with information from the United States Department of the Air Force Military History Institute that is requested by that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809fe6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fee may not be charged under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab809fe7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person for information that the person requests to carry out a duty as a member of the armed forces or an officer or employee of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab809fe8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a release of information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809fe9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee charged for providing information under this section may not exceed the cost of providing the information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809fea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received under subsection (a) for providing information in any fiscal year shall be credited to the appropriation or appropriations charged the costs of providing information to the public from the United States Department of the Air Force Military History Institute during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab809feb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab809fec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States Department of the Air Force Military History Institute” means the archive for historical records and materials of the Air Force and the Space Force that the Secretary of the Air Force designates as the primary archive for such records and materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab809fed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9594/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “officer of the United States” and “employee of the United States” have the meanings given the terms “officer” and “employee”, respectively, in sections 2104 and 2105, respectively, of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab809fee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1085(c)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–289; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/e/8/A"},"text":"Pub. L. 116–283, div. A, title IX, § 923(e)(8)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3816"},"text":"134 Stat. 3816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab809fef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab809ff0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab809ff1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/8/B"},"text":"Pub. L. 116–283, § 923(e)(8)(B)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Air Force Military History Institute: fee for providing historical information to the public”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/8/A/i"},"text":"Pub. L. 116–283, § 923(e)(8)(A)(i)","children":[],"tail":", inserted “Department of the” before “Air Force Military History”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/e/8/A/ii"},"text":"Pub. L. 116–283, § 923(e)(8)(A)(ii)","children":[],"tail":", inserted “Department of the” before “Air Force Military History” and “and the Space Force” after “materials of the Air Force”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
