{"tag":"section","attrib":{"id":"idaac69d8a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6211"},"text":null,"children":[{"tag":"num","attrib":{"value":"6211"},"text":"§ 6211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerated schedule for isolating high-level nuclear waste at the Defense Waste Processing Facility, Savannah River Site","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall accelerate the schedule for the isolation of high-level nuclear waste in glass canisters at the Defense Waste Processing Facility at the Savannah River Site, South Carolina, if the Secretary determines that the acceleration of such schedule—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaac69d8b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6211/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will achieve long-term cost savings to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaac69d8c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s6211/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could accelerate the removal and isolation of high-level nuclear waste from long-term storage tanks at the site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaac69d8d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1401"},"text":"139 Stat. 1401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaac69d8e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaac69d8f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaac69d90-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s2631"},"text":"section 2631 of Title 50","children":[],"tail":", War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/s3111/b/1"},"text":"Pub. L. 119–60, § 3111(b)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
