{"tag":"section","attrib":{"id":"idab2ab775-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468"},"text":null,"children":[{"tag":"num","attrib":{"value":"8468"},"text":"§ 8468.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Visitors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab2ab776-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Board of Visitors to the Academy is constituted annually of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2ab777-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chair of the Committee on Armed Services of the Senate, or the designee of such chair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab778-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ranking member of the Committee on Armed Services of the Senate, or the designee of the ranking member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab779-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two other members of the Senate designated by the Majority Leader of the Senate, one of whom is a member of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab77a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two other members of the Senate designated by the Minority Leader of the Senate, one of whom is a member of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab77b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chair of the Committee on Armed Services of the House of Representatives, or the designee of such chair;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab77c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ranking member of the Committee on Armed Services of the House of Representatives, or the designee of the ranking member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab77d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two other members of the House of Representatives designated by the Speaker of the House of Representatives, one of whom is a member of the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab77e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two other members of the House of Representatives designated by the Minority Leader of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab77f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six persons designated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab780-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The persons designated by the President serve for three years each except that any member whose term of office has expired shall continue to serve until his successor is appointed by the President. The President shall designate two persons each year to succeed the members whose terms expire that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab781-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a member of the Board dies or resigns, a successor shall be designated for the unexpired portion of the term by the official who designated the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab782-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall visit the Academy annually. With the approval of the Secretary of the Navy, the Board or its members may make other visits to the Academy in connection with the duties of the Board or to consult with the Superintendent of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab783-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall inquire into the state of morale and discipline, the curriculum, instruction, physical equipment, fiscal affairs, academic methods, and other matters relating to the Academy that the Board decides to consider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab784-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 60 days after its annual visit, the Board shall submit a written report to the President and the Committees on Armed Services of the Senate and House of Representatives of its action and of its views and recommendations pertaining to the Academy. Any report of a visit, other than the annual visit, shall, if approved by a majority of the members of the Board, be submitted to the President and the Committees on Armed Services of the Senate and House of Representatives within 60 days after the approval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab785-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon approval by the Secretary, the Board may call in advisers for consultation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab786-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While performing his duties, each member of the Board and each adviser shall be reimbursed under Government travel regulations for his travel expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab2ab787-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab2ab788-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of the members of the Board may call an official meeting of the Board once per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab2ab789-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member may attend such meeting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab2ab78a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in person, at the Academy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab2ab78b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8468/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remotely, at the election of such member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab2ab78c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/434"},"text":"70A Stat. 434","children":[],"tail":", § 6968; "},{"tag":"ref","attrib":{"href":"/us/pl/96/579/s13/b"},"text":"Pub. L. 96–579, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-23"},"text":"Dec. 23, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3369"},"text":"94 Stat. 3369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1061/e/2"},"text":"Pub. L. 104–106, div. A, title X, § 1061(e)(2)","children":[],"tail":", title XV, § 1502(a)(12), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/443"},"text":"110 Stat. 443","children":[],"tail":", 503; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1067/1"},"text":"Pub. L. 106–65, div. A, title X, § 1067(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/774"},"text":"113 Stat. 774","children":[],"tail":"; renumbered § 8468, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/c/1"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV"},"text":"Pub. L. 117–81, div. A, title V","children":[],"tail":", §§ 554(b), 555(b), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1738"},"text":"135 Stat. 1738","children":[],"tail":", 1739; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s558/b"},"text":"Pub. L. 118–159, div. A, title V, § 558(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","childr