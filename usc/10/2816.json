{"tag":"section","attrib":{"id":"ida9dcda22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816"},"text":null,"children":[{"tag":"num","attrib":{"value":"2816"},"text":"§ 2816.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of energy security and energy resilience in life-cycle cost for military construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9dcda23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned, when evaluating the life-cycle designed cost of a covered military construction project, shall include as a facility requirement the long-term consideration of energy security and energy resilience that would ensure that the resulting facility is capable of continuing to perform its missions, during the life of the facility, in the event of a natural or human-caused disaster, an attack, or any other unplanned event that would otherwise interfere with the ability of the facility to perform its missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A facility requirement under paragraph (1) shall not be weighed, for cost purposes, against other facility requirements in determining the design of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in the Building Life-cycle Cost Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include the requirements of subsection (a) in applying the latest version of the building life-cycle cost program, as developed by the National Institute of Standards and Technology, to consider on-site distributed energy assets in a building design for a covered military construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9dcda27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Military Construction Project Defined","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida9dcda28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “covered military construction project” means a military construction project for a facility that is used to perform critical functions during a natural or human-caused disaster, an attack, or any other unplanned event.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida9dcda29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the term “facility” includes at a minimum any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida9dcda2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operations centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nuclear command and control facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda2c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integrated strategic and tactical warning and attack assessment facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda2d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Continuity of government facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda2e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Missile defense facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda2f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Air defense facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda30-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospitals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda31-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Armories and readiness centers of the National Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda32-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida9dcda33-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2816/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Satellite and missile launch and control facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9dcda34-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dB/tXXVIII/s2804/a"},"text":"Pub. L. 116–283, div. B, title XXVIII, § 2804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4320"},"text":"134 Stat. 4320","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
