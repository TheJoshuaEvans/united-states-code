{"tag":"section","attrib":{"id":"idabb2ab80-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305"},"text":null,"children":[{"tag":"num","attrib":{"value":"14305"},"text":"§ 14305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of promotion zones: mandatory consideration for promotion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabb2ab81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before convening a mandatory promotion board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14101/a"},"text":"section 14101(a) of this title","children":[],"tail":", the Secretary of the military department concerned shall establish a promotion zone for officers serving in each grade and competitive category to be considered by the board."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb2ab82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number in the Zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned shall determine the number of officers in the promotion zone for officers serving in any grade and competitive category from among officers who are eligible for promotion in that grade and competitive category under the provisions of sections 14303 and 14304 of this title and who are otherwise eligible for promotion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabb2ab83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors in Determining Number in the Zone","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary’s determination under subsection (b) shall be made on the basis of an estimate of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabb2ab84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of officers needed in that competitive category in the next higher grade in each of the next five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a promotion zone for officers to be promoted to a grade to which the maximum years of in grade criteria established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s14304"},"text":"section 14304 of this title","children":[],"tail":" apply, the number of officers in that competitive category who are required to be considered for selection for promotion to the next higher grade under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabb2ab86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s14305/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of officers that should be placed in the promotion zone in each of the next five years to provide to officers in those years relatively similar opportunities for promotion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabb2ab87-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1611"},"text":"Pub. L. 103–337, div. A, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2935"},"text":"108 Stat. 2935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabb2ab88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idabb2ab89-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idabb2ab8a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1691/b/1"},"text":"section 1691(b)(1) of Pub. L. 103–337","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s10001"},"text":"section 10001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
