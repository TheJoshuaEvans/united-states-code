ib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out par. (3) which read as follows: “The term ‘Javits-Wagner-O’Day Act’ means the Act entitled ‘An Act to create a Committee on Purchases of Blind-made Products, and for other purposes’, approved "},{"tag":"date","attrib":{"date":"1938-06-25"},"text":"June 25, 1938","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s46–48c"},"text":"41 U.S.C. 46–48c","children":[],"tail":"), commonly referred to as the Wagner-O’Day Act, that was revised and reenacted in the Act of "},{"tag":"date","attrib":{"date":"1971-06-23"},"text":"June 23, 1971","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/85/77"},"text":"85 Stat. 77","children":[],"tail":"), commonly referred to as the Javits-Wagner-O’Day Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s804/1/A"},"text":"Pub. L. 103–337, § 804(1)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s804/1/B"},"text":"Pub. L. 103–337, § 804(1)(B)","children":[],"tail":", (C), redesignated par. (4) as (3) and struck out former par. (3) which read as follows: “The terms ‘approved commodity’ and ‘approved service’ mean a commodity and a service, respectively, that has been determined by the Committee for Purchase from the Blind and Other Severely Handicapped under section 2 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s47"},"text":"41 U.S.C. 47","children":[],"tail":") to be suitable for procurement by the Federal Government.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s804/2"},"text":"Pub. L. 103–337, § 804(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaa411aa7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa411aa8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa411aa9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVIII/s835"},"text":"Pub. L. 105–85, div. A, title VIII, § 835","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1843"},"text":"111 Stat. 1843","children":[],"tail":", provided that the amendment made by that section is effective as of "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"Sept. 30, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaa411aaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s4401"},"text":"section 4401 of Pub. L. 104–106","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2220"},"text":"section 2220 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idaa411aab-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tVIII/s808/c"},"text":"Pub. L. 102–484, div. A, title VIII, § 808(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2450"},"text":"106 Stat. 2450","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tVIII/s808/c"},"text":"“Sections 2301(d) [repealed] and 2410d [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3903"},"text":"10 U.S.C. 3903","children":[],"tail":"] of title 10, United States Code (as added by subsections (a) and (b), respectively), shall take effect on "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa411aac-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contract Participation by Agencies for the Blind or Other Severely Handicapped","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/87/tVIII/s8025"},"text":"Pub. L. 108–87, title VIII, § 8025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1077"},"text":"117 Stat. 1077","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/b/6"},"text":"Pub. L. 113–291, div. A, title X, § 1071(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3507"},"text":"128 Stat. 3507","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dA/tX/s1071/b/6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the funds for the procurement of supplies or services appropriated by this Act [see Tables for classification] and hereafter, qualified nonprofit agencies for the blind or other severely handicapped shall be afforded the maximum practicable opportunity to participate as subcontractors and suppliers in the performance of contracts let by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the current fiscal year and hereafter, a business concern which has negotiated with a military service or defense agency a subcontracting plan for the participation by small business concerns pursuant to section 8(d) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"15 U.S.C. 637(d)","children":[],"tail":") shall be given credit toward meeting that subcontracting goal for any purchases made from qualified nonprofit agencies for the blind or other severely handicapped."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the phrase ‘qualified nonprofit agency for the blind or other severely handicapped’ means a nonprofit agency for the blind or other severely handicapped that has been approved by the Committee for the Purchase from the Blind and Other Severely Handicapped under chapter 85 of title 41, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8025"},"text":"Pub. L. 107–248, title VIII, § 8025","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1542"},"text":"116 Stat. 1542","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/117/dA/tVIII/s8028"},"text":"Pub. L. 107–117, div. A, title VIII, § 8028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-10"},"text":"Jan. 10, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2253"},"text":"115 Stat. 2253","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/259/tVIII/s8028"},"text":"Pub. L. 106–259, title VIII, § 8028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-09"},"text":"Aug. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/680"},"text":"114 Stat. 680","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/79/tVIII/s8030"},"text":"Pub. L. 106–79, title VIII, § 8030","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-25"},"text":"Oct. 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1237"},"text":"113 Stat. 1237","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/262/tVIII/s8030"},"text":"Pub. L. 105–262, title VIII, § 8030","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"hre