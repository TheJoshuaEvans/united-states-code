{"tag":"section","attrib":{"id":"idab724762-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9414b"},"text":"§ 9414b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Air Force Institute of Technology: administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab724763-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director and Chancellor.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab724764-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director and Chancellor of the United States Air Force Institute of Technology shall be selected by the Secretary of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724765-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director and Chancellor shall be one of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab724766-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer of the Air Force or the Space Force on active duty in a grade not below the grade of colonel who possesses such qualifications as the Secretary considers appropriate and is assigned or detailed to such position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab724767-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Senior Executive Service or a civilian individual, including an individual who was retired from the Air Force or the Space Force in a grade not below brigadier general, who has the qualifications appropriate for the position of Director and Chancellor and is selected by the Secretary as the best qualified from among candidates for the position in accordance with a process and criteria determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab724768-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term for civilian director and chancellor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual selected for the position of Director and Chancellor under paragraph (2)(B) shall serve in that position for a term of not more than five years and may be continued in that position for an additional term of up to five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab724769-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provost and Chief Academic Officer.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab72476a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established at the United States Air Force Institute of Technology the civilian position of Provost and Chief Academic Officer who shall be selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab72476b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual selected for the position of Provost and Chief Academic Officer shall serve in that position for a term of not more than five years and may be continued in that position for an additional term of up to five years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab72476c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9414b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The individual serving as Provost and Chief Academic Officer is entitled to such compensation for such service as the Secretary shall prescribe for purposes of this section, but not more than the rate of compensation authorized for level IV of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab72476d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s554/a"},"text":"Pub. L. 112–81, div. A, title V, § 554(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1414"},"text":"125 Stat. 1414","children":[],"tail":", § 9314b; renumbered § 9414b, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s806/a/3"},"text":"Pub. L. 115–232, div. A, title VIII, § 806(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1832"},"text":"132 Stat. 1832","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s556/a"},"text":"Pub. L. 116–92, div. A, title V, § 556(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1392"},"text":"133 Stat. 1392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s923/d/5"},"text":"Pub. L. 116–283, div. A, title IX, § 923(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3814"},"text":"134 Stat. 3814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tV/s554/b"},"text":"Pub. L. 117–263, div. A, title V, § 554(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2594"},"text":"136 Stat. 2594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tV/s521"},"text":"Pub. L. 118–159, div. A, title V, § 521","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1882"},"text":"138 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab72476e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab72476f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idab724770-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsec. (b)(3), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab724771-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out “or the equivalent grade in the Space Force” after “brigadier general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s554/b/2"},"text":"Pub. L. 117–263, § 554(b)(2)","children":[],"tail":", substituted “Chief Academic Officer” for “Academic Dean” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s554/b/1"},"text":"Pub. L. 117–263, § 554(b)(1)","children":[],"tail":", substituted “Chief Academic Officer” for “Academic Dean” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s554/b/3"},"text":"Pub. L. 117–263, § 554(b)(3)","children":[],"tail":", substituted “selected” for “appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s554/b/4"},"text":"Pub. L. 117–263, § 554(b)(4)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “An individual appointed to the position of Provost and Academic Dean shall serve in that position for a term of five years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/5/A"},"text":"Pub. L. 116–283, § 923(d)(5)(A)","children":[],"tail":", inserted “or the Space Force” after “the Air Force” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s923/d/5/B"},"text":"Pub. L. 116–283, § 923(d)(5)(B)","children":[],"tail":", inserted “or the equivalent grade in the Space Force” after “brigadier general”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s556/a/1"},"text":"Pub. L. 116–92, § 556(a)(1)","children":[],"tail":", (2), substituted “"},{"tag":"inline","attrib":{},"text":"Director and Chancellor","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Commandant","children":[],"tail":"” in heading and “Director and Chancellor” for “Commandant” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s556/a/3"},"text":"Pub. L. 116–92, § 556(a)(3)","children":[],"tail":", which directed substitution of “"},{"tag":"inline","attrib":{},"text":"Director and Chancellor","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Commandant","children":[],"tail":"” in heading, was executed by substituting “"},{"tag":"inline","attrib":{},"text":"director and chancellor","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"commandant","children":[],"tail":"” to reflect the probable intent of Congress and conform the style of paragraph headings to that used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s9314b"},"text":"section 9314b of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab724772-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idab724773-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tV/s556/c"},"text":"Pub. L. 116–92, div. A, title V, § 556(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1392"},"text":"133 Stat. 1392","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tV/s556/c"},"text":"“Any reference in any law, regulation, map, document, paper, or other record of the United States to the Commandant of the United States Air Force Institute of Technology shall be deemed to be a reference to the Director and Chancellor of the United States Air Force Institute of Technology.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab724774-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
