{"tag":"section","attrib":{"id":"ida8027511-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a"},"text":null,"children":[{"tag":"num","attrib":{"value":"711a"},"text":"§ 711a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American National Red Cross: detail of commissioned officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Commissioned officers of the Army, Navy, and Air Force may be detailed for duty with the American National Red Cross, by the Secretary of the military department concerned, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8027512-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for duty with the Service to the Armed Forces Division—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8027513-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more officers of the Army Medical Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027514-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more officers of the Medical Department of the Navy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027515-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more officers selected from among medical officers, dental officers, veterinary officers, medical service officers, nurses, and medical specialists of the Air Force; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8027516-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to be in charge of the first-aid department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida8027517-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of the Medical Corps of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027518-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of the Medical Corps of the Navy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida8027519-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s711a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medical officer of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida802751a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/235/s4/a/1/A"},"text":"Pub. L. 90–235, § 4(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/759"},"text":"81 Stat. 759","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/329"},"text":"Pub. L. 90–329","children":[],"tail":", "},