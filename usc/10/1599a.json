{"tag":"section","attrib":{"id":"ida8fcda26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1599a"},"text":"§ 1599a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance to certain employees in acquisition of critical skills","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8fcda27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall establish an undergraduate training program with respect to civilian employees in the Military Department Civilian Intelligence Personnel Management System that is similar in purpose, conditions, content, and administration to the program established by the Secretary of Defense under section 16 of the National Security Agency Act of 1959 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3614"},"text":"50 U.S.C. 3614","children":[],"tail":") for civilian employees of the National Security Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8fcda28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1599a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds for Training Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any payment made by the Secretary to carry out the program required to be established by subsection (a) may be made in any fiscal year only to the extent that appropriated funds are available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8fcda29-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93/tV/s505/a"},"text":"Pub. L. 104–93, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/973"},"text":"109 Stat. 973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/f/20"},"text":"Pub. L. 112–239, div. A, title X, § 1076(f)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1952"},"text":"126 Stat. 1952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tX/s1071/c/9"},"text":"Pub. L. 113–291, div. A, title X, § 1071(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3509"},"text":"128 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8fcda2a-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8fcda2b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8fcda2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3614"},"text":"50 U.S.C. 3614","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s402"},"text":"50 U.S.C. 402","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “National Security Agency Act” for “National Security Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
