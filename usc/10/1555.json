{"tag":"section","attrib":{"id":"ida8e4e63c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555"},"text":null,"children":[{"tag":"num","attrib":{"value":"1555"},"text":"§ 1555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8e4e63d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of each military department shall assign to the staff of the service review agency of that military department at least one attorney and at least one physician. Such assignments shall be made on a permanent, full-time basis and may be made from members of the armed forces or civilian employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e4e63e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Personnel assigned pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e4e63f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall work under the supervision of the director or executive director (as the case may be) of the service review agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e640-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be assigned duties as advisers to the director or executive director or other staff members on legal and medical matters, respectively, that are being considered by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8e4e641-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “service review agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8e4e642-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of the Army, the Army Review Boards Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e643-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of the Navy, the Navy Council of Personnel Boards and the Board for Correction of Naval Records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8e4e644-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1555/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Department of the Air Force, the Department of the Air Force Review Boards Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8e4e645-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s542/a/1"},"text":"Pub. L. 105–261, div. A, title V, § 542(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2020"},"text":"112 Stat. 2020","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s582"},"text":"Pub. L. 106–65, div. A, title V, § 582","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/634"},"text":"113 Stat. 634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/j/2/A"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(j)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/673"},"text":"137 Stat. 673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8e4e646-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8e4e647-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8e4e648-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" inserted “the Department of” after “Air Force,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" inserted “the Navy Council of Personnel Boards and” after “Department of the Navy,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8e4e649-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8e4e64a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tV/s542/b"},"text":"Pub. L. 105–261, div. A, title V, § 542(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2020"},"text":"112 Stat. 2020","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tV/s542/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1555"},"text":"Section 1555 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
