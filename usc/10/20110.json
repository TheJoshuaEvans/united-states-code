{"tag":"section","attrib":{"id":"idabc82f81-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110"},"text":null,"children":[{"tag":"num","attrib":{"value":"20110"},"text":"§ 20110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strength in grade: Space Force general officers in a Space Force active status, not on sustained duty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idabc82f82-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Strength","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authorized strength of general officers in the Space Force serving in a Space Force active status but not on sustained duty is five.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f83-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following Space Force general officers shall not be counted for purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idabc82f84-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those counted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s526"},"text":"section 526 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idabc82f85-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Those serving in a joint duty assignment for purposes of chapter 38 of this title, except that the number of officers who may be excluded under this paragraph may not exceed two.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f86-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permanent Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Space Force general officer may not be reduced in permanent grade because of a reduction in the number authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idabc82f87-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s20110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitations of subsection (a) do not apply to an officer released from a joint duty assignment or other non-joint active service assignment, but only during the 60-day period beginning on the date the officer departs the joint duty or other active service assignment. The Secretary of Defense may authorize the Secretary of the Air Force to extend the 60-day period by an additional 120 days, except that not more than three Space Force officers may be covered by an extension under this subsection at the same time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idabc82f88-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tV/s501/c"},"text":"Pub. L. 119–60, div. A, title V, § 501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/854"},"text":"139 Stat. 854","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
