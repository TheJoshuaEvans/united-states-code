{"tag":"section","attrib":{"id":"ida98bd46b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572"},"text":null,"children":[{"tag":"num","attrib":{"value":"2572"},"text":"§ 2572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents, historical artifacts, and condemned or obsolete combat materiel: loan, gift, or exchange","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida98bd46c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned may lend or give items described in subsection (c) that are not needed by the military department concerned (or by the Coast Guard, in the case of the Secretary of Homeland Security), to any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd46d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A municipal corporation, county, or other political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd46e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A servicemen’s monument association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd46f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A museum, historical society, or historical institution of a State or a foreign nation or a nonprofit military aviation heritage foundation or association incorporated in a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd470-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An incorporated museum or memorial that is operated and maintained for educational purposes only and the charter of which denies it the right to operate for profit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd471-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A post of the Veterans of Foreign Wars of the United States or of the American Legion or a unit of any other recognized war veterans’ association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd472-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A local or national unit of any war veterans’ association of a foreign nation which is recognized by the national government of that nation (or by the government of one of the principal political subdivisions of that nation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd473-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A post of the Sons of Veterans Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd474-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd475-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the Secretary concerned may exchange items described in subsection (c) that are not needed by the armed forces for any of the following items or services if such items or services directly benefit the historical collection of the armed forces:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd476-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Similar items held by any individual, organization, institution, agency, or nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd477-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conservation supplies, equipment, facilities, or systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd478-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Search, salvage, or transportation services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd479-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restoration, conservation, or preservation services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd47a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd47b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may not make an exchange under paragraph (1) unless the monetary value of property transferred, or services provided, to the United States under the exchange is not less than the value of the property transferred by the United States. The Secretary concerned may waive the limitation in the preceding sentence in the case of an exchange of property for property in any case in which the Secretary determines that the item to be received by the United States in the exchange will significantly enhance the historical collection of the property administered by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd47c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies to the following types of property held by a military department or the Coast Guard: books, manuscripts, works of art, historical artifacts, drawings, plans, models, and condemned or obsolete combat materiel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd47d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd47e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan or gift made under this section shall be subject to regulations prescribed by the Secretary concerned and to regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":". The Secretary concerned shall ensure that an item authorized to be donated under this section is demilitarized in the interest of public safety, as determined necessary by the Secretary or the Secretary’s delegee."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd47f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd480-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), the United States may not incur any expense in connection with a loan or gift under subsection (a), including any expense associated with demilitarizing an item under paragraph (1), for which the recipient of the item shall be responsible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd481-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may, without cost to the recipient, demilitarize, prepare, and transport in the continental United States for donation to a recognized war veterans’ association an item authorized to be donated under this section if the Secretary determines the demilitarization, preparation, and transportation can be accomplished as a training mission without additional budgetary requirements for the unit involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida98bd482-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida98bd483-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), and notwithstanding this section or any other provision of law, the President may not transfer a veterans memorial object to a foreign country or an entity controlled by a foreign government, or otherwise transfer or convey such an object to any person or entity for purposes of the ultimate transfer or conveyance of the object to a foreign country or entity controlled by a foreign government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd484-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd485-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “entity controlled by a foreign government” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4874/c/1"},"text":"section 4874(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd486-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “veterans memorial object” means any object, including a physical structure or portion thereof, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida98bd487-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located at a cemetery of the National Cemetery System, war memorial, or military installation in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida98bd488-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is dedicated to, or otherwise memorializes, the death in combat or combat-related duties of members of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida98bd489-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was brought to the United States from abroad before 1907 as a memorial of combat abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida98bd48a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The prohibition imposed by paragraph (1) does not apply to a transfer of a veterans memorial object if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida98bd48b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of that veterans memorial object is specifically authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida98bd48c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2572/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer is made after ","children":[{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida98bd48d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/143"},"text":"70A Stat. 143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/tV/s511/82"},"text":"Pub. L. 96–513, title V, § 511(82)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2927"},"text":"94 Stat. 2927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tIII/s324/a"},"text":"Pub. L. 100–456, div. A, title III, § 324(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1954"},"text":"102 Stat. 1954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tIII/s325"},"text":"Pub. L. 101–510, div. A, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1531"},"text":"104 Stat. 1531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s373"},"text":"Pub. L. 102–484, div. A, title III, § 373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2385"},"text":"106 Stat. 2385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1071"},"text":"Pub. L. 103–337, div. A, title X, § 1071","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2859"},"text":"108 Stat. 2859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIII/s372"},"text":"Pub. L. 104–106, div. A, title III, § 372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/280"},"text":"110 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1043/d"},"text":"Pub. L. 107–107, div. A, title X, § 1043(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1219"},"text":"115 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/b/9"},"text":"Pub. L. 107–217, § 3(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1296"},"text":"116 Stat. 1296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1704/b/1"},"text":"Pub. L. 107–296, title XVII, § 1704(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tIII/s369"},"text":"Pub. L. 107–314, div. A, title III, § 369","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2524"},"text":"116 Stat. 2524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title III, § 352, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4425"},"text":"122 Stat. 4425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIII/s355/a"},"text":"Pub. L. 112–239, div. A, title III, § 355(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1702"},"text":"126 Stat. 1702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2864/a"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2864(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1869"},"text":"131 Stat. 1869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1870/d/4"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1870(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4286"},"text":"134 Stat. 4286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/t/4"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(t)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2150"},"text":"135 Stat. 2150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida98bd48e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida98bd48f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida98bd490-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2572","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5:150p.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1896-05-22/ch231"},"text":"May 22, 1896, ch. 231","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1928-05-26/ch785"},"text":"May 26, 1928, ch. 785","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-02-28/ch137"},"text":"Feb. 28, 1933, ch. 137","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1940-06-19/ch398"},"text":"June 19, 1940, ch. 398","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-31/ch421"},"text":"July 31, 1947, ch. 421","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1948-02-27/ch76/s1"},"text":"Feb. 27, 1948, ch. 76, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/37"},"text":"62 Stat. 37","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1951-10-31/ch654/s2/2"},"text":"Oct. 31, 1951, ch. 654, § 2(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/706"},"text":"65 Stat. 706","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “may” is substituted for the words “are each authorized, in their discretion”. The reference to posts of the Grand Army of the Republic is omitted, since that organization disbanded in 1950. The words “under regulations to be prescribed by him” are substituted for the words “subject to rules and regulations covering the same in each department”. The words “without expense to the United States” are substituted for the words “and the Government shall be at no expense in connection with any such loan or gift”. The words “local unit” are inserted in clause (7) to conform to clauses (5), (6), and (8).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida98bd491-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida98bd492-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1870/d/4"},"text":"Pub. L. 116–283, § 1870(d)(4)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/t/4"},"text":"Pub. L. 117–81, § 1701(t)(4)","children":[],"tail":", substituted “section 4874(c)(1)” for “section 2536(c)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (e)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s2864/a"},"text":"Pub. L. 115–91, § 2864(a)","children":[],"tail":", substituted “from abroad before 1907” for “from abroad”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s2864/b"},"text":"Pub. L. 115–91, § 2864(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s352/1"},"text":"Pub. L. 110–417, § 352(1)","children":[],"tail":", inserted at end “The Secretary concerned shall ensure that an item authorized to be donated under this section is demilitarized in the interest of public safety, as determined necessary by the Secretary or the Secretary’s delegee.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/s352/2"},"text":"Pub. L. 110–417, § 352(2)","children":[],"tail":", inserted “, including any expense associated with demilitarizing an item under paragraph (1), for which the recipient of the item shall be responsible” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" substituted “of Homeland Security” for “of Transportation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" inserted before period at end “or a nonprofit military aviation heritage foundation or association incorporated in a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"section 121 of title 40","children":[],"tail":"” for “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/d/1"},"text":"Pub. L. 107–107, § 1043(d)(1)","children":[],"tail":", inserted “, county, or other political subdivision of a State” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/d/2"},"text":"Pub. L. 107–107, § 1043(d)(2)","children":[],"tail":", substituted “servicemen’s monument” for “soldiers’ monument”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1043/d/3"},"text":"Pub. L. 107–107, § 1043(d)(3)","children":[],"tail":", inserted “or memorial” after “An incorporated museum”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “not needed by the armed forces for any of the following items or services if such items or services directly benefit the historical collection of the armed forces:” for “not needed by the armed forces for similar items held by any individual, organization, institution, agency, or nation or for search, salvage, transportation, and restoration services which directly benefit the historical collection of the armed forces.” and added subpars. (A) to (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" inserted “transportation,” after “salvage,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" designated existing provisions as subpar. (A), substituted “Except as provided in subparagraph (B), the” for “The”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s325/1"},"text":"Pub. L. 101–510, § 325(1)","children":[],"tail":", inserted before period at end “or for search, salvage, and restoration services which directly benefit the historical collection of the armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s325/2"},"text":"Pub. L. 101–510, § 325(2)","children":[],"tail":", inserted “, or services provided,” after “monetary value of property transferred” in first sentence and “in the case of an exchange of property for property” after “preceding sentence” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" substituted “Documents, historical artifacts, and condemned or obsolete combat materiel: loan, gift, or exchange” for “Condemned or obsolete material: loan or gift to certain organizations” in section catchline, and amended text generally. Prior to amendment, text read as follows: “Subject to regulations under section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":"), the Secretary of a military department, or the Secretary of Transportation, under regulations to be prescribed by him, may lend or give, without expense to the United States, books, manuscripts, works of art, drawings, plans, models, and condemned or obsolete combat material that are not needed by that department to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a municipal corporation;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a soldiers’ monument association;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a State museum;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) an incorporated museum, operated and maintained for educational purposes only, whose charter denies it the right to operate for profit;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) a post of the Veterans of Foreign Wars of the United States;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) a post of the American Legion;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) a local unit of any other recognized war veterans’ association; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) a post of the Sons of Veterans Reserve.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" substituted “section 205 of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":"), the Secretary of a military department or the Secretary of Transportation” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"section 486 of title 40","children":[],"tail":", the Secretary of a military department or the Secretary of the Treasury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida98bd493-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida98bd494-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applicable as if included in the enactment of title XVIII of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" as enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/s1701/a/2"},"text":"section 1701(a)(2) of Pub. L. 117–81","children":[],"tail":", set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":" and note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-01-01"},"text":"Jan. 1, 2022","children":[],"tail":", with additional provisions for delayed implementation and applicability of existing law, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1801/d"},"text":"section 1801(d) of Pub. L. 116–283","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida98bd495-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dB/tXXVIII/s2864/d"},"text":"Pub. L. 115–91, div. B, title XXVIII, § 2864(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1869"},"text":"131 Stat. 1869","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dB/tXXVIII/s2864/d"},"text":"“The amendments made by this section [amending this section] shall take effect ","children":[{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida98bd496-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective on the date of transfer of the Coast Guard to the Department of Homeland Security, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1704/g"},"text":"section 1704(g) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida98bd497-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida98bd498-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Destruction or Scrapping of World War II–Era Aircraft","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tX/s1051"},"text":"Pub. L. 119–60, div. A, title X, § 1051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1042"},"text":"139 Stat. 1042","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dA/tX/s1051"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may not destroy, dismantle, scrap, cannibalize, or otherwise render permanently inoperable any aircraft that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was manufactured prior to ","children":[{"tag":"date","attrib":{"date":"1945-12-31"},"text":"December 31, 1945","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the custody or administrative control of the Department of the Air Force as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Dispositions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Aircraft described in subsection (a) may only be—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retained in the inventory of the Department of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to an eligible entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deaccessioned under a plan approved by the Secretary of Defense that supports the long-term preservation of such aircraft, consistent with guidelines described in the report of the Committee on Armed Services of the Senate accompanying S. 2296 of the 119th Congress (S. Rept. 119–39).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may waive the prohibition under subsection (a) on a case-by-case basis only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is determined by qualified personnel of the Air Force or another eligible entity to be beyond practical restoration or preservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no eligible entity expresses interest in accepting the aircraft within the one-year period following the publication of public notice of the availability of the aircraft for transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary submits to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] written notification and justification of the waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days has elapsed following the date of such submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘aircraft’ includes fixed-wing and rotary-wing manned aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term ‘eligible entity’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Museum of the United States Air Force or another official Department of Defense museum; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal department or agency, nonprofit institution, or museum, with demonstrated indoor preservation and public display capabilities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida98bd499-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Acquisition of Historical Artifacts Through Exchange of Obsolete or Surplus Property","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tX/s1052"},"text":"Pub. L. 108–136, div. A, title X, § 1052","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1614"},"text":"117 Stat. 1614","children":[],"tail":", provided that, during fiscal years 2004 and 2005, the Secretary of a military department could use the authority provided by this section to acquire an historical artifact that directly benefitted the historical collection of the Armed Forces in exchange for any obsolete or surplus property held by that military department, without regard to whether the property was described in subsec. (c) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida98bd49a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Moratorium on the Return of Veterans Memorial Objects to Foreign Nations Without Specific Authorization in Law","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tX/s1051"},"text":"Pub. L. 106–65, div. A, title X, § 1051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/763"},"text":"113 Stat. 763","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1061"},"text":"Pub. L. 109–163, div. A, title X, § 1061","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3445"},"text":"119 Stat. 3445","children":[],"tail":", established a moratorium period during which the President was prohibited from transferring a veterans memorial object to a foreign country or an entity controlled by a foreign government unless specifically authorized by law, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tIII/s355/b"},"text":"Pub. L. 112–239, div. A, title III, § 355(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1702"},"text":"126 Stat. 1702","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
