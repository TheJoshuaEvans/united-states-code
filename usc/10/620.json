"},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ida7ecf146-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida7ecf147-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions Under Defense Officer Personnel Management Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Regulations prescribed under this section applicable to establishment of initial active-duty lists, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/s621/a"},"text":"section 621(a) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s611"},"text":"section 611 of this title","children":[],"tail":"."}]