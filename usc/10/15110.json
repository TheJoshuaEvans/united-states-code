{"tag":"section","attrib":{"id":"idabbc487d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s15110"},"text":null,"children":[{"tag":"num","attrib":{"value":"15110"},"text":"§ 15110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall prescribe regulations regarding the administration of this chapter. The elements of such regulations shall include mechanisms to clarify the manner in which provisions of other chapters of this part of this subtitle shall be used in the administration of this chapter in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idabbc487e-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tV/s514/a"},"text":"Pub. L. 118–31, div. A, title V, § 514(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/248"},"text":"137 Stat. 248","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXVII/s1701/a/47"},"text":"Pub. L. 118–159, div. A, title XVII, § 1701(a)(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2206"},"text":"138 Stat. 2206","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idabbc487f-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idabbc4880-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idabbc4881-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “this subtitle” for “the title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
