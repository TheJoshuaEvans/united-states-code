{"tag":"section","attrib":{"id":"idaa1d3ead-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3323"},"text":null,"children":[{"tag":"num","attrib":{"value":"3323"},"text":"§ 3323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-plus contracting prohibited for military construction and military family housing projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa1d3eae-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract entered into by the United States in connection with a military construction project or a military family housing project may not use any form of cost-plus contracting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa1d3eaf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition specified in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa1d3eb0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in addition to the prohibition specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3322/a"},"text":"section 3322(a) of this title","children":[],"tail":" on the use of the cost-plus-a-percentage-of-cost system of contracting; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa1d3eb1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies notwithstanding a declaration of war or the declaration by the President of a national emergency under section 201 of the National Emergencies Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1621"},"text":"50 U.S.C. 1621","children":[],"tail":") that includes the use of the armed forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa1fafb2-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1817/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1817(a)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4186"},"text":"134 Stat. 4186","children":[],"tail":", 4187; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1801/a/27"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1801(a)(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/684"},"text":"137 Stat. 684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa1fafb3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaa1fafb4-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idaa1fafb5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text"