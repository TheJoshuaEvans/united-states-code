{"tag":"section","attrib":{"id":"ida8db6fc6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1490"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490"},"text":"§ 1490.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of remains: certain retired members and dependents who die in military medical facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8db6fc7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1490/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b), when a member entitled to retired or retainer pay or equivalent pay, or a dependent of such a member, dies while properly admitted under chapter 55 of this title to a medical facility of the armed forces, the Secretary concerned may transport the remains, or pay the cost of transporting the remains, of the decedent to the place of burial of the decedent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8db6fc8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1490/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8db6fc9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1490/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation provided under this section may not be to a place further from the place of death than the decedent’s last place of permanent residence, and any amount paid under this section may not exceed the cost of transportation from the place of death to the decedent’s last place of permanent residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8db6fca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1490/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation of the remains of a decedent may not be provided under this section if such transportation is authorized by sections 1481 and 1482 of this title or by chapter 23 of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8db6fcb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1490/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Dependent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “dependent” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8db6fcc-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1032/a/1"},"text":"Pub. L. 98–94, title X, § 1032(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/671"},"text":"97 Stat. 671","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/26/s7/k/3"},"text":"Pub. L. 100–26, § 7(k)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-04-21"},"text":"Apr. 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/284"},"text":"101 Stat. 284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tVI/s626/a"},"text":"Pub. L. 102–190, div. A, title VI, § 626(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1379"},"text":"105 Stat. 1379","children":[],"tail":", 1380; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s562/a"},"text":"Pub. L. 108–136, div. A, title V, § 562(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1483"},"text":"117 Stat. 1483","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8db6fcd-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8db6fce-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8db6fcf-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s562/a/1"},"text":"Pub. L. 108–136, § 562(a)(1)","children":[],"tail":", struck out “located in the United States” after “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s562/a/2"},"text":"Pub. L. 108–136, § 562(a)(2)","children":[],"tail":", struck out “outside the United States or to a place” before “further”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s562/b"},"text":"Pub. L. 108–136, § 562(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “In this section:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘United States’ includes the Commonwealth of Puerto Rico and the territories and possessions of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘dependent’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s626/b/1"},"text":"Pub. L. 102–190, § 626(b)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, section catchline read as follows: “Transportation of remains of members entitled to retired or retainer pay who die in a military medical facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s626/a/1"},"text":"Pub. L. 102–190, § 626(a)(1)","children":[],"tail":", inserted “, or a dependent of such a member,” after “equivalent pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s626/a/2"},"text":"Pub. L. 102–190, § 626(a)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which read as follows: “In this section, the term ‘United States’ includes the Commonwealth of Puerto Rico and the territories and possessions of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/26"},"text":"Pub. L. 100–26","children":[],"tail":" inserted “the term” after “In this section,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida8db6fd0-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida8db6fd1-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s562/c"},"text":"Pub. L. 108–136, div. A, title V, § 562(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1483"},"text":"117 Stat. 1483","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tV/s562/c"},"text":"“The amendments made by this section [amending this section] shall apply only with respect to persons dying on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida8db6fd2-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tX/s1032/b"},"text":"Pub. L. 98–94, title X, § 1032(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/672"},"text":"97 Stat. 672","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/94/tX/s1032/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1490"},"text":"Section 1490 of title 10","children":[],"tail":", United States Code, as added by subsection (a), shall apply with respect to the transportation of the remains of persons dying after "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
