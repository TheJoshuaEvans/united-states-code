{"tag":"section","attrib":{"id":"ida849de39-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1031"},"text":null,"children":[{"tag":"num","attrib":{"value":"1031"},"text":"§ 1031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of oath","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President, the Vice-President, the Secretary of Defense, any commissioned officer, and any other person designated under regulations prescribed by the Secretary of Defense may administer any oath—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida849de3a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1031/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required for the enlistment or appointment of any person in the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida849de3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1031/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by law in connection with such an enlistment or appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida849de3c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/80"},"text":"70A Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tV/s595/b"},"text":"Pub. L. 109–364, div. A, title V, § 595(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2235"},"text":"120 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"ty