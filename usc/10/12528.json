{"tag":"section","attrib":{"id":"idaba453b7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528"},"text":null,"children":[{"tag":"num","attrib":{"value":"12528"},"text":"§ 12528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserve Mobilization Income Insurance Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaba453b8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established on the books of the Treasury a fund to be known as the “Reserve Mobilization Income Insurance Fund”, which shall be administered by the Secretary of the Treasury. The Fund shall be used for the accumulation of funds in order to finance the liabilities of the insurance program on an actuarially sound basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453b9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assets of Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be deposited into the Fund the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba453ba-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premiums paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12527"},"text":"section 12527 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba453bb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba453bc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any return on investment of the assets of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453bd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in the Fund shall be available for paying insurance benefits under the insurance program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453be-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment of Assets of Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury shall invest such portion of the Fund as is not in the judgment of the Secretary of Defense required to meet current liabilities. Such investments shall be in public debt securities with maturities suitable to the needs of the Fund, as determined by the Secretary of Defense, and bearing interest at rates determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturities. The income on such investments shall be credited to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaba453bf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Accounting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the beginning of each fiscal year, the Secretary, in consultation with the Board of Actuaries and the Secretary of the Treasury, shall determine the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaba453c0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The projected amount of the premiums to be collected, investment earnings to be received, and any transfers or appropriations to be made for the Fund for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba453c1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for that fiscal year of any cumulative unfunded liability (including any negative amount or any gain to the Fund) resulting from payments of benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaba453c2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s12528/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount for that fiscal year (including any negative amount) of any cumulative actuarial gain or loss to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaba453c3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s512/a/1"},"text":"Pub. L. 104–106, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/302"},"text":"110 Stat. 302","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
