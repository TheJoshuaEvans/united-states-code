{"tag":"section","attrib":{"id":"ida90d7cd3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762"},"text":null,"children":[{"tag":"num","attrib":{"value":"1762"},"text":"§ 1762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration project relating to certain acquisition personnel management policies and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida90d7cd4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense is authorized to carry out a demonstration project, the purpose of which is to determine the feasibility or desirability of one or more proposals for improving the personnel management policies or procedures that apply with respect to the acquisition workforce of the Department of Defense and supporting personnel assigned to work directly with the acquisition workforce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7cd5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7cd6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, any demonstration project described in subsection (a) shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4703"},"text":"section 4703 of title 5","children":[],"tail":" and all other provisions of such title that apply with respect to any demonstration project under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7cd7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), in applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4703"},"text":"section 4703 of title 5","children":[],"tail":" with respect to a demonstration project described in subsection (a)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90d7cd8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “180 days” in subsection (b)(4) of such section shall be deemed to read “120 days”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cd9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “90 days” in subsection (b)(6) of such section shall be deemed to read “30 days”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cda-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (d)(1) of such section shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7cdb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (2) shall not apply with respect to a demonstration project unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90d7cdc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each organization or team participating in the demonstration project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida90d7cdd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one-third of the workforce participating in the demonstration project consists of members of the acquisition workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90d7cde-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least two-thirds of the workforce participating in the demonstration project consists of members of the acquisition workforce and supporting personnel assigned to work directly with the acquisition workforce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cdf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstration project commences before ","children":[{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7ce0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall exercise the authorities granted to the Office of Personnel Management under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4703"},"text":"section 4703 of title 5","children":[],"tail":" for purposes of the demonstration project authorized under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7ce1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number of Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total number of persons who may participate at any one time in the demonstration project under this section may not exceed 130,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7ce2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Reorganizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The applicability of paragraph (2) of subsection (b) to an organization or team shall not terminate by reason that the organization or team, after having satisfied the conditions in paragraph (3) of such subsection when it began to participate in a demonstration project under this section, ceases to meet one or both of the conditions set forth in subparagraph (A) of such paragraph (3) as a result of a reorganization, restructuring, realignment, consolidation, or other organizational change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7ce3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7ce4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall designate an independent organization to conduct two assessments of the acquisition workforce demonstration project described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7ce5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such assessment shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ida90d7ce6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the workforce included in the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7ce7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the flexibilities used in the project to appoint individuals to the acquisition workforce and whether those appointments are based on competitive procedures and recognize veteran’s preferences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7ce8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the flexibilities used in the project to develop a performance appraisal system that recognizes excellence in performance and offers opportunities for improvement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7ce9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The steps taken to ensure that such system is fair and transparent for all employees in the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How the project allows the organization to better meet mission needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7ceb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of how the flexibilities in subparagraphs (B) and (C) are used, and what barriers have been encountered that inhibit their use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whether there is a process for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ida90d7ced-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring ongoing performance feedback and dialogue among supervisors, managers, and employees throughout the performance appraisal period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ida90d7cee-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting timetables for performance appraisals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cef-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project’s impact on career progression.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cf0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project’s appropriateness or inappropriateness in light of the complexities of the workforce affected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cf1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project’s sufficiency in terms of providing protections for diversity in promotion and retention of personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cf2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The adequacy of the training, policy guidelines, and other preparations afforded in connection with using the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ida90d7cf3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether there is a process for ensuring employee involvement in the development and improvement of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7cf4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The first assessment under this subsection shall be completed not later than ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":". The second and final assessment shall be completed not later than "},{"tag":"date","attrib":{"date":"2016-09-30"},"text":"September 30, 2016","children":[],"tail":". The Secretary shall submit to the covered congressional committees a copy of each assessment within 30 days after receipt by the Secretary of the assessment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7cf5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Congressional Committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida90d7cf6-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Armed Services of the Senate and the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7cf7-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida90d7cf8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida90d7cf9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1762/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to conduct a demonstration project under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2031-12-31"},"text":"December 31, 2031","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsect