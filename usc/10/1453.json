{"tag":"section","attrib":{"id":"ida8d4438b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1453"},"text":null,"children":[{"tag":"num","attrib":{"value":"1453"},"text":"§ 1453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of amounts erroneously paid","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida8d4438c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recovery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to any other method of recovery provided by law, the Secretary concerned may authorize the recovery of any amount erroneously paid to a person under this subchapter by deduction from later payments to that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida8d4438d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Waive Recovery","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recovery of an amount erroneously paid to a person under this subchapter is not required if, in the judgment of the Secretary concerned—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida8d4438e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been no fault by the person to whom the amount was erroneously paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida8d4438f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1453/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery of such amount would be contrary to the purposes of this subchapter or against equity and good conscience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida8d44390-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/425/s1/3"},"text":"Pub. L. 92–425, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-21"},"text":"Sept. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/710"},"text":"86 Stat. 710","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s634"},"text":"Pub. L. 104–201, div. A, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2577"},"text":"110 Stat. 2577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s105/a"},"text":"Pub. L. 104–316, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3830"},"text":"110 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida8d44391-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida8d44392-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida8d44393-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “amounts” for “annuity” in section catchline and amended text generally. Prior to amendment, text read as follows: “In addition to other methods of recovery provided by law, the Secretary concerned may authorize the recovery, by deduction from later payments to a person, of any amount erroneously paid to him under this subchapter. However, recovery is not required if, in the judgment of the Secretary concerned and the Comptroller General, there has been no fault by the person to whom the amount was erroneously paid and recovery would be contrary to the purposes of this subchapter or against equity and good conscience.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" struck out “and the Comptroller General” after “judgment of the Secretary concerned” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
