{"tag":"section","attrib":{"id":"idaa70b5e9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4293"},"text":null,"children":[{"tag":"num","attrib":{"value":"4293"},"text":"§ 4293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major defense acquisition programs: incentive program for contractors to purchase capital assets manufactured in United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa70b5ea-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4293/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Incentive Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall plan and establish an incentive program in accordance with this section for contractors to purchase capital assets manufactured in the United States in part with funds available to the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa70b5eb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4293/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Industrial Capabilities Fund May Be Used","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may use the Defense Industrial Capabilities Fund, established under section 814 of the National Defense Authorization Act for Fiscal Year 2004, for incentive payments under the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa70b5ec-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4293/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to Major Defense Acquisition Program Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The incentive program shall apply to contracts for the procurement of a major defense acquisition program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa70b5ed-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s4293/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide consideration in source selection in any request for proposals for a major defense acquisition program for offerors with eligible capital assets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa70b5ee-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tVIII/s822/a/1"},"text":"Pub. L. 108–136, div. A, title VIII, § 822(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1546"},"text":"117 Stat. 1546","children":[],"tail":", § 2436; renumbered § 4293, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1847/f/2"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1847(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4258"},"text":"134 Stat. 4258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaa70b5ef-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","a