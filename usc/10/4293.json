nal rules shall expire no later than 270 days after the effective date of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2436"},"text":"section 2436 of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4293"},"text":"10 U.S.C. 4293","children":[],"tail":"] [see Effective Date note above], as added by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
