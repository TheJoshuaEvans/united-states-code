{"tag":"section","attrib":{"id":"ida89650c8-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1110b"},"text":"§ 1110b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" TRICARE program: extension of dependent coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida89650c9-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with subsection (c), an individual described in subsection (b) shall be deemed to be a dependent (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2/D"},"text":"section 1072(2)(D) of this title","children":[],"tail":") for purposes of coverage under the TRICARE program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida89650ca-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this subsection is an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida89650cb-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be a dependent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":" but for exceeding an age limit under such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650cc-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not attained the age of 26;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650cd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible to enroll in an eligible employer-sponsored plan (as defined in section 5000A(f)(2) of the Internal Revenue Code of 1986);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650ce-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not otherwise a dependent of a member or a former member under any subparagraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/2"},"text":"section 1072(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650cf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets other criteria specified in regulations prescribed by the Secretary, similar to regulations prescribed by the Secretary of Health and Human Services under section 2714(b) of the Public Health Service Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida89650d0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premium","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida89650d1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe by regulation a premium (or premiums) for coverage under the TRICARE program provided pursuant to this section to an individual described in subsection (b). Such premium shall apply instead of any enrollment fees required under section 1075 or 1075a of this title, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650d2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly amount of the premium in effect for a month for coverage under the TRICARE program pursuant to this section shall be the amount equal to the cost of such coverage that the Secretary determines on an appropriate actuarial basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650d3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the requirements and procedures applicable to the payment of premiums under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida89650d4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s1110b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts collected as premiums under this subsection shall be credited to the appropriation available for the Defense Health Program Account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1100"},"text":"section 1100 of this title","children":[],"tail":", shall be merged with sums in such Account that are available for the fiscal year in which collected, and shall be available under subsection (b) of such section for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida89650d5-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVII/s702/a/1"},"text":"Pub. L. 111–383, div. A, title VII, § 702(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4244"},"text":"124 Stat. 4244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s701/j/1/F"},"text":"Pub. L. 114–328, div. A, title VII, § 701(j)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2192"},"text":"130 Stat. 2192","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVII/s739/f"},"text":"Pub. L. 115–91, div. A, title VII, § 739(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1447"},"text":"131 Stat. 1447","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida89650d6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida89650d7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ida89650d8-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5000A of the Internal Revenue Code of 1986, referred to in subsec. (b)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5000A"},"text":"section 5000A of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2714 of the Public Health Service Act, referred to in subsec. (b)(5), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–14"},"text":"section 300gg–14 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida89650d9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “section 1075 or 1075a of this title, as appropriate” for “section 1075 of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted at end “Such premium shall apply instead of any enrollment fees required under section 1075 of this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida89650da-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida89650db-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the provision of health care under the TRICARE program beginning on "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s701/k"},"text":"section 701(k) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072"},"text":"section 1072 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ida89650dc-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date and Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tVII/s702/b"},"text":"Pub. L. 111–383, div. A, title VII, § 702(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4245"},"text":"124 Stat. 4245","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tVII/s702/b"},"text":"“The amendments made by this section [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":". The Secretary of Defense shall prescribe an interim final rule with respect to such amendments, effective not later than "},{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}]