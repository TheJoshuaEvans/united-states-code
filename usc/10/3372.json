2"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1462"},"text":"131 Stat. 1462","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/99/661"},"text":"Pub. L. 99–661","children":[],"tail":" added identical subsections."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (b), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/1"},"text":"Pub. L. 116–283, § 1819(c)(1)","children":[],"tail":", (3), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s815/a/2"},"text":"Pub. L. 115–91, div. A, title VIII, § 815(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1462"},"text":"131 Stat. 1462","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsec. (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":", which was transferred to this section, redesignated as subsec. (c), and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/1"},"text":"Pub. L. 116–283, § 1819(c)(1)","children":[],"tail":", (4), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s811/3"},"text":"Pub. L. 114–328, div. A, title VIII, § 811(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2268"},"text":"130 Stat. 2268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s815/a/1"},"text":"Pub. L. 115–91, div. A, title VIII, § 815(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1462"},"text":"131 Stat. 1462","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaa1fb004-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" designated introductory provisions as par. (1) and inserted heading, redesignated former pars. (1) to (3) as subpars. (A) to (C), respectively, of par. (1) and realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/1"},"text":"Pub. L. 116–283, § 1819(c)(1)","children":[],"tail":", (2)(A), redesignated subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":" as subsec. (a) of this section and substituted “Contractual Action to Provide Time for Definitization of Contractual Terms, Specifications, and Price; Limitations on Obligation of Funds” for “Limitations on Obligation of Funds” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/2/A"},"text":"Pub. L. 116–283, § 1819(c)(2)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/2/C"},"text":"Pub. L. 116–283, § 1819(c)(2)(C)","children":[],"tail":", inserted par. (2) designation and heading. Former par. (2) redesignated subpar. (A) of par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/2/B"},"text":"Pub. L. 116–283, § 1819(c)(2)(B)","children":[],"tail":", (D), redesignated subsec. (a)(2) as (a)(2)(A), inserted heading, realigned margin, and substituted “Except as provided in subparagraph (B),” for “Except as provided in paragraph (3),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/2/B"},"text":"Pub. L. 116–283, § 1819(c)(2)(B)","children":[],"tail":", (E), redesignated subsec. (a)(3) as (a)(2)(B), inserted heading, realigned margin, and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3377/b"},"text":"section 3377(b) of this title","children":[],"tail":"” for “subsection (h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/2/F"},"text":"Pub. L. 116–283, § 1819(c)(2)(F)","children":[],"tail":", redesignated par. (4) as (3) and inserted heading. Former par. (3) redesignated subpar. (B) of par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/2/G"},"text":"Pub. L. 116–283, § 1819(c)(2)(G)","children":[],"tail":", redesignated par. (5) as (4) and inserted heading. Former par. (4) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1819/c/1"},"text":"Pub. L. 116–283, § 1819(c)(1)","children":[],"tail":", (3), redesignated subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326"},"text":"section 2326 of this title","children":[],"tail":" as subsec. (b) of this section and substituted “subsection (a)(1)” for “subsection (b)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Su