 "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa1fb007-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Agreement Limits for Operation Warp Speed","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVIII/s883"},"text":"Pub. L. 117–263, div. A, title VIII, § 883","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2746"},"text":"136 Stat. 2746","children":[],"tail":", which provided that the value of any modification to, or order made under, a contract or other agreement by the Department of Defense on or after "},{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":", to address the COVID–19 pandemic through vaccines and other therapeutic measures generally would not be counted toward any limit established prior to "},{"tag":"date","attrib":{"date":"2020-03-01"},"text":"March 1, 2020","children":[],"tail":", on the total estimated amount of all projects to be issued under the contract or other agreement, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tVIII/s811/b/1"},"text":"Pub. L. 119–60, div. A, title VIII, § 811(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/948"},"text":"139 Stat. 948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idaa1fb008-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Relaxation of Undefinitized Contract Action Limitations and Restrictions Related to National Emergency for Coronavirus Disease 2019","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tIII/s13004"},"text":"Pub. L. 116–136, div. B, title III, § 13004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/522"},"text":"134 Stat. 522","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dB/tIII/s13004"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326/b/3"},"text":"Section 2326(b)(3) of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3372/a/2/B"},"text":"10 U.S.C. 3372(a)(2)(B)","children":[],"tail":"], shall not apply to any undefinitized contract action of the Department of Defense related to the national emergency for the Coronavirus Disease 2019 (COVID–19)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term ‘undefinitized contract action’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326/j/6"},"text":"section 2326(j)(6) of title 10","children":[],"tail":", United States Code [probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326/j/1"},"text":"section 2326(j)(1) of title 10","children":[],"tail":", now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3377/b/1"},"text":"10 U.S.C. 3377(b)(1)","children":[],"tail":", which defines “undefinitized contractual action”].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tIII/s13005"},"text":"Pub. L. 116–136, div. B, title III, § 13005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/522"},"text":"134 Stat. 522","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dB/tIII/s13005"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an agency may waive the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2326/b"},"text":"section 2326(b) of title 10","children":[],"tail":", United States Code [now "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3372/a"},"text":"10 U.S.C. 3372(a)","children":[],"tail":"], with respect to a contract of such agency if the head of the agency determines that the waiver is necessary due to the national emergency for the Coronavirus Disease 2019 (COVID–19)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term ‘head of an agency’ has the meaning given that term in section 2302(2) [probably means section 2302(1); now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3004"},"text":"10 U.S.C. 3004","children":[],"tail":"] of title 10, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
