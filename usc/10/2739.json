{"tag":"section","attrib":{"id":"ida9cc38b2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2739"},"text":null,"children":[{"tag":"num","attrib":{"value":"2739"},"text":"§ 2739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts recovered from third parties for loss or damage to personal property shipped or stored at Government expense: crediting to appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida9cc38b3-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of Collections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any qualifying military department third-party collection shall be credited to the appropriate current appropriation. Amounts so credited shall be merged with the funds in that appropriation and shall be available for the same period and purposes as the funds with which merged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc38b4-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Current Appropriation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), the appropriate current appropriation with respect to a qualifying military department third-party collection is the appropriation currently available, as of the date of the collection, for the payment of claims by that military department for loss or damage of personal property shipped or stored at Government expense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida9cc38b5-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s2739/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying Military Department Third-Party Collections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), a qualifying military department third-party collection is any amount that a military department collects under sections 3711, 3716, 3717, and 3721 of title 31 from a third party for a loss or damage to personal property that occurred during shipment or storage of the property at Government expense and for which the Secretary of the military department paid the owner in settlement of a claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida9cc38b6-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1010/a/1"},"text":"Pub. L. 105–261, div. A, title X, § 1010(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2117"},"text":"112 Stat. 2117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida9cc38b7-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida9cc38b8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida9cc38b9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1010/b"},"text":"Pub. L. 105–261, div. A, title X, § 1010(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2117"},"text":"112 Stat. 2117","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tX/s1010/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2739"},"text":"Section 2739 of title 10","children":[],"tail":", United States Code, as added by subsection (a), applies with respect to amounts collected by a military department on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
