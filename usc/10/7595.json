{"tag":"section","attrib":{"id":"idaaf8ab58-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595"},"text":null,"children":[{"tag":"num","attrib":{"value":"7595"},"text":"§ 7595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army Military History Institute: fee for providing historical information to the public","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaaf8ab59-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the Secretary of the Army may charge a person a fee for providing the person with information from the United States Army Military History Institute that is requested by that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8ab5a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fee may not be charged under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8ab5b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a person for information that the person requests to carry out a duty as a member of the armed forces or an officer or employee of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8ab5c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a release of information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8ab5d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee charged for providing information under this section may not exceed the cost of providing the information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8ab5e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received under subsection (a) for providing information in any fiscal year shall be credited to the appropriation or appropriations charged the costs of providing information to the public from the United States Army Military History Institute during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaaf8ab5f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaaf8ab60-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States Army Military History Institute” means the archive for historical records and materials of the Army that the Secretary of the Army designates as the primary archive for such records and materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaaf8ab61-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s7595/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “officer of the United States” and “employee of the United States” have the meanings given the terms “officer” and “employee”, respectively, in sections 2104 and 2105, respectively, of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaaf8ab62-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1085(a)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–287, § 4595; renumbered § 7595, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s808/d"},"text":"Pub. L. 115–232, div. A, title VIII, § 808(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1839"},"text":"132 Stat. 1839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idaaf8ab63-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf8ab64-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idaaf8ab65-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 7601 to 7603 were renumbered sections 8801 to 8803 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7604 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8804"},"text":"section 8804 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 7604, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/471"},"text":"70A Stat. 471","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/718/s44"},"text":"Pub. L. 89–718, § 44","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1120"},"text":"80 Stat. 1120","children":[],"tail":", related to profit on sales from ships’ stores, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s329/a/1"},"text":"Pub. L. 101–510, § 329(a)(1)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 7605 and 7606 were renumbered sections 8805 and 8806 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf8ab66-3a6f-11f1-a58a-d8db54b14ab5"},"tex