{"tag":"section","attrib":{"id":"idab3dcacd-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8684"},"text":null,"children":[{"tag":"num","attrib":{"value":"8684"},"text":"§ 8684.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overhaul of naval vessels: competition between public and private shipyards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy should ensure, in any case in which the Secretary awards a project for repair, alteration, overhaul, or conversion of a naval vessel following competition between public and private shipyards, that each of the following criteria is met:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dcace-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8684/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The bid of any public shipyard for the award includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3dcacf-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8684/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full costs to the United States associated with future retirement benefits of civilian employees of that shipyard consistent with computation methodology established by Office of Management and Budget Circular A–76; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dcad0-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8684/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case in which equal access to the Navy supply system is not allowed to public and private shipyards, a pro rata share of the costs of the Navy supply system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dcad1-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8684/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs applicable to oversight of the contract by the appropriate Navy supervisor of shipbuilding, conversion, and repair are added to the bid of any private shipyard for the purpose of comparability analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dcad2-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8684/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The award is made using the results of the comparability analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3dcad3-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1225/a/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1225(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2054"},"text":"102 Stat. 2054","children":[],"tail":", § 7313; renumbered § 7314, "},{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1622/a"},"text":"Pub. L. 101–189, div. A, title XVI, § 1622(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1604"},"text":"103 Stat. 1604","children":[],"tail":"; renumbered § 8684, "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s807/d/2"},"text":"Pub. L. 115–232, div. A, title VIII, § 807(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1836"},"text":"132 Stat. 1836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3dcad4-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3dcad5-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idab3dcad6-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8684 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s9252"},"text":"section 9252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3dcad7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7314"},"text":"section 7314 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7313"},"text":"section 7313 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab3dcad8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3dcad9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idab3dcada-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1225/b"},"text":"Pub. L. 100–456, div. A, title XII, § 1225(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2055"},"text":"102 Stat. 2055","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/456/dA/tXII/s1225/b"},"text":"“Section 7313 [now 8684] of title 10, United States Code, as added by subsection (a), applies to any award by the Secretary of the Navy made after the end of the 30-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":"] for repair, alteration, overhaul, or conversion of a naval vessel following competition between public and private shipyards.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
