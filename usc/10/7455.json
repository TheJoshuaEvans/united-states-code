tml:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1055.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1056 (1st sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"10:1056 (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-29/ch714"},"text":"June 29, 1948, ch. 714","children":[],"tail":", §§ 1–6, "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1094"},"text":"62 Stat. 1094","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-06-30/ch432/s732"},"text":"June 30, 1954, ch. 432, § 732","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/356"},"text":"68 Stat. 356","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1057.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1058.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1059(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1059(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1059(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4355(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"10:1060.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the word “designated” is substituted for the word “appointed” to make it clear that the positions described are not constitutional offices.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 10:1056(e) (2d sentence).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “during the term for which such member was appointed” and “Such successor shall be appointed * * * who died or resigned” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “as it may deem necessary or advisable effectuate the duties imposed upon it by the provisions of sections 1055–1060 of this title” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the words “called for consultation by the Board in connection with the business of the Board” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idaaf17ea7-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idaaf17ea8-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “two other members” for “one other member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s558/a/1"},"text":"Pub. L. 118–159, § 558(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to membership of Board of Visitors."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s558/a/2"},"text":"Pub. L. 118–159, § 558(a)(2)","children":[],"tail":", inserted “and the Committees on Armed Services of the Senate and House of Representatives” after “the President” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s554/a"},"text":"Pub. L. 117–81, § 554(a)","children":[],"tail":", substituted “is appointed by the President” for “is appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s555/a"},"text":"Pub. L. 117–81, § 555(a)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4355"},"text":"section 4355 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", substituted “Committee on Armed Services” for “Committee on National Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1502/a/12"},"text":"Pub. L. 104–106, § 1502(a)(12)","children":[],"tail":", substituted “National Security” for “Armed Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1061/e/2"},"text":"Pub. L. 104–106, § 1061(e)(2)","children":[],"tail":", struck out “is entitled to not more than $5 a day and” after “each adviser”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/579"},"text":"Pub. L. 96–579","children":[],"tail":" required member whose term of office had expired to continue service until appointment of a successor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idaaf17ea9-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idaaf17eaa-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":