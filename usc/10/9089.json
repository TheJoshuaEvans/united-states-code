{"tag":"section","attrib":{"id":"idab63ef77-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9089"},"text":null,"children":[{"tag":"num","attrib":{"value":"9089"},"text":"§ 9089.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program Executive Officer for Assured Access to Space","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab63ef78-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9089/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idab63ef79-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9089/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a Program Executive Officer for Assured Access to Space within the Space Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab63ef7a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9089/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Program Executive Officer for Assured Access to Space shall serve a term of four years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef7b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9089/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Program Executive Officer for Assured Access to Space, while so serving, shall have the grade of brigadier general, major general, lieutenant general, or general.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab63ef7c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s9089/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Program Executive Officer for Assured Access to Space, while serving as the Program Executive Officer, shall also serve as the Commander of Space Launch Delta 45.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab63ef7d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXVI/s1601/b"},"text":"Pub. L. 119–60, div. A, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1173"},"text":"139 Stat. 1173","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
