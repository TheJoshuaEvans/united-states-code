{"tag":"section","attrib":{"id":"ida7f1ac71-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s636"},"text":null,"children":[{"tag":"num","attrib":{"value":"636"},"text":"§ 636.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement for years of service: regular and Space Force officers in grades above brigadier general; regular Navy officers in grades above rear admiral (lower half)","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida7f1ac72-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s636/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major Generals and Rear Admirals Serving in Grade","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ida7f1ac73-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s636/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) or (c) and under section 637(b) or 637a of this title, each officer of the Regular Army, Regular Air Force, or Regular Marine Corps who holds the regular grade of major general, and each officer of the Regular Navy who holds the regular grade of rear admiral, shall, if not earlier retired, be retired on the first day of the first month beginning after the date of the fifth anniversary of his appointment to that grade or on the first day of the month after the month in which he completes 35 years of active commissioned service, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida7f1ac74-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s636/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) or (c) and under section 637(b) or 637a of this title, each officer of the Space Force who holds the grade of major general shall, if not earlier retired, be retired as specified in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac75-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s636/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lieutenant Generals and Vice Admirals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the administration of subsection (a) in the case of an officer who is serving in the grade of lieutenant general or vice admiral, the number of years of active commissioned service applicable to the officer is 38 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida7f1ac76-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s636/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Generals and Admirals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the administration of subsection (a) in the case of an officer who is serving in the grade of general or admiral, the number of years of active commissioned service applicable to the officer is 40 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida7f1ac77-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513/tI/s105"},"text":"Pub. L. 96–513, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2863"},"text":"94 Stat. 2863","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXIV/s1405/14"},"text":"Pub. L. 98–525, title XIV, § 1405(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2622"},"text":"98 Stat. 2622","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tV/s506/a"},"text":"Pub. L. 105–85, div. A, title V, § 506(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1726"},"text":"111 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s505/b/4"},"text":"Pub. L. 114–328, div. A, title V, § 505(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2108"},"text":"130 Stat. 2108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIX/s924/b/4/G"},"text":"Pub. L. 116–283, div. A, title IX, § 924(b)(4)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3822"},"text":"134 Stat. 3822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVII/s1722/b/6/D"},"text":"Pub. L. 118–31, div. A, title XVII, § 1722(b)(6)(D)","children":[],"tail":", (E)(iv), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/669"},"text":"137 Stat. 669","children":[],"tail":", 670.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida7f1ac78-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida7f1ac79-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida7f1ac7a-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1722/b/6/E/iv"},"text":"Pub. L. 118–31, § 1722(b)(6)(E)(iv)","children":[],"tail":", substituted “and Space Force officers in grades above brigadier general; regular Navy officers in grades above” for “officers in grades above brigadier general and” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1722/b/6/D"},"text":"Pub. L. 118–31, § 1722(b)(6)(D)","children":[],"tail":", designated existing provisions as par. (1), substituted “or Regular Marine Corps” for “Regular Marine Corps, or Regular Space Force”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Regular Marine Corps, or Regular Space Force” for “or Regular Marine Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted “or 637a” after “637(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s506/b"},"text":"Pub. L. 105–85, § 506(b)","children":[],"tail":", substituted “regular officers in grades above brigadier general and rear admiral (lower half)” for “regular major generals and rear admirals” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s506/a"},"text":"Pub. L. 105–85, § 506(a)","children":[],"tail":", designated existing provisions as subsec. (a), inserted heading, substituted “Except as provided in subsection (b) or (c) and” for “Except as provided”, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" substituted “35” for “thirty-five”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida7f1ac7b-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ida7f1ac7c-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-09-15"},"text":"Sept. 15, 1981","children":[],"tail":", but the authority to prescribe regulations under this section effective on "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701"},"text":"section 701 of Pub. L. 96–513","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
