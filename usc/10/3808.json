{"tag":"section","attrib":{"id":"idaa3c5f3b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3808"},"text":null,"children":[{"tag":"num","attrib":{"value":"3808"},"text":"§ 3808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain Navy contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idaa3c5f3c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repair, Maintenance, or Overhaul of Naval Vessels: Rate for Progress Payments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall provide that the rate for progress payments on any contract awarded by the Secretary for repair, maintenance, or overhaul of a naval vessel shall be not less than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idaa3c5f3d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 95 percent, in the case of a firm considered to be a small business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idaa3c5f3e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent, in the case of any other firm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3c5f3f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Advance Funds for Immediate Salvage Operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may advance to private salvage companies such funds as the Secretary considers necessary to provide for the immediate financing of salvage operations. Advances under this subsection shall be made on terms that the Secretary considers adequate for the protection of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idaa3c5f40-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s3808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security for Construction and Conversion of Naval Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall provide, in each contract for construction or conversion of a naval vessel, that, when partial, progress, or other payments are made under such contract, the United States is secured by a lien upon work in progress and on property acquired for performance of the contract on account of all payments so made. The lien is paramount to all other liens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idaa3c5f41-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVIII/s1834/a"},"text":"Pub. L. 116–283, div. A, title XVIII, § 1834(a)","children":[],"tail":", (i)(1)–(4), as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1701/n/1/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1701(n)(1)(B)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2145"},"text":"135 Stat. 2145","children":[],