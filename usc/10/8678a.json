{"tag":"section","attrib":{"id":"idab3dca17-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8678a"},"text":"§ 8678a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on decommissioning or inactivating a battle force ship before the end of expected service life","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idab3dca18-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy may not decommission or inactivate a battle force ship before the end of the expected service life of the ship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dca19-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy may waive the limitation under subsection (a) with respect to a battle force ship if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dca1a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary submits to the congressional defense committees the certification described in subsection (c) with respect to such ship by not later than three days after the date on which the President submits the budget materials under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for the fiscal year in which such waiver is sought; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dca1b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 30 days has elapsed following the date on which the National Defense Authorization Act for such fiscal year is enacted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dca1c-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certification described in this subsection is a certification that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dca1d-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3dca1e-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the battle force ship in a reduced operating status is not feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dca1f-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the ship with reduced capability is not feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dca20-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the ship as a Navy Reserve unit is not feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dca21-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring the ship to the Coast Guard is not feasible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dca22-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining the ship is not required to support the most recent national defense strategy required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/g"},"text":"section 113(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dca23-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes an explanation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3dca24-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the options assessed and the rationale for the determinations under subparagraphs (A) through (D) of paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dca25-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rationale for the determination under subparagraph (E) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dca26-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A certification submitted under subsection (b) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idab3dca27-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idab3dca28-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “battle force ship” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idab3dca29-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commissioned United States Ship warship capable of contributing to combat operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idab3dca2a-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A United States Naval Ship that contributes directly to Navy warfighting or support missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idab3dca2b-3a6f-11f1-a58a-d8db54b14ab5","identifier":"/us/usc/t10/s8678a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “expected service life” means the number of years a naval vessel is expected to be in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idab3dca2c-3a6f-11f1-a58a-d8db54b14ab5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tX/s1014/a"},"text":"Pub. L. 117–81, div. A, title X, § 1014(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1894"},"text":"135 Stat. 1894","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1024/a"},"text":"Pub. L. 117–263, div. A, title X, § 1024(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2764"},"text":"136 Stat. 2764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idab3dca2d-3a6f-11f1-a58a-d8db54b14ab5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idab3dca2e-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idab3dca2f-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s1024/a/1"},"text":"Pub. L. 117–263, § 1024(a)(1)","children":[],"tail":", inserted “by not later than three days after the date on which the President submits the budget materials under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":" for the fiscal year in which such waiver is sought” after “such ship”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s1024/a/2"},"text":"Pub. L. 117–263, § 1024(a)(2)","children":[],"tail":", substituted “the National Defense Authorization Act for such fiscal year is enacted” for “such certification was submitted”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idab3dca30-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idab3dca31-3a6f-11f1-a58a-d8db54b14ab5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tX/s1024/b"},"text":"Pub. L. 117–263, div. A, title X, § 1024(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2764"},"text":"136 Stat. 2764","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dA/tX/s1024/b"},"text":"“The amendments made by subsection (a) [amending this section] do not apply to a battle force ship (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s8678a/e/1"},"text":"section 8678a(e)(1) of title 10","children":[],"tail":", United States Code) that is proposed to be decommissioned or inactivated during fiscal year 2023.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
